<nav class="nav">
  <a href="/orger" class="nav-brand">Orger</a>
  <div style="display:flex; gap: var(--space-md); align-items:center;">
    <a href="/orger/product" style="color: var(--color-text-secondary);">Product</a>
    <a href="/sign-in" class="btn-ghost">Login</a>
  </div>
</nav>

<section style="position:relative; padding: var(--space-4xl) var(--space-md) var(--space-3xl); text-align:center;">
  <div class="dotted-grid" style="position:absolute; inset:0; opacity:0.5; pointer-events:none;"></div>

  <div style="position:relative; z-index:1; max-width: 760px; margin: 0 auto;">
    <div style="display:inline-flex; align-items:center; gap: var(--space-xs); padding: var(--space-xs) var(--space-md); background: var(--color-bg-surface); border:1px solid var(--color-border-subtle); border-radius: var(--radius-full); font-size: 0.875rem; color: var(--color-text-secondary); margin-bottom: var(--space-xl);">
      <span style="width:6px; height:6px; background: var(--color-pop); border-radius:50%;"></span>
      <span class="mono">Pricing</span>
    </div>

    <h1 style="font-size: clamp(3rem, 8vw, 6rem); margin-bottom: var(--space-lg); line-height: 1.1;">
      This is the whole<br>pricing page.
    </h1>

    <p style="font-size: 1.25rem; color: var(--color-text-secondary); margin-bottom: var(--space-2xl); line-height: 1.4; max-width: 560px; margin-left:auto; margin-right:auto;">
      Orger is free. Every chart, every seat, the humans you have and the agents you should build. There is no tier above this one.
    </p>

    <form action="/orger/waitlist" method="post" style="display:flex; gap: var(--space-sm); justify-content:center; max-width: 480px; margin: 0 auto var(--space-md); flex-wrap:wrap;">
      <input type="hidden" name="source" value="pricing">
      <input
        type="email"
        name="email"
        required
        placeholder="you@yourcompany.com"
        style="flex:1; min-width: 240px; padding: var(--space-sm) var(--space-md); background: var(--color-bg-surface); border: 1px solid var(--color-border-medium); border-radius: var(--radius-md); color: var(--color-text-primary); font-family: var(--font-body); font-size: 1rem;"
      >
      <button type="submit" class="btn-primary">Get on the waitlist</button>
    </form>

    <p style="font-size: 0.875rem; color: var(--color-text-tertiary);">
      No card. No tiers. Free when it opens.
    </p>
  </div>
</section>

<section style="max-width: 560px; margin: 0 auto; padding: 0 var(--space-md) var(--space-3xl);">
  <div style="background: var(--color-bg-surface); border: 1px solid var(--color-pop); border-radius: var(--radius-2xl); padding: var(--space-2xl); text-align:left;">
    <div style="display:flex; align-items:baseline; gap: var(--space-sm); margin-bottom: var(--space-xs);">
      <span style="font-size: 3rem; font-weight: 800; color: var(--color-pop);">Free</span>
      <span class="mono" style="color: var(--color-text-tertiary); font-size: 0.875rem;">/ forever</span>
    </div>
    <p style="color: var(--color-text-secondary); margin-bottom: var(--space-xl); line-height: 1.5;">
      One plan. It is the only plan. Org charts have layers. Pricing does not.
    </p>
    <% const included = [
      "Drag and drop canvas",
      "Humans and AI agents on one surface",
      "Grounded agent recommendations from real org data",
      "Skill recommendations for every agent",
      "One-click public share link",
      "No seat limit, ever"
    ]; %>
    <ul style="list-style:none; padding:0; margin:0 0 var(--space-xl);">
      <% included.forEach(function(item){ %>
        <li style="display:flex; align-items:flex-start; gap: var(--space-sm); padding: var(--space-sm) 0; border-bottom: 1px solid var(--color-border-subtle); color: var(--color-text-primary);">
          <span style="color: var(--color-pop); font-weight: 700; flex-shrink:0;">&#10003;</span>
          <span><%= item %></span>
        </li>
      <% }); %>
    </ul>
    <form action="/orger/waitlist" method="post" style="display:flex; gap: var(--space-sm); flex-wrap:wrap;">
      <input type="hidden" name="source" value="pricing">
      <input
        type="email"
        name="email"
        required
        placeholder="you@yourcompany.com"
        style="flex:1; min-width: 200px; padding: var(--space-sm) var(--space-md); background: var(--color-bg-deep); border: 1px solid var(--color-border-medium); border-radius: var(--radius-md); color: var(--color-text-primary); font-family: var(--font-body); font-size: 1rem;"
      >
      <button type="submit" class="btn-primary">Get on the waitlist</button>
    </form>
  </div>
</section>

<section style="max-width: 760px; margin: 0 auto; padding: 0 var(--space-md) var(--space-3xl);">
  <h2 style="font-size: 1.875rem; text-align:center; margin-bottom: var(--space-xl);">Orger vs. the old org chart</h2>
  <% const rows = [
    ["Price", "Free", "$100+ / month"],
    ["Billing", "No seats counted", "Per employee"],
    ["To start", "Just your email", "Book a sales demo"],
    ["What it charts", "Humans and agents", "Humans only"]
  ]; %>
  <div style="background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg); overflow:hidden;">
    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; padding: var(--space-md) var(--space-lg); background: var(--color-bg-elevated); font-size: 0.875rem;">
      <span style="color: var(--color-text-tertiary);" class="mono"></span>
      <span style="color: var(--color-pop); font-weight: 600;">Orger</span>
      <span style="color: var(--color-text-secondary); font-weight: 600;">Traditional tools</span>
    </div>
    <% rows.forEach(function(r){ %>
      <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; padding: var(--space-md) var(--space-lg); border-top: 1px solid var(--color-border-subtle); align-items:center;">
        <span style="color: var(--color-text-tertiary); font-size: 0.875rem;"><%= r[0] %></span>
        <span style="color: var(--color-text-primary); font-weight: 500;"><%= r[1] %></span>
        <span style="color: var(--color-text-secondary);"><%= r[2] %></span>
      </div>
    <% }); %>
  </div>
</section>

<section style="max-width: 680px; margin: 0 auto; padding: 0 var(--space-md) var(--space-3xl);">
  <h2 style="font-size: 1.875rem; text-align:center; margin-bottom: var(--space-xl);">Questions, peeled back</h2>
  <% const faqs = [
    ["Is it really free?", "Yes. No tier, no trial clock, no card on file. Free is the plan, and the plan is free."],
    ["Why is it free?", "Charting your org and the agents it needs should not sit behind a paywall. Get the chart in front of you first. The value shows itself."],
    ["What is the catch?", "There is not one. Orger is a project by OTP (orgtp.com) and the agency Sneeze It. We build it because we use it ourselves to map our own humans and agents."],
    ["What will it cost at launch?", "Free. That is the point. orger.ai is a waitlist today, and free is what it opens as."]
  ]; %>
  <% faqs.forEach(function(f){ %>
    <div style="background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg); padding: var(--space-lg); margin-bottom: var(--space-md);">
      <h3 style="font-size: 1.125rem; margin-bottom: var(--space-sm); color: var(--color-text-primary);"><%= f[0] %></h3>
      <p style="color: var(--color-text-secondary); line-height: 1.5; margin:0;"><%= f[1] %></p>
    </div>
  <% }); %>
</section>

<section style="position:relative; padding: var(--space-3xl) var(--space-md) var(--space-4xl); text-align:center;">
  <div class="dotted-grid" style="position:absolute; inset:0; opacity:0.4; pointer-events:none;"></div>

  <div style="position:relative; z-index:1; max-width: 600px; margin: 0 auto;">
    <h2 style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: var(--space-md);">
      Free when it opens.
    </h2>
    <p style="font-size: 1.125rem; color: var(--color-text-secondary); margin-bottom: var(--space-xl); line-height: 1.4;">
      Drop your email and we will tell you the moment the canvas is live. That is the entire transaction.
    </p>

    <form action="/orger/waitlist" method="post" style="display:flex; gap: var(--space-sm); justify-content:center; max-width: 480px; margin: 0 auto var(--space-md); flex-wrap:wrap;">
      <input type="hidden" name="source" value="pricing">
      <input
        type="email"
        name="email"
        required
        placeholder="you@yourcompany.com"
        style="flex:1; min-width: 240px; padding: var(--space-sm) var(--space-md); background: var(--color-bg-surface); border: 1px solid var(--color-border-medium); border-radius: var(--radius-md); color: var(--color-text-primary); font-family: var(--font-body); font-size: 1rem;"
      >
      <button type="submit" class="btn-primary">Get on the waitlist</button>
    </form>

    <p style="font-size: 0.875rem; color: var(--color-text-tertiary);">
      No spam. Just a heads-up when Orger opens.
    </p>
  </div>

  <div style="position:absolute; bottom: var(--space-xl); right: var(--space-xl); width: 80px; height: 80px; opacity: 0.9;" aria-hidden="true">
    <img src="/orger/public/images/shrub-pixel.png" alt="" onerror="this.style.display='none'" style="width:100%; height:100%; image-rendering: pixelated;">
  </div>
</section>

<footer class="footer">
  Orger is a project by <a href="https://orgtp.com" target="_blank" rel="noopener">OTP</a>. Built with Shrub the ogre. Even ogres need a team.
</footer>
