<nav class="nav">
  <a href="/orger" class="nav-brand">Orger</a>
  <div style="display:flex; gap: var(--space-md); align-items:center;">
    <a href="/orger/product" style="color: var(--color-text-secondary);">Product</a>
    <a href="/sign-in" class="btn-ghost">Login</a>
  </div>
</nav>

<main style="position:relative;">

  <!-- HERO -->
  <section style="min-height: calc(100vh - 80px); display:flex; flex-direction:column; align-items:center; justify-content:center; padding: var(--space-4xl) var(--space-md); text-align:center; position:relative;">
    <div class="dotted-grid" style="position:absolute; inset:0; opacity:0.5; pointer-events:none;"></div>

    <div style="position:relative; z-index:1; max-width: 800px;">
      <div style="display:inline-flex; align-items:center; gap: var(--space-xs); padding: var(--space-xs) var(--space-md); background: var(--color-bg-surface); border:1px solid var(--color-border-subtle); border-radius: var(--radius-full); font-size: 0.875rem; color: var(--color-text-secondary); margin-bottom: var(--space-xl);">
        <span style="width:6px; height:6px; background: var(--color-pop); border-radius:50%;"></span>
        <span class="mono">Org chart software</span>
      </div>

      <h1 style="font-size: clamp(2.75rem, 7vw, 5rem); margin-bottom: var(--space-lg); line-height: 1.1;">
        Org chart software that knows about agents.
      </h1>

      <p style="font-size: 1.25rem; color: var(--color-text-secondary); margin-bottom: var(--space-2xl); line-height: 1.5; max-width: 600px; margin-left:auto; margin-right:auto;">
        Most org chart tools only draw the humans you already have. Orger puts the humans you have and the AI agents you should build on one canvas. Every org has layers. Orger shows yours.
      </p>

      <form action="/orger/waitlist" method="post" style="display:flex; gap: var(--space-sm); justify-content:center; max-width: 480px; margin: 0 auto var(--space-md); flex-wrap:wrap;">
        <input
          type="email"
          name="email"
          required
          placeholder="you@yourcompany.com"
          style="flex:1; min-width: 240px; padding: var(--space-sm) var(--space-md); background: var(--color-bg-surface); border: 1px solid var(--color-border-medium); border-radius: var(--radius-md); color: var(--color-text-primary); font-family: var(--font-body); font-size: 1rem;"
        >
        <input type="hidden" name="source" value="org-chart-software">
        <button type="submit" class="btn-primary">Get on the waitlist</button>
      </form>

      <p style="font-size: 0.875rem; color: var(--color-text-tertiary);">
        Free. Coming soon. Get on the list.
      </p>
    </div>

    <div style="position:absolute; bottom: var(--space-xl); right: var(--space-xl); width: 80px; height: 80px; opacity: 0.9;" aria-hidden="true">
      <img src="/orger/public/images/shrub-pixel.png" alt="" onerror="this.style.display='none'" style="width:100%; height:100%; image-rendering: pixelated;">
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="max-width: 1200px; margin: 0 auto; padding: var(--space-5xl) var(--space-md);">
    <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); text-align:center; margin-bottom: var(--space-2xl);">
      How it works
    </h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-lg);">
      <%
        const steps = [
          { n: '1', t: 'Drag in the humans you have', d: 'Start with your real team. Drop each person onto the canvas and put them where they actually sit. No setup, no import wizard.' },
          { n: '2', t: 'Click an empty seat', d: 'Orger reads your organization and the best-practices library, then gives a grounded recommendation for the agent that belongs there, plus the skills it needs.' },
          { n: '3', t: 'Share the chart in one click', d: 'Generate a public share link and send it to your team, your coach, or your board. They see the layers without an account.' }
        ];
      %>
      <% steps.forEach(function(s) { %>
        <div style="background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg); padding: var(--space-lg);">
          <div style="display:inline-flex; align-items:center; justify-content:center; width:40px; height:40px; background: var(--color-pop); color: var(--color-pop-text); border-radius: var(--radius-md); font-family: var(--font-display); font-weight:800; font-size: 1.25rem; margin-bottom: var(--space-md);">
            <%= s.n %>
          </div>
          <h3 style="font-size: 1.25rem; margin-bottom: var(--space-sm);"><%= s.t %></h3>
          <p style="color: var(--color-text-secondary); line-height: 1.5;"><%= s.d %></p>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- WHAT MAKES IT DIFFERENT -->
  <section style="max-width: 1200px; margin: 0 auto; padding: var(--space-3xl) var(--space-md) var(--space-5xl);">
    <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); text-align:center; margin-bottom: var(--space-md);">
      What makes it different
    </h2>
    <p style="text-align:center; color: var(--color-text-secondary); max-width: 560px; margin: 0 auto var(--space-2xl); line-height: 1.5;">
      Other org chart software stops at the humans. Orger keeps going.
    </p>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-lg);">
      <%
        const features = [
          { t: 'Humans and agents on one surface', d: 'No second tool, no spreadsheet. The people you employ and the agents you should build live on the same canvas, color-coded so you can read the org at a glance.' },
          { t: 'Grounded recommendations, not guesses', d: 'When you click a seat, the recommendation is drawn from real organizational data and a best-practices library. Orger tells you which agent fits and why.' },
          { t: 'One-click public share link', d: 'Publish the chart and share a link. No seat invites, no permissions matrix. The people who need to see the layers just open it.' },
          { t: 'It shows your layers', d: 'Every org has layers. Most charts flatten them into boxes. Orger keeps the structure honest so you can see where the work actually sits.' }
        ];
      %>
      <% features.forEach(function(f) { %>
        <div style="background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg); padding: var(--space-lg);">
          <h3 style="font-size: 1.25rem; margin-bottom: var(--space-sm);"><%= f.t %></h3>
          <p style="color: var(--color-text-secondary); line-height: 1.5;"><%= f.d %></p>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- WHAT IT IS NOT -->
  <section style="max-width: 760px; margin: 0 auto; padding: 0 var(--space-md) var(--space-5xl); text-align:center;">
    <div style="background: var(--color-bg-surface); border: 1px solid var(--color-border-medium); border-radius: var(--radius-xl); padding: var(--space-2xl);">
      <h2 style="font-size: clamp(1.5rem, 3.5vw, 2rem); margin-bottom: var(--space-md);">
        What Orger is not
      </h2>
      <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.0625rem;">
        Orger is not an enterprise HRIS tool. It does not sync with Workday or ADP, and it is not priced per employee. There is no sales demo to get started and no tier to unlock. It is a free canvas for solo founders and small teams, roughly 1 to 20 people, who want to see their org clearly and plan the agents that come next.
      </p>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section style="position:relative; padding: var(--space-5xl) var(--space-md); text-align:center;">
    <div class="dotted-grid" style="position:absolute; inset:0; opacity:0.4; pointer-events:none;"></div>
    <div style="position:relative; z-index:1; max-width: 640px; margin: 0 auto;">
      <h2 style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: var(--space-md); line-height: 1.15;">
        See your layers. Plan your agents.
      </h2>
      <p style="color: var(--color-text-secondary); font-size: 1.125rem; margin-bottom: var(--space-xl); line-height: 1.5;">
        Orger is coming soon. Get on the waitlist and we will send a heads-up the day the canvas opens.
      </p>
      <form action="/orger/waitlist" method="post" style="display:flex; gap: var(--space-sm); justify-content:center; max-width: 480px; margin: 0 auto var(--space-md); flex-wrap:wrap;">
        <input
          type="email"
          name="email"
          required
          placeholder="you@yourcompany.com"
          style="flex:1; min-width: 240px; padding: var(--space-sm) var(--space-md); background: var(--color-bg-surface); border: 1px solid var(--color-border-medium); border-radius: var(--radius-md); color: var(--color-text-primary); font-family: var(--font-body); font-size: 1rem;"
        >
        <input type="hidden" name="source" value="org-chart-software">
        <button type="submit" class="btn-primary">Get on the waitlist</button>
      </form>
      <p style="font-size: 0.875rem; color: var(--color-text-tertiary);">
        Free. No per-seat pricing. No demo gate.
      </p>
    </div>
  </section>

</main>

<footer class="footer">
  Orger is a project by <a href="https://orgtp.com" target="_blank" rel="noopener">OTP</a>. Built with Shrub the ogre. Even ogres need a team.
</footer>
