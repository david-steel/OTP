# Copy this to .env and fill in real values
# cp env.template .env

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/otp

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Clerk Webhook signing secret (from Clerk dashboard -> Webhooks -> Signing Secret, starts with whsec_)
CLERK_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=re_...
# Resend Audience for the pre-signup interest list. Create once via:
#   railway run --service otp-platform npx tsx scripts/resend-audience-setup.ts
# Then paste the printed id here.
OTP_RESEND_AUDIENCE_ID=

# Onboarding scheduler: defaults on in production. Set true to enable locally.
ENABLE_ONBOARDING_SCHEDULER=false

# Realtime sync (R0): org_events outbox. The table is created at boot
# regardless; this flag only gates whether mutations EMIT events. Default OFF --
# nothing is written until flipped, so deploying the instrumentation is inert.
ORG_EVENTS_ENABLED=false
# Days to keep events before the nightly prune (default 30).
ORG_EVENTS_RETENTION_DAYS=30
# Retention prune cron: defaults on in production. Set true to enable locally.
ENABLE_ORG_EVENTS_RETENTION=false

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=otp-oos-files

# App
NODE_ENV=development
PORT=3000
