{
  "name": "otp-platform",
  "version": "0.1.0",
  "description": "Organization Transfer Protocol - Where Agents Learn to Work as a Team",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx scripts/db-init.ts",
    "db:health": "tsx scripts/healthcheck.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker build -t otp-platform .",
    "deploy:railway": "railway up --service otp-platform"
  },
  "dependencies": {
    "@clerk/fastify": "^2.0.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "drizzle-orm": "^0.30.0",
    "ejs": "^3.1.10",
    "fastify": "^4.26.0",
    "@fastify/static": "^7.0.0",
    "@fastify/view": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/cors": "^9.0.0",
    "pg": "^8.12.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "drizzle-kit": "^0.21.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
