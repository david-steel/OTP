{
  "name": "otp-platform",
  "version": "0.2.0",
  "description": "Organization Transport Protocol - Where Agents Learn to Work as a Team",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "css:build": "tailwindcss -i src/styles/input.css -o public/styles.css --minify",
    "css:watch": "tailwindcss -i src/styles/input.css -o public/styles.css --watch",
    "build": "npm run css:build && tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest --passWithNoTests",
    "lint": "eslint --ext .ts src/",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx scripts/db-init.ts",
    "db:health": "tsx scripts/healthcheck.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker build -t otp-platform .",
    "deploy:railway": "railway up --service otp-platform"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@clerk/fastify": "^3.1.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "drizzle-orm": "^0.30.0",
    "ejs": "^3.1.10",
    "fastify": "^5.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.12.0",
    "resend": "^6.10.0",
    "uuid": "^9.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "drizzle-kit": "^0.21.0",
    "eslint": "^8.56.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
