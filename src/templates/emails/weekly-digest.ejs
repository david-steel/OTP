<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>What's New on OTP</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f6f9; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f6f9;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%;">

          <!-- Header -->
          <tr>
            <td style="background-color: #0a0f1e; padding: 32px 40px; border-radius: 12px 12px 0 0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <span style="color: #0095ff; font-size: 24px; font-weight: 700; letter-spacing: -0.5px;">OTP</span>
                    <span style="color: #7cc4fe; font-size: 14px; font-weight: 400; margin-left: 8px;">Product Updates</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top: 12px;">
                    <span style="color: #5a6577; font-size: 13px;"><%= dateRangeStart %> - <%= dateRangeEnd %></span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color: #ffffff; padding: 40px;">

              <!-- Greeting -->
              <h1 style="margin: 0 0 8px 0; font-size: 22px; font-weight: 700; color: #0a0f1e; line-height: 1.3;">
                What's New on OTP
              </h1>
              <p style="margin: 0 0 32px 0; font-size: 15px; color: #5a6577; line-height: 1.6;">
                <%= entries.length %> update<%= entries.length === 1 ? '' : 's' %> shipped this week. Here's what changed.
              </p>

              <!-- Changelog entries -->
              <% for (const entry of entries) { %>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                <tr>
                  <td style="background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; border-left: 3px solid #0095ff;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">

                      <!-- Date + tags row -->
                      <tr>
                        <td style="padding-bottom: 8px;">
                          <span style="font-size: 12px; font-weight: 600; color: #0095ff; background-color: #f0f7ff; padding: 2px 8px; border-radius: 4px;"><%= new Date(entry.date + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                          <% for (const tag of entry.tags) { %>
                          <%
                            let tagColor = '#5a6577';
                            let tagBg = '#f1f5f9';
                            if (tag === 'Core') { tagColor = '#e11d48'; tagBg = '#fff1f2'; }
                            else if (tag === 'Security') { tagColor = '#dc2626'; tagBg = '#fef2f2'; }
                            else if (tag === 'Quality') { tagColor = '#7c3aed'; tagBg = '#f5f3ff'; }
                            else if (tag === 'Major') { tagColor = '#d97706'; tagBg = '#fffbeb'; }
                            else if (tag === 'Improvement') { tagColor = '#059669'; tagBg = '#ecfdf5'; }
                            else if (tag === 'Performance') { tagColor = '#2563eb'; tagBg = '#eff6ff'; }
                            else if (tag === 'SEO') { tagColor = '#7c3aed'; tagBg = '#f5f3ff'; }
                            else if (tag === 'Infrastructure') { tagColor = '#d97706'; tagBg = '#fffbeb'; }
                          %>
                          <span style="font-size: 11px; font-weight: 600; color: <%= tagColor %>; background-color: <%= tagBg %>; padding: 2px 8px; border-radius: 4px; margin-left: 4px;"><%= tag %></span>
                          <% } %>
                        </td>
                      </tr>

                      <!-- Title -->
                      <tr>
                        <td>
                          <p style="margin: 0 0 6px 0; font-size: 15px; font-weight: 700; color: #0a0f1e; line-height: 1.4;">
                            <%= entry.title %>
                          </p>
                        </td>
                      </tr>

                      <!-- Summary -->
                      <tr>
                        <td>
                          <p style="margin: 0; font-size: 14px; color: #5a6577; line-height: 1.6;">
                            <%= entry.summary %>
                          </p>
                        </td>
                      </tr>

                    </table>
                  </td>
                </tr>
              </table>
              <% } %>

              <!-- CTA -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top: 32px;">
                <tr>
                  <td align="center">
                    <a href="https://orgtp.com/whats-new" style="display: inline-block; background-color: #0095ff; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; padding: 14px 32px; border-radius: 8px;">
                      See all updates
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Network Stats Footer -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top: 28px;">
                <tr>
                  <td align="center" style="border-top: 1px solid #e2e8f0; padding-top: 20px;">
                    <p style="margin: 0; font-size: 13px; color: #7c8a9c; line-height: 1.5;">
                      <%= networkStats.totalOrgs %> organization<%= networkStats.totalOrgs === 1 ? '' : 's' %> &middot; <%= networkStats.totalClaims.toLocaleString() %> coordination skills published
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #f4f6f9; padding: 24px 40px; text-align: center; border-radius: 0 0 12px 12px;">
              <p style="margin: 0 0 8px 0; font-size: 12px; color: #7c8a9c; line-height: 1.5;">
                OTP - Organization Transport Protocol<br>
                <a href="https://orgtp.com" style="color: #0076cc; text-decoration: none;">orgtp.com</a>
              </p>
              <p style="margin: 0; font-size: 11px; color: #a0aab8; line-height: 1.5;">
                You're receiving this because you published on OTP.<br>
                <a href="https://orgtp.com/settings" style="color: #7c8a9c; text-decoration: underline;">Unsubscribe</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
