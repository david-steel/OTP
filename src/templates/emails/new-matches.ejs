<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New matches on the OTP network</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f6f9; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f6f9;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%;">

          <!-- Header -->
          <tr>
            <td style="background-color: #0a0f1e; padding: 32px 40px; border-radius: 12px 12px 0 0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <span style="color: #0095ff; font-size: 24px; font-weight: 700; letter-spacing: -0.5px;">OTP</span>
                    <span style="color: #7cc4fe; font-size: 14px; font-weight: 400; margin-left: 8px;">Network Intelligence</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color: #ffffff; padding: 40px;">

              <!-- Greeting -->
              <h1 style="margin: 0 0 8px 0; font-size: 22px; font-weight: 700; color: #0a0f1e; line-height: 1.3;">
                <%= totalMatches %> skill<%= totalMatches === 1 ? '' : 's' %> on the network match your operations
              </h1>
              <p style="margin: 0 0 28px 0; font-size: 15px; color: #5a6577; line-height: 1.6;">
                Your OOS is published. We found claims from other organizations that align with how you work. These are real operational patterns from teams solving similar problems.
              </p>

              <!-- Match groups by org -->
              <% for (const group of matchGroups) { %>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
                <tr>
                  <td style="background-color: #f0f7ff; border: 1px solid #b9dffe; border-radius: 8px; padding: 20px;">

                    <!-- Org header -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 14px;">
                      <tr>
                        <td>
                          <span style="font-size: 13px; font-weight: 600; color: #0076cc; text-transform: uppercase; letter-spacing: 0.5px;">
                            From <%= group.orgName %>
                          </span>
                          <span style="font-size: 12px; color: #7c8a9c; margin-left: 8px;">
                            (<%= group.matches.length %> match<%= group.matches.length === 1 ? '' : 'es' %>)
                          </span>
                        </td>
                      </tr>
                    </table>

                    <!-- Individual claims -->
                    <% for (const match of group.matches) { %>
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: <%= group.matches.indexOf(match) < group.matches.length - 1 ? '12' : '0' %>px;">
                      <tr>
                        <td style="background-color: #ffffff; border-radius: 6px; padding: 16px; border-left: 3px solid #0095ff;">
                          <p style="margin: 0 0 6px 0; font-size: 14px; font-weight: 600; color: #0a0f1e; line-height: 1.4;">
                            <%= match.rule %>
                          </p>
                          <p style="margin: 0; font-size: 12px; color: #7c8a9c;">
                            <span style="display: inline-block; background-color: #e0effe; color: #005899; padding: 2px 8px; border-radius: 4px; font-weight: 500; font-size: 11px;">
                              <%= match.section.replace(/_/g, ' ') %>
                            </span>
                            <% if (match.confidence) { %>
                            <span style="margin-left: 6px; color: #5a6577; font-size: 11px;">
                              <%= match.confidence %> confidence
                            </span>
                            <% } %>
                          </p>
                        </td>
                      </tr>
                    </table>
                    <% } %>

                  </td>
                </tr>
              </table>
              <% } %>

              <!-- CTA -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top: 32px;">
                <tr>
                  <td align="center">
                    <a href="<%= ctaUrl %>" style="display: inline-block; background-color: #0095ff; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; padding: 14px 32px; border-radius: 8px;">
                      See your matches
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin: 24px 0 0 0; font-size: 13px; color: #7c8a9c; text-align: center; line-height: 1.5;">
                Matches are computed from claim similarities across all published OOS files on the network.
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #f4f6f9; padding: 24px 40px; text-align: center; border-radius: 0 0 12px 12px;">
              <p style="margin: 0; font-size: 12px; color: #7c8a9c; line-height: 1.5;">
                OTP - Organization Transport Protocol<br>
                <a href="https://orgtp.com" style="color: #0076cc; text-decoration: none;">orgtp.com</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
