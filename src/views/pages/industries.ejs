<%# /industries -- v7 layout (light, editorial). Directory of coordination
    intelligence grouped by industry. Route provides `industries` array. %>
<style>
  .ind-peek { animation:ind-peek 7s ease-in-out infinite; }
  @keyframes ind-peek { 0%,100%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-9px) rotate(-3deg);} }
  @media (prefers-reduced-motion:reduce){ .ind-peek{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--green);"></span>Directory
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.2rem,4.4vw,3.5rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
          Coordination intelligence, <span class="text-[var(--blue)]">by industry.</span>
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mx-auto md:mx-0 mt-5">
          See how organizations in different industries coordinate their AI agent teams. Browse the publishers, compare the claims, borrow what works.
        </p>
      </div>
      <div class="relative shrink-0" style="width:148px; max-width:40vw;">
        <img src="/public/orgy-clean.png" alt="Orgy, the OTP mascot"
             class="ind-peek block w-full" style="filter:drop-shadow(0 16px 26px rgba(20,22,28,.18));">
      </div>
    </div>
  </div>
</section>

<!-- ================= INDUSTRY GRID ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-7">Browse industries</div>

    <% if (industries.length === 0) { %>
      <div class="card p-10 sm:p-14 text-center">
        <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65]">
          No industries represented yet.
          <a href="/publish" class="text-[var(--blue-deep)] font-semibold link-u">Be the first to publish.</a>
        </p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% industries.forEach(function(ind) { %>
          <a href="/industry/<%= encodeURIComponent(ind.industry) %>" class="card lift p-6 block group">
            <div class="font-display text-[var(--ink)] text-[1.15rem] font-bold leading-snug group-hover:text-[var(--blue-deep)] transition-colors">
              <%= ind.industry %>
            </div>
            <div class="flex items-center gap-2.5 mt-3">
              <span class="font-mono text-[11px] font-medium text-[var(--ink-mute)]"><%= ind.org_count %> publisher<%= ind.org_count > 1 ? 's' : '' %></span>
              <span class="w-1 h-1 rounded-full" style="background:var(--line);"></span>
              <span class="font-mono text-[11px] font-medium text-[var(--ink-mute)]"><%= ind.claim_count %> claims</span>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <div class="eyebrow mb-4">Add your organization</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.07]"
        style="font-size:clamp(1.9rem,4vw,2.9rem); font-weight:700;">
      Put your industry on the map.
    </h2>
    <p class="text-[17px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mx-auto mt-5">
      Publish your Organization Operating System and let other teams in your industry compare their coordination patterns to yours.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/publish" class="btn-primary px-8 py-4 text-[16px]">Publish your OOS &rarr;</a>
    </div>
  </div>
</section>
