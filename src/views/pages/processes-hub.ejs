<% /*
  /processes -- the Processes hub. Phase 1 of the SOP/Process feature.
  Dual-rendered (renderInShell): a signed-in viewer gets the app shell; the
  route redirects signed-out users to /sign-in before we get here.

  SOURCE OF TRUTH: SOPs live embedded per-seat in the OOS/chart graph. This
  page only READS them (aggregated server-side via process-hub.ts) and WRITES
  them back through the EXISTING PATCH /api/v1/team/entity route -- the same
  call /dashboard/team uses. To add/edit/delete a SOP we take the owning
  seat's current sops[] (rebuilt client-side from `entries`), mutate it, and
  PATCH the seat with the full new array. No new persistence.

  Locals:
    entries        [{ seatExternalId, seatName, seatRole, seatType,
                      sop:{title,trigger,steps,outputs,tools,notes}, sopIndex,
                      inheritedBy:[name], canEdit }]
    totalCount     int
    seatFacets     [{ externalId, name, role, type, count }]  (sop-owning seats)
    pickableSeats  [{ externalId, name, role, type, count }]  (editable seats for "+ New")
    templateGroups SOP_TEMPLATE_GROUPS (role-grouped starter SOPs)
    canEdit        bool (viewer can edit at least one seat)

  Security (the repo's recurring EJS + XSS gotchas):
    - All user/AI strings rendered via the escaping interpolation tag, and via
      textContent in the client script -- never innerHTML with user data.
    - jsonForScript() serializes the inline payload so a value containing a
      closing script tag cannot break out of the script context.
    - This header is a JS block comment, NOT an EJS hash comment (a hash
      comment closes on the first percent-gt it sees -- the May 2026 500 class).
*/ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%
  var _entries = Array.isArray(entries) ? entries : [];
  var _seatFacets = Array.isArray(seatFacets) ? seatFacets : [];
  var _pickable = Array.isArray(pickableSeats) ? pickableSeats : [];
  var _groups = Array.isArray(templateGroups) ? templateGroups : [];
  var _total = typeof totalCount === 'number' ? totalCount : _entries.length;
  var _canEdit = !!canEdit;
  var _schedulerEnabled = !!(typeof schedulerEnabled !== 'undefined' && schedulerEnabled);
%>
<style>
  .ph-wrap { max-width: 1080px; }
  .ph-card { background: var(--card, #fff); border: 1.5px solid var(--line, #e5e7eb); border-radius: 14px; transition: border-color .15s ease, box-shadow .15s ease; }
  .ph-card:hover { border-color: var(--blue, #0d7df2); box-shadow: 0 2px 14px rgba(13,125,242,.08); }
  /* align-items:stretch -> every card in a row matches the tallest, so the
     boxes are uniform. The card is flex-col with .ph-actions at margin-top:auto,
     so the action toolbars line up at the bottom across the row. min-width:0
     lets long content shrink/scroll instead of overflowing the column. */
  .ph-grid { display: grid; grid-template-columns: 1fr; gap: 16px; align-items: stretch; }
  @media (min-width: 640px) { .ph-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .ph-grid { grid-template-columns: repeat(3, 1fr); } }
  .ph-card { min-width: 0; }
  .ph-card * { min-width: 0; }
  .ph-chip { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 999px; border: 1px solid transparent; line-height: 1.4; }
  .ph-chip-human { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
  .ph-chip-agent { background: var(--orgy-soft, #fff6da); color: var(--orgy-on-light, #8a6d1a); border-color: var(--orgy-line, #f0dca0); }
  .ph-chip-mute { background: #f3f4f6; color: #6b7280; border-color: #e5e7eb; }
  .ph-chip-tool { background: #f8fafc; color: #475569; border-color: #e2e8f0; font-weight: 600; }
  .ph-chip-sched { background: #eef2ff; color: #4338ca; border-color: #c7d2fe; }
  .ph-btn { display: inline-flex; align-items: center; gap: 6px; font-size: 13.5px; font-weight: 600; padding: 10px 18px; border-radius: 10px; border: 1.5px solid transparent; cursor: pointer; text-decoration: none; white-space: nowrap; transition: background .12s ease, border-color .12s ease, color .12s ease; }
  .ph-btn-primary { background: var(--blue, #0d7df2); color: #fff; }
  .ph-btn-primary:hover { background: var(--blue-deep, #0a63c2); }
  .ph-btn-ghost { background: #fff; color: var(--ink-soft, #374151); border-color: var(--line, #e5e7eb); }
  .ph-btn-ghost:hover { border-color: var(--blue, #0d7df2); color: var(--blue-deep, #0a63c2); background: #f8fbff; }
  .ph-btn-sm { font-size: 12.5px; padding: 6px 11px; border-radius: 8px; gap: 5px; }
  /* Card action toolbar: one tidy wrapping row of equal-height pills. */
  .ph-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 7px; margin-top: auto; padding-top: 13px; border-top: 1px solid var(--line, #eef0f3); }
  .ph-btn-ic { width: 14px; height: 14px; flex: 0 0 auto; pointer-events: none; }
  .ph-btn-danger { color: #be123c; }
  .ph-btn-danger:hover { border-color: #fca5a5; color: #9f1239; background: #fef2f2; }
  .ph-toggle .ph-btn-ic { transition: transform .15s ease; }
  .ph-toggle[aria-expanded="true"] .ph-btn-ic { transform: rotate(180deg); }
  .ph-input { width: 100%; font-size: 14px; padding: 10px 12px; border-radius: 10px; border: 1.5px solid var(--line, #e5e7eb); background: #fff; color: var(--ink, #1f2937); }
  .ph-input:focus { outline: none; border-color: var(--blue, #0d7df2); }
  .ph-detail { display: none; }
  .ph-detail.open { display: block; }
  /* Role/description as a plain muted subtitle -- NOT a pill. Wraps naturally,
     soft-clamped to 3 lines so a long description can't balloon the card. */
  .ph-card-desc { font-size: 13px; line-height: 1.5; color: var(--ink-mute, #6b7280); margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .ph-modal-back { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 60; display: none; align-items: flex-start; justify-content: center; padding: 40px 16px; overflow-y: auto; }
  .ph-modal-back.open { display: flex; }
  .ph-modal { background: #fff; border-radius: 16px; width: 100%; max-width: 640px; box-shadow: 0 20px 60px rgba(15,23,42,.25); }

  /* ---- Shared run/runs/schedule overlay (centered modal) ----
     Running, viewing recent runs, and scheduling ALL happen here so the card
     grid never changes height (the inline-expansion grid distortion is gone).
     Fixed max-width + max-height with an internally scrolling body keeps long
     output / wide code blocks contained -- they never widen the page. */
  .ph-overlay-back { position: fixed; inset: 0; background: rgba(15,23,42,.45); z-index: 65; display: none; align-items: flex-start; justify-content: center; padding: 40px 16px; overflow-y: auto; }
  .ph-overlay-back.open { display: flex; }
  .ph-overlay { background: #fff; border-radius: 16px; width: 100%; max-width: 760px; max-height: 86vh; display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(15,23,42,.25); overflow: hidden; }
  .ph-overlay-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding: 16px 20px; border-bottom: 1px solid var(--line, #e5e7eb); flex: 0 0 auto; }
  .ph-overlay-title { font-size: 1.05rem; font-weight: 700; color: var(--ink, #1f2937); font-family: 'Schibsted Grotesk','Inter',sans-serif; letter-spacing: -.01em; line-height: 1.3; }
  .ph-overlay-spacer { flex: 1 1 auto; }
  .ph-overlay-close { flex: 0 0 auto; color: var(--ink-mute, #9ca3af); background: none; border: 0; cursor: pointer; line-height: 0; padding: 2px; border-radius: 8px; }
  .ph-overlay-close:hover { color: var(--ink, #1f2937); background: #f3f4f6; }
  /* Scrollable body. min-width:0 lets inner pre/code shrink + scroll instead of
     stretching the overlay wider than its max-width. */
  .ph-overlay-body { flex: 1 1 auto; min-width: 0; overflow-y: auto; overflow-x: hidden; padding: 18px 20px; }
  .ph-overlay-foot { flex: 0 0 auto; display: flex; align-items: center; justify-content: flex-end; gap: 8px; padding: 14px 20px; border-top: 1px solid var(--line, #e5e7eb); background: #fafbfc; }
  /* In the overlay the rendered markdown can use the full body width/height. */
  .ph-overlay-body .ph-md { padding: 0; max-height: none; }
  .ph-overlay-body .ph-result { border: 0; }
  .ph-overlay-body .ph-result-head { padding: 0 0 12px; background: none; border-bottom: 1px solid var(--line, #e5e7eb); margin-bottom: 14px; }
  .ph-overlay-body .ph-result-foot { padding: 14px 0 0; margin-top: 14px; background: none; }
  .ph-overlay-body .ph-stream { max-height: 56vh; }
  .ph-label { display: block; font-size: 12px; font-weight: 700; color: var(--ink-soft, #374151); margin-bottom: 4px; }
  .ph-list-row { display: flex; gap: 8px; margin-bottom: 6px; }
  .ph-step-num { flex: 0 0 auto; width: 22px; height: 38px; display:flex; align-items:center; justify-content:center; font-size: 12px; font-weight: 700; color: var(--ink-mute, #9ca3af); }
  .ph-run-meta { font-size: 11.5px; color: var(--ink-mute, #6b7280); margin-top: 6px; display: flex; flex-wrap: wrap; gap: 8px; }
  .ph-run-err { font-size: 12.5px; color: #be123c; font-weight: 600; }
  .ph-spin { display: inline-block; width: 13px; height: 13px; border: 2px solid rgba(255,255,255,.5); border-top-color: #fff; border-radius: 50%; animation: ph-spin .7s linear infinite; vertical-align: middle; }
  @keyframes ph-spin { to { transform: rotate(360deg); } }
  .ph-badge { display:inline-block; font-size:10.5px; font-weight:700; padding:1px 7px; border-radius:999px; }
  .ph-badge-ok { background:#dcfce7; color:#15803d; }
  .ph-badge-fail { background:#fee2e2; color:#b91c1c; }

  /* ---- "Agent at work" run surface ---- */
  .ph-result { border: 1.5px solid var(--line, #e5e7eb); border-radius: 12px; background: var(--card, #fff); overflow: hidden; }
  .ph-result-ok { border-color: #bbf7d0; }
  .ph-result-fail { border-color: #fecaca; }
  .ph-result-head { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; padding: 12px 16px; border-bottom: 1px solid var(--line, #e5e7eb); background: #fafbfc; }
  .ph-result-agent { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 999px; background: var(--orgy-soft, #fff6da); color: var(--orgy-on-light, #8a6d1a); border: 1px solid var(--orgy-line, #f0dca0); }
  .ph-result-sop { font-size: 13.5px; font-weight: 700; color: var(--ink, #1f2937); font-family: 'Schibsted Grotesk','Inter',sans-serif; }
  .ph-result-spacer { flex: 1 1 auto; }
  /* Rendered agent markdown body. innerHTML here is SERVER-SANITIZED (outputHtml
     from renderAgentMarkdown) -- safe by construction; do not feed raw output. */
  .ph-md { font-size: 14px; line-height: 1.65; color: var(--ink, #1f2937); padding: 16px 18px; max-height: 520px; overflow-y: auto; word-break: break-word; }
  .ph-md > :first-child { margin-top: 0; }
  .ph-md > :last-child { margin-bottom: 0; }
  .ph-md h1 { font-size: 1.3rem; font-weight: 800; margin: 18px 0 8px; font-family: 'Schibsted Grotesk','Inter',sans-serif; letter-spacing: -.01em; }
  .ph-md h2 { font-size: 1.12rem; font-weight: 700; margin: 16px 0 7px; font-family: 'Schibsted Grotesk','Inter',sans-serif; }
  .ph-md h3 { font-size: 1rem; font-weight: 700; margin: 14px 0 6px; }
  .ph-md h4 { font-size: .92rem; font-weight: 700; margin: 12px 0 5px; color: var(--ink-soft, #374151); }
  .ph-md p { margin: 8px 0; }
  .ph-md ul, .ph-md ol { margin: 8px 0; padding-left: 22px; }
  .ph-md li { margin: 3px 0; }
  .ph-md blockquote { margin: 10px 0; padding: 4px 14px; border-left: 3px solid var(--blue, #0d7df2); color: var(--ink-soft, #374151); background: #f8fafc; border-radius: 0 6px 6px 0; }
  .ph-md hr { border: 0; border-top: 1px solid var(--line, #e5e7eb); margin: 16px 0; }
  .ph-md a { color: var(--blue-deep, #0a63c2); text-decoration: underline; }
  .ph-md code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; background: #f1f5f9; color: #be185d; padding: 1px 5px; border-radius: 4px; }
  .ph-md pre { background: #0f172a; color: #e2e8f0; border-radius: 8px; padding: 12px 14px; overflow-x: auto; margin: 10px 0; }
  .ph-md pre code { background: none; color: inherit; padding: 0; font-size: 12.5px; }
  .ph-md table { border-collapse: collapse; width: 100%; margin: 10px 0; font-size: 13px; }
  .ph-md th, .ph-md td { border: 1px solid var(--line, #e5e7eb); padding: 6px 10px; text-align: left; }
  .ph-md th { background: #f8fafc; font-weight: 700; }
  /* Footer pill chips */
  .ph-result-foot { display: flex; flex-wrap: wrap; gap: 6px; padding: 10px 16px; border-top: 1px solid var(--line, #e5e7eb); background: #fafbfc; }
  .ph-pill { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 999px; background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; }
  /* Running state */
  .ph-working { display: flex; align-items: center; gap: 12px; padding: 18px; border: 1.5px solid var(--blue, #0d7df2); border-radius: 12px; background: linear-gradient(90deg, rgba(13,125,242,.04), rgba(13,125,242,.01)); }
  .ph-working-dot { flex: 0 0 auto; width: 12px; height: 12px; border-radius: 50%; background: var(--blue, #0d7df2); animation: ph-pulse 1.1s ease-in-out infinite; }
  @keyframes ph-pulse { 0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(13,125,242,.35); } 50% { opacity: .55; transform: scale(.82); box-shadow: 0 0 0 7px rgba(13,125,242,0); } }
  .ph-working-text { font-size: 13.5px; font-weight: 600; color: var(--ink, #1f2937); }
  .ph-working-text b { color: var(--blue-deep, #0a63c2); }
  /* Live transcript: the agent's output as it streams in, before the final
     formatted render swaps in. Plain text, monospace, auto-scrolls to bottom. */
  .ph-stream { margin-top: 10px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; line-height: 1.55; color: var(--ink, #1f2937); white-space: pre-wrap; word-break: break-word; max-height: 360px; overflow-y: auto; padding: 12px 14px; background: #f8fafc; border: 1px solid var(--line, #e5e7eb); border-radius: 10px; }
  .ph-stream-caret { display: inline-block; width: 7px; height: 14px; margin-left: 1px; background: var(--blue, #0d7df2); vertical-align: text-bottom; animation: ph-blink 1s step-end infinite; }
  @keyframes ph-blink { 50% { opacity: 0; } }
  .ph-msg { font-size: 13px; line-height: 1.5; color: var(--ink-soft, #374151); padding: 14px 16px; border: 1.5px solid #fde68a; background: #fffbeb; border-radius: 10px; }
  .ph-msg-fail { border-color: #fecaca; background: #fef2f2; color: #b91c1c; }
  /* Recent-run rows reuse the result card chrome, denser. */
  .ph-run-row { border: 1px solid var(--line, #e5e7eb); border-radius: 10px; margin-bottom: 8px; overflow: hidden; }
  .ph-run-row-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; cursor: pointer; padding: 9px 12px; }
  .ph-run-row-head:hover { background: #f8fafc; }
  .ph-run-row .ph-md { max-height: 360px; border-top: 1px solid var(--line, #e5e7eb); }
</style>

<section class="bg-[var(--white)]">
  <div class="ph-wrap mx-auto px-6 pt-[124px] pb-12 sm:pt-[148px]"<%- (typeof authUserId !== 'undefined' && authUserId) ? ' style="padding-top:56px;"' : '' %>>

    <nav class="text-[12.5px] text-[var(--ink-mute,#6b7280)] mb-4">
      <a href="/dashboard" class="hover:text-[var(--ink,#1f2937)] font-semibold">Dashboard</a>
      <span class="mx-1.5">/</span>
      <span>Processes</span>
    </nav>

    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-bold text-[2rem] tracking-[-0.02em] text-[var(--ink,#1f2937)]" style="font-family:'Schibsted Grotesk','Inter',sans-serif;">Processes <span class="text-[var(--ink-mute,#9ca3af)] font-semibold text-[1.1rem] align-middle" id="ph-count"><%= _total %></span></h1>
        <p class="text-[15px] text-[var(--ink-soft,#374151)] mt-1.5 max-w-[42rem]">The documented processes your team -- humans and agents -- runs on. Author once on a seat; every AI agent under it inherits the SOP at runtime.</p>
        <p class="text-[13px] text-[var(--ink-mute,#6b7280)] mt-2">Need a starting point? <a href="/process-templates" class="text-[var(--blue-deep,#0a63c2)] font-semibold hover:underline">Browse the free Process Library &rarr;</a></p>
      </div>
      <% if (_canEdit) { %>
      <button type="button" id="ph-new" class="ph-btn ph-btn-primary" title="Document a new process">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        New Process
      </button>
      <% } %>
    </div>

    <!-- Search + facets -->
    <div class="mt-6 flex flex-wrap items-center gap-3">
      <div class="relative flex-1 min-w-[220px]">
        <input id="ph-search" class="ph-input pl-9" type="search" placeholder="Search processes by title, seat, trigger, or tool..." autocomplete="off">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ink-mute,#9ca3af)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
      </div>
      <select id="ph-facet" class="ph-input" style="width:auto; min-width:180px;">
        <option value="all">All processes</option>
        <option value="humans">Humans only</option>
        <option value="agents">Agents only</option>
        <option value="has-trigger">Has a trigger</option>
        <% _seatFacets.forEach(function(s){ %>
          <option value="<%= s.externalId %>"><%= s.name %> (<%= s.count %>)</option>
        <% }); %>
      </select>
    </div>

    <!-- Empty state -->
    <div id="ph-empty" class="ph-card mt-8 px-6 py-12 text-center" style="<%= _entries.length === 0 ? '' : 'display:none;' %>border-style:dashed;">
      <div class="mx-auto mb-4 flex items-center justify-center" style="width:48px;height:48px;border-radius:12px;background:var(--orgy-soft,#fff6da);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--orgy-on-light,#8a6d1a)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h6"/></svg>
      </div>
      <h2 class="text-[1.05rem] font-bold text-[var(--ink,#1f2937)]" style="font-family:'Schibsted Grotesk','Inter',sans-serif;">No processes documented yet</h2>
      <p class="text-[14px] text-[var(--ink-soft,#374151)] mt-1.5">Start from a template -- proven SOPs for founders, sales, customer success, and marketing.</p>
      <% if (_canEdit) { %>
      <div class="mt-5">
        <button type="button" id="ph-new-empty" class="ph-btn ph-btn-primary">Start from a template</button>
      </div>
      <% } %>
    </div>

    <!-- No-results-after-filter state -->
    <div id="ph-noresults" class="ph-card mt-8 px-6 py-10 text-center" style="display:none; border-style:dashed;">
      <p class="text-[14px] text-[var(--ink-soft,#374151)]">No processes match your search.</p>
    </div>

    <!-- Cards -->
    <div id="ph-grid" class="ph-grid mt-8"<%= _entries.length === 0 ? ' style="display:none;"' : '' %>>
      <% _entries.forEach(function(e, i){
           var sop = e.sop || {};
           var steps = Array.isArray(sop.steps) ? sop.steps : [];
           var tools = Array.isArray(sop.tools) ? sop.tools : [];
           var outputs = Array.isArray(sop.outputs) ? sop.outputs : [];
           var inheritedBy = Array.isArray(e.inheritedBy) ? e.inheritedBy : [];
      %>
      <div class="ph-card p-5 flex flex-col gap-3" data-idx="<%= i %>"
           data-seat="<%= e.seatExternalId %>" data-type="<%= e.seatType %>" data-sopindex="<%= e.sopIndex %>">
        <div class="flex flex-wrap items-center gap-1.5">
          <span class="ph-chip <%= e.seatType === 'agent' ? 'ph-chip-agent' : 'ph-chip-human' %>"><%= e.seatType === 'agent' ? 'Agent' : 'Human' %><% if (e.seatName) { %> &middot; <%= e.seatName %><% } %></span>
          <% if (steps.length) { %><span class="ph-chip ph-chip-mute"><%= steps.length %> step<%= steps.length === 1 ? '' : 's' %></span><% } %>
          <% if (e.schedule) { %><span class="ph-chip ph-chip-sched"<% if (e.schedule.nextRunAt) { %> title="Next run: <%= e.schedule.nextRunAt %>"<% } %>>&#9200; <%= e.schedule.label %></span><% } %>
        </div>
        <% if (e.seatRole) { %>
          <p class="ph-card-desc"><%= e.seatRole %></p>
        <% } %>
        <div class="font-bold text-[15.5px] leading-snug text-[var(--ink,#1f2937)]" style="font-family:'Schibsted Grotesk','Inter',sans-serif;"><%= sop.title || '(untitled process)' %></div>
        <% if (sop.trigger) { %>
          <div class="text-[12.5px] text-[var(--ink-mute,#6b7280)]"><span class="font-semibold">Trigger:</span> <%= sop.trigger %></div>
        <% } %>
        <% if (tools.length) { %>
          <div class="flex flex-wrap gap-1.5">
            <% tools.forEach(function(t){ %><span class="ph-chip ph-chip-tool"><%= t %></span><% }); %>
          </div>
        <% } %>
        <% if (inheritedBy.length) { %>
          <div class="text-[11.5px] text-[var(--ink-mute,#9ca3af)]">Inherited by <%= inheritedBy.join(', ') %></div>
        <% } %>

        <!-- Expandable detail -->
        <div class="ph-detail border-t pt-3 mt-1" style="border-color:var(--line,#e5e7eb);">
          <% if (steps.length) { %>
            <div class="ph-label">Steps</div>
            <ol class="list-decimal pl-5 text-[13px] text-[var(--ink-soft,#374151)] space-y-1 mb-3">
              <% steps.forEach(function(s){ %><li><%= s %></li><% }); %>
            </ol>
          <% } %>
          <% if (outputs.length) { %>
            <div class="ph-label">Outputs</div>
            <ul class="list-disc pl-5 text-[13px] text-[var(--ink-soft,#374151)] space-y-1 mb-3">
              <% outputs.forEach(function(o){ %><li><%= o %></li><% }); %>
            </ul>
          <% } %>
          <% if (sop.notes) { %>
            <div class="ph-label">Notes</div>
            <p class="text-[13px] text-[var(--ink-soft,#374151)] mb-1"><%= sop.notes %></p>
          <% } %>
        </div>

        <div class="ph-actions">
          <% if (e.canEdit && e.seatType === 'agent') { %>
          <button type="button" class="ph-run ph-btn ph-btn-primary ph-btn-sm" title="Run this process now">
            <svg class="ph-btn-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>Run
          </button>
          <% } %>
          <button type="button" class="ph-toggle ph-btn ph-btn-ghost ph-btn-sm" aria-expanded="false" title="Show steps, outputs, and notes">
            <svg class="ph-btn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg><span class="ph-toggle-label">Details</span>
          </button>
          <% if (e.canEdit) { %>
            <% if (e.seatType === 'agent') { %>
            <button type="button" class="ph-runs ph-btn ph-btn-ghost ph-btn-sm" title="Recent runs">
              <svg class="ph-btn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 1.8"/></svg>Runs
            </button>
            <button type="button" class="ph-schedule ph-btn ph-btn-ghost ph-btn-sm" title="Schedule this process to run automatically">
              <svg class="ph-btn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/></svg>Schedule
            </button>
            <% } %>
            <button type="button" class="ph-edit ph-btn ph-btn-ghost ph-btn-sm" title="Edit this process">
              <svg class="ph-btn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>Edit
            </button>
            <button type="button" class="ph-delete ph-btn ph-btn-ghost ph-btn-sm ph-btn-danger" title="Delete this process">
              <svg class="ph-btn-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h16M9 7V4.5h6V7M6 7l1 13h10l1-13"/></svg>Delete
            </button>
          <% } %>
        </div>

      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Shared run / recent-runs / schedule overlay. ONE instance, reused for every
     card. Run output, recent runs, and the schedule form all render into
     #ph-overlay-body so the card grid never grows (kills the grid distortion).
     Empty + hidden until a Run/Runs/Schedule click populates it. -->
<div id="ph-overlay-back" class="ph-overlay-back" role="dialog" aria-modal="true" aria-labelledby="ph-overlay-title">
  <div class="ph-overlay">
    <div class="ph-overlay-head">
      <span id="ph-overlay-chip" class="ph-result-agent" style="display:none;"></span>
      <span id="ph-overlay-title" class="ph-overlay-title"></span>
      <div class="ph-overlay-spacer"></div>
      <button type="button" id="ph-overlay-close" class="ph-overlay-close" aria-label="Close">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="ph-overlay-body" class="ph-overlay-body"></div>
    <div id="ph-overlay-foot" class="ph-overlay-foot" style="display:none;"></div>
  </div>
</div>

<% if (_canEdit) { %>
<!-- New / Edit modal -->
<div id="ph-modal-back" class="ph-modal-back" role="dialog" aria-modal="true" aria-labelledby="ph-modal-title">
  <div class="ph-modal">
    <div class="flex items-center justify-between px-6 pt-5 pb-3 border-b" style="border-color:var(--line,#e5e7eb);">
      <h2 id="ph-modal-title" class="text-[1.15rem] font-bold text-[var(--ink,#1f2937)]" style="font-family:'Schibsted Grotesk','Inter',sans-serif;">New Process</h2>
      <button type="button" id="ph-modal-close" class="text-[var(--ink-mute,#9ca3af)] hover:text-[var(--ink,#1f2937)]" aria-label="Close">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="px-6 py-5 space-y-4">
      <!-- Template picker (shown only when creating) -->
      <div id="ph-tpl-wrap">
        <label class="ph-label" for="ph-tpl">Insert from template (optional)</label>
        <select id="ph-tpl" class="ph-input">
          <option value="">Start from blank</option>
          <% _groups.forEach(function(g, gi){ %>
            <optgroup label="<%= g.role %>">
              <% (g.templates || []).forEach(function(t, ti){ %>
                <option value="<%= gi %>:<%= ti %>"><%= t.title %></option>
              <% }); %>
            </optgroup>
          <% }); %>
        </select>
      </div>

      <div>
        <label class="ph-label" for="ph-seat">Owning seat</label>
        <select id="ph-seat" class="ph-input">
          <% _pickable.forEach(function(s){ %>
            <option value="<%= s.externalId %>" data-type="<%= s.type %>"><%= s.name %><% if (s.role) { %> &middot; <%= s.role %><% } %> (<%= s.type %>)</option>
          <% }); %>
        </select>
      </div>

      <div>
        <label class="ph-label" for="ph-title">Title</label>
        <input id="ph-title" class="ph-input" type="text" maxlength="200" placeholder="e.g. Daily inbox triage">
      </div>

      <div>
        <label class="ph-label" for="ph-trigger">Trigger (optional)</label>
        <input id="ph-trigger" class="ph-input" type="text" maxlength="500" placeholder="e.g. Every weekday at 8 AM">
      </div>

      <div>
        <label class="ph-label">Steps</label>
        <div id="ph-steps"></div>
        <button type="button" id="ph-add-step" class="ph-btn ph-btn-ghost ph-btn-sm mt-1">+ Add step</button>
      </div>

      <div>
        <label class="ph-label">Outputs (optional)</label>
        <div id="ph-outputs"></div>
        <button type="button" id="ph-add-output" class="ph-btn ph-btn-ghost ph-btn-sm mt-1">+ Add output</button>
      </div>

      <div>
        <label class="ph-label" for="ph-tools">Tools (optional, comma-separated)</label>
        <input id="ph-tools" class="ph-input" type="text" placeholder="e.g. Gmail, Slack, CRM">
      </div>

      <div>
        <label class="ph-label" for="ph-notes">Notes (optional)</label>
        <textarea id="ph-notes" class="ph-input" rows="2" maxlength="2000"></textarea>
      </div>

      <div id="ph-error" class="text-[13px] text-[#be123c]" style="display:none;"></div>
    </div>

    <div class="flex items-center justify-end gap-2 px-6 py-4 border-t" style="border-color:var(--line,#e5e7eb);">
      <button type="button" id="ph-cancel" class="ph-btn ph-btn-ghost">Cancel</button>
      <button type="button" id="ph-save" class="ph-btn ph-btn-primary">Save process</button>
    </div>
  </div>
</div>
<% } %>

<script>
(function(){
  var ENTRIES = <%- jsonForScript(entries || []) %>;
  var TEMPLATE_GROUPS = <%- jsonForScript(templateGroups || []) %>;
  // Process Library deep-link payload (/processes?insert=<slug>). null unless a
  // valid library SOP slug was passed. jsonForScript-escaped like the rest.
  var INSERT_SOP = <%- jsonForScript(typeof insertSop !== 'undefined' ? insertSop : null) %>;
  var CAN_EDIT = <%- _canEdit ? 'true' : 'false' %>;
  // When false, schedules can be created but stay DORMANT (the poller is off);
  // the schedule UI shows a "preview" note so users aren't confused.
  var SCHEDULER_ENABLED = <%- _schedulerEnabled ? 'true' : 'false' %>;

  // ---- Search + facet filtering (client mirror of process-hub.filterSops) ----
  var searchEl = document.getElementById('ph-search');
  var facetEl = document.getElementById('ph-facet');
  var grid = document.getElementById('ph-grid');
  var noResults = document.getElementById('ph-noresults');
  var emptyState = document.getElementById('ph-empty');
  var countEl = document.getElementById('ph-count');

  function entryMatches(e, q, facet){
    var sop = e.sop || {};
    if (facet && facet !== 'all') {
      if (facet === 'humans' && e.seatType !== 'human') return false;
      else if (facet === 'agents' && e.seatType !== 'agent') return false;
      else if (facet === 'has-trigger' && !(sop.trigger && String(sop.trigger).trim())) return false;
      else if (facet !== 'humans' && facet !== 'agents' && facet !== 'has-trigger' && e.seatExternalId !== facet) return false;
    }
    var needle = (q || '').trim().toLowerCase();
    if (!needle) return true;
    var hay = [sop.title || '', e.seatName || '', e.seatRole || '', sop.trigger || ''].concat(Array.isArray(sop.tools) ? sop.tools : []);
    return hay.some(function(h){ return String(h).toLowerCase().indexOf(needle) !== -1; });
  }

  function applyFilter(){
    if (!grid) return;
    var q = searchEl ? searchEl.value : '';
    var facet = facetEl ? facetEl.value : 'all';
    var cards = grid.querySelectorAll('[data-idx]');
    var shown = 0;
    cards.forEach(function(card){
      var e = ENTRIES[Number(card.getAttribute('data-idx'))];
      var ok = e && entryMatches(e, q, facet);
      card.style.display = ok ? '' : 'none';
      if (ok) shown++;
    });
    if (countEl) countEl.textContent = String(shown);
    if (ENTRIES.length === 0) return; // empty state already shown server-side
    if (noResults) noResults.style.display = shown === 0 ? '' : 'none';
    grid.style.display = shown === 0 ? 'none' : '';
  }
  if (searchEl) searchEl.addEventListener('input', applyFilter);
  if (facetEl) facetEl.addEventListener('change', applyFilter);

  // ---- Expand / collapse card detail ----
  if (grid) grid.addEventListener('click', function(ev){
    var t = ev.target;
    var toggleBtn = t.closest && t.closest('.ph-toggle');
    if (toggleBtn) {
      var card = toggleBtn.closest('[data-idx]');
      var detail = card && card.querySelector('.ph-detail');
      if (detail) {
        var open = detail.classList.toggle('open');
        toggleBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        var lbl = toggleBtn.querySelector('.ph-toggle-label');
        if (lbl) lbl.textContent = open ? 'Hide' : 'Details';
      }
    }
  });

  if (!CAN_EDIT) return;

  // ---- Write path: PATCH /api/v1/team/entity with the seat's full sops[] ----
  function api(method, path, body){
    var opts = { method: method, headers: {}, credentials: 'same-origin' };
    if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
    return fetch('/api/v1' + path, opts).then(function(r){
      if (!r.ok) {
        return r.text().then(function(text){
          var j = {}; try { j = text ? JSON.parse(text) : {}; } catch(e){}
          var inner = j.error || {};
          throw { status: r.status, code: inner.code || 'API_ERROR', message: inner.message || ('HTTP ' + r.status) };
        });
      }
      return r.status === 204 ? {} : r.json();
    });
  }
  function fmtErr(e){ return e ? ((e.code ? e.code + ': ' : '') + (e.message || 'error')) : 'Unknown error'; }

  // Rebuild a seat's current sops[] array from the entries we rendered.
  // entries carry sopIndex so we can place them back in order, then mutate.
  function seatSops(seatExternalId){
    var rows = ENTRIES
      .filter(function(e){ return e.seatExternalId === seatExternalId; })
      .sort(function(a, b){ return (a.sopIndex || 0) - (b.sopIndex || 0); });
    return rows.map(function(e){ return e.sop; });
  }
  function seatType(seatExternalId){
    var hit = ENTRIES.find(function(e){ return e.seatExternalId === seatExternalId; });
    if (hit) return hit.seatType;
    // New seat with no SOPs yet: read from the picker option.
    var opt = document.querySelector('#ph-seat option[value="' + cssEsc(seatExternalId) + '"]');
    return opt ? opt.getAttribute('data-type') : 'agent';
  }
  function cssEsc(s){ return String(s).replace(/["\\]/g, '\\$&'); }

  function patchSeatSops(seatExternalId, type, sops){
    return api('PATCH', '/team/entity', { type: type, externalId: seatExternalId, patch: { sops: sops } });
  }

  // ---- Modal ----
  var back = document.getElementById('ph-modal-back');
  var modalTitle = document.getElementById('ph-modal-title');
  var tplWrap = document.getElementById('ph-tpl-wrap');
  var tplSel = document.getElementById('ph-tpl');
  var seatSel = document.getElementById('ph-seat');
  var titleEl = document.getElementById('ph-title');
  var triggerEl = document.getElementById('ph-trigger');
  var stepsWrap = document.getElementById('ph-steps');
  var outputsWrap = document.getElementById('ph-outputs');
  var toolsEl = document.getElementById('ph-tools');
  var notesEl = document.getElementById('ph-notes');
  var errEl = document.getElementById('ph-error');
  var saveBtn = document.getElementById('ph-save');

  var editing = null; // { seatExternalId, sopIndex } when editing, null when creating

  function lineRow(wrap, value, placeholder){
    var row = document.createElement('div');
    row.className = 'ph-list-row';
    var input = document.createElement('input');
    input.className = 'ph-input';
    input.type = 'text';
    input.value = value || '';
    input.placeholder = placeholder || '';
    var rm = document.createElement('button');
    rm.type = 'button';
    rm.className = 'ph-btn ph-btn-ghost ph-btn-sm';
    rm.textContent = '✕';
    rm.addEventListener('click', function(){ row.remove(); });
    row.appendChild(input);
    row.appendChild(rm);
    wrap.appendChild(row);
    return input;
  }
  function readLines(wrap){
    return Array.prototype.slice.call(wrap.querySelectorAll('input'))
      .map(function(i){ return i.value.trim(); })
      .filter(Boolean);
  }
  function setLines(wrap, arr, placeholder){
    wrap.innerHTML = '';
    (arr && arr.length ? arr : ['']).forEach(function(v){ lineRow(wrap, v, placeholder); });
  }

  function openModal(mode, seat, sop, sopIndex){
    editing = mode === 'edit' ? { seatExternalId: seat, sopIndex: sopIndex } : null;
    modalTitle.textContent = mode === 'edit' ? 'Edit Process' : 'New Process';
    if (errEl) { errEl.style.display = 'none'; errEl.textContent = ''; }
    if (tplWrap) tplWrap.style.display = mode === 'edit' ? 'none' : '';
    if (tplSel) tplSel.value = '';
    sop = sop || {};
    titleEl.value = sop.title || '';
    triggerEl.value = sop.trigger || '';
    setLines(stepsWrap, sop.steps || [''], 'Describe the step');
    setLines(outputsWrap, sop.outputs || [], 'Describe the output');
    toolsEl.value = Array.isArray(sop.tools) ? sop.tools.join(', ') : '';
    notesEl.value = sop.notes || '';
    if (mode === 'edit' && seat) {
      // Lock the seat select to the owning seat (a SOP can't change owners here).
      seatSel.value = seat;
      seatSel.disabled = true;
    } else {
      seatSel.disabled = false;
    }
    back.classList.add('open');
  }
  function closeModal(){ back.classList.remove('open'); editing = null; }

  function applyTemplate(){
    if (!tplSel || !tplSel.value) return;
    var parts = tplSel.value.split(':');
    var g = TEMPLATE_GROUPS[Number(parts[0])];
    var t = g && g.templates ? g.templates[Number(parts[1])] : null;
    if (!t) return;
    titleEl.value = t.title || '';
    triggerEl.value = t.trigger || '';
    setLines(stepsWrap, t.steps || [''], 'Describe the step');
    setLines(outputsWrap, t.outputs || [], 'Describe the output');
    toolsEl.value = Array.isArray(t.tools) ? t.tools.join(', ') : '';
    notesEl.value = t.notes || '';
  }
  if (tplSel) tplSel.addEventListener('change', applyTemplate);

  document.getElementById('ph-add-step').addEventListener('click', function(){ lineRow(stepsWrap, '', 'Describe the step'); });
  document.getElementById('ph-add-output').addEventListener('click', function(){ lineRow(outputsWrap, '', 'Describe the output'); });

  ['ph-new', 'ph-new-empty'].forEach(function(id){
    var b = document.getElementById(id);
    if (b) b.addEventListener('click', function(){ openModal('new'); });
  });
  document.getElementById('ph-modal-close').addEventListener('click', closeModal);
  document.getElementById('ph-cancel').addEventListener('click', closeModal);
  back.addEventListener('click', function(ev){ if (ev.target === back) closeModal(); });

  function buildSop(){
    var sop = { title: titleEl.value.trim() };
    if (triggerEl.value.trim()) sop.trigger = triggerEl.value.trim();
    var steps = readLines(stepsWrap); if (steps.length) sop.steps = steps;
    var outputs = readLines(outputsWrap); if (outputs.length) sop.outputs = outputs;
    var tools = toolsEl.value.split(',').map(function(s){ return s.trim(); }).filter(Boolean);
    if (tools.length) sop.tools = tools;
    if (notesEl.value.trim()) sop.notes = notesEl.value.trim();
    return sop;
  }

  saveBtn.addEventListener('click', function(){
    var sop = buildSop();
    if (!sop.title) {
      errEl.textContent = 'Title is required.'; errEl.style.display = ''; return;
    }
    var seat = editing ? editing.seatExternalId : seatSel.value;
    if (!seat) { errEl.textContent = 'Pick an owning seat.'; errEl.style.display = ''; return; }
    var type = seatType(seat);
    var sops = seatSops(seat);
    if (editing) {
      sops = sops.slice();
      sops[editing.sopIndex] = sop;
    } else {
      sops = sops.concat([sop]);
    }
    saveBtn.disabled = true;
    patchSeatSops(seat, type, sops)
      .then(function(){ window.location.reload(); })
      .catch(function(e){ saveBtn.disabled = false; errEl.textContent = 'Save failed: ' + fmtErr(e); errEl.style.display = ''; });
  });

  // ---- Run a SOP / view recent runs (agent seats only) ----
  function el(tag, cls, text){
    var n = document.createElement(tag);
    if (cls) n.className = cls;
    if (text != null) n.textContent = String(text);
    return n;
  }
  function fmtWhen(iso){
    if (!iso) return '';
    var d = new Date(iso);
    return isNaN(d.getTime()) ? String(iso) : d.toLocaleString();
  }
  function fmtCost(cents){
    if (cents == null) return null;
    var c = Number(cents);
    if (!isFinite(c)) return null;
    return '$' + (c / 100).toFixed(c % 100 === 0 ? 2 : 2);
  }
  // Friendly copy for the known terminal/error states. Returns null for an
  // ordinary failure (we then show the raw error text).
  function friendlyState(code){
    if (!code) return null;
    if (code === 'INSUFFICIENT_BALANCE') return 'Insufficient wallet balance. Add credits to run agents.';
    if (code === 'RATE_LIMITED') return 'Too many runs. Give it a minute, then try again.';
    if (code === 'DEMO_RUN_LIMIT') return 'Demo run limit reached for today. Sign up to run more.';
    if (code === 'NOT_CONFIGURED' || /ANTHROPIC_API_KEY/.test(code)) return 'Agent runtime is not configured yet (no API key on the server).';
    return null;
  }

  // ---- Shared overlay controller ----------------------------------------
  // One overlay reused for Run / Runs / Schedule. All three render into the
  // body so the card grid never changes height. Header shows the agent chip +
  // a title; the body scrolls; an optional footer holds actions (Run again /
  // Close). API contracts are unchanged -- only WHERE results render moved.
  var ovBack = document.getElementById('ph-overlay-back');
  var ovBody = document.getElementById('ph-overlay-body');
  var ovTitle = document.getElementById('ph-overlay-title');
  var ovChip = document.getElementById('ph-overlay-chip');
  var ovFoot = document.getElementById('ph-overlay-foot');
  var ovCloseBtn = document.getElementById('ph-overlay-close');

  function overlaySetHeader(title, agentName){
    if (ovTitle) ovTitle.textContent = title || '';
    if (ovChip){
      if (agentName){ ovChip.textContent = agentName; ovChip.style.display = ''; }
      else { ovChip.textContent = ''; ovChip.style.display = 'none'; }
    }
  }
  function overlayClearFoot(){
    if (!ovFoot) return;
    ovFoot.innerHTML = '';
    ovFoot.style.display = 'none';
  }
  function overlaySetFoot(buttons){
    if (!ovFoot) return;
    ovFoot.innerHTML = '';
    if (!buttons || !buttons.length){ ovFoot.style.display = 'none'; return; }
    buttons.forEach(function(b){ ovFoot.appendChild(b); });
    ovFoot.style.display = '';
  }
  // Returns the body element to render into (cleared).
  function openOverlay(title, agentName){
    overlaySetHeader(title, agentName);
    overlayClearFoot();
    if (ovBody){ ovBody.innerHTML = ''; ovBody.scrollTop = 0; }
    if (ovBack) ovBack.classList.add('open');
    return ovBody;
  }
  function closeOverlay(){ if (ovBack) ovBack.classList.remove('open'); }
  if (ovCloseBtn) ovCloseBtn.addEventListener('click', closeOverlay);
  if (ovBack) ovBack.addEventListener('click', function(ev){ if (ev.target === ovBack) closeOverlay(); });
  document.addEventListener('keydown', function(ev){
    if (ev.key === 'Escape' && ovBack && ovBack.classList.contains('open')) closeOverlay();
  });
  function ovBtn(cls, label){ var b = el('button', cls, label); b.type = 'button'; return b; }

  // Footer pill chips: model, tokens, cost, duration. Small + roomy, not a
  // cramped one-liner.
  function footChips(run){
    var foot = el('div', 'ph-result-foot');
    var any = false;
    if (run.model) { foot.appendChild(el('span', 'ph-pill', run.model)); any = true; }
    var ti = (run.tokensInput != null) ? run.tokensInput : run.tokens_input;
    var to = (run.tokensOutput != null) ? run.tokensOutput : run.tokens_output;
    if (ti != null || to != null) { foot.appendChild(el('span', 'ph-pill', (ti || 0) + ' in / ' + (to || 0) + ' out tokens')); any = true; }
    var cost = fmtCost(run.costCents != null ? run.costCents : run.cost_cents);
    if (cost) { foot.appendChild(el('span', 'ph-pill', cost)); any = true; }
    var dur = fmtDuration(run);
    if (dur) { foot.appendChild(el('span', 'ph-pill', dur)); any = true; }
    return any ? foot : null;
  }
  function fmtDuration(run){
    var start = run.startedAt || run.started_at;
    var end = run.completedAt || run.completed_at;
    if (!start || !end) return null;
    var ms = new Date(end).getTime() - new Date(start).getTime();
    if (!isFinite(ms) || ms < 0) return null;
    if (ms < 1000) return ms + ' ms';
    return (ms / 1000).toFixed(1) + 's';
  }

  // Render the markdown body. outputHtml is SERVER-SANITIZED (renderAgentMarkdown
  // strict allowlist), so innerHTML here is safe by construction. We never feed
  // the raw `output` string to innerHTML.
  function mdBody(run){
    var body = el('div', 'ph-md');
    var html = (typeof run.outputHtml === 'string') ? run.outputHtml : '';
    if (html) { body.innerHTML = html; }
    else { body.appendChild(el('p', null, run.output ? run.output : '(no output)')); }
    return body;
  }

  // A full "agent at work" result card: agent chip + SOP title + status badge,
  // rendered markdown body, footer chips.
  function resultCard(e, run){
    var status = run.status || (run.error ? 'failed' : 'succeeded');
    var ok = status === 'succeeded';
    var card = el('div', 'ph-result ' + (ok ? 'ph-result-ok' : 'ph-result-fail'));

    var head = el('div', 'ph-result-head');
    head.appendChild(el('span', 'ph-result-agent', e.seatName || 'Agent'));
    var sopTitle = run.sopTitle || run.sop_title || (e.sop && e.sop.title) || 'Process run';
    head.appendChild(el('span', 'ph-result-sop', sopTitle));
    head.appendChild(el('div', 'ph-result-spacer'));
    head.appendChild(el('span', 'ph-badge ' + (ok ? 'ph-badge-ok' : 'ph-badge-fail'), ok ? 'Succeeded' : 'Failed'));
    card.appendChild(head);

    if (ok) {
      card.appendChild(mdBody(run));
      var foot = footChips(run);
      if (foot) card.appendChild(foot);
    } else {
      var code = run.error || 'Run failed';
      var msg = friendlyState(code) || code;
      card.appendChild(el('div', 'ph-msg ph-msg-fail', msg));
    }
    return card;
  }

  // The pulsing "● {Agent} is working through {SOP}…" running state.
  function workingCard(e){
    var sop = e.sop || {};
    var wrap = el('div', 'ph-working');
    wrap.appendChild(el('div', 'ph-working-dot'));
    var text = el('div', 'ph-working-text');
    var name = document.createElement('b');
    name.textContent = e.seatName || 'Agent';
    text.appendChild(name);
    text.appendChild(document.createTextNode(' is working through '));
    var sopName = document.createElement('b');
    sopName.textContent = sop.title || 'this process';
    text.appendChild(sopName);
    text.appendChild(document.createTextNode('…'));
    wrap.appendChild(text);
    return wrap;
  }

  // Re-enable the card's Run button + reset its label (it stays in the grid
  // behind the overlay). Stored so the stream/JSON paths can call it.
  function makeBtnReset(btn, label){
    return function(){ if (btn){ btn.disabled = false; btn.innerHTML = label; } };
  }
  // Footer for a finished run: "Run again" + "Close".
  function setRunFinishedFoot(e, btn, label){
    var again = ovBtn('ph-btn ph-btn-ghost ph-btn-sm', 'Run again');
    again.addEventListener('click', function(){ runSop(e, btn, label); });
    var close = ovBtn('ph-btn ph-btn-primary ph-btn-sm', 'Close');
    close.addEventListener('click', closeOverlay);
    overlaySetFoot([again, close]);
  }

  // Stream a run over SSE. We POST with Accept: text/event-stream and read the
  // response body with a reader + TextDecoder, parsing `data: {...}\n\n` frames.
  // (EventSource can't POST, so we hand-roll the SSE consumer.) Each {t} delta
  // is appended to a live transcript so the user watches the agent type; the
  // final {done,...} event swaps in the nicely formatted outputHtml + chips.
  // Renders into the shared overlay body (`panel`). Falls back to the JSON path
  // if the browser lacks fetch-stream support. API request shape unchanged.
  function streamRun(e, btn, label, panel){
    var sop = e.sop || {};
    var body = sop.id ? { sopId: sop.id } : { sopTitle: sop.title };

    // Live transcript surface, appended under the "working" card.
    var stream = el('pre', 'ph-stream');
    var caret = el('span', 'ph-stream-caret');
    stream.appendChild(caret);
    panel.appendChild(stream);
    function appendDelta(t){
      caret.remove();
      stream.appendChild(document.createTextNode(t));
      stream.appendChild(caret);
      stream.scrollTop = stream.scrollHeight;
    }
    var done = makeBtnReset(btn, label);
    function showFail(code, message){
      panel.innerHTML = '';
      var msg = friendlyState(code) || message || 'Run failed';
      panel.appendChild(el('div', 'ph-msg ph-msg-fail', msg));
      setRunFinishedFoot(e, btn, label);
    }
    function showFinal(evt){
      panel.innerHTML = '';
      // Build a run object resultCard understands from the final event.
      panel.appendChild(resultCard(e, {
        status: evt.status, error: evt.error, outputHtml: evt.outputHtml,
        sopTitle: evt.sopTitle, model: evt.model,
        tokensInput: evt.tokensInput, tokensOutput: evt.tokensOutput,
        costCents: evt.costCents, startedAt: evt.startedAt, completedAt: evt.completedAt,
      }));
      setRunFinishedFoot(e, btn, label);
    }

    return fetch('/api/v1/agents/' + encodeURIComponent(e.seatExternalId) + '/run', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'text/event-stream' },
      credentials: 'same-origin',
      body: JSON.stringify(body)
    }).then(function(r){
      // Pre-hijack failures come back as JSON errors (clean, never mid-stream).
      var ct = (r.headers.get('content-type') || '').toLowerCase();
      if (!r.ok || ct.indexOf('text/event-stream') === -1) {
        return r.text().then(function(text){
          var j = {}; try { j = text ? JSON.parse(text) : {}; } catch(e2){}
          var inner = j.error || {};
          showFail(inner.code || 'API_ERROR', inner.message || ('HTTP ' + r.status));
        });
      }
      if (!r.body || !r.body.getReader) {
        // No stream-reading support: degrade to the JSON run path.
        return runSopJson(e, btn, label, panel, body);
      }
      var reader = r.body.getReader();
      var decoder = new TextDecoder();
      var buf = '';
      function handleFrame(payload){
        var data;
        try { data = JSON.parse(payload); } catch(e2){ return; }
        if (data.t != null) { appendDelta(data.t); return; }
        if (data.error) { showFail(null, data.error); return; }
        if (data.done) { showFinal(data); return; }
      }
      function pump(){
        return reader.read().then(function(res){
          if (res.done) {
            // Flush any trailing frame.
            buf += decoder.decode();
            var rest = buf.split('\n\n');
            rest.forEach(function(chunk){
              var line = chunk.replace(/^data: ?/, '').trim();
              if (line) handleFrame(line);
            });
            return;
          }
          buf += decoder.decode(res.value, { stream: true });
          var parts = buf.split('\n\n');
          buf = parts.pop(); // keep the incomplete tail
          parts.forEach(function(chunk){
            var line = chunk.replace(/^data: ?/, '').trim();
            if (line) handleFrame(line);
          });
          return pump();
        });
      }
      return pump();
    }).catch(function(err){
      showFail(err && err.code ? err.code : null, (err && err.message) ? err.message : 'Run failed');
    }).then(done);
  }

  // JSON fallback (back-compat / no fetch-stream support). Mirrors the old flow.
  // Renders into the shared overlay body (`panel`). API request shape unchanged.
  function runSopJson(e, btn, label, panel, body){
    return api('POST', '/agents/' + encodeURIComponent(e.seatExternalId) + '/run', body)
      .then(function(run){ panel.innerHTML = ''; panel.appendChild(resultCard(e, run)); setRunFinishedFoot(e, btn, label); })
      .catch(function(err){
        panel.innerHTML = '';
        var code = err && err.code ? err.code : 'ERROR';
        var msg = friendlyState(code) || (err && err.message ? err.message : 'Run failed');
        panel.appendChild(el('div', 'ph-msg ph-msg-fail', msg));
        setRunFinishedFoot(e, btn, label);
      });
  }

  // Run a SOP: open the overlay immediately with the "working" state, then
  // stream the result into it. The card grid is untouched -- the run output
  // lives in the overlay. `btn`/`label` are the card's Run button (optional,
  // used only to reset its spinner + power "Run again").
  function runSop(e, btn, label){
    var sop = e.sop || {};
    var panel = openOverlay(sop.title || 'Process run', e.seatName || 'Agent');
    if (!panel) return;
    panel.appendChild(workingCard(e));
    if (btn){
      if (label == null) label = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="ph-spin"></span> Running';
    }
    var reset = makeBtnReset(btn, label);
    // Prefer the live SSE stream; fall back to JSON where fetch streaming is
    // unavailable (handled inside streamRun).
    if (window.fetch && window.ReadableStream && window.TextDecoder) {
      streamRun(e, btn, label, panel);
    } else {
      runSopJson(e, btn, label, panel, sop.id ? { sopId: sop.id } : { sopTitle: sop.title })
        .then(reset);
    }
  }

  function showRecentRuns(e, btn){
    var panel = openOverlay('Recent runs', e.seatName || 'Agent');
    if (!panel) return;
    var closeBtn = ovBtn('ph-btn ph-btn-ghost ph-btn-sm', 'Close');
    closeBtn.addEventListener('click', closeOverlay);
    overlaySetFoot([closeBtn]);
    panel.appendChild(el('div', 'ph-run-meta', 'Loading recent runs...'));
    if (btn) btn.disabled = true;
    api('GET', '/agents/' + encodeURIComponent(e.seatExternalId) + '/runs?limit=25', null)
      .then(function(res){
        panel.innerHTML = '';
        var runs = (res && Array.isArray(res.runs)) ? res.runs : [];
        var thisTitle = (e.sop && e.sop.title ? String(e.sop.title) : '').trim().toLowerCase();
        if (runs.length === 0) { panel.appendChild(el('div', 'ph-run-meta', 'No runs yet.')); return; }
        runs.forEach(function(run){
          var row = el('div', 'ph-run-row');
          var matches = thisTitle && String(run.sop_title || '').trim().toLowerCase() === thisTitle;
          if (matches) row.style.borderColor = 'var(--blue,#0d7df2)';
          var headRow = el('div', 'ph-run-row-head');
          var left = el('div', null);
          left.style.display = 'flex';
          left.style.alignItems = 'center';
          left.style.gap = '8px';
          var st = run.status || 'succeeded';
          left.appendChild(el('span', 'ph-badge ' + (st === 'succeeded' ? 'ph-badge-ok' : 'ph-badge-fail'), st === 'succeeded' ? 'Succeeded' : 'Failed'));
          var titleSpan = el('span', null, run.sop_title || run.trigger || 'run');
          titleSpan.style.fontWeight = '600';
          titleSpan.style.fontSize = '12.5px';
          left.appendChild(titleSpan);
          headRow.appendChild(left);
          var when = el('span', null, fmtWhen(run.created_at || run.started_at));
          when.style.fontSize = '11.5px';
          when.style.color = 'var(--ink-mute,#6b7280)';
          headRow.appendChild(when);
          row.appendChild(headRow);
          // Collapsed by default; expanding renders the run's outputHtml.
          var detail = el('div', null);
          detail.style.display = 'none';
          if (run.status === 'failed') {
            var fmsg = friendlyState(run.error) || run.error || 'Run failed';
            detail.appendChild(el('div', 'ph-msg ph-msg-fail', fmsg));
          } else {
            detail.appendChild(mdBody(run));
            var foot = footChips(run);
            if (foot) detail.appendChild(foot);
          }
          row.appendChild(detail);
          headRow.addEventListener('click', function(){ detail.style.display = detail.style.display === 'none' ? '' : 'none'; });
          panel.appendChild(row);
        });
      })
      .catch(function(err){
        panel.innerHTML = '';
        panel.appendChild(el('div', 'ph-run-err', (err && err.message) ? err.message : 'Could not load runs'));
      })
      .then(function(){ if (btn) btn.disabled = false; });
  }

  // ---- Schedule a SOP (autonomous cadence) ----
  // Maps a gate-fail code to inline upsell copy + the relevant settings link.
  function scheduleGateMsg(code){
    if (code === 'NO_WALLET') return { msg: 'Scheduling needs a funded wallet.', href: '/settings/billing', cta: 'Add funds' };
    if (code === 'NO_API_KEY') return { msg: 'Scheduling needs an API key.', href: '/settings/api', cta: 'Create an API key' };
    return null;
  }

  // Cadence picker form. minute/hour/weekday inputs show/hide by cadence.
  function buildScheduleForm(e, panel){
    var sop = e.sop || {};
    var wrap = el('div', null);
    wrap.style.display = 'flex';
    wrap.style.flexDirection = 'column';
    wrap.style.gap = '8px';

    if (!SCHEDULER_ENABLED){
      var note = el('div', 'ph-run-meta', 'Scheduling is in preview - your schedule is saved now and runs activate soon.');
      note.style.color = 'var(--orgy-on-light,#8a6d1a)';
      note.style.fontWeight = '600';
      wrap.appendChild(note);
    }

    var row = el('div', null);
    row.style.display = 'flex';
    row.style.flexWrap = 'wrap';
    row.style.gap = '8px';
    row.style.alignItems = 'center';

    var cad = document.createElement('select');
    cad.className = 'ph-input';
    cad.style.width = 'auto';
    ['hourly','daily','weekly'].forEach(function(c){
      var o = document.createElement('option'); o.value = c;
      o.textContent = c.charAt(0).toUpperCase() + c.slice(1);
      cad.appendChild(o);
    });
    cad.value = 'weekly';

    var wkSel = document.createElement('select');
    wkSel.className = 'ph-input'; wkSel.style.width = 'auto';
    ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'].forEach(function(d, i){
      var o = document.createElement('option'); o.value = String(i); o.textContent = d; wkSel.appendChild(o);
    });
    wkSel.value = '1';

    var hourSel = document.createElement('select');
    hourSel.className = 'ph-input'; hourSel.style.width = 'auto';
    for (var h = 0; h < 24; h++){
      var oh = document.createElement('option'); oh.value = String(h);
      oh.textContent = (h < 10 ? '0' : '') + h + ':00';
      hourSel.appendChild(oh);
    }
    hourSel.value = '8';

    var minSel = document.createElement('select');
    minSel.className = 'ph-input'; minSel.style.width = 'auto';
    [0,15,30,45].forEach(function(m){
      var om = document.createElement('option'); om.value = String(m);
      om.textContent = ':' + (m < 10 ? '0' : '') + m; minSel.appendChild(om);
    });
    minSel.value = '0';

    function syncVis(){
      var c = cad.value;
      wkSel.style.display = (c === 'weekly') ? '' : 'none';
      hourSel.style.display = (c === 'weekly' || c === 'daily') ? '' : 'none';
    }
    cad.addEventListener('change', syncVis);

    row.appendChild(cad);
    row.appendChild(wkSel);
    row.appendChild(el('span', null, 'at'));
    row.appendChild(hourSel);
    row.appendChild(minSel);
    wrap.appendChild(row);
    syncVis();

    var nameInput = document.createElement('input');
    nameInput.className = 'ph-input';
    nameInput.placeholder = 'Schedule name (optional)';
    wrap.appendChild(nameInput);

    var actions = el('div', null);
    actions.style.display = 'flex'; actions.style.gap = '8px'; actions.style.alignItems = 'center';
    var saveBtn = el('button', 'ph-btn ph-btn-primary ph-btn-sm', 'Save schedule');
    saveBtn.type = 'button';
    var msgEl = el('div', 'ph-run-err', '');
    msgEl.style.display = 'none';
    actions.appendChild(saveBtn);
    actions.appendChild(msgEl);
    wrap.appendChild(actions);

    saveBtn.addEventListener('click', function(){
      var body = {
        cadence: cad.value,
        minute: parseInt(minSel.value, 10),
        hour: parseInt(hourSel.value, 10),
        weekday: parseInt(wkSel.value, 10),
        timezone: (Intl.DateTimeFormat().resolvedOptions().timeZone) || 'America/New_York'
      };
      if (sop && sop.id) body.sopId = sop.id; else body.sopTitle = sop && sop.title;
      var nm = (nameInput.value || '').trim(); if (nm) body.name = nm;
      saveBtn.disabled = true; msgEl.style.display = 'none';
      api('POST', '/agents/' + encodeURIComponent(e.seatExternalId) + '/schedules', body)
        .then(function(){ renderSchedulePanel(panel, e); })
        .catch(function(err){
          saveBtn.disabled = false;
          var up = scheduleGateMsg(err && err.code);
          msgEl.innerHTML = '';
          if (up){
            msgEl.appendChild(document.createTextNode(up.msg + ' '));
            var a = document.createElement('a');
            a.href = up.href; a.textContent = up.cta;
            a.style.textDecoration = 'underline'; a.style.color = 'var(--blue,#0d7df2)';
            msgEl.appendChild(a);
          } else {
            msgEl.textContent = (err && err.message) ? err.message : 'Could not save schedule';
          }
          msgEl.style.display = '';
        });
    });

    return wrap;
  }

  function cadenceLabel(s){
    // Best-effort human label from the stored cron + timezone.
    var cron = (s.cron || '').split(/\s+/);
    if (cron.length !== 5) return s.cron || '';
    var min = cron[0], hr = cron[1], dow = cron[4];
    var pad = function(n){ n = String(n); return n.length < 2 ? '0' + n : n; };
    if (hr === '*') return 'Hourly at :' + pad(min);
    var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var time = pad(hr) + ':' + pad(min);
    if (dow === '*') return 'Daily at ' + time;
    return (days[parseInt(dow,10)] || ('day ' + dow)) + ' at ' + time;
  }

  function renderSchedulePanel(panel, e){
    panel.style.display = '';
    panel.innerHTML = '';
    panel.appendChild(el('div', 'ph-run-meta', 'Loading schedules...'));
    api('GET', '/agents/' + encodeURIComponent(e.seatExternalId) + '/schedules', null)
      .then(function(res){
        panel.innerHTML = '';
        var all = (res && Array.isArray(res.schedules)) ? res.schedules : [];
        var sopTitle = (e.sop && e.sop.title ? String(e.sop.title) : '').trim().toLowerCase();
        var sopId = e.sop && e.sop.id;
        // Show schedules that target THIS SOP (by id when present, else title).
        var mine = all.filter(function(s){
          if (sopId && s.sop_id) return s.sop_id === sopId;
          return String(s.sop_title || '').trim().toLowerCase() === sopTitle;
        });

        var head = el('div', 'ph-label', 'Schedule this process');
        panel.appendChild(head);
        panel.appendChild(buildScheduleForm(e, panel));

        if (mine.length){
          var listHead = el('div', 'ph-label', 'Existing schedules');
          listHead.style.marginTop = '12px';
          panel.appendChild(listHead);
          mine.forEach(function(s){
            var row = el('div', 'ph-run-row');
            var rh = el('div', 'ph-run-row-head');
            var left = el('div', null);
            left.style.display = 'flex'; left.style.alignItems = 'center'; left.style.gap = '8px';
            left.appendChild(el('span', 'ph-badge ' + (s.enabled ? 'ph-badge-ok' : 'ph-badge-fail'), s.enabled ? 'On' : 'Off'));
            var lbl = el('span', null, cadenceLabel(s) + (s.timezone ? ' (' + s.timezone + ')' : ''));
            lbl.style.fontWeight = '600'; lbl.style.fontSize = '12.5px';
            left.appendChild(lbl);
            rh.appendChild(left);
            var ctrls = el('div', null);
            ctrls.style.display = 'flex'; ctrls.style.gap = '6px';
            var tgl = el('button', 'ph-btn ph-btn-ghost ph-btn-sm', s.enabled ? 'Disable' : 'Enable');
            tgl.type = 'button';
            tgl.addEventListener('click', function(){
              tgl.disabled = true;
              api('PATCH', '/schedules/' + encodeURIComponent(s.id), { enabled: !s.enabled })
                .then(function(){ renderSchedulePanel(panel, e); })
                .catch(function(err){
                  tgl.disabled = false;
                  var up = scheduleGateMsg(err && err.code);
                  alert(up ? up.msg : ('Could not update: ' + fmtErr(err)));
                });
            });
            var del = el('button', 'ph-btn ph-btn-ghost ph-btn-sm', 'Delete');
            del.type = 'button'; del.style.color = '#be123c';
            del.addEventListener('click', function(){
              if (!window.confirm('Delete this schedule?')) return;
              del.disabled = true;
              api('DELETE', '/schedules/' + encodeURIComponent(s.id), null)
                .then(function(){ renderSchedulePanel(panel, e); })
                .catch(function(err){ del.disabled = false; alert('Delete failed: ' + fmtErr(err)); });
            });
            ctrls.appendChild(tgl); ctrls.appendChild(del);
            rh.appendChild(ctrls);
            row.appendChild(rh);
            if (s.next_run_at){
              var nr = el('div', 'ph-run-meta', 'Next run: ' + fmtWhen(s.next_run_at));
              row.appendChild(nr);
            }
            panel.appendChild(row);
          });
        }
      })
      .catch(function(err){
        panel.innerHTML = '';
        panel.appendChild(el('div', 'ph-run-err', (err && err.message) ? err.message : 'Could not load schedules'));
      });
  }

  function openSchedule(e, btn){
    var panel = openOverlay('Schedule', e.seatName || 'Agent');
    if (!panel) return;
    var close = ovBtn('ph-btn ph-btn-ghost ph-btn-sm', 'Close');
    close.addEventListener('click', closeOverlay);
    overlaySetFoot([close]);
    renderSchedulePanel(panel, e);
  }

  // ---- Edit / Delete / Run / Recent runs from a card ----
  // Run / Runs / Schedule all open the shared overlay (no inline expansion, so
  // the card grid never changes height). closest() resolves the owning button
  // even if a click lands on a child node. API contracts are unchanged.
  if (grid) grid.addEventListener('click', function(ev){
    var t = ev.target;
    var btn = t.closest && t.closest('button');
    var card = t.closest && t.closest('[data-idx]');
    if (!card || !btn) return;
    var e = ENTRIES[Number(card.getAttribute('data-idx'))];
    if (!e) return;
    if (btn.classList.contains('ph-schedule')) {
      openSchedule(e, btn); return;
    }
    if (btn.classList.contains('ph-run')) {
      runSop(e, btn); return;
    }
    if (btn.classList.contains('ph-runs')) {
      showRecentRuns(e, btn); return;
    }
    if (btn.classList.contains('ph-edit')) {
      openModal('edit', e.seatExternalId, e.sop, e.sopIndex);
    } else if (btn.classList.contains('ph-delete')) {
      if (!window.confirm('Delete "' + (e.sop && e.sop.title ? e.sop.title : 'this process') + '"? This removes it from ' + e.seatName + "'s SOPs.")) return;
      var sops = seatSops(e.seatExternalId).slice();
      sops.splice(e.sopIndex, 1);
      btn.disabled = true;
      patchSeatSops(e.seatExternalId, e.seatType, sops)
        .then(function(){ window.location.reload(); })
        .catch(function(err){ btn.disabled = false; alert('Delete failed: ' + fmtErr(err)); });
    }
  });

  // ---- Process Library deep-link: open New Process prefilled from a SOP ----
  // Fires when arriving via /processes?insert=<slug> with a valid library SOP.
  // openModal('new', ..., sop) fills title/trigger/steps/outputs/tools/notes;
  // the user still picks the owning seat and saves. Strip ?insert= from the URL
  // so a refresh doesn't re-open the modal.
  if (INSERT_SOP && INSERT_SOP.title) {
    openModal('new', null, INSERT_SOP);
    try {
      var u = new URL(window.location.href);
      u.searchParams.delete('insert');
      history.replaceState(null, '', u.toString());
    } catch (e) { /* no-op */ }
  }
})();
</script>
