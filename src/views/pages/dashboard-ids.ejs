<%- include('../partials/orgy-palette'); %>
<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%- include('../partials/ui-page-header', { mascot: 'issues', title: 'Issues (IDS) — admin view', subtitle: 'Cross-team list. Click a team chip to filter. Use the per-row mover to assign an issue to a different team.' }) %>
    </div>
    <div class="flex gap-2 items-center">
      <a href="/l8" class="text-xs px-3 py-1.5 border border-gray-200 rounded text-gray-700 hover:bg-gray-50">Back to meetings</a>
    </div>
  </div>

  <!-- Filters -->
  <div class="mb-4 flex flex-wrap gap-2 items-center text-sm">
    <span class="text-xs uppercase tracking-wide text-gray-500 font-semibold mr-1">Team</span>
    <a href="/dashboard/ids<%= filterIdsStatus ? '?idsStatus=' + filterIdsStatus : '' %>"
       class="px-2 py-1 rounded-full border <%= !filterTeamId ? 'bg-orgy-soft border-orgy-soft text-orgy-blue font-semibold' : 'bg-white border-gray-200 text-gray-600 hover:border-gray-300' %>">All teams</a>
    <% (orgTeams || []).forEach(function(t) {
      const qs = new URLSearchParams();
      qs.set('teamId', t.id);
      if (filterIdsStatus) qs.set('idsStatus', filterIdsStatus);
    %>
      <a href="/dashboard/ids?<%= qs.toString() %>"
         class="px-2 py-1 rounded-full border <%= filterTeamId === t.id ? 'bg-indigo-100 border-indigo-300 text-indigo-800 font-semibold' : 'bg-white border-gray-200 text-gray-700 hover:border-gray-300' %>">
        <%= t.name %><% if (t.isDefault) { %> ·<% } %>
      </a>
    <% }); %>

    <span class="mx-2 h-4 w-px bg-gray-200"></span>

    <span class="text-xs uppercase tracking-wide text-gray-500 font-semibold mr-1">Status</span>
    <% ['', 'open', 'identified', 'discussed', 'solved'].forEach(function(s) {
      const qs = new URLSearchParams();
      if (filterTeamId) qs.set('teamId', filterTeamId);
      if (s) qs.set('idsStatus', s);
      const active = (filterIdsStatus || '') === s;
      const label = s || 'Open (any)';
    %>
      <a href="/dashboard/ids<%= qs.toString() ? '?' + qs.toString() : '' %>"
         class="px-2 py-1 rounded-full border <%= active ? 'bg-amber-100 border-amber-300 text-amber-800 font-semibold' : 'bg-white border-gray-200 text-gray-600 hover:border-gray-300' %>">
        <%= label %>
      </a>
    <% }); %>
  </div>

  <!-- Issues list -->
  <div class="border rounded-lg bg-white overflow-hidden">
    <% if (!issues || issues.length === 0) { %>
      <div class="px-4 py-10 text-center text-sm text-gray-500">
        No issues match these filters.
      </div>
    <% } else { %>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="text-left px-4 py-2 font-semibold">Issue</th>
            <th class="text-left px-3 py-2 font-semibold w-32">Status</th>
            <th class="text-left px-3 py-2 font-semibold w-40">Owner</th>
            <th class="text-left px-3 py-2 font-semibold w-44">Team</th>
            <th class="text-left px-3 py-2 font-semibold w-28">Created</th>
          </tr>
        </thead>
        <tbody>
          <% issues.forEach(function(i) {
            const statusClass = i.idsStatus === 'open'
              ? 'bg-gray-100 text-gray-700'
              : i.idsStatus === 'identified' ? 'bg-blue-100 text-blue-800'
              : i.idsStatus === 'discussed' ? 'bg-amber-100 text-amber-800'
              : 'bg-emerald-100 text-emerald-800';
          %>
            <tr class="border-b last:border-b-0 hover:bg-gray-50/60" data-issue-id="<%= i.id %>">
              <td class="px-4 py-2.5">
                <div class="font-medium text-gray-900"><%= i.title %></div>
                <% if (i.description) { %>
                  <div class="text-xs text-gray-500 mt-0.5 line-clamp-1"><%= i.description.length > 120 ? i.description.slice(0, 120) + '…' : i.description %></div>
                <% } %>
              </td>
              <td class="px-3 py-2.5">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-medium <%= statusClass %>"><%= i.idsStatus %></span>
              </td>
              <td class="px-3 py-2.5 text-xs text-gray-600">
                <%= i.ownerName || i.ownerExternalId || '—' %>
              </td>
              <td class="px-3 py-2.5">
                <div class="flex items-center gap-1.5">
                  <% if (i.teamName) { %>
                    <span class="inline-block px-2 py-0.5 rounded-full bg-indigo-50 border border-indigo-200 text-indigo-700 text-xs font-medium"><%= i.teamName %></span>
                  <% } else { %>
                    <span class="inline-block px-2 py-0.5 rounded-full bg-amber-50 border border-amber-200 text-amber-700 text-xs font-medium">no team</span>
                  <% } %>
                  <select class="issue-team-mover text-xs px-1 py-0.5 border rounded text-gray-500" title="Move to a different team">
                    <option value="">…</option>
                    <% (orgTeams || []).forEach(function(tm) { if (tm.id === i.teamId) return; %>
                      <option value="<%= tm.id %>"><%= tm.name %></option>
                    <% }); %>
                  </select>
                </div>
              </td>
              <td class="px-3 py-2.5 text-xs text-gray-500 whitespace-nowrap">
                <%= i.createdAt ? new Date(i.createdAt).toLocaleDateString() : '—' %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <p class="mt-3 text-xs text-gray-500"><%= (issues || []).length %> issue<%= (issues || []).length === 1 ? '' : 's' %> shown · admin-only view</p>
</div>

<script>
  document.querySelectorAll('.issue-team-mover').forEach(function(sel) {
    sel.addEventListener('change', async function(e) {
      var newTeamId = e.currentTarget.value;
      if (!newTeamId) return;
      var tr = e.currentTarget.closest('tr');
      if (!tr) return;
      var issueId = tr.dataset.issueId;
      e.currentTarget.disabled = true;
      try {
        var r = await fetch('/api/v1/tickets/' + issueId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ teamId: newTeamId }),
        });
        if (!r.ok) {
          var body = await r.json().catch(function(){ return {}; });
          throw new Error(body && body.error ? (body.error.message || body.error.code) : ('HTTP ' + r.status));
        }
        // If a team filter is active, the row no longer belongs here -- fade it out.
        // Otherwise, refresh so the team chip updates inline.
        var urlHasTeam = new URLSearchParams(window.location.search).has('teamId');
        if (urlHasTeam) {
          tr.style.transition = 'opacity 0.25s';
          tr.style.opacity = '0';
          setTimeout(function(){ tr.remove(); }, 250);
        } else {
          location.reload();
        }
      } catch (err) {
        alert('Move failed: ' + (err.message || 'unknown'));
        e.currentTarget.disabled = false;
        e.currentTarget.value = '';
      }
    });
  });
</script>
