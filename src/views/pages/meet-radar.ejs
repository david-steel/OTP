        { pos: 'right:42%; bottom:-2%;', size: 18, color: '#0095ff', delay: 3.7 },
        { pos: 'left:30%; top:50%;',  size: 12, color: '#d4ad32', delay: 1.0 },
        { pos: 'right:30%; top:50%;', size: 14, color: '#0095ff', delay: 2.4 },
      ]; %>
      <% sparkles.forEach(s => { %>
        <div class="pointer-events-none absolute radar-sparkle z-20" style="<%= s.pos %> animation-delay: <%= s.delay %>s; filter: drop-shadow(0 0 8px <%= s.color %>aa) drop-shadow(0 0 16px <%= s.color %>66);">
          <svg width="<%= s.size %>" height="<%= s.size %>" viewBox="0 0 24 24" fill="<%= s.color %>" stroke="<%= s.color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
          </svg>
        </div>
      <% }); %>

      <div class="relative z-10 radar-float" style="filter: drop-shadow(0 36px 64px rgba(0,0,0,0.65)) drop-shadow(0 0 36px rgba(212,173,50,0.32));">
        <img src="/public/images/radar-mascot.png" alt="Radar — half human Chief of Staff in olive uniform with RADAR dog tags, half AI circuit board. Built on OTP." class="h-auto w-[380px] sm:w-[520px] md:w-[620px] lg:w-[680px]" />
