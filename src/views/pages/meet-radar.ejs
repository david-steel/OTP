    <p class="mx-auto mt-2 max-w-2xl text-sm sm:text-base text-amber-300/90 font-semibold">
      Plus Radar — your built-in AI Chief of Staff that runs the work between meetings.
    </p>

    <!-- BIG Radar mascot in the middle. Sparkles around him. -->
    <div class="relative mx-auto mt-10 flex w-full items-center justify-center md:mt-14">
      <% const sparkles = [
        { pos: 'left:6%; top:12%;',   size: 32, color: '#d4ad32', delay: 0.4 },
        { pos: 'right:4%; top:8%;',   size: 26, color: '#0095ff', delay: 0.9 },
        { pos: 'left:12%; top:42%;',  size: 20, color: '#0095ff', delay: 1.5 },
        { pos: 'right:10%; top:36%;', size: 30, color: '#d4ad32', delay: 1.9 },
        { pos: 'left:2%; bottom:18%;',  size: 22, color: '#84cc16', delay: 2.3 },
        { pos: 'right:2%; bottom:14%;', size: 28, color: '#0095ff', delay: 2.7 },
        { pos: 'left:22%; top:2%;',   size: 16, color: '#d4ad32', delay: 3.1 },
        { pos: 'right:22%; bottom:2%;', size: 18, color: '#84cc16', delay: 3.5 },
        { pos: 'left:-4%; top:30%;',  size: 14, color: '#0095ff', delay: 0.3 },
        { pos: 'right:-4%; top:22%;', size: 16, color: '#d4ad32', delay: 1.2 },
        { pos: 'left:18%; bottom:6%;',  size: 14, color: '#84cc16', delay: 1.7 },
        { pos: 'right:18%; top:18%;', size: 18, color: '#0095ff', delay: 2.1 },
        { pos: 'left:36%; top:-4%;',  size: 20, color: '#d4ad32', delay: 2.5 },
        { pos: 'right:36%; top:-4%;', size: 16, color: '#0095ff', delay: 2.9 },
        { pos: 'left:42%; bottom:-2%;', size: 22, color: '#84cc16', delay: 3.3 },
        { pos: 'right:42%; bottom:-2%;', size: 18, color: '#0095ff', delay: 3.7 },
        { pos: 'left:30%; top:50%;',  size: 12, color: '#d4ad32', delay: 1.0 },
        { pos: 'right:30%; top:50%;', size: 14, color: '#0095ff', delay: 2.4 },
      ]; %>
      <% sparkles.forEach(s => { %>
        <div class="pointer-events-none absolute radar-sparkle z-20" style="<%= s.pos %> animation-delay: <%= s.delay %>s; filter: drop-shadow(0 0 8px <%= s.color %>aa) drop-shadow(0 0 16px <%= s.color %>66);">
          <svg width="<%= s.size %>" height="<%= s.size %>" viewBox="0 0 24 24" fill="<%= s.color %>" stroke="<%= s.color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
          </svg>
        </div>
      <% }); %>

      <div class="relative z-10 radar-float" style="filter: drop-shadow(0 36px 64px rgba(0,0,0,0.65)) drop-shadow(0 0 36px rgba(212,173,50,0.32));">
        <img src="/public/images/radar-mascot.png" alt="Radar — your AI Chief of Staff, built into every OTP account." class="h-auto w-[380px] sm:w-[520px] md:w-[620px] lg:w-[680px]" />
      </div>
    </div>

    <!-- Primary CTA -->
    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/sign-up" class="group inline-flex items-center gap-2 rounded-xl px-8 py-4 text-base font-bold text-otp-950 transition-transform duration-200 hover:scale-[1.04] active:scale-[0.98]" style="background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #b8941c 100%); box-shadow: 0 0 0 1px rgba(212,173,50,0.4), 0 14px 32px -10px rgba(212,173,50,0.5);">
        <span>Create your free account</span>
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <p class="mt-5 text-[11px] uppercase tracking-[0.25em] text-gray-500">
      <span class="text-white">Join in Beta = Free forever</span> &middot;
      <span class="text-amber-400">No credit card</span> &middot;
      <span class="text-otp-300">Whole team included</span>
    </p>
  </div>
</section>

