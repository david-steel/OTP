        <div class="mt-8">
          <a href="/sign-up" class="inline-flex items-center gap-2 rounded-lg px-6 py-3 text-base font-bold text-otp-950 transition-transform hover:scale-[1.03]" style="background: linear-gradient(135deg, #d4ad32, #f5c84d);">
            Get Radar for your team
