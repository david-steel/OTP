    <% const fullFeatures = [
      { icon: '📋', label: 'Vision Plan',          desc: 'Long-range view, three-year target, one-year focus, quarterly priorities. One living document the whole team reads from.' },
      { icon: '📊', label: 'Weekly Scoreboard',    desc: '5 to 15 KPIs, owner per row, weekly cadence. Red/yellow/green at a glance.' },
      { icon: '🎯', label: 'Quarterly Priorities', desc: 'The handful of 90-day goals that actually matter. Owner, deadline, progress bar.' },
      { icon: '✅', label: 'To-Do List',           desc: 'Action items from every meeting. Owned. Dated. Closed.' },
      { icon: '⚠',  label: 'Issues Board',         desc: 'Surface, prioritize, and solve. The list that keeps you out of fire-drill mode.' },
      { icon: '🗓', label: 'Leadership Meeting',   desc: 'Same agenda every week. Scoreboard review. Priorities check. To-dos. Issues. Done in 90 minutes.' },
      { icon: '🪪', label: 'Team Chart',           desc: 'Roles and seats. Who owns what. The org structure that survives growth.' },
      { icon: '📣', label: 'Team Updates',         desc: 'Wins, news, and customer/employee feedback in one stream. Keep the team aligned between meetings.' },
      { icon: '🤝', label: '1-on-1s',              desc: 'Recurring manager-direct touchpoints with shared notes and follow-ups.' },
      { icon: '📚', label: 'Process Docs',         desc: 'The handful of core processes documented and findable. The knowledge that walks out the door otherwise.' },
      { icon: '⭐', label: 'Goals & Targets',      desc: 'Long-range objectives that ladder up from quarterly priorities to multi-year plans.' },
      { icon: '🔗', label: 'Integrations',         desc: 'Slack, Google Workspace, Microsoft 365, Notion. Pull data in. Push action items out.' },
    ]; %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% fullFeatures.forEach(f => { %>
        <div class="feature-tile rounded-2xl border border-white/10 bg-white/[0.025] p-5">
