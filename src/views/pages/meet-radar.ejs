    </p>

    <!-- Radar mascot — LARGE: this is the product visual -->
    <div class="relative mx-auto mt-8 flex w-full items-center justify-center md:mt-12">
      <% const sparkles = [
        { pos: 'left:6%; top:12%;',   size: 32, color: '#d4ad32', delay: 0.4 },
        { pos: 'right:4%; top:8%;',   size: 26, color: '#0095ff', delay: 0.9 },
        { pos: 'left:12%; top:42%;',  size: 20, color: '#0095ff', delay: 1.5 },
        { pos: 'right:10%; top:36%;', size: 30, color: '#d4ad32', delay: 1.9 },
        { pos: 'left:2%; bottom:18%;',  size: 22, color: '#84cc16', delay: 2.3 },
        { pos: 'right:2%; bottom:14%;', size: 28, color: '#0095ff', delay: 2.7 },
        { pos: 'left:22%; top:2%;',   size: 16, color: '#d4ad32', delay: 3.1 },
        { pos: 'right:22%; bottom:2%;', size: 18, color: '#84cc16', delay: 3.5 },
        { pos: 'left:-4%; top:30%;',  size: 14, color: '#0095ff', delay: 0.3 },
        { pos: 'right:-4%; top:22%;', size: 16, color: '#d4ad32', delay: 1.2 },
