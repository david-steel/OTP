<!-- ============================================================
     /meet-radar — Positioning page for LinkedIn EOS audiences.
     Audience: companies/operators running EOS for themselves
     (Ninety / Bloom Growth / EOS One users). NOT coaches.
     Coach play lives on /coach as a separate parallel track.
     Every CTA on this page drives to /sign-up.
     ============================================================ -->
<style>
  @keyframes radar-sparkle {
    0%, 100% { opacity: 0; transform: scale(0.4) rotate(0); }
    25% { opacity: 1; transform: scale(1) rotate(90deg); }
    50% { opacity: 0.6; transform: scale(0.8) rotate(180deg); }
    75% { opacity: 1; transform: scale(1) rotate(270deg); }
  }
  .radar-sparkle { animation: radar-sparkle 4s ease-in-out infinite; }

  @keyframes radar-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .radar-float { animation: radar-float 6s ease-in-out infinite; }

  @keyframes radar-pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(212, 173, 50, 0.6); }
    50% { box-shadow: 0 0 0 12px rgba(212, 173, 50, 0); }
  }
  .radar-pulse-glow { animation: radar-pulse-glow 2.4s ease-in-out infinite; }

  .radar-gradient-gold {
    background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #d4ad32 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Hero headline composition — tight leading so the two lines feel like
     one thought. Gold line sits flush under the white line. */
  .hero-headline {
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .hero-headline .line-1,
  .hero-headline .line-2 {
    display: block;
  }
  .hero-headline .line-2 {
    margin-top: 0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .radar-sparkle, .radar-float, .radar-pulse-glow { animation: none !important; }
  }
</style>

<!-- =====================================================
     HERO — Radar large, tight headline, single CTA to /sign-up
     ===================================================== -->
<section class="bg-otp-950 relative overflow-hidden pt-20 pb-8 sm:pt-28 sm:pb-12">
