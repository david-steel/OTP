            </svg>
          </div>
        <% }); %>
        <div class="relative z-10 radar-float" style="filter: drop-shadow(0 32px 56px rgba(0,0,0,0.6)) drop-shadow(0 0 32px rgba(212,173,50,0.3));">
          <img src="/public/images/radar-mascot.png" alt="Radar — half human Chief of Staff in olive uniform with RADAR dog tags, half AI circuit board. Built on OTP." class="h-auto w-[320px] sm:w-[420px] md:w-[480px]" />
        </div>
      </div>
    </div>
  </div>
</section>

