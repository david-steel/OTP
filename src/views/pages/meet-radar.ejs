        <div class="mt-7 space-y-3">
          <% const radarCaps = [
            { icon: '⚡', label: 'Daily briefings', desc: 'Pulls activity from Slack, email, calendar, CRM, and the scoreboard. Hands you a brief that replaces 2+ hours of manual checking.' },
            { icon: '📊', label: 'Live scoreboard updates', desc: 'Pulls weekly KPIs from source systems. No more chasing teammates for numbers before the meeting.' },
