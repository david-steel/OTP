    <div class="mt-12 text-center">
      <a href="/sign-up" class="inline-flex items-center gap-2 rounded-lg px-6 py-3 text-base font-bold text-otp-950 transition-transform hover:scale-[1.03]" style="background: linear-gradient(135deg, #d4ad32, #f5c84d);">
        Start running on OTP - free
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- =====================================================
     RADAR — the bonus AI Chief of Staff
     ===================================================== -->
<section class="bg-otp-950 relative py-16 sm:py-24 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
