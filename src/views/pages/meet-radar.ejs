      <!-- Right: Radar mascot -->
      <div class="relative flex items-center justify-center">
        <% const sideSparkles = [
          { pos: 'left:8%; top:14%;',   size: 22, color: '#d4ad32', delay: 0.4 },
          { pos: 'right:6%; top:10%;',  size: 18, color: '#0095ff', delay: 0.9 },
          { pos: 'left:14%; bottom:18%;', size: 16, color: '#84cc16', delay: 1.5 },
          { pos: 'right:10%; bottom:14%;', size: 20, color: '#d4ad32', delay: 2.0 },
          { pos: 'left:42%; top:-4%;',  size: 14, color: '#0095ff', delay: 2.4 },
          { pos: 'right:38%; bottom:-2%;', size: 16, color: '#84cc16', delay: 2.8 },
          { pos: 'left:-2%; top:48%;',  size: 12, color: '#d4ad32', delay: 1.0 },
          { pos: 'right:-2%; top:44%;', size: 14, color: '#0095ff', delay: 1.8 },
        ]; %>
        <% sideSparkles.forEach(s => { %>
          <div class="pointer-events-none absolute radar-sparkle z-20" style="<%= s.pos %> animation-delay: <%= s.delay %>s; filter: drop-shadow(0 0 8px <%= s.color %>aa);">
            <svg width="<%= s.size %>" height="<%= s.size %>" viewBox="0 0 24 24" fill="<%= s.color %>" stroke="<%= s.color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
