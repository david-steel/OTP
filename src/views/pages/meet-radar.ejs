<%# /meet-radar — platform-first landing for leadership teams.
    Audience: operators currently on per-seat meeting software.
    Trademark-safe naming; beta framing justifies free pricing.
    Every CTA drives to /sign-up. %>
<style>
  @keyframes radar-sparkle {
    0%, 100% { opacity: 0; transform: scale(0.4) rotate(0); }
    25% { opacity: 1; transform: scale(1) rotate(90deg); }
    50% { opacity: 0.6; transform: scale(0.8) rotate(180deg); }
    75% { opacity: 1; transform: scale(1) rotate(270deg); }
  }
  .radar-sparkle { animation: radar-sparkle 4s ease-in-out infinite; }

  @keyframes radar-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .radar-float { animation: radar-float 6s ease-in-out infinite; }

  @keyframes radar-pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(212, 173, 50, 0.55); }
    50% { box-shadow: 0 0 0 10px rgba(212, 173, 50, 0); }
  }
  .radar-pulse-glow { animation: radar-pulse-glow 2.4s ease-in-out infinite; }

  .radar-gradient-gold {
    background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #d4ad32 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .hero-headline .line-1,
  .hero-headline .line-2 {
    display: block;
  }
  .hero-headline .line-2 {
    margin-top: 0.1em;
  }

  /* Feature tile hover */
  .feature-tile {
    transition: transform .2s ease, border-color .2s ease, background-color .2s ease;
  }
  .feature-tile:hover {
    transform: translateY(-2px);
    border-color: rgba(212, 173, 50, 0.4);
    background-color: rgba(255, 255, 255, 0.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .radar-sparkle, .radar-float, .radar-pulse-glow, .feature-tile { animation: none !important; transition: none !important; }
  }
</style>

<!-- =====================================================
     BETA BANNER — top of page, frames why everything is free
     ===================================================== -->
<div class="relative w-full" style="background: linear-gradient(90deg, rgba(212,173,50,0.18), rgba(245,200,77,0.22), rgba(212,173,50,0.18)); border-bottom: 1px solid rgba(212,173,50,0.35);">
  <div class="mx-auto max-w-6xl px-4 py-2.5 sm:py-3 text-center">
    <p class="text-[11px] sm:text-xs font-bold uppercase tracking-[0.2em] text-amber-300">
      <span class="inline-block px-2 py-0.5 rounded-md bg-amber-400/20 text-amber-200 mr-2 border border-amber-300/30">BETA</span>
      <span class="text-white/90">We're brand new — that's why everything is free.</span>
      <span class="hidden sm:inline text-amber-200/80">Lock in free for your whole team before pricing turns on.</span>
    </p>
  </div>
</div>

<!-- =====================================================
     HERO — platform-first headline + feature tile preview
     ===================================================== -->
<section class="bg-otp-950 relative overflow-hidden pt-16 pb-12 sm:pt-20 sm:pb-16">
  <div class="absolute inset-0 bg-grid opacity-20"></div>
  <div class="absolute top-[-200px] right-[-100px] w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute bottom-[-200px] left-[-100px] w-[500px] h-[500px] bg-blue-500/8 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">

    <div class="mb-5 inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.2em] text-amber-400 bg-amber-500/10 border border-amber-500/20">
      <span class="w-1.5 h-1.5 rounded-full bg-amber-400 radar-pulse-glow"></span>
      The operating platform for leadership teams
    </div>

    <h1 class="hero-headline font-extrabold text-white">
      <span class="line-1">Every tool you need to run your week.</span>
      <span class="line-2 radar-gradient-gold">Free while we're in beta.</span>
    </h1>

    <p class="mx-auto mt-5 max-w-2xl text-base sm:text-lg leading-relaxed text-gray-300">
      Vision Plan. Weekly Scoreboard. Quarterly Priorities. To-Dos. Issues Board. Leadership Meeting. Team Chart. Plus a built-in AI Chief of Staff.
    </p>
    <p class="mx-auto mt-2 max-w-2xl text-sm sm:text-base text-amber-300/90 font-semibold">
      The same rhythm your leadership team already runs — without the per-seat price tag.
    </p>

    <!-- Feature tile preview (the platform IS the hero visual) -->
    <div class="relative mx-auto mt-10 max-w-5xl">
      <!-- App chrome / window frame -->
      <div class="rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.04] to-white/[0.02] backdrop-blur shadow-2xl overflow-hidden">
        <!-- Title bar -->
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/10 bg-white/[0.02]">
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/60"></span>
          </div>
          <div class="flex-1 text-center text-[10px] uppercase tracking-[0.25em] text-gray-500">orgtp.com / your team</div>
          <div class="w-12"></div>
        </div>

        <!-- Tile grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 p-4 sm:p-6">
          <% const heroTiles = [
            { icon: '📋', label: 'Vision Plan',         hint: 'Long-range + 1-year' },
            { icon: '📊', label: 'Weekly Scoreboard',   hint: '5–15 live KPIs' },
            { icon: '🎯', label: 'Quarterly Priorities',hint: '90-day goals' },
            { icon: '✅', label: 'To-Dos',              hint: 'Owned + dated' },
            { icon: '⚠',  label: 'Issues Board',        hint: 'Surface + solve' },
            { icon: '🗓', label: 'Leadership Meeting',  hint: 'Weekly cadence' },
            { icon: '🪪', label: 'Team Chart',          hint: 'Roles + seats' },
            { icon: '📣', label: 'Team Updates',        hint: 'Wins + news' },
          ]; %>
          <% heroTiles.forEach(t => { %>
            <div class="feature-tile rounded-xl border border-white/10 bg-white/[0.025] p-4 text-left">
              <div class="text-2xl mb-2"><%= t.icon %></div>
              <div class="text-sm font-bold text-white"><%= t.label %></div>
              <div class="text-[11px] text-gray-500 mt-0.5"><%= t.hint %></div>
            </div>
          <% }); %>
          <!-- Radar tile — gold-accented, marks the bonus -->
          <div class="feature-tile rounded-xl border border-amber-400/40 bg-gradient-to-br from-amber-400/15 to-amber-500/5 p-4 text-left col-span-2 sm:col-span-1 lg:col-span-2">
            <div class="flex items-center gap-3">
              <div class="flex-shrink-0">
                <div class="relative w-12 h-12 rounded-full overflow-hidden ring-2 ring-amber-400/40">
                  <img src="/public/images/radar-mascot.png" alt="Radar" class="w-full h-full object-cover" />
                </div>
              </div>
              <div>
                <div class="text-[10px] font-bold uppercase tracking-[0.18em] text-amber-300 mb-0.5">Built-in &middot; AI</div>
                <div class="text-sm font-bold text-white">Radar, your AI Chief of Staff</div>
                <div class="text-[11px] text-amber-100/70 mt-0.5">Briefings, scoreboard pulls, issue radar</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Primary CTA -->
    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/sign-up" class="group inline-flex items-center gap-2 rounded-xl px-8 py-4 text-base font-bold text-otp-950 transition-transform duration-200 hover:scale-[1.04] active:scale-[0.98]" style="background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #b8941c 100%); box-shadow: 0 0 0 1px rgba(212,173,50,0.4), 0 14px 32px -10px rgba(212,173,50,0.5);">
        <span>Create your free account</span>
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <p class="mt-5 text-[11px] uppercase tracking-[0.25em] text-gray-500">
      <span class="text-white">Free during beta</span> &middot;
      <span class="text-amber-400">No credit card</span> &middot;
      <span class="text-otp-300">Whole team included</span>
    </p>
  </div>
</section>

<!-- =====================================================
