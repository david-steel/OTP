<%-
  /* /claim/:slug/done — Post-claim confirmation.
     Variables: profile, slug, status ('success' | 'already_claimed'), publicProfileUrl, dashboardUrl */
%>
<section class="bg-gradient-to-b from-amber-50 via-white to-white">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20 text-center">

    <% if (status === 'already_claimed') { %>
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber-100 mb-6">
        <span class="text-amber-600 text-3xl">!</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">This profile is already claimed.</h1>
      <p class="text-gray-600 mb-8">
        Someone else claimed this profile before you. If you believe this is your profile and there's a dispute, email David directly and we'll sort it out.
      </p>
      <a href="mailto:david@orgtp.com?subject=Profile dispute - <%= slug %>" class="inline-flex items-center px-6 py-3 rounded-xl bg-gray-900 text-white font-semibold hover:bg-gray-800">
        Email David
      </a>
    <% } else { %>
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-6">
        <span class="text-green-600 text-3xl">✓</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">You're in.</h1>
      <p class="text-base sm:text-lg text-gray-700 mb-2">
        Your OTP profile is claimed<% if (profile) { %>, <%= profile.displayName.split(' ')[0] %><% } %>.
      </p>
      <p class="text-sm text-gray-600 mb-8">
        David got the notification. You're tracked as part of the Founding 25 cohort.
      </p>

      <% if (typeof inviteUrl !== 'undefined' && inviteUrl) { %>
        <!-- Shareable client-invite link — the highest-value next action for a newly-claimed coach -->
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 border-2 border-amber-300 rounded-2xl p-6 sm:p-7 mb-8 text-left max-w-xl mx-auto shadow-lg shadow-amber-100/60">
          <div class="flex items-start gap-3 mb-4">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-amber-400 text-white font-extrabold text-lg shadow-md">★</div>
            <div>
              <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-amber-700 mb-0.5">Your coach link</div>
              <h2 class="text-lg sm:text-xl font-bold text-gray-900">Invite your clients. Build your ecosystem.</h2>
            </div>
          </div>
          <p class="text-sm text-gray-700 mb-4">
            This is your personal link. Send it to any leadership team you work with — they join under your roof, you get the coach view across all of them. As a Founding 25 coach you keep them in perpetuity, no matter what tier they ever land on later.
          </p>
          <div class="flex flex-col sm:flex-row gap-2 mb-3">
            <input type="text" id="coach-invite-url" value="<%= inviteUrl %>" readonly class="flex-1 px-3 py-2.5 text-sm font-mono text-gray-900 bg-white border border-amber-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-400" />
            <button type="button" onclick="(function(){var i=document.getElementById('coach-invite-url');i.select();document.execCommand('copy');var b=event.target;var t=b.textContent;b.textContent='Copied ✓';setTimeout(function(){b.textContent=t;},1800);})()" class="inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-gray-900 hover:bg-gray-800 text-white text-sm font-semibold whitespace-nowrap">
              Copy link
            </button>
          </div>
          <p class="text-xs text-gray-500">
            Each client gets their own private workspace. You'll see their chart, KPIs, and AI footprint side-by-side in your coach view (rolling out this week).
          </p>
        </div>
      <% } %>

      <div class="flex flex-col sm:flex-row gap-3 justify-center max-w-2xl mx-auto mb-8">
        <a href="/dashboard/practice" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold">
          Open My Practice →
        </a>
        <a href="<%= dashboardUrl %>" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-gray-900 hover:bg-gray-800 text-white font-semibold">
          Edit profile
        </a>
        <a href="<%= publicProfileUrl %>" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-white border-2 border-gray-300 text-gray-900 font-semibold hover:border-gray-400">
          View public profile
        </a>
      </div>

      <!-- Founder Certified Coach badge — downloadable -->
      <div class="bg-white border-2 border-gray-200 rounded-2xl p-6 sm:p-7 max-w-xl mx-auto mb-8 shadow-lg shadow-gray-100/60">
        <div class="grid gap-5 sm:gap-6 sm:grid-cols-[160px,1fr] items-center text-left">
          <div class="flex justify-center sm:justify-start">
            <img src="/public/images/founder-coach-badge-preview.png" alt="OTP Founder Certified Coach Badge" class="w-32 sm:w-40 h-auto" />
          </div>
          <div>
            <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-blue-900 mb-1">Yours to use</div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2">Founder Certified Coach Badge</h3>
            <p class="text-sm text-gray-700 mb-4">
              Put this on your website, in your email signature, or anywhere you want clients to know you're part of the OTP Founding cohort. Yours forever.
            </p>
            <div class="flex flex-wrap gap-2">
              <a href="/public/images/founder-coach-badge.png" download="OTP-Founder-Certified-Coach-Badge.png" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-gray-900 hover:bg-gray-800 text-white text-sm font-semibold">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
                Download PNG
              </a>
              <a href="/public/images/founder-coach-badge-preview.png" download="OTP-Founder-Certified-Coach-Badge-web.png" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-white border-2 border-gray-300 hover:border-gray-400 text-gray-900 text-sm font-semibold">
                Web size
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-left max-w-md mx-auto">
        <div class="text-xs font-bold uppercase tracking-wider text-amber-700 mb-2">Founding 25 perks unlocked</div>
        <ul class="text-sm text-gray-700 space-y-1">
          <li>★ Founder Certified Coach badge (downloadable above)</li>
          <li>★ Badge displayed on your public profile</li>
          <li>★ Roadmap voting (monthly)</li>
          <li>★ Founder cohort Slack + direct vote on the roadmap</li>
          <li>★ Perpetual attribution on every client you bring</li>
        </ul>
      </div>
    <% } %>

  </div>
</section>
