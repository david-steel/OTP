<%# /level-10-meetings -- v7 layout (light, editorial). Google Ads sitelink landing page.
    Sitelink label: "Level 10 Meetings (TM)". Audience: leadership teams running
    a weekly Level 10 Meeting rhythm. Every CTA drives to /sign-up.
    gtagSendEvent onclick preserved (ad conversion). %>
<style>
  .l10-float { animation:l10-float 7.5s ease-in-out infinite; }
  @keyframes l10-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12px);} }
  .l10-glow {
    position:absolute; left:50%; top:52%; width:80%; height:62%;
    transform:translate(-50%,-50%); z-index:0; pointer-events:none;
    background:radial-gradient(ellipse, rgba(10,157,99,0.20), transparent 70%);
  }
  @media (prefers-reduced-motion:reduce){ .l10-float{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1180px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 mb-6"
             style="border-color:var(--orgy-deep); background:rgba(189,214,34,0.14);">
          <span class="tick" style="background:var(--orgy-deep);"></span>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--ink)]">Beta: free forever for your whole team</span>
        </div>
        <div class="eyebrow mb-4">The weekly leadership meeting</div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.3rem,4.8vw,3.8rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
          Run a tighter <span class="text-[var(--green-deep)]">Level 10 Meeting&trade;</span>.
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[36rem] mx-auto md:mx-0 mt-5">
          Same agenda, same time, every week. A 90 minute meeting that starts on time, works the issues that matter, and actually ends on time. OTP gives your leadership team the timed agenda, the live scoreboard, and the issues board in one place.
        </p>
        <div class="flex flex-wrap gap-3 justify-center md:justify-start mt-8">
          <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-primary px-8 py-4 text-[16px]">Run yours on OTP, free &rarr;</a>
        </div>
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--ink-mute)] mt-6">
          Free in beta &nbsp;&middot;&nbsp; No credit card &nbsp;&middot;&nbsp; Whole team included
        </p>
      </div>
      <div class="relative shrink-0" style="width:360px; max-width:64vw;">
        <div class="l10-glow"></div>
        <img src="/public/images/orgy-scoreboard.webp" alt="Orgy reviewing a KPI scorecard"
             class="l10-float relative block w-full" style="z-index:1; filter:drop-shadow(0 22px 34px rgba(20,22,28,.2));">
      </div>
    </div>
  </div>
</section>

<!-- ================= THE AGENDA ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[600px] mx-auto text-center mb-14">
      <div class="eyebrow mb-4">The agenda</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.7rem); font-weight:700;">
        The standard weekly agenda, on the clock.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        Seven segments. 90 minutes. The structure stays the same every week so the team never has to think about format, only about the work.
      </p>
    </div>

    <% const agenda = [
      { mins: '5',  label: 'Segue',                            desc: 'Open the room. Personal best and business best from each person on the team.' },
      { mins: '5',  label: 'Scoreboard review',                desc: 'Walk the weekly KPIs. Every number is on track or off track. No discussion yet.' },
      { mins: '5',  label: 'Rock review',                      desc: 'Quarterly priorities, owner by owner. On track or off track. Off track drops to the issues list.' },
      { mins: '5',  label: 'Customer and Employee Headlines',  desc: 'Quick good news and bad news from customers and the team. Anything bigger drops to issues.' },
      { mins: '5',  label: 'To-Do List',                       desc: 'Run last week\'s to-dos. Done or not done. Anything stuck drops to the issues list.' },
      { mins: '60', label: 'IDS: Identify, Discuss, Solve issues', desc: 'The core of the meeting. Prioritize the list, then identify, discuss, and solve one issue at a time.' },
      { mins: '5',  label: 'Conclude and rate the meeting',    desc: 'Recap new to-dos, confirm messaging to the team, and rate the meeting one to ten.' },
    ]; %>

    <div class="space-y-3">
      <% agenda.forEach(row => { %>
        <div class="card lift flex items-start gap-4 p-5">
          <div class="flex-shrink-0 flex flex-col items-center justify-center w-16 rounded-[11px] border px-2 py-2"
               style="border-color:rgba(10,157,99,0.28); background:rgba(10,157,99,0.07);">
            <span class="font-display text-[1.35rem] font-bold leading-none" style="color:var(--green-deep);"><%= row.mins %></span>
            <span class="font-mono text-[9px] font-semibold uppercase tracking-[0.16em] mt-1" style="color:var(--green);">min</span>
          </div>
          <div>
            <h3 class="font-display text-[1.05rem] font-bold text-[var(--ink)]"><%= row.label %></h3>
            <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7] mt-1"><%= row.desc %></p>
          </div>
        </div>
      <% }); %>
    </div>

    <div class="mt-6 flex items-center justify-between rounded-[16px] border px-6 py-4"
         style="border-color:rgba(10,157,99,0.3); background:linear-gradient(180deg,rgba(10,157,99,.07),var(--card));">
      <span class="font-mono text-[12px] font-semibold uppercase tracking-[0.18em]" style="color:var(--green-deep);">Total</span>
      <span class="font-display text-[1.15rem] font-bold text-[var(--ink)]">90 minutes</span>
    </div>
  </div>
</section>

<!-- ================= IN THE TOOL ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[640px] mx-auto text-center mb-14">
      <div class="eyebrow mb-4">In the tool</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.8rem); font-weight:700;">
        Everything the meeting needs, on one screen.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        No tabs to juggle, no spreadsheets to chase. The agenda, the numbers, and the issues live together.
      </p>
    </div>

    <% const tools = [
      { tag: 'Pace',    label: 'Timed agenda',     desc: 'Each segment runs on a clock. The timer keeps the segue short and protects the 60 minutes for IDS.' },
      { tag: 'Numbers', label: 'Live Scoreboard',  desc: 'The weekly KPIs sit right in the meeting. Walk the numbers without leaving the screen.' },
      { tag: 'Friction',label: 'Issues Board',     desc: 'The full list for IDS. Prioritize the top three, then identify, discuss, and solve in order.' },
      { tag: 'Capture', label: 'To-Dos as you go', desc: 'Capture action items the moment they come up. Each one gets an owner and a due date on the spot.' },
      { tag: 'Quality', label: 'Meeting rating',   desc: 'Close every meeting with a one to ten rating so you can track meeting quality over time.' },
    ]; %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% tools.forEach(t => { %>
        <div class="card lift p-6">
          <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-mute)] mb-3"><%= t.tag %></div>
          <h3 class="font-display text-[1.1rem] font-bold text-[var(--ink)] mb-1.5"><%= t.label %></h3>
          <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7]"><%= t.desc %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= RADAR PREPS THE MEETING ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[920px] mx-auto px-6 py-24 sm:py-28">
    <div class="card p-8 sm:p-11">
      <div class="flex flex-col sm:flex-row items-start gap-7">
        <div class="shrink-0 mx-auto sm:mx-0">
          <img src="/public/hand-1.png" alt="" aria-hidden="true" class="l10-float block" style="width:84px; height:auto; filter:drop-shadow(0 10px 16px rgba(20,22,28,.18));">
        </div>
        <div>
          <div class="eyebrow mb-3" style="color:var(--blue-deep);">Radar preps the meeting</div>
          <h2 class="font-display text-[var(--ink)] leading-[1.15] mb-3"
              style="font-size:clamp(1.5rem,2.8vw,2.1rem); font-weight:700;">
            The meeting starts <span class="text-[var(--blue)]">with current numbers</span>.
          </h2>
          <p class="text-[15.5px] text-[var(--ink-soft)] leading-[1.72]">
            Every OTP account includes Radar, a built-in AI Chief of Staff. Before everyone sits down, Radar pulls the live scoreboard and surfaces the week's issues. The meeting starts on time, on the numbers, instead of ten minutes of "let me find that".
          </p>
          <p class="text-[14px] font-semibold text-[var(--green-deep)] mt-3">
            No add-on. No extra seat fee. Radar comes with every account.
          </p>
          <div class="mt-7">
            <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink inline-flex items-center gap-2 px-7 py-3.5 text-[15px]">
              Get Radar on your team, free &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-7"
         style="background:var(--ink); color:var(--orgy);">
      <span aria-hidden>&#9733;</span>
      <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.18em]">Join in beta = free forever</span>
      <span aria-hidden>&#9733;</span>
    </div>

    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(2rem,4.4vw,3.2rem); font-weight:800;">
      Run your next Level 10 Meeting&trade; on OTP. Free for your whole team.
    </h2>
    <p class="text-[17px] leading-[1.6] max-w-[38rem] mx-auto mt-6" style="color:#5a2a06;">
      OTP is the operating platform for leadership teams that run the EOS&reg; weekly meeting rhythm. Vision Plan, Weekly Scoreboard, Quarterly Priorities, To-Dos, Issues Board, the Leadership Meeting, and Team Chart. Sign up while we're in beta and your whole team stays free for life, grandfathered when paid plans turn on.
    </p>

    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink px-9 py-4 text-[16px]">Create your free account &rarr;</a>
    </div>

    <p class="font-mono text-[11px] uppercase tracking-[0.18em] mt-8" style="color:#7a3a0c;">
      OTP is not affiliated with EOS Worldwide, Ninety, or Bloom Growth.
    </p>
  </div>
</section>
