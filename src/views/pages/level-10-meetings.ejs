<%# /level-10-meetings — Google Ads sitelink landing page.
    Sitelink label: "Level 10 Meetings (TM)".
    Audience: leadership teams running a weekly Level 10 Meeting rhythm.
    Trademark-safe naming; beta framing justifies free pricing.
    Every CTA drives to /sign-up. %>
<style>
  .radar-gradient-gold {
    background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #d4ad32 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
  }

  .feature-tile {
    transition: transform .2s ease, border-color .2s ease, background-color .2s ease;
  }
  .feature-tile:hover {
    transform: translateY(-2px);
    border-color: rgba(212, 173, 50, 0.4);
    background-color: rgba(255, 255, 255, 0.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-tile { animation: none !important; transition: none !important; }
  }
</style>

<!-- =====================================================
     BETA BANNER — solid gold + black text. Free-forever promise.
     ===================================================== -->
<div class="relative w-full" style="background: linear-gradient(90deg, #d4ad32 0%, #f5c84d 35%, #f5c84d 65%, #d4ad32 100%); box-shadow: 0 1px 0 rgba(0,0,0,0.2), 0 4px 16px -4px rgba(212,173,50,0.4);">
  <div class="mx-auto max-w-6xl px-4 py-3 sm:py-3.5 text-center">
    <p class="text-xs sm:text-sm font-extrabold uppercase tracking-[0.18em] text-black flex items-center justify-center flex-wrap gap-x-2 gap-y-1">
      <span class="inline-block px-2 py-0.5 rounded-md bg-black text-amber-300 mr-1">BETA</span>
      <span>Join now = Free forever for your whole team.</span>
      <span class="hidden sm:inline text-black/75 font-bold normal-case tracking-normal">Beta members lock in free pricing before paid plans turn on.</span>
    </p>
  </div>
</div>

<!-- =====================================================
     HERO — the weekly leadership meeting
     ===================================================== -->
<section class="bg-otp-950 relative overflow-hidden pt-16 pb-14 sm:pt-20 sm:pb-20">
  <div class="absolute inset-0 bg-grid opacity-20"></div>
  <div class="absolute top-[-200px] right-[-100px] w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute bottom-[-200px] left-[-100px] w-[500px] h-[500px] bg-blue-500/8 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <p class="text-xs font-bold uppercase tracking-[0.25em] text-amber-400">The weekly leadership meeting</p>

    <h1 class="hero-headline font-extrabold text-white mt-5">
      Run a tighter <span class="radar-gradient-gold">Level 10 Meeting&trade;</span>.
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-base sm:text-lg leading-relaxed text-gray-300">
      Same agenda, same time, every week. A 90 minute meeting that starts on time, works the issues that matter, and actually ends on time. OTP gives your leadership team the timed agenda, the live scoreboard, and the issues board in one place.
    </p>

    <div class="mt-9 flex justify-center">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="group inline-flex items-center gap-2 rounded-xl px-8 py-4 text-base font-bold text-otp-950 transition-transform duration-200 hover:scale-[1.04] active:scale-[0.98]" style="background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #b8941c 100%); box-shadow: 0 0 0 1px rgba(212,173,50,0.4), 0 14px 32px -10px rgba(212,173,50,0.5);">
        <span>Run yours on OTP, free</span>
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <p class="mt-6 text-[11px] uppercase tracking-[0.25em] text-gray-500">
      <span class="text-white">Free in Beta</span> &middot;
      <span class="text-amber-400">No credit card</span> &middot;
      <span class="text-otp-300">Whole team included</span>
    </p>
  </div>
</section>

<!-- =====================================================
     THE AGENDA — timed weekly agenda, vertical row list
     ===================================================== -->
<section class="bg-otp-950 relative py-16 sm:py-24 border-t border-white/5">
  <div class="mx-auto max-w-3xl px-6 sm:px-8">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-amber-400">The agenda</p>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold tracking-tight text-white leading-tight">
        The standard weekly agenda, on the clock.
      </h2>
      <p class="mt-5 text-base text-gray-400">
        Seven segments. 90 minutes. The structure stays the same every week so the team never has to think about format, only about the work.
      </p>
    </div>

    <% const agenda = [
      { mins: '5',  label: 'Segue',                          desc: 'Open the room. Personal best and business best from each person on the team.' },
      { mins: '5',  label: 'Scoreboard review',              desc: 'Walk the weekly KPIs. Every number is on track or off track. No discussion yet.' },
      { mins: '5',  label: 'Rock review',                    desc: 'Quarterly priorities, owner by owner. On track or off track. Off track drops to the issues list.' },
      { mins: '5',  label: 'Customer and Employee Headlines', desc: 'Quick good news and bad news from customers and the team. Anything bigger drops to issues.' },
      { mins: '5',  label: 'To-Do List',                     desc: 'Run last week\'s to-dos. Done or not done. Anything stuck drops to the issues list.' },
      { mins: '60', label: 'IDS: Identify, Discuss, Solve issues', desc: 'The core of the meeting. Prioritize the list, then identify, discuss, and solve one issue at a time.' },
      { mins: '5',  label: 'Conclude and rate the meeting',  desc: 'Recap new to-dos, confirm messaging to the team, and rate the meeting one to ten.' },
    ]; %>

    <ul class="space-y-3">
      <% agenda.forEach(row => { %>
        <li class="feature-tile flex items-start gap-4 rounded-2xl border border-white/10 bg-white/[0.025] p-5">
          <div class="flex-shrink-0 flex flex-col items-center justify-center w-16 rounded-xl border border-amber-400/25 bg-amber-400/[0.06] px-2 py-2">
            <span class="text-xl font-extrabold text-amber-400 leading-none"><%= row.mins %></span>
            <span class="text-[9px] font-bold uppercase tracking-[0.18em] text-amber-400/70 mt-1">min</span>
          </div>
          <div>
            <h3 class="text-base font-bold text-white"><%= row.label %></h3>
            <p class="text-sm text-gray-400 leading-relaxed mt-1"><%= row.desc %></p>
          </div>
        </li>
      <% }); %>
    </ul>

    <div class="mt-6 flex items-center justify-between rounded-2xl border border-amber-400/25 bg-gradient-to-b from-amber-400/[0.06] to-white/[0.02] px-6 py-4">
      <span class="text-sm font-bold uppercase tracking-[0.2em] text-amber-400">Total</span>
      <span class="text-lg font-extrabold text-white">90 minutes</span>
    </div>
  </div>
</section>

<!-- =====================================================
     IN THE TOOL — feature tiles for what OTP gives you
     ===================================================== -->
<section class="bg-otp-950 relative py-16 sm:py-24 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-amber-400">In the tool</p>
      <h2 class="mt-4 text-3xl sm:text-5xl font-bold tracking-tight text-white leading-tight">
        Everything the meeting needs, on one screen.
      </h2>
      <p class="mt-5 text-lg text-gray-400">
        No tabs to juggle, no spreadsheets to chase. The agenda, the numbers, and the issues live together.
      </p>
    </div>

    <% const tools = [
      { icon: '⏱', label: 'Timed agenda',     desc: 'Each segment runs on a clock. The timer keeps the segue short and protects the 60 minutes for IDS.' },
      { icon: '📊', label: 'Live Scoreboard', desc: 'The weekly KPIs sit right in the meeting. Walk the numbers without leaving the screen.' },
      { icon: '⚠',  label: 'Issues Board',     desc: 'The full list for IDS. Prioritize the top three, then identify, discuss, and solve in order.' },
      { icon: '✅', label: 'To-Dos as you go', desc: 'Capture action items the moment they come up. Each one gets an owner and a due date on the spot.' },
      { icon: '★',  label: 'Meeting rating',   desc: 'Close every meeting with a one to ten rating so you can track meeting quality over time.' },
    ]; %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% tools.forEach(t => { %>
        <div class="feature-tile rounded-2xl border border-white/10 bg-white/[0.025] p-5">
          <div class="text-2xl mb-3"><%= t.icon %></div>
          <h3 class="text-base font-bold text-white mb-1.5"><%= t.label %></h3>
          <p class="text-sm text-gray-400 leading-relaxed"><%= t.desc %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- =====================================================
     RADAR PREPS THE MEETING — gold-accent section
     ===================================================== -->
<section class="bg-otp-950 relative py-16 sm:py-24 border-t border-white/5">
  <div class="mx-auto max-w-3xl px-6 sm:px-8">
    <div class="rounded-2xl border border-amber-400/25 bg-gradient-to-b from-amber-400/[0.06] to-white/[0.02] p-7 sm:p-10 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-amber-400 mb-3">Radar preps the meeting</p>
      <h2 class="text-2xl sm:text-4xl font-bold text-white leading-tight">
        The meeting starts <span class="radar-gradient-gold">with current numbers</span>.
      </h2>
      <p class="mt-5 text-base sm:text-lg text-gray-300 leading-relaxed">
        Every OTP account includes Radar, a built-in AI Chief of Staff. Before everyone sits down, Radar pulls the live scoreboard and surfaces the week's issues. The meeting starts on time, on the numbers, instead of ten minutes of "let me find that".
      </p>
      <p class="mt-3 text-sm text-amber-300/90 font-semibold">
        No add-on. No extra seat fee. Radar comes with every account.
      </p>

      <div class="mt-8 flex justify-center">
        <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-bold text-otp-950 transition-transform hover:scale-[1.03]" style="background: linear-gradient(135deg, #d4ad32, #f5c84d);">
          Get Radar on your team, free
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- =====================================================
     FINAL CTA — beta urgency + account creation push
     ===================================================== -->
<section class="bg-otp-950 relative overflow-hidden py-16 sm:py-24 border-t border-white/5">
  <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(212,173,50,0.16), transparent 70%);"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 sm:px-8 text-center">
    <div class="mb-6 flex justify-center">
      <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-otp-950" style="background: linear-gradient(90deg, #d4ad32, #f5c84d, #d4ad32); box-shadow: 0 0 0 1px rgba(212,173,50,0.5), 0 8px 24px -6px rgba(212,173,50,0.45);">
        <span aria-hidden>&starf;</span>
        Join in Beta = Free forever
        <span aria-hidden>&starf;</span>
      </div>
    </div>

    <h2 class="text-3xl sm:text-5xl font-bold tracking-tight text-white leading-tight">
      Run your next Level 10 Meeting&trade; on OTP.<br class="hidden sm:inline" />
      <span class="radar-gradient-gold">Free for your whole team.</span>
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-base sm:text-lg text-gray-300 leading-relaxed">
      OTP is the operating platform for leadership teams that run the EOS&reg; weekly meeting rhythm. Vision Plan, Weekly Scoreboard, Quarterly Priorities, To-Dos, Issues Board, the Leadership Meeting, and Team Chart. Sign up while we're in Beta and your whole team stays free for life, grandfathered when paid plans turn on.
    </p>

    <div class="mt-10 flex justify-center">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="group inline-flex items-center gap-2 rounded-xl px-10 py-4 text-lg font-bold text-otp-950 transition-transform duration-200 hover:scale-[1.04] active:scale-[0.98]" style="background: linear-gradient(135deg, #d4ad32 0%, #f5c84d 50%, #b8941c 100%); box-shadow: 0 0 0 1px rgba(212,173,50,0.5), 0 16px 36px -10px rgba(212,173,50,0.55);">
        <span>Create your free account</span>
        <svg class="h-5 w-5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <p class="mt-8 text-[11px] uppercase tracking-[0.2em] text-gray-500">
      OTP is not affiliated with EOS Worldwide, Ninety, or Bloom Growth.
    </p>
  </div>
</section>
