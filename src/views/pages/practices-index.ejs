<!-- Practices Index Header -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14 pb-10 sm:pb-14">
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
        <span class="px-2 py-0.5 rounded-full bg-otp-500/20 text-otp-300 font-semibold">Playbooks</span>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight">AI Coordination Playbooks by Industry</h1>
      <p class="text-gray-400 mt-4 max-w-lg">Battle-tested coordination practices for AI agent teams. Pick your industry, download a CLAUDE.md, and your agents start working better today.</p>
    </div>
  </div>
</section>

<section class="bg-white py-10 sm:py-14">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <%
      var industryIcons = {
        agency: { color: 'otp', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/>' },
        fitness: { color: 'purple', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>' },
        healthcare: { color: 'emerald', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
        saas: { color: 'amber', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/>' },
        'professional-services': { color: 'indigo', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>' },
        ecommerce: { color: 'rose', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>' },
      };
    %>
    <% if (industries.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% industries.forEach(function(ind) { %>
          <%
            var icon = industryIcons[ind.slug] || { color: 'otp', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-6.548 0c-1.131.094-1.976 1.057-1.976 2.192V16.5A2.25 2.25 0 0012 18.75h.75"/>' };
          %>
          <a href="/practices/<%= ind.slug %>" class="block p-6 rounded-xl border border-gray-100 card-hover group">
            <div class="w-10 h-10 mb-3 rounded-lg bg-<%= icon.color %>-50 border border-<%= icon.color %>-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-<%= icon.color %>-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><%- icon.svg %></svg>
            </div>
            <div class="text-lg font-bold text-gray-900 group-hover:text-otp-600 transition-colors"><%= ind.name %></div>
            <div class="text-sm text-gray-500 mt-2">
              <strong><%= ind.practiceCount %></strong> coordination practices
            </div>
            <div class="mt-3 text-xs text-otp-500 font-medium group-hover:underline">View playbook &rarr;</div>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="text-center py-12 text-gray-400">Practice packs coming soon. <a href="/publish" class="text-otp-500">Be the first to contribute.</a></div>
    <% } %>

    <div class="mt-12 p-6 bg-gray-50 rounded-xl border border-gray-100">
      <h2 class="text-lg font-bold text-gray-900 mb-2">Your industry not listed?</h2>
      <p class="text-gray-600 mb-4">We're adding new industry playbooks every week. Subscribe to get notified when yours is ready.</p>
      <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md">
        <input type="email" name="email" required placeholder="your@email.com"
               class="flex-1 px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500 text-sm">
        <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off">
        <button type="submit" class="px-5 py-2.5 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-all text-sm whitespace-nowrap">Notify Me</button>
      </form>
      <p id="newsletter-result" class="text-sm mt-2 hidden"></p>
    </div>
  </div>
</section>

<script>
document.getElementById('newsletter-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target;
  const email = form.email.value;
  const honeypot = form.website.value;
  const resultEl = document.getElementById('newsletter-result');
  if (honeypot) return;
  try {
    const res = await fetch('/api/v1/newsletter/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, source: 'practices_index' }),
    });
    const data = await res.json();
    resultEl.classList.remove('hidden');
    if (res.ok) {
      resultEl.className = 'text-sm mt-2 text-green-600';
      resultEl.textContent = data.message || "You're in! Check your email to confirm.";
      form.email.value = '';
    } else {
      resultEl.className = 'text-sm mt-2 text-red-600';
      resultEl.textContent = data.error?.message || 'Something went wrong.';
    }
  } catch (e) {
    resultEl.classList.remove('hidden');
    resultEl.className = 'text-sm mt-2 text-red-600';
    resultEl.textContent = 'Network error. Please try again.';
  }
});
</script>
