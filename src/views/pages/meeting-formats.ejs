<%- include('../partials/orgy-palette'); %>
<% /* XSS guard: jsonForScript escapes < and > so an embedded value cannot break out of the <script> context (stored-XSS guard). */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%
  // ---- Custom Meeting Formats (build) ----
  // Auto-injected: memberRole, currentPath, assetVersion, authState.
  // sectionTypes = MEETING_SECTION_TYPES (key/label/description/defaultMinutes).
  // List + builder are driven client-side off /api/v1/meeting-formats.
  var _auth = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _types = (typeof sectionTypes !== 'undefined' && Array.isArray(sectionTypes)) ? sectionTypes : [];
  var _groups = (typeof kpiGroups !== 'undefined' && Array.isArray(kpiGroups)) ? kpiGroups : [];
  var _teams = (typeof mfTeams !== 'undefined' && Array.isArray(mfTeams)) ? mfTeams : [];
  var _templates = (typeof templateIndex !== 'undefined' && Array.isArray(templateIndex)) ? templateIndex : [];
%>
<style>
  .mf-card { border:1px solid #e5e7eb; border-radius:12px; background:#fff; padding:1rem 1.1rem; }
  .mf-badge { display:inline-flex; align-items:center; padding:2px 9px; border-radius:9999px; font-size:10px; font-weight:700; }
  .mf-sec-row { display:flex; align-items:center; gap:6px; padding:6px 8px; border:1px solid #e5e7eb; border-radius:8px; background:#fff; }
  .mf-in { font-size:13px; padding:0.35rem 0.5rem; border:1px solid #e5e7eb; border-radius:6px; }
  .mf-mini { font-size:12px; font-weight:600; color:#6b7280; background:none; border:none; cursor:pointer; padding:2px 6px; border-radius:6px; }
  .mf-mini:hover { background:#f3f4f6; color:#111827; }
  .mf-mini.danger:hover { color:#b91c1c; background:#fef2f2; }
  .mf-btn { font-size:13px; font-weight:600; padding:0.5rem 1rem; border-radius:8px; cursor:pointer; border:none; }
  .mf-btn-primary { background:#2563eb; color:#fff; }
  .mf-btn-ghost { background:#fff; color:#6b7280; border:1px solid #e5e7eb; }
</style>

<div class="max-w-5xl mx-auto px-4 py-8">
  <%- include('../partials/ui-page-header', { helpKey: 'dashboard.meeting-formats', title: 'Meeting formats', eyebrow: 'Meetings', subtitle: 'Build your own meeting agenda once, then run it every time.', mascot: 'mcp-api' }) %>

  <% if (_auth === 'unauthenticated') { %>
    <div class="bg-gray-50 border rounded-xl p-8 text-center">
      <p class="text-gray-600 mb-4">Sign in to build meeting formats.</p>
      <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600">Sign In</a>
    </div>
  <% } else if (_auth === 'no_org') { %>
    <div class="bg-gray-50 border rounded-xl p-8 text-center">
      <p class="text-gray-600 mb-4">Set up your organization first.</p>
      <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600">Go to dashboard</a>
    </div>
  <% } else { %>

    <div class="flex items-center justify-between mb-5 gap-3">
      <p class="text-sm text-gray-500">A format is a reusable agenda: ordered sections with timeboxes. Keep it private or share it with your org.</p>
      <div class="flex items-center gap-2 flex-none">
        <button type="button" id="mf-from-template" class="mf-btn mf-btn-ghost whitespace-nowrap">Start from a template</button>
        <button type="button" id="mf-new" class="mf-btn mf-btn-primary whitespace-nowrap">New format</button>
      </div>
    </div>

    <!-- Template picker (hidden until "Start from a template") -->
    <div id="mf-tpl-panel" class="mf-card" style="display:none; margin-bottom:1.25rem;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:0.6rem;">
        <div style="font-weight:700; color:#111827;">Start from a template <span style="font-weight:400; color:#9ca3af; font-size:12px;">(180+ proven agendas — EOS, Scaling Up, retros, 1:1s, and more)</span></div>
        <button type="button" id="mf-tpl-close" class="mf-mini">Close</button>
      </div>
      <input type="text" id="mf-tpl-search" class="mf-in" placeholder="Search templates…" style="width:100%; margin-bottom:0.6rem;" />
      <div id="mf-tpl-list" style="max-height:340px; overflow-y:auto; display:flex; flex-direction:column; gap:6px;"></div>
    </div>

    <!-- Builder (hidden until New/Edit) -->
    <div id="mf-builder" class="mf-card" style="display:none; margin-bottom:1.25rem;">
      <input type="hidden" id="mf-id" />
      <div style="display:grid; grid-template-columns:1fr 200px; gap:0.75rem; margin-bottom:0.75rem;">
        <label style="display:flex; flex-direction:column; gap:0.25rem; font-size:12px; font-weight:600; color:#374151;">Format name<input id="mf-name" type="text" class="mf-in" placeholder="e.g. Weekly Sales Standup" /></label>
        <label style="display:flex; flex-direction:column; gap:0.25rem; font-size:12px; font-weight:600; color:#374151;">Visibility
          <select id="mf-vis" class="mf-in"><option value="org">Shared with org</option><option value="private">Private (just me)</option></select>
        </label>
      </div>
      <label style="display:flex; flex-direction:column; gap:0.25rem; font-size:12px; font-weight:600; color:#374151; margin-bottom:0.85rem;">Description <span style="font-weight:400;color:#9ca3af;">(optional)</span><textarea id="mf-desc" rows="2" class="mf-in"></textarea></label>

      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.5rem;">
        <div style="font-size:13px; font-weight:700; color:#111827;">Agenda <span id="mf-total" style="font-weight:500; color:#9ca3af;"></span></div>
        <span style="display:flex; gap:6px; align-items:center;">
          <select id="mf-add-type" class="mf-in"></select>
          <button type="button" id="mf-add" class="mf-btn mf-btn-ghost" style="padding:0.35rem 0.7rem;">+ Add section</button>
        </span>
      </div>
      <div style="display:flex; align-items:center; gap:6px; padding:0 8px 4px; font-size:10px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:#9ca3af;">
        <span style="flex:0 0 150px;">Section</span>
        <span style="flex:1;">Title</span>
        <span style="width:64px; text-align:center;">Min</span>
        <span style="flex:1.3;">Notes</span>
        <span style="width:78px;"></span>
      </div>
      <div id="mf-sections" style="display:flex; flex-direction:column; gap:6px;"></div>

      <div style="margin-top:1rem; display:flex; gap:0.5rem;">
        <button type="button" id="mf-save" class="mf-btn mf-btn-primary">Save format</button>
        <button type="button" id="mf-cancel" class="mf-btn mf-btn-ghost">Cancel</button>
      </div>
    </div>

    <div id="mf-list" style="display:flex; flex-direction:column; gap:0.75rem;"><div style="color:#9ca3af; font-size:14px;">Loading…</div></div>

  <% } %>
</div>

<script>
  var MF_TYPES = <%- jsonForScript(_types) %>;
  var MF_GROUPS = <%- jsonForScript(_groups) %>;
  var MF_TEAMS = <%- jsonForScript(_teams) %>;
  var MF_TEMPLATES = <%- jsonForScript(_templates) %>;
  (function() {
    if (!document.getElementById('mf-list')) return;
    var typeByKey = {}; MF_TYPES.forEach(function(t){ typeByKey[t.key] = t; });

    var listEl = document.getElementById('mf-list');
    var builder = document.getElementById('mf-builder');
    var secWrap = document.getElementById('mf-sections');
    var addType = document.getElementById('mf-add-type');
    var totalEl = document.getElementById('mf-total');

    MF_TYPES.forEach(function(t){ var o = document.createElement('option'); o.value = t.key; o.textContent = t.label; addType.appendChild(o); });

    function esc(s){ var d = document.createElement('div'); d.textContent = (s == null ? '' : String(s)); return d.innerHTML; }

    // ----- builder -----
    function bindControl(type, bind) {
      // Options: All + (scorecard -> KPI groups) or (rocks/todos/issues -> teams).
      var opts = [{ v: 'all', l: type === 'scorecard' ? 'All KPIs' : 'All' }];
      if (type === 'scorecard') { MF_GROUPS.forEach(function(g){ opts.push({ v: 'group:' + g, l: 'Group: ' + g }); }); }
      else { MF_TEAMS.forEach(function(tm){ opts.push({ v: 'team:' + tm.id, l: 'Team: ' + tm.name }); }); }
      var cur = 'all';
      if (bind && bind.scope === 'group' && bind.value) cur = 'group:' + bind.value;
      else if (bind && bind.scope === 'team' && bind.value) cur = 'team:' + bind.value;
      var html = '<select class="mf-in mf-bind" style="font-size:12px;">';
      opts.forEach(function(o){ html += '<option value="' + esc(o.v) + '"' + (o.v === cur ? ' selected' : '') + '>' + esc(o.l) + '</option>'; });
      return html + '</select>';
    }
    function sectionRow(sec) {
      var t = typeByKey[sec.type] || { label: sec.type, description: '', dataLinked: false };
      var wrap = document.createElement('div'); wrap.className = 'mf-section'; wrap.dataset.type = sec.type;
      wrap.style.cssText = 'display:flex; flex-direction:column; gap:4px;';
      var row = document.createElement('div'); row.className = 'mf-sec-row';
      row.innerHTML =
        '<span style="flex:0 0 150px; font-size:12px; font-weight:700; color:#374151;" title="' + esc(t.description) + '">' + esc(t.label) + '</span>' +
        '<input class="mf-in mf-title" style="flex:1;" placeholder="Section title" />' +
        '<input class="mf-in mf-min" type="number" min="0" style="width:64px;" title="Minutes" />' +
        '<input class="mf-in mf-notes" style="flex:1.3;" placeholder="Facilitator notes (optional)" />' +
        '<button type="button" class="mf-mini mf-up" title="Move up">↑</button>' +
        '<button type="button" class="mf-mini mf-down" title="Move down">↓</button>' +
        '<button type="button" class="mf-mini danger mf-del" title="Remove">✕</button>';
      row.querySelector('.mf-title').value = sec.title || t.label;
      row.querySelector('.mf-min').value = (sec.minutes != null ? sec.minutes : (t.defaultMinutes || 5));
      row.querySelector('.mf-notes').value = sec.notes || '';
      row.querySelector('.mf-up').addEventListener('click', function(){ if (wrap.previousElementSibling) { secWrap.insertBefore(wrap, wrap.previousElementSibling); recalc(); } });
      row.querySelector('.mf-down').addEventListener('click', function(){ if (wrap.nextElementSibling) { secWrap.insertBefore(wrap.nextElementSibling, wrap); recalc(); } });
      row.querySelector('.mf-del').addEventListener('click', function(){ wrap.remove(); recalc(); });
      row.querySelector('.mf-min').addEventListener('input', recalc);
      wrap.appendChild(row);
      if (t.dataLinked) {
        var bl = document.createElement('div');
        bl.style.cssText = 'display:flex; align-items:center; gap:6px; padding-left:156px;';
        bl.innerHTML = '<span style="font-size:11px; font-weight:600; color:#9ca3af;">Pulls data from:</span>' + bindControl(sec.type, sec.bind);
        wrap.appendChild(bl);
      }
      return wrap;
    }
    function recalc() {
      var total = 0; secWrap.querySelectorAll('.mf-min').forEach(function(i){ var n = Number(i.value); if (!isNaN(n)) total += n; });
      totalEl.textContent = total ? '· ' + total + ' min total' : '';
    }
    function readSections() {
      var out = [];
      secWrap.querySelectorAll('.mf-section').forEach(function(wrap){
        var sec = {
          type: wrap.dataset.type,
          title: wrap.querySelector('.mf-title').value.trim(),
          minutes: Number(wrap.querySelector('.mf-min').value) || 0,
          notes: wrap.querySelector('.mf-notes').value.trim(),
        };
        var bindSel = wrap.querySelector('.mf-bind');
        if (bindSel) {
          var v = bindSel.value;
          if (v && v !== 'all') { var p = v.split(':'); sec.bind = { scope: p[0], value: p.slice(1).join(':') }; }
          else { sec.bind = { scope: 'all' }; }
        }
        out.push(sec);
      });
      return out;
    }
    function openBuilder(fmt) {
      document.getElementById('mf-id').value = (fmt && fmt.id) ? fmt.id : '';
      document.getElementById('mf-name').value = fmt ? (fmt.name || '') : '';
      document.getElementById('mf-desc').value = fmt ? (fmt.description || '') : '';
      document.getElementById('mf-vis').value = fmt ? (fmt.visibility || 'org') : 'org';
      secWrap.innerHTML = '';
      var structure = (fmt && Array.isArray(fmt.structure)) ? fmt.structure : [];
      if (!structure.length && !fmt) { ['segue','scorecard','rocks','headlines','todos','issues','conclude'].forEach(function(k){ secWrap.appendChild(sectionRow({ type: k })); }); }
      else { structure.forEach(function(s){ secWrap.appendChild(sectionRow(s)); }); }
      recalc();
      builder.style.display = 'block';
      builder.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    document.getElementById('mf-new').addEventListener('click', function(){ openBuilder(null); });

    // ----- start from a template -----
    var tplPanel = document.getElementById('mf-tpl-panel');
    var tplList = document.getElementById('mf-tpl-list');
    var tplSearch = document.getElementById('mf-tpl-search');
    function renderTemplates(q) {
      q = (q || '').trim().toLowerCase();
      var items = MF_TEMPLATES.filter(function(t){
        if (!q) return true;
        return ((t.title || '') + ' ' + (t.shortName || '') + ' ' + (t.category || '')).toLowerCase().indexOf(q) > -1;
      }).slice(0, 80);
      if (!items.length) { tplList.innerHTML = '<div style="color:#9ca3af; font-size:13px; padding:8px;">No templates match.</div>'; return; }
      tplList.innerHTML = '';
      items.forEach(function(t){
        var row = document.createElement('button'); row.type = 'button';
        row.style.cssText = 'text-align:left; border:1px solid #e5e7eb; border-radius:8px; background:#fff; padding:8px 10px; cursor:pointer;';
        row.onmouseover = function(){ row.style.background = '#f9fafb'; }; row.onmouseout = function(){ row.style.background = '#fff'; };
        row.innerHTML = '<div style="font-size:13px; font-weight:700; color:#111827;">' + esc(t.shortName || t.title) + '</div>' +
          '<div style="font-size:11px; color:#9ca3af;">' + esc(t.category || '') + (t.minutes ? ' · ' + t.minutes + ' min' : '') + '</div>';
        row.addEventListener('click', function(){ loadTemplate(t.slug); });
        tplList.appendChild(row);
      });
    }
    function loadTemplate(slug) {
      fetch('/api/v1/meeting-formats/template/' + encodeURIComponent(slug), { headers: { 'Accept': 'application/json' } })
        .then(function(r){ if (!r.ok) throw new Error('load failed'); return r.json(); })
        .then(function(d){ tplPanel.style.display = 'none'; openBuilder({ name: d.name, description: d.description, structure: d.structure, visibility: 'org' }); })
        .catch(function(){ alert('Could not load that template.'); });
    }
    document.getElementById('mf-from-template').addEventListener('click', function(){ tplPanel.style.display = 'block'; renderTemplates(''); tplSearch.focus(); tplPanel.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
    document.getElementById('mf-tpl-close').addEventListener('click', function(){ tplPanel.style.display = 'none'; });
    tplSearch.addEventListener('input', function(){ renderTemplates(tplSearch.value); });
    document.getElementById('mf-cancel').addEventListener('click', function(){ builder.style.display = 'none'; });
    document.getElementById('mf-add').addEventListener('click', function(){ secWrap.appendChild(sectionRow({ type: addType.value })); recalc(); });

    document.getElementById('mf-save').addEventListener('click', function(){
      var name = document.getElementById('mf-name').value.trim();
      if (!name) { alert('Give your format a name.'); return; }
      var sections = readSections();
      if (!sections.length) { alert('Add at least one section.'); return; }
      var id = document.getElementById('mf-id').value;
      var body = { name: name, description: document.getElementById('mf-desc').value.trim() || null, visibility: document.getElementById('mf-vis').value, structure: sections };
      OTP.apiSave({
        method: id ? 'PATCH' : 'POST',
        url: '/api/v1/meeting-formats' + (id ? '/' + encodeURIComponent(id) : ''),
        body: body, btnEl: document.getElementById('mf-save'), errorContext: 'Save format',
        onSuccess: function(){ builder.style.display = 'none'; load(); },
      });
    });

    // ----- list -----
    function load() {
      fetch('/api/v1/meeting-formats', { headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.json(); })
        .then(function(d){ render((d && d.formats) || []); })
        .catch(function(){ listEl.innerHTML = '<div style="color:#b91c1c;font-size:14px;">Could not load formats.</div>'; });
    }
    function render(formats) {
      if (!formats.length) { listEl.innerHTML = '<div class="mf-card" style="text-align:center; color:#6b7280;">No formats yet. Click <strong>New format</strong> to build your first agenda.</div>'; return; }
      listEl.innerHTML = '';
      formats.forEach(function(f){
        var structure = Array.isArray(f.structure) ? f.structure : [];
        var mins = structure.reduce(function(s, x){ return s + (Number(x.minutes) || 0); }, 0);
        var card = document.createElement('div'); card.className = 'mf-card';
        var vis = f.visibility === 'private'
          ? '<span class="mf-badge" style="background:#f3f4f6;color:#6b7280;">Private</span>'
          : '<span class="mf-badge" style="background:#eef2ff;color:#3730a3;">Shared</span>';
        card.innerHTML =
          '<div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">' +
            '<div style="min-width:0;">' +
              '<div style="font-weight:700; color:#111827; font-size:16px; display:flex; align-items:center; gap:8px;">' + esc(f.name) + vis + '</div>' +
              (f.description ? '<div style="font-size:13px; color:#6b7280; margin-top:2px;">' + esc(f.description) + '</div>' : '') +
              '<div style="font-size:12px; color:#9ca3af; margin-top:6px;">' + structure.length + ' section' + (structure.length === 1 ? '' : 's') + (mins ? ' · ' + mins + ' min' : '') + '</div>' +
            '</div>' +
            '<div style="display:flex; gap:6px; flex:none; align-items:center;">' +
              '<button type="button" class="mf-btn mf-btn-primary mf-run" style="padding:0.35rem 0.85rem;">Run</button>' +
              '<button type="button" class="mf-mini mf-edit">Edit</button>' +
              '<button type="button" class="mf-mini danger mf-delete">Delete</button>' +
            '</div>' +
          '</div>';
        card.querySelector('.mf-run').addEventListener('click', function(){
          var form = document.createElement('form'); form.method = 'POST'; form.action = '/l8/run-format/' + encodeURIComponent(f.id);
          document.body.appendChild(form); form.submit();
        });
        card.querySelector('.mf-edit').addEventListener('click', function(){ openBuilder(f); });
        card.querySelector('.mf-delete').addEventListener('click', function(){
          if (!confirm('Delete the format "' + f.name + '"? This cannot be undone.')) return;
          OTP.apiSave({ method: 'DELETE', url: '/api/v1/meeting-formats/' + encodeURIComponent(f.id), errorContext: 'Delete format', onSuccess: load });
        });
        listEl.appendChild(card);
      });
    }
    load();
  })();
</script>
