<%# /partners -- v7 layout (light, editorial). OTP Partner Program landing
    + application form. For trusted advisors (EOS Implementers, Scaling Up
    coaches, fractional CXOs, MSPs, AI consultancies, Vistage chairs, etc.).
    Form posts to /api/v1/partner-signup. %>
<style>
  .pt-wave { animation:pt-wave 3.2s ease-in-out infinite; transform-origin:75% 85%; }
  @keyframes pt-wave { 0%,70%,100%{transform:rotate(0);} 80%{transform:rotate(14deg);} 90%{transform:rotate(-6deg);} }
  .pt-tilt { animation:pt-tilt 7s ease-in-out infinite; }
  @keyframes pt-tilt { 0%,100%{transform:translateY(0) rotate(-2deg);} 50%{transform:translateY(-10px) rotate(2deg);} }
  @media (prefers-reduced-motion:reduce){ .pt-wave,.pt-tilt{ animation:none; } }

  /* tier badges */
  .tier-badge {
    width:64px; height:64px; border-radius:16px;
    display:flex; align-items:center; justify-content:center;
    font-family:'Schibsted Grotesk',sans-serif; font-weight:800;
    font-size:22px; letter-spacing:-0.02em; margin-bottom:1.1rem;
  }
  .tier-founding-badge { background:linear-gradient(135deg,var(--orange),var(--orange-deep)); color:#fff; }
  .tier-certified-badge { background:linear-gradient(135deg,var(--blue),var(--blue-deep)); color:#fff; }
  .tier-master-badge { background:linear-gradient(135deg,var(--green),var(--green-deep)); color:#fff; }

  /* form fields -- light */
  .field-label {
    display:block; font-family:'JetBrains Mono',monospace;
    font-size:11px; font-weight:500; letter-spacing:0.06em;
    text-transform:uppercase; color:var(--ink-mute); margin-bottom:6px;
  }
  .field-required::after { content:" *"; color:var(--orange-deep); }
  .field-input {
    width:100%; padding:11px 14px;
    background:var(--card); border:1px solid var(--line);
    border-radius:10px; color:var(--ink);
    font-family:'Inter',sans-serif; font-size:14px;
    transition:border-color 150ms ease, box-shadow 150ms ease;
  }
  .field-input:focus {
    outline:none; border-color:var(--blue);
    box-shadow:0 0 0 3px rgba(13,125,242,0.12);
  }
  .field-input::placeholder { color:var(--ink-mute); }
  textarea.field-input { min-height:104px; resize:vertical; }

  .channel-checkbox {
    display:flex; align-items:center; gap:8px;
    padding:10px 12px; background:var(--card);
    border:1px solid var(--line); border-radius:10px;
    cursor:pointer; transition:border-color 150ms ease, background 150ms ease;
    font-size:13px; color:var(--ink-soft);
  }
  .channel-checkbox:hover { border-color:var(--blue); }
  .channel-checkbox input[type="checkbox"] { accent-color:var(--blue); cursor:pointer; }
  .channel-checkbox:has(input:checked) {
    background:rgba(13,125,242,0.06); border-color:var(--blue);
  }
  .channel-checkbox:has(input:checked) span { color:var(--ink); font-weight:600; }

  .channel-group-label {
    font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:500;
    text-transform:uppercase; letter-spacing:0.12em; color:var(--ink-mute);
    margin-bottom:10px; margin-top:20px;
  }
  .channel-group-label:first-child { margin-top:0; }

  .radio-pill {
    display:inline-flex; align-items:center; gap:6px;
    padding:8px 14px; background:var(--card);
    border:1px solid var(--line); border-radius:999px;
    cursor:pointer; font-size:13px; color:var(--ink-soft);
    transition:border-color 150ms ease, background 150ms ease;
  }
  .radio-pill input { accent-color:var(--blue); }
  .radio-pill:has(input:checked) {
    background:rgba(13,125,242,0.06); border-color:var(--blue); color:var(--ink);
  }

  /* honeypot -- visually hidden but accessible */
  .hp-field { position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden; }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-14">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 mb-6"
             style="border-color:var(--orange-deep); background:rgba(255,122,26,0.10);">
          <span class="tick" style="background:var(--orange);"></span>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:var(--orange-deep);">Founding Partner program is open</span>
        </div>
        <div class="eyebrow mb-4">
          <a href="/" class="link-u" style="border:none;">OTP</a> &nbsp;/&nbsp; Partner Program
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.3rem,4.6vw,3.6rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
          Your clients are about to bring agents in. <span class="text-[var(--orange-deep)]">Be the one who shows them how.</span>
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[38rem] mt-5">
          OTP is the operating layer for organizations that run AI agents alongside humans. Every company you advise is heading there. Most of them don't know it yet.
        </p>
        <p class="text-[15px] text-[var(--ink-soft)] leading-[1.7] max-w-[38rem] mt-4">
          The OTP Partner Program is for the trusted advisors already in those rooms: EOS Implementers, Scaling Up coaches, Vistage chairs, fractional CXOs, MSPs, AI consultancies, agent builders. You bring the trust. We bring the protocol. Your clients get an AI-native operating model with you as the implementation lead.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#apply" class="btn-primary px-8 py-4 text-[16px]">Apply to the program &rarr;</a>
          <a href="/browse" class="btn-ghost px-8 py-4 text-[16px]">Browse the network</a>
        </div>
      </div>
      <div class="relative shrink-0" style="width:230px; max-width:54vw;">
        <img src="/public/orgy-cut.png" alt="Ollie, the OTP mascot"
             class="pt-tilt relative block w-full" style="filter:drop-shadow(0 22px 34px rgba(20,22,28,.2));">
      </div>
    </div>
  </div>
</section>

<!-- ================= WHO THIS IS FOR ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[680px]">
      <div class="eyebrow mb-4">Who this is for</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.12]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        If your clients trust you to fix what's broken about how their company runs, this is your channel.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-5">
        OTP isn't a tool you sell. It's a transformation you lead. Below are the disciplines we're actively recruiting from for the Founding Partner cohort.
      </p>
    </div>

    <% const disciplines = [
      'EOS Implementers (Traction)', 'Scaling Up Coaches', 'Vistage / YPO / EO Forum Chairs',
      'Pinnacle / Petra Coaches', 'Fractional CIOs and CTOs', 'Fractional CMOs and CROs',
      'Fractional COOs and CFOs', 'MSPs and AI Consultancies', 'Systems Integrators',
      'AI Builders and Agent Engineers', 'Automation Specialists', 'Management and Strategy Consultants'
    ]; %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-7 gap-y-2.5 mt-11">
      <% disciplines.forEach(d => { %>
        <div class="flex gap-2.5 text-[14.5px] text-[var(--ink-soft)]">
          <span style="color:var(--orange);">&bull;</span><%= d %>
        </div>
      <% }); %>
    </div>
    <p class="text-[13px] text-[var(--ink-mute)] mt-7">
      Don't see your discipline? Apply anyway and tell us how you fit. We're more interested in the trust you've earned than the title on your card.
    </p>
  </div>
</section>

<!-- ================= THE DEAL ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[640px] mb-12">
      <div class="eyebrow mb-4">The deal</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.8rem); font-weight:700;">
        What you get when you partner with OTP.
      </h2>
    </div>

    <% const deal = [
      { tag: 'Revenue',     label: 'Recurring revenue share',       desc: 'Earn on every client you bring in for as long as they stay subscribed. Founding Partners get the highest rate. Specific structure shared during certification.' },
      { tag: 'Dashboard',   label: 'Multi-tenant partner dashboard', desc: 'Manage every client org from a single login. Switch between accounts, push templates, run audits across your book. Built for advisors with portfolios.' },
      { tag: 'Brand',       label: 'Co-branded onboarding',         desc: 'Your brand alongside OTP in your clients\' first experience. White-label is on the roadmap for Master Integrators.' },
      { tag: 'Access',      label: 'Founder access + partner Slack', desc: 'Direct line to David Steel for strategic conversations. A private Slack for partners to swap intel, share what\'s working with clients, and shape the roadmap.' },
    ]; %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <% deal.forEach(d => { %>
        <div class="card lift p-7">
          <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-mute)] mb-3"><%= d.tag %></div>
          <h3 class="font-display text-[1.25rem] font-bold text-[var(--ink)] mb-2"><%= d.label %></h3>
          <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7]"><%= d.desc %></p>
        </div>
      <% }); %>
    </div>

    <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7] max-w-[42rem] mt-8">
      Plus: early access to the OTP agent runtime, certification training, marketing materials, a Certified OTP Integrator badge, and inclusion in the public partner directory.
    </p>
  </div>
</section>

<!-- ================= THREE TIERS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1180px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[680px] mb-12">
      <div class="eyebrow mb-4">Certification tiers</div>
