        </ul>
        <div class="pt-4" style="border-top:1px solid var(--line);">
          <div class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] mb-1" style="color:var(--green-deep);">How you earn it</div>
          <p class="text-[12.5px] text-[var(--ink-soft)] leading-[1.65]">Five or more live client orgs. One published case study. Active for 6+ months as a Certified Integrator.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ================= APPLICATION FORM ================= -->
<section class="bg-[var(--white)]" id="apply">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28">
    <div class="mb-10">
      <div class="eyebrow mb-4">Apply for the program</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.8rem); font-weight:700;">
        Become a Certified OTP Integrator.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        Tell us about your practice. David personally reviews every application and replies within 3 business days.
      </p>
    </div>

    <form id="partner-application-form" class="space-y-8" novalidate>
      <!-- Honeypot (bots fill this; humans don't see it) -->
      <div class="hp-field" aria-hidden="true">
        <label>Website (leave blank)</label>
        <input type="text" name="website" autocomplete="off" tabindex="-1" />
      </div>

      <!-- About You -->
      <div>
        <h3 class="font-display text-[1.05rem] font-bold text-[var(--ink)] mb-4">About you</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="fullName" class="field-label field-required">Full name</label>
            <input id="fullName" name="fullName" type="text" required maxlength="200" class="field-input" placeholder="Jane Smith" />
          </div>
          <div>
            <label for="email" class="field-label field-required">Email</label>
            <input id="email" name="email" type="email" required maxlength="255" class="field-input" placeholder="jane@yourfirm.com" />
          </div>
          <div>
            <label for="title" class="field-label">Title or role</label>
            <input id="title" name="title" type="text" maxlength="255" class="field-input" placeholder="Founder &amp; EOS Implementer" />
          </div>
          <div>
            <label for="linkedinUrl" class="field-label">LinkedIn URL</label>
            <input id="linkedinUrl" name="linkedinUrl" type="url" maxlength="500" class="field-input" placeholder="https://linkedin.com/in/janesmith" />
          </div>
        </div>
      </div>

      <!-- About Your Practice -->
      <div>
        <h3 class="font-display text-[1.05rem] font-bold text-[var(--ink)] mb-4">About your practice</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label for="companyName" class="field-label field-required">Company name</label>
            <input id="companyName" name="companyName" type="text" required maxlength="255" class="field-input" placeholder="Smith &amp; Associates Consulting" />
          </div>
        </div>

        <div class="mt-5">
          <label class="field-label">Active clients you currently serve</label>
          <div class="flex flex-wrap gap-2">
            <label class="radio-pill"><input type="radio" name="clientCountRange" value="under_5" /> <span>Under 5</span></label>
            <label class="radio-pill"><input type="radio" name="clientCountRange" value="5_to_20" /> <span>5 to 20</span></label>
            <label class="radio-pill"><input type="radio" name="clientCountRange" value="20_to_50" /> <span>20 to 50</span></label>
            <label class="radio-pill"><input type="radio" name="clientCountRange" value="50_plus" /> <span>50+</span></label>
          </div>
        </div>
      </div>

      <!-- Channels / Certifications -->
      <div>
        <h3 class="font-display text-[1.05rem] font-bold text-[var(--ink)] mb-1">How you show up <span style="color:var(--orange-deep);">*</span></h3>
        <p class="text-[12.5px] text-[var(--ink-mute)] mb-5">Select every framework, certification, role, or discipline you currently hold or operate as. Pick all that apply.</p>

        <div class="space-y-1">

          <div class="channel-group-label">Operating systems &amp; frameworks</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="eos_implementer" /> <span>EOS Implementer (Traction)</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="scaling_up_coach" /> <span>Scaling Up Coach</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="pinnacle_petra" /> <span>Pinnacle / Petra Coach</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="okr_lattice" /> <span>OKR / Lattice</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="agile_scrum" /> <span>Agile / Scrum</span></label>
          </div>

          <div class="channel-group-label">Forum &amp; peer-group leaders</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="vistage_chair" /> <span>Vistage Chair</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="ypo_facilitator" /> <span>YPO Forum Facilitator</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="eo_facilitator" /> <span>EO Forum Facilitator</span></label>
          </div>

          <div class="channel-group-label">Fractional CXO</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="fractional_cio" /> <span>Fractional CIO</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="fractional_cto" /> <span>Fractional CTO</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="fractional_cmo" /> <span>Fractional CMO</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="fractional_cfo" /> <span>Fractional CFO</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="fractional_coo" /> <span>Fractional COO</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="fractional_cro" /> <span>Fractional CRO</span></label>
          </div>

          <div class="channel-group-label">Service providers</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="msp" /> <span>MSP (Managed Service Provider)</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="ai_consultancy" /> <span>AI Consultancy</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="systems_integrator" /> <span>Systems Integrator</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="dev_agency" /> <span>Dev Agency</span></label>
          </div>

          <div class="channel-group-label">Builders</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="ai_builder" /> <span>AI Builder / Engineer</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="agent_engineer" /> <span>Agent Engineer</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="automation_specialist" /> <span>Automation (Zapier / Make / n8n)</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="mcp_developer" /> <span>MCP Developer</span></label>
