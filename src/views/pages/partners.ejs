            <label class="channel-checkbox"><input type="checkbox" name="channels" value="ai_builder" /> <span>AI Builder / Engineer</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="agent_engineer" /> <span>Agent Engineer</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="automation_specialist" /> <span>Automation (Zapier / Make / n8n)</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="mcp_developer" /> <span>MCP Developer</span></label>
          </div>

          <div class="channel-group-label">Coaches &amp; consultants</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="business_coach" /> <span>Business Coach</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="management_consultant" /> <span>Management Consultant</span></label>
            <label class="channel-checkbox"><input type="checkbox" name="channels" value="growth_coach" /> <span>Growth Coach</span></label>
