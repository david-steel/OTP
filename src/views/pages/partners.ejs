    <blockquote class="text-xl sm:text-2xl text-gray-100 leading-[1.5] font-light max-w-3xl mb-6">
      "I built OTP because my own company hit the wall everyone is about to hit. Half my team is AI now. The org chart broke. The KPIs broke. The way we coordinate broke. I had to invent the operating layer to fix it. The trusted advisors who get to this first &mdash; the EOS implementers, the fractional CXOs, the AI consultancies &mdash; have a window right now. I'd rather be in business with people I respect than chase scale alone."
    </blockquote>
    <div class="text-sm text-gray-400">&mdash; David Steel, founder of OTP</div>
  </div>
</section>

<!-- FORM HANDLER -->
<script>
(function() {
  var form = document.getElementById('partner-application-form');
  var statusEl = document.getElementById('form-status');
  var submitBtn = document.getElementById('submit-btn');
  var otherCheckbox = document.getElementById('channel-other');
  var otherInput = document.getElementById('otherChannel');

  // Show/hide "Other" text input based on checkbox state
  if (otherCheckbox && otherInput) {
    otherCheckbox.addEventListener('change', function() {
      if (this.checked) {
        otherInput.classList.remove('hidden');
        otherInput.focus();
      } else {
        otherInput.classList.add('hidden');
        otherInput.value = '';
      }
    });
  }

  function showStatus(message, isError) {
    statusEl.textContent = message;
    statusEl.className = 'rounded-lg p-4 text-sm ' + (isError
      ? 'bg-red-500/10 border border-red-500/30 text-red-300'
      : 'bg-emerald-500/10 border border-emerald-500/30 text-emerald-200');
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    statusEl.classList.add('hidden');
    submitBtn.disabled = true;
    var originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Submitting...';

    var formData = new FormData(form);
    var channels = formData.getAll('channels');
    var payload = {
      companyName: (formData.get('companyName') || '').trim(),
      fullName: (formData.get('fullName') || '').trim(),
      email: (formData.get('email') || '').trim(),
      title: (formData.get('title') || '').trim() || null,
      linkedinUrl: (formData.get('linkedinUrl') || '').trim() || null,
      channels: channels,
      otherChannel: (formData.get('otherChannel') || '').trim() || null,
      clientCountRange: formData.get('clientCountRange') || null,
      fitNote: (formData.get('fitNote') || '').trim() || null,
      source: formData.get('source') || 'partners-page',
      website: formData.get('website') || '',
    };

    if (!payload.companyName || !payload.fullName || !payload.email) {
      showStatus('Please fill in your name, email, and company name.', true);
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
      return;
    }
    if (channels.length === 0) {
      showStatus('Pick at least one discipline that describes how you show up.', true);
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
      return;
    }

    try {
      var res = await fetch('/api/v1/partner-signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      var json = await res.json();
      if (!res.ok) {
        showStatus(json.error && json.error.message ? json.error.message : 'Something went wrong. Try again in a minute.', true);
      } else {
        showStatus(json.message || 'Application received.', false);
        form.reset();
        if (otherInput) otherInput.classList.add('hidden');
      }
    } catch (err) {
      showStatus('Network error. Please try again.', true);
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });
})();
</script>
