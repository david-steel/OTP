<%- include('../partials/orgy-palette'); %>
<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/dashboard" class="text-sm text-orgy-blue hover:text-orgy inline-flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Dashboard
    </a>
  </div>

  <h1 class="text-2xl font-bold mb-2"><%= (typeof profile !== 'undefined' && profile) ? 'Edit' : 'Create' %> Consultant Profile</h1>
  <p class="text-gray-500 text-sm mb-6">Set up your public expert profile so others can find and contact you.</p>

  <% if (typeof profile !== 'undefined' && profile && profile.claimed) { %>
    <!-- Coach-only banner: link to the new Practice dashboard. Only show
         once the profile is claimed (the user is a real coach). -->
    <a href="/dashboard/practice" class="block mb-8 group">
      <div class="flex items-center gap-4 p-4 rounded-xl bg-gradient-to-r from-amber-50 to-orange-50 border-2 border-amber-300 hover:border-amber-400 transition-all hover:shadow-md">
        <div class="flex-shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-amber-400 text-white font-extrabold text-lg shadow-md">★</div>
        <div class="flex-1 min-w-0">
          <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-amber-700">Founder Certified Coach</div>
          <div class="text-sm sm:text-base font-bold text-gray-900">My Practice — your clients, side-by-side</div>
          <div class="text-xs text-gray-600 mt-0.5">Share your invite link and see every leadership team you bring in one place.</div>
        </div>
        <div class="flex-shrink-0 text-amber-700 group-hover:translate-x-0.5 transition-transform" aria-hidden>→</div>
      </div>
    </a>
  <% } %>

  <form id="consultant-form" class="space-y-6">
    <!-- Slug -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Profile Slug</label>
      <div class="flex items-center gap-2">
        <span class="text-sm text-gray-400">/expert/</span>
        <input type="text" name="slug" value="<%= (typeof profile !== 'undefined' && profile && profile.slug) ? profile.slug : '' %>" required class="flex-1 border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="your-name" pattern="[a-z0-9\-]+" title="Lowercase letters, numbers, and hyphens only">
      </div>
      <p class="text-xs text-gray-400 mt-1">Lowercase letters, numbers, and hyphens only. This is your public URL.</p>
    </div>

    <!-- Display Name -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
      <input type="text" name="display_name" value="<%= (typeof profile !== 'undefined' && profile && profile.display_name) ? profile.display_name : '' %>" required class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="Your Name">
    </div>

    <!-- Profile Photo (upload + crop/move) -->
    <% var _avatar = (typeof profile !== 'undefined' && profile && (profile.avatar_url || profile.photo_url)) ? (profile.avatar_url || profile.photo_url) : ''; %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Profile Photo</label>
      <input type="hidden" name="photo_url" id="photo-url-input" value="<%= _avatar %>">
      <div class="flex items-center gap-4">
        <div id="avatar-preview" class="h-20 w-20 rounded-full bg-gray-100 border border-gray-200 overflow-hidden flex items-center justify-center text-gray-400 text-2xl font-bold shrink-0">
          <% if (_avatar) { %><img src="<%= _avatar %>" alt="" class="h-full w-full object-cover"><% } else { %><span>+</span><% } %>
        </div>
        <div class="flex flex-col gap-1.5">
          <button type="button" id="photo-upload-btn" class="text-xs px-3 py-1.5 bg-orgy-blue text-white rounded-lg font-semibold hover:bg-orgy-blue-deep w-max">Upload &amp; crop photo</button>
          <button type="button" id="photo-remove-btn" class="text-xs text-gray-500 hover:text-rose-600 text-left <%= _avatar ? '' : 'hidden' %>">Remove photo</button>
          <p class="text-[11px] text-gray-400">Square works best. Drag to reposition and zoom before saving.</p>
        </div>
      </div>
      <input type="file" id="photo-file" accept="image/*" class="hidden">

      <!-- Crop / move editor (hidden until an image is chosen) -->
      <div id="photo-editor" class="hidden mt-3 border rounded-lg p-3 bg-gray-50">
        <div id="crop-frame" style="position:relative; width:220px; height:220px; margin:0 auto; overflow:hidden; border-radius:9999px; background:#e5e7eb; cursor:move; touch-action:none;">
          <img id="crop-img" alt="" draggable="false" style="position:absolute; left:0; top:0; user-select:none; -webkit-user-drag:none; max-width:none;">
        </div>
        <div class="flex items-center gap-2 mt-3">
          <span class="text-xs text-gray-500">Zoom</span>
          <input type="range" id="crop-zoom" min="1" max="3" step="0.01" value="1" class="flex-1">
        </div>
        <div class="flex gap-2 mt-3 justify-end">
          <button type="button" id="crop-cancel" class="text-xs px-3 py-1.5 bg-gray-200 rounded-lg hover:bg-gray-300">Cancel</button>
          <button type="button" id="crop-apply" class="text-xs px-3 py-1.5 bg-orgy-blue text-white rounded-lg font-semibold hover:bg-orgy-blue-deep">Apply</button>
        </div>
      </div>

      <details class="mt-2">
        <summary class="text-[11px] text-gray-400 cursor-pointer">or paste an image URL</summary>
        <input type="url" id="photo-url-text" value="<%= (_avatar && _avatar.indexOf('data:') !== 0) ? _avatar : '' %>" class="w-full mt-1 border rounded-lg px-3 py-2 text-sm" placeholder="https://example.com/photo.jpg">
      </details>
      <p class="text-xs text-gray-400 mt-1">Leave blank to show your initials.</p>
    </div>

    <!-- Bio -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Bio</label>
      <textarea name="bio" rows="4" class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none resize-none" placeholder="Tell people about your expertise, experience, and what you help organizations with."><%= (typeof profile !== 'undefined' && profile && profile.bio) ? profile.bio : '' %></textarea>
    </div>

    <!-- Expertise Tags -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Expertise Tags</label>
      <input type="text" name="expertise_tags" value="<%= (typeof profile !== 'undefined' && profile && profile.expertise_tags) ? profile.expertise_tags.join(', ') : '' %>" class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="AI Agents, Digital Marketing, Operations">
      <p class="text-xs text-gray-400 mt-1">Comma-separated. These appear as filterable tags on your profile.</p>
    </div>

    <!-- Contact Email -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Contact Email</label>
      <input type="email" name="contact_email" value="<%= (typeof profile !== 'undefined' && profile && profile.contact_email) ? profile.contact_email : '' %>" required class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="you@company.com">
      <p class="text-xs text-gray-400 mt-1">Where inquiries from the contact form will be sent. Not displayed publicly.</p>
    </div>

    <!-- Links -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Website URL</label>
        <input type="url" name="website_url" value="<%= (typeof profile !== 'undefined' && profile && profile.website_url) ? profile.website_url : '' %>" class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="https://yoursite.com">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">LinkedIn URL</label>
        <input type="url" name="linkedin_url" value="<%= (typeof profile !== 'undefined' && profile && profile.linkedin_url) ? profile.linkedin_url : '' %>" class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="https://linkedin.com/in/yourname">
      </div>
    </div>

    <!-- Publish Toggle -->
    <div class="flex items-center gap-3 bg-gray-50 p-4 rounded-lg">
      <input type="checkbox" name="published" id="published" class="w-4 h-4 text-orgy-blue border-gray-300 rounded focus:ring-orgy-blue" <%= (typeof profile !== 'undefined' && profile && profile.published) ? 'checked' : '' %>>
      <label for="published" class="text-sm font-medium text-gray-700">Publish profile</label>
      <span class="text-xs text-gray-400">When enabled, your profile is visible in the expert directory.</span>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between pt-2">
      <div id="form-status" class="text-sm"></div>
      <button type="submit" id="save-btn" class="px-6 py-2.5 bg-orgy-blue text-white rounded-lg font-medium text-sm hover:bg-orgy-blue-deep transition-colors">
        <%= (typeof profile !== 'undefined' && profile) ? 'Save Changes' : 'Create Profile' %>
      </button>
    </div>
  </form>
</div>

<script>
document.getElementById('consultant-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('save-btn');
  var status = document.getElementById('form-status');
  var form = this;
  btn.disabled = true;
  btn.textContent = 'Saving...';
  status.textContent = '';
  status.className = 'text-sm';

  var tagsRaw = form.expertise_tags.value;
  var tags = tagsRaw ? tagsRaw.split(',').map(function(t) { return t.trim(); }).filter(Boolean) : [];

  var payload = {
    slug: form.slug.value.trim(),
    displayName: form.display_name.value.trim(),
    avatarUrl: form.photo_url.value.trim() || undefined,
    bio: form.bio.value.trim() || undefined,
    expertiseTags: tags,
    contactEmail: form.contact_email.value.trim() || undefined,
    website: form.website_url.value.trim() || undefined,
    linkedinUrl: form.linkedin_url.value.trim() || undefined,
    published: form.published.checked
  };

  var isEdit = <%= (typeof profile !== 'undefined' && profile) ? 'true' : 'false' %>;
  var method = isEdit ? 'PUT' : 'POST';
  var url = '/api/v1/consultants/profile';

  try {
    var res = await fetch(url, {
      method: method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    if (res.ok) {
      status.textContent = 'Saved successfully.';
      status.className = 'text-sm text-green-600';
      if (!isEdit) {
        window.location.href = '/dashboard/consultant';
      }
    } else {
      var data = await res.json().catch(function() { return {}; });
      var errMsg = 'Failed to save.';
      if (data.error && data.error.message) errMsg = data.error.message;
      else if (data.error && data.error.details) errMsg = data.error.details.map(function(d) { return d.message; }).join(', ');
      else if (typeof data.error === 'string') errMsg = data.error;
      throw new Error(errMsg);
    }
  } catch (err) {
    status.textContent = err.message;
    status.className = 'text-sm text-red-600';
  }
  btn.disabled = false;
  btn.textContent = isEdit ? 'Save Changes' : 'Create Profile';
});
</script>

<script>
// Profile photo: upload -> drag to reposition + zoom -> Apply crops a square
// to a 256x256 data URL stored in the hidden #photo-url-input (submitted as
// avatarUrl). No server storage needed -- it rides in the existing text column.
(function() {
  var hidden = document.getElementById('photo-url-input');
  if (!hidden) return;
  var preview = document.getElementById('avatar-preview');
  var fileInput = document.getElementById('photo-file');
  var uploadBtn = document.getElementById('photo-upload-btn');
  var removeBtn = document.getElementById('photo-remove-btn');
  var editor = document.getElementById('photo-editor');
  var frame = document.getElementById('crop-frame');
  var img = document.getElementById('crop-img');
  var zoom = document.getElementById('crop-zoom');
  var applyBtn = document.getElementById('crop-apply');
  var cancelBtn = document.getElementById('crop-cancel');
  var urlText = document.getElementById('photo-url-text');

  var F = 220, OUT = 256;
  var natW = 0, natH = 0, baseScale = 1, left = 0, top = 0;

  function dispW() { return natW * baseScale * parseFloat(zoom.value); }
  function dispH() { return natH * baseScale * parseFloat(zoom.value); }
  function paint() {
    img.style.width = dispW() + 'px';
    img.style.height = dispH() + 'px';
    img.style.left = left + 'px';
    img.style.top = top + 'px';
  }
  function clamp() {
    var dw = dispW(), dh = dispH();
    if (left > 0) left = 0;
    if (top > 0) top = 0;
    if (left < F - dw) left = F - dw;
    if (top < F - dh) top = F - dh;
  }
  function setPreview(src) {
    preview.innerHTML = '';
    var im = document.createElement('img');
    im.src = src; im.alt = '';
    im.className = 'h-full w-full object-cover';
    preview.appendChild(im);
    if (removeBtn) removeBtn.classList.remove('hidden');
  }

  if (uploadBtn) uploadBtn.addEventListener('click', function() { fileInput.click(); });
  if (fileInput) fileInput.addEventListener('change', function() {
    var f = fileInput.files && fileInput.files[0];
    if (!f) return;
    if (f.size > 8 * 1024 * 1024) { alert('Image is too large (max 8MB). Try a smaller file.'); fileInput.value = ''; return; }
    var reader = new FileReader();
    reader.onload = function(ev) {
      img.onload = function() {
        natW = img.naturalWidth; natH = img.naturalHeight;
        if (!natW || !natH) { alert('Could not read that image.'); return; }
        baseScale = F / Math.min(natW, natH); // cover the frame
        zoom.value = 1;
        left = (F - dispW()) / 2; top = (F - dispH()) / 2;
        paint();
        editor.classList.remove('hidden');
      };
      img.src = ev.target.result;
    };
    reader.readAsDataURL(f);
  });

  // Drag to pan (mouse + touch)
  var dragging = false, sx = 0, sy = 0, sl = 0, st = 0;
  function pt(e) { var t = e.touches && e.touches[0]; return { x: t ? t.clientX : e.clientX, y: t ? t.clientY : e.clientY }; }
  function down(e) { dragging = true; var p = pt(e); sx = p.x; sy = p.y; sl = left; st = top; e.preventDefault(); }
  function move(e) { if (!dragging) return; var p = pt(e); left = sl + (p.x - sx); top = st + (p.y - sy); clamp(); paint(); }
  function up() { dragging = false; }
  if (frame) {
    frame.addEventListener('mousedown', down);
    frame.addEventListener('touchstart', down, { passive: false });
  }
  window.addEventListener('mousemove', move);
  window.addEventListener('mouseup', up);
  window.addEventListener('touchmove', move, { passive: false });
  window.addEventListener('touchend', up);

  if (zoom) zoom.addEventListener('input', function() {
    // zoom around the frame center so it feels stable
    var c = F / 2;
    var dwOld = img.offsetWidth || dispW(), dhOld = img.offsetHeight || dispH();
    var fx = dwOld ? (c - left) / dwOld : 0.5;
    var fy = dhOld ? (c - top) / dhOld : 0.5;
    var dwNew = dispW(), dhNew = dispH();
    left = c - fx * dwNew; top = c - fy * dhNew;
    clamp(); paint();
  });

  if (cancelBtn) cancelBtn.addEventListener('click', function() { editor.classList.add('hidden'); fileInput.value = ''; });

  if (applyBtn) applyBtn.addEventListener('click', function() {
    var fr = frame.getBoundingClientRect();
    var ir = img.getBoundingClientRect();
    if (!ir.width || !ir.height) return;
    var sxr = natW / ir.width, syr = natH / ir.height;
    var srcX = (fr.left - ir.left) * sxr;
    var srcY = (fr.top - ir.top) * syr;
    var srcW = fr.width * sxr;
    var srcH = fr.height * syr;
    var canvas = document.createElement('canvas');
    canvas.width = OUT; canvas.height = OUT;
    var ctx = canvas.getContext('2d');
    try {
      ctx.drawImage(img, srcX, srcY, srcW, srcH, 0, 0, OUT, OUT);
      var dataUrl = canvas.toDataURL('image/jpeg', 0.85);
      hidden.value = dataUrl;
      if (urlText) urlText.value = '';
      setPreview(dataUrl);
    } catch (err) { alert('Could not crop that image: ' + err.message); }
    editor.classList.add('hidden');
    fileInput.value = '';
  });

  if (removeBtn) removeBtn.addEventListener('click', function() {
    hidden.value = '';
    if (urlText) urlText.value = '';
    preview.innerHTML = '<span class="text-gray-400 text-2xl font-bold">+</span>';
    removeBtn.classList.add('hidden');
    editor.classList.add('hidden');
  });

  if (urlText) urlText.addEventListener('input', function() {
    var v = urlText.value.trim();
    hidden.value = v;
    if (v) setPreview(v);
  });
})();
</script>
