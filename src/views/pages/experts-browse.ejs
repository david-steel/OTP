<%# /experts -- v7 layout (light, editorial). Operating-system coach directory.
    Content sections only -- layout supplies head/nav/footer. %>
<%
  // experts: array of consultant_profiles rows (camelCase columns from cp.*)
  // counts: { total, claimed, eos }
%>
<style>
  .ex-wave { animation:ex-wave 3.4s ease-in-out infinite; transform-origin:72% 88%; }
  @keyframes ex-wave { 0%,68%,100%{transform:rotate(0);} 80%{transform:rotate(15deg);} 90%{transform:rotate(-7deg);} }
  @media (prefers-reduced-motion:reduce){ .ex-wave{ animation:none; } }
  .ex-input, .ex-select {
    font-family:'Inter',sans-serif; font-size:13px;
    color:var(--ink); background:var(--card);
    border:1px solid var(--line); border-radius:9px;
    padding:9px 12px; transition:border-color .15s ease;
  }
  .ex-select { font-family:'JetBrains Mono',monospace; font-size:12px; }
  .ex-input::placeholder { color:var(--ink-mute); }
  .ex-input:focus, .ex-select:focus { outline:none; border-color:var(--blue); }
  .ex-badge {
    font-family:'JetBrains Mono',monospace; font-size:9.5px; font-weight:600;
    letter-spacing:0.05em; text-transform:uppercase;
    padding:3px 8px; border-radius:6px; border:1px solid;
  }
  .ex-prose a { color:var(--blue-deep); font-weight:600; border-bottom:1.5px solid currentColor; }
</style>

<!-- ================= HERO + FILTERS ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-12 sm:pt-[148px] sm:pb-14">

    <div class="flex flex-col-reverse md:flex-row items-start gap-8 md:gap-12">
      <div class="flex-1">
        <div class="eyebrow mb-4 flex items-center gap-2.5">
          <span class="tick" style="background:var(--green);"></span>Directory
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2rem,4.2vw,3.2rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
          Operating-System <span class="text-[var(--blue)]">Coach Directory</span>.
        </h1>
        <p class="font-mono text-[12.5px] text-[var(--ink-mute)] mt-4">
          <%= counts.total %> coaches listed
          <% if (counts.eos > 0) { %> &middot; <%= counts.eos %> operating-system coaches<% } %>
          <% if (counts.claimed > 0) { %> &middot; <%= counts.claimed %> claimed<% } %>
        </p>
        <p class="ex-prose text-[15px] sm:text-[16px] text-[var(--ink-soft)] leading-[1.65] max-w-[42rem] mt-4">
          Public directory of operating-system coaches and consultants, including business coaches and OTP-native publishers. Coaches can <a href="/for-coaches">claim their profile</a> to add bio, services, calendar, and published coordination intelligence.
        </p>
        <div class="mt-6">
          <a href="/for-coaches" class="btn-primary inline-block px-6 py-3 text-[15px]">Are you a coach? Claim your profile &rarr;</a>
        </div>
      </div>
      <div class="shrink-0 self-center md:self-start" style="width:96px; max-width:26vw;">
        <img src="/public/hand-3.png" alt="" aria-hidden="true"
             class="ex-wave block w-full" style="filter:drop-shadow(0 12px 20px rgba(20,22,28,.15));">
      </div>
    </div>

    <!-- Filters -->
    <div class="card p-4 sm:p-5 mt-10 flex gap-3 flex-wrap items-center">
      <div class="flex-1 min-w-[200px]">
        <input type="text" id="filter-search" placeholder="Search by name, city, or framework..." class="ex-input w-full">
      </div>
      <select id="filter-source" class="ex-select">
        <option value="">All listings</option>
        <option value="eosworldwide">Operating-system coaches</option>
        <option value="otp">OTP Publishers</option>
        <option value="claimed">Claimed only</option>
      </select>
      <select id="filter-country" class="ex-select">
        <option value="">All countries</option>
      </select>
    </div>
  </div>
</section>

<!-- ================= CARDS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-16 sm:py-20">

    <div id="experts-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% if (typeof experts !== 'undefined' && experts.length > 0) { %>
        <% experts.forEach(function(e) {
          var isEOS = e.directory_source === 'eosworldwide';
          var isClaimed = e.claimed === true;
          var locParts = [e.geo_city, e.geo_state, e.geo_country].filter(Boolean);
          var locStr = locParts.join(', ');
          var sourceTag = isEOS ? 'eosworldwide' : (e.directory_source || 'otp');
          var claimTag = isClaimed ? 'claimed' : 'unclaimed';
        %>
          <a href="/expert/<%= e.slug %>"
             class="card lift p-5 block"
             data-name="<%= (e.display_name || '').toLowerCase() %>"
             data-city="<%= (e.geo_city || '').toLowerCase() %>"
             data-country="<%= (e.geo_country || '') %>"
             data-source="<%= sourceTag %>"
             data-claim="<%= claimTag %>">
            <div class="flex items-start gap-3.5">
              <% if (e.photo_url) { %>
                <img src="<%= e.photo_url %>" alt="<%= e.display_name %>" loading="lazy" class="w-14 h-14 rounded-full object-cover shrink-0">
              <% } else { %>
                <div class="w-14 h-14 rounded-full text-white flex items-center justify-center text-lg font-bold shrink-0 font-display"
                     style="background:linear-gradient(135deg,var(--blue),var(--blue-deep));">
                  <%= (e.display_name || '?').charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <div class="flex-1 min-w-0">
                <div class="font-display font-bold text-[15px] text-[var(--ink)] truncate"><%= e.display_name %></div>
                <% if (locStr) { %>
                  <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-0.5 truncate"><%= locStr %></div>
                <% } %>
                <% if (e.headline) { %>
                  <p class="text-[12.5px] text-[var(--ink-soft)] leading-[1.5] mt-1.5 line-clamp-2"><%= e.headline %></p>
                <% } %>
              </div>
            </div>

            <!-- Source / claim badges -->
            <div class="flex flex-wrap gap-1.5 mt-3.5">
              <% if (isEOS) { %>
                <span class="ex-badge" style="background:rgba(13,125,242,0.08);color:var(--blue-deep);border-color:rgba(13,125,242,0.2);">Operating-System Coach</span>
              <% } else if (sourceTag === 'otp') { %>
                <span class="ex-badge" style="background:rgba(168,230,58,0.18);color:var(--orgy-deep);border-color:rgba(139,196,42,0.4);">OTP Publisher</span>
              <% } %>
              <% if (isClaimed) { %>
                <span class="ex-badge" style="background:rgba(10,157,99,0.1);color:var(--green-deep);border-color:rgba(10,157,99,0.28);">Claimed</span>
              <% } else if (e.directory_source) { %>
                <span class="ex-badge" style="background:var(--grey);color:var(--ink-mute);border-color:var(--line);">Directory listing</span>
              <% } %>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="col-span-full card p-12 sm:p-16 text-center">
          <div class="font-display text-[1.2rem] font-bold text-[var(--ink)] mb-2">No coaches in the directory yet.</div>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.6]">
            If you are a coach, <a href="/for-coaches" class="text-[var(--blue-deep)] font-semibold link-u">claim your profile</a>.
          </p>
        </div>
      <% } %>
    </div>

    <div id="experts-more-wrap" class="mt-8 text-center" style="display:none;">
      <button id="experts-more" type="button" class="card lift p-5" style="cursor:pointer;font-weight:600;border:1px solid var(--line);background:var(--white);">
        Show more coaches
      </button>
      <div id="experts-count" class="font-mono text-[11px] text-[var(--ink-mute)] mt-3"></div>
    </div>

    <!-- Trademark + sourcing footer -->
    <div class="ex-prose mt-14 pt-7 border-t border-[var(--line)] text-[12.5px] text-[var(--ink-mute)] leading-[1.65] max-w-[44rem]">
      <p class="mb-2">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[var(--ink-soft)]">Listings.</span>
        This is a public directory of operating-system coaches and consultants. Listings are factual references to publicly available coach profiles and do not imply endorsement in either direction. Coaches can <a href="/for-coaches">claim their listing</a> to control the content shown, or <a href="/tickets?type=takedown">request removal</a>. OTP and Sneeze It are an independent product and are not affiliated with, endorsed by, or sponsored by any operating-system framework or its provider.
      </p>
    </div>
  </div>
</section>

<script>
(function() {
  // Full directory as compact JSON; the server renders only the first batch
  // of cards as HTML (page weight). Filters search ALL profiles and the grid
  // is re-materialized client-side in batches.
  var ALL = <%- expertsLiteJson %>;
  var BATCH = 60;
  var grid = document.getElementById('experts-grid');
  var search = document.getElementById('filter-search');
  var sourceSel = document.getElementById('filter-source');
  var countrySel = document.getElementById('filter-country');
  var moreWrap = document.getElementById('experts-more-wrap');
  var moreBtn = document.getElementById('experts-more');
  var countEl = document.getElementById('experts-count');

  // Populate country filter from the FULL dataset.
  var countrySet = {};
  ALL.forEach(function(e) { if (e.co) countrySet[e.co] = (countrySet[e.co] || 0) + 1; });
  Object.keys(countrySet).sort().forEach(function(co) {
    var opt = document.createElement('option');
    opt.value = co;
    opt.textContent = co + ' (' + countrySet[co] + ')';
    countrySel.appendChild(opt);
  });

  function el(tag, cls, style, text) {
    var n = document.createElement(tag);
    if (cls) n.className = cls;
    if (style) n.setAttribute('style', style);
    if (text != null) n.textContent = text;
    return n;
  }

  function badge(text, style) {
    return el('span', 'ex-badge', style, text);
  }

  function renderCard(e) {
    var srcTag = e.ds === 'eosworldwide' ? 'eosworldwide' : (e.ds || 'otp');
    var a = el('a', 'card lift p-5 block');
    a.href = '/expert/' + encodeURIComponent(e.s);

    var row = el('div', 'flex items-start gap-3.5');
    if (e.p) {
      var img = el('img', 'w-14 h-14 rounded-full object-cover shrink-0');
      img.src = e.p; img.alt = e.n; img.loading = 'lazy';
      row.appendChild(img);
    } else {
      row.appendChild(el('div',
        'w-14 h-14 rounded-full text-white flex items-center justify-center text-lg font-bold shrink-0 font-display',
        'background:linear-gradient(135deg,var(--blue),var(--blue-deep));',
        (e.n || '?').charAt(0).toUpperCase()));
    }
    var body = el('div', 'flex-1 min-w-0');
    body.appendChild(el('div', 'font-display font-bold text-[15px] text-[var(--ink)] truncate', null, e.n));
    var loc = [e.c, e.st, e.co].filter(Boolean).join(', ');
    if (loc) body.appendChild(el('div', 'font-mono text-[11px] text-[var(--ink-mute)] mt-0.5 truncate', null, loc));
    if (e.h) body.appendChild(el('p', 'text-[12.5px] text-[var(--ink-soft)] leading-[1.5] mt-1.5 line-clamp-2', null, e.h));
    row.appendChild(body);
    a.appendChild(row);

    var badges = el('div', 'flex flex-wrap gap-1.5 mt-3.5');
    if (srcTag === 'eosworldwide') {
      badges.appendChild(badge('Operating-System Coach', 'background:rgba(13,125,242,0.08);color:var(--blue-deep);border-color:rgba(13,125,242,0.2);'));
    } else if (srcTag === 'otp') {
      badges.appendChild(badge('OTP Publisher', 'background:rgba(168,230,58,0.18);color:var(--orgy-deep);border-color:rgba(139,196,42,0.4);'));
    }
    if (e.cl) {
      badges.appendChild(badge('Claimed', 'background:rgba(10,157,99,0.1);color:var(--green-deep);border-color:rgba(10,157,99,0.28);'));
    } else if (e.ds) {
      badges.appendChild(badge('Directory listing', 'background:var(--grey);color:var(--ink-mute);border-color:var(--line);'));
    }
    a.appendChild(badges);
    return a;
  }

  function matches(e, q, src, co) {
    var srcTag = e.ds === 'eosworldwide' ? 'eosworldwide' : (e.ds || 'otp');
    var matchSearch = !q
      || (e.n || '').toLowerCase().indexOf(q) !== -1
      || (e.c || '').toLowerCase().indexOf(q) !== -1;
    var matchSource = !src
      || (src === 'claimed' && e.cl === 1)
      || (src === srcTag);
    var matchCountry = !co || e.co === co;
    return matchSearch && matchSource && matchCountry;
  }

  var filtered = ALL;
  var shown = grid.querySelectorAll('a.card').length; // server-rendered batch

  function updateMore() {
    var remaining = filtered.length - shown;
    moreWrap.style.display = remaining > 0 ? '' : 'none';
    if (remaining > 0) moreBtn.textContent = 'Show more coaches (' + remaining + ' more)';
    countEl.textContent = 'Showing ' + Math.min(shown, filtered.length) + ' of ' + filtered.length;
    countEl.style.display = '';
  }

  function appendBatch() {
    var frag = document.createDocumentFragment();
    var next = filtered.slice(shown, shown + BATCH);
    next.forEach(function(e) { frag.appendChild(renderCard(e)); });
    grid.appendChild(frag);
    shown += next.length;
    updateMore();
  }

  function applyFilter() {
    var q = (search.value || '').toLowerCase().trim();
    var src = sourceSel.value;
    var co = countrySel.value;
    filtered = ALL.filter(function(e) { return matches(e, q, src, co); });
    grid.innerHTML = '';
    shown = 0;
    if (filtered.length === 0) {
      var empty = el('div', 'col-span-full card p-12 text-center', null, 'No coaches match that filter.');
      grid.appendChild(empty);
      moreWrap.style.display = 'none';
      countEl.textContent = '';
      return;
    }
    appendBatch();
  }

  moreBtn.addEventListener('click', appendBatch);
  search.addEventListener('input', applyFilter);
  sourceSel.addEventListener('change', applyFilter);
  countrySel.addEventListener('change', applyFilter);
  updateMore();
})();
</script>
