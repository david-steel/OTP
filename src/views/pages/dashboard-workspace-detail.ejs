<%- include('../partials/orgy-palette'); %>
<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/dashboard/workspaces" class="text-sm text-orgy-blue hover:text-orgy inline-flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Workspaces
    </a>
  </div>

  <!-- Workspace Header -->
  <div class="bg-white p-6 rounded-lg border mb-6">
    <h1 class="text-2xl font-bold mb-1"><%= workspace.name %></h1>
    <% if (workspace.description) { %>
      <p class="text-gray-500 text-sm"><%= workspace.description %></p>
    <% } %>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">

    <!-- Members Section (left column on large screens) -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-lg border">
        <div class="p-4 border-b">
          <h2 class="font-semibold">Members</h2>
        </div>

        <!-- Invite Form -->
        <div class="p-4 border-b bg-gray-50">
          <form id="invite-form" class="flex gap-2">
            <input type="email" name="email" required class="flex-1 border rounded-lg px-3 py-2 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="Email address">
            <button type="submit" id="invite-btn" class="px-3 py-2 bg-orgy-blue text-white rounded-lg text-sm font-medium hover:bg-orgy-blue-deep transition-colors shrink-0">Invite</button>
          </form>
          <div id="invite-status" class="text-xs mt-2 hidden"></div>
        </div>

        <!-- Members List -->
        <div class="divide-y">
          <% if (typeof members !== 'undefined' && members.length > 0) { %>
            <% members.forEach(function(member) { %>
              <div class="p-4 flex items-center justify-between">
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= member.email %></div>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-xs capitalize
                      <% if (member.role === 'owner') { %>text-orgy-blue<% } else { %>text-gray-500<% } %>
                    "><%= member.role %></span>
                    <% if (member.status === 'pending') { %>
                      <span class="text-xs px-1.5 py-0.5 bg-yellow-100 text-yellow-700 rounded">Pending</span>
                    <% } %>
                    <% if (member.invited_at) { %>
                      <span class="text-xs text-gray-400">Invited <%= new Date(member.invited_at).toLocaleDateString() %></span>
                    <% } %>
                  </div>
                </div>
                <% if (member.role !== 'owner') { %>
                  <button type="button" onclick="removeMember('<%= member.id %>', '<%= member.email %>')" class="text-xs text-red-500 hover:text-red-700 cursor-pointer">Remove</button>
                <% } %>
              </div>
            <% }); %>
          <% } else { %>
            <div class="p-4 text-sm text-gray-400 text-center">No members yet. Invite someone above.</div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- OOS Files Section (right columns) -->
    <div class="lg:col-span-2">
      <h2 class="font-semibold mb-3">OOS Files</h2>
      <% if (typeof oosFiles !== 'undefined' && oosFiles.length > 0) { %>
        <div class="grid gap-4">
          <% oosFiles.forEach(function(oos) { %>
            <a href="/oos/<%= oos.id %>" class="bg-white p-5 rounded-lg border claim-card flex items-start gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-semibold"><%= oos.org_name %></span>
                  <% if (oos.badge === 'founding') { %>
                    <span class="badge-founding text-white text-xs px-2 py-0.5 rounded">Founding</span>
                  <% } %>
                  <% if (oos.quality_tier) { %>
                    <span class="badge-<%= oos.quality_tier %> text-white text-xs px-2 py-0.5 rounded"><%= oos.quality_tier %></span>
                  <% } %>
                </div>
                <div class="text-sm text-gray-500 mb-2">
                  <%= oos.industry %> &middot; <%= oos.size %> &middot; v<%= oos.version %>
                </div>
                <div class="flex gap-4 text-xs text-gray-400">
                  <span><%= oos.claim_count %> claims</span>
                  <span class="px-2 py-0.5 bg-gray-100 rounded"><%= oos.template.replace('_', ' ') %></span>
                  <span>Published <%= new Date(oos.published_at).toLocaleDateString() %></span>
                </div>
              </div>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-12 text-gray-400 bg-white rounded-lg border">
          <p class="text-lg mb-1">No OOS files in this workspace.</p>
          <p class="text-sm">Publish an OOS file and assign it to this workspace.</p>
        </div>
      <% } %>
    </div>

  </div>
</div>

<script>
document.getElementById('invite-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('invite-btn');
  var status = document.getElementById('invite-status');
  var form = this;
  btn.disabled = true;
  btn.textContent = 'Inviting...';
  status.classList.add('hidden');

  try {
    var res = await fetch('/api/v1/workspaces/<%= workspace.id %>/members', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: form.email.value.trim() })
    });
    if (res.ok) {
      window.location.reload();
    } else {
      var data = await res.json().catch(function() { return {}; });
      throw new Error(data.error || 'Failed to send invitation.');
    }
  } catch (err) {
    status.textContent = err.message;
    status.className = 'text-xs mt-2 text-red-600';
    status.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Invite';
  }
});

async function removeMember(memberId, email) {
  if (!confirm('Remove ' + email + ' from this workspace?')) return;
  try {
    var res = await fetch('/api/v1/workspaces/<%= workspace.id %>/members/' + memberId, {
      method: 'DELETE'
    });
    if (res.ok) {
      window.location.reload();
    } else {
      alert('Failed to remove member.');
    }
  } catch (err) {
    alert('Error: ' + err.message);
  }
}
</script>
