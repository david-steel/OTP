<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/expert/<%= profile.slug %>" class="text-sm text-otp-500 hover:text-otp-400 inline-flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to <%= profile.display_name %>
    </a>
  </div>

  <div class="flex items-center gap-4 mb-6">
    <% if (profile.photo_url) { %>
      <img src="<%= profile.photo_url %>" alt="<%= profile.display_name %>" class="w-12 h-12 rounded-full object-cover">
    <% } else { %>
      <div class="w-12 h-12 rounded-full bg-otp-500 text-white flex items-center justify-center text-lg font-bold">
        <%= (profile.display_name || '?').charAt(0).toUpperCase() %>
      </div>
    <% } %>
    <div>
      <h1 class="text-xl font-bold">Contact <%= profile.display_name %></h1>
      <p class="text-sm text-gray-500">Send a message directly to this expert.</p>
    </div>
  </div>

  <form id="contact-form" class="bg-white rounded-xl border p-6 sm:p-8 space-y-4">
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
        <input type="text" name="name" required class="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-otp-500 focus:border-otp-500 outline-none" placeholder="Your name">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Your Email</label>
        <input type="email" name="email" required class="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-otp-500 focus:border-otp-500 outline-none" placeholder="you@company.com">
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Company <span class="text-gray-400 font-normal">(optional)</span></label>
      <input type="text" name="company" class="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-otp-500 focus:border-otp-500 outline-none" placeholder="Company name">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
      <textarea name="message" rows="5" required class="w-full px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-otp-500 focus:border-otp-500 outline-none resize-none" placeholder="What would you like to discuss?"></textarea>
    </div>
    <button type="submit" id="submit-btn" class="w-full px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-colors">Send Message</button>
    <div id="form-error" class="hidden text-center py-2 text-red-600 text-sm"></div>
  </form>

  <div id="form-success" class="hidden bg-white rounded-xl border p-8 text-center">
    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h2 class="text-lg font-bold text-gray-900 mb-1">Message Sent</h2>
    <p class="text-sm text-gray-500 mb-4">Your message has been sent to <%= profile.display_name %>. They will get back to you directly.</p>
    <a href="/expert/<%= profile.slug %>" class="text-sm text-otp-500 hover:text-otp-400">Back to profile</a>
  </div>
</div>

<script>
document.getElementById('contact-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('submit-btn');
  var form = this;
  btn.disabled = true;
  btn.textContent = 'Sending...';
  document.getElementById('form-error').classList.add('hidden');

  var name = form.name.value.trim();
  var email = form.email.value.trim();
  var company = form.company.value.trim();
  var message = form.message.value.trim();

  try {
    var res = await fetch('/api/v1/inquiries', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        expertSlug: '<%= profile.slug %>',
        senderName: name,
        senderEmail: email,
        senderOrg: company || null,
        message: message
      })
    });
    if (res.ok) {
      form.classList.add('hidden');
      document.getElementById('form-success').classList.remove('hidden');
    } else {
      var data = await res.json().catch(function() { return {}; });
      throw new Error(data.error || 'Server error');
    }
  } catch (err) {
    document.getElementById('form-error').textContent = err.message || 'Something went wrong. Please try again.';
    document.getElementById('form-error').classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Send Message';
  }
});
</script>
