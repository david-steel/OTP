<%- include('../partials/orgy-palette'); %>
<%
  // ---- Portfolio index ----
  // Locals: authState ('unauthenticated' | 'no_org' | 'authenticated'),
  //         featureEnabled (bool), portfolios ([{ id, name, role }]).
  // Gated behind the 'portfolio' Labs feature. When off we show an
  // enable-in-Labs card instead of the list. Plain JS line comments only --
  // never an EJS close-delimiter inside a comment.
  var _auth = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _on = (typeof featureEnabled !== 'undefined') ? !!featureEnabled : false;
  var _ports = (typeof portfolios !== 'undefined' && Array.isArray(portfolios)) ? portfolios : [];
  var _invites = (typeof pendingInvites !== 'undefined' && Array.isArray(pendingInvites)) ? pendingInvites : [];
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%- include('../partials/ui-page-header', {
    mascot: 'team',
    title: 'Portfolios',
    subtitle: 'Roll KPIs up across several organizations into one view.'
  }) %>

  <% if (_auth === 'unauthenticated') { %>
    <div class="bg-white border rounded-xl p-8 text-center">
      <p class="text-gray-600 mb-4">Sign in to view your portfolios.</p>
      <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Sign in</a>
    </div>

  <% } else if (_auth === 'no_org') { %>
    <div class="bg-white border rounded-xl p-8 text-center">
      <p class="text-gray-600 mb-4">Complete your organization profile first.</p>
      <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Set up profile</a>
    </div>

  <% } else if (!_on) { %>
    <!-- Labs-gated: feature is off for this org -->
    <div class="bg-white border rounded-xl p-8 text-center max-w-2xl mx-auto">
      <h2 class="font-bold text-gray-900 text-lg mb-2">Portfolios are in Labs</h2>
      <p class="text-sm text-gray-600 leading-relaxed mb-5 max-w-[60ch] mx-auto">
        Group several organizations under one roof and roll their KPIs up into shared super-metrics.
        Turn it on in Labs to start building your first portfolio.
      </p>
      <a href="/settings/labs" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Enable in Labs</a>
    </div>

  <% } else { %>
    <!-- Feature on: list of the user's portfolios -->

    <% if (_invites.length > 0) { %>
      <!-- Pending invites: portfolios that have invited an org this user owns -->
      <div class="bg-white border rounded-xl p-6 mb-6">
        <h2 class="font-bold text-gray-900 text-base mb-1">Pending portfolio invitations</h2>
        <p class="text-sm text-gray-600 mb-4">An organization you own has been invited to join a portfolio.</p>
        <div class="border rounded-lg overflow-hidden">
          <% _invites.forEach(function(inv) { %>
            <div class="flex items-center justify-between gap-4 px-5 py-4 border-b last:border-b-0"
                 data-invite-portfolio="<%= inv.portfolioOrgId %>" data-invite-member="<%= inv.memberOrgId %>">
              <div class="min-w-0">
                <div class="font-semibold text-gray-900 truncate"><%= inv.portfolioName %></div>
                <div class="text-sm text-gray-600 truncate">Inviting <span class="font-medium"><%= inv.memberOrgName %></span></div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <button type="button"
                        class="invite-accept-btn px-3 py-1.5 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">
                  Accept
                </button>
                <button type="button"
                        class="invite-decline-btn px-3 py-1.5 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium transition-colors">
                  Decline
                </button>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <div class="flex items-center justify-end mb-4">
      <button type="button" id="new-portfolio-btn"
              class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">
        New portfolio
      </button>
    </div>

    <!-- New-portfolio form (hidden until "New portfolio" is clicked) -->
    <div id="new-portfolio-form" class="bg-white border rounded-xl p-6 mb-6" style="display:none;">
      <label for="new-portfolio-name" class="block text-sm font-semibold text-gray-900 mb-2">Portfolio name</label>
      <div class="flex flex-wrap gap-2 items-center">
        <input type="text" id="new-portfolio-name" placeholder="e.g. Northeast Region"
               class="flex-1 min-w-[16rem] px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500/40">
        <button type="button" id="create-portfolio-btn"
                class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">
          Create
        </button>
        <button type="button" id="cancel-portfolio-btn"
                class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium transition-colors">
          Cancel
        </button>
      </div>
      <p id="new-portfolio-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
    </div>

    <% if (_ports.length === 0) { %>
      <div class="bg-white border rounded-xl p-10 text-center">
        <p class="text-sm text-gray-600">No portfolios yet. Create your first one to roll metrics up across organizations.</p>
      </div>
    <% } else { %>
      <div class="bg-white border rounded-xl overflow-hidden">
        <% _ports.forEach(function(p) { %>
          <a href="/portfolio/<%= p.id %>"
             class="flex items-center justify-between gap-4 px-5 py-4 border-b last:border-b-0 hover:bg-gray-50/60 transition-colors">
            <div class="min-w-0">
              <div class="font-semibold text-gray-900 truncate"><%= p.name %></div>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <% if (p.role) { %>
                <span class="inline-block px-2 py-0.5 rounded-full bg-orgy-soft text-orgy-blue text-xs font-semibold"><%= p.role %></span>
              <% } %>
              <span class="text-gray-400" aria-hidden="true">&rarr;</span>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  <% } %>
</div>

<% if (_auth === 'authenticated' && _on) { %>
<script>
  (function () {
    var openBtn = document.getElementById('new-portfolio-btn');
    var form = document.getElementById('new-portfolio-form');
    var nameInput = document.getElementById('new-portfolio-name');
    var createBtn = document.getElementById('create-portfolio-btn');
    var cancelBtn = document.getElementById('cancel-portfolio-btn');
    var errEl = document.getElementById('new-portfolio-error');

    function showErr(msg) { errEl.textContent = msg; errEl.style.display = 'block'; }
    function clearErr() { errEl.textContent = ''; errEl.style.display = 'none'; }

    if (openBtn) openBtn.addEventListener('click', function () {
      form.style.display = 'block';
      nameInput.focus();
    });
    if (cancelBtn) cancelBtn.addEventListener('click', function () {
      form.style.display = 'none';
      nameInput.value = '';
      clearErr();
    });

    function create() {
      var name = (nameInput.value || '').trim();
      clearErr();
      if (!name) { showErr('A portfolio name is required.'); return; }
      createBtn.disabled = true;
      fetch('/api/v1/portfolios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ name: name })
      })
        .then(function (r) {
          return r.ok ? r.json() : r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not create portfolio.');
          });
        })
        .then(function (data) {
          var id = data && (data.id || (data.portfolio && data.portfolio.id));
          window.location.href = id ? ('/portfolio/' + id) : '/portfolio';
        })
        .catch(function (err) {
          createBtn.disabled = false;
          showErr(err.message || 'Could not create portfolio.');
        });
    }

    if (createBtn) createBtn.addEventListener('click', create);
    if (nameInput) nameInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); create(); }
    });

    // ---- Pending invite accept / decline ----
    function actOnInvite(row, action) {
      var portfolioId = row.getAttribute('data-invite-portfolio');
      var memberId = row.getAttribute('data-invite-member');
      var btns = row.querySelectorAll('button');
      for (var i = 0; i < btns.length; i++) btns[i].disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/invites/' + encodeURIComponent(memberId) + '/' + action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin'
      })
        .then(function (r) {
          if (r.ok) return;
          return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not update invite.');
          });
        })
        .then(function () { window.location.reload(); })
        .catch(function (err) {
          for (var i = 0; i < btns.length; i++) btns[i].disabled = false;
          window.alert(err.message || 'Could not update invite.');
        });
    }

    var acceptBtns = document.querySelectorAll('.invite-accept-btn');
    for (var a = 0; a < acceptBtns.length; a++) {
      acceptBtns[a].addEventListener('click', function (e) {
        actOnInvite(e.target.closest('[data-invite-portfolio]'), 'accept');
      });
    }
    var declineBtns = document.querySelectorAll('.invite-decline-btn');
    for (var d = 0; d < declineBtns.length; d++) {
      declineBtns[d].addEventListener('click', function (e) {
        actOnInvite(e.target.closest('[data-invite-portfolio]'), 'decline');
      });
    }
  })();
</script>
<% } %>
