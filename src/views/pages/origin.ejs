<%#
  /origin -- The Origin of OTP. A standalone editorial "lore" page rendered in
  the v7 layout (real OTP nav + footer). Page-specific styles are scoped under
  .origin so they never touch the shared nav/footer. SEO (title, description,
  canonical, jsonLd Article) is passed from the route via renderV7.
%>
<style>
  .origin{
    --bg:#fbfaf7; --paper:#ffffff; --ink:#14161c; --ink-soft:#525866; --rule:#e7e4dd;
    --blue:#0d7df2; --green:#0a9d63; --lime:#8BC42A; --orange:#ff7a1a; --amber:#D97706;
    --maxw:680px;
    background:var(--bg); color:var(--ink);
    font-family:"Inter",system-ui,-apple-system,sans-serif; font-size:19px; line-height:1.68;
    -webkit-font-smoothing:antialiased;
  }
  .origin *{box-sizing:border-box}
  .origin .wrap{max-width:var(--maxw);margin:0 auto;padding:0 26px}

  .origin .hero{padding:84px 0 56px}
  .origin .kicker{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--blue);margin:0 0 24px}
  .origin h1{font-family:"Schibsted Grotesk",sans-serif;font-weight:800;font-size:48px;line-height:1.04;letter-spacing:-0.03em;margin:0 0 26px;color:var(--ink)}
  .origin h1 .b{color:var(--blue)}
  .origin .lede{font-size:21px;color:var(--ink-soft);margin:0 0 26px;max-width:580px}
