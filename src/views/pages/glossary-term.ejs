<%
  // term: { slug, name, definition, whyItMatters, framework, relatedSlugs[], aliases[] }
  // relatedTerms: [{ slug, name, definition }]
  function humanize(s) { return (s || '').replace(/-/g, ' '); }
%>
<!-- Term header -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14 pb-10 sm:pb-14">
    <nav class="text-xs text-gray-400 mb-4">
      <a href="/" class="hover:text-otp-300">Home</a>
      <span class="mx-1.5 text-gray-600">/</span>
      <a href="/glossary" class="hover:text-otp-300">Glossary</a>
      <span class="mx-1.5 text-gray-600">/</span>
      <span class="text-gray-300"><%= term.name %></span>
    </nav>
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-2 text-xs mb-3">
        <span class="px-2 py-0.5 rounded-full bg-otp-500/20 text-otp-300 font-semibold">Glossary</span>
        <% if (term.framework) { %>
          <span class="px-2 py-0.5 rounded-full bg-white/10 text-gray-300 font-semibold"><%= term.framework %></span>
        <% } %>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight"><%= term.name %></h1>
      <% if (term.aliases && term.aliases.length) { %>
        <p class="text-sm text-gray-400 mt-2">Also known as: <%= term.aliases.join(', ') %></p>
      <% } %>
    </div>
  </div>
</section>

<!-- Term body -->
<article class="bg-white py-10 sm:py-14">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">

    <div class="prose prose-lg max-w-none">
      <p class="text-lg text-gray-800 leading-relaxed"><%= term.definition %></p>
    </div>

    <% if (term.whyItMatters) { %>
      <div class="mt-8 p-5 rounded-xl border border-otp-100 bg-otp-50">
        <div class="text-xs font-semibold text-otp-600 uppercase tracking-wider mb-2">Why it matters</div>
        <p class="text-gray-800 leading-relaxed"><%= term.whyItMatters %></p>
      </div>
    <% } %>

    <% if (relatedTerms && relatedTerms.length) { %>
      <section class="mt-12">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Related terms</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          <% relatedTerms.forEach(function(rt) { %>
            <a href="/glossary/<%= rt.slug %>" class="block p-4 rounded-lg border border-gray-200 bg-white hover:border-otp-300 hover:bg-otp-50/40 transition-colors">
              <div class="font-semibold text-gray-900 group-hover:text-otp-600"><%= rt.name %></div>
              <div class="text-sm text-gray-600 mt-1 line-clamp-2"><%= rt.definition.length > 130 ? rt.definition.slice(0, 127) + '...' : rt.definition %></div>
            </a>
          <% }); %>
        </div>
      </section>
    <% } %>

    <% if (term.relatedSlugs && term.relatedSlugs.length > (relatedTerms ? relatedTerms.length : 0)) { %>
      <% var missing = term.relatedSlugs.filter(function(s) { return !relatedTerms.some(function(r) { return r.slug === s; }); }); %>
      <% if (missing.length) { %>
        <p class="mt-6 text-sm text-gray-500">
          See also:
          <% missing.forEach(function(s, i) { %>
            <a href="/glossary/<%= s %>" class="text-otp-500 hover:text-otp-600"><%= humanize(s) %></a><% if (i < missing.length - 1) { %>, <% } %>
          <% }); %>
        </p>
      <% } %>
    <% } %>

    <!-- Cross-link to product surfaces -->
    <section class="mt-14 p-6 rounded-xl border border-gray-200 bg-gray-50">
      <h2 class="text-base font-bold text-gray-900 mb-2">Build with this on OTP</h2>
      <p class="text-gray-700 mb-4 text-sm">OTP encodes coordination intelligence so AI agent teams can run on it. If this term shows up in your team's playbook, it belongs in your OOS.</p>
      <div class="flex flex-wrap gap-3 text-sm">
        <a href="/start-here" class="inline-flex items-center px-4 py-2 rounded-lg bg-otp-500 text-white font-semibold hover:bg-otp-600 transition-colors">Get started</a>
        <a href="/practices" class="inline-flex items-center px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-800 font-semibold hover:border-otp-300 transition-colors">Browse practices</a>
        <a href="/glossary" class="inline-flex items-center px-4 py-2 rounded-lg text-otp-500 hover:text-otp-600 font-semibold">All terms →</a>
      </div>
    </section>

    <p class="mt-10 text-xs text-gray-500">
      Found an issue with this definition? <a href="/tickets" class="text-otp-500 hover:text-otp-600 font-medium">Tell us</a> and we'll fix it.
    </p>

  </div>
</article>
