<%-
  /* /takedown/:slug/done — Removal confirmation.
     Variables: profile (may be null after future deletion) */
%>
<section class="bg-gradient-to-b from-gray-50 via-white to-white">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20 text-center">

    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-6">
      <span class="text-green-600 text-3xl">✓</span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">Got it. Your request is logged.</h1>
    <p class="text-base sm:text-lg text-gray-700 mb-2">
      <% if (profile) { %>
        We'll unpublish <strong><%= profile.displayName %></strong> from the OTP directory within 24 hours.
      <% } else { %>
        We'll unpublish your profile within 24 hours.
      <% } %>
    </p>
    <p class="text-sm text-gray-600 mb-10">
      If you provided your email, we'll confirm when it's done. No further action needed from you. If you change your mind in the meantime, just reply to the confirmation email.
    </p>

    <a href="/" class="inline-flex items-center px-6 py-3 rounded-xl bg-gray-900 text-white font-semibold hover:bg-gray-800">
      Back to OTP home
    </a>

  </div>
</section>
