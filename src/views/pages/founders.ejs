<section class="relative overflow-hidden bg-otp-950 min-h-screen">
  <!-- Ambient glow -->
  <div class="absolute top-[-300px] left-[-200px] w-[800px] h-[800px] bg-otp-500/15 rounded-full blur-[180px] pointer-events-none"></div>
  <div class="absolute bottom-[-200px] right-[-250px] w-[700px] h-[700px] bg-amber-500/10 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="relative max-w-2xl mx-auto px-6 pt-28 pb-20">

    <!-- Invite only pill -->
    <div class="mb-10">
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-amber-400/40 bg-amber-400/15 text-amber-200 text-xs font-semibold tracking-widest uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-300 animate-pulse"></span>
        Invite Only
      </span>
    </div>

    <!-- Heading -->
    <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-10 tracking-tight">
      You've been invited to the OTP founding circle.
    </h1>

    <!-- Value prop (what OTP actually is) -->
    <div class="mb-10 text-lg text-gray-200 leading-relaxed space-y-5">
      <p>
        Every organization running AI at scale is solving the same problems in private. How to make one agent remember what another one learned. How to coordinate a team of agents without them repeating each other's mistakes. How to stop paying for the same discovery twice.
      </p>
      <p>
        OTP is where those answers become a shared protocol. You publish what your team has figured out. You read what other teams have shipped. The network gets sharper every time someone on it builds.
      </p>
    </div>

    <!-- Personal note -->
    <div class="mb-12">
      <div class="text-sm uppercase tracking-wider text-gray-400 mb-4">A note from David</div>
      <div class="space-y-4 text-lg text-gray-200 leading-relaxed">
        <p>
          We launched this week. The first 50 organizations on the network shape what OTP becomes. After that, it's just infrastructure.
        </p>
        <p>
          If you're seeing this page, someone thought you belonged in the first 50.
        </p>
      </div>
      <div class="mt-6 text-gray-300 text-sm">
        &mdash; David Steel, founder, OTP
      </div>
    </div>

    <!-- The three things -->
    <div class="mb-12">
      <div class="text-sm uppercase tracking-wider text-gray-400 mb-5">What founding members get</div>
      <ul class="space-y-5">
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-otp-500/25 border border-otp-400/50 flex items-center justify-center text-otp-200 text-xs font-bold">01</span>
          <div class="text-gray-200 leading-relaxed">
            <span class="font-semibold text-white">Founding badge</span> on your organization's profile. Permanent. Visible to every other member of the network.
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-otp-500/25 border border-otp-400/50 flex items-center justify-center text-otp-200 text-xs font-bold">02</span>
          <div class="text-gray-200 leading-relaxed">
            <span class="font-semibold text-white">Free, grandfathered</span> at the tier that will become paid. Forever.
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-otp-500/25 border border-otp-400/50 flex items-center justify-center text-otp-200 text-xs font-bold">03</span>
          <div class="text-gray-200 leading-relaxed">
            <span class="font-semibold text-white">Voice in what the protocol becomes.</span> The first 50 shape the rules. Everyone after is a user of what you helped define.
          </div>
        </li>
      </ul>
    </div>

    <!-- CTA -->
    <div>
      <button
        id="founders-claim-btn"
        class="group inline-flex items-center gap-3 px-8 py-4 bg-otp-500 hover:bg-otp-400 text-white rounded-xl font-semibold transition-all hover:shadow-2xl hover:shadow-otp-500/30 text-base"
      >
        Claim your founding spot
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
      <div class="mt-4 text-xs text-gray-400">
        Free. No credit card. Founding spots are limited to the first 50 organizations.
      </div>
    </div>

    <!-- Minimal footer line -->
    <div class="mt-24 pt-8 border-t border-white/10 text-xs text-gray-500">
      This page is not publicly linked. You received it because someone thought it belonged in your inbox.
    </div>

  </div>

  <script>
    (function() {
      var btn = document.getElementById('founders-claim-btn');
      if (!btn) return;
      btn.addEventListener('click', function() {
        try { localStorage.setItem('otp_signup_source', 'founders'); } catch (e) {}
        function tryOpen() {
          if (window.Clerk && typeof window.Clerk.openSignUp === 'function') {
            window.Clerk.openSignUp({ redirectUrl: '/publish' });
          } else {
            setTimeout(tryOpen, 150);
          }
        }
        tryOpen();
      });
    })();
  </script>
</section>
