<%# /founders -- v7 layout (light, editorial). Invite-only founding
    circle page. Not publicly linked. Personal note from David. %>
<style>
  .fo-pulse { animation:fo-pulse 2.4s ease-in-out infinite; }
  @keyframes fo-pulse { 0%,100%{opacity:1; transform:scale(1);} 50%{opacity:.4; transform:scale(.82);} }
  .fo-tip { animation:fo-tip 5.5s ease-in-out infinite; transform-origin:bottom right; }
  @keyframes fo-tip { 0%,100%{transform:rotate(0);} 50%{transform:rotate(-9deg);} }
  @media (prefers-reduced-motion:reduce){ .fo-pulse,.fo-tip{ animation:none; } }
</style>

<!-- ================= HERO + INVITE ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[720px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="eyebrow mb-6 flex items-center gap-2.5">
      <span class="tick fo-pulse" style="background:var(--orange);"></span>Invite only
    </div>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(2.2rem,4.4vw,3.5rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
      You've been invited to the OTP founding circle.
    </h1>

    <div class="mt-8 space-y-5 text-[16.5px] text-[var(--ink-soft)] leading-[1.72]">
      <p>
        Every organization running AI at scale is solving the same problems in private. How to make one agent remember what another one learned. How to coordinate a team of agents without them repeating each other's mistakes. How to stop paying for the same discovery twice.
      </p>
      <p>
        OTP is where those answers become a shared protocol. You publish what your team has figured out. You read what other teams have shipped. The network gets sharper every time someone on it builds.
      </p>
    </div>
  </div>
</section>

<!-- ================= A NOTE FROM DAVID ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[720px] mx-auto px-6 py-20 sm:py-24">
    <div class="card p-8 sm:p-11 relative">
      <img src="/public/hand-2.png" alt="" aria-hidden="true"
           class="fo-tip absolute -top-7 -right-4 sm:-right-7" style="width:72px; height:auto; filter:drop-shadow(0 10px 18px rgba(20,22,28,.18));">
      <div class="eyebrow mb-5">A note from David</div>
      <div class="space-y-4 text-[16px] text-[var(--ink-soft)] leading-[1.72]">
        <p>
          We launched this week. The first 50 organizations on the network shape what OTP becomes. After that, it is just infrastructure.
        </p>
        <p>
          If you are seeing this page, someone thought you belonged in the first 50.
        </p>
      </div>
      <div class="font-mono text-[12.5px] text-[var(--ink-mute)] mt-6">
        &mdash; David Steel, founder, OTP
      </div>
    </div>
  </div>
</section>

<!-- ================= WHAT FOUNDING MEMBERS GET ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[820px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-8">What founding members get</div>
    <div class="grid sm:grid-cols-3 gap-5">
      <div class="card lift p-7">
        <div class="font-display leading-none mb-4" style="font-size:2.4rem; font-weight:800; color:var(--blue);">01</div>
        <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold mb-2">Founding badge</h3>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7]">
          On your organization's profile. Permanent. Visible to every other member of the network.
        </p>
      </div>
      <div class="card lift p-7">
        <div class="font-display leading-none mb-4" style="font-size:2.4rem; font-weight:800; color:var(--green);">02</div>
        <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold mb-2">Free, grandfathered</h3>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7]">
          At the tier that will become paid. Forever.
        </p>
      </div>
      <div class="card lift p-7 border-t-[3px]" style="border-top-color:var(--orange); background:linear-gradient(180deg,rgba(255,122,26,.06),var(--card));">
        <div class="font-display leading-none mb-4" style="font-size:2.4rem; font-weight:800; color:var(--orange-deep);">03</div>
        <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold mb-2">A voice in the protocol</h3>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7]">
          The first 50 shape the rules. Everyone after is a user of what you helped define.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[680px] mx-auto px-6 py-24 sm:py-28 text-center">
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(1.9rem,4.2vw,3rem); font-weight:800;">
      Claim your founding spot.
    </h2>
    <p class="text-[16.5px] leading-[1.6] max-w-[32rem] mx-auto mt-5" style="color:#5a2a06;">
      Free. No credit card. Founding spots are limited to the first 50 organizations.
    </p>
    <div class="flex justify-center mt-9">
      <a href="/sign-up" id="founders-claim-btn" class="btn-ink px-9 py-4 text-[16px]">
        Claim your founding spot &rarr;
      </a>
    </div>
    <p class="font-mono text-[11px] uppercase tracking-[0.14em] mt-10" style="color:#5a2a06;">
      This page is not publicly linked. You received it because someone thought it belonged in your inbox.
    </p>
  </div>
</section>

<script>
  (function() {
    var btn = document.getElementById('founders-claim-btn');
    if (!btn) return;
    btn.addEventListener('click', function() {
      try { localStorage.setItem('otp_signup_source', 'founders'); } catch (e) {}
    });
  })();
</script>
