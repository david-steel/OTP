<div class="bg-otp-950 min-h-screen -mt-[65px] pt-[65px]" id="graph-page">
  <!-- Top Stats Bar -->
  <div class="border-b border-white/5 bg-otp-950/90 backdrop-blur-sm">
    <div class="max-w-[1600px] mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <h1 class="text-white font-semibold text-sm tracking-wide">Intelligence Graph</h1>
      </div>
      <div class="flex items-center gap-6 text-xs">
        <div class="flex items-center gap-2">
          <span class="text-gray-500">Publishers</span>
          <span class="text-white font-semibold" id="stat-publishers">--</span>
        </div>
        <div class="w-px h-4 bg-white/10"></div>
        <div class="flex items-center gap-2">
          <span class="text-gray-500">Claims</span>
          <span class="text-white font-semibold" id="stat-claims">--</span>
        </div>
        <div class="w-px h-4 bg-white/10"></div>
        <div class="flex items-center gap-2">
          <span class="text-gray-500">Connections</span>
          <span class="text-white font-semibold" id="stat-connections">--</span>
        </div>
        <div class="w-px h-4 bg-white/10"></div>
        <div class="flex items-center gap-2">
          <span class="text-gray-500">Patterns</span>
          <span class="text-white font-semibold" id="stat-patterns">--</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Graph Container -->
  <div id="graph-container" style="height: calc(100vh - 200px); position: relative; overflow: hidden;">
    <!-- Grid background -->
    <div class="absolute inset-0 bg-grid opacity-30" style="pointer-events: none;"></div>

    <!-- Loading state -->
    <div id="graph-loading" class="absolute inset-0 flex items-center justify-center z-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 px-6 py-3 rounded-xl bg-white/5 border border-white/10">
          <svg class="animate-spin h-5 w-5 text-otp-400" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span class="text-gray-400 text-sm">Loading intelligence graph...</span>
        </div>
      </div>
    </div>

    <!-- Empty state -->
    <div id="graph-empty" class="absolute inset-0 flex items-center justify-center z-10 hidden">
      <div class="text-center max-w-md">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-otp-500/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-otp-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        </div>
        <p class="text-white text-lg font-medium mb-2">No published OOS files yet</p>
        <p class="text-gray-500 text-sm mb-4">The intelligence graph forms as organizations publish their coordination protocols.</p>
        <a href="/publish" class="inline-flex items-center gap-2 px-5 py-2.5 bg-otp-500 hover:bg-otp-400 text-white rounded-lg text-sm font-medium transition-colors">Be the first publisher</a>
      </div>
    </div>

    <!-- SVG Canvas -->
    <svg id="graph-svg" width="100%" height="100%" style="position: absolute; inset: 0;"></svg>

    <!-- Tooltip -->
    <div id="graph-tooltip" class="absolute pointer-events-none z-30 hidden" style="max-width: 280px;">
      <div class="rounded-lg border border-white/10 bg-[rgba(10,15,30,0.95)] backdrop-blur-sm px-4 py-3 shadow-xl">
        <div id="tooltip-content" class="text-sm"></div>
      </div>
    </div>

    <!-- Layer Control Panel (bottom-right) -->
    <div id="layer-panel" class="absolute bottom-4 right-4 z-20 hidden" style="width: 240px;">
      <div class="rounded-xl border border-white/10 bg-[rgba(10,15,30,0.9)] backdrop-blur-sm overflow-hidden shadow-2xl">
        <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
          <span class="text-white text-xs font-semibold tracking-wide uppercase">Layers</span>
          <button id="layer-collapse" class="text-gray-500 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
        </div>
        <div id="layer-list" class="px-3 py-2 flex flex-col gap-1">
          <!-- Layer: Organizations -->
          <label class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors">
            <div class="relative">
              <input type="checkbox" id="layer-orgs" checked disabled class="sr-only peer">
              <div class="w-8 h-4 bg-otp-500/30 rounded-full peer-checked:bg-otp-500 transition-colors"></div>
              <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full peer-checked:translate-x-4 transition-transform"></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white text-xs font-medium">Organizations</div>
              <div class="text-gray-500 text-[10px]">Publisher nodes</div>
            </div>
            <div class="w-2.5 h-2.5 rounded-full bg-otp-500 flex-shrink-0"></div>
          </label>

          <!-- Layer: Claim Connections -->
          <label class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors">
            <div class="relative">
              <input type="checkbox" id="layer-connections" checked class="sr-only peer">
              <div class="w-8 h-4 bg-white/10 rounded-full peer-checked:bg-purple-500 transition-colors"></div>
              <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full peer-checked:translate-x-4 transition-transform"></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white text-xs font-medium">Claim Connections</div>
              <div class="text-gray-500 text-[10px]">Similar claims across orgs</div>
            </div>
            <div class="w-2.5 h-2.5 rounded-full bg-purple-500 flex-shrink-0"></div>
          </label>

          <!-- Layer: Sections -->
          <label class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors">
            <div class="relative">
              <input type="checkbox" id="layer-sections" class="sr-only peer">
              <div class="w-8 h-4 bg-white/10 rounded-full peer-checked:bg-cyan-500 transition-colors"></div>
              <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full peer-checked:translate-x-4 transition-transform"></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white text-xs font-medium">Sections</div>
              <div class="text-gray-500 text-[10px]">Color by section type</div>
            </div>
            <div class="w-2.5 h-2.5 rounded-full bg-cyan-500 flex-shrink-0"></div>
          </label>

          <!-- Layer: Confidence -->
          <label class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors">
            <div class="relative">
              <input type="checkbox" id="layer-confidence" class="sr-only peer">
              <div class="w-8 h-4 bg-white/10 rounded-full peer-checked:bg-emerald-500 transition-colors"></div>
              <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full peer-checked:translate-x-4 transition-transform"></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white text-xs font-medium">Confidence</div>
              <div class="text-gray-500 text-[10px]">High / Medium / Low</div>
            </div>
            <div class="flex items-center gap-0.5 flex-shrink-0">
              <div class="w-2 h-2 rounded-full" style="background:#059669"></div>
              <div class="w-2 h-2 rounded-full" style="background:#d97706"></div>
              <div class="w-2 h-2 rounded-full" style="background:#9ca3af"></div>
            </div>
          </label>

          <!-- Layer: Evidence -->
          <label class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors">
            <div class="relative">
              <input type="checkbox" id="layer-evidence" class="sr-only peer">
              <div class="w-8 h-4 bg-white/10 rounded-full peer-checked:bg-amber-500 transition-colors"></div>
              <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full peer-checked:translate-x-4 transition-transform"></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white text-xs font-medium">Evidence</div>
              <div class="text-gray-500 text-[10px]">Evidence type strength</div>
            </div>
            <div class="w-2.5 h-2.5 rounded-full bg-amber-500 flex-shrink-0"></div>
          </label>
        </div>

        <!-- Section legend (shown when sections layer active) -->
        <div id="section-legend" class="hidden border-t border-white/5 px-4 py-3">
          <div class="text-gray-500 text-[10px] uppercase tracking-wide font-semibold mb-2">Section Colors</div>
          <div class="flex flex-col gap-1.5 text-[11px]">
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:#3b82f6"></div><span class="text-gray-400">Core Operating Rules</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:#8b5cf6"></div><span class="text-gray-400">Agent Roles & Authority</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:#06b6d4"></div><span class="text-gray-400">Coordination Patterns</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:#f59e0b"></div><span class="text-gray-400">Operational Heuristics</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:#ef4444"></div><span class="text-gray-400">Failure Patterns</span></div>
            <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:#10b981"></div><span class="text-gray-400">Human-AI Boundary</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Node Detail Panel (appears on click, replaces layer panel position) -->
    <div id="detail-panel" class="absolute bottom-4 right-4 z-20 hidden" style="width: 300px;">
      <div class="rounded-xl border border-white/10 bg-[rgba(10,15,30,0.95)] backdrop-blur-sm overflow-hidden shadow-2xl">
        <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
          <span class="text-white text-xs font-semibold tracking-wide uppercase" id="detail-title">Organization</span>
          <button id="detail-close" class="text-gray-500 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="detail-content" class="px-4 py-3">
          <!-- Filled dynamically -->
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
(function() {
  // ---- Color Maps ----
  var templateColors = {
    agent_army: '#0095ff',
    value_chain: '#22c55e',
    org_chart: '#f97316'
  };

  var sectionColors = {
    core_operating_rules: '#3b82f6',
    agent_roles_and_authority: '#8b5cf6',
    coordination_patterns: '#06b6d4',
    operational_heuristics: '#f59e0b',
    failure_patterns: '#ef4444',
    human_ai_boundary_conditions: '#10b981'
  };

  var confidenceColors = {
    HIGH: '#059669',
    MEDIUM: '#d97706',
    LOW: '#9ca3af'
  };

  var evidenceColors = {
    MEASURED_RESULT: '#7c3aed',
    OBSERVED_PATTERN: '#2563eb',
    STATED_RULE: '#059669',
    INFERENCE: '#d97706',
    SPECULATION: '#9ca3af'
  };

  // ---- State ----
  var graphData = null;
  var simulation = null;
  var claimNodes = [];
  var claimEdges = [];
  var orgNodeElems = null;
  var claimNodeElems = null;
  var orgEdgeElems = null;
  var claimEdgeElems = null;
  var gMain = null;

  // Layer states
  var layers = {
    connections: true,
    sections: false,
    confidence: false,
    evidence: false
  };

  // ---- Load Data ----
  async function loadGraph() {
    try {
      var resp = await fetch('/api/v1/graph');
      var data = await resp.json();
      graphData = data;

      // Update stats
      document.getElementById('stat-publishers').textContent = data.stats?.publishers || data.nodes?.length || 0;
      document.getElementById('stat-claims').textContent = data.stats?.totalClaims || 0;
      document.getElementById('stat-connections').textContent = data.stats?.connections || data.edges?.length || 0;
      document.getElementById('stat-patterns').textContent = data.stats?.patterns || 0;

      if (!data.nodes || data.nodes.length === 0) {
        document.getElementById('graph-loading').classList.add('hidden');
        document.getElementById('graph-empty').classList.remove('hidden');
        return;
      }

      document.getElementById('graph-loading').classList.add('hidden');
      document.getElementById('layer-panel').classList.remove('hidden');
      renderGraph(data);
    } catch (e) {
      document.getElementById('graph-loading').innerHTML =
        '<div class="text-center"><span class="text-red-400 text-sm">Failed to load graph data.</span></div>';
    }
  }

  // ---- Render ----
  function renderGraph(data) {
    var container = document.getElementById('graph-container');
    var width = container.clientWidth;
    var height = container.clientHeight;
    var svg = d3.select('#graph-svg');
    svg.selectAll('*').remove();

    // Defs for glow filter
    var defs = svg.append('defs');
    var filter = defs.append('filter').attr('id', 'glow').attr('x', '-50%').attr('y', '-50%').attr('width', '200%').attr('height', '200%');
    filter.append('feGaussianBlur').attr('stdDeviation', '4').attr('result', 'coloredBlur');
    var feMerge = filter.append('feMerge');
    feMerge.append('feMergeNode').attr('in', 'coloredBlur');
    feMerge.append('feMergeNode').attr('in', 'SourceGraphic');

    // Radial gradient for org nodes
    data.nodes.forEach(function(n, i) {
      var grad = defs.append('radialGradient').attr('id', 'org-grad-' + i);
      var baseColor = templateColors[n.template] || '#6b7280';
      grad.append('stop').attr('offset', '0%').attr('stop-color', baseColor).attr('stop-opacity', 0.9);
      grad.append('stop').attr('offset', '100%').attr('stop-color', baseColor).attr('stop-opacity', 0.6);
    });

    gMain = svg.append('g').attr('class', 'graph-main');

    // Zoom
    var zoom = d3.zoom().scaleExtent([0.2, 5]).on('zoom', function(event) {
      gMain.attr('transform', event.transform);
    });
    svg.call(zoom);
    // Initial zoom to center
    svg.call(zoom.transform, d3.zoomIdentity.translate(width / 2, height / 2).scale(0.9).translate(-width / 2, -height / 2));

    // Build claim nodes from the claims data
    claimNodes = [];
    claimEdges = [];

    if (data.claims) {
      var claimIndex = 0;
      data.nodes.forEach(function(orgNode) {
        var orgClaims = data.claims[orgNode.id] || [];
        orgClaims.forEach(function(c, ci) {
          var angle = (2 * Math.PI * ci) / Math.max(orgClaims.length, 1);
          var radius = 60 + Math.random() * 30;
          claimNodes.push({
            id: 'claim-' + orgNode.id + '-' + ci,
            orgId: orgNode.id,
            orgIndex: data.nodes.indexOf(orgNode),
            claimId: c.claimId,
            section: c.section,
            confidence: c.confidence,
            evidence: c.evidence,
            rule: c.rule,
            // Offset from org node
            offsetX: Math.cos(angle) * radius,
            offsetY: Math.sin(angle) * radius,
            x: 0,
            y: 0
          });
          claimIndex++;
        });
      });
    }

    // Org-level edges (claim similarity connections)
    var orgEdgeLayer = gMain.append('g').attr('class', 'org-edges');
    orgEdgeElems = orgEdgeLayer.selectAll('line')
      .data(data.edges)
      .join('line')
      .attr('stroke', '#8b5cf6')
      .attr('stroke-width', function(d) { return Math.min(Math.max(d.weight || 1, 1), 6); })
      .attr('stroke-opacity', 0.3)
      .style('cursor', 'pointer')
      .on('click', function(event, d) {
        var srcId = d.source.id || d.source;
        var tgtId = d.target.id || d.target;
        window.location.href = '/compare/' + srcId + '/' + tgtId;
      })
      .on('mouseenter', function(event, d) {
        d3.select(this).attr('stroke-opacity', 0.7);
        showTooltip(event, '<div class="text-white font-medium mb-1">' + (d.weight || 1) + ' similar claim' + ((d.weight || 1) > 1 ? 's' : '') + '</div>' +
          (d.topClaims ? d.topClaims.slice(0, 2).map(function(tc) {
            return '<div class="text-gray-400 text-[11px] truncate mb-0.5">"' + truncate(tc.claimA, 40) + '"</div>';
          }).join('') : '') +
          '<div class="text-gray-500 text-[10px] mt-1">Click to compare</div>');
      })
      .on('mouseleave', function() {
        d3.select(this).attr('stroke-opacity', 0.3);
        hideTooltip();
      });

    // Claim edge layer (between individual claim dots -- only when connections layer is on)
    var claimEdgeLayer = gMain.append('g').attr('class', 'claim-edges');

    // Claim node layer
    var claimNodeLayer = gMain.append('g').attr('class', 'claim-nodes');
    claimNodeElems = claimNodeLayer.selectAll('circle')
      .data(claimNodes)
      .join('circle')
      .attr('r', 3)
      .attr('fill', function(d) { return getClaimColor(d); })
      .attr('fill-opacity', 0.7)
      .attr('stroke', 'none')
      .style('cursor', 'pointer')
      .on('mouseenter', function(event, d) {
        d3.select(this).attr('r', 5).attr('fill-opacity', 1);
        showTooltip(event, '<div class="text-white font-medium mb-1">' + d.claimId + '</div>' +
          '<div class="text-gray-400 text-[11px] mb-1">' + formatSection(d.section) + '</div>' +
          '<div class="text-gray-500 text-[10px] leading-relaxed">' + truncate(d.rule, 120) + '</div>' +
          '<div class="flex gap-3 mt-2">' +
          '<span class="text-[10px]" style="color:' + (confidenceColors[d.confidence] || '#9ca3af') + '">' + d.confidence + '</span>' +
          '<span class="text-[10px]" style="color:' + (evidenceColors[d.evidence] || '#9ca3af') + '">' + formatEvidence(d.evidence) + '</span>' +
          '</div>');
      })
      .on('mouseleave', function(event, d) {
        d3.select(this).attr('r', 3).attr('fill-opacity', 0.7);
        hideTooltip();
      });

    // Initially hide claim nodes (they appear when a section/confidence/evidence layer is toggled)
    claimNodeElems.style('display', 'none');

    // Org nodes layer (on top)
    var orgNodeLayer = gMain.append('g').attr('class', 'org-nodes');

    // Force simulation for org nodes
    simulation = d3.forceSimulation(data.nodes)
      .force('link', d3.forceLink(data.edges).id(function(d) { return d.id; }).distance(200))
      .force('charge', d3.forceManyBody().strength(-400))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collision', d3.forceCollide().radius(function(d) { return getOrgRadius(d) + 40; }));

    // Org node groups
    orgNodeElems = orgNodeLayer.selectAll('g')
      .data(data.nodes)
      .join('g')
      .style('cursor', 'pointer')
      .call(d3.drag()
        .on('start', function(event, d) { if (!event.active) simulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on('drag', function(event, d) { d.fx = event.x; d.fy = event.y; })
        .on('end', function(event, d) { if (!event.active) simulation.alphaTarget(0); d.fx = null; d.fy = null; })
      );

    // Org outer glow ring
    orgNodeElems.append('circle')
      .attr('r', function(d) { return getOrgRadius(d) + 8; })
      .attr('fill', 'none')
      .attr('stroke', function(d) { return templateColors[d.template] || '#6b7280'; })
      .attr('stroke-width', 1)
      .attr('stroke-opacity', 0.15);

    // Org main circle
    orgNodeElems.append('circle')
      .attr('r', function(d) { return getOrgRadius(d); })
      .attr('fill', function(d, i) { return 'url(#org-grad-' + i + ')'; })
      .attr('stroke', function(d) { return templateColors[d.template] || '#6b7280'; })
      .attr('stroke-width', 2)
      .attr('stroke-opacity', 0.5)
      .attr('filter', 'url(#glow)');

    // Org label
    orgNodeElems.append('text')
      .text(function(d) { return d.orgName; })
      .attr('dy', function(d) { return getOrgRadius(d) + 18; })
      .attr('text-anchor', 'middle')
      .attr('font-size', '12px')
      .attr('font-weight', '600')
      .attr('fill', '#e2e8f0')
      .attr('paint-order', 'stroke')
      .attr('stroke', '#060a14')
      .attr('stroke-width', '3px');

    // Claim count inside org node
    orgNodeElems.append('text')
      .text(function(d) { return d.claimCount; })
      .attr('text-anchor', 'middle')
      .attr('dy', '0.35em')
      .attr('font-size', '13px')
      .attr('font-weight', '700')
      .attr('fill', '#fff');

    // Badge indicator (founding)
    orgNodeElems.filter(function(d) { return d.badge === 'founding'; })
      .append('g')
      .attr('transform', function(d) {
        var r = getOrgRadius(d);
        return 'translate(' + (r * 0.7) + ',' + (-r * 0.7) + ')';
      })
      .each(function() {
        d3.select(this).append('circle').attr('r', 6).attr('fill', '#f59e0b').attr('stroke', '#060a14').attr('stroke-width', 2);
        d3.select(this).append('text').text('\u2605').attr('text-anchor', 'middle').attr('dy', '0.35em').attr('font-size', '7px').attr('fill', '#fff');
      });

    // Quality tier ring
    orgNodeElems.filter(function(d) { return d.qualityTier; })
      .append('circle')
      .attr('r', function(d) { return getOrgRadius(d) + 4; })
      .attr('fill', 'none')
      .attr('stroke', function(d) {
        var tierColors = { platinum: '#a78bfa', gold: '#fbbf24', silver: '#d1d5db', bronze: '#d97706' };
        return tierColors[d.qualityTier] || 'transparent';
      })
      .attr('stroke-width', 2)
      .attr('stroke-opacity', 0.6)
      .attr('stroke-dasharray', '4,3');

    // Org node interaction
    orgNodeElems
      .on('click', function(event, d) {
        event.stopPropagation();
        showDetailPanel(d);
      })
      .on('mouseenter', function(event, d) {
        d3.select(this).select('circle:nth-child(2)').attr('stroke-opacity', 1);
        showTooltip(event, '<div class="text-white font-semibold mb-1">' + d.orgName + '</div>' +
          '<div class="flex items-center gap-2 mb-1">' +
          '<span class="text-[10px] px-1.5 py-0.5 rounded" style="background:' + (templateColors[d.template] || '#6b7280') + '30; color:' + (templateColors[d.template] || '#6b7280') + '">' + formatTemplate(d.template) + '</span>' +
          (d.industry ? '<span class="text-gray-500 text-[10px]">' + d.industry + '</span>' : '') +
          '</div>' +
          '<div class="text-gray-400 text-[11px]">' + d.claimCount + ' claims</div>' +
          (d.qualityTier ? '<div class="text-gray-500 text-[10px] mt-1 capitalize">' + d.qualityTier + ' tier</div>' : '') +
          '<div class="text-gray-600 text-[10px] mt-1">Click for details</div>');
      })
      .on('mouseleave', function(event, d) {
        d3.select(this).select('circle:nth-child(2)').attr('stroke-opacity', 0.5);
        hideTooltip();
      });

    // Tick
    simulation.on('tick', function() {
      orgEdgeElems
        .attr('x1', function(d) { return d.source.x; })
        .attr('y1', function(d) { return d.source.y; })
        .attr('x2', function(d) { return d.target.x; })
        .attr('y2', function(d) { return d.target.y; });

      orgNodeElems.attr('transform', function(d) { return 'translate(' + d.x + ',' + d.y + ')'; });

      // Position claim nodes relative to their org
      claimNodeElems
        .attr('cx', function(d) {
          var orgNode = data.nodes[d.orgIndex];
          return orgNode ? orgNode.x + d.offsetX : 0;
        })
        .attr('cy', function(d) {
          var orgNode = data.nodes[d.orgIndex];
          return orgNode ? orgNode.y + d.offsetY : 0;
        });
    });

    // Click background to deselect
    svg.on('click', function() {
      hideDetailPanel();
    });

    // Initial layer state
    updateLayers();
  }

  // ---- Helpers ----
  function getOrgRadius(d) {
    return Math.sqrt(d.claimCount || 10) * 4 + 12;
  }

  function getClaimColor(d) {
    if (layers.confidence) return confidenceColors[d.confidence] || '#9ca3af';
    if (layers.evidence) return evidenceColors[d.evidence] || '#9ca3af';
    if (layers.sections) return sectionColors[d.section] || '#6b7280';
    return '#64748b';
  }

  function truncate(str, len) {
    if (!str) return '';
    return str.length > len ? str.substring(0, len) + '...' : str;
  }

  function formatTemplate(t) {
    if (!t) return '';
    return t.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  function formatSection(s) {
    if (!s) return '';
    return s.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  function formatEvidence(e) {
    if (!e) return '';
    return e.replace(/_/g, ' ').toLowerCase().replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  // ---- Tooltip ----
  function showTooltip(event, html) {
    var tooltip = document.getElementById('graph-tooltip');
    var content = document.getElementById('tooltip-content');
    content.innerHTML = html;
    tooltip.classList.remove('hidden');

    var container = document.getElementById('graph-container');
    var rect = container.getBoundingClientRect();
    var x = event.clientX - rect.left + 15;
    var y = event.clientY - rect.top - 10;

    // Keep in bounds
    if (x + 280 > rect.width) x = event.clientX - rect.left - 295;
    if (y + 150 > rect.height) y = rect.height - 160;
    if (y < 10) y = 10;

    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }

  function hideTooltip() {
    document.getElementById('graph-tooltip').classList.add('hidden');
  }

  // ---- Detail Panel ----
  function buildCompareDropdown(d) {
    if (!graphData || !graphData.nodes || graphData.nodes.length < 2) return '';
    var others = graphData.nodes.filter(function(n) { return n.id !== d.id; });
    if (others.length === 0) return '';

    var options = others.map(function(n) {
      return '<option value="' + n.id + '">' + n.orgName + ' (' + n.claimCount + ' claims)</option>';
    }).join('');

    return '<div class="mt-3">' +
      '<label class="text-gray-500 text-[10px] uppercase tracking-wide block mb-1.5">Compare with</label>' +
      '<div class="flex gap-2">' +
      '<select id="compare-target" class="flex-1 bg-white/5 border border-white/10 rounded-lg px-2 py-1.5 text-gray-300 text-xs focus:border-otp-500 focus:outline-none appearance-none" style="background-image:url(\'data:image/svg+xml;utf8,<svg fill=\"%239ca3af\" viewBox=\"0 0 20 20\" xmlns=\"http://www.w3.org/2000/svg\"><path fill-rule=\"evenodd\" d=\"M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z\" clip-rule=\"evenodd\"/></svg>\'); background-repeat:no-repeat; background-position:right 8px center; background-size:14px; padding-right:28px;">' +
      options +
      '</select>' +
      '<button onclick="goCompare(\'' + d.id + '\')" class="px-3 py-1.5 bg-purple-500/20 text-purple-400 rounded-lg text-xs font-medium hover:bg-purple-500/30 transition-colors whitespace-nowrap">Compare</button>' +
      '</div></div>';
  }

  function goCompare(sourceId) {
    var sel = document.getElementById('compare-target');
    if (sel && sel.value) {
      window.location.href = '/compare/' + sourceId + '/' + sel.value;
    }
  }

  function showDetailPanel(d) {
    document.getElementById('layer-panel').classList.add('hidden');
    var panel = document.getElementById('detail-panel');
    panel.classList.remove('hidden');
    document.getElementById('detail-title').textContent = d.orgName;

    var claims = graphData.claims ? graphData.claims[d.id] || [] : [];
    var sectionCounts = {};
    claims.forEach(function(c) {
      sectionCounts[c.section] = (sectionCounts[c.section] || 0) + 1;
    });
    var topSections = Object.entries(sectionCounts).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 3);

    var tierBadge = '';
    if (d.qualityTier) {
      var tierC = { platinum: '#a78bfa', gold: '#fbbf24', silver: '#d1d5db', bronze: '#d97706' };
      tierBadge = '<span class="text-[10px] px-1.5 py-0.5 rounded capitalize" style="background:' + (tierC[d.qualityTier] || '#6b7280') + '20; color:' + (tierC[d.qualityTier] || '#6b7280') + '">' + d.qualityTier + '</span>';
    }

    var badgeHtml = '';
    if (d.badge === 'founding') {
      badgeHtml = '<span class="text-[10px] px-1.5 py-0.5 rounded" style="background:#f59e0b20; color:#f59e0b">\u2605 Founding</span>';
    }

    document.getElementById('detail-content').innerHTML =
      '<div class="flex items-center gap-2 mb-3">' +
      '<span class="text-[10px] px-1.5 py-0.5 rounded" style="background:' + (templateColors[d.template] || '#6b7280') + '30; color:' + (templateColors[d.template] || '#6b7280') + '">' + formatTemplate(d.template) + '</span>' +
      (d.industry ? '<span class="text-gray-500 text-[10px]">' + d.industry + '</span>' : '') +
      tierBadge + badgeHtml +
      '</div>' +
      '<div class="grid grid-cols-2 gap-3 mb-4">' +
      '<div class="bg-white/5 rounded-lg px-3 py-2"><div class="text-white text-lg font-bold">' + d.claimCount + '</div><div class="text-gray-500 text-[10px]">Claims</div></div>' +
      '<div class="bg-white/5 rounded-lg px-3 py-2"><div class="text-white text-lg font-bold capitalize">' + (d.qualityTier || '--') + '</div><div class="text-gray-500 text-[10px]">Quality Tier</div></div>' +
      '</div>' +
      (topSections.length > 0 ? '<div class="mb-4"><div class="text-gray-500 text-[10px] uppercase tracking-wide mb-2">Top Sections</div>' +
      topSections.map(function(s) {
        return '<div class="flex items-center justify-between py-1"><div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:' + (sectionColors[s[0]] || '#6b7280') + '"></div><span class="text-gray-300 text-[11px]">' + formatSection(s[0]) + '</span></div><span class="text-gray-500 text-[11px]">' + s[1] + '</span></div>';
      }).join('') + '</div>' : '') +
      '<div class="flex gap-2 mt-3">' +
      '<a href="/oos/' + d.id + '" class="flex-1 text-center px-3 py-2 bg-otp-500/20 text-otp-400 rounded-lg text-xs font-medium hover:bg-otp-500/30 transition-colors">View OOS</a>' +
      '</div>' +
      buildCompareDropdown(d);
  }

  function hideDetailPanel() {
    document.getElementById('detail-panel').classList.add('hidden');
    if (graphData && graphData.nodes && graphData.nodes.length > 0) {
      document.getElementById('layer-panel').classList.remove('hidden');
    }
  }

  // ---- Layer Controls ----
  function updateLayers() {
    layers.connections = document.getElementById('layer-connections').checked;
    layers.sections = document.getElementById('layer-sections').checked;
    layers.confidence = document.getElementById('layer-confidence').checked;
    layers.evidence = document.getElementById('layer-evidence').checked;

    // Show/hide org edges
    if (orgEdgeElems) {
      orgEdgeElems.transition().duration(300)
        .attr('stroke-opacity', layers.connections ? 0.3 : 0);
    }

    // Show/hide claim nodes based on any claim-level layer being active
    var showClaims = layers.sections || layers.confidence || layers.evidence;
    if (claimNodeElems) {
      claimNodeElems
        .style('display', showClaims ? 'block' : 'none')
        .transition().duration(300)
        .attr('fill', function(d) { return getClaimColor(d); })
        .attr('fill-opacity', showClaims ? 0.7 : 0);
    }

    // Section legend
    document.getElementById('section-legend').classList.toggle('hidden', !layers.sections);

    // When sections active, force sections mode even if confidence/evidence also on
    // Priority: confidence > evidence > sections > default
  }

  // Wire up layer toggles
  ['layer-connections', 'layer-sections', 'layer-confidence', 'layer-evidence'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('change', updateLayers);
  });

  // Only allow one claim-coloring layer at a time (sections, confidence, evidence)
  ['layer-sections', 'layer-confidence', 'layer-evidence'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', function() {
        if (this.checked) {
          ['layer-sections', 'layer-confidence', 'layer-evidence'].forEach(function(otherId) {
            if (otherId !== id) document.getElementById(otherId).checked = false;
          });
        }
        updateLayers();
      });
    }
  });

  // Layer panel collapse toggle
  document.getElementById('layer-collapse').addEventListener('click', function() {
    var list = document.getElementById('layer-list');
    var legend = document.getElementById('section-legend');
    list.classList.toggle('hidden');
    if (!layers.sections) legend.classList.add('hidden');
    // Flip chevron
    this.querySelector('svg').style.transform = list.classList.contains('hidden') ? 'rotate(180deg)' : '';
  });

  // Detail panel close
  document.getElementById('detail-close').addEventListener('click', function(e) {
    e.stopPropagation();
    hideDetailPanel();
  });

  // ---- Init ----
  loadGraph();
})();
</script>
