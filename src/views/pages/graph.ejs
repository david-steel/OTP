<div class="max-w-6xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-2">Organizational Intelligence Graph</h1>
  <p class="text-gray-500 text-sm mb-6">Connections between published OOS files. Edges represent similar coordination patterns. Click a node to view that OOS. Click an edge to compare the two organizations.</p>

  <!-- Graph Container -->
  <div id="graph-container" class="bg-white border rounded-lg" style="height: 500px; position: relative;">
    <div id="graph-loading" class="absolute inset-0 flex items-center justify-center text-gray-400">
      Loading graph...
    </div>
    <svg id="graph-svg" width="100%" height="100%"></svg>
  </div>

  <!-- Legend -->
  <div class="flex gap-6 mt-4 text-xs text-gray-500">
    <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-full bg-blue-500"></div> Agent Army</div>
    <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-full bg-green-500"></div> Value Chain</div>
    <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-full bg-orange-500"></div> Org Chart</div>
    <div class="flex items-center gap-1"><div class="w-6 h-0.5 bg-gray-400"></div> Similar claims</div>
    <div class="flex items-center gap-1"><div class="w-6 h-1 bg-gray-600"></div> Many similar claims</div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-4 mt-6">
    <div class="bg-white p-4 border rounded">
      <div class="text-2xl font-bold text-otp-600" id="node-count">0</div>
      <div class="text-xs text-gray-500">Published OOS Files</div>
    </div>
    <div class="bg-white p-4 border rounded">
      <div class="text-2xl font-bold text-otp-600" id="edge-count">0</div>
      <div class="text-xs text-gray-500">Connections</div>
    </div>
    <div class="bg-white p-4 border rounded">
      <div class="text-2xl font-bold text-otp-600" id="pattern-count">0</div>
      <div class="text-xs text-gray-500">Cross-Org Patterns</div>
    </div>
  </div>
</div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
async function loadGraph() {
  try {
    const resp = await fetch('/api/v1/graph');
    const data = await resp.json();

    document.getElementById('node-count').textContent = data.nodes?.length || 0;
    document.getElementById('edge-count').textContent = data.edges?.length || 0;

    if (!data.nodes || data.nodes.length === 0) {
      document.getElementById('graph-loading').innerHTML =
        '<div class="text-center"><p class="text-lg mb-2">No OOS files published yet.</p><p class="text-sm">The graph forms as organizations publish their coordination intelligence.</p><a href="/publish" class="text-otp-500 hover:underline text-sm">Be the first publisher</a></div>';
      return;
    }

    document.getElementById('graph-loading').style.display = 'none';
    renderGraph(data);
  } catch (e) {
    document.getElementById('graph-loading').textContent = 'Failed to load graph data.';
  }
}

function renderGraph(data) {
  const container = document.getElementById('graph-container');
  const width = container.clientWidth;
  const height = container.clientHeight;

  const svg = d3.select('#graph-svg');
  svg.selectAll('*').remove();

  const colorMap = { agent_army: '#3b82f6', value_chain: '#22c55e', org_chart: '#f97316' };

  const simulation = d3.forceSimulation(data.nodes)
    .force('link', d3.forceLink(data.edges).id(d => d.id).distance(120))
    .force('charge', d3.forceManyBody().strength(-200))
    .force('center', d3.forceCenter(width / 2, height / 2))
    .force('collision', d3.forceCollide().radius(d => Math.sqrt(d.claimCount || 10) * 3 + 10));

  const g = svg.append('g');

  // Zoom
  svg.call(d3.zoom().scaleExtent([0.3, 3]).on('zoom', (event) => {
    g.attr('transform', event.transform);
  }));

  // Edges
  const link = g.append('g')
    .selectAll('line')
    .data(data.edges)
    .join('line')
    .attr('stroke', '#94a3b8')
    .attr('stroke-width', d => Math.min(d.weight || 1, 5))
    .attr('stroke-opacity', 0.5)
    .style('cursor', 'pointer')
    .on('click', (event, d) => {
      window.location.href = `/compare/${d.source.id || d.source}/${d.target.id || d.target}`;
    });

  // Nodes
  const node = g.append('g')
    .selectAll('g')
    .data(data.nodes)
    .join('g')
    .style('cursor', 'pointer')
    .on('click', (event, d) => {
      window.location.href = `/oos/${d.id}`;
    })
    .call(d3.drag()
      .on('start', (event, d) => { if (!event.active) simulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
      .on('drag', (event, d) => { d.fx = event.x; d.fy = event.y; })
      .on('end', (event, d) => { if (!event.active) simulation.alphaTarget(0); d.fx = null; d.fy = null; })
    );

  node.append('circle')
    .attr('r', d => Math.sqrt(d.claimCount || 10) * 3 + 5)
    .attr('fill', d => colorMap[d.template] || '#6b7280')
    .attr('stroke', '#fff')
    .attr('stroke-width', 2);

  node.append('text')
    .text(d => d.orgName)
    .attr('dy', d => Math.sqrt(d.claimCount || 10) * 3 + 18)
    .attr('text-anchor', 'middle')
    .attr('font-size', '11px')
    .attr('fill', '#374151');

  // Badge indicator
  node.filter(d => d.badge === 'founding')
    .append('circle')
    .attr('r', 4)
    .attr('cx', d => Math.sqrt(d.claimCount || 10) * 3)
    .attr('cy', d => -(Math.sqrt(d.claimCount || 10) * 3))
    .attr('fill', '#f59e0b')
    .attr('stroke', '#fff')
    .attr('stroke-width', 1);

  // Tooltip
  node.append('title')
    .text(d => `${d.orgName}\n${d.template.replace('_', ' ')} | ${d.industry}\n${d.claimCount} claims | ${d.qualityTier || 'unrated'}`);

  link.append('title')
    .text(d => `${d.weight} similar claim${d.weight > 1 ? 's' : ''}`);

  simulation.on('tick', () => {
    link.attr('x1', d => d.source.x).attr('y1', d => d.source.y)
        .attr('x2', d => d.target.x).attr('y2', d => d.target.y);
    node.attr('transform', d => `translate(${d.x},${d.y})`);
  });
}

loadGraph();
</script>
