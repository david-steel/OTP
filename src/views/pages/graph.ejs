    custom: '#6b7280',
    gpt: '#10b981',
    chatgpt: '#10b981',
    openai: '#10b981',
    gemini: '#3b82f6',
    'google gemini': '#3b82f6',
  };

  // MCP Server colors by category
  var mcpServerColors = {
    // Communication
    slack: '#4A154B',
    gmail: '#EA4335',
    'google-workspace': '#4285F4',
    'google-calendar': '#4285F4',
    whatsapp: '#25D366',
    // Productivity
    todoist: '#E44332',
    obsidian: '#7C3AED',
    n8n: '#FF6D5A',
    // Data/Analytics
    'google-ads': '#FBBC04',
    'meta-ads': '#0081FB',
    'meta-ad-library': '#0081FB',
    'search-atlas': '#10B981',
    // CRM/Business
    ghl: '#2BB673',
    accelo: '#FF6B35',
    calendly: '#006BFF',
    quickbooks: '#2CA01C',
    // Infrastructure
    playwright: '#2EAD33',
    fireflies: '#6366F1',
    // AI services (when listed as MCP)
    openai: '#10b981',
    nanobanana: '#F59E0B',
    claude: '#c084fc',
  };

  // Known AI platform names (used to distinguish platform vs MCP)
  var AI_PLATFORM_NAMES = ['claude', 'gpt', 'chatgpt', 'openai', 'gemini', 'google gemini', 'custom'];

  function isAIPlatform(name) {
    return AI_PLATFORM_NAMES.indexOf((name || '').toLowerCase()) !== -1;
  }

  function getPlatformColor(name) {
    var lower = (name || '').toLowerCase();
    return platformColors[lower] || '#9ca3af';
  }

  function getMcpColor(name) {
    var lower = (name || '').toLowerCase();
    return mcpServerColors[lower] || '#9CA3AF';
  }

  function getInfraColor(name, type) {
    if (type === 'mcp') return getMcpColor(name);
    return getPlatformColor(name);
  }

  // Get node color: industry override > template default
  function getNodeColor(d) {
    if (layers.efficiency) return efficiencyColor(calcOrgGroupEfficiency(d));
    return industryColors[d.industry] || templateColors[d.template] || '#6b7280';
  }

  // Generate initials from org name (max 3 chars)
  function getInitials(name) {
    if (!name) return '?';
    var words = name.trim().split(/\s+/);
    if (words.length === 1) return words[0].substring(0, 3).toUpperCase();
    return words.slice(0, 3).map(function(w) { return w[0]; }).join('').toUpperCase();
  }

  var sectionColors = {
    core_operating_rules: '#3b82f6',
    agent_roles_and_authority: '#8b5cf6',
    coordination_patterns: '#06b6d4',
    operational_heuristics: '#f59e0b',
    failure_patterns: '#ef4444',
    human_ai_boundary_conditions: '#10b981'
  };

  var confidenceColors = {
    HIGH: '#059669',
    MEDIUM: '#d97706',
    LOW: '#9ca3af'
  };

  var evidenceColors = {
    MEASURED_RESULT: '#7c3aed',
    OBSERVED_PATTERN: '#2563eb',
    STATED_RULE: '#059669',
    INFERENCE: '#d97706',
    SPECULATION: '#9ca3af'
  };

  // Token efficiency multipliers by confidence_evidence
  var effMultipliers = {
    'HIGH_MEASURED_RESULT': 10, 'HIGH_OBSERVED_REPEATEDLY': 7, 'HIGH_OBSERVED_ONCE': 5,
    'HIGH_HUMAN_DEFINED_RULE': 5, 'HIGH_INFERENCE': 3, 'HIGH_SPECULATION': 1.5,
    'MEDIUM_MEASURED_RESULT': 6, 'MEDIUM_OBSERVED_REPEATEDLY': 4, 'MEDIUM_OBSERVED_ONCE': 3,
    'MEDIUM_HUMAN_DEFINED_RULE': 3, 'MEDIUM_INFERENCE': 2, 'MEDIUM_SPECULATION': 1,
    'LOW_MEASURED_RESULT': 3, 'LOW_OBSERVED_REPEATEDLY': 2, 'LOW_OBSERVED_ONCE': 1.5,
    'LOW_HUMAN_DEFINED_RULE': 1.5, 'LOW_INFERENCE': 0.8, 'LOW_SPECULATION': 0.5
  };

  function calcOrgEfficiency(orgId, graphData) {
    var claims = graphData.claims ? graphData.claims[orgId] || [] : [];
    if (claims.length === 0) return 0;
    var totalCost = 0, totalSavings = 0;
    claims.forEach(function(c) {
      var cost = Math.ceil(((c.rule || '') + (c.why || '') + (c.failureMode || '') + (c.scope || '')).length / 4) || 30;
      var mult = effMultipliers[c.confidence + '_' + c.evidence] || 1;
      totalCost += cost;
      totalSavings += cost * mult;
    });
    return totalCost > 0 ? totalSavings / totalCost : 0;
  }

  function efficiencyColor(eff) {
    if (eff >= 5) return '#059669';
    if (eff >= 2) return '#3b82f6';
    if (eff >= 1) return '#d97706';
    return '#ef4444';
  }

  function efficiencyLabel(eff) {
    if (eff >= 5) return 'High';
    if (eff >= 2) return 'Moderate';
    if (eff >= 1) return 'Low';
    return 'Inefficient';
  }

  // ---- State ----
  var graphData = null;
  var simulation = null;
  var expandedOrgs = {};      // orgId -> true if expanded
  var minSimilarity = 0.5;    // Slider value
  var orgGroups = {};          // orgId -> { nodes: [...], oosIds: [...], claims: [...], ... }
  var aggEdges = [];           // Aggregated org-to-org edges
  var claimSimEdges = [];      // Individual claim-to-claim similarities
  var currentMode = 'intelligence';  // 'intelligence' | 'infrastructure' | 'economy'
  var infraSimulation = null;  // Separate simulation for infrastructure mode

  // D3 selections
  var gMain = null;
  var orgEdgeLayer = null;
  var claimEdgeLayer = null;
  var claimNodeLayer = null;
  var orgNodeLayer = null;
  var orgNodeElems = null;

  // Layer states
  var layers = {
    connections: true,
    sections: false,
    confidence: false,
    evidence: false,
    efficiency: false
  };

  // ---- Load Data ----
  async function loadGraph() {
    try {
      var resp = await fetch('/api/v1/graph');
      var data = await resp.json();
      graphData = data;

      // Update stats
      document.getElementById('stat-publishers').textContent = data.stats?.publishers || data.nodes?.length || 0;
      document.getElementById('stat-claims').textContent = data.stats?.totalClaims || 0;
      document.getElementById('stat-connections').textContent = data.stats?.connections || data.edges?.length || 0;
      document.getElementById('stat-patterns').textContent = data.stats?.patterns || 0;

      // Calculate avg efficiency across all orgs
      var totalEff = 0;
      if (data.nodes && data.nodes.length > 0) {
        data.nodes.forEach(function(n) { totalEff += calcOrgEfficiency(n.id, data); });
        var avgEff = totalEff / data.nodes.length;
        document.getElementById('stat-efficiency').textContent = avgEff.toFixed(1) + 'x';
        document.getElementById('stat-efficiency').style.color = efficiencyColor(avgEff);
      }

      if (!data.nodes || data.nodes.length === 0) {
        document.getElementById('graph-loading').classList.add('hidden');
        document.getElementById('graph-empty').classList.remove('hidden');
        return;
      }

      document.getElementById('graph-loading').classList.add('hidden');
      document.getElementById('layer-panel').classList.remove('hidden');

      // Build org groups from nodes (group by orgId)
      buildOrgGroups(data);
      renderGraph(data);
    } catch (e) {
      document.getElementById('graph-loading').innerHTML =
        '<div class="text-center"><span class="text-red-500 text-sm">Failed to load graph data.</span></div>';
    }
  }

  // ---- Build Org Groups ----
  // Group OOS file nodes by orgId to create org-level super-nodes
  function buildOrgGroups(data) {
    orgGroups = {};
    data.nodes.forEach(function(n) {
      var oid = n.orgId || n.id;
      if (!orgGroups[oid]) {
        orgGroups[oid] = {
          orgId: oid,
          orgName: n.orgName,
          template: n.template,
          industry: n.industry,
          qualityTier: n.qualityTier,
          badge: n.badge,
          oosIds: [],
          totalClaims: 0,
          claims: []
        };
      }
      orgGroups[oid].oosIds.push(n.id);
      orgGroups[oid].totalClaims += n.claimCount;
      // Collect claims for this OOS file
      var fileClaims = data.claims ? data.claims[n.id] || [] : [];
      fileClaims.forEach(function(c) {
        orgGroups[oid].claims.push({
          oosId: n.id,
          claimId: c.claimId,
          section: c.section,
          confidence: c.confidence,
          evidence: c.evidence,
          rule: c.rule
        });
      });
    });
  }

  // ---- Build Aggregated Edges ----
  // From raw similarities, build org-to-org aggregated edges filtered by minSimilarity
  function buildAggEdges() {
    var sims = graphData.similarities || [];
    // Map oosId -> orgId
    var oosToOrg = {};
    graphData.nodes.forEach(function(n) {
      oosToOrg[n.id] = n.orgId || n.id;
    });

    // Group similarities by org pair
    var pairMap = {};
    claimSimEdges = [];

    sims.forEach(function(s) {
      if (s.score < minSimilarity) return;
      var orgA = oosToOrg[s.oosAId];
      var orgB = oosToOrg[s.oosBId];
      if (!orgA || !orgB || orgA === orgB) return;

      var key = [orgA, orgB].sort().join(':');
      if (!pairMap[key]) {
        pairMap[key] = {
          sourceOrg: orgA < orgB ? orgA : orgB,
          targetOrg: orgA < orgB ? orgB : orgA,
          pairs: [],
          totalScore: 0
        };
      }
      pairMap[key].pairs.push({
        oosA: s.oosAId,
        oosB: s.oosBId,
        claimA: s.claimARule,
        claimB: s.claimBRule,
        score: s.score
      });
      pairMap[key].totalScore += s.score;

      // Also store for claim-level edges
      claimSimEdges.push({
        oosA: s.oosAId,
        oosB: s.oosBId,
        orgA: orgA,
        orgB: orgB,
        claimA: s.claimARule,
        claimB: s.claimBRule,
        score: s.score
      });
    });

    aggEdges = [];
    Object.keys(pairMap).forEach(function(key) {
      var p = pairMap[key];
      aggEdges.push({
        sourceOrg: p.sourceOrg,
        targetOrg: p.targetOrg,
        count: p.pairs.length,
        avgScore: p.totalScore / p.pairs.length,
        topClaims: p.pairs.sort(function(a, b) { return b.score - a.score; }).slice(0, 3)
      });
    });
  }

  // ---- Render ----
  function renderGraph(data) {
    var container = document.getElementById('graph-container');
    var width = container.clientWidth;
    var height = container.clientHeight;
    var svg = d3.select('#graph-svg');
    svg.selectAll('*').remove();

    // Defs for drop shadow
    var defs = svg.append('defs');
    var shadow = defs.append('filter').attr('id', 'drop-shadow').attr('x', '-50%').attr('y', '-50%').attr('width', '200%').attr('height', '200%');
    shadow.append('feDropShadow').attr('dx', '0').attr('dy', '2').attr('stdDeviation', '4').attr('flood-color', '#000000').attr('flood-opacity', '0.08');

    // Outer glow for selected org
    var glow = defs.append('filter').attr('id', 'org-glow').attr('x', '-50%').attr('y', '-50%').attr('width', '200%').attr('height', '200%');
    glow.append('feDropShadow').attr('dx', '0').attr('dy', '0').attr('stdDeviation', '8').attr('flood-color', '#6366f1').attr('flood-opacity', '0.3');

    gMain = svg.append('g').attr('class', 'graph-main');

    // Zoom
    var zoom = d3.zoom().scaleExtent([0.2, 5]).on('zoom', function(event) {
      gMain.attr('transform', event.transform);
    });
    svg.call(zoom);
    svg.call(zoom.transform, d3.zoomIdentity.translate(width / 2, height / 2).scale(0.9).translate(-width / 2, -height / 2));

    // Create layers in draw order
    orgEdgeLayer = gMain.append('g').attr('class', 'org-edges');
    claimEdgeLayer = gMain.append('g').attr('class', 'claim-edges');
    claimNodeLayer = gMain.append('g').attr('class', 'claim-nodes');
    orgNodeLayer = gMain.append('g').attr('class', 'org-nodes');

    // Build aggregated edges
    buildAggEdges();

    // Create org-level simulation data
    var orgArray = Object.values(orgGroups);
    orgArray.forEach(function(o, i) {
      o.x = width / 2 + (Math.cos(2 * Math.PI * i / orgArray.length) * 200);
      o.y = height / 2 + (Math.sin(2 * Math.PI * i / orgArray.length) * 200);
    });

    // Force simulation for org nodes only
    // Track which orgs have connections for gravity weighting
    var connectedOrgIds = {};
    aggEdges.forEach(function(e) {
      connectedOrgIds[e.sourceOrg] = true;
      connectedOrgIds[e.targetOrg] = true;
    });

    var maxRadius = Math.min(width, height) * 0.35;

    simulation = d3.forceSimulation(orgArray)
      .force('charge', d3.forceManyBody().strength(-1000))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collision', d3.forceCollide().radius(function(d) { return getOrgRadius(d) + 60; }))
      .force('radial', d3.forceRadial(
        function(d) { return connectedOrgIds[d.orgId] ? maxRadius : maxRadius * 0.6; },
        width / 2, height / 2
      ).strength(function(d) { return connectedOrgIds[d.orgId] ? 0.05 : 0.3; }))
      .force('link', d3.forceLink(aggEdges.map(function(e) {
        return {
          source: orgArray.find(function(o) { return o.orgId === e.sourceOrg; }),
          target: orgArray.find(function(o) { return o.orgId === e.targetOrg; })
        };
      }).filter(function(e) { return e.source && e.target; })).distance(300).strength(0.3));

    // Draw everything
    drawOrgEdges();
    drawOrgNodes(orgArray);

    // Tick
    simulation.on('tick', function() {
      updatePositions();
    });

    // Click background to deselect
    svg.on('click', function() {
      hideDetailPanel();
    });

    // Initial layer state
    updateLayers();
  }

  // ---- Draw Org-to-Org Aggregated Edges ----
  function drawOrgEdges() {
    orgEdgeLayer.selectAll('*').remove();

    if (!layers.connections) return;

    var orgArray = Object.values(orgGroups);

    aggEdges.forEach(function(edge) {
      var srcOrg = orgArray.find(function(o) { return o.orgId === edge.sourceOrg; });
      var tgtOrg = orgArray.find(function(o) { return o.orgId === edge.targetOrg; });
      if (!srcOrg || !tgtOrg) return;

      // Determine thickness: 1-3 thin(1.5), 4-7 medium(3), 8+ thick(5)
      var thickness = edge.count <= 3 ? 1.5 : (edge.count <= 7 ? 3 : 5);
      var isDashed = edge.avgScore < 0.5;
      // Color intensity based on avg score
      var opacity = 0.2 + (edge.avgScore * 0.5);

      var g = orgEdgeLayer.append('g').attr('class', 'agg-edge');

      // The path
      g.append('path')
        .attr('class', 'agg-edge-path')
        .datum({ srcOrg: srcOrg, tgtOrg: tgtOrg, edge: edge })
        .attr('fill', 'none')
        .attr('stroke', '#8b5cf6')
        .attr('stroke-width', thickness)
        .attr('stroke-opacity', opacity)
        .attr('stroke-dasharray', isDashed ? '6,4' : 'none')
        .style('cursor', 'pointer')
        .on('mouseenter', function(event) {
          d3.select(this).attr('stroke-opacity', Math.min(opacity + 0.3, 0.9));
          showTooltip(event, '<div class="text-gray-900 font-medium mb-1">' + edge.count + ' similar claim' + (edge.count > 1 ? 's' : '') + '</div>' +
            '<div class="text-gray-500 text-[11px] mb-1">Avg score: ' + edge.avgScore.toFixed(2) + '</div>' +
            edge.topClaims.slice(0, 2).map(function(tc) {
              return '<div class="text-gray-500 text-[10px] truncate mb-0.5">"' + truncate(tc.claimA, 40) + '"</div>';
            }).join('') +
            '<div class="text-gray-400 text-[10px] mt-1">Click to compare</div>');
        })
        .on('mouseleave', function() {
          d3.select(this).attr('stroke-opacity', opacity);
          hideTooltip();
        })
        .on('click', function(event) {
          event.stopPropagation();
          // Navigate to compare using first OOS IDs
          var srcOos = srcOrg.oosIds[0];
          var tgtOos = tgtOrg.oosIds[0];
          if (srcOos && tgtOos) {
            window.location.href = '/compare/' + srcOos + '/' + tgtOos;
          }
        });

      // Edge label
      g.append('text')
        .attr('class', 'agg-edge-label')
        .datum({ srcOrg: srcOrg, tgtOrg: tgtOrg, edge: edge })
        .attr('text-anchor', 'middle')
        .attr('font-size', '10px')
        .attr('fill', '#8b5cf6')
        .attr('fill-opacity', 0.7)
        .attr('dy', '-6')
        .text(edge.count + ' similarit' + (edge.count === 1 ? 'y' : 'ies'));
    });
  }

  // ---- Draw Claim-Level Edges ----
  function drawClaimEdges() {
    claimEdgeLayer.selectAll('*').remove();

    // Only draw when both connected orgs are expanded
    claimSimEdges.forEach(function(sim) {
      var bothExpanded = expandedOrgs[sim.orgA] && expandedOrgs[sim.orgB];
      if (!bothExpanded) return;

      // Find matching claim nodes
      var srcClaim = findClaimNode(sim.orgA, sim.claimA);
      var tgtClaim = findClaimNode(sim.orgB, sim.claimB);
      if (!srcClaim || !tgtClaim) return;

      claimEdgeLayer.append('line')
        .attr('class', 'claim-sim-line')
        .datum({ src: srcClaim, tgt: tgtClaim })
        .attr('stroke', '#c084fc')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.4)
        .attr('stroke-dasharray', '3,2');
    });
  }

  // Find a claim node DOM data by orgId and rule text
  function findClaimNode(orgId, ruleText) {
    var org = orgGroups[orgId];
    if (!org || !org.claimPositions) return null;
    for (var i = 0; i < org.claims.length; i++) {
      if (org.claims[i].rule === ruleText && org.claimPositions[i]) {
        return { x: org.claimPositions[i].x, y: org.claimPositions[i].y };
      }
    }
    return null;
  }

  // ---- Draw Org Nodes ----
  function drawOrgNodes(orgArray) {
    orgNodeLayer.selectAll('*').remove();

    orgNodeElems = orgNodeLayer.selectAll('g.org-group')
      .data(orgArray, function(d) { return d.orgId; })
      .join('g')
      .attr('class', 'org-group')
      .style('cursor', 'pointer')
      .call(d3.drag()
        .on('start', function(event, d) { if (!event.active) simulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on('drag', function(event, d) { d.fx = event.x; d.fy = event.y; })
        .on('end', function(event, d) { if (!event.active) simulation.alphaTarget(0); d.fx = null; d.fy = null; })
      );

    // Org main circle
    orgNodeElems.append('circle')
      .attr('class', 'org-circle')
      .attr('r', function(d) { return getOrgRadius(d); })
      .attr('fill', function(d) { return getNodeColor(d); })
      .attr('fill-opacity', 0.9)
      .attr('stroke', '#ffffff')
      .attr('stroke-width', 2.5)
      .attr('filter', 'url(#drop-shadow)');

    // Quality tier ring
    orgNodeElems.filter(function(d) { return d.qualityTier; })
      .append('circle')
      .attr('class', 'tier-ring')
      .attr('r', function(d) { return getOrgRadius(d) + 4; })
      .attr('fill', 'none')
      .attr('stroke', function(d) {
        var tierColors = { platinum: '#a78bfa', gold: '#fbbf24', silver: '#d1d5db', bronze: '#d97706' };
        return tierColors[d.qualityTier] || 'transparent';
      })
      .attr('stroke-width', 2)
      .attr('stroke-opacity', 0.6)
      .attr('stroke-dasharray', '4,3');

    // Initials (large, always visible)
    orgNodeElems.append('text')
      .attr('class', 'org-initials')
      .text(function(d) { return getInitials(d.orgName); })
      .attr('text-anchor', 'middle')
      .attr('dy', '0.1em')
      .attr('font-size', function(d) { return Math.max(14, getOrgRadius(d) * 0.5) + 'px'; })
      .attr('font-weight', '700')
      .attr('fill', '#fff')
      .attr('letter-spacing', '1px')
      .attr('pointer-events', 'none');

    // Claim count below initials
    orgNodeElems.append('text')
      .attr('class', 'org-stats')
      .text(function(d) { return d.totalClaims + ' claims'; })
      .attr('text-anchor', 'middle')
      .attr('dy', function(d) { return (getOrgRadius(d) * 0.35 + 12) + 'px'; })
      .attr('font-size', '9px')
      .attr('fill', 'rgba(255,255,255,0.75)')
      .attr('pointer-events', 'none');

    // Badge indicator (founding)
    orgNodeElems.filter(function(d) { return d.badge === 'founding'; })
      .append('g')
      .attr('class', 'badge-founding')
      .attr('transform', function(d) {
        var r = getOrgRadius(d);
        return 'translate(' + (r * 0.7) + ',' + (-r * 0.7) + ')';
      })
      .each(function() {
        d3.select(this).append('circle').attr('r', 8).attr('fill', '#f59e0b').attr('stroke', '#ffffff').attr('stroke-width', 2);
        d3.select(this).append('text').text('\u2605').attr('text-anchor', 'middle').attr('dy', '0.35em').attr('font-size', '8px').attr('fill', '#fff');
      });

    // Expand/collapse indicator (inside circle, bottom area)
    orgNodeElems.append('circle')
      .attr('class', 'expand-bg')
      .attr('cx', 0)
      .attr('cy', function(d) { return getOrgRadius(d) + 14; })
      .attr('r', 12)
      .attr('fill', '#ffffff')
      .attr('stroke', '#d1d5db')
      .attr('stroke-width', 1.5)
      .attr('filter', 'url(#drop-shadow)')
      .attr('cursor', 'pointer');

    orgNodeElems.append('text')
      .attr('class', 'expand-indicator')
      .text(function(d) { return expandedOrgs[d.orgId] ? '\u2212' : '+'; })
      .attr('text-anchor', 'middle')
      .attr('dy', function(d) { return getOrgRadius(d) + 19; })
      .attr('font-size', '18px')
      .attr('font-weight', '700')
      .attr('fill', '#374151')
      .attr('pointer-events', 'none');

    // Org node interaction
    orgNodeElems
      .on('click', function(event, d) {
        event.stopPropagation();
        toggleOrgExpand(d);
      })
      .on('mouseenter', function(event, d) {
        d3.select(this).select('.org-circle').attr('stroke-width', 3.5).attr('filter', 'url(#org-glow)');
        var eff = calcOrgGroupEfficiency(d);
        showTooltip(event, '<div class="text-gray-900 font-semibold mb-1">' + d.orgName + '</div>' +
          '<div class="flex items-center gap-2 mb-1">' +
          '<span class="text-[10px] px-1.5 py-0.5 rounded" style="background:' + (templateColors[d.template] || '#6b7280') + '18; color:' + (templateColors[d.template] || '#6b7280') + '">' + formatTemplate(d.template) + '</span>' +
          (d.industry ? '<span class="text-gray-500 text-[10px]">' + d.industry + '</span>' : '') +
          '</div>' +
          '<div class="text-gray-600 text-[11px]">' + d.totalClaims + ' claims across ' + d.oosIds.length + ' OOS file' + (d.oosIds.length > 1 ? 's' : '') + '</div>' +
          '<div class="text-[10px] mt-1" style="color:' + efficiencyColor(eff) + '">Token Efficiency: ' + eff.toFixed(1) + 'x ' + efficiencyLabel(eff) + '</div>' +
          (d.qualityTier ? '<div class="text-gray-500 text-[10px] capitalize">' + d.qualityTier + ' tier</div>' : '') +
          '<div class="text-gray-400 text-[10px] mt-1">Click to ' + (expandedOrgs[d.orgId] ? 'collapse' : 'expand claims') + '</div>');
      })
      .on('mouseleave', function() {
        d3.select(this).select('.org-circle').attr('stroke-width', 2.5).attr('filter', 'url(#drop-shadow)');
        hideTooltip();
      })
      .on('dblclick', function(event, d) {
        event.stopPropagation();
        showDetailPanel(d);
      });
  }

  // ---- Toggle Org Expand/Collapse ----
  function toggleOrgExpand(orgData) {
    var oid = orgData.orgId;
    if (expandedOrgs[oid]) {
      expandedOrgs[oid] = false;
    } else {
      expandedOrgs[oid] = true;
    }
    updateClaimNodes();
    drawClaimEdges();
    drawOrgEdges();
    updatePositions();

    // Update expand indicator
    orgNodeElems.select('.expand-indicator')
      .text(function(d) { return expandedOrgs[d.orgId] ? '\u2212' : '+'; });
  }

  // ---- Update Claim Nodes (radial layout around expanded orgs) ----
  function updateClaimNodes() {
    claimNodeLayer.selectAll('*').remove();

    var orgArray = Object.values(orgGroups);
    var showClaimColors = layers.sections || layers.confidence || layers.evidence;

    orgArray.forEach(function(org) {
      if (!expandedOrgs[org.orgId]) {
        org.claimPositions = null;
        return;
      }

      var claims = org.claims;
      if (claims.length === 0) {
        org.claimPositions = null;
        return;
      }

      // Compute radial positions around org center
      var baseRadius = getOrgRadius(org) + 25;
      var positions = [];
      var rings = Math.ceil(claims.length / 12);

      claims.forEach(function(c, i) {
        var ring = Math.floor(i / 12);
        var posInRing = i % 12;
        var ringCount = Math.min(12, claims.length - ring * 12);
        var angle = (2 * Math.PI * posInRing) / ringCount - Math.PI / 2;
        var r = baseRadius + ring * 18;
        positions.push({
          x: org.x + Math.cos(angle) * r,
          y: org.y + Math.sin(angle) * r,
          angle: angle,
          radius: r
        });
      });

      org.claimPositions = positions;

      // Draw claim dots
      var claimG = claimNodeLayer.selectAll('.claim-' + org.orgId.replace(/[^a-zA-Z0-9]/g, ''))
        .data(claims)
        .join('circle')
        .attr('class', 'claim-dot claim-' + org.orgId.replace(/[^a-zA-Z0-9]/g, ''))
        .attr('cx', function(d, i) { return positions[i].x; })
        .attr('cy', function(d, i) { return positions[i].y; })
        .attr('r', 0)
        .attr('fill', function(d) { return getClaimColor(d); })
        .attr('fill-opacity', 0.8)
        .attr('stroke', '#fff')
        .attr('stroke-width', 0.5)
        .style('cursor', 'pointer')
        .on('mouseenter', function(event, d) {
          d3.select(this).attr('r', 6).attr('fill-opacity', 1);
          showTooltip(event, '<div class="text-gray-900 font-medium mb-1">' + d.claimId + '</div>' +
            '<div class="text-gray-500 text-[11px] mb-1">' + formatSection(d.section) + '</div>' +
            '<div class="text-gray-500 text-[10px] leading-relaxed">' + truncate(d.rule, 120) + '</div>' +
            '<div class="flex gap-3 mt-2">' +
            '<span class="text-[10px]" style="color:' + (confidenceColors[d.confidence] || '#9ca3af') + '">' + d.confidence + '</span>' +
            '<span class="text-[10px]" style="color:' + (evidenceColors[d.evidence] || '#9ca3af') + '">' + formatEvidence(d.evidence) + '</span>' +
            '</div>');
        })
        .on('mouseleave', function() {
          d3.select(this).attr('r', 4).attr('fill-opacity', 0.8);
          hideTooltip();
        });

      // Animate claim dots expanding outward
      claimG.transition().duration(300).ease(d3.easeCubicOut)
        .attr('r', 4);

      // Draw radial connector lines from org center to each claim
      claims.forEach(function(c, i) {
        claimNodeLayer.append('line')
          .attr('class', 'claim-connector claim-' + org.orgId.replace(/[^a-zA-Z0-9]/g, ''))
          .attr('x1', org.x)
          .attr('y1', org.y)
          .attr('x2', positions[i].x)
          .attr('y2', positions[i].y)
          .attr('stroke', '#e5e7eb')
          .attr('stroke-width', 0.5)
          .attr('stroke-opacity', 0)
          .lower()
          .transition().duration(300)
          .attr('stroke-opacity', 0.4);
      });
    });
  }

  // ---- Update Positions (called on tick) ----
  function updatePositions() {
    if (!orgNodeElems) return;

    orgNodeElems.attr('transform', function(d) { return 'translate(' + d.x + ',' + d.y + ')'; });

    // Update aggregated edge paths
    orgEdgeLayer.selectAll('.agg-edge-path').each(function(d) {
      if (!d) return;
      var sx = d.srcOrg.x, sy = d.srcOrg.y, tx = d.tgtOrg.x, ty = d.tgtOrg.y;
      var dx = tx - sx, dy = ty - sy;
      var dist = Math.sqrt(dx * dx + dy * dy);
      var dr = dist * 0.6;
      d3.select(this).attr('d', 'M' + sx + ',' + sy + 'A' + dr + ',' + dr + ' 0 0,1 ' + tx + ',' + ty);
    });

    // Update edge labels
    orgEdgeLayer.selectAll('.agg-edge-label').each(function(d) {
      if (!d) return;
      var mx = (d.srcOrg.x + d.tgtOrg.x) / 2;
      var my = (d.srcOrg.y + d.tgtOrg.y) / 2;
      // Offset label slightly above the midpoint of the arc
      var dx = d.tgtOrg.x - d.srcOrg.x;
      var dy = d.tgtOrg.y - d.srcOrg.y;
      var len = Math.sqrt(dx * dx + dy * dy) || 1;
      var nx = -dy / len * 15;
      var ny = dx / len * 15;
      d3.select(this).attr('x', mx + nx).attr('y', my + ny);
    });

    // Update claim node positions if expanded
    var orgArray = Object.values(orgGroups);
    orgArray.forEach(function(org) {
      if (!expandedOrgs[org.orgId] || !org.claimPositions) return;

      var baseRadius = getOrgRadius(org) + 25;
      var claims = org.claims;

      // Recompute positions relative to current org position
      claims.forEach(function(c, i) {
        var ring = Math.floor(i / 12);
        var posInRing = i % 12;
        var ringCount = Math.min(12, claims.length - ring * 12);
        var angle = (2 * Math.PI * posInRing) / ringCount - Math.PI / 2;
        var r = baseRadius + ring * 18;
        org.claimPositions[i].x = org.x + Math.cos(angle) * r;
        org.claimPositions[i].y = org.y + Math.sin(angle) * r;
      });

      // Update claim dot positions
      var safeClass = org.orgId.replace(/[^a-zA-Z0-9]/g, '');
      claimNodeLayer.selectAll('circle.claim-' + safeClass)
        .attr('cx', function(d, i) { return org.claimPositions[i] ? org.claimPositions[i].x : org.x; })
        .attr('cy', function(d, i) { return org.claimPositions[i] ? org.claimPositions[i].y : org.y; });

      // Update connector lines
      var connectors = claimNodeLayer.selectAll('line.claim-' + safeClass);
      var ci = 0;
      connectors.each(function() {
        if (org.claimPositions[ci]) {
          d3.select(this)
            .attr('x1', org.x).attr('y1', org.y)
            .attr('x2', org.claimPositions[ci].x).attr('y2', org.claimPositions[ci].y);
        }
        ci++;
      });
    });

    // Update claim-to-claim edges
    claimEdgeLayer.selectAll('.claim-sim-line').each(function(d) {
      if (!d) return;
      d3.select(this)
        .attr('x1', d.src.x).attr('y1', d.src.y)
        .attr('x2', d.tgt.x).attr('y2', d.tgt.y);
    });
  }

  // ---- Helpers ----
  function getOrgRadius(d) {
    return Math.sqrt(d.totalClaims || d.claimCount || 10) * 5 + 20;
  }

  function calcOrgGroupEfficiency(orgData) {
    if (!graphData) return 0;
    var totalEff = 0;
    var count = 0;
    orgData.oosIds.forEach(function(oosId) {
      var eff = calcOrgEfficiency(oosId, graphData);
      if (eff > 0) { totalEff += eff; count++; }
    });
    return count > 0 ? totalEff / count : 0;
  }

  function getClaimColor(d) {
    if (layers.confidence) return confidenceColors[d.confidence] || '#9ca3af';
    if (layers.evidence) return evidenceColors[d.evidence] || '#9ca3af';
    if (layers.sections) return sectionColors[d.section] || '#6b7280';
    return '#64748b';
  }

  function truncate(str, len) {
    if (!str) return '';
    return str.length > len ? str.substring(0, len) + '...' : str;
  }

  function formatTemplate(t) {
    if (!t) return '';
    return t.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  function formatSection(s) {
    if (!s) return '';
    return s.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  function formatEvidence(e) {
    if (!e) return '';
    return e.replace(/_/g, ' ').toLowerCase().replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  // ---- Tooltip ----
  function showTooltip(event, html) {
    var tooltip = document.getElementById('graph-tooltip');
    var content = document.getElementById('tooltip-content');
    content.innerHTML = html;
    tooltip.classList.remove('hidden');

    var container = document.getElementById('graph-container');
    var rect = container.getBoundingClientRect();
    var x = event.clientX - rect.left + 15;
    var y = event.clientY - rect.top - 10;

    if (x + 280 > rect.width) x = event.clientX - rect.left - 295;
    if (y + 150 > rect.height) y = rect.height - 160;
    if (y < 10) y = 10;

    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }

  function hideTooltip() {
    document.getElementById('graph-tooltip').classList.add('hidden');
  }

  // ---- Detail Panel ----
  function buildCompareDropdown(d) {
    var orgArray = Object.values(orgGroups);
    if (orgArray.length < 2) return '';
    var others = orgArray.filter(function(o) { return o.orgId !== d.orgId; });
    if (others.length === 0) return '';

    var options = others.map(function(o) {
      return '<option value="' + o.oosIds[0] + '">' + o.orgName + ' (' + o.totalClaims + ' claims)</option>';
    }).join('');

    return '<div class="mt-3">' +
      '<label class="text-gray-400 text-[10px] uppercase tracking-wide block mb-1.5">Compare with</label>' +
      '<div class="flex gap-2">' +
      '<select id="compare-target" class="flex-1 bg-gray-50 border border-gray-200 rounded-lg px-2 py-1.5 text-gray-700 text-xs focus:border-otp-500 focus:outline-none appearance-none" style="background-image:url(\'data:image/svg+xml;utf8,<svg fill=\"%239ca3af\" viewBox=\"0 0 20 20\" xmlns=\"http://www.w3.org/2000/svg\"><path fill-rule=\"evenodd\" d=\"M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z\" clip-rule=\"evenodd\"/></svg>\'); background-repeat:no-repeat; background-position:right 8px center; background-size:14px; padding-right:28px;">' +
      options +
      '</select>' +
      '<button onclick="goCompare(\'' + d.oosIds[0] + '\')" class="px-3 py-1.5 bg-purple-50 text-purple-600 rounded-lg text-xs font-medium hover:bg-purple-100 transition-colors whitespace-nowrap border border-purple-200">Compare</button>' +
      '</div></div>';
  }

  window.goCompare = function(sourceId) {
    var sel = document.getElementById('compare-target');
    if (sel && sel.value) {
      window.location.href = '/compare/' + sourceId + '/' + sel.value;
    }
  };

  function showDetailPanel(d) {
    document.getElementById('layer-panel').classList.add('hidden');
    var panel = document.getElementById('detail-panel');
    panel.classList.remove('hidden');
    document.getElementById('detail-title').textContent = d.orgName;

    var claims = d.claims || [];
    var sectionCounts = {};
    claims.forEach(function(c) {
      sectionCounts[c.section] = (sectionCounts[c.section] || 0) + 1;
    });
    var topSections = Object.entries(sectionCounts).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 3);

    var tierBadge = '';
    if (d.qualityTier) {
      var tierC = { platinum: '#a78bfa', gold: '#fbbf24', silver: '#d1d5db', bronze: '#d97706' };
      tierBadge = '<span class="text-[10px] px-1.5 py-0.5 rounded capitalize" style="background:' + (tierC[d.qualityTier] || '#6b7280') + '15; color:' + (tierC[d.qualityTier] || '#6b7280') + '">' + d.qualityTier + '</span>';
    }

    var badgeHtml = '';
    if (d.badge === 'founding') {
      badgeHtml = '<span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-50 text-amber-600">\u2605 Founding</span>';
    }

    var eff = calcOrgGroupEfficiency(d);

    document.getElementById('detail-content').innerHTML =
      '<div class="flex items-center gap-2 mb-3">' +
      '<span class="text-[10px] px-1.5 py-0.5 rounded" style="background:' + (templateColors[d.template] || '#6b7280') + '18; color:' + (templateColors[d.template] || '#6b7280') + '">' + formatTemplate(d.template) + '</span>' +
      (d.industry ? '<span class="text-gray-500 text-[10px]">' + d.industry + '</span>' : '') +
      tierBadge + badgeHtml +
      '</div>' +
      '<div class="grid grid-cols-3 gap-2 mb-4">' +
      '<div class="bg-gray-50 rounded-lg px-3 py-2 border border-gray-100"><div class="text-gray-900 text-lg font-bold">' + d.totalClaims + '</div><div class="text-gray-400 text-[10px]">Claims</div></div>' +
      '<div class="bg-gray-50 rounded-lg px-3 py-2 border border-gray-100"><div class="text-gray-900 text-lg font-bold capitalize">' + (d.qualityTier || '--') + '</div><div class="text-gray-400 text-[10px]">Quality</div></div>' +
      '<div class="rounded-lg px-3 py-2 border" style="background:' + efficiencyColor(eff) + '10; border-color:' + efficiencyColor(eff) + '30"><div class="text-lg font-bold" style="color:' + efficiencyColor(eff) + '">' + eff.toFixed(1) + 'x</div><div class="text-[10px]" style="color:' + efficiencyColor(eff) + '">' + efficiencyLabel(eff) + '</div></div>' +
      '</div>' +
      (topSections.length > 0 ? '<div class="mb-4"><div class="text-gray-400 text-[10px] uppercase tracking-wide mb-2">Top Sections</div>' +
      topSections.map(function(s) {
        return '<div class="flex items-center justify-between py-1"><div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full" style="background:' + (sectionColors[s[0]] || '#6b7280') + '"></div><span class="text-gray-700 text-[11px]">' + formatSection(s[0]) + '</span></div><span class="text-gray-400 text-[11px]">' + s[1] + '</span></div>';
      }).join('') + '</div>' : '') +
      '<div class="flex gap-2 mt-3">' +
      '<a href="/oos/' + d.oosIds[0] + '" class="flex-1 text-center px-3 py-2 bg-otp-500/10 text-otp-500 rounded-lg text-xs font-medium hover:bg-otp-500/20 transition-colors border border-otp-500/20">View OOS</a>' +
      '</div>' +
      buildCompareDropdown(d);
  }

  function hideDetailPanel() {
    document.getElementById('detail-panel').classList.add('hidden');
    if (graphData && graphData.nodes && graphData.nodes.length > 0) {
      document.getElementById('layer-panel').classList.remove('hidden');
    }
  }

  // ---- Layer Controls ----
  function updateLayers() {
    layers.connections = document.getElementById('layer-connections').checked;
    layers.sections = document.getElementById('layer-sections').checked;
    layers.confidence = document.getElementById('layer-confidence').checked;
    layers.evidence = document.getElementById('layer-evidence').checked;
    layers.efficiency = document.getElementById('layer-efficiency').checked;

    // When efficiency layer is active, recolor org nodes
    if (orgNodeElems) {
      orgNodeElems.select('.org-circle')
        .transition().duration(400)
        .attr('fill', function(d) { return getNodeColor(d); });
    }

    // Redraw edges (connections toggle controls visibility)
    drawOrgEdges();
    // Force position update since simulation may have settled (tick no longer firing)
    updatePositions();

    // Update claim colors if any claims are expanded
    claimNodeLayer.selectAll('.claim-dot')
      .transition().duration(300)
      .attr('fill', function(d) { return getClaimColor(d); });

    // Section legend
    document.getElementById('section-legend').classList.toggle('hidden', !layers.sections);
  }

  // Wire up layer toggles
  ['layer-connections', 'layer-sections', 'layer-confidence', 'layer-evidence', 'layer-efficiency'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('change', updateLayers);
  });

  // Only allow one claim-coloring layer at a time
  ['layer-sections', 'layer-confidence', 'layer-evidence'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', function() {
        if (this.checked) {
          ['layer-sections', 'layer-confidence', 'layer-evidence'].forEach(function(otherId) {
            if (otherId !== id) document.getElementById(otherId).checked = false;
          });
        }
        updateLayers();
      });
    }
  });

  // Layer panel collapse toggle
  document.getElementById('layer-collapse').addEventListener('click', function() {
    if (currentMode === 'infrastructure') {
      var infraList = document.getElementById('infra-layer-list');
      var pLegend = document.getElementById('platform-legend');
      infraList.classList.toggle('hidden');
      pLegend.classList.toggle('hidden');
      this.querySelector('svg').style.transform = infraList.classList.contains('hidden') ? 'rotate(180deg)' : '';
    } else {
      var list = document.getElementById('layer-list');
      var legend = document.getElementById('section-legend');
      var slider = document.getElementById('sim-slider-section');
      list.classList.toggle('hidden');
      slider.classList.toggle('hidden');
      if (!layers.sections) legend.classList.add('hidden');
      this.querySelector('svg').style.transform = list.classList.contains('hidden') ? 'rotate(180deg)' : '';
    }
  });

  // Detail panel close
  document.getElementById('detail-close').addEventListener('click', function(e) {
    e.stopPropagation();
    hideDetailPanel();
  });

  // ---- Similarity Slider ----
  var simSlider = document.getElementById('sim-slider');
  var simSliderValue = document.getElementById('sim-slider-value');
  simSlider.addEventListener('input', function() {
    minSimilarity = parseFloat(this.value);
    simSliderValue.textContent = minSimilarity.toFixed(2);

    // Rebuild edges with new threshold
    buildAggEdges();
    drawOrgEdges();
    updatePositions();
    drawClaimEdges();

    // Update connection count in stats bar
    var totalConnections = 0;
    aggEdges.forEach(function(e) { totalConnections += e.count; });
    document.getElementById('stat-connections').textContent = totalConnections;
  });

  // ---- Mode Switching ----
  function switchMode(mode) {
    if (mode === 'economy') return; // Disabled
    if (mode === currentMode) return;
    currentMode = mode;

    // Update page title
    var titles = { intelligence: 'Intelligence Graph', infrastructure: 'Infrastructure Graph', economy: 'Economy Graph' };
    var titleEl = document.querySelector('#graph-page h1');
    if (titleEl) titleEl.textContent = titles[mode] || 'Intelligence Graph';

    // Update tab styling
    document.querySelectorAll('.mode-tab').forEach(function(tab) {
      var m = tab.getAttribute('data-mode');
      if (m === 'economy') return; // Economy always stays grey
      if (m === mode) {
        tab.classList.remove('bg-transparent', 'text-gray-600');
        tab.classList.add('bg-otp-500', 'text-white');
      } else {
        tab.classList.remove('bg-otp-500', 'text-white');
        tab.classList.add('bg-transparent', 'text-gray-600');
      }
    });

    // Show/hide appropriate UI
    var economyPlaceholder = document.getElementById('graph-economy');
    var svgCanvas = document.getElementById('graph-svg');
    var layerPanel = document.getElementById('layer-panel');

    if (mode === 'economy') {
      economyPlaceholder.classList.remove('hidden');
      svgCanvas.style.display = 'none';
      layerPanel.classList.add('hidden');
      return;
    }

    economyPlaceholder.classList.add('hidden');
    svgCanvas.style.display = '';

    // Toggle layer lists based on mode
    var intelligenceLayers = document.getElementById('layer-list');
    var infraLayers = document.getElementById('infra-layer-list');
    var simSliderSection = document.getElementById('sim-slider-section');
    var sectionLegend = document.getElementById('section-legend');
    var platformLegend = document.getElementById('platform-legend');

    if (mode === 'intelligence') {
      intelligenceLayers.classList.remove('hidden');
      infraLayers.classList.add('hidden');
      simSliderSection.classList.remove('hidden');
      platformLegend.classList.add('hidden');
      sectionLegend.classList.toggle('hidden', !layers.sections);
    } else if (mode === 'infrastructure') {
      intelligenceLayers.classList.add('hidden');
      infraLayers.classList.remove('hidden');
      simSliderSection.classList.add('hidden');
      sectionLegend.classList.add('hidden');
      platformLegend.classList.remove('hidden');
    }

    // Stop previous simulation
    if (simulation) { simulation.stop(); simulation = null; }
    if (infraSimulation) { infraSimulation.stop(); infraSimulation = null; }

    // Clear and rebuild
    if (!graphData || !graphData.nodes || graphData.nodes.length === 0) return;

    hideDetailPanel();

    // Update stats bar
    updateStatsBar(mode);

    if (mode === 'intelligence') {
      buildOrgGroups(graphData);
      expandedOrgs = {};
      renderGraph(graphData);
    } else if (mode === 'infrastructure') {
      renderInfrastructureGraph(graphData);
    }
  }

  function updateStatsBar(mode) {
    if (!graphData) return;

    var statLabels = {
      intelligence: [
        { id: 'stat-publishers', label: 'Publishers', value: graphData.stats?.publishers || 0 },
        { id: 'stat-claims', label: 'Claims', value: graphData.stats?.totalClaims || 0 },
        { id: 'stat-connections', label: 'Connections', value: graphData.stats?.connections || 0 },
        { id: 'stat-patterns', label: 'Patterns', value: graphData.stats?.patterns || 0 },
      ],
      infrastructure: [
        { id: 'stat-publishers', label: 'Publishers', value: graphData.stats?.publishers || 0 },
        { id: 'stat-claims', label: 'AI Platforms', value: graphData.platformStats ? (graphData.platformStats.aiPlatformCount || 0) : 0 },
        { id: 'stat-connections', label: 'MCP Servers', value: graphData.platformStats ? (graphData.platformStats.mcpServerCount || 0) : 0 },
        { id: 'stat-patterns', label: 'Total Connections', value: graphData.platformStats ? graphData.platformStats.totalConnections : 0 },
      ],
    };

    var stats = statLabels[mode] || statLabels.intelligence;
    stats.forEach(function(s) {
      var el = document.getElementById(s.id);
      if (el) {
        el.textContent = s.value;
        el.style.color = '';
      }
      // Update the label too
      var labelEl = el ? el.previousElementSibling : null;
      if (labelEl) labelEl.textContent = s.label;
    });

    // Reset efficiency stat
    var effEl = document.getElementById('stat-efficiency');
    if (mode === 'infrastructure') {
      effEl.textContent = '--';
      effEl.style.color = '';
      var effLabel = effEl.previousElementSibling;
      if (effLabel) effLabel.textContent = 'Avg Efficiency';
    } else {
      // Recalculate efficiency for intelligence mode
      if (graphData.nodes && graphData.nodes.length > 0) {
        var totalEff = 0;
        graphData.nodes.forEach(function(n) { totalEff += calcOrgEfficiency(n.id, graphData); });
        var avgEff = totalEff / graphData.nodes.length;
        effEl.textContent = avgEff.toFixed(1) + 'x';
        effEl.style.color = efficiencyColor(avgEff);
      }
    }
  }

  // ---- Infrastructure Mode ----
  function renderInfrastructureGraph(data) {
    var container = document.getElementById('graph-container');
    var width = container.clientWidth;
    var height = container.clientHeight;
    var svg = d3.select('#graph-svg');
    svg.selectAll('*').remove();

    // Defs
    var defs = svg.append('defs');
    var shadow = defs.append('filter').attr('id', 'drop-shadow').attr('x', '-50%').attr('y', '-50%').attr('width', '200%').attr('height', '200%');
    shadow.append('feDropShadow').attr('dx', '0').attr('dy', '2').attr('stdDeviation', '4').attr('flood-color', '#000000').attr('flood-opacity', '0.08');

    var glow = defs.append('filter').attr('id', 'org-glow').attr('x', '-50%').attr('y', '-50%').attr('width', '200%').attr('height', '200%');
    glow.append('feDropShadow').attr('dx', '0').attr('dy', '0').attr('stdDeviation', '8').attr('flood-color', '#6366f1').attr('flood-opacity', '0.3');

    var infraMain = svg.append('g').attr('class', 'infra-main');

    // Zoom
    var zoom = d3.zoom().scaleExtent([0.2, 5]).on('zoom', function(event) {
      infraMain.attr('transform', event.transform);
    });
    svg.call(zoom);
    svg.call(zoom.transform, d3.zoomIdentity.translate(width / 2, height / 2).scale(0.9).translate(-width / 2, -height / 2));

    // Create layers
    var edgeLayer = infraMain.append('g').attr('class', 'infra-edges');
    var mcpNodeLayer = infraMain.append('g').attr('class', 'infra-mcp-nodes');
    var platformNodeLayer = infraMain.append('g').attr('class', 'infra-platform-nodes');
    var orgNodeLayerInfra = infraMain.append('g').attr('class', 'infra-org-nodes');

    // Build node data -- new format: nodePlatforms[oosId] = { platforms: [...], mcpServers: [...] }
    var nodePlatforms = data.nodePlatforms || {};
    var platformStatsData = data.platformStats || { platforms: [], totalConnections: 0 };

    // Build org nodes (reuse orgGroups)
    buildOrgGroups(data);
    var orgArray = Object.values(orgGroups);

    // Separate platform stats into AI platforms and MCP servers
    var aiPlatformStats = (platformStatsData.platforms || []).filter(function(p) { return p.type === 'platform'; });
    var mcpServerStats = (platformStatsData.platforms || []).filter(function(p) { return p.type === 'mcp'; });

    // Build AI platform nodes (diamond shape)
    var platformNodes = aiPlatformStats.map(function(p) {
      return {
        id: 'platform-' + p.name,
        name: p.name,
        orgCount: p.orgCount,
        _infraType: 'platform',
        _infraId: 'platform-' + p.name,
      };
    });

    // Build MCP server nodes (pill/rounded-rect shape)
    var mcpNodes = mcpServerStats.map(function(p) {
      return {
        id: 'mcp-' + p.name,
        name: p.name,
        orgCount: p.orgCount,
        _infraType: 'mcp',
        _infraId: 'mcp-' + p.name,
      };
    });

    // Build edges: org -> platform and org -> mcp
    var infraEdges = [];
    orgArray.forEach(function(org) {
      var orgPlatformSet = {};
      var orgMcpSet = {};
      org.oosIds.forEach(function(oosId) {
        var nodeData = nodePlatforms[oosId];
        if (!nodeData) return;
        // Handle both old format (array) and new format (object with platforms + mcpServers)
        var platforms = Array.isArray(nodeData) ? nodeData : (nodeData.platforms || []);
        var mcpServers = Array.isArray(nodeData) ? [] : (nodeData.mcpServers || []);
        platforms.forEach(function(p) { orgPlatformSet[p.toLowerCase()] = true; });
        mcpServers.forEach(function(m) { orgMcpSet[m.toLowerCase()] = true; });
      });
      Object.keys(orgPlatformSet).forEach(function(pName) {
        infraEdges.push({
          sourceOrg: org.orgId,
          targetId: 'platform-' + pName,
          name: pName,
          type: 'platform',
        });
      });
      Object.keys(orgMcpSet).forEach(function(mName) {
        infraEdges.push({
          sourceOrg: org.orgId,
          targetId: 'mcp-' + mName,
          name: mName,
          type: 'mcp',
        });
      });
    });

    // Check layer states
    var showPlatforms = document.getElementById('infra-layer-platforms').checked;
    var showMcp = document.getElementById('infra-layer-mcp').checked;
    var showConnections = document.getElementById('infra-layer-connections').checked;

    // Combine all nodes for simulation
    var allNodes = [];
    orgArray.forEach(function(o) {
      o._infraType = 'org';
      o._infraId = o.orgId;
      allNodes.push(o);
    });
    platformNodes.forEach(function(p) { allNodes.push(p); });
    mcpNodes.forEach(function(m) { allNodes.push(m); });

    // Initial positions: platforms center, MCP outer ring, orgs outside
    var platformCount = platformNodes.length;
    var mcpCount = mcpNodes.length;
    var orgCount = orgArray.length;
    var pIdx = 0, mIdx = 0, oIdx = 0;

    allNodes.forEach(function(n) {
      if (n._infraType === 'platform') {
        var angle = (2 * Math.PI * pIdx) / Math.max(platformCount, 1);
        n.x = width / 2 + Math.cos(angle) * 60;
        n.y = height / 2 + Math.sin(angle) * 60;
        pIdx++;
      } else if (n._infraType === 'mcp') {
        var angle = (2 * Math.PI * mIdx) / Math.max(mcpCount, 1);
        n.x = width / 2 + Math.cos(angle) * 180;
        n.y = height / 2 + Math.sin(angle) * 180;
        mIdx++;
      } else {
        var angle = (2 * Math.PI * oIdx) / Math.max(orgCount, 1);
        n.x = width / 2 + Math.cos(angle) * 320;
        n.y = height / 2 + Math.sin(angle) * 320;
        oIdx++;
      }
    });

    // Build simulation links
    var simLinks = infraEdges.map(function(e) {
      return {
        source: allNodes.find(function(n) { return n._infraId === e.sourceOrg; }),
        target: allNodes.find(function(n) { return n._infraId === e.targetId; }),
        edge: e,
      };
    }).filter(function(l) { return l.source && l.target; });

    // Force simulation
    infraSimulation = d3.forceSimulation(allNodes)
      .force('charge', d3.forceManyBody().strength(function(d) {
        if (d._infraType === 'platform') return -300;
        if (d._infraType === 'mcp') return -200;
        return -500;
      }))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collision', d3.forceCollide().radius(function(d) {
        if (d._infraType === 'platform') return getInfraPlatformRadius(d) + 25;
        if (d._infraType === 'mcp') return getInfraMcpWidth(d) / 2 + 15;
        return getOrgRadius(d) + 35;
      }))
      .force('link', d3.forceLink(simLinks).distance(function(d) {
        // Shorter links for platform connections, longer for MCP
        return d.edge.type === 'platform' ? 160 : 200;
      }).strength(0.3))
      .force('radial', d3.forceRadial(
        function(d) {
          if (d._infraType === 'platform') return 0;
          if (d._infraType === 'mcp') return Math.min(width, height) * 0.18;
          return Math.min(width, height) * 0.35;
        },
        width / 2, height / 2
      ).strength(function(d) {
        if (d._infraType === 'platform') return 0.4;
        if (d._infraType === 'mcp') return 0.15;
        return 0.05;
      }));

    // Draw edges
    var edgeElems = edgeLayer.selectAll('line.infra-edge')
      .data(simLinks)
      .join('line')
      .attr('class', 'infra-edge')
      .attr('stroke', function(d) { return getInfraColor(d.edge.name, d.edge.type); })
      .attr('stroke-width', function(d) { return d.edge.type === 'mcp' ? 1 : 1.5; })
      .attr('stroke-opacity', showConnections ? 0.3 : 0)
      .attr('stroke-dasharray', function(d) { return d.edge.type === 'mcp' ? '3,2' : '4,3'; });

    // Draw AI platform nodes (diamonds)
    var platformElems = platformNodeLayer.selectAll('g.platform-node')
      .data(platformNodes)
      .join('g')
      .attr('class', 'platform-node')
      .style('cursor', 'pointer')
      .style('display', showPlatforms ? null : 'none')
      .call(d3.drag()
        .on('start', function(event, d) { if (!event.active) infraSimulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on('drag', function(event, d) { d.fx = event.x; d.fy = event.y; })
        .on('end', function(event, d) { if (!event.active) infraSimulation.alphaTarget(0); d.fx = null; d.fy = null; })
      );

    // Diamond shape (rotated square)
    platformElems.append('rect')
      .attr('class', 'platform-diamond')
      .attr('width', function(d) { return getInfraPlatformRadius(d) * 2; })
      .attr('height', function(d) { return getInfraPlatformRadius(d) * 2; })
      .attr('x', function(d) { return -getInfraPlatformRadius(d); })
      .attr('y', function(d) { return -getInfraPlatformRadius(d); })
      .attr('rx', 3)
      .attr('transform', 'rotate(45)')
      .attr('fill', function(d) { return getPlatformColor(d.name); })
      .attr('fill-opacity', 0.85)
      .attr('stroke', '#ffffff')
      .attr('stroke-width', 2)
      .attr('filter', 'url(#drop-shadow)');

    // Platform label below
    platformElems.append('text')
      .attr('text-anchor', 'middle')
      .attr('dy', function(d) { return getInfraPlatformRadius(d) + 16; })
      .attr('font-size', '10px')
      .attr('font-weight', '600')
      .attr('fill', function(d) { return getPlatformColor(d.name); })
      .text(function(d) { return d.name; });

    // Platform count inside diamond
    platformElems.append('text')
      .attr('text-anchor', 'middle')
      .attr('dy', '0.35em')
      .attr('font-size', function(d) { return Math.max(9, getInfraPlatformRadius(d) * 0.6) + 'px'; })
      .attr('font-weight', '700')
      .attr('fill', '#fff')
      .attr('pointer-events', 'none')
      .text(function(d) { return d.orgCount; });

    // Platform tooltips
    platformElems
      .on('mouseenter', function(event, d) {
        d3.select(this).select('.platform-diamond').attr('stroke-width', 3).attr('filter', 'url(#org-glow)');
        var connectedOrgs = infraEdges
          .filter(function(e) { return e.targetId === d.id; })
          .map(function(e) {
            var org = orgArray.find(function(o) { return o.orgId === e.sourceOrg; });
            return org ? org.orgName : '';
          })
          .filter(function(n) { return n; });
        showTooltip(event,
          '<div class="text-gray-900 font-semibold mb-1">' + d.name + '</div>' +
          '<div class="text-[10px] px-1.5 py-0.5 rounded bg-purple-50 text-purple-600 inline-block mb-2">AI Platform</div>' +
          '<div class="text-gray-500 text-[11px] mb-2">' + d.orgCount + ' organization' + (d.orgCount !== 1 ? 's' : '') + '</div>' +
          '<div class="text-gray-400 text-[10px] uppercase tracking-wide mb-1">Used by</div>' +
          connectedOrgs.slice(0, 6).map(function(n) {
            return '<div class="text-gray-600 text-[11px]">' + n + '</div>';
          }).join('') +
          (connectedOrgs.length > 6 ? '<div class="text-gray-400 text-[10px] mt-1">+' + (connectedOrgs.length - 6) + ' more</div>' : '')
        );
      })
      .on('mouseleave', function() {
        d3.select(this).select('.platform-diamond').attr('stroke-width', 2).attr('filter', 'url(#drop-shadow)');
        hideTooltip();
      })
      .on('click', function(event, d) {
        event.stopPropagation();
        showInfraDetailPanel(d, 'platform', orgArray, infraEdges);
      });

    // Draw MCP server nodes (rounded rectangles / pills)
    var mcpElems = mcpNodeLayer.selectAll('g.mcp-node')
      .data(mcpNodes)
      .join('g')
      .attr('class', 'mcp-node')
      .style('cursor', 'pointer')
      .style('display', showMcp ? null : 'none')
      .call(d3.drag()
        .on('start', function(event, d) { if (!event.active) infraSimulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on('drag', function(event, d) { d.fx = event.x; d.fy = event.y; })
        .on('end', function(event, d) { if (!event.active) infraSimulation.alphaTarget(0); d.fx = null; d.fy = null; })
      );

    // Pill/rounded-rect shape for MCP servers
    mcpElems.append('rect')
      .attr('class', 'mcp-pill')
      .attr('width', function(d) { return getInfraMcpWidth(d); })
      .attr('height', function(d) { return getInfraMcpHeight(d); })
      .attr('x', function(d) { return -getInfraMcpWidth(d) / 2; })
      .attr('y', function(d) { return -getInfraMcpHeight(d) / 2; })
      .attr('rx', function(d) { return getInfraMcpHeight(d) / 2; })
      .attr('ry', function(d) { return getInfraMcpHeight(d) / 2; })
      .attr('fill', function(d) { return getMcpColor(d.name); })
      .attr('fill-opacity', 0.85)
      .attr('stroke', '#ffffff')
      .attr('stroke-width', 1.5)
      .attr('filter', 'url(#drop-shadow)');

    // MCP server name inside pill
    mcpElems.append('text')
      .attr('text-anchor', 'middle')
      .attr('dy', '0.35em')
      .attr('font-size', '9px')
      .attr('font-weight', '600')
      .attr('fill', '#fff')
      .attr('pointer-events', 'none')
      .text(function(d) { return formatMcpName(d.name); });

    // MCP tooltips
    mcpElems
      .on('mouseenter', function(event, d) {
        d3.select(this).select('.mcp-pill').attr('stroke-width', 2.5).attr('filter', 'url(#org-glow)');
        var connectedOrgs = infraEdges
          .filter(function(e) { return e.targetId === d.id; })
          .map(function(e) {
            var org = orgArray.find(function(o) { return o.orgId === e.sourceOrg; });
            return org ? org.orgName : '';
          })
          .filter(function(n) { return n; });
        showTooltip(event,
          '<div class="text-gray-900 font-semibold mb-1">' + d.name + '</div>' +
          '<div class="text-[10px] px-1.5 py-0.5 rounded bg-cyan-50 text-cyan-600 inline-block mb-2">MCP Server</div>' +
          '<div class="text-gray-500 text-[11px] mb-2">' + d.orgCount + ' organization' + (d.orgCount !== 1 ? 's' : '') + '</div>' +
          '<div class="text-gray-400 text-[10px] uppercase tracking-wide mb-1">Used by</div>' +
          connectedOrgs.slice(0, 6).map(function(n) {
            return '<div class="text-gray-600 text-[11px]">' + n + '</div>';
          }).join('') +
          (connectedOrgs.length > 6 ? '<div class="text-gray-400 text-[10px] mt-1">+' + (connectedOrgs.length - 6) + ' more</div>' : '')
        );
      })
      .on('mouseleave', function() {
        d3.select(this).select('.mcp-pill').attr('stroke-width', 1.5).attr('filter', 'url(#drop-shadow)');
        hideTooltip();
      })
      .on('click', function(event, d) {
        event.stopPropagation();
        showInfraDetailPanel(d, 'mcp', orgArray, infraEdges);
      });

    // Draw org nodes (circles, same as intelligence mode)
    var orgElems = orgNodeLayerInfra.selectAll('g.infra-org-group')
      .data(orgArray, function(d) { return d.orgId; })
      .join('g')
      .attr('class', 'infra-org-group')
      .style('cursor', 'pointer')
      .call(d3.drag()
        .on('start', function(event, d) { if (!event.active) infraSimulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
        .on('drag', function(event, d) { d.fx = event.x; d.fy = event.y; })
        .on('end', function(event, d) { if (!event.active) infraSimulation.alphaTarget(0); d.fx = null; d.fy = null; })
      );

    orgElems.append('circle')
      .attr('class', 'org-circle')
      .attr('r', function(d) { return getOrgRadius(d); })
      .attr('fill', function(d) { return industryColors[d.industry] || templateColors[d.template] || '#6b7280'; })
      .attr('fill-opacity', 0.9)
      .attr('stroke', '#ffffff')
      .attr('stroke-width', 2.5)
      .attr('filter', 'url(#drop-shadow)');

    orgElems.filter(function(d) { return d.qualityTier; })
      .append('circle')
      .attr('class', 'tier-ring')
      .attr('r', function(d) { return getOrgRadius(d) + 4; })
      .attr('fill', 'none')
      .attr('stroke', function(d) {
        var tierColors = { platinum: '#a78bfa', gold: '#fbbf24', silver: '#d1d5db', bronze: '#d97706' };
        return tierColors[d.qualityTier] || 'transparent';
      })
      .attr('stroke-width', 2)
      .attr('stroke-opacity', 0.6)
      .attr('stroke-dasharray', '4,3');

    orgElems.append('text')
      .attr('class', 'org-initials')
      .text(function(d) { return getInitials(d.orgName); })
      .attr('text-anchor', 'middle')
      .attr('dy', '0.1em')
      .attr('font-size', function(d) { return Math.max(14, getOrgRadius(d) * 0.5) + 'px'; })
      .attr('font-weight', '700')
      .attr('fill', '#fff')
      .attr('letter-spacing', '1px')
      .attr('pointer-events', 'none');

    orgElems.append('text')
      .attr('class', 'org-stats')
      .text(function(d) {
        var pCount = 0;
        var mCount = 0;
        d.oosIds.forEach(function(oosId) {
          var nodeData = nodePlatforms[oosId];
          if (!nodeData) return;
          var platforms = Array.isArray(nodeData) ? nodeData : (nodeData.platforms || []);
          var mcpServers = Array.isArray(nodeData) ? [] : (nodeData.mcpServers || []);
          pCount += platforms.length;
          mCount += mcpServers.length;
        });
        if (mCount > 0) return pCount + ' plat + ' + mCount + ' MCP';
        return pCount + ' platform' + (pCount !== 1 ? 's' : '');
      })
      .attr('text-anchor', 'middle')
      .attr('dy', function(d) { return (getOrgRadius(d) * 0.35 + 12) + 'px'; })
      .attr('font-size', '9px')
      .attr('fill', 'rgba(255,255,255,0.75)')
      .attr('pointer-events', 'none');

    // Badge indicator
    orgElems.filter(function(d) { return d.badge === 'founding'; })
      .append('g')
      .attr('class', 'badge-founding')
      .attr('transform', function(d) {
        var r = getOrgRadius(d);
        return 'translate(' + (r * 0.7) + ',' + (-r * 0.7) + ')';
      })
      .each(function() {
        d3.select(this).append('circle').attr('r', 8).attr('fill', '#f59e0b').attr('stroke', '#ffffff').attr('stroke-width', 2);
        d3.select(this).append('text').text('\u2605').attr('text-anchor', 'middle').attr('dy', '0.35em').attr('font-size', '8px').attr('fill', '#fff');
      });

    orgElems
      .on('mouseenter', function(event, d) {
        d3.select(this).select('.org-circle').attr('stroke-width', 3.5).attr('filter', 'url(#org-glow)');
        // Find platforms and MCP servers used by this org
        var orgPlatformNames = [];
        var orgMcpNames = [];
        d.oosIds.forEach(function(oosId) {
          var nodeData = nodePlatforms[oosId];
          if (!nodeData) return;
          var platforms = Array.isArray(nodeData) ? nodeData : (nodeData.platforms || []);
          var mcpServers = Array.isArray(nodeData) ? [] : (nodeData.mcpServers || []);
          platforms.forEach(function(p) { if (orgPlatformNames.indexOf(p) === -1) orgPlatformNames.push(p); });
          mcpServers.forEach(function(m) { if (orgMcpNames.indexOf(m) === -1) orgMcpNames.push(m); });
        });
        var platformHtml = orgPlatformNames.length > 0 ?
          '<div class="text-gray-400 text-[10px] uppercase tracking-wide mb-1 mt-1">AI Platforms</div>' +
          orgPlatformNames.map(function(p) {
            return '<div class="flex items-center gap-1.5 text-[11px]"><div class="w-2 h-2 rounded-sm rotate-45" style="background:' + getPlatformColor(p) + '"></div><span class="text-gray-600">' + p + '</span></div>';
          }).join('') : '';
        var mcpHtml = orgMcpNames.length > 0 ?
          '<div class="text-gray-400 text-[10px] uppercase tracking-wide mb-1 mt-1">MCP Servers</div>' +
          orgMcpNames.slice(0, 8).map(function(m) {
            return '<div class="flex items-center gap-1.5 text-[11px]"><div class="w-2 h-2 rounded-sm" style="background:' + getMcpColor(m) + '; border-radius:2px;"></div><span class="text-gray-600">' + m + '</span></div>';
          }).join('') +
          (orgMcpNames.length > 8 ? '<div class="text-gray-400 text-[10px] mt-0.5">+' + (orgMcpNames.length - 8) + ' more</div>' : '') : '';
        showTooltip(event,
          '<div class="text-gray-900 font-semibold mb-1">' + d.orgName + '</div>' +
          '<div class="flex items-center gap-2 mb-1">' +
          '<span class="text-[10px] px-1.5 py-0.5 rounded" style="background:' + (templateColors[d.template] || '#6b7280') + '18; color:' + (templateColors[d.template] || '#6b7280') + '">' + formatTemplate(d.template) + '</span>' +
          '</div>' +
          platformHtml + mcpHtml
        );
      })
      .on('mouseleave', function() {
        d3.select(this).select('.org-circle').attr('stroke-width', 2.5).attr('filter', 'url(#drop-shadow)');
        hideTooltip();
      })
      .on('click', function(event, d) {
        event.stopPropagation();
        showDetailPanel(d);
      });

    // Tick handler
    infraSimulation.on('tick', function() {
      edgeElems
        .attr('x1', function(d) { return d.source.x; })
        .attr('y1', function(d) { return d.source.y; })
        .attr('x2', function(d) { return d.target.x; })
        .attr('y2', function(d) { return d.target.y; });

      platformElems.attr('transform', function(d) { return 'translate(' + d.x + ',' + d.y + ')'; });
      mcpElems.attr('transform', function(d) { return 'translate(' + d.x + ',' + d.y + ')'; });
      orgElems.attr('transform', function(d) { return 'translate(' + d.x + ',' + d.y + ')'; });
    });

    // Click background to deselect
    svg.on('click', function() {
      hideDetailPanel();
    });

    // Show layer panel
    document.getElementById('layer-panel').classList.remove('hidden');

    // Wire up infra layer toggles
    var infraPlatformsCb = document.getElementById('infra-layer-platforms');
    var infraMcpCb = document.getElementById('infra-layer-mcp');
    var infraConnCb = document.getElementById('infra-layer-connections');

    function updateInfraLayers() {
      var showP = infraPlatformsCb.checked;
      var showM = infraMcpCb.checked;
      var showC = infraConnCb.checked;
      platformElems.style('display', showP ? null : 'none');
      mcpElems.style('display', showM ? null : 'none');
      edgeElems.each(function(d) {
        var isVisible = showC;
        if (isVisible) {
          // Also check if the target node type is visible
          if (d.edge.type === 'platform' && !showP) isVisible = false;
          if (d.edge.type === 'mcp' && !showM) isVisible = false;
        }
        d3.select(this).attr('stroke-opacity', isVisible ? 0.3 : 0);
      });
      document.getElementById('platform-legend').classList.toggle('hidden', !showP && !showM);
    }

    infraPlatformsCb.onchange = updateInfraLayers;
    infraMcpCb.onchange = updateInfraLayers;
    infraConnCb.onchange = updateInfraLayers;
  }

  function getInfraPlatformRadius(d) {
    // Scale from 15 to 30 based on org count
    return Math.max(15, Math.min(30, 12 + d.orgCount * 4));
  }

  function getInfraMcpWidth(d) {
    // Scale pill width based on name length and org count
    var nameLen = formatMcpName(d.name).length;
    return Math.max(50, Math.min(90, nameLen * 6 + 20));
  }

  function getInfraMcpHeight(d) {
    return 22;
  }

  function formatMcpName(name) {
    if (!name) return '';
    // Capitalize and clean up hyphenated names
    return name.split('-').map(function(w) {
      return w.charAt(0).toUpperCase() + w.slice(1);
    }).join(' ');
  }

  function showInfraDetailPanel(d, type, orgArray, infraEdges) {
    document.getElementById('layer-panel').classList.add('hidden');
    var panel = document.getElementById('detail-panel');
    panel.classList.remove('hidden');

    var typeLabel = type === 'mcp' ? 'MCP Server' : 'AI Platform';
    var color = type === 'mcp' ? getMcpColor(d.name) : getPlatformColor(d.name);
    var badgeClass = type === 'mcp' ? 'bg-cyan-50 text-cyan-600' : 'bg-purple-50 text-purple-600';

    document.getElementById('detail-title').textContent = d.name;

    var connectedOrgs = infraEdges
      .filter(function(e) { return e.targetId === d.id; })
      .map(function(e) {
        return orgArray.find(function(o) { return o.orgId === e.sourceOrg; });
      })
      .filter(function(o) { return o; });

    var shapeHtml = type === 'mcp'
      ? '<div class="w-5 h-3 rounded-full" style="background:' + color + '"></div>'
      : '<div class="w-5 h-5 rounded-sm rotate-45" style="background:' + color + '"></div>';

    document.getElementById('detail-content').innerHTML =
      '<div class="flex items-center gap-2 mb-3">' +
      shapeHtml +
      '<span class="text-[10px] px-1.5 py-0.5 rounded ' + badgeClass + '">' + typeLabel + '</span>' +
      '</div>' +
      '<div class="grid grid-cols-2 gap-2 mb-4">' +
      '<div class="bg-gray-50 rounded-lg px-3 py-2 border border-gray-100"><div class="text-gray-900 text-lg font-bold">' + d.orgCount + '</div><div class="text-gray-400 text-[10px]">Organizations</div></div>' +
      '<div class="bg-gray-50 rounded-lg px-3 py-2 border border-gray-100"><div class="text-gray-900 text-lg font-bold">' + Math.round(d.orgCount / Math.max(orgArray.length, 1) * 100) + '%</div><div class="text-gray-400 text-[10px]">Adoption</div></div>' +
      '</div>' +
      '<div class="mb-3"><div class="text-gray-400 text-[10px] uppercase tracking-wide mb-2">Organizations using ' + d.name + '</div>' +
      connectedOrgs.map(function(o) {
        return '<div class="flex items-center justify-between py-1">' +
          '<div class="flex items-center gap-2">' +
          '<div class="w-5 h-5 rounded-full flex items-center justify-center text-[8px] font-bold text-white" style="background:' + (industryColors[o.industry] || templateColors[o.template] || '#6b7280') + '">' + getInitials(o.orgName).charAt(0) + '</div>' +
          '<span class="text-gray-700 text-[11px]">' + o.orgName + '</span>' +
          '</div>' +
          '<span class="text-gray-400 text-[10px]">' + o.totalClaims + ' claims</span>' +
          '</div>';
      }).join('') +
      '</div>';
  }

  // Wire up mode tabs
  document.querySelectorAll('.mode-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var mode = this.getAttribute('data-mode');
      switchMode(mode);
    });
  });

  // ---- Init ----
  loadGraph();
})();
</script>
