<%- include('../partials/orgy-palette'); %>
<%
  // ---- Settings: Billing (Company Settings) ----
  // Live preview of agent-team cost. Humans are free; every AI agent on the
  // org chart is billable. Pricing rule: if the org has >=1 ACTIVE API key,
  // ALL agents bill at $16/agent/mo (API + MCP); otherwise all agents bill at
  // $12/agent/mo (Basic). Self-serve billing is gated behind BILLING_ENABLED.
  // Locals: agents {total}, hasApiMcp, rate, monthlyTotal, activeApiKeys,
  //         billingEnabled, prices {basic,apiMcp}, orgName, stripeCustomerId.
  //         Auto-injected: assetVersion, authState.
  // Everything below is typeof-guarded so the page never throws on a missing local.
  var _auth     = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _agents   = (typeof agents !== 'undefined' && agents && typeof agents === 'object') ? agents : {};
  var _total    = (typeof _agents.total === 'number') ? _agents.total : 0;
  var _prices   = (typeof prices !== 'undefined' && prices && typeof prices === 'object') ? prices : {};
  var _pBasic   = (typeof _prices.basic === 'number') ? _prices.basic : 12;
  var _pApiMcp  = (typeof _prices.apiMcp === 'number') ? _prices.apiMcp : 16;
  var _keys     = (typeof activeApiKeys === 'number') ? activeApiKeys : 0;
  var _hasApiMcp = (typeof hasApiMcp !== 'undefined') ? !!hasApiMcp : (_keys >= 1);
  var _rate     = (typeof rate === 'number') ? rate : (_hasApiMcp ? _pApiMcp : _pBasic);
  var _monthly  = (typeof monthlyTotal === 'number') ? monthlyTotal : (_total * _rate);
  var _billingOn = (typeof billingEnabled !== 'undefined') ? !!billingEnabled : false;
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%- include('../partials/ui-page-header', { helpKey: 'settings.billing', title: 'Billing', eyebrow: 'Company Settings', subtitle: 'Humans are free. You pay per agent on your chart.', mascot: 'mcp-api' }) %>


    <% if (_auth === 'unauthenticated') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Sign in to view your billing.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Sign In</a>
      </div>
    <% } else if (_auth === 'no_org') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Complete your organization profile first.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Set Up Profile</a>
      </div>
    <% } else { %>

      <!-- two-column: nav stacks above content on mobile, sidebar on >=md -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">

        <!-- left: settings nav -->
        <%- include('../partials/settings-nav') %>

        <!-- right: content -->
        <div class="flex-1 min-w-0 w-full space-y-6">

          <!-- Card 1: Your plan -->
          <div class="bg-white border rounded-xl p-6">
            <h2 class="font-bold text-gray-900 text-lg mb-1">Your plan</h2>
            <% if (_hasApiMcp) { %>
              <p class="text-sm text-gray-500 mb-5">Your agents are billed at $<%= _pApiMcp %>/mo each (API + MCP active &mdash; you have <%= _keys %> API key<%= _keys === 1 ? '' : 's' %>).</p>
            <% } else { %>
              <p class="text-sm text-gray-500 mb-5">Your agents are billed at $<%= _pBasic %>/mo each (Basic). Creating an API key moves your agents to the $<%= _pApiMcp %> API + MCP rate.</p>
            <% } %>

            <div class="flex flex-wrap items-end gap-x-8 gap-y-4 mb-5">
              <div>
                <div class="text-4xl font-extrabold text-gray-900 leading-none"><%= _total %></div>
                <div class="text-xs uppercase tracking-wider text-gray-500 mt-1.5">Billable agents</div>
              </div>
              <div>
                <div class="text-4xl font-extrabold text-otp-600 leading-none">$<%= _rate %><span class="text-lg font-bold text-gray-400">/mo</span></div>
                <div class="text-xs uppercase tracking-wider text-gray-500 mt-1.5">Applied rate &middot; per agent</div>
              </div>
              <div>
                <div class="text-4xl font-extrabold text-gray-900 leading-none">$<%= _monthly %><span class="text-lg font-bold text-gray-400">/mo</span></div>
                <div class="text-xs uppercase tracking-wider text-gray-500 mt-1.5">Estimated monthly</div>
              </div>
            </div>

            <div class="border-t pt-4 space-y-2.5">
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-700"><%= _total %> agent<%= _total === 1 ? '' : 's' %> &times; $<%= _rate %> <span class="text-gray-400">(<%= _hasApiMcp ? 'API + MCP' : 'Basic' %>)</span></span>
                <span class="font-semibold text-gray-900 font-mono">$<%= _monthly %></span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-700">Humans on your chart</span>
                <span class="font-semibold text-emerald-600">Free</span>
              </div>
              <div class="flex items-center justify-between text-sm border-t pt-2.5">
                <span class="font-semibold text-gray-900">Estimated monthly</span>
                <span class="font-bold text-gray-900 font-mono">$<%= _monthly %>/mo</span>
              </div>
            </div>
          </div>

          <!-- Card 2: API access FYI -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">API access</h3>
            <p class="text-sm text-gray-600 mb-3">
              <% if (_hasApiMcp) { %>
                At least one active API key is in use, so all agents bill at the $<%= _pApiMcp %> API + MCP rate.
              <% } else { %>
                No active API keys, so all agents bill at the $<%= _pBasic %> Basic rate. Create a key to move to the $<%= _pApiMcp %> API + MCP rate.
              <% } %>
            </p>
            <p class="text-sm text-gray-500">
              <span class="font-semibold text-gray-700"><%= _keys %></span> key<%= _keys === 1 ? '' : 's' %> active
              &middot; <a href="/settings/api" class="text-otp-600 font-medium hover:text-otp-700 hover:underline">Manage API keys</a>
            </p>
          </div>

          <!-- Card 3: Manage agents -->
          <div class="bg-gray-50 border rounded-xl p-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Manage agents</h3>
              <p class="text-sm text-gray-500">Add or remove agents on your org chart to change what you'd pay.</p>
            </div>
            <a href="/dashboard/team" class="shrink-0 inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
              Open team chart
            </a>
          </div>

          <!-- Card 4: Upgrade / subscription (gated by BILLING_ENABLED) -->
          <% if (!_billingOn) { %>
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
              <h3 class="font-bold text-amber-900 mb-1">Start subscription</h3>
              <p class="text-sm text-amber-800 mb-4">
                Self-serve billing isn't switched on yet &mdash; this is a preview of your agent-team cost. You aren't being charged.
              </p>
              <button type="button" disabled
                class="inline-block px-5 py-2.5 bg-gray-200 text-gray-500 font-semibold rounded-lg text-sm cursor-not-allowed">
                Upgrade / Start subscription
              </button>
            </div>
          <% } else { %>
            <div class="bg-white border rounded-xl p-6">
              <h3 class="font-bold text-gray-900 mb-1">Start subscription</h3>
              <p class="text-sm text-gray-600 mb-4">
                This starts a $<%= _rate %>/agent/mo subscription
                (<%= _total %> agent<%= _total === 1 ? '' : 's' %> &times; $<%= _rate %> = $<%= _monthly %>/mo).
              </p>
              <button type="button" id="billing-checkout-btn"
                class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm">
                Upgrade / Start subscription
              </button>
            </div>
            <script>
              (function () {
                var btn = document.getElementById('billing-checkout-btn');
                if (!btn) return;
                btn.addEventListener('click', function () {
                  btn.disabled = true;
                  fetch('/settings/billing/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: '{}'
                  }).then(function (res) {
                    return res.json().then(function (data) {
                      if (res.ok && data && data.url) {
                        window.location.href = data.url;
                      } else {
                        alert((data && (data.message || data.error)) || ('Checkout unavailable (HTTP ' + res.status + ').'));
                        btn.disabled = false;
                      }
                    }).catch(function () {
                      alert('Checkout unavailable (HTTP ' + res.status + ').');
                      btn.disabled = false;
                    });
                  }).catch(function () {
                    alert('Could not reach the billing service. Please try again.');
                    btn.disabled = false;
                  });
                });
              })();
            </script>
          <% } %>

        </div>
      </div>

    <% } %>
</div>
