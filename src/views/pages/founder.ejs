<%# /founder -- founder / company-record page for OrgTP LLC. Published on the
    official site for bank / KYC verification. noindex (not searchable, not in
    nav or sitemap). v7 layout, v7.css PREBUILT -> scoped .fnd-* CSS only. %>
<% var _v = (typeof assetVersion !== 'undefined' ? assetVersion : 'dev'); %>
<style>
  .fnd-wrap { max-width: 820px; margin: 0 auto; padding: 132px 24px 96px; }
  .fnd-eyebrow { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-mute,#888c96); }
  .fnd-card { background:var(--white,#fff); border:1px solid var(--line,#e6e8ec); border-radius:20px; box-shadow:0 26px 64px -30px rgba(20,22,28,.22); padding:36px; margin-top:16px; }
  @media (max-width:560px){ .fnd-card { padding:26px 22px; } }
  .fnd-top { display:flex; gap:28px; align-items:center; flex-wrap:wrap; }
  .fnd-photo { width:148px; height:148px; border-radius:18px; object-fit:cover; flex:none; border:1px solid var(--line,#e6e8ec); box-shadow:0 12px 28px -14px rgba(20,22,28,.32); }
  .fnd-name { font-family:'Schibsted Grotesk',sans-serif; font-weight:700; font-size:clamp(1.8rem,3vw,2.3rem); letter-spacing:-0.02em; color:var(--ink,#14161c); margin:0; line-height:1.05; }
  .fnd-title { font-size:16px; font-weight:700; color:var(--blue,#0d7df2); margin-top:7px; }
  .fnd-org { font-size:15px; color:var(--ink-soft,#494d57); margin-top:3px; }
  .fnd-bio { font-size:16px; line-height:1.68; color:var(--ink-soft,#494d57); margin-top:26px; }
  .fnd-divider { height:1px; background:var(--line,#e6e8ec); margin:28px 0; }
  .fnd-details { display:grid; grid-template-columns:1fr; gap:16px 28px; }
  @media (min-width:620px){ .fnd-details { grid-template-columns:1fr 1fr; } }
  .fnd-dl-label { font-size:11px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-mute,#888c96); }
  .fnd-dl-val { font-size:15px; color:var(--ink,#14161c); margin-top:4px; line-height:1.5; }
  .fnd-dl-val a { color:var(--blue,#0d7df2); text-decoration:none; }
  .fnd-dl-val a:hover { text-decoration:underline; }
  .fnd-note { font-size:13px; line-height:1.6; color:var(--ink-mute,#888c96); margin-top:28px; }
</style>

<div class="fnd-wrap">
  <div class="fnd-eyebrow">OrgTP &middot; Company record</div>
  <div class="fnd-card">
    <div class="fnd-top">
      <img class="fnd-photo" src="/public/images/founder-david-sieradzky.jpg?v=<%= _v %>" alt="David Sieradzky, Founder of OrgTP LLC">
      <div>
        <h1 class="fnd-name">David Sieradzky</h1>
        <div class="fnd-title">Founder</div>
        <div class="fnd-org">OrgTP LLC &mdash; Organization Transport Protocol</div>
      </div>
    </div>

    <p class="fnd-bio">David Sieradzky is the Founder of OrgTP (Organization Transport Protocol), the operating system for teams of people and AI agents. He leads the company's vision, product, and operations &mdash; building the platform that gives every employee and every AI agent a seat, a number, and clear accountability inside one organization.</p>

    <div class="fnd-divider"></div>

    <div class="fnd-details">
      <div><div class="fnd-dl-label">Legal entity</div><div class="fnd-dl-val">OrgTP LLC</div></div>
      <div><div class="fnd-dl-label">Founder &amp; principal</div><div class="fnd-dl-val">David Sieradzky</div></div>
      <div><div class="fnd-dl-label">Business address</div><div class="fnd-dl-val">277 Fairfield Rd<br>Fairfield, NJ 07004</div></div>
      <div><div class="fnd-dl-label">Website</div><div class="fnd-dl-val"><a href="https://orgtp.com">orgtp.com</a></div></div>
      <div><div class="fnd-dl-label">Contact</div><div class="fnd-dl-val"><a href="mailto:david@orgtp.com">david@orgtp.com</a></div></div>
    </div>

    <p class="fnd-note">This page is published on the official OrgTP website (orgtp.com) to confirm the founder and principal of OrgTP LLC.</p>
  </div>
</div>
