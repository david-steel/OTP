<%# /free-account -- v7 layout (light, editorial). Google Ads sitelink landing page.
    Sitelink label: "Claim your Free Account". Per-seat pricing comparison.
    Every CTA drives to /sign-up. gtagSendEvent onclick preserved (ad conversion). %>
<style>
  .fa-float { animation:fa-float 7s ease-in-out infinite; }
  @keyframes fa-float { 0%,100%{transform:translateY(0) rotate(-3deg);} 50%{transform:translateY(-14px) rotate(3deg);} }
  .fa-glow {
    position:absolute; inset:-12% -8%; z-index:0; pointer-events:none;
    background:radial-gradient(ellipse, rgba(168,230,58,0.30), transparent 68%);
  }
  @media (prefers-reduced-motion:reduce){ .fa-float{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 mb-7"
         style="border-color:var(--orgy-deep); background:rgba(168,230,58,0.14);">
      <span class="tick" style="background:var(--orgy-deep);"></span>
      <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--ink)]">Beta: free forever for your whole team</span>
    </div>

    <div class="eyebrow mb-4">Pricing</div>
    <h1 class="font-display text-[var(--ink)] mx-auto max-w-[20ch]"
        style="font-size:clamp(2.3rem,5.4vw,4.1rem); line-height:1.05; font-weight:700; letter-spacing:-0.025em;">
      The whole platform.
      <span class="text-[var(--green-deep)]">Free for your whole team.</span>
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[40rem] mx-auto mt-6">
      Vision Plan, Weekly Scoreboard, Quarterly Priorities, To-Dos, Issues Board, the weekly Leadership Meeting, Team Chart, Team Updates, 1-on-1s, and Process Docs. Plus Radar, your built-in AI Chief of Staff.
    </p>

    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-primary px-8 py-4 text-[16px]">Claim your free account &rarr;</a>
    </div>
    <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--ink-mute)] mt-6">
      No credit card &nbsp;&middot;&nbsp; Whole team included &nbsp;&middot;&nbsp; Free forever in beta
    </p>
  </div>
</section>

<!-- ================= THE PLAN ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[620px] mx-auto text-center mb-14">
      <div class="eyebrow mb-4">One plan. No tiers.</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.8rem); font-weight:700;">
        Other operating tools have four price tiers. OTP has one.
      </h2>
    </div>

    <div class="grid lg:grid-cols-5 gap-5 items-start">
      <!-- OTP Free plan card -->
      <div class="lg:col-span-3 card p-7 sm:p-9 border-t-[3px] relative" style="border-top-color:var(--orgy-deep);">
        <div class="absolute -top-7 right-6">
          <img src="/public/hand-3.png" alt="" aria-hidden="true" class="fa-float block" style="width:78px; height:auto; filter:drop-shadow(0 10px 16px rgba(20,22,28,.2));">
        </div>
        <div class="flex items-baseline justify-between flex-wrap gap-2">
          <h3 class="font-display text-[1.35rem] font-bold text-[var(--ink)]">OTP Free</h3>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] rounded-md px-2 py-1"
                style="color:var(--green-deep); background:rgba(10,157,99,0.10); border:1px solid rgba(10,157,99,0.28);">Beta</span>
        </div>
        <div class="mt-4 flex items-baseline gap-2">
          <span class="font-display text-[3.4rem] font-bold text-[var(--ink)] leading-none">$0</span>
          <span class="text-[14px] text-[var(--ink-mute)]">/ whole team / month</span>
        </div>
        <p class="mt-3 text-[14px] text-[var(--ink-soft)] leading-[1.6]">No per-seat fees. No user limit. No credit card. Everything below is included.</p>

        <ul class="mt-6 grid sm:grid-cols-2 gap-x-5 gap-y-2.5 text-[14px] text-[var(--ink-soft)]">
          <% const included = [
            'Vision Plan', 'Weekly Scoreboard', 'Quarterly Priorities', 'To-Dos',
            'Issues Board', 'Leadership Meeting', 'Team Chart', 'Team Updates',
            '1-on-1s', 'Process Docs', 'Radar AI Chief of Staff', 'Unlimited users'
          ]; %>
          <% included.forEach(item => { %>
            <li class="flex items-start gap-2">
              <span class="flex-shrink-0 mt-0.5" style="color:var(--green);">&#10003;</span>
              <span><%= item %></span>
            </li>
          <% }); %>
        </ul>

        <div class="mt-8">
          <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-primary inline-flex items-center gap-2 px-7 py-3.5 text-[15px]">
            Claim your free account &rarr;
          </a>
        </div>
      </div>

      <!-- Reference card -->
      <div class="lg:col-span-2 card p-7 sm:p-9" style="background:var(--grey);">
        <h3 class="font-display text-[1.05rem] font-bold text-[var(--ink-soft)]">What you pay elsewhere</h3>
        <div class="mt-4 flex items-baseline gap-2">
          <span class="font-display text-[2.6rem] font-bold text-[var(--ink-mute)]">$8 to $16</span>
        </div>
        <p class="text-[14px] text-[var(--ink-mute)]">/ user / month</p>
        <p class="mt-4 text-[14px] text-[var(--ink-soft)] leading-[1.65]">
          Per-seat EOS tools like Ninety, Bloom Growth, and EOS One charge for every person on payroll. The bill grows every time you hire.
        </p>
        <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--ink-mute)]">Per-seat is their business model. Not ours.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= SAVINGS MATH ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[720px] mx-auto px-6 py-24 sm:py-28">
    <div class="card p-7 sm:p-10">
      <div class="eyebrow mb-3">Do the math</div>
      <h2 class="font-display text-[var(--ink)] leading-[1.15] mb-6"
          style="font-size:clamp(1.5rem,2.8vw,2.1rem); font-weight:700;">
        Per-seat pricing adds up fast. Here is what your team would pay.
      </h2>

      <div>
        <div class="idx-row flex items-baseline justify-between gap-3 py-3.5">
          <span class="text-[14.5px] text-[var(--ink-soft)]">10-person leadership team on per-seat software</span>
          <span class="font-display font-bold text-[var(--ink)] whitespace-nowrap">~$1,920 / year</span>
        </div>
        <div class="idx-row flex items-baseline justify-between gap-3 py-3.5">
          <span class="text-[14.5px] text-[var(--ink-soft)]">25-person company on per-seat software</span>
          <span class="font-display font-bold text-[var(--ink)] whitespace-nowrap">~$4,800 / year</span>
        </div>
        <div class="idx-row flex items-baseline justify-between gap-3 py-3.5">
          <span class="text-[14.5px] text-[var(--ink-soft)]">100-person company on per-seat software</span>
          <span class="font-display font-bold text-[var(--ink)] whitespace-nowrap">~$19,200 / year</span>
        </div>
        <div class="idx-row flex items-baseline justify-between gap-3 py-3.5">
          <span class="text-[14.5px] font-semibold text-[var(--ink)]">Same setup on OTP, free in beta</span>
          <span class="font-display font-bold text-[var(--green-deep)] whitespace-nowrap">$0</span>
        </div>
      </div>

      <div class="mt-8">
        <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink inline-flex items-center gap-2 px-7 py-3.5 text-[15px]">
          Move your team to OTP, free &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ================= FAQ ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28">
    <div class="text-center mb-12">
      <div class="eyebrow mb-3">Questions</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.7rem); font-weight:700;">
        The honest answers about free.
      </h2>
    </div>

    <% const faqs = [
      { q: 'Is it really free?',
        a: 'Yes. The full OTP platform plus Radar, your built-in AI Chief of Staff, at no cost. No per-seat fees. No trial clock counting down. No credit card.' },
      { q: 'How long does free last?',
        a: 'OTP is in beta. Beta members are grandfathered free for life. When paid plans turn on, you keep the free plan you signed up on. Joining now locks that in.' },
      { q: 'Do I need a credit card?',
        a: 'No. You create an account and start running your team. There is no card on file and nothing to cancel later.' },
      { q: 'How many users are included?',
        a: 'Your whole team. There is no per-seat fee and no user cap. Add your leadership team, add the whole company, add Radar. The price stays $0.' },
      { q: 'What is the catch?',
        a: 'OTP is funded by the agency Sneeze It, which runs its own team on OTP every week. The platform has to be good because we use it ourselves. Beta is how we grow the user base before paid plans launch.' },
      { q: 'What happens when paid plans launch?',
        a: 'Beta members stay free. Your team is grandfathered onto the free plan permanently. The per-seat pricing that other tools charge will never apply to accounts that joined during beta.' }
    ]; %>

    <div class="space-y-3">
      <% faqs.forEach(f => { %>
        <div class="card lift p-6">
          <h3 class="font-display text-[1.05rem] font-bold text-[var(--ink)] mb-2"><%= f.q %></h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]"><%= f.a %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-7"
         style="background:var(--ink); color:var(--orgy);">
      <span aria-hidden>&#9733;</span>
      <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.18em]">Join in beta = free forever</span>
      <span aria-hidden>&#9733;</span>
    </div>

    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(2.1rem,4.6vw,3.4rem); font-weight:800;">
      The whole platform. Free for your whole team.
    </h2>
    <p class="text-[17px] leading-[1.6] max-w-[36rem] mx-auto mt-6" style="color:#5a2a06;">
      Claim your free account while OTP is in beta. Your whole team stays free for life, grandfathered when paid plans turn on. No credit card, no per-seat fee.
    </p>

    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink px-9 py-4 text-[16px]">Claim your free account &rarr;</a>
    </div>

    <p class="font-mono text-[11px] uppercase tracking-[0.18em] mt-8" style="color:#7a3a0c;">
      OTP is not affiliated with EOS Worldwide, Ninety, or Bloom Growth.
    </p>
  </div>
</section>
