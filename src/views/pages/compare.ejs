<div class="max-w-6xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-2">OOS Comparison</h1>
  <p class="text-gray-500 text-sm mb-6">Side-by-side diff of coordination intelligence. Similarity is keyword-based -- review both claims to confirm.</p>

  <!-- Summary -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-blue-50 border border-blue-200 p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-blue-600"><%= diff.summary.uniqueToA %></div>
      <div class="text-xs text-blue-500">Unique to <%= diff.oosA.orgName %></div>
    </div>
    <div class="bg-green-50 border border-green-200 p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-green-600"><%= diff.summary.uniqueToB %></div>
      <div class="text-xs text-green-500">Unique to <%= diff.oosB.orgName %></div>
    </div>
    <div class="bg-yellow-50 border border-yellow-200 p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-yellow-600"><%= diff.summary.similar %></div>
      <div class="text-xs text-yellow-500">Similar</div>
    </div>
    <div class="bg-gray-50 border border-gray-200 p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-gray-500"><%= diff.summary.duplicate %></div>
      <div class="text-xs text-gray-400">Duplicate</div>
    </div>
  </div>

  <!-- Orgs Header -->
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div class="bg-white p-3 rounded border text-sm">
      <strong><%= diff.oosA.orgName %></strong> &middot; <%= diff.oosA.claimCount %> claims
    </div>
    <div class="bg-white p-3 rounded border text-sm">
      <strong><%= diff.oosB.orgName %></strong> &middot; <%= diff.oosB.claimCount %> claims
    </div>
  </div>

  <!-- Filter -->
  <div class="mb-4">
    <select id="diff-filter" class="text-sm border rounded px-3 py-1.5" onchange="filterDiff()">
      <option value="">All</option>
      <option value="UNIQUE_TO_B">Unique to <%= diff.oosB.orgName %> (highest value)</option>
      <option value="UNIQUE_TO_A">Unique to <%= diff.oosA.orgName %></option>
      <option value="SIMILAR">Similar</option>
      <option value="DUPLICATE">Duplicate</option>
    </select>
  </div>

  <!-- Diff Items -->
  <div id="diff-list">
    <% diff.claims.forEach(function(item) { %>
      <div class="diff-item mb-3 rounded-lg p-4
        <% if (item.classification === 'UNIQUE_TO_A') { %>diff-unique-a<% } %>
        <% if (item.classification === 'UNIQUE_TO_B') { %>diff-unique-b<% } %>
        <% if (item.classification === 'SIMILAR') { %>diff-similar<% } %>
        <% if (item.classification === 'DUPLICATE') { %>diff-duplicate<% } %>
      " data-classification="<%= item.classification %>">

        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-medium px-2 py-0.5 rounded
            <% if (item.classification === 'UNIQUE_TO_A') { %>bg-blue-100 text-blue-700<% } %>
            <% if (item.classification === 'UNIQUE_TO_B') { %>bg-green-100 text-green-700<% } %>
            <% if (item.classification === 'SIMILAR') { %>bg-yellow-100 text-yellow-700<% } %>
            <% if (item.classification === 'DUPLICATE') { %>bg-gray-100 text-gray-500<% } %>
          "><%= item.classification.replace(/_/g, ' ') %></span>

          <% if (item.similarityScore) { %>
            <span class="text-xs text-gray-400"><%= Math.round(item.similarityScore * 100) %>% overlap</span>
          <% } %>
        </div>

        <% if (item.classification === 'SIMILAR') { %>
          <!-- Side by side for similar claims -->
          <div class="grid grid-cols-2 gap-4 mt-2">
            <div class="text-sm">
              <div class="text-xs text-gray-400 mb-1"><%= diff.oosA.orgName %></div>
              <p class="font-medium"><%= item.claimA ? item.claimA.rule : '' %></p>
              <% if (item.claimA) { %>
                <div class="flex gap-1 mt-1">
                  <span class="text-xs bg-gray-100 px-1 rounded"><%= item.claimA.confidence %></span>
                  <span class="text-xs bg-gray-100 px-1 rounded"><%= item.claimA.evidence.replace(/_/g, ' ') %></span>
                </div>
              <% } %>
            </div>
            <div class="text-sm">
              <div class="text-xs text-gray-400 mb-1"><%= diff.oosB.orgName %></div>
              <p class="font-medium"><%= item.claimB ? item.claimB.rule : '' %></p>
              <% if (item.claimB) { %>
                <div class="flex gap-1 mt-1">
                  <span class="text-xs bg-gray-100 px-1 rounded"><%= item.claimB.confidence %></span>
                  <span class="text-xs bg-gray-100 px-1 rounded"><%= item.claimB.evidence.replace(/_/g, ' ') %></span>
                </div>
              <% } %>
            </div>
          </div>
        <% } else { %>
          <!-- Single claim for unique/duplicate -->
          <div class="text-sm mt-1">
            <% const claim = item.claimA || item.claimB; %>
            <% if (claim) { %>
              <p class="font-medium mb-1"><%= claim.rule %></p>
              <p class="text-gray-600 text-xs"><strong>Why:</strong> <%= claim.why %></p>
              <p class="text-gray-500 text-xs"><strong>Failure mode:</strong> <%= claim.failureMode %></p>
              <div class="flex gap-1 mt-2">
                <span class="text-xs bg-gray-100 px-1 rounded"><%= claim.claimId %></span>
                <span class="text-xs bg-gray-100 px-1 rounded"><%= claim.confidence %></span>
                <span class="text-xs bg-gray-100 px-1 rounded"><%= claim.evidence.replace(/_/g, ' ') %></span>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    <% }); %>
  </div>

  <!-- Merge Preview CTA -->
  <div class="mt-8 p-6 bg-otp-50 border border-otp-200 rounded-lg text-center">
    <p class="font-medium mb-2">Want to import patterns from this comparison?</p>
    <a href="/merge/<%= diff.oosA.id %>/<%= diff.oosB.id %>" class="px-6 py-2 bg-otp-500 text-white rounded hover:bg-otp-400 text-sm inline-block">Preview Merge</a>
  </div>
</div>

<script>
function filterDiff() {
  const filter = document.getElementById('diff-filter').value;
  document.querySelectorAll('.diff-item').forEach(el => {
    el.style.display = !filter || el.dataset.classification === filter ? '' : 'none';
  });
}
</script>
