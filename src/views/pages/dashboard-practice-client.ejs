<%- include('../partials/orgy-palette'); %>
<%-
  /* /dashboard/practice/client/:id — coach-view summary of one linked client.
     Read-only. Variables: client, attribution, stats */
%>
<section class="bg-gray-50 min-h-screen">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">

    <!-- Viewing-as-coach banner. Yellow strip so it's clear this is not
         the coach's own workspace. -->
    <div class="bg-amber-100 border-2 border-amber-300 rounded-xl px-4 py-3 mb-6 flex items-center gap-3 text-sm">
      <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-amber-400 text-white font-bold text-xs">★</span>
      <span class="text-amber-900">
        <strong>You're viewing as coach.</strong>
        Read-only access. Your client owns this workspace and can revoke your access at any time.
      </span>
      <a href="/dashboard/practice" class="ml-auto text-xs text-amber-800 hover:text-amber-900 underline whitespace-nowrap">
        ← Back to practice
      </a>
    </div>

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-gray-900 mb-1"><%= client.name %></h1>
      <div class="text-sm text-gray-500 space-x-3">
        <% if (client.industry) { %><span><%= client.industry %></span><% } %>
        <% if (client.size) { %><span>· <%= client.size %></span><% } %>
        <% if (attribution && attribution.attributed_at) { %>
          <span>· Joined your practice <%= new Date(attribution.attributed_at).toLocaleDateString() %></span>
        <% } %>
      </div>
    </div>

    <% if (nudgeStatus === 'sent') { %>
      <div class="bg-emerald-50 border-2 border-emerald-200 rounded-xl p-4 mb-6 flex items-center gap-3">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500 text-white text-xs font-bold">✓</span>
        <div class="text-sm text-emerald-900"><strong>Nudge sent.</strong> Your client got an email with a concrete first-step CTA. Replies route to your inbox.</div>
      </div>
    <% } else if (nudgeStatus === 'no_email') { %>
      <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-4 mb-6 flex items-center gap-3">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-amber-500 text-white text-xs font-bold">!</span>
        <div class="text-sm text-amber-900"><strong>No email on file for this client.</strong> Reach out directly through the channel you normally use.</div>
      </div>
    <% } else if (nudgeStatus === 'fail') { %>
      <div class="bg-red-50 border-2 border-red-200 rounded-xl p-4 mb-6 flex items-center gap-3">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-red-500 text-white text-xs font-bold">×</span>
        <div class="text-sm text-red-900"><strong>Send failed.</strong> Resend may be down — try again in a minute.</div>
      </div>
    <% } %>

    <% if (stats.empty) { %>

      <!-- Empty state: client signed up but hasn't built anything yet -->
      <div class="bg-white border-2 border-gray-200 rounded-2xl p-10 text-center max-w-xl mx-auto">
        <div class="text-5xl mb-4">📭</div>
        <h2 class="text-lg font-bold text-gray-900 mb-2">Nothing here yet</h2>
        <p class="text-sm text-gray-600 mb-3">
          <strong><%= client.name %></strong> joined your practice but hasn't started building.
        </p>
        <p class="text-xs text-gray-500 mb-6">
          The fastest way to activate them: send a nudge email with a concrete first-step CTA.
        </p>
        <form method="POST" action="/dashboard/practice/client/<%= client.id %>/nudge" onsubmit="return confirm('Send a nudge email to <%= client.name %>?\n\nThey will receive a templated email with a concrete first-step CTA. Replies to that email route to YOU.');">
          <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold transition-transform hover:scale-[1.02]">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span>Send activation nudge →</span>
          </button>
        </form>
        <p class="mt-3 text-[11px] text-gray-400">Reply-To is set to your coach email so any response lands in your inbox, not OTP's.</p>
      </div>

    <% } else { %>

      <!-- Meeting cadence: the coach's core accountability signal. -->
      <%
        var _lastMtg = (typeof cadence !== 'undefined' && cadence && cadence.lastMeetingAt) ? new Date(cadence.lastMeetingAt) : null;
        var _daysSince = _lastMtg ? Math.floor((Date.now() - _lastMtg.getTime()) / 86400000) : null;
        var _cadenceClass = _daysSince === null ? 'border-gray-200 bg-gray-50'
                          : _daysSince <= 10 ? 'border-emerald-200 bg-emerald-50'
                          : _daysSince <= 21 ? 'border-amber-200 bg-amber-50'
                          : 'border-red-200 bg-red-50';
      %>
      <div class="rounded-xl border-2 <%= _cadenceClass %> p-5 mb-6 flex flex-wrap items-center gap-x-6 gap-y-2">
        <div>
          <div class="text-[11px] font-bold uppercase tracking-wider text-gray-600 mb-1">Weekly meeting cadence</div>
          <% if (_lastMtg) { %>
            <div class="text-sm text-gray-800">Last Leadership Meeting: <strong><%= _lastMtg.toLocaleDateString() %></strong>
              <span class="text-gray-500">(<%= _daysSince === 0 ? 'today' : _daysSince + ' day' + (_daysSince === 1 ? '' : 's') + ' ago' %>)</span>
            </div>
          <% } else { %>
            <div class="text-sm text-gray-700">No meeting has been run in OTP yet.</div>
          <% } %>
        </div>
        <div class="text-3xl font-extrabold text-gray-900"><%= (typeof cadence !== 'undefined' && cadence) ? cadence.meetingCount : 0 %><span class="text-sm font-medium text-gray-500 ml-1.5">meetings run</span></div>
        <div class="ml-auto text-xs <%= (_daysSince !== null && _daysSince > 21) ? 'text-red-700 font-semibold' : 'text-gray-500' %>">
          <% if (_daysSince === null) { %>Get them running their weekly Leadership Meeting.
          <% } else if (_daysSince > 21) { %>Cadence has gone quiet &mdash; nudge them.
          <% } else if (_daysSince > 10) { %>A bit overdue for this week's meeting.
          <% } else { %>Cadence is healthy.<% } %>
        </div>
      </div>

      <!-- Summary stats grid -->
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-8">
        <% var cards = [
          { label: 'Team members',     n: stats.members, color: 'gray',    hint: 'Human seats on the chart.' },
          { label: 'Teams',            n: stats.teams,   color: 'gray',    hint: 'L8 / sub-team groupings.' },
          { label: 'KPIs tracked',     n: stats.kpis,    color: 'blue',    hint: 'Numbers on the scorecard.' },
          { label: 'Org charts',       n: stats.charts,  color: 'amber',   hint: 'Visual structure maps.' },
          { label: 'AI agents',        n: stats.agents,  color: 'red',     hint: 'Manager / runtime agents.' },
          { label: 'OOS files',        n: stats.oosFiles,color: 'emerald', hint: 'Published operating-system docs.' },
        ]; %>
        <% cards.forEach(function(c){
             var border = { gray: 'border-gray-200', blue: 'border-orgy-soft', amber: 'border-amber-200', red: 'border-red-200', emerald: 'border-emerald-200' }[c.color];
             var text = { gray: 'text-gray-700', blue: 'text-orgy-blue', amber: 'text-amber-700', red: 'text-red-700', emerald: 'text-emerald-700' }[c.color];
        %>
          <div class="rounded-xl bg-white border-2 <%= border %> p-5">
            <div class="text-[11px] font-bold uppercase tracking-wider <%= text %> mb-1"><%= c.label %></div>
            <div class="text-3xl font-extrabold text-gray-900"><%= c.n %></div>
            <div class="mt-1 text-xs text-gray-500"><%= c.hint %></div>
          </div>
        <% }); %>
      </div>

      <!-- Note while deeper views are pending v0.5 -->
      <div class="bg-white border border-gray-200 rounded-xl p-5 text-sm text-gray-600">
        <strong class="text-gray-900">Deep views coming.</strong>
        Direct read-only views of <%= client.name %>'s chart, KPIs, and OOS files unlock in v0.5. For now, the stats above tell you whether the workspace is active and where the gaps are.
      </div>

    <% } %>

    <!-- Footer with attribution disclosure -->
    <div class="mt-8 text-xs text-gray-500 text-center">
      Coach attribution &middot; OTP Founder Certified Coach program
    </div>

  </div>
</section>
