<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex, nofollow">
<title>Hero preview (fish) — OTP</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#14161c; --ink-soft:#3c424d; --ink-mute:#7c828d;
    --blue:#0d7df2; --green:#8bc42a; --green-deep:#6fa01f; --orgy:#a8e63a; --line:#ececef;
  }
  *{ box-sizing:border-box; } html,body{ margin:0; }
  body{ background:#fff; color:var(--ink); font-family:'Schibsted Grotesk','Inter',sans-serif; -webkit-font-smoothing:antialiased; }

  .nav{ height:64px; border-bottom:1px solid var(--line); }
  .nav-in{ max-width:1180px; margin:0 auto; height:100%; padding:0 28px; display:flex; align-items:center; justify-content:space-between; }
  .brand{ font-family:'JetBrains Mono',ui-monospace,monospace; font-weight:500; font-size:18px; letter-spacing:-.02em; }
  .brand .b{ color:var(--blue); }
  .nav-links{ display:flex; gap:26px; font-size:14px; color:var(--ink-soft); }
  .nav-cta{ background:var(--ink); color:#fff; font-size:14px; font-weight:600; padding:9px 16px; border-radius:9px; }
  @media (max-width:760px){ .nav-links{ display:none; } }

  .hero{ position:relative; overflow:hidden; }
  .hero-in{ max-width:1180px; margin:0 auto; padding:96px 28px 104px; display:grid; grid-template-columns:1.04fr .96fr; gap:48px; align-items:center; }
  .eyebrow{ font-weight:600; font-size:13px; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-mute); }
  .h1{ font-weight:600; font-size:clamp(2.7rem,5.2vw,4.2rem); line-height:1.03; letter-spacing:-0.038em; margin:20px 0 0; max-width:13ch; }
  .h1 .accent{ color:var(--blue); }
  .sub{ font-family:'Inter',sans-serif; font-weight:400; font-size:clamp(1.06rem,1.35vw,1.2rem); line-height:1.6; color:var(--ink-soft); margin:26px 0 0; max-width:31rem; }
  .cta-row{ margin-top:36px; display:flex; align-items:center; gap:18px; flex-wrap:wrap; }
  .cta{ background:var(--blue); color:#fff; font-weight:600; font-size:16px; padding:15px 26px; border-radius:11px; box-shadow:0 10px 24px rgba(13,125,242,.22); display:inline-block; }
  .cta-note{ font-family:'Inter',sans-serif; font-size:13.5px; color:var(--ink-mute); }

  /* ---------- the coded fish scene (no video, loops forever) ---------- */
  .art{ position:relative; min-height:460px; }
  .scene{ position:absolute; inset:0; overflow:hidden; }
  .glow{ position:absolute; left:50%; top:52%; width:60%; aspect-ratio:1; transform:translate(-50%,-50%);
    background:radial-gradient(closest-side, rgba(168,230,58,.22), rgba(168,230,58,0) 70%);
    border-radius:50%; animation:breathe 7s ease-in-out infinite; }

  .fish{ position:absolute; color:var(--green); will-change:transform; aspect-ratio:100/64; height:auto;
    filter:drop-shadow(0 8px 14px rgba(20,22,28,.10)); overflow:visible; }

  /* central fish: grows bigger and bigger, then eases back for a seamless loop */
  .lead{ left:50%; top:50%; width:120px; margin:-38px 0 0 -60px; color:var(--green);
    filter:drop-shadow(0 18px 26px rgba(20,22,28,.16));
    animation:grow 8s cubic-bezier(.45,.05,.3,1) infinite, bobLead 4.5s ease-in-out infinite; }
  @keyframes grow{ 0%{ transform:scale(.34); } 62%{ transform:scale(1.55); } 100%{ transform:scale(.34); } }
  @keyframes bobLead{ 0%,100%{ translate:0 0; } 50%{ translate:0 -10px; } }

  /* small fish drifting around like a gentle school */
  .f1{ width:46px; left:14%; top:24%; color:var(--green); animation:driftA 11s ease-in-out infinite; }
  .f2{ width:38px; left:64%; top:18%; color:var(--green-deep); animation:driftB 13s ease-in-out infinite; }
  .f3{ width:52px; left:70%; top:62%; color:var(--green); animation:driftC 12s ease-in-out infinite; }
  .f4{ width:34px; left:20%; top:68%; color:var(--blue); animation:driftB 14s ease-in-out infinite reverse; }
  .f5{ width:42px; left:44%; top:12%; color:var(--green-deep); animation:driftA 15s ease-in-out infinite reverse; }
  .f6{ width:30px; left:34%; top:80%; color:var(--green); animation:driftC 16s ease-in-out infinite; }

  @keyframes driftA{ 0%,100%{ transform:translate(0,0) rotate(-5deg); } 50%{ transform:translate(34px,-30px) rotate(4deg); } }
  @keyframes driftB{ 0%,100%{ transform:translate(0,0) rotate(3deg); } 50%{ transform:translate(-30px,26px) rotate(-4deg); } }
  @keyframes driftC{ 0%,100%{ transform:translate(0,0) rotate(-3deg); } 50%{ transform:translate(-26px,-24px) rotate(5deg); } }
  @keyframes breathe{ 0%,100%{ opacity:.65; transform:translate(-50%,-50%) scale(.9); } 50%{ opacity:1; transform:translate(-50%,-50%) scale(1.08); } }

  @media (max-width:920px){
    .hero-in{ grid-template-columns:1fr; gap:8px; padding:64px 24px 76px; text-align:center; }
    .h1, .sub{ margin-left:auto; margin-right:auto; }
    .h1{ max-width:none; } .cta-row{ justify-content:center; }
    .art{ order:-1; min-height:300px; }
  }
  @media (prefers-reduced-motion: reduce){
    .fish, .lead, .glow{ animation:none !important; }
    .lead{ transform:scale(1.2); }
  }
  .pv-flag{ font-family:'Inter',sans-serif; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:#b3b8c0; text-align:center; padding:14px; border-top:1px solid var(--line); }
</style>
</head>
<body>
  <!-- one fish shape, instanced many times via <use> -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="fish" viewBox="0 0 100 64">
        <ellipse cx="47" cy="32" rx="29" ry="18" fill="currentColor"/>
        <path d="M19,32 L2,15 L8,32 L2,49 Z" fill="currentColor" opacity=".62"/>
        <path d="M42,15 Q51,3 60,17 Z" fill="currentColor" opacity=".62"/>
        <circle cx="62" cy="27" r="3.4" fill="#14161c"/>
        <circle cx="63.2" cy="25.8" r="1.1" fill="#fff"/>
      </symbol>
    </defs>
  </svg>

  <nav class="nav">
    <div class="nav-in">
      <div class="brand"><span class="b">[</span>OTP<span class="b">]</span></div>
      <div class="nav-links"><span>Protocol</span><span>Pricing</span><span>Browse</span><span>Blog</span></div>
      <a class="nav-cta" href="#">Get started</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-in">
      <div class="copy">
        <div class="eyebrow">For teams of people and AI</div>
        <h1 class="h1">Your people and <span class="accent">AI agents</span>, on one team.</h1>
        <p class="sub">Free meeting software for your whole team. Your AI agents get a seat right next to your people. No agents of your own yet? Start with five of ours, free.</p>
        <div class="cta-row">
          <a class="cta" href="#">Start free &rarr;</a>
          <span class="cta-note">No credit card. Free for your whole team.</span>
        </div>
      </div>

      <div class="art">
        <div class="scene">
          <div class="glow"></div>
          <svg class="fish f1"><use href="#fish"/></svg>
          <svg class="fish f2"><use href="#fish"/></svg>
          <svg class="fish f3"><use href="#fish"/></svg>
          <svg class="fish f4"><use href="#fish"/></svg>
          <svg class="fish f5"><use href="#fish"/></svg>
          <svg class="fish f6"><use href="#fish"/></svg>
          <svg class="fish lead"><use href="#fish"/></svg>
        </div>
      </div>
    </div>
  </section>

  <div class="pv-flag">Isolated preview &middot; coded fish animation (no video, loops free)</div>
</body>
</html>
