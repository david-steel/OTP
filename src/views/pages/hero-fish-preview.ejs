<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex, nofollow">
<title>Hero preview (fish) — OTP</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#14161c; --ink-soft:#3c424d; --ink-mute:#7c828d;
    --blue:#0d7df2; --school:#0d7df2; --line:#ececef;
  }
  *{ box-sizing:border-box; } html,body{ margin:0; }
  body{ background:#fff; color:var(--ink); font-family:'Schibsted Grotesk','Inter',sans-serif; -webkit-font-smoothing:antialiased; }

  .nav{ height:64px; border-bottom:1px solid var(--line); }
  .nav-in{ max-width:1180px; margin:0 auto; height:100%; padding:0 28px; display:flex; align-items:center; justify-content:space-between; }
  .brand{ font-family:'JetBrains Mono',ui-monospace,monospace; font-weight:500; font-size:18px; letter-spacing:-.02em; }
  .brand .b{ color:var(--blue); }
  .nav-links{ display:flex; gap:26px; font-size:14px; color:var(--ink-soft); }
  .nav-cta{ background:var(--ink); color:#fff; font-size:14px; font-weight:600; padding:9px 16px; border-radius:9px; }
  @media (max-width:760px){ .nav-links{ display:none; } }

  .hero{ position:relative; overflow:hidden; }
  .hero-in{ max-width:1180px; margin:0 auto; padding:96px 28px 104px; display:grid; grid-template-columns:1.04fr .96fr; gap:48px; align-items:center; }
  .eyebrow{ font-weight:600; font-size:13px; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-mute); }
  .h1{ font-weight:600; font-size:clamp(2.7rem,5.2vw,4.2rem); line-height:1.03; letter-spacing:-0.038em; margin:20px 0 0; max-width:13ch; }
  .h1 .accent{ color:var(--blue); }
  .sub{ font-family:'Inter',sans-serif; font-weight:400; font-size:clamp(1.06rem,1.35vw,1.2rem); line-height:1.6; color:var(--ink-soft); margin:26px 0 0; max-width:31rem; }
  .cta-row{ margin-top:36px; display:flex; align-items:center; gap:18px; flex-wrap:wrap; }
  .cta{ background:var(--blue); color:#fff; font-weight:600; font-size:16px; padding:15px 26px; border-radius:11px; box-shadow:0 10px 24px rgba(13,125,242,.22); display:inline-block; }
  .cta-note{ font-family:'Inter',sans-serif; font-size:13.5px; color:var(--ink-mute); }

  /* ---------- blue line-art school that merges into one bigger fish ---------- */
  .art{ position:relative; min-height:480px; }
  .scene{ position:absolute; inset:0; overflow:hidden; }

  .fish{ position:absolute; left:50%; top:50%; height:auto; aspect-ratio:150/80;
    overflow:visible; transform-origin:center; }

  .s{ color:var(--school); animation:converge 8.5s cubic-bezier(.5,.04,.3,1) infinite; }
  .s1{ width:62px; --hx:-150px; --hy:-46px; }
  .s2{ width:50px; --hx:-118px; --hy:-12px; }
  .s3{ width:66px; --hx:-178px; --hy:18px; }
  .s4{ width:46px; --hx:-100px; --hy:46px; }
  .s5{ width:54px; --hx:-202px; --hy:-30px; }
  .s6{ width:42px; --hx:-138px; --hy:72px; }

  /* school swims to the exact center, shrinks to a point and vanishes, then re-forms */
  @keyframes converge{
    0%    { transform:translate(-50%,-50%) translate(var(--hx),var(--hy)) scale(1); opacity:1; }
    14%   { transform:translate(-50%,-50%) translate(var(--hx),var(--hy)) scale(1); opacity:1; }
    40%   { transform:translate(-50%,-50%) translate(0,0) scale(.5);  opacity:1; }
    46%   { transform:translate(-50%,-50%) translate(0,0) scale(.06); opacity:0; }
    90%   { transform:translate(-50%,-50%) translate(0,0) scale(.06); opacity:0; }
    91%   { transform:translate(-50%,-50%) translate(var(--hx),var(--hy)) scale(1); opacity:0; }
    100%  { transform:translate(-50%,-50%) translate(var(--hx),var(--hy)) scale(1); opacity:1; }
  }

  /* the one fish blooms from that point AFTER the school is gone, grows, fades before the school returns */
  .big{ width:218px; color:var(--blue); animation:emerge 8.5s cubic-bezier(.5,.04,.3,1) infinite; }
  @keyframes emerge{
    0%   { transform:translate(-50%,-50%) scale(0);    opacity:0; }
    46%  { transform:translate(-50%,-50%) scale(0);    opacity:0; }
    50%  { transform:translate(-50%,-50%) scale(.22);  opacity:1; }
    72%  { transform:translate(-50%,-50%) scale(1);    opacity:1; }
    84%  { transform:translate(-50%,-50%) scale(1.2);  opacity:1; }
    86%  { transform:translate(-50%,-50%) scale(1.26); opacity:1; }
    90%  { transform:translate(-50%,-50%) scale(1.3);  opacity:0; }
    100% { transform:translate(-50%,-50%) scale(0);    opacity:0; }
  }

  @media (max-width:920px){
    .hero-in{ grid-template-columns:1fr; gap:8px; padding:64px 24px 76px; text-align:center; }
    .h1, .sub{ margin-left:auto; margin-right:auto; }
    .h1{ max-width:none; } .cta-row{ justify-content:center; }
    .art{ order:-1; min-height:300px; }
  }
  @media (prefers-reduced-motion: reduce){
    .s, .big{ animation:none !important; }
    .s{ opacity:0; } .big{ transform:translate(-50%,-50%) scale(1.1); opacity:1; }
  }
  .pv-flag{ font-family:'Inter',sans-serif; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:#b3b8c0; text-align:center; padding:14px; border-top:1px solid var(--line); }
</style>
</head>
<body>
  <!-- traced from the Sakana fugu line-fish: leaf body, sharp nose right, forked tail left, gill -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="fish" viewBox="0 0 150 80">
        <g fill="none" stroke="currentColor" stroke-width="7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M48,40 C52,20 80,10 104,14 C122,17 132,28 138,40"/>
          <path d="M48,40 C52,60 80,70 104,66 C122,63 132,52 138,40"/>
          <path d="M48,40 C34,30 20,22 8,16"/>
          <path d="M48,40 C34,50 20,58 8,64"/>
          <path d="M104,20 C97,30 97,50 104,60"/>
        </g>
      </symbol>
    </defs>
  </svg>

  <nav class="nav">
    <div class="nav-in">
      <div class="brand"><span class="b">[</span>OTP<span class="b">]</span></div>
      <div class="nav-links"><span>Protocol</span><span>Pricing</span><span>Browse</span><span>Blog</span></div>
      <a class="nav-cta" href="#">Get started</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-in">
      <div class="copy">
        <div class="eyebrow">For teams of people and AI</div>
        <h1 class="h1">Your people and <span class="accent">AI agents</span>, on one team.</h1>
        <p class="sub">Free meeting software for your whole team. Your AI agents get a seat right next to your people. No agents of your own yet? Start with five of ours, free.</p>
        <div class="cta-row">
          <a class="cta" href="#">Start free &rarr;</a>
          <span class="cta-note">No credit card. Free for your whole team.</span>
        </div>
      </div>

      <div class="art">
        <div class="scene">
          <svg class="fish s s1"><use href="#fish"/></svg>
          <svg class="fish s s2"><use href="#fish"/></svg>
          <svg class="fish s s3"><use href="#fish"/></svg>
          <svg class="fish s s4"><use href="#fish"/></svg>
          <svg class="fish s s5"><use href="#fish"/></svg>
          <svg class="fish s s6"><use href="#fish"/></svg>
          <svg class="fish big"><use href="#fish"/></svg>
        </div>
      </div>
    </div>
  </section>

  <div class="pv-flag">Isolated preview &middot; blue school merges into one fish (traced from Sakana, recolored)</div>
</body>
</html>
