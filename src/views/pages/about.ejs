<style>
  .ab-float { animation:ab-float 6.5s ease-in-out infinite; }
  @keyframes ab-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-13px);} }
  .ab-glow {
    position:absolute; left:50%; top:54%; width:78%; height:60%;
    transform:translate(-50%,-50%); z-index:0; pointer-events:none;
    background:radial-gradient(ellipse, rgba(13,125,242,0.20), transparent 70%);
    animation:ab-breathe 6.5s ease-in-out infinite;
  }
  @keyframes ab-breathe { 0%,100%{opacity:.5;} 50%{opacity:1;} }
  .ab-prose h2 {
    font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700;
    font-size:clamp(1.45rem,2.6vw,1.95rem); letter-spacing:-0.01em;
    color:var(--ink); line-height:1.2; margin-top:2.4rem;
  }
  .ab-prose h2:first-child { margin-top:0; }
  .ab-prose p { color:var(--ink-soft); font-size:16px; line-height:1.78; margin-top:1rem; }
  .ab-prose strong { color:var(--ink); font-weight:600; }
  .ab-prose a { color:var(--blue-deep); font-weight:600; border-bottom:1.5px solid currentColor; }
  .ab-wave { animation:ab-wave 3.2s ease-in-out infinite; transform-origin:75% 85%; }
  @keyframes ab-wave { 0%,70%,100%{transform:rotate(0);} 80%{transform:rotate(14deg);} 90%{transform:rotate(-6deg);} }
  @media (prefers-reduced-motion:reduce){ .ab-float,.ab-glow,.ab-wave{ animation:none; } }
