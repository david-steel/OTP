        <div class="md:col-span-2">
          <div class="text-5xl font-extrabold text-otp-500 tracking-tight" style="font-variant-numeric: tabular-nums;">05</div>
        </div>
        <div class="md:col-span-7">
          <div class="text-xl font-bold text-gray-900 mb-2">The Coordination Checkup</div>
          <p class="text-sm text-gray-600 leading-[1.7]">
