<%# /tools -- the toolbox. Five foundational tools + extended list. v7 layout. %>
<style>
  .tl-num {
    font-family:'Schibsted Grotesk',sans-serif; font-weight:800;
    font-size:clamp(2.4rem,5vw,3.4rem); letter-spacing:-0.03em;
    color:var(--blue); line-height:1; font-variant-numeric:tabular-nums;
  }
  .tl-link { font-weight:600; color:var(--blue-deep); border-bottom:1.5px solid rgba(13,125,242,.3); padding-bottom:1px; transition:border-color .15s ease; }
  .tl-link:hover { border-bottom-color:var(--blue-deep); }
  .tl-orgy { animation:tl-orgy 6.5s ease-in-out infinite; }
  @keyframes tl-orgy { 0%,100%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-12px) rotate(3deg);} }
  @media (prefers-reduced-motion:reduce){ .tl-orgy{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-7">
        <div class="eyebrow mb-4 flex items-center gap-2.5">
          <span class="tick" style="background:var(--orgy);"></span>The toolbox
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.1rem,4.8vw,3.5rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
          The OTP Toolbox.<br>
          <span class="text-[var(--ink-mute)]">Free. Use them whether you sign up or not.</span>
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mt-6">
          Five foundational tools, plus the rest of what has been built. The protocol is open. The chart is the canonical implementation. The diagnostic gives you a score. Everything below is something a real OTP user reaches for in their first week.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="/start-here" class="btn-primary inline-block px-7 py-3.5 text-[15px]">Schedule a 30-min intro &rarr;</a>
          <a href="/what-is-otp" class="btn-ghost inline-block px-7 py-3.5 text-[15px]">Or learn what OTP is</a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="relative">
          <img src="/public/images/hero-tools.webp"
               alt="The OTP toolbox: clipboard, scorecard, blueprint, diagnostic gauge, and protocol cards arranged inside an open toolbox"
               width="1024" height="1024" loading="eager" fetchpriority="high"
               class="w-full h-auto rounded-[20px]" style="filter:drop-shadow(0 24px 40px rgba(20,22,28,.16));">
          <img src="/public/orgy-cut.png" alt="Ollie, the OTP mascot"
               class="tl-orgy absolute" style="width:104px; height:auto; top:-34px; right:-22px; filter:drop-shadow(0 14px 22px rgba(20,22,28,.24));">
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= FIVE FOUNDATIONAL TOOLS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4" style="color:var(--blue-deep);">Five foundational tools</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] max-w-[36rem] mb-12"
        style="font-size:clamp(1.9rem,3.8vw,2.9rem); font-weight:700;">
      Start with these. Skip the rest until you need it.
    </h2>

    <div class="space-y-4">

      <!-- 01 -- OOS Starter Template -->
      <div class="card p-7 sm:p-8 grid grid-cols-1 md:grid-cols-12 gap-5 md:gap-8 items-start">
        <div class="md:col-span-1"><div class="tl-num">01</div></div>
        <div class="md:col-span-8">
          <h3 class="font-display text-[var(--ink)] text-[1.3rem] font-bold mb-2">OOS Starter Template</h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]">
            A plain-YAML file you fill in to describe your organization. Entities (humans + agents), claims (rules, patterns, failures), publishable to the network. The same format the canonical OTP chart writes automatically. Use it to learn the shape, then graduate to the live editor.
          </p>
        </div>
        <div class="md:col-span-3 md:text-right">
          <a href="/public/downloads/oos-starter.yaml" download class="tl-link inline-block text-[14px]">Download YAML &darr;</a>
          <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-2">~ 3 KB &middot; commented</div>
        </div>
      </div>

      <!-- 02 -- The Org Chart Builder -->
      <div class="card p-7 sm:p-8 grid grid-cols-1 md:grid-cols-12 gap-5 md:gap-8 items-start">
        <div class="md:col-span-1"><div class="tl-num">02</div></div>
        <div class="md:col-span-8">
          <h3 class="font-display text-[var(--ink)] text-[1.3rem] font-bold mb-2">The Org Chart Builder</h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]">
            Live at <code class="font-mono text-[12px] bg-[var(--grey)] px-1.5 py-0.5 rounded border border-[var(--line)]">/dashboard/team</code>. Add humans and AI agents as named seats. Wire reporting and escalation lines by drag. Author SOPs. Track KPIs. Export the inherited CLAUDE.md for any agent. Five Founder/CEO SOP templates seeded so you have a starting point in sixty seconds.
          </p>
        </div>
        <div class="md:col-span-3 md:text-right">
          <a href="/sign-up" class="tl-link inline-block text-[14px]">Open the builder &nearr;</a>
          <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-2">requires sign-up</div>
        </div>
      </div>

      <!-- 03 -- CLAUDE.md Compiler -->
      <div class="card p-7 sm:p-8 grid grid-cols-1 md:grid-cols-12 gap-5 md:gap-8 items-start">
        <div class="md:col-span-1"><div class="tl-num">03</div></div>
        <div class="md:col-span-8">
          <h3 class="font-display text-[var(--ink)] text-[1.3rem] font-bold mb-2">The CLAUDE.md Compiler</h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]">
            Click any agent tile, hit "Copy as CLAUDE.md," and OTP compiles that agent's own SOPs plus the SOPs of the human it reports to into a single markdown file. Drop it into Claude Code, Cursor, Codex, Aider, or any other stack. The agent now reads its inherited context at every session. Output formats: AGENTS.md, CLAUDE.md, .cursorrules, generic system prompt.
          </p>
        </div>
        <div class="md:col-span-3 md:text-right">
          <a href="/public/downloads/claude-md-template.md" download class="tl-link inline-block text-[14px]">Download template &darr;</a>
          <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-2">manual fallback &middot; or use the live compiler</div>
        </div>
      </div>

      <!-- 04 -- Agent Builder -->
      <div class="card p-7 sm:p-8 grid grid-cols-1 md:grid-cols-12 gap-5 md:gap-8 items-start">
        <div class="md:col-span-1"><div class="tl-num">04</div></div>
        <div class="md:col-span-8">
          <h3 class="font-display text-[var(--ink)] text-[1.3rem] font-bold mb-2">The Agent Builder</h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]">
            Describe a role. Pick skills and tools. Set a personality framework (DISC, Big Five, MBTI, or skip). The builder drafts a complete agent spec informed by coordination patterns from organizations already running agents in production. Output is a CLAUDE.md you can drop into any stack, or a tile you place directly on your chart.
          </p>
        </div>
        <div class="md:col-span-3 md:text-right">
          <a href="/agent-builder" class="tl-link inline-block text-[14px]">Open the builder &nearr;</a>
          <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-2">~ 30 seconds &middot; no sign-up needed</div>
        </div>
      </div>

      <!-- 05 -- Coordination Checkup -->
      <div class="card p-7 sm:p-8 grid grid-cols-1 md:grid-cols-12 gap-5 md:gap-8 items-start">
        <div class="md:col-span-1"><div class="tl-num">05</div></div>
        <div class="md:col-span-8">
          <h3 class="font-display text-[var(--ink)] text-[1.3rem] font-bold mb-2">The Coordination Checkup</h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]">
            Score your organization against the 8 Levels of Agentic Maturity. Each level names what is actually happening (or not) at that level. Honest read of where you sit, what is blocking the next level, and what to do this week. Originally built for Bassim, our internal evaluator. Now public.
          </p>
        </div>
        <div class="md:col-span-3 md:text-right">
          <a href="/checkup" class="tl-link inline-block text-[14px]">Take the checkup &nearr;</a>
          <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-2">~ 10 minutes &middot; gives a score</div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ================= EXTENDED TOOLBOX ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">The rest of the toolbox</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.12] max-w-[36rem] mb-10"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      Everything else, one click in.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12">
      <% const extendedTools = [
        { href:'/practices', name:'Industry Practice Packs', desc:'Curated coordination patterns by industry. Agency, fitness, healthcare, more.' },
        { href:'/browse', name:'OOS Browser', desc:'Every published OOS on the network. Read how other orgs run.' },
        { href:'/search', name:'Coordination Claim Search', desc:'Full-text search every claim every org has published. Filter by confidence and evidence.' },
        { href:'/experts', name:'Consultant Network', desc:'Verified consultants who help organizations run on OTP.' },
        { href:'/agent-onboarding', name:'Agent Onboarding Framework', desc:'Day-one onboarding spec for any new AI agent. The OTP-native version of new-hire docs.' },
        { href:'/generate', name:'Operating Plan Generator', desc:'Draft a complete OOS from a description. Edit before publishing.' },
        { href:'/protocol', name:'The Protocol Spec', desc:'The canonical "what is the OOS file format" page. For builders.' },
        { href:'/glossary', name:'Glossary', desc:'Every OTP term in one place. Useful when you are about to say "what\'s an OOS again."' },
        { href:'/guide', name:'Implementation Guide', desc:'Step-by-step from sign-up to first published OOS.' },
        { href:'/faq', name:'FAQ', desc:'The questions everyone asks, answered honestly.' }
      ]; %>
      <% extendedTools.forEach(function(t){ %>
        <a href="<%= t.href %>" class="idx-row group block py-4">
          <div class="flex items-baseline justify-between gap-4">
            <div class="flex-1">
              <div class="font-display text-[var(--ink)] text-[1rem] font-bold group-hover:text-[var(--blue-deep)] transition-colors"><%= t.name %></div>
              <div class="text-[13px] text-[var(--ink-mute)] leading-[1.55] mt-0.5"><%= t.desc %></div>
            </div>
            <span class="text-[var(--ink-mute)] group-hover:text-[var(--blue-deep)] transition-colors">&rarr;</span>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.08]"
        style="font-size:clamp(1.9rem,4.2vw,3rem); font-weight:800;">
      Use any one of these. See if any one is enough.
    </h2>
    <p class="text-[16px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mx-auto mt-5">
      The fastest way to know whether OTP belongs in your org is to try one tool against one real problem you have right now.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Build your chart &rarr;</a>
      <a href="/what-is-otp" class="btn-ghost px-8 py-4 text-[16px]">What is OTP</a>
    </div>
  </div>
</section>
