        </div>
        <div class="md:col-span-3">
          <a href="/public/downloads/claude-md-template.md" download class="inline-flex items-center gap-2 text-otp-600 font-semibold border-b border-otp-300 hover:text-otp-700 hover:border-otp-600 pb-1">
