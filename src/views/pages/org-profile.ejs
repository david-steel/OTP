<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- Profile Header -->
  <div class="bg-white p-6 rounded-lg border mb-6">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <h1 class="text-2xl font-bold"><%= org.name %></h1>
          <% if (org.badge === 'founding') { %>
            <span class="badge-founding text-white text-xs px-2 py-0.5 rounded">Founding Publisher</span>
          <% } %>
          <% if (org.qualityTier) { %>
            <span class="badge-<%= org.qualityTier %> text-white text-xs px-2 py-0.5 rounded capitalize"><%= org.qualityTier %></span>
          <% } %>
          <% if (org.agenticLevel) { %>
            <span class="badge-level badge-level-<%= org.agenticLevel %>" title="Bassim Eledath's 8 Levels of Agentic Engineering">L<%= org.agenticLevel %> <%= org.agenticLabel %></span>
          <% } %>
        </div>
        <div class="text-gray-500 text-sm"><%= org.industry %> &middot; <%= org.size %></div>
        <div class="text-xs text-gray-400 mt-1">Member since <%= new Date(org.memberSince).toLocaleDateString() %></div>
      </div>
      <div class="text-right">
        <div class="text-3xl font-bold text-otp-600"><%= stats.totalClaims %></div>
        <div class="text-xs text-gray-500">total claims</div>
      </div>
    </div>

    <div class="grid grid-cols-4 gap-4 mt-6 text-center text-sm">
      <div>
        <div class="text-lg font-bold"><%= stats.publishedFiles %></div>
        <div class="text-xs text-gray-500">Published Files</div>
      </div>
      <div>
        <div class="text-lg font-bold"><%= stats.totalClaims %></div>
        <div class="text-xs text-gray-500">Total Claims</div>
      </div>
      <div>
        <div class="text-lg font-bold">v<%= stats.latestVersion %></div>
        <div class="text-xs text-gray-500">Latest Version</div>
      </div>
      <div>
        <div class="text-lg font-bold"><%= stats.latestPublish ? new Date(stats.latestPublish).toLocaleDateString() : '--' %></div>
        <div class="text-xs text-gray-500">Last Published</div>
      </div>
    </div>
  </div>

  <!-- Published OOS Files -->
  <h2 class="text-lg font-semibold mb-4">Published OOS Files</h2>
  <% if (oosFiles.length > 0) { %>
    <% oosFiles.forEach(function(oos) { %>
      <a href="/oos/<%= oos.id %>" class="block bg-white p-4 rounded-lg border mb-3 claim-card">
        <div class="flex items-center justify-between">
          <div>
            <span class="text-sm font-medium capitalize"><%= oos.template.replace('_', ' ') %></span>
            <span class="text-xs text-gray-400 ml-2">v<%= oos.version %></span>
          </div>
          <div class="flex gap-2 text-xs">
            <span class="bg-gray-100 px-2 py-0.5 rounded"><%= oos.claimCount %> claims</span>
            <span class="bg-gray-100 px-2 py-0.5 rounded"><%= oos.wordCount %> words</span>
          </div>
        </div>
        <div class="flex gap-1 mt-2">
          <span class="bg-confidence-high text-white px-1.5 py-0.5 rounded text-xs"><%= (oos.confidenceDistribution || {}).high || 0 %> H</span>
          <span class="bg-confidence-medium text-white px-1.5 py-0.5 rounded text-xs"><%= (oos.confidenceDistribution || {}).medium || 0 %> M</span>
          <span class="bg-confidence-low text-white px-1.5 py-0.5 rounded text-xs"><%= (oos.confidenceDistribution || {}).low || 0 %> L</span>
          <span class="text-xs text-gray-400 ml-2">Published <%= oos.publishedAt ? new Date(oos.publishedAt).toLocaleDateString() : 'Draft' %></span>
        </div>
      </a>
    <% }); %>
  <% } else { %>
    <div class="text-center py-8 text-gray-400 text-sm">No published OOS files yet.</div>
  <% } %>
</div>
