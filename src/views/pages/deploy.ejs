<%# /deploy -- v7 layout (light, editorial). Track 2 destination:
    Bring Your Agents In (L4-L6). Solo operator with agents already
    running ad-hoc. Goal: register, place, KPI, runtime.
    Rendered via reply.view('pages/deploy', data, { layout: 'layouts/v7' }). %>
<style>
  .dep-num {
    width:42px; height:42px; border-radius:12px;
    display:flex; align-items:center; justify-content:center;
    font-family:'Schibsted Grotesk',sans-serif; font-weight:800; font-size:17px;
    background:rgba(255,122,26,.12); color:var(--orange-deep);
    border:1px solid rgba(255,122,26,.25); flex-shrink:0;
  }
  .dep-pill {
    display:inline-flex; align-items:center; gap:7px;
    padding:6px 12px; border-radius:8px;
    font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:500;
    letter-spacing:0.04em;
    background:rgba(255,122,26,.1); color:var(--orange-deep);
    border:1px solid rgba(255,122,26,.25);
  }
  .dep-orgy { animation:dep-orgy 5.5s ease-in-out infinite; }
  @keyframes dep-orgy { 0%,100%{transform:translateY(0) rotate(-5deg);} 50%{transform:translateY(-12px) rotate(-5deg);} }
  @media (prefers-reduced-motion:reduce){ .dep-orgy{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[920px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16">
    <div class="eyebrow mb-7 flex items-center gap-2 flex-wrap">
      <a href="/" class="link-u" style="color:var(--ink-mute); border-bottom-width:1.5px;">OTP</a>
      <span style="color:var(--line);">/</span>
      <span style="color:var(--ink);">Bring Your Agents In</span>
    </div>

    <div class="flex flex-col-reverse md:flex-row items-start gap-8 md:gap-12">
      <div class="flex-1">
        <div class="mb-8">
          <span class="dep-pill">
            <span class="w-1.5 h-1.5 rounded-full" style="background:var(--orange);"></span>
            Track 2 &middot; You're running agents already &middot; L4&ndash;L6
          </span>
        </div>
        <h1 class="font-display text-[var(--ink)] max-w-[42rem]"
            style="font-size:clamp(2.2rem,4.4vw,3.4rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
          Your agents are running. Now give them a chart.
        </h1>
        <p class="text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[40rem] mt-6">
          You've already crossed the starting line. You have agents. They're working. But they're scattered across tabs, scripts, and crontabs, and nobody knows their KPIs.
        </p>
        <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] max-w-[40rem] mt-3">
          This track is about formalizing what you've built. Four steps: register the agents you have, give each one a seat on your chart, assign each one a number it owns, and put them on a runtime that doesn't die when your credits run out.
        </p>
      </div>
      <img src="/public/images/orgy-mascot.png" alt="Orgy, the OTP mascot"
           class="dep-orgy shrink-0 mx-auto md:mx-0" style="width:150px; height:auto; filter:drop-shadow(0 18px 28px rgba(20,22,28,.18));">
    </div>
  </div>
</section>

<!-- ================= FOUR STEPS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[920px] mx-auto px-6 py-20 sm:py-24">
    <% const depSteps = [
      { n:'1', href:'/dashboard/team', time:'~ 20 min', title:'Register your existing agents',
        body:"List every agent you're already running. What does it do, who owns it, what triggers it, where does it live today (cron, Claude Code, Make, n8n, Lambda)? This is the inventory step. You can't manage what you can't see.",
        cta:'Open the agent registry' },
      { n:'2', href:'/graph', time:'~ 30 min', title:'Place every agent on the chart',
        body:"Each agent gets a seat alongside your humans. Who does it report to? Who owns it as a manager? If you can't place it on the chart, it's not really part of the org, it's a script. This is where most teams hit the pain wall and realize the chart they had wasn't built to receive agents.",
        cta:'Open the chart' },
      { n:'3', href:'/dashboard/kpis', time:'~ 25 min', title:'Assign each agent a KPI',
        body:"One number per agent. Cold emails sent. Tickets resolved. Loads tracked. Anomalies caught. If an agent doesn't own a number, it doesn't earn its seat, and you can't tell whether it's helping or just consuming tokens. This is the difference between an agent and a script.",
        cta:'Wire up KPIs' },
      { n:'4', href:'/mcp', time:'~ 30 min', title:'Hook up triggers and runtime',
        body:'Schedule your agents through OTP\'s MCP layer. Daily, hourly, on-event. No more cron jobs that die when your credits run out. No more "Dirk stopped working last Tuesday and nobody knew." OTP fires them, watches them, and reports the KPI back to the chart.',
        cta:'Configure the runtime' },
    ]; %>

    <div class="space-y-4">
      <% depSteps.forEach((s) => { %>
        <a href="<%= s.href %>" class="card lift block p-7 sm:p-8">
          <div class="flex items-start gap-5">
            <div class="dep-num"><%= s.n %></div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <h3 class="font-display text-[var(--ink)] text-[1.3rem] sm:text-[1.45rem] font-bold tracking-[-0.01em]"><%= s.title %></h3>
                <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--ink-mute)]"><%= s.time %></span>
              </div>
              <p class="text-[14.5px] text-[var(--ink-soft)] leading-[1.7] mb-4"><%= s.body %></p>
              <span class="inline-flex items-center gap-1.5 text-[14px] text-[var(--orange-deep)] link-u">
                <%= s.cta %> &rarr;
              </span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= WHAT'S NEXT ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[920px] mx-auto px-6 py-20 sm:py-24">
    <div class="card p-8 sm:p-11" style="background:linear-gradient(180deg,rgba(255,122,26,.05),var(--card));">
      <div class="eyebrow mb-3" style="color:var(--orange-deep);">When this track gets too small</div>
      <h2 class="font-display text-[var(--ink)] leading-[1.12] mb-3"
          style="font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; letter-spacing:-0.02em;">
        Track 3 &middot; Coordinate your team
      </h2>
      <p class="text-[15.5px] text-[var(--ink-soft)] leading-[1.7] max-w-[42rem] mb-6">
        When more than one human is running agents, Track 2's solo-operator shape stops scaling. You'll need multi-user permissions, a cross-agent registry, an inter-agent message bus, and Bassim's L7&ndash;L8 maturity scoring. That's Track 3.
      </p>
      <a href="/teams" class="inline-flex items-center gap-2 text-[15px] text-[var(--orange-deep)] link-u">
        See Track 3 &rarr;
      </a>
    </div>
  </div>
</section>
