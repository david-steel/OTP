<%# /fix-accountability-gaps -- v7 layout (light, editorial). Google Ads sitelink landing page.
    Sitelink label: "Fix Accountability Gaps". Problem-first framing.
    Every CTA drives to /sign-up. gtagSendEvent onclick preserved (ad conversion). %>
<style>
  .ag-peek { animation:ag-peek 6s ease-in-out infinite; transform-origin:bottom center; }
  @keyframes ag-peek { 0%,100%{transform:translateY(8px) rotate(-2deg);} 50%{transform:translateY(-6px) rotate(2deg);} }
  @media (prefers-reduced-motion:reduce){ .ag-peek{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[840px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 mb-7"
         style="border-color:var(--orgy-deep); background:rgba(189,214,34,0.14);">
      <span class="tick" style="background:var(--orgy-deep);"></span>
      <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--ink)]">Beta: free forever for your whole team</span>
    </div>

    <div class="eyebrow mb-4">Accountability</div>
    <h1 class="font-display text-[var(--ink)] mx-auto max-w-[18ch]"
        style="font-size:clamp(2.3rem,5.4vw,3.9rem); line-height:1.06; font-weight:700; letter-spacing:-0.025em;">
      Close the gaps where <span class="text-[var(--orange-deep)]">accountability leaks</span>.
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[40rem] mx-auto mt-6">
      Every commitment made in the meeting feels solid on Monday. Then it quietly slips between Mondays. Nothing tracks it, nobody owns it, and you only find out when it has already become a fire.
    </p>
    <p class="text-[15px] sm:text-[16px] font-semibold text-[var(--green-deep)] max-w-[40rem] mx-auto mt-3">
      OTP gives every priority an owner, every action a due date, and a built-in AI Chief of Staff that watches for drift between meetings.
    </p>

    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-primary px-8 py-4 text-[16px]">Fix it on OTP, free &rarr;</a>
    </div>
    <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--ink-mute)] mt-6">
      Free in beta &nbsp;&middot;&nbsp; No credit card &nbsp;&middot;&nbsp; Whole team included
    </p>
  </div>
</section>

<!-- ================= THE PROBLEM ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[620px] mx-auto text-center mb-14">
      <div class="eyebrow mb-4" style="color:var(--orange-deep);">The problem</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.8rem); font-weight:700;">
        Where accountability breaks.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        It is rarely one big failure. It is three small gaps that repeat every week.
      </p>
    </div>

    <% const problems = [
      { label: 'No clear owner',                desc: 'A priority belongs to "the team", so it belongs to no one. When everyone is accountable, nobody is. The work waits for a name that never gets assigned.' },
      { label: 'It lives in scattered places',  desc: 'A spreadsheet, a doc, someone\'s notes, three different tools. There is no single place to look, so the team stops looking. The commitment fades from view.' },
      { label: 'Drift goes unseen',             desc: 'Nothing tracks the commitment between meetings. You only find out it slipped when it is already a fire. By then the quarter is half gone.' },
    ]; %>

    <div class="grid sm:grid-cols-3 gap-5">
      <% problems.forEach(p => { %>
        <div class="card p-7 border-t-[3px]" style="border-top-color:var(--orange);">
          <div class="text-[1.6rem] mb-3" aria-hidden style="color:var(--orange-deep);">&#9888;</div>
          <h3 class="font-display text-[1.15rem] font-bold text-[var(--ink)] mb-2"><%= p.label %></h3>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]"><%= p.desc %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= THE FIX ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-24 sm:py-28">
    <div class="max-w-[640px] mx-auto text-center mb-14">
      <div class="eyebrow mb-4" style="color:var(--green-deep);">The fix</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.6vw,2.8rem); font-weight:700;">
        One platform that closes every gap.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        OTP runs the rhythm your leadership team already knows. Each tool removes one place accountability leaks.
      </p>
    </div>

    <% const fixes = [
      { tag: 'Structure',  label: 'Team Chart',           desc: 'One owner per seat. No ambiguity about who answers for what. The structure that survives growth.' },
      { tag: 'Quarter',    label: 'Quarterly Priorities', desc: 'Every 90-day goal is owned, dated, and has visible progress. No priority hides behind "the team".' },
      { tag: 'Week',       label: 'To-Dos',               desc: 'Every action item from every meeting. Owned and closed. Nothing falls into someone\'s private notes.' },
      { tag: 'Friction',   label: 'Issues Board',         desc: 'Problems get surfaced and solved, not buried. The list that keeps you out of fire-drill mode.' },
      { tag: 'Numbers',    label: 'Weekly Scoreboard',    desc: 'An owner on every KPI. Red, yellow, green at a glance. Accountability you can read in one row.' },
    ]; %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% fixes.forEach(f => { %>
        <div class="card lift p-6">
          <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-mute)] mb-3"><%= f.tag %></div>
          <h3 class="font-display text-[1.1rem] font-bold text-[var(--ink)] mb-1.5"><%= f.label %></h3>
          <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.7]"><%= f.desc %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= THE WEDGE: RADAR ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[920px] mx-auto px-6 py-24 sm:py-28">
    <div class="card p-8 sm:p-11 relative overflow-hidden">
      <div class="hidden sm:block absolute -bottom-2 right-6">
        <img src="/public/orgy-clean.png" alt="" aria-hidden="true" class="ag-peek block" style="width:118px; height:auto; filter:drop-shadow(0 14px 22px rgba(20,22,28,.2));">
      </div>
      <div class="sm:max-w-[78%]">
        <div class="eyebrow mb-3" style="color:var(--blue-deep);">The difference</div>
        <h2 class="font-display text-[var(--ink)] leading-[1.13] mb-4"
            style="font-size:clamp(1.6rem,3vw,2.4rem); font-weight:700;">
          Radar tracks accountability <span class="text-[var(--blue)]">between meetings</span>.
        </h2>
        <p class="text-[15.5px] text-[var(--ink-soft)] leading-[1.72]">
          Per-seat EOS&reg; tools only see the meeting. They show you the priority on the screen, and that is where their job ends. The slip happens in the four days nobody is watching.
        </p>
        <p class="text-[15.5px] text-[var(--ink-soft)] leading-[1.72] mt-4">
          Every OTP account includes Radar, a built-in AI Chief of Staff. Radar reads your Quarterly Priorities and To-Dos through the week, tracks what is moving and what is not, and flags drift before Friday. Nothing reaches the meeting as a surprise.
        </p>
      </div>

      <div class="mt-8 grid sm:grid-cols-3 gap-4">
        <% const radarPoints = [
          { label: 'Reads the work',    desc: 'Pulls Quarterly Priorities and To-Dos all week, not just on meeting day.' },
          { label: 'Flags drift early', desc: 'Catches a slipping commitment mid-week, while there is still time to act.' },
          { label: 'No surprises',      desc: 'The meeting starts with the situation already known. No fire drills.' },
        ]; %>
        <% radarPoints.forEach(c => { %>
          <div class="rounded-[13px] border p-4" style="border-color:var(--line); background:var(--grey);">
            <div class="text-[1.1rem] mb-2" aria-hidden style="color:var(--blue);">&#9733;</div>
            <h3 class="font-display text-[0.95rem] font-bold text-[var(--ink)] mb-1"><%= c.label %></h3>
            <p class="text-[12.5px] text-[var(--ink-soft)] leading-[1.65]"><%= c.desc %></p>
          </div>
        <% }); %>
      </div>

      <p class="mt-7 text-[14px] font-semibold text-[var(--green-deep)]">
        Radar is included free for the whole team while in beta. No add-on. No per-seat fee.
      </p>

      <div class="mt-7">
        <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink inline-flex items-center gap-2 px-7 py-3.5 text-[15px]">
          Put Radar on your team, free &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-7"
         style="background:var(--ink); color:var(--orgy);">
      <span aria-hidden>&#9733;</span>
      <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.18em]">Join in beta = free forever</span>
      <span aria-hidden>&#9733;</span>
    </div>

    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(2.1rem,4.6vw,3.4rem); font-weight:800;">
      Stop the slip. Run accountable on OTP.
    </h2>
    <p class="text-[17px] leading-[1.6] max-w-[38rem] mx-auto mt-6" style="color:#5a2a06;">
      One platform for your Vision Plan, Scoreboard, Quarterly Priorities, To-Dos, Issues, and weekly meeting. Plus Radar watching for drift between Mondays. Free for your whole team while we are in beta, and grandfathered free when paid plans turn on.
    </p>

    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink px-9 py-4 text-[16px]">Create your free account &rarr;</a>
    </div>

    <p class="font-mono text-[11px] uppercase tracking-[0.18em] mt-8" style="color:#7a3a0c;">
      OTP is not affiliated with EOS Worldwide, Ninety, or Bloom Growth.
    </p>
  </div>
</section>
