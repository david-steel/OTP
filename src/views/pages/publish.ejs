// ---- Prompt toggle and copy ----

function togglePrompt() {
  var section = document.getElementById('prompt-section');
  var btn = document.getElementById('prompt-toggle-btn');
  var isHidden = section.classList.contains('hidden');
  section.classList.toggle('hidden');
  btn.textContent = isHidden ? 'Hide prompt' : 'Show prompt';
}

function copyPrompt() {
  var text = document.getElementById('generation-prompt').textContent;
  navigator.clipboard.writeText(text).then(function() {
    var btn = document.getElementById('copy-prompt-btn');
    btn.textContent = 'Copied!';
    btn.classList.add('text-green-600');
    setTimeout(function() { btn.textContent = 'Copy'; btn.classList.remove('text-green-600'); }, 2000);
  });
}

