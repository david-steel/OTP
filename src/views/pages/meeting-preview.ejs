<%
  // Public meeting preview — served to unauthenticated requests at
  // /l8/meeting/:id (humans clicking from outside the platform AND link-unfurl
  // bots like Slackbot/Twitterbot/LinkedInBot/facebookexternalhit).
  //
  // What this surface MUST NOT leak: meeting body content (segue notes,
  // headlines, scorecard snapshot, rocks snapshot, agenda contents, ratings,
  // cascading message). Only public-safe metadata: title, scheduled date,
  // attendee NAMES (not emails or IDs), and the sign-in CTA.
  //
  // The orchestrating route at /l8/meeting/:id branches on auth state and
  // hands this template only the safe fields.

  var notFound = locals.notFound === true;
  var attendeeNames = locals.attendeeNames || [];
  var dateLabel = locals.dateLabel || '';
  var timeLabel = locals.timeLabel || '';
  var meetingTitle = locals.meetingTitle || 'Meeting';
  var signInUrl = locals.signInUrl || '/sign-in';
%>

<div style="background:#f7f2e6;min-height:100vh;color:#221c11;">
  <div class="max-w-2xl mx-auto px-6 py-16 sm:py-24">

    <% if (notFound) { %>
      <div class="text-[11px] uppercase font-mono tracking-[0.22em]" style="color:#6f6450;">OTP &middot; Meeting</div>
      <h1 class="mt-3 font-extrabold tracking-tight" style="font-family:Archivo,sans-serif;font-size:clamp(2.2rem,4.6vw,3.4rem);line-height:1;letter-spacing:-0.03em;">Meeting not found.</h1>
      <p class="mt-6" style="font-family:Inter,sans-serif;font-size:15px;line-height:1.7;color:#6f6450;">This link is invalid, the meeting was removed, or you don't have an organization that owns it.</p>
      <div class="mt-10">
        <a href="<%= signInUrl %>" class="inline-flex items-center px-5 py-3 font-semibold rounded transition-opacity hover:opacity-90"
           style="background:#17130d;color:#f4ecda;font-family:Inter,sans-serif;font-size:14px;letter-spacing:0.01em;border-radius:7px;">
          Sign in to OTP &rarr;
        </a>
      </div>
    <% } else { %>
      <div class="text-[11px] uppercase font-mono tracking-[0.22em]" style="color:#6f6450;">
        OTP &middot; L8 Meeting
      </div>

      <h1 class="mt-3 font-extrabold tracking-tight" style="font-family:Archivo,sans-serif;font-size:clamp(2.2rem,4.6vw,3.4rem);line-height:1;letter-spacing:-0.03em;">
        <%= meetingTitle %>
      </h1>

      <% if (dateLabel) { %>
        <div class="mt-5 font-mono text-sm" style="color:#221c11;letter-spacing:0.04em;">
          <%= dateLabel %><% if (timeLabel) { %> &middot; <%= timeLabel %><% } %>
        </div>
      <% } %>

      <% if (attendeeNames.length > 0) { %>
        <div class="mt-8">
          <div class="text-[11px] uppercase font-mono tracking-[0.22em]" style="color:#6f6450;">Attendees</div>
          <ul class="mt-2 space-y-1" style="font-family:Inter,sans-serif;font-size:15px;color:#221c11;">
            <% attendeeNames.forEach(function(name) { %>
              <li><%= name %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="mt-12 pt-8" style="border-top:1px solid #221c1124;">
        <p style="font-family:Inter,sans-serif;font-size:15px;line-height:1.7;color:#6f6450;">
          Sign in with the email this meeting was shared with to view the agenda, scorecard, rocks, headlines, and to-dos.
        </p>
        <div class="mt-6">
          <a href="<%= signInUrl %>" class="inline-flex items-center px-5 py-3 font-semibold rounded transition-opacity hover:opacity-90"
             style="background:#17130d;color:#f4ecda;font-family:Inter,sans-serif;font-size:14px;letter-spacing:0.01em;border-radius:7px;">
            Sign in to view &rarr;
          </a>
        </div>
      </div>
    <% } %>

  </div>
</div>
