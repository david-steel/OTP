<!-- AEO cluster page. Renders one AeoCluster: header, FAQ accordion, related
     pages, and the MCP install snippet. Data: src/data/aeo-clusters.ts -->

<!-- Header -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14 pb-10 sm:pb-14">
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
        <a href="/answers" class="px-2 py-0.5 rounded-full bg-otp-500/20 text-otp-300 font-semibold hover:bg-otp-500/30 transition-colors"><%= cluster.badge %></a>
        <span class="text-gray-500">Answers for AI engines</span>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight"><%= cluster.h1 %></h1>
      <p class="text-gray-400 mt-4 max-w-xl leading-relaxed"><%= cluster.intro %></p>
    </div>
  </div>
</section>

<!-- FAQ body -->
<section class="bg-white py-10 sm:py-14">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">

    <div class="space-y-6">
      <% cluster.items.forEach(function(item, i) { %>
        <details class="group border-b border-gray-100 pb-2"<%= i === 0 ? ' open' : '' %>>
          <summary class="flex items-center justify-between cursor-pointer py-3 text-gray-900 font-semibold hover:text-otp-600 transition-colors">
            <span class="pr-4"><%= item.q %></span>
            <svg class="w-5 h-5 text-gray-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="pb-4 text-gray-700 text-sm leading-relaxed"><%- item.a %></div>
        </details>
      <% }); %>
    </div>

    <!-- Install snippet -->
    <div class="mt-12 rounded-xl bg-otp-950 border border-otp-500/20 p-6 sm:p-8">
      <h2 class="text-lg font-bold text-white mb-2">Ask your own AI assistant</h2>
      <p class="text-gray-400 text-sm mb-4">OTP is published as an MCP server. Add this block to Claude Desktop, Cursor, Windsurf, or Cline, restart the client, and your assistant can query the live coordination data behind these answers.</p>
      <pre class="bg-black/60 border border-white/10 rounded-lg p-4 text-xs text-otp-200 overflow-x-auto"><code>"otp": {
  "command": "npx",
  "args": ["-y", "@orgtp/mcp-server"]
}</code></pre>
      <p class="text-gray-400 text-sm mt-4">Then ask: <span class="text-otp-300 font-medium">"<%= cluster.ask %>"</span></p>
    </div>

    <!-- Related answer pages -->
    <% if (typeof related !== 'undefined' && related.length) { %>
      <div class="mt-12">
        <h2 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Related answer pages</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          <% related.forEach(function(r) { %>
            <a href="/answers/<%= r.slug %>" class="block p-4 rounded-lg border border-gray-200 hover:border-otp-400 hover:bg-otp-50 transition-colors">
              <span class="text-xs font-semibold text-otp-600"><%= r.badge %></span>
              <span class="block text-sm text-gray-700 mt-1 leading-snug"><%= r.h1 %></span>
            </a>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <p class="text-gray-500 mb-4">Run AI agents in your company? Publish how they coordinate so the network can learn from you.</p>
      <a href="/publish" class="inline-flex items-center gap-2 px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-all hover:shadow-lg hover:shadow-otp-500/25 group">Publish Your OOS<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></a>
    </div>

  </div>
</section>
