<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-8">
    <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Weekly Leadership Meetings</div>
    <h1 class="text-2xl font-bold"><%= org.name %></h1>
    <p class="text-sm text-gray-600 mt-1">Run your weekly leadership meeting from one page. Checkin, Scorecard, Quarterly Priorities, Headlines, To-Dos, Issues, Conclude.</p>
  </div>

  <!-- Quick create -->
  <form action="/l10/create<%= devOrgIdParam ? ('?orgId=' + devOrgIdParam) : '' %>" method="POST" class="border rounded-lg p-4 mb-8 bg-gray-50">
    <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-gray-700">New Meeting</h2>
    <div class="grid grid-cols-3 gap-3">
      <input name="title" type="text" required placeholder="e.g. Leadership Meeting -- 2026-05-05"
             class="col-span-2 border rounded p-2 text-sm"
             value="Leadership Meeting -- <%= new Date().toISOString().slice(0,10) %>">
      <input name="scheduledAt" type="datetime-local" required
             class="border rounded p-2 text-sm"
             value="<%= new Date(Date.now() + 86400000).toISOString().slice(0,16) %>">
    </div>
    <div class="mt-3 flex justify-between items-center">
      <select name="meetingType" class="border rounded p-2 text-sm">
        <option value="leadership">Leadership Team</option>
        <option value="departmental">Departmental</option>
        <option value="1on1">1-on-1</option>
        <option value="other">Other</option>
      </select>
      <button class="px-4 py-2 bg-otp-500 text-white rounded text-sm font-medium hover:bg-otp-400">
        Create + Open
      </button>
    </div>
  </form>

  <!-- Meeting list -->
  <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-gray-700">Recent Meetings</h2>
  <% if (!meetings || meetings.length === 0) { %>
    <div class="bg-yellow-50 border border-yellow-200 rounded p-4 text-sm">
      No meetings yet. Create one above to begin running your weekly leadership meeting from OTP.
    </div>
  <% } else { %>
    <div class="space-y-2">
      <% meetings.forEach(function(m) { %>
        <a href="/l10/meeting/<%= m.id %><%= devOrgIdParam ? ('?orgId=' + devOrgIdParam) : '' %>" class="block border rounded p-4 hover:bg-gray-50">
          <div class="flex items-center justify-between">
            <div>
              <div class="font-medium"><%= m.title %></div>
              <div class="text-xs text-gray-500 mt-1">
                <%= m.meetingType %> &middot; <%= new Date(m.scheduledAt).toLocaleString() %>
              </div>
            </div>
            <div class="text-xs">
              <span class="px-2 py-0.5 rounded
                <%= m.status === 'scheduled' ? 'bg-gray-100 text-gray-700' :
                   m.status === 'in_progress' ? 'bg-blue-100 text-blue-800' :
                   m.status === 'completed' ? 'bg-emerald-100 text-emerald-800' :
                   'bg-red-100 text-red-800' %>">
                <%= m.status %>
              </span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>
