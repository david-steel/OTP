<%# /process-templates/:slug -- a single SOP detail page. v7 layout,
    dual-rendered (renderInShell). Content comes from src/data/sop-templates.ts
    via the sop-library route (sop + related + categoryLabel locals). All SOP
    strings are escaped (authored content, but escaped for consistency and
    XSS-safety). NOTE: an EJS comment closes on the first percent-gt it sees,
    so no EJS tag examples in here. %>
<style>
  .sd-lead { font-size:16px; color:var(--ink-soft); line-height:1.7; }
  .sd-block-label {
    font-family:'JetBrains Mono',monospace; font-size:10.5px; font-weight:600;
    letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute); margin-bottom:8px;
  }
  .sd-meta { display:flex; flex-wrap:wrap; gap:8px; }
  .sd-badge {
    font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; letter-spacing:0.04em;
    text-transform:uppercase; color:var(--blue-deep); background:rgba(13,125,242,.08);
    border:1px solid rgba(13,125,242,.16); border-radius:7px; padding:5px 10px;
  }
  .sd-pill {
    font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-soft);
    background:var(--card); border:1px solid var(--line); border-radius:7px; padding:5px 10px;
  }
  .sd-callout {
    background:var(--grey); border:1px solid var(--line); border-radius:12px; padding:16px 18px;
    font-size:14px; color:var(--ink-soft); line-height:1.62;
  }
  .sd-callout strong { color:var(--ink); font-weight:600; }

  .sd-steps { counter-reset:sd-step; list-style:none; margin:0; padding:0; }
  .sd-step {
    display:flex; gap:14px; padding:16px 0; border-bottom:1px solid var(--line); page-break-inside:avoid;
  }
  .sd-step:last-child { border-bottom:none; }
  .sd-step-no {
    counter-increment:sd-step; flex:none; width:30px; height:30px; border-radius:9px;
    display:flex; align-items:center; justify-content:center;
    font-family:'Schibsted Grotesk',sans-serif; font-weight:800; font-size:13px;
    background:var(--orgy); color:var(--ink);
  }
  .sd-step-no::before { content:counter(sd-step); }
  .sd-step-text { font-size:14.5px; color:var(--ink-soft); line-height:1.6; align-self:center; }

  .sd-list { list-style:none; margin:0; padding:0; }
  .sd-list li { display:flex; gap:10px; padding:7px 0; font-size:14px; color:var(--ink-soft); line-height:1.55; }
  .sd-list li::before { content:''; flex:none; width:7px; height:7px; margin-top:7px; border-radius:2px; background:var(--blue); }
  .sd-tools { display:flex; flex-wrap:wrap; gap:8px; }
  .sd-tool {
    font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-soft);
    background:var(--card); border:1px solid var(--line); border-radius:8px; padding:5px 11px;
  }

  .sd-btn {
    display:inline-flex; align-items:center; gap:8px; padding:11px 18px; border-radius:11px;
    font-size:14px; font-weight:600; text-decoration:none; cursor:pointer; border:1.5px solid transparent;
    transition:all .14s ease;
  }
  .sd-btn-primary { background:var(--blue); color:#fff; }
  .sd-btn-primary:hover { background:var(--blue-deep); }
  .sd-btn-ghost { background:var(--card); color:var(--ink); border-color:var(--line); }
  .sd-btn-ghost:hover { border-color:var(--blue); color:var(--blue-deep); }

  .sd-cta { background:var(--card); border:1.5px solid var(--line); border-radius:16px; padding:24px; }
  .sd-chip {
    font-size:12px; color:var(--ink-soft); background:var(--grey); border:1px solid var(--line);
    border-radius:9999px; padding:5px 11px; white-space:nowrap;
  }
  .sd-related-card {
    display:block; padding:16px; background:var(--card); border:1.5px solid var(--line);
    border-radius:14px; text-decoration:none; transition:border-color .15s ease, transform .15s ease;
  }
  .sd-related-card:hover { border-color:var(--blue); transform:translateY(-2px); }

  @media print {
    .no-print { display:none !important; }
    body { background:#fff !important; color:#000 !important; }
    .sd-lead, .sd-step-text, .sd-list li, .sd-callout, h1, h2, h3 { color:#000 !important; }
    a { color:#000 !important; text-decoration:none; }
    .sd-step { border-color:#ccc !important; page-break-inside:avoid; }
    h1, h2, h3 { page-break-after:avoid; }
    section { background:#fff !important; }
  }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[860px] mx-auto px-6 pt-[124px] pb-8 sm:pt-[148px] sm:pb-10"<%- (typeof authUserId !== 'undefined' && authUserId) ? ' style="padding-top:56px;"' : '' %>>
    <a href="/process-templates" class="no-print eyebrow inline-flex items-center gap-2 mb-5 text-[var(--ink-soft)]" style="text-decoration:none;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Process Library
    </a>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(1.8rem,3.6vw,2.6rem); line-height:1.12; font-weight:700; letter-spacing:-0.025em;">
      <%= sop.title %>
    </h1>
    <p class="sd-lead mt-4 max-w-[44rem]"><%= sop.description %></p>
    <div class="sd-meta mt-5">
      <span class="sd-badge"><%= categoryLabel %></span>
      <span class="sd-pill"><%= sop.steps.length %> step<%= sop.steps.length === 1 ? '' : 's' %></span>
    </div>
  </div>
</section>

<!-- ================= BODY ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[860px] mx-auto px-6 py-10 sm:py-14">

    <!-- When to use + trigger -->
    <div class="card p-6 sm:p-8">
      <div class="sd-block-label">When to use</div>
      <p class="text-[15px] text-[var(--ink-soft)] leading-[1.7] mb-5"><%= sop.whenToUse %></p>
      <div class="sd-block-label">Trigger</div>
      <div class="sd-callout"><strong>Runs when:</strong> <%= sop.trigger %></div>
    </div>

    <!-- Steps -->
    <div class="card p-6 sm:p-8 mt-6">
      <h2 class="font-display text-[var(--ink)] text-[1.35rem] font-bold tracking-[-0.015em] mb-1">The procedure</h2>
      <p class="text-[13px] text-[var(--ink-mute)] mb-4 font-mono"><%= sop.steps.length %> step<%= sop.steps.length === 1 ? '' : 's' %></p>
      <ol class="sd-steps">
        <% sop.steps.forEach(function(step) { %>
          <li class="sd-step">
            <div class="sd-step-no"></div>
            <div class="sd-step-text"><%= step %></div>
          </li>
        <% }); %>
      </ol>
    </div>

    <!-- Outputs + Tools -->
    <% if ((sop.outputs && sop.outputs.length) || (sop.tools && sop.tools.length)) { %>
      <div class="grid gap-6 mt-6" style="grid-template-columns:1fr;">
        <% if (sop.outputs && sop.outputs.length) { %>
          <div class="card p-6 sm:p-8">
            <div class="sd-block-label">Outputs</div>
            <ul class="sd-list">
              <% sop.outputs.forEach(function(o) { %><li><span><%= o %></span></li><% }); %>
            </ul>
          </div>
        <% } %>
        <% if (sop.tools && sop.tools.length) { %>
          <div class="card p-6 sm:p-8">
            <div class="sd-block-label">Tools</div>
            <div class="sd-tools">
              <% sop.tools.forEach(function(t) { %><span class="sd-tool"><%= t %></span><% }); %>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- Tips -->
    <% if (sop.tips && sop.tips.length) { %>
      <div class="card p-6 sm:p-8 mt-6">
        <div class="sd-block-label">Tips</div>
        <ul class="sd-list">
          <% sop.tips.forEach(function(t) { %><li><span><%= t %></span></li><% }); %>
        </ul>
      </div>
    <% } %>

    <!-- Notes -->
    <% if (sop.notes) { %>
      <div class="sd-callout mt-6"><strong>Note:</strong> <%= sop.notes %></div>
    <% } %>

    <!-- Actions -->
    <div class="no-print flex flex-wrap gap-3 mt-6">
      <a class="sd-btn sd-btn-ghost" href="/process-templates/<%= sop.slug %>/download">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download .md
      </a>
      <button class="sd-btn sd-btn-ghost" type="button" onclick="window.print()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print
      </button>
    </div>

    <!-- Use in OTP CTA -- funnels a browser into the executable-agent product.
         Deep-links to the Processes hub prefilled from this library SOP. If
         signed out, the hub's auth redirect returns the user here-prefilled. -->
    <div class="sd-cta no-print mt-8">
      <h3 class="font-display text-[var(--ink)] text-[1.15rem] font-bold tracking-[-0.015em] mb-1.5">Use this SOP in OrgTP</h3>
      <p class="text-[14px] text-[var(--ink-soft)] leading-[1.6] mb-4">
        Don't just download it. Drop this SOP onto a seat in OrgTP and every AI agent under that seat inherits and runs it at runtime &mdash; with the trigger, steps, outputs, and tools already filled in.
      </p>
      <div class="flex flex-wrap gap-3">
        <a class="sd-btn sd-btn-primary" href="/processes?insert=<%= encodeURIComponent(sop.slug) %>">Use in OTP &rarr;</a>
        <a class="sd-btn sd-btn-ghost" href="/process-templates">Browse more SOPs</a>
      </div>
    </div>

    <!-- Keyword chips -->
    <% if (sop.keywords && sop.keywords.length) { %>
      <div class="no-print mt-8">
        <div class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-mute)] mb-2.5">Related searches</div>
        <div class="flex flex-wrap gap-2">
          <% sop.keywords.forEach(function(k) { %>
            <a class="sd-chip" href="/process-templates?q=<%= encodeURIComponent(k) %>"><%= k %></a>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Related SOPs -->
    <% if (related && related.length) { %>
      <div class="mt-10">
        <h2 class="font-display text-[var(--ink)] text-[1.2rem] font-bold tracking-[-0.015em] mb-4">Related SOPs</h2>
        <div class="grid gap-4" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));">
          <% related.forEach(function(r) { %>
            <a class="sd-related-card" href="/process-templates/<%= r.slug %>">
              <div class="sd-meta mb-2"><span class="sd-badge"><%= categoryLabel %></span></div>
              <div class="font-display text-[var(--ink)] text-[1rem] font-bold tracking-[-0.01em] leading-[1.25]"><%= r.shortName || r.title %></div>
              <div class="font-mono text-[11px] text-[var(--ink-mute)] mt-1.5"><%= r.steps.length %> step<%= r.steps.length === 1 ? '' : 's' %></div>
            </a>
          <% }); %>
        </div>
      </div>
    <% } %>

    <div class="no-print mt-10">
      <a href="/process-templates" class="text-[14px] font-semibold text-[var(--blue-deep)] link-u">&larr; Back to the Process Library</a>
    </div>

  </div>
</section>
