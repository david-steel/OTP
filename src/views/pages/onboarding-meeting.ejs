<%# Step 7 of 7 -- first meeting (finale). Display only; CTA finishes onboarding.
    Locals: org, members[], teamName, counts {seats,goals,kpis,agents,teams} %>
<%
function ob_initials(name){
  var n=String(name||'').trim(); if(!n) return '?';
  var p=n.split(/\s+/);
  return ((p[0][0]||'')+(p.length>1?(p[p.length-1][0]||''):'')).toUpperCase()||'?';
}
var ob_palette=['#14161c','#ff7a1a','#0d7df2','#0a9d63','#8BC42A'];
var ob_recap=[];
ob_recap.push(counts.seats + ' seat' + (counts.seats===1?'':'s'));
if(counts.goals)  ob_recap.push(counts.goals  + ' goal' + (counts.goals===1?'':'s'));
if(counts.kpis)   ob_recap.push(counts.kpis   + ' KPI'  + (counts.kpis===1?'':'s'));
if(counts.agents) ob_recap.push(counts.agents + ' agent'+ (counts.agents===1?'':'s'));
if(counts.teams)  ob_recap.push(counts.teams  + ' team' + (counts.teams===1?'':'s'));
%>
<style>
  :root{
    --white:#fcfcfd; --grey:#f0f1f3; --card:#ffffff;
    --ink:#14161c; --ink-soft:#494d57; --ink-mute:#888c96;
    --blue:#0d7df2; --blue-deep:#0a56b0;
    --orange:#ff7a1a; --orange-deep:#d4540a;
    --green:#0a9d63; --green-deep:#06724a;
    --orgy:#A8E63A; --orgy-deep:#8BC42A;
    --line:rgba(20,22,28,0.12); --line-soft:rgba(20,22,28,0.07);
  }
  html{-webkit-font-smoothing:antialiased;}
  body{font-family:'Inter',sans-serif; background:var(--white); color:var(--ink); margin:0;
    background-image:radial-gradient(circle at 84% 8%, rgba(168,230,58,0.13), transparent 40%),
                     radial-gradient(circle at 12% 94%, rgba(13,125,242,0.08), transparent 42%);}
  .font-display{font-family:'Schibsted Grotesk','Inter',sans-serif;}
  .mono{font-family:'JetBrains Mono',monospace;}
  ::selection{background:var(--orgy); color:var(--ink);}
  .rise{opacity:0; animation:rise .6s cubic-bezier(.16,1,.3,1) forwards;}
  @keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
  .pop{opacity:0; animation:pop .55s cubic-bezier(.34,1.4,.5,1) forwards;}
  @keyframes pop{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
  .seg{height:6px;border-radius:99px;background:var(--grey);flex:1;overflow:hidden;position:relative;}
  .seg.done::after,.seg.now::after{content:"";position:absolute;inset:0;border-radius:99px;background:var(--orgy);}
  .seg.done::after{width:100%;}
  .seg.now::after{width:100%;transform-origin:left;animation:fillseg .9s .2s cubic-bezier(.16,1,.3,1) backwards;}
  @keyframes fillseg{from{transform:scaleX(0)}to{transform:scaleX(1)}}
  .orgy{animation:cheer 4.5s ease-in-out infinite;}
  @keyframes cheer{0%,100%{transform:translateY(0) rotate(-1.5deg)}50%{transform:translateY(-13px) rotate(1.5deg)}}
  .orgy-glow{animation:breathe 4.5s ease-in-out infinite;}
  @keyframes breathe{0%,100%{opacity:.55;transform:scale(.92)}50%{opacity:1;transform:scale(1.08)}}
  .bubble{background:var(--card);border:1px solid var(--line);border-radius:16px 16px 16px 5px;
    box-shadow:0 14px 34px -16px rgba(20,22,28,.24);}
  .btn-go{background:var(--orgy);color:var(--ink);font-family:'Schibsted Grotesk',sans-serif;font-weight:800;
    border-radius:11px;transition:background .18s,transform .18s cubic-bezier(.16,1,.3,1);
    box-shadow:0 10px 24px -10px rgba(139,196,42,.85);}
  .btn-go:hover{background:var(--orgy-deep);transform:translateY(-2px);}
  .step-chip{display:inline-flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--line);
    border-radius:99px;padding:4px 12px 4px 6px;}
  .recap{display:inline-flex;align-items:center;gap:7px;background:rgba(10,157,99,0.08);
    border:1px solid rgba(10,157,99,0.22);border-radius:99px;padding:5px 12px;}
  .meet{background:var(--card);border:1px solid var(--line);border-radius:16px;
    box-shadow:0 2px 6px rgba(20,22,28,.05), 0 20px 44px -28px rgba(20,22,28,.22);}
  .ag{display:flex;align-items:center;gap:10px;padding:9px 0;border-top:1px solid var(--line-soft);}
  .agnum{width:22px;height:22px;border-radius:7px;flex:none;display:flex;align-items:center;justify-content:center;
    font-family:'JetBrains Mono',monospace;font-weight:500;font-size:11px;background:var(--grey);color:var(--ink-soft);}
  .av-stack{display:flex;}
  .av-stack > *{margin-left:-6px;box-shadow:0 0 0 2.5px var(--card);}
  .av-stack > *:first-child{margin-left:0;}
  .sav{width:27px;height:27px;border-radius:7px;flex:none;display:flex;align-items:center;justify-content:center;
    font-family:'Schibsted Grotesk',sans-serif;font-weight:800;font-size:11px;color:#fff;}
  .orgify{background:#fafbf3;border:1.5px dashed rgba(139,196,42,0.6);border-radius:14px;}
</style>

<header class="border-b border-[var(--line-soft)] bg-[var(--white)]/85 backdrop-blur-sm">
  <div class="max-w-[1080px] mx-auto px-6 h-[58px] flex items-center justify-between">
    <span class="mono font-medium text-[17px]"><span class="text-[var(--orgy-deep)]">[</span><span class="text-[var(--ink)]">OTP</span><span class="text-[var(--orgy-deep)]">]</span></span>
    <div class="flex items-center gap-4">
      <span class="mono text-[11px] tracking-[0.16em] text-[var(--ink-mute)] hidden sm:inline">SETTING UP YOUR ORG</span>
      <a href="/dashboard" class="mono text-[11px] tracking-[0.12em] text-[var(--ink-mute)] hover:text-[var(--ink)] inline-flex items-center gap-1 transition-colors">SKIP &rarr; TAKE ME IN</a>
    </div>
  </div>
  <div class="max-w-[1080px] mx-auto px-6 pb-3 -mt-1">
    <div class="flex gap-1.5">
      <span class="seg done"></span><span class="seg done"></span><span class="seg done"></span>
      <span class="seg done"></span><span class="seg done"></span><span class="seg done"></span><span class="seg now"></span>
    </div>
  </div>
</header>

<main class="max-w-[1000px] mx-auto px-6 pt-12 pb-20">
  <div class="grid lg:grid-cols-12 gap-x-10 gap-y-10 items-center">

    <div class="lg:col-span-5 relative flex flex-col items-center">
      <div class="bubble pop max-w-[315px] px-4 py-3 mb-1" style="animation-delay:.5s">
        <p class="text-[14px] leading-[1.5] text-[var(--ink)]">
          That's your whole org, on the chart. One thing left, and it's the best one. <b class="font-semibold text-[var(--green-deep)]">Let's run your first meeting.</b>
        </p>
      </div>
      <div class="relative pop" style="animation-delay:.2s">
        <div class="orgy-glow absolute left-1/2 -translate-x-1/2 bottom-3 w-[54%] h-[30%] rounded-full -z-10"
             style="background:radial-gradient(ellipse, rgba(168,230,58,0.38), transparent 70%);"></div>
        <img src="/public/images/onboarding-orgy-meeting.webp" alt="Orgy" class="orgy relative w-[340px]">
      </div>
    </div>

    <div class="lg:col-span-7">
      <div class="bg-[var(--card)] border border-[var(--line)] rounded-[20px] p-7 sm:p-9 rise"
           style="animation-delay:.32s; box-shadow:0 2px 6px rgba(20,22,28,.05), 0 26px 50px -28px rgba(20,22,28,.22);">

        <div class="flex items-center gap-2.5 flex-wrap rise" style="animation-delay:.4s">
          <div class="step-chip">
            <img src="/public/favicon-orgy.png" alt="" class="h-[22px] w-[22px]">
            <span class="mono text-[10.5px] tracking-[0.14em] text-[var(--ink-soft)] font-medium">STEP 7 OF 7 · FIRST MEETING</span>
          </div>
          <span class="recap mono text-[10.5px] tracking-[0.05em] text-[var(--green-deep)] font-medium">
            <%= ob_recap.join(' · ') %>
          </span>
        </div>

        <h1 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.05] mt-4 mb-1.5 rise"
            style="font-size:clamp(1.8rem,3.2vw,2.4rem); font-weight:800; animation-delay:.46s">
          Your org is ready. Time to meet.
        </h1>
        <p class="text-[14.5px] text-[var(--ink-soft)] leading-[1.55] mb-6 rise" style="animation-delay:.52s">
          The chart isn't the point. The meeting is. Here's the one that makes it run.
        </p>

        <div class="meet p-5 rise" style="animation-delay:.58s">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="mono text-[10px] tracking-[0.14em] text-[var(--ink-mute)] font-medium mb-1">WEEKLY MEETING</div>
              <div class="font-display font-bold text-[18px] text-[var(--ink)] leading-tight"><%= teamName %></div>
              <div class="text-[12.5px] text-[var(--ink-mute)] mt-0.5">Mondays &middot; 30 minutes &middot; same time, every week</div>
            </div>
            <% if (members.length) { %>
            <div class="av-stack pt-1">
              <% members.slice(0,5).forEach(function(m, i){ %>
                <div class="sav" style="background:<%= ob_palette[i % ob_palette.length] %>"><%= ob_initials(m.displayName) %></div>
              <% }); %>
            </div>
            <% } %>
          </div>
          <div class="mt-3">
            <div class="ag" style="border-top:none">
              <span class="agnum">1</span>
              <span class="text-[13.5px] text-[var(--ink)] font-medium">Check the scorecard</span>
              <span class="text-[12px] text-[var(--ink-mute)] ml-auto">your KPIs, green or red</span>
            </div>
            <div class="ag">
              <span class="agnum">2</span>
              <span class="text-[13.5px] text-[var(--ink)] font-medium">Review the goals</span>
              <span class="text-[12px] text-[var(--ink-mute)] ml-auto">on track or off track</span>
            </div>
            <div class="ag">
              <span class="agnum">3</span>
              <span class="text-[13.5px] text-[var(--ink)] font-medium">Work the issues list</span>
              <span class="text-[12px] text-[var(--ink-mute)] ml-auto">surface it, solve it</span>
            </div>
            <div class="ag">
              <span class="agnum">4</span>
              <span class="text-[13.5px] text-[var(--ink)] font-medium">Assign the to-dos</span>
              <span class="text-[12px] text-[var(--ink-mute)] ml-auto">a name on every one</span>
            </div>
          </div>
        </div>

        <div class="orgify flex items-start gap-3 p-4 mt-5 rise" style="animation-delay:.68s">
          <img src="/public/favicon-orgy.png" alt="" class="h-[30px] w-[30px] flex-none mt-0.5">
          <p class="text-[13px] leading-[1.55] text-[var(--ink-soft)]">
            One last thing. When the team hits something messy in that meeting, a goal with no owner, a number nobody's hitting, you
            <b class="font-semibold text-[var(--orgy-deep)]">Orgify it</b>: pull it onto the chart, give it a seat, give it a number. That's the whole game.
          </p>
        </div>

        <div class="mt-7 rise" style="animation-delay:.8s">
          <a href="/dashboard" class="btn-go inline-flex items-center gap-2 px-7 py-3.5 text-[15px]">
            Start your first meeting
            <span aria-hidden>&rarr;</span>
          </a>
          <div class="mt-3.5">
            <a href="/dashboard" class="text-[13px] text-[var(--ink-mute)] hover:text-[var(--ink)] underline underline-offset-2 transition-colors">
              Explore your chart first
            </a>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>
