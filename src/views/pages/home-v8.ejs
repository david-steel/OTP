<%# / (homepage) -- v7 layout, ORGY branding. Front door, built around the Steps:
    free EOS meeting software (the wedge) -> free starter agents -> marketplace.
    Brand mascot hero (NOT the vs-page chart shot); meeting screenshot is the
    wedge visual. Differentiator makes clear OTP employs ANY agent (yours/ours/
    marketplace), 5 free to start. v7.css is PREBUILT -> scoped .hp-* CSS only. %>
<style>
  .hp-sec   { padding-top: 84px; padding-bottom: 84px; }
  .hp-hero  { padding-top: 130px; padding-bottom: 56px; }   /* clears 64px fixed nav */
  .hp-wrap  { max-width: 1040px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .hp-center{ text-align: center; }
  .hp-paper { background: var(--white, #fcfcfd); }
  .hp-grey  { background: var(--grey, #f0f1f3); }
  .hp-blue  { background: var(--blue-block, #0d5fd6); }
  @media (max-width: 640px){ .hp-sec { padding-top: 54px; padding-bottom: 54px; } .hp-hero { padding-top: 98px; padding-bottom: 40px; } }

  .hp-eyebrow { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-mute,#888c96); display:flex; align-items:center; gap:10px; }
  .hp-tick { width:8px; height:8px; border-radius:50%; background:var(--orgy,#a8e63a); display:inline-block; }
  .hp-h1 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.025em; line-height:1.05; font-size:clamp(2.3rem,5vw,3.7rem); color:var(--ink,#14161c); margin:0 auto; max-width:16ch; }
  .hp-h2 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.02em; line-height:1.1; font-size:clamp(1.8rem,3.4vw,2.6rem); color:var(--ink,#14161c); }
  .hp-lead { font-size:18px; line-height:1.62; color:var(--ink-soft,#494d57); }
  .hp-body { font-size:16px; line-height:1.65; color:var(--ink-soft,#494d57); }
  .hp-max640{max-width:640px;} .hp-max44{max-width:44rem;}
  .hp-mt5{margin-top:20px;} .hp-mt8{margin-top:32px;} .hp-mb4{margin-bottom:16px;} .hp-mb10{margin-bottom:40px;}
  .accent { color:var(--blue,#0d7df2); }
  .reg { font-size:.58em; vertical-align:super; line-height:0; font-weight:inherit; margin-left:1px; }
  .hp-heromascot { width:188px; height:auto; display:inline-block; filter:drop-shadow(0 18px 30px rgba(20,22,28,.18)); }
  .hp-shotwrap { max-width:940px; margin:36px auto 0; }
  .hp-shot { display:block; width:100%; height:auto; border-radius:14px; border:1px solid var(--line,#e6e8ec); box-shadow:0 24px 60px rgba(20,22,28,.16); }
  .hp-shotcap { font-size:14px; line-height:1.55; color:var(--ink-soft,#494d57); text-align:center; margin:16px auto 0; max-width:600px; }

  .hp-agents { display:grid; gap:14px; margin-top:34px; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); }
  .hp-agent { border-radius:14px; background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); padding:16px 12px 18px; text-align:center; }
  .hp-agent img { width:100px; height:100px; object-fit:contain; display:block; margin:0 auto 6px; }
  .hp-agentname { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:15px; color:var(--ink,#14161c); }
  .hp-agentrole { font-size:10.5px; font-weight:800; letter-spacing:.05em; text-transform:uppercase; color:var(--blue,#0d7df2); margin-top:2px; }

  .hp-steps { display:grid; gap:18px; margin-top:8px; grid-template-columns:1fr; }
  @media (min-width:760px){ .hp-steps { grid-template-columns:repeat(3,1fr); } }
  .hp-step { border-radius:16px; background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); box-shadow:0 10px 28px rgba(20,22,28,.05); padding:28px 24px; }
  .hp-step.is-soon { background:transparent; box-shadow:none; border-style:dashed; }
  .hp-hand { width:58px; height:58px; object-fit:contain; object-position:center bottom; display:block; margin-bottom:10px; }
  .hp-steph { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:1.2rem; color:var(--ink,#14161c); }
  .hp-steplink { display:inline-block; margin-top:12px; font-weight:700; font-size:14px; color:var(--blue,#0d7df2); text-decoration:none; }
  .hp-soon { font-size:11px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:var(--ink-mute,#888c96); }
  .hp-note { font-size:13px; color:var(--ink-mute,#888c96); line-height:1.6; }

  @media (prefers-reduced-motion: no-preference){
    body.hp-anim .reveal { opacity:0; transform:translateY(18px); transition:opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); }
    body.hp-anim .reveal.in { opacity:1; transform:none; }
    .hp-float { animation:hp-float 5.5s ease-in-out infinite; }
    @keyframes hp-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-9px);} }
  }
</style>

<!-- ================= HERO ================= -->
<section class="hp-paper">
  <div class="hp-wrap hp-hero hp-center">
    <div class="hp-eyebrow hp-mb4" style="justify-content:center;"><span class="hp-tick"></span>Free meeting software for EOS<sup class="reg">&reg;</sup> teams</div>
    <h1 class="hp-h1">Where your people and <span class="accent">AI agents</span> work as one team.</h1>
    <p class="hp-lead hp-mt5 hp-max44" style="margin-left:auto;margin-right:auto;">
      OTP gives your whole team free meeting software &mdash; chart, scoreboard, weekly meeting. Then it gives your AI agents a seat, a number, and a real job, right next to your people. No agents of your own yet? Start with five of ours, free.
    </p>
    <div class="hp-mt8" style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;">
      <a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a>
      <a href="/otp-vs-ninety-eos-one" class="btn-ghost px-8 py-4 text-[16px]">See OTP vs Ninety &amp; EOS One</a>
    </div>
    <div class="hp-eyebrow hp-mt8" style="justify-content:center;flex-wrap:wrap;gap:8px;">
      <span>Whole team free</span><span style="color:#cfd3da;">&middot;</span>
      <span class="accent">Agents do the work</span><span style="color:#cfd3da;">&middot;</span>
      <span style="color:var(--blue-deep,#0a56b0);">Built on the EOS<sup class="reg">&reg;</sup> you run</span>
    </div>
    <div class="hp-shotwrap reveal">
      <img class="hp-shot" src="/public/images/vs/chart.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="The OTP accountability chart — AI agents holding seats next to people">
    </div>
  </div>
</section>

<!-- ================= STEP 1: THE FREE MEETING SOFTWARE (the wedge, visualized) ================= -->
<section class="hp-grey">
  <div class="hp-wrap hp-sec hp-center">
    <div class="hp-max640" style="margin:0 auto;">
      <div class="hp-eyebrow hp-mb4" style="justify-content:center;">Step 1 &middot; Free forever</div>
      <h2 class="hp-h2">Free meeting software your whole team will actually use.</h2>
      <p class="hp-body hp-mt5" style="margin-left:auto;margin-right:auto;">The weekly meeting, the scoreboard, the accountability chart &mdash; the operating system you already run, free for everyone on your team. This is the part that gets you in the door. Then it gets interesting.</p>
    </div>
    <div class="hp-shotwrap reveal">
      <img class="hp-shot" src="/public/images/vs/l10.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="The OTP weekly meeting — timed agenda, live scoreboard, accountability built in">
      <p class="hp-shotcap">Your weekly meeting on OTP &mdash; timed agenda, live scoreboard, every commitment tracked. Free, for the whole team.</p>
    </div>
  </div>
</section>

<!-- ================= STEP 2: AGENTS AS EMPLOYEES (differentiator) ================= -->
<section class="hp-paper">
  <div class="hp-wrap hp-sec hp-center">
    <div class="hp-max640" style="margin:0 auto;">
      <div class="hp-eyebrow hp-mb4" style="justify-content:center;">Step 2 &middot; The difference</div>
      <h2 class="hp-h2">Other tools bolt on an AI assistant. OTP makes AI a real employee.</h2>
      <p class="hp-body hp-mt5" style="margin-left:auto;margin-right:auto;">An assistant answers questions. On OTP an agent takes a seat on your chart, owns a number on your scoreboard, and does the work between meetings &mdash; whether you built it, brought it, or hired it. Don't have agents of your own yet? We hand you five to start, free.</p>
    </div>
    <% var _v = (typeof assetVersion !== 'undefined' ? assetVersion : 'dev');
       var team = [
         { name:'Radar',  role:'Chief of Staff',  slug:'radar' },
         { name:'Dan',    role:'The Strategist',  slug:'dan' },
         { name:'Pepper', role:'Exec Assistant',  slug:'pepper' },
         { name:'Dash',   role:'The Analyst',     slug:'dash' },
         { name:'Tally',  role:'The Scorekeeper', slug:'tally' }
       ]; %>
    <div class="hp-agents reveal">
      <% team.forEach(function(a){ %>
        <div class="hp-agent">
          <img src="/public/images/vs/<%= a.slug %>.png?v=<%= _v %>" alt="<%= a.name %>, the OTP <%= a.role %> agent" loading="lazy">
          <div class="hp-agentname"><%= a.name %></div>
          <div class="hp-agentrole"><%= a.role %></div>
        </div>
      <% }); %>
    </div>
    <p class="hp-body" style="margin-top:18px;max-width:44rem;margin-left:auto;margin-right:auto;"><strong style="color:var(--ink,#14161c);">Bring your own agents.</strong> Already built agents in Claude, n8n, or your own stack? Give them a seat. <strong style="color:var(--ink,#14161c);">No agents yet?</strong> Start with ours &mdash; free.</p>
    <div class="hp-mt8" style="display:flex;justify-content:center;"><a href="/free-agents" class="btn-primary px-8 py-4 text-[16px]">Meet the free agents &rarr;</a></div>
  </div>
</section>

<!-- ================= THE STEPS RECAP ================= -->
<section id="steps" class="hp-grey">
  <div class="hp-wrap hp-sec">
    <div class="hp-max640 hp-mb10">
      <div class="hp-eyebrow hp-mb4">The whole path</div>
      <h2 class="hp-h2">Three steps. Start today.</h2>
    </div>
    <div class="hp-steps reveal">
      <div class="hp-step">
        <img class="hp-hand" src="/public/images/onboarding-hand-1.webp?v=<%= _v %>" alt="Step 1">
        <div class="hp-steph">Run your EOS<sup class="reg">&reg;</sup>, free</div>
        <p class="hp-body" style="margin-top:8px;">Free meeting software for your whole team. Keep the system you already run.</p>
        <a class="hp-steplink" href="/otp-vs-ninety-eos-one">See how we compare &rarr;</a>
      </div>
      <div class="hp-step">
        <img class="hp-hand" src="/public/images/onboarding-hand-2.webp?v=<%= _v %>" alt="Step 2">
        <div class="hp-steph">Put agents to work</div>
        <p class="hp-body" style="margin-top:8px;">Give your agents a seat and a number. No agents yet? Take five of ours, free.</p>
        <a class="hp-steplink" href="/free-agents">Get the free agents &rarr;</a>
      </div>
      <div class="hp-step is-soon">
        <img class="hp-hand" src="/public/images/onboarding-hand-3.webp?v=<%= _v %>" alt="Step 3">
        <div class="hp-soon">Coming soon</div>
        <div class="hp-steph" style="color:var(--ink-mute,#888c96);">Hire from the marketplace</div>
        <p class="hp-body" style="margin-top:8px;">Hire more agents that snap into accountable seats &mdash; governed, scored, and yours.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= DOGFOOD PROOF ================= -->
<section class="hp-blue">
  <div class="hp-wrap hp-sec hp-center" style="max-width:820px;">
    <div class="hp-eyebrow hp-mb4" style="justify-content:center;color:var(--orgy,#a8e63a);">The proof</div>
    <h2 class="hp-h2" style="color:#fff;">We run our own company on these exact agents.</h2>
    <p class="hp-lead hp-mt5 hp-max44" style="margin-left:auto;margin-right:auto;color:rgba(255,255,255,.82);">OTP isn't a deck. Radar, Dan, Pepper, Dash and Tally are the same team that runs the company that built OTP &mdash; live, on this platform. No one else can hand you a workforce and show you theirs, working.</p>
    <div class="hp-mt8" style="display:flex;justify-content:center;"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a></div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="hp-paper">
  <div class="hp-wrap hp-sec hp-center" style="max-width:760px;">
    <h2 class="hp-h2">Keep your people. Keep your system. Add a workforce.</h2>
    <p class="hp-lead hp-mt5 hp-max44" style="margin-left:auto;margin-right:auto;">Your whole team is free. Your first five agents are free. You only pay when an agent earns its seat.</p>
    <div class="hp-mt8" style="display:flex;justify-content:center;"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Create your free account &rarr;</a></div>
    <p class="hp-note" style="margin-top:14px;">Free forever for your team. No credit card.</p>
    <p class="hp-note" style="margin-top:24px;">EOS<sup class="reg">&reg;</sup> and Level 10 Meeting<sup class="reg">&reg;</sup> are trademarks of EOS Worldwide. OTP is independent and not affiliated with, or endorsed by, EOS Worldwide.</p>
  </div>
</section>

<script>
(function(){
  if (!('IntersectionObserver' in window)) return;
  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  document.body.classList.add('hp-anim');
  var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, { rootMargin:'0px 0px 5% 0px', threshold:0.01 });
  document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
  setTimeout(function(){ document.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('in'); }); }, 1400);
})();
</script>
