<% /*
  /rocks/:id/smart -- the free SMART Rock Planner. v7 layout, dual-rendered
  (renderInShell): a signed-in viewer gets the app shell, a signed-out visitor
  would get the v7 compose (the route 404s the signed-out/no-org case before we
  get here, so in practice this is always authed). Laid out like David's SMART
  ROCK Planner PDF: WHO / ROCK / DUE DATE header, Describe the Rock, the five
  SMART text prompts, Milestones (reused from the existing milestones API),
  Describe your finish line, Resources Needed, Foreseen Obstacles. Save persists
  description + smartData to the rock via the PUT rocks endpoint.

  Locals: rock, milestones (array), assignablePeople, canEdit.

  Security notes (the repo's recurring EJS gotchas):
    - jsonForScript() serializes the bootstrap blob so a value containing a
      closing script tag cannot break out of the inline script context.
    - All user-supplied strings rendered server-side are HTML-escaped via the
      escaping interpolation tag. Client-built DOM sets user text via
      textContent, never innerHTML, so a hostile obstacle string is inert.
    - This header is a JS block comment, NOT an EJS hash comment, because an EJS
      hash comment closes on the first percent-gt it sees -- a tag example
      inside one would crash the parser (the May 2026 /dashboard 500 class).
  XSS guard: embed a value in an inline script tag via jsonForScript() --
  escapes < and > so a value containing a closing script tag can't break out.
*/ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%
  var _smart = (rock && rock.smartData && typeof rock.smartData === 'object') ? rock.smartData : {};
  var _due = '';
  if (rock && rock.dueDate) { try { _due = new Date(rock.dueDate).toISOString().slice(0,10); } catch (e) { _due = ''; } }
  var _ownerLabel = (rock && (rock.ownerName || rock.ownerExternalId)) || '';
  var _resources = Array.isArray(_smart.resources) ? _smart.resources : [];
  var _obstacles = Array.isArray(_smart.obstacles) ? _smart.obstacles : [];
%>
<style>
  /* SMART planner -- light, editorial, print-clean. */
  .sr-wrap { max-width: 920px; }
  .sr-card { background: var(--card, #fff); border: 1.5px solid var(--line, #e5e7eb); border-radius: 14px; }
  .sr-label { font-family: 'Schibsted Grotesk','Inter',sans-serif; font-weight: 700; font-size: 0.95rem; color: var(--ink, #1f2937); }
  .sr-hint { font-size: 12.5px; color: var(--ink-mute, #6b7280); }
  .sr-input, .sr-textarea {
    width: 100%; font-size: 14.5px; color: var(--ink, #1f2937);
    background: var(--card, #fff); border: 1.5px solid var(--line, #e5e7eb);
    border-radius: 10px; padding: 9px 12px; outline: none;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .sr-input:focus, .sr-textarea:focus { border-color: var(--blue, #0d7df2); box-shadow: 0 0 0 4px rgba(13,125,242,.12); }
  .sr-textarea { resize: vertical; min-height: 64px; line-height: 1.6; }
  .sr-input:disabled, .sr-textarea:disabled { background: var(--grey, #f3f4f6); color: var(--ink-mute, #6b7280); cursor: not-allowed; }
  .sr-smart-letter {
    width: 28px; height: 28px; border-radius: 8px; flex: none;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Schibsted Grotesk',sans-serif; font-weight: 800; font-size: 14px;
    background: var(--orgy, #ffe28a); color: var(--ink, #1f2937);
  }
  .sr-btn {
    font-size: 13px; font-weight: 600; padding: 9px 16px; border-radius: 10px;
    border: 1.5px solid transparent; cursor: pointer;
  }
  .sr-btn-primary { background: var(--blue, #0d7df2); color: #fff; }
  .sr-btn-primary:hover { background: var(--blue-deep, #0a63c2); }
  .sr-btn-primary:disabled { opacity: .5; cursor: default; }
  .sr-btn-ghost { background: var(--card, #fff); color: var(--ink-soft, #374151); border-color: var(--line, #e5e7eb); }
  .sr-btn-ghost:hover { border-color: var(--blue, #0d7df2); color: var(--ink, #1f2937); }
  .sr-list-row { display: flex; align-items: center; gap: 8px; }
  .sr-chip-del { color: #c1c8d1; font-weight: 800; cursor: pointer; border: none; background: none; font-size: 16px; line-height: 1; }
  .sr-chip-del:hover { color: #e11d48; }
  .sr-saved { font-size: 12.5px; color: #059669; font-weight: 600; }
  .sr-ms-row { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--line, #eef0f2); }
  .sr-ms-row:last-child { border-bottom: none; }

  /* AI assist (PAID upsell). Premium framing -- a subtle violet gradient card. */
  .sr-ai-card {
    border: 1.5px solid #d9caf7; border-radius: 14px; padding: 18px 20px;
    background: linear-gradient(180deg, #faf7ff 0%, #f4eeff 100%);
  }
  .sr-ai-badge {
    display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 800;
    letter-spacing: .04em; text-transform: uppercase; color: #6d28d9;
    background: #ede4ff; border: 1px solid #d9caf7; border-radius: 999px; padding: 3px 9px;
  }
  .sr-ai-title { font-family: 'Schibsted Grotesk','Inter',sans-serif; font-weight: 800; font-size: 1.02rem; color: var(--ink, #1f2937); }
  .sr-ai-btn-primary { background: #7c3aed; color: #fff; border: 1.5px solid transparent; }
  .sr-ai-btn-primary:hover { background: #6d28d9; }
  .sr-ai-btn-primary:disabled { opacity: .55; cursor: default; }
  .sr-ai-btn-ghost { background: #fff; color: #6d28d9; border: 1.5px solid #d9caf7; }
  .sr-ai-btn-ghost:hover { border-color: #7c3aed; color: #5b21b6; }
  .sr-ai-panel { margin-top: 14px; border-top: 1px dashed #d9caf7; padding-top: 14px; }
  .sr-ai-soon {
    margin-top: 14px; border: 1px solid #d9caf7; border-radius: 10px; padding: 12px 14px;
    background: #fff; font-size: 13.5px; color: var(--ink-soft, #374151);
  }
  .sr-ai-cost { font-size: 12px; color: #6d28d9; font-weight: 600; }
  .sr-crit-row { padding: 8px 0; border-bottom: 1px solid #ece3ff; font-size: 13.5px; }
  .sr-crit-row:last-child { border-bottom: none; }
  .sr-crit-sev { display: inline-block; font-size: 11px; font-weight: 800; text-transform: uppercase; border-radius: 6px; padding: 1px 7px; margin-right: 7px; }
  .sr-crit-weak { background: #fef3c7; color: #92400e; }
  .sr-crit-missing { background: #fee2e2; color: #991b1b; }
  .sr-crit-ok { background: #dcfce7; color: #166534; }
  @media print { .sr-ai-card { display: none !important; } }

  /* Print: hide chrome, black on white, prints like the PDF planner. */
  @media print {
    .no-print { display: none !important; }
    body { background: #fff !important; }
    .sr-card { border-color: #000 !important; box-shadow: none !important; break-inside: avoid; }
    .sr-input, .sr-textarea { border-color: #999 !important; color: #000 !important; background: #fff !important; }
    .sr-smart-letter { background: #fff !important; border: 1.5px solid #000; color: #000 !important; }
    .sr-label, .sr-hint, .sr-input, .sr-textarea { color: #000 !important; }
    a[href]:after { content: ""; }
  }
</style>

<section class="bg-[var(--white)]">
  <div class="sr-wrap mx-auto px-6 pt-[124px] pb-12 sm:pt-[148px]"<%- (typeof authUserId !== 'undefined' && authUserId) ? ' style="padding-top:56px;"' : '' %> data-rock-id="<%= rock.id %>">

    <!-- Top bar: back + print/save (no-print). -->
    <div class="no-print flex items-center justify-between gap-3 mb-6">
      <a href="/dashboard#rocks" class="text-[13px] font-semibold text-[var(--ink-soft)] hover:text-[var(--ink)]">&larr; Back to dashboard</a>
      <div class="flex items-center gap-2">
        <span id="sr-saved" class="sr-saved" style="display:none;">Saved</span>
        <button type="button" id="sr-print" class="sr-btn sr-btn-ghost">Print</button>
        <% if (canEdit) { %><button type="button" id="sr-save" class="sr-btn sr-btn-primary">Save</button><% } %>
      </div>
    </div>

    <% if (!canEdit) { %>
      <div class="no-print sr-card px-4 py-3 mb-6 text-[13px] text-[var(--ink-soft)]" style="background:var(--grey,#f3f4f6);">
        You have view-only access. This planner is read-only for your role.
      </div>
    <% } %>

    <h1 class="font-bold text-[1.9rem] tracking-[-0.02em] text-[var(--ink)]" style="font-family:'Schibsted Grotesk','Inter',sans-serif;">SMART Rock Planner</h1>
    <p class="sr-hint mt-1">Sharpen one quarterly priority into a SMART commitment. Print it, pin it, work it.</p>

    <!-- Header: WHO / ROCK / DUE DATE -->
    <div class="sr-card p-5 sm:p-6 mt-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto]">
        <div>
          <label class="sr-label" for="sr-title">Rock</label>
          <input id="sr-title" class="sr-input mt-1.5" type="text" value="<%= rock.title %>" maxlength="500" <%= canEdit ? '' : 'disabled' %> placeholder="What is the priority?">
        </div>
        <div>
          <label class="sr-label" for="sr-due">Due date</label>
          <input id="sr-due" class="sr-input mt-1.5" type="date" value="<%= _due %>" <%= canEdit ? '' : 'disabled' %>>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-[1fr_auto] mt-4">
        <div>
          <label class="sr-label" for="sr-owner">Who (owner)</label>
          <% if (canEdit && (assignablePeople || []).length > 0) { %>
            <select id="sr-owner" class="sr-input mt-1.5">
              <option value="">&mdash; owner &mdash;</option>
              <% (assignablePeople || []).forEach(function(p){ %>
                <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>" <%= p.externalId === rock.ownerExternalId ? 'selected' : '' %>><%= p.name %></option>
              <% }); %>
            </select>
          <% } else { %>
            <input class="sr-input mt-1.5" type="text" value="<%= _ownerLabel %>" disabled>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Describe the Rock -> rocks.description -->
    <div class="sr-card p-5 sm:p-6 mt-5">
      <label class="sr-label" for="sr-description">Describe the Rock</label>
      <p class="sr-hint mt-0.5">In a sentence or two, what does done look like?</p>
      <textarea id="sr-description" class="sr-textarea mt-2" maxlength="5000" <%= canEdit ? '' : 'disabled' %> placeholder="Describe the priority and why it matters this quarter..."><%= rock.description || '' %></textarea>
    </div>

    <!-- AI assist (PAID upsell, Phase 3). Hidden for read-only roles (the
         assist edits the form). Ships gated OFF -> "coming soon" panel, no API
         call. The live flag + endpoints are gated in rock-ai.ts as well. -->
    <% if (canEdit) { %>
    <div class="sr-ai-card no-print mt-5" id="sr-ai-card">
      <div class="flex items-start justify-between gap-3 flex-wrap">
        <div>
          <span class="sr-ai-badge">&#10024; AI</span>
          <div class="sr-ai-title mt-1.5">Let AI draft your SMART Rock</div>
          <p class="sr-hint mt-0.5" style="max-width:520px;">Describe your goal in one sentence and OTP drafts the full SMART Rock, milestones and all, then flags any weak spots. A premium add-on.</p>
        </div>
        <div class="flex items-center gap-2 flex-none">
          <button type="button" id="sr-ai-draft-btn" class="sr-btn sr-ai-btn-primary">&#10024; Draft with AI</button>
          <button type="button" id="sr-ai-critique-btn" class="sr-btn sr-ai-btn-ghost">Critique my Rock</button>
        </div>
      </div>
      <div id="sr-ai-panel"></div>
    </div>
    <% } %>

    <!-- Is my Rock SMART? Five free-text prompts -> smart_data -->
    <div class="sr-card p-5 sm:p-6 mt-5">
      <h2 class="sr-label" style="font-size:1.05rem;">Is my Rock SMART?</h2>
      <p class="sr-hint mt-0.5 mb-3">Answer each prompt. These are the heart of the planner.</p>

      <div class="space-y-4">
        <div class="flex gap-3">
          <div class="sr-smart-letter">S</div>
          <div class="flex-1">
            <label class="sr-label" for="sr-specific">Specific</label>
            <p class="sr-hint">What specifically will I achieve?</p>
            <textarea id="sr-specific" class="sr-textarea mt-1.5" maxlength="4000" <%= canEdit ? '' : 'disabled' %>><%= _smart.specific || '' %></textarea>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="sr-smart-letter">M</div>
          <div class="flex-1">
            <label class="sr-label" for="sr-measurable">Measurable</label>
            <p class="sr-hint">How will I measure completion?</p>
            <textarea id="sr-measurable" class="sr-textarea mt-1.5" maxlength="4000" <%= canEdit ? '' : 'disabled' %>><%= _smart.measurable || '' %></textarea>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="sr-smart-letter">A</div>
          <div class="flex-1">
            <label class="sr-label" for="sr-attainable">Attainable</label>
            <p class="sr-hint">Can I get it done with the time and resources I have?</p>
            <textarea id="sr-attainable" class="sr-textarea mt-1.5" maxlength="4000" <%= canEdit ? '' : 'disabled' %>><%= _smart.attainable || '' %></textarea>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="sr-smart-letter">R</div>
          <div class="flex-1">
            <label class="sr-label" for="sr-relevant">Relevant</label>
            <p class="sr-hint">Is it tied to our 1-year plan?</p>
            <textarea id="sr-relevant" class="sr-textarea mt-1.5" maxlength="4000" <%= canEdit ? '' : 'disabled' %>><%= _smart.relevant || '' %></textarea>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="sr-smart-letter">T</div>
          <div class="flex-1">
            <label class="sr-label" for="sr-timeFramed">Time-framed</label>
            <p class="sr-hint">Key dates along the way and the final date.</p>
            <textarea id="sr-timeFramed" class="sr-textarea mt-1.5" maxlength="4000" <%= canEdit ? '' : 'disabled' %>><%= _smart.timeFramed || '' %></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- Milestones: reuse the existing rock_milestones API. -->
    <div class="sr-card p-5 sm:p-6 mt-5" id="sr-ms-card">
      <h2 class="sr-label" style="font-size:1.05rem;">Milestones</h2>
      <p class="sr-hint mt-0.5 mb-3">First step, mid steps, and the finish line. Check off as you go.</p>
      <div id="sr-ms-list"></div>
      <% if (canEdit) { %>
      <form id="sr-ms-add" class="no-print flex flex-wrap items-center gap-2 mt-3">
        <input type="text" name="title" required maxlength="255" placeholder="+ milestone (e.g. First step)" class="sr-input" style="flex:1 1 200px;">
        <input type="date" name="dueDate" class="sr-input" style="flex:0 0 auto; width:auto;" title="By date (optional)">
        <button type="submit" class="sr-btn sr-btn-primary">Add</button>
      </form>
      <% } %>
    </div>

    <!-- Describe your finish line -> smart_data.finishLine -->
    <div class="sr-card p-5 sm:p-6 mt-5">
      <label class="sr-label" for="sr-finishLine">Describe your finish line</label>
      <p class="sr-hint mt-0.5">When this is unmistakably done, what is true?</p>
      <textarea id="sr-finishLine" class="sr-textarea mt-2" maxlength="2000" <%= canEdit ? '' : 'disabled' %> placeholder="The moment I know this Rock is complete..."><%= _smart.finishLine || '' %></textarea>
    </div>

    <!-- Resources Needed -> smart_data.resources[] -->
    <div class="sr-card p-5 sm:p-6 mt-5">
      <h2 class="sr-label" style="font-size:1.05rem;">Resources Needed</h2>
      <p class="sr-hint mt-0.5 mb-3">People, tools, budget, or information this Rock depends on.</p>
      <div id="sr-resources"></div>
      <% if (canEdit) { %>
      <form id="sr-resources-add" class="no-print flex items-center gap-2 mt-3">
        <input type="text" name="item" maxlength="500" placeholder="+ resource" class="sr-input" style="flex:1;">
        <button type="submit" class="sr-btn sr-btn-ghost">Add</button>
      </form>
      <% } %>
    </div>

    <!-- Foreseen Obstacles -> smart_data.obstacles[] -->
    <div class="sr-card p-5 sm:p-6 mt-5">
      <h2 class="sr-label" style="font-size:1.05rem;">Foreseen Obstacles</h2>
      <p class="sr-hint mt-0.5 mb-3">What could get in the way, so you can plan around it now.</p>
      <div id="sr-obstacles"></div>
      <% if (canEdit) { %>
      <form id="sr-obstacles-add" class="no-print flex items-center gap-2 mt-3">
        <input type="text" name="item" maxlength="500" placeholder="+ obstacle" class="sr-input" style="flex:1;">
        <button type="submit" class="sr-btn sr-btn-ghost">Add</button>
      </form>
      <% } %>
    </div>

    <% if (canEdit) { %>
    <div class="no-print flex items-center justify-end gap-2 mt-6">
      <span id="sr-saved-2" class="sr-saved" style="display:none;">Saved</span>
      <button type="button" id="sr-save-2" class="sr-btn sr-btn-primary">Save SMART Rock</button>
    </div>
    <% } %>
  </div>
</section>

<script>
(function(){
  var ROCK_ID = <%- jsonForScript(rock.id) %>;
  var CAN_EDIT = <%- jsonForScript(!!canEdit) %>;
  var MILESTONES = <%- jsonForScript(milestones || []) %>;
  var RESOURCES = <%- jsonForScript(_resources) %>;
  var OBSTACLES = <%- jsonForScript(_obstacles) %>;
  // AI assist launch gate. false (default) = "coming soon" -- no API call.
  var AI_LIVE = <%- jsonForScript(typeof aiRockAssistLive !== 'undefined' ? !!aiRockAssistLive : false) %>;

  // ---- API helper (cookie auth, same pattern as the dashboard) ----
  function api(method, path, body){
    var opts = { method: method, headers: {}, credentials: 'same-origin' };
    if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
    return fetch('/api/v1' + path, opts).then(function(r){
      if (!r.ok) {
        return r.text().then(function(text){
          var j = {}; try { j = text ? JSON.parse(text) : {}; } catch(e){}
          var inner = j.error || {};
          throw { status: r.status, code: inner.code || 'API_ERROR', message: inner.message || ('HTTP ' + r.status) };
        });
      }
      return r.status === 204 ? {} : r.json();
    });
  }
  function fmtErr(e){ return e ? ((e.code ? e.code + ': ' : '') + (e.message || 'error')) : 'Unknown error'; }
  function $(id){ return document.getElementById(id); }

  // ---- Save state flash ----
  function flashSaved(){
    [$('sr-saved'), $('sr-saved-2')].forEach(function(el){
      if (!el) return; el.style.display = 'inline'; el.textContent = 'Saved';
      setTimeout(function(){ el.style.display = 'none'; }, 2000);
    });
  }

  // ---- Resources / Obstacles add-lists (client-managed, persisted on Save) ----
  // Rendered via textContent so user strings can never inject markup.
  function renderList(hostId, arr){
    var host = $(hostId); if (!host) return;
    host.innerHTML = '';
    if (!arr.length) {
      var empty = document.createElement('p');
      empty.className = 'sr-hint'; empty.textContent = 'None added yet.';
      host.appendChild(empty); return;
    }
    arr.forEach(function(val, i){
      var row = document.createElement('div'); row.className = 'sr-list-row';
      var dot = document.createElement('span'); dot.textContent = '•';
      dot.style.color = 'var(--ink-mute,#6b7280)'; row.appendChild(dot);
      var span = document.createElement('span');
      span.style.flex = '1'; span.style.fontSize = '14px'; span.textContent = val;
      row.appendChild(span);
      if (CAN_EDIT) {
        var del = document.createElement('button');
        del.type = 'button'; del.className = 'sr-chip-del no-print';
        del.setAttribute('aria-label', 'Remove'); del.textContent = '×';
        del.addEventListener('click', function(){ arr.splice(i, 1); renderList(hostId, arr); });
        row.appendChild(del);
      }
      host.appendChild(row);
    });
  }
  function wireAddList(formId, arr, hostId){
    var form = $(formId); if (!form) return;
    form.addEventListener('submit', function(e){
      e.preventDefault();
      var input = form.querySelector('input[name="item"]');
      var v = (input.value || '').trim();
      if (!v) return;
      if (arr.length >= 30) { alert('Up to 30 items.'); return; }
      arr.push(v); input.value = ''; renderList(hostId, arr);
    });
  }
  renderList('sr-resources', RESOURCES);
  renderList('sr-obstacles', OBSTACLES);
  wireAddList('sr-resources-add', RESOURCES, 'sr-resources');
  wireAddList('sr-obstacles-add', OBSTACLES, 'sr-obstacles');

  // ---- Milestones (reuse the existing milestones API) ----
  function fmtDate(d){ return d ? String(d).slice(0,10) : ''; }
  function todayStr(){
    var n = new Date();
    return n.getFullYear() + '-' + String(n.getMonth()+1).padStart(2,'0') + '-' + String(n.getDate()).padStart(2,'0');
  }
  function renderMilestones(){
    var host = $('sr-ms-list'); if (!host) return;
    host.innerHTML = '';
    if (!MILESTONES.length) {
      var empty = document.createElement('p');
      empty.className = 'sr-hint'; empty.textContent = 'No milestones yet. Add the first step below.';
      host.appendChild(empty); return;
    }
    var today = todayStr();
    MILESTONES.forEach(function(m){
      var row = document.createElement('div'); row.className = 'sr-ms-row'; row.setAttribute('data-ms-id', m.id);

      var cb = document.createElement('input');
      cb.type = 'checkbox'; cb.className = 'no-print'; cb.style.accentColor = '#059669';
      cb.checked = !!m.completedAt; cb.disabled = !CAN_EDIT;
      cb.addEventListener('change', function(){
        var checked = cb.checked;
        api('POST', '/milestones/' + m.id + '/complete', { completed: checked })
          .then(function(res){ m.completedAt = (res.milestone && res.milestone.completedAt) || (checked ? new Date().toISOString() : null); renderMilestones(); })
          .catch(function(e){ cb.checked = !checked; alert('Milestone update failed: ' + fmtErr(e)); });
      });
      row.appendChild(cb);

      var title = document.createElement('span');
      title.style.flex = '1'; title.style.fontSize = '14px';
      title.textContent = m.title;
      if (m.completedAt) { title.style.textDecoration = 'line-through'; title.style.color = 'var(--ink-mute,#9ca3af)'; }
      row.appendChild(title);

      var due = fmtDate(m.dueDate);
      var dueEl = document.createElement('span');
      dueEl.style.fontSize = '12px'; dueEl.style.flex = 'none';
      if (due) {
        dueEl.textContent = 'by ' + due;
        var overdue = !m.completedAt && due < today;
        dueEl.style.color = overdue ? '#e11d48' : 'var(--ink-mute,#9ca3af)';
        if (overdue) dueEl.style.fontWeight = '600';
      } else {
        dueEl.textContent = m.completedAt ? ('done ' + fmtDate(m.completedAt)) : '';
        dueEl.style.color = 'var(--ink-mute,#9ca3af)';
      }
      row.appendChild(dueEl);

      if (CAN_EDIT) {
        var del = document.createElement('button');
        del.type = 'button'; del.className = 'sr-chip-del no-print';
        del.setAttribute('aria-label', 'Delete milestone'); del.textContent = '×';
        del.title = 'Delete milestone (its to-dos survive)';
        del.addEventListener('click', function(){
          if (!confirm('Delete this milestone? Its to-dos survive, unlinked.')) return;
          api('DELETE', '/milestones/' + m.id)
            .then(function(){ MILESTONES = MILESTONES.filter(function(x){ return x.id !== m.id; }); renderMilestones(); })
            .catch(function(e){ alert('Delete failed: ' + fmtErr(e)); });
        });
        row.appendChild(del);
      }
      host.appendChild(row);
    });
  }
  renderMilestones();

  var msAdd = $('sr-ms-add');
  if (msAdd) {
    msAdd.addEventListener('submit', function(e){
      e.preventDefault();
      var titleEl = msAdd.querySelector('input[name="title"]');
      var dueEl = msAdd.querySelector('input[name="dueDate"]');
      var title = (titleEl.value || '').trim();
      if (!title) return;
      var body = { title: title };
      if (dueEl.value) body.dueDate = dueEl.value;
      api('POST', '/rocks/' + ROCK_ID + '/milestones', body)
        .then(function(res){ if (res.milestone) MILESTONES.push(res.milestone); titleEl.value = ''; dueEl.value = ''; renderMilestones(); })
        .catch(function(e){ alert('Add milestone failed: ' + fmtErr(e)); });
    });
  }

  // ---- Save: description + title + dueDate + owner + smartData ----
  function collectSmart(){
    function val(id){ var el = $(id); return el && el.value.trim() ? el.value : undefined; }
    var out = {
      specific: val('sr-specific'),
      measurable: val('sr-measurable'),
      attainable: val('sr-attainable'),
      relevant: val('sr-relevant'),
      timeFramed: val('sr-timeFramed'),
      finishLine: val('sr-finishLine'),
    };
    if (RESOURCES.length) out.resources = RESOURCES.slice();
    if (OBSTACLES.length) out.obstacles = OBSTACLES.slice();
    return out;
  }
  function doSave(btn){
    if (!CAN_EDIT) return;
    var titleEl = $('sr-title');
    var title = (titleEl.value || '').trim();
    if (title.length < 3) { alert('Rock title must be at least 3 characters.'); return; }
    var body = {
      title: title,
      description: $('sr-description').value,
      smartData: collectSmart(),
    };
    var dueEl = $('sr-due');
    if (dueEl.value) {
      // The rocks API wants an ISO datetime; anchor the date at midnight UTC.
      body.dueDate = new Date(dueEl.value + 'T00:00:00.000Z').toISOString();
    }
    var ownerEl = $('sr-owner');
    if (ownerEl && ownerEl.value) {
      var p = ownerEl.value.split(':');
      body.ownerEntityType = p[0] || undefined;
      body.ownerExternalId = p[1] || undefined;
      body.ownerName = p.slice(2).join(':') || undefined;
    }
    var buttons = [$('sr-save'), $('sr-save-2')].filter(Boolean);
    buttons.forEach(function(b){ b.disabled = true; });
    api('PUT', '/rocks/' + ROCK_ID, body)
      .then(function(){ flashSaved(); })
      .catch(function(e){ alert('Save failed: ' + fmtErr(e)); })
      .then(function(){ buttons.forEach(function(b){ b.disabled = false; }); });
  }
  [$('sr-save'), $('sr-save-2')].forEach(function(b){ if (b) b.addEventListener('click', function(){ doSave(b); }); });

  // ---- AI assist (PAID upsell) ----
  // All AI strings are rendered via textContent, never innerHTML, so a hostile
  // model/string can never inject markup (same discipline as the lists above).
  var aiPanel = $('sr-ai-panel');
  var aiDraftBtn = $('sr-ai-draft-btn');
  var aiCritiqueBtn = $('sr-ai-critique-btn');

  function aiClearPanel(){ if (aiPanel) aiPanel.innerHTML = ''; }
  function aiBusy(busy){
    [aiDraftBtn, aiCritiqueBtn].forEach(function(b){ if (b) b.disabled = busy; });
  }
  function aiCostLine(costCents){
    var p = document.createElement('div');
    p.className = 'sr-ai-cost'; p.style.marginTop = '8px';
    var cents = (typeof costCents === 'number') ? costCents : 0;
    p.textContent = 'This used ' + cents + ' credit' + (cents === 1 ? '' : 's') + '.';
    return p;
  }
  function aiNote(text){
    var p = document.createElement('p');
    p.className = 'sr-hint'; p.style.marginTop = '4px'; p.textContent = text;
    return p;
  }

  // Coming-soon panel (default state, no API call).
  function showComingSoon(){
    aiClearPanel(); if (!aiPanel) return;
    var box = document.createElement('div'); box.className = 'sr-ai-soon';
    var t = document.createElement('div');
    t.style.fontWeight = '700'; t.textContent = '✨ AI Rock drafting is coming soon.';
    var d = aiNote('Describe your goal in a sentence and OTP will draft your full SMART Rock and flag weak spots. We’ll let you know the moment it’s live.');
    box.appendChild(t); box.appendChild(d);
    var ok = document.createElement('button');
    ok.type = 'button'; ok.className = 'sr-btn sr-ai-btn-ghost'; ok.style.marginTop = '10px';
    ok.textContent = 'OK'; ok.addEventListener('click', aiClearPanel);
    box.appendChild(ok);
    aiPanel.appendChild(box);
  }

  // Handle an error from an AI endpoint with a graceful, on-brand message.
  function aiHandleError(e){
    aiClearPanel(); if (!aiPanel) return;
    var box = document.createElement('div'); box.className = 'sr-ai-soon';
    var code = e && e.code;
    if (code === 'COMING_SOON') { showComingSoon(); return; }
    if (code === 'INSUFFICIENT_BALANCE') {
      box.appendChild(aiNote('You’re out of AI credits. Add credits to use AI assist.'));
      var link = document.createElement('a');
      link.href = '/settings/billing'; link.className = 'sr-btn sr-ai-btn-primary';
      link.style.marginTop = '10px'; link.style.display = 'inline-block'; link.style.textDecoration = 'none';
      link.textContent = 'Add credits';
      box.appendChild(link);
    } else if (code === 'NOT_CONFIGURED') {
      box.appendChild(aiNote('AI assist isn’t available right now. Please try again later.'));
    } else {
      box.appendChild(aiNote('AI assist failed: ' + fmtErr(e)));
    }
    aiPanel.appendChild(box);
  }

  // ---- Draft: one sentence -> populate the whole form ----
  function showDraftInput(){
    aiClearPanel(); if (!aiPanel) return;
    var wrap = document.createElement('div'); wrap.className = 'sr-ai-panel';
    var label = document.createElement('label');
    label.className = 'sr-label'; label.setAttribute('for', 'sr-ai-sentence');
    label.textContent = 'Describe your Rock in one sentence';
    var input = document.createElement('input');
    input.id = 'sr-ai-sentence'; input.className = 'sr-input'; input.style.marginTop = '8px';
    input.type = 'text'; input.maxLength = 500;
    input.placeholder = 'e.g. By end of Q3, lift our qualified-lead close rate from 12% to 20%.';
    var row = document.createElement('div');
    row.style.display = 'flex'; row.style.gap = '8px'; row.style.marginTop = '10px'; row.style.flexWrap = 'wrap';
    var go = document.createElement('button');
    go.type = 'button'; go.className = 'sr-btn sr-ai-btn-primary'; go.textContent = '✨ Generate draft';
    var cancel = document.createElement('button');
    cancel.type = 'button'; cancel.className = 'sr-btn sr-ai-btn-ghost'; cancel.textContent = 'Cancel';
    cancel.addEventListener('click', aiClearPanel);
    row.appendChild(go); row.appendChild(cancel);
    wrap.appendChild(label); wrap.appendChild(input); wrap.appendChild(row);
    aiPanel.appendChild(wrap);
    input.focus();

    function submit(){
      var sentence = (input.value || '').trim();
      if (sentence.length < 8) { alert('Describe your Rock in at least a sentence.'); return; }
      aiBusy(true); go.disabled = true; go.textContent = 'Drafting…';
      api('POST', '/rocks/' + ROCK_ID + '/ai/draft', { sentence: sentence })
        .then(function(res){ applyDraft(res.draft, res.costCents); })
        .catch(aiHandleError)
        .then(function(){ aiBusy(false); });
    }
    go.addEventListener('click', submit);
    input.addEventListener('keydown', function(ev){ if (ev.key === 'Enter') { ev.preventDefault(); submit(); } });
  }

  // Fill the form from a validated draft. The user reviews + Saves via the
  // existing Save button -- the draft does NOT auto-persist.
  function applyDraft(draft, costCents){
    if (!draft) { aiClearPanel(); return; }
    function set(id, v){ var el = $(id); if (el && typeof v === 'string') el.value = v; }
    set('sr-title', draft.title);
    set('sr-description', draft.description);
    set('sr-specific', draft.specific);
    set('sr-measurable', draft.measurable);
    set('sr-attainable', draft.attainable);
    set('sr-relevant', draft.relevant);
    set('sr-timeFramed', draft.timeFramed);
    set('sr-finishLine', draft.finishLine);

    aiClearPanel();
    if (!aiPanel) return;
    var box = document.createElement('div'); box.className = 'sr-ai-soon';
    var t = document.createElement('div');
    t.style.fontWeight = '700'; t.textContent = '✨ Draft ready — review and Save.';
    box.appendChild(t);
    box.appendChild(aiNote('We filled in the fields below. Edit anything, then hit Save to keep it.'));

    // Suggested milestones (the draft does not create them; the user adds the
    // ones they want via the milestone form). List them as suggestions.
    if (Array.isArray(draft.milestones) && draft.milestones.length) {
      var msTitle = document.createElement('div');
      msTitle.className = 'sr-label'; msTitle.style.fontSize = '0.9rem'; msTitle.style.marginTop = '10px';
      msTitle.textContent = 'Suggested milestones';
      box.appendChild(msTitle);
      draft.milestones.forEach(function(m){
        if (!m || typeof m.title !== 'string') return;
        var row = document.createElement('div'); row.className = 'sr-crit-row';
        var span = document.createElement('span'); span.textContent = m.title + (m.dueDate ? ' — by ' + m.dueDate : '');
        row.appendChild(span);
        var add = document.createElement('button');
        add.type = 'button'; add.className = 'sr-chip-del'; add.style.color = '#7c3aed'; add.style.fontSize = '13px';
        add.textContent = '+ add'; add.style.marginLeft = '8px';
        add.addEventListener('click', function(){
          var body = { title: m.title }; if (m.dueDate) body.dueDate = m.dueDate;
          api('POST', '/rocks/' + ROCK_ID + '/milestones', body)
            .then(function(r){ if (r.milestone) { MILESTONES.push(r.milestone); renderMilestones(); } add.disabled = true; add.textContent = 'added'; })
            .catch(function(e){ alert('Add milestone failed: ' + fmtErr(e)); });
        });
        row.appendChild(add);
        box.appendChild(row);
      });
    }
    box.appendChild(aiCostLine(costCents));
    aiPanel.appendChild(box);
  }

  // ---- Critique: review the stored Rock field by field ----
  function runCritique(){
    aiBusy(true);
    aiClearPanel();
    if (aiPanel) aiPanel.appendChild(aiNote('Reviewing your Rock…'));
    api('POST', '/rocks/' + ROCK_ID + '/ai/critique', {})
      .then(function(res){ showCritique(res.critique, res.costCents); })
      .catch(aiHandleError)
      .then(function(){ aiBusy(false); });
  }
  function showCritique(crit, costCents){
    aiClearPanel(); if (!aiPanel || !crit) return;
    var box = document.createElement('div'); box.className = 'sr-ai-soon';
    var t = document.createElement('div');
    t.style.fontWeight = '700'; t.textContent = 'Critique';
    box.appendChild(t);
    if (typeof crit.overall === 'string' && crit.overall) box.appendChild(aiNote(crit.overall));
    (crit.critiques || []).forEach(function(c){
      if (!c || typeof c.field !== 'string') return;
      var row = document.createElement('div'); row.className = 'sr-crit-row';
      var sev = document.createElement('span');
      var sevClass = c.severity === 'missing' ? 'sr-crit-missing' : (c.severity === 'ok' ? 'sr-crit-ok' : 'sr-crit-weak');
      sev.className = 'sr-crit-sev ' + sevClass; sev.textContent = c.severity || 'weak';
      row.appendChild(sev);
      var field = document.createElement('strong'); field.textContent = c.field + ': '; row.appendChild(field);
      var issue = document.createElement('span'); issue.textContent = c.issue || ''; row.appendChild(issue);
      if (c.suggestion) {
        var sug = document.createElement('div');
        sug.className = 'sr-hint'; sug.style.marginTop = '2px'; sug.textContent = 'Fix: ' + c.suggestion;
        row.appendChild(sug);
      }
      box.appendChild(row);
    });
    box.appendChild(aiCostLine(costCents));
    aiPanel.appendChild(box);
  }

  if (aiDraftBtn) aiDraftBtn.addEventListener('click', function(){ if (!AI_LIVE) { showComingSoon(); return; } showDraftInput(); });
  if (aiCritiqueBtn) aiCritiqueBtn.addEventListener('click', function(){ if (!AI_LIVE) { showComingSoon(); return; } runCritique(); });

  // ---- Print ----
  var printBtn = $('sr-print');
  if (printBtn) printBtn.addEventListener('click', function(){ window.print(); });
})();
</script>
