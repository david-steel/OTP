<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold">Admin Dashboard</h1>
      <p class="text-gray-500 text-sm">Platform-wide stats and management.</p>
    </div>
    <span class="px-3 py-1 bg-red-100 text-red-700 text-xs font-bold rounded-full uppercase">Super Admin</span>
  </div>

  <!-- Quick links: two menus -- Super Admin (platform tools) + Org Admin
       (this org's pages). Collapsed from two crowded chip rows into dropdowns. -->
  <div class="mb-8 flex flex-wrap items-center gap-2 text-xs">
    <div class="adm-dd relative" data-dd>
      <button type="button" data-dd-toggle aria-haspopup="true" aria-expanded="false"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-50 text-red-700 border border-red-200 rounded-lg font-semibold hover:bg-red-100 transition-colors">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
        Super Admin
        <svg class="adm-chev w-3 h-3 text-red-400 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-dd-menu hidden role="menu" class="absolute left-0 mt-1.5 min-w-[220px] bg-white border border-gray-200 rounded-lg shadow-lg p-1 z-50">
        <a href="/admin/health" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-red-50 hover:text-red-700">Funnel + Email Health</a>
        <a href="/admin/improvements" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-red-50 hover:text-red-700">Improvements / Roadmap</a>
        <a href="/admin/subscribers" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-red-50 hover:text-red-700">Pre-Signup Subscribers</a>
        <a href="/admin/partners?key=otp-founding-2026" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-red-50 hover:text-red-700">Partner Applications</a>
        <div class="h-px bg-gray-100 my-1"></div>
        <a href="/admin/users.csv" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-gray-100">Users CSV</a>
        <a href="/tickets" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-gray-100">Issue Tracker</a>
        <a href="/whats-new" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-gray-100">What's New</a>
      </div>
    </div>

    <div class="adm-dd relative" data-dd>
      <button type="button" data-dd-toggle aria-haspopup="true" aria-expanded="false"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-otp-50 text-otp-700 border border-otp-200 rounded-lg font-semibold hover:bg-otp-100 transition-colors">
        <span class="w-1.5 h-1.5 rounded-full bg-otp-500"></span>
        Org Admin
        <svg class="adm-chev w-3 h-3 text-otp-400 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-dd-menu hidden role="menu" class="absolute left-0 mt-1.5 min-w-[220px] bg-white border border-gray-200 rounded-lg shadow-lg p-1 z-50">
        <a href="/dashboard" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">Dashboard</a>
        <a href="/dashboard/team" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">Team Chart</a>
        <a href="/dashboard/members" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">Members</a>
        <a href="/admin/skills" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">Skills Inventory</a>
        <a href="/dashboard/kpis" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">KPIs</a>
        <a href="/dashboard/oos-operating-plan" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">OOS Operating Plan</a>
        <a href="/l8" role="menuitem" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-otp-50 hover:text-otp-700">L8 Meetings</a>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function closeAll() {
        document.querySelectorAll('.adm-dd').forEach(function(dd) {
          dd.removeAttribute('data-open');
          var m = dd.querySelector('[data-dd-menu]'); if (m) m.hidden = true;
          var t = dd.querySelector('[data-dd-toggle]'); if (t) t.setAttribute('aria-expanded', 'false');
          var c = dd.querySelector('.adm-chev'); if (c) c.style.transform = '';
        });
      }
      document.querySelectorAll('.adm-dd [data-dd-toggle]').forEach(function(t) {
        t.addEventListener('click', function(e) {
          e.stopPropagation();
          var dd = t.closest('.adm-dd');
          var open = dd.hasAttribute('data-open');
          closeAll();
          if (!open) {
            dd.setAttribute('data-open', '');
            var m = dd.querySelector('[data-dd-menu]'); if (m) m.hidden = false;
            t.setAttribute('aria-expanded', 'true');
            var c = dd.querySelector('.adm-chev'); if (c) c.style.transform = 'rotate(180deg)';
          }
        });
      });
      document.addEventListener('click', closeAll);
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeAll(); });
    })();
  </script>

  <!-- Two goals scoreboard: USERS and USAGE -->
  <div class="mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-sm font-semibold uppercase text-gray-600 tracking-wide">The two goals: users and usage</h2>
      <span class="text-xs text-gray-400">goal: 50 users</span>
    </div>
    <div class="grid grid-cols-5 gap-3">
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-3xl font-bold text-otp-600"><%= userStats.total %></div>
        <div class="text-xs text-gray-500 mt-1">Users</div>
        <div class="text-xs text-gray-400 mt-1"><%= 50 - userStats.total %> to goal</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-3xl font-bold <%= userStats.returned > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= userStats.returned %></div>
        <div class="text-xs text-gray-500 mt-1">Returned</div>
        <div class="text-xs text-gray-400 mt-1">signed in again</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-3xl font-bold <%= userStats.withOrg > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= userStats.withOrg %></div>
        <div class="text-xs text-gray-500 mt-1">Has Org</div>
        <div class="text-xs text-gray-400 mt-1">created workspace</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-3xl font-bold <%= userStats.mcpActive > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= userStats.mcpActive %></div>
        <div class="text-xs text-gray-500 mt-1">Using MCP</div>
        <div class="text-xs text-gray-400 mt-1">called API</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-3xl font-bold <%= userStats.publishers > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= userStats.publishers %></div>
        <div class="text-xs text-gray-500 mt-1">Published</div>
        <div class="text-xs text-gray-400 mt-1">shipped an OOS</div>
      </div>
    </div>
  </div>

  <!-- Users table -->
  <div class="mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="font-semibold">Users (<%= users.length %>)</h3>
      <a href="/admin/users.csv" class="text-xs text-otp-600 hover:underline">Download CSV</a>
    </div>
    <div class="bg-white border rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left text-xs text-gray-500">
          <tr>
            <th class="px-4 py-2"></th>
            <th class="px-4 py-2">Email</th>
            <th class="px-4 py-2">Signed up</th>
            <th class="px-4 py-2">Last login</th>
            <th class="px-4 py-2">Org</th>
            <th class="px-4 py-2 text-right">MCP calls</th>
            <th class="px-4 py-2 text-right">Published</th>
            <th class="px-4 py-2 text-center">Onboarding</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr><td colspan="8" class="px-4 py-6 text-center text-gray-400 text-xs">No users yet. Once someone signs up through Clerk, they'll show here.</td></tr>
          <% } else { %>
            <% users.forEach(function(u) { %>
              <tr class="border-t hover:bg-gray-50 cursor-pointer" onclick="toggleUserActivity('<%= u.clerkUserId %>')">
                <td class="px-4 py-2 text-center">
                  <svg class="w-3.5 h-3.5 text-gray-400 transition-transform" id="user-chevron-<%= u.clerkUserId %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </td>
                <td class="px-4 py-2">
                  <div class="font-medium"><%= u.email || '--' %></div>
                  <% if (u.name) { %><div class="text-xs text-gray-400"><%= u.name %></div><% } %>
                </td>
                <td class="px-4 py-2 text-gray-500 text-xs"><%= u.signUpAt.toLocaleString('en-US', { month: 'short', day: 'numeric' }) %></td>
                <td class="px-4 py-2 text-xs">
                  <% if (u.lastSignInAt) { %>
                    <% if (u.daysSinceLastLogin === 0) { %>
                      <span class="text-green-600 font-medium">today</span>
                    <% } else if (u.daysSinceLastLogin === 1) { %>
                      <span class="text-gray-700">yesterday</span>
                    <% } else if (u.daysSinceLastLogin < 7) { %>
                      <span class="text-gray-700"><%= u.daysSinceLastLogin %>d ago</span>
                    <% } else if (u.daysSinceLastLogin < 30) { %>
                      <span class="text-gray-500"><%= u.daysSinceLastLogin %>d ago</span>
                    <% } else { %>
                      <span class="text-red-500"><%= u.daysSinceLastLogin %>d ago</span>
                    <% } %>
                    <% if (u.hasReturned) { %><span class="text-green-600 ml-1" title="Returned after signup">●</span><% } %>
                  <% } else { %>
                    <span class="text-gray-300">never</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 text-gray-500 text-xs">
                  <% if (u.orgName) { %><%= u.orgName %><% } else { %><span class="text-gray-300">--</span><% } %>
                </td>
                <td class="px-4 py-2 text-right text-xs">
                  <% if (u.mcpCallCount > 0) { %>
                    <span class="text-otp-600 font-semibold"><%= u.mcpCallCount %></span>
                  <% } else { %>
                    <span class="text-gray-300">0</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 text-right text-xs">
                  <% if (u.publishedOos > 0) { %>
                    <span class="text-otp-600 font-semibold"><%= u.publishedOos %></span>
                  <% } else { %>
                    <span class="text-gray-300">0</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 text-center text-xs">
                  <% if (u.unsubscribed) { %>
                    <span class="text-red-500">unsub</span>
                  <% } else { %>
                    <span class="text-gray-500"><%= u.onboardingStage %>/3</span>
                  <% } %>
                </td>
              </tr>
              <tr class="hidden bg-gray-50" id="user-activity-<%= u.clerkUserId %>">
                <td colspan="8" class="px-6 py-4 border-t">
                  <div class="text-xs text-gray-500 mb-2">Recent activity (<%= u.orgName ? u.orgName : 'no org yet' %>)</div>
                  <% if (u.activity && u.activity.length > 0) { %>
                    <ul class="space-y-1">
                      <% u.activity.forEach(function(a) { %>
                        <li class="flex items-center gap-3 text-xs">
                          <span class="text-gray-400 w-24 flex-shrink-0"><%= a.createdAt.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></span>
                          <span class="font-mono px-1.5 py-0.5 rounded
                            <% if (a.action.includes('published')) { %>bg-green-100 text-green-700<% } else if (a.action.includes('created')) { %>bg-blue-100 text-blue-700<% } else { %>bg-gray-100 text-gray-600<% } %>
                          "><%= a.action %></span>
                          <span class="text-gray-400"><%= a.entityType %></span>
                        </li>
                      <% }); %>
                    </ul>
                  <% } else { %>
                    <div class="text-xs text-gray-400 italic">No activity yet. <%= u.orgName ? 'Has org but has not done anything in it.' : 'No org created yet.' %></div>
                  <% } %>
                  <div class="text-xs text-gray-400 mt-3 pt-3 border-t flex items-center justify-between gap-3">
                    <div>
                      Clerk user ID: <span class="font-mono"><%= u.clerkUserId %></span>
                      <% if (u.lastMcpUsedAt) { %>
                        · Last MCP call: <%= u.lastMcpUsedAt.toLocaleString() %>
                      <% } %>
                    </div>
                    <form method="POST" action="/admin/impersonate/by-clerk/<%= u.clerkUserId %>" onclick="event.stopPropagation();">
                      <button type="submit" class="text-xs px-3 py-1 bg-amber-50 text-amber-800 border border-amber-200 rounded hover:bg-amber-100 font-semibold">View as <%= u.email || u.name || 'user' %></button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    function toggleUserActivity(userId) {
      var row = document.getElementById('user-activity-' + userId);
      var chevron = document.getElementById('user-chevron-' + userId);
      if (!row) return;
      row.classList.toggle('hidden');
      if (chevron) chevron.style.transform = row.classList.contains('hidden') ? '' : 'rotate(90deg)';
    }
  </script>

  <!-- Stats Grid -->
  <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-otp-600"><%= stats.totalOrgs %></div>
      <div class="text-xs text-gray-500">Organizations</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-otp-600"><%= stats.publishedOos %></div>
      <div class="text-xs text-gray-500">Published OOS</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-otp-600"><%= stats.totalClaims %></div>
      <div class="text-xs text-gray-500">Total Claims</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-otp-600"><%= stats.totalSimilarities %></div>
      <div class="text-xs text-gray-500">Similarities</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-otp-600"><%= stats.openTickets %></div>
      <div class="text-xs text-gray-500">Open Tickets</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-otp-600"><%= stats.apiKeys %></div>
      <div class="text-xs text-gray-500">API Keys</div>
    </div>
  </div>

  <!-- Recent Activity + Organizations side by side -->
  <div class="grid lg:grid-cols-2 gap-6 mb-8">

    <!-- Organizations -->
    <div>
      <h3 class="font-semibold mb-3">Organizations (<%= orgs.length %>)</h3>
      <div class="bg-white border rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-left text-xs text-gray-500">
            <tr>
              <th class="px-4 py-2">Name</th>
              <th class="px-4 py-2">Industry</th>
              <th class="px-4 py-2">Quality</th>
              <th class="px-4 py-2">Level</th>
              <th class="px-4 py-2">Joined</th>
              <th class="px-4 py-2 text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% orgs.forEach(function(org) { %>
              <tr class="border-t hover:bg-gray-50 <%= org.deletion_requested_at ? 'opacity-60' : '' %>">
                <td class="px-4 py-2">
                  <a href="/org/<%= org.id %>" class="text-otp-600 hover:underline font-medium"><%= org.name %></a>
                  <% if (org.badge) { %><span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 capitalize"><%= org.badge %></span><% } %>
                </td>
                <td class="px-4 py-2 text-gray-500 capitalize"><%= org.industry %></td>
                <td class="px-4 py-2">
                  <% if (org.quality_tier) { %>
                    <span class="text-xs px-1.5 py-0.5 rounded capitalize
                      <% if (org.quality_tier === 'platinum') { %>bg-purple-100 text-purple-700<% } %>
                      <% if (org.quality_tier === 'gold') { %>bg-yellow-100 text-yellow-700<% } %>
                      <% if (org.quality_tier === 'silver') { %>bg-gray-100 text-gray-600<% } %>
                      <% if (org.quality_tier === 'bronze') { %>bg-orange-100 text-orange-700<% } %>
                    "><%= org.quality_tier %></span>
                  <% } else { %>
                    <span class="text-gray-300">--</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 text-gray-500"><%= org.agentic_level ? 'L' + org.agentic_level : '--' %></td>
                <td class="px-4 py-2 text-gray-400 text-xs"><%= new Date(org.created_at).toLocaleDateString() %></td>
                <td class="px-4 py-2 text-right whitespace-nowrap">
                  <% if (org.deletion_requested_at) { %>
                    <% var _dleft = Math.max(0, Math.ceil((new Date(org.deletion_requested_at).getTime() + 7*86400000 - Date.now())/86400000)); %>
                    <span class="text-[11px] text-red-600 font-semibold mr-2" title="Permanently purged when the countdown hits 0">Deleting &middot; <%= _dleft %>d left</span>
                    <button type="button" class="adm-restore text-xs px-2 py-1 border border-gray-300 rounded hover:bg-gray-50" data-org-id="<%= org.id %>" data-org-name="<%= org.name %>">Restore</button>
                  <% } else { %>
                    <button type="button" class="adm-delete text-xs text-gray-400 hover:text-red-600 hover:underline" data-org-id="<%= org.id %>" data-org-name="<%= org.name %>">Delete</button>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Org hard-delete confirmation modal (super admin). Two checkboxes + type
         DELETE (case-sensitive) to arm the button. Mirrors the GHL pattern. -->
    <div id="org-del-overlay" class="hidden fixed inset-0" style="background:rgba(15,23,42,0.45);z-index:80;"></div>
    <div id="org-del-modal" class="hidden fixed inset-0 flex items-center justify-center p-4" style="z-index:81;">
      <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg p-6">
        <div class="flex items-start justify-between gap-3">
          <h3 class="text-lg font-bold text-gray-900">Delete <span id="org-del-name"></span></h3>
          <button type="button" id="org-del-x" class="text-gray-400 hover:text-gray-700 text-2xl leading-none">&times;</button>
        </div>
        <p class="text-sm text-gray-500 mt-1">This soft-deletes the organization. It can be restored for 7 days, then all of its data is permanently and irreversibly purged.</p>
        <div class="mt-4 space-y-3 border-t border-gray-100 pt-4">
          <label class="flex items-start gap-2 text-sm text-gray-700">
            <input type="checkbox" id="org-del-ack1" class="mt-0.5"> I confirm I have discussed this with the client and have authority to take this action.
          </label>
          <label class="flex items-start gap-2 text-sm text-gray-700">
            <input type="checkbox" id="org-del-ack2" class="mt-0.5"> I understand this is irreversible after 7 days and all data inside this organization will be lost.
          </label>
          <label class="block text-sm text-gray-700">
            Type <span class="font-mono font-bold">DELETE</span> to confirm:
            <input type="text" id="org-del-word" autocomplete="off" spellcheck="false" class="mt-1 w-full border rounded px-2 py-1.5 text-sm" placeholder="DELETE">
          </label>
        </div>
        <div class="mt-5 flex justify-end gap-2">
          <button type="button" id="org-del-cancel" class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">Not now</button>
          <button type="button" id="org-del-confirm" disabled class="px-4 py-2 text-sm bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700" style="opacity:0.5;cursor:not-allowed;">Delete account</button>
        </div>
        <p id="org-del-msg" class="mt-2 text-xs text-red-600"></p>
      </div>
    </div>
    <script>
      (function(){
        var overlay=document.getElementById('org-del-overlay'), modal=document.getElementById('org-del-modal');
        var nameEl=document.getElementById('org-del-name'), ack1=document.getElementById('org-del-ack1'), ack2=document.getElementById('org-del-ack2');
        var word=document.getElementById('org-del-word'), confirmBtn=document.getElementById('org-del-confirm'), msg=document.getElementById('org-del-msg');
        var currentId=null;
        function refresh(){
          var ok = ack1.checked && ack2.checked && word.value === 'DELETE';
          confirmBtn.disabled = !ok;
          confirmBtn.style.opacity = ok ? '1' : '0.5';
          confirmBtn.style.cursor = ok ? 'pointer' : 'not-allowed';
        }
        function open(id, name){ currentId=id; nameEl.textContent=name||'organization'; ack1.checked=false; ack2.checked=false; word.value=''; msg.textContent=''; refresh(); overlay.classList.remove('hidden'); modal.classList.remove('hidden'); }
        function close(){ overlay.classList.add('hidden'); modal.classList.add('hidden'); currentId=null; }
        [ack1,ack2].forEach(function(el){ el.addEventListener('change', refresh); });
        word.addEventListener('input', refresh);
        document.getElementById('org-del-x').addEventListener('click', close);
        document.getElementById('org-del-cancel').addEventListener('click', close);
        overlay.addEventListener('click', close);
        confirmBtn.addEventListener('click', function(){
          if(!currentId || confirmBtn.disabled) return;
          confirmBtn.disabled=true; confirmBtn.textContent='Deleting...';
          fetch('/api/v1/admin/orgs/'+currentId+'/delete', { method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin', body: JSON.stringify({ ackAuthority:true, ackIrreversible:true, confirm:'DELETE' }) })
            .then(function(r){ return r.json().catch(function(){return {};}).then(function(j){ if(!r.ok) throw (j.error||{message:'HTTP '+r.status}); return j; }); })
            .then(function(){ window.location.reload(); })
            .catch(function(e){ msg.textContent = (e && e.message) || 'Delete failed'; confirmBtn.disabled=false; confirmBtn.textContent='Delete account'; refresh(); });
        });
        document.querySelectorAll('.adm-delete').forEach(function(b){ b.addEventListener('click', function(){ open(b.getAttribute('data-org-id'), b.getAttribute('data-org-name')); }); });
        document.querySelectorAll('.adm-restore').forEach(function(b){ b.addEventListener('click', function(){
          if(!confirm('Restore "'+(b.getAttribute('data-org-name')||'this org')+'"? It becomes active again immediately.')) return;
          b.disabled=true;
          fetch('/api/v1/admin/orgs/'+b.getAttribute('data-org-id')+'/restore', { method:'POST', credentials:'same-origin' })
            .then(function(r){ if(!r.ok) throw 0; return r.json(); })
            .then(function(){ window.location.reload(); })
            .catch(function(){ b.disabled=false; alert('Restore failed.'); });
        }); });
      })();
    </script>

    <!-- Recent Audit Logs -->
    <div>
      <h3 class="font-semibold mb-3">Recent Activity</h3>
      <div class="bg-white border rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-left text-xs text-gray-500">
            <tr>
              <th class="px-4 py-2">Action</th>
              <th class="px-4 py-2">Org</th>
              <th class="px-4 py-2">Time</th>
            </tr>
          </thead>
          <tbody>
            <% auditLogs.forEach(function(log) { %>
              <tr class="border-t hover:bg-gray-50">
                <td class="px-4 py-2">
                  <span class="text-xs font-mono px-1.5 py-0.5 rounded
                    <% if (log.action.includes('published')) { %>bg-green-100 text-green-700<% } else if (log.action.includes('created')) { %>bg-blue-100 text-blue-700<% } else { %>bg-gray-100 text-gray-600<% } %>
                  "><%= log.action %></span>
                </td>
                <td class="px-4 py-2 text-gray-500 text-xs"><%= log.org_name || '--' %></td>
                <td class="px-4 py-2 text-gray-400 text-xs"><%= new Date(log.created_at).toLocaleString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Portfolios (super-admin tooling: bring existing orgs into the portfolio model).
       Loads entirely client-side from GET /api/v1/admin/portfolios so this panel
       does NOT require the /admin page route to pre-load any data. -->
  <div class="mb-8" id="adm-portfolios">
    <h3 class="font-semibold mb-3">Portfolios</h3>
    <div class="grid lg:grid-cols-2 gap-6 mb-4">
      <!-- Create portfolio above an org -->
      <div class="bg-white border rounded-lg p-4">
        <div class="font-medium text-sm mb-1">Create a portfolio above an org</div>
        <p class="text-xs text-gray-500 mb-3">The org becomes the first member; a new parent portfolio is created above it.</p>
        <div class="space-y-2">
          <input type="text" id="adm-pf-above-org" placeholder="Existing org ID (UUID)" autocomplete="off" spellcheck="false" class="w-full border rounded px-2 py-1.5 text-sm">
          <input type="text" id="adm-pf-above-name" placeholder="Portfolio name (optional)" autocomplete="off" class="w-full border rounded px-2 py-1.5 text-sm">
          <button type="button" id="adm-pf-above-btn" class="text-xs px-3 py-1.5 bg-otp-600 text-white rounded-lg font-semibold hover:bg-otp-700">Create above</button>
        </div>
        <p id="adm-pf-above-msg" class="mt-2 text-xs text-red-600"></p>
      </div>

      <!-- Promote org to portfolio -->
      <div class="bg-white border rounded-lg p-4">
        <div class="font-medium text-sm mb-1">Promote an org to a portfolio</div>
        <p class="text-xs text-gray-500 mb-3">Turns an existing org INTO a portfolio in place. Its data and members stay put.</p>
        <div class="space-y-2">
          <input type="text" id="adm-pf-promote-org" placeholder="Org ID (UUID)" autocomplete="off" spellcheck="false" class="w-full border rounded px-2 py-1.5 text-sm">
          <button type="button" id="adm-pf-promote-btn" class="text-xs px-3 py-1.5 bg-otp-600 text-white rounded-lg font-semibold hover:bg-otp-700">Promote</button>
        </div>
        <p id="adm-pf-promote-msg" class="mt-2 text-xs text-red-600"></p>
      </div>
    </div>

    <div class="bg-white border rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left text-xs text-gray-500">
          <tr>
            <th class="px-4 py-2">Portfolio</th>
            <th class="px-4 py-2 text-right">Members</th>
            <th class="px-4 py-2">Member orgs</th>
          </tr>
        </thead>
        <tbody id="adm-pf-tbody">
          <tr><td colspan="3" class="px-4 py-6 text-center text-gray-400 text-xs">Loading portfolios...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    (function() {
      var tbody = document.getElementById('adm-pf-tbody');

      function esc(s) { var d = document.createElement('div'); d.textContent = (s == null ? '' : String(s)); return d.innerHTML; }

      function renderError(el, e) {
        el.textContent = (e && e.message) ? e.message : 'Request failed';
      }

      function readJson(r) {
        return r.json().catch(function(){ return {}; }).then(function(j) {
          if (!r.ok) throw (j.error || { message: 'HTTP ' + r.status });
          return j;
        });
      }

      function loadPortfolios() {
        fetch('/api/v1/admin/portfolios', { credentials: 'same-origin' })
          .then(readJson)
          .then(function(j) {
            var list = (j && j.portfolios) || [];
            if (list.length === 0) {
              tbody.innerHTML = '<tr><td colspan="3" class="px-4 py-6 text-center text-gray-400 text-xs">No portfolios yet.</td></tr>';
              return;
            }
            tbody.innerHTML = list.map(function(p) {
              var members = (p.members || []).map(function(m) {
                return '<span class="inline-flex items-center gap-1 text-xs bg-gray-100 text-gray-600 rounded px-1.5 py-0.5 mr-1 mb-1">'
                  + esc(m.name)
                  + ' <button type="button" class="adm-pf-unlink text-gray-400 hover:text-red-600" data-pf="' + esc(p.id) + '" data-member="' + esc(m.id) + '" title="Unlink">&times;</button>'
                  + '</span>';
              }).join('') || '<span class="text-gray-300 text-xs">none</span>';
              return '<tr class="border-t align-top">'
                + '<td class="px-4 py-2"><div class="font-medium">' + esc(p.name) + '</div><div class="text-xs text-gray-400 font-mono">' + esc(p.id) + '</div></td>'
                + '<td class="px-4 py-2 text-right text-otp-600 font-semibold">' + esc(p.memberCount) + '</td>'
                + '<td class="px-4 py-2">'
                  + '<div class="mb-2">' + members + '</div>'
                  + '<div class="flex items-center gap-1">'
                    + '<input type="text" class="adm-pf-link-input border rounded px-2 py-1 text-xs w-56" placeholder="Member org ID (UUID)" data-pf="' + esc(p.id) + '">'
                    + '<button type="button" class="adm-pf-link-btn text-xs px-2 py-1 border border-gray-300 rounded hover:bg-gray-50" data-pf="' + esc(p.id) + '">Link</button>'
                  + '</div>'
                + '</td>'
                + '</tr>';
            }).join('');
            wireRowControls();
          })
          .catch(function(e) {
            tbody.innerHTML = '<tr><td colspan="3" class="px-4 py-6 text-center text-red-500 text-xs">' + esc((e && e.message) || 'Failed to load portfolios') + '</td></tr>';
          });
      }

      function wireRowControls() {
        document.querySelectorAll('.adm-pf-link-btn').forEach(function(b) {
          b.addEventListener('click', function() {
            var pf = b.getAttribute('data-pf');
            var input = document.querySelector('.adm-pf-link-input[data-pf="' + pf + '"]');
            var memberOrgId = input ? input.value.trim() : '';
            if (!memberOrgId) return;
            b.disabled = true;
            fetch('/api/v1/admin/portfolios/' + pf + '/members', {
              method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
              body: JSON.stringify({ memberOrgId: memberOrgId })
            }).then(readJson).then(function() { loadPortfolios(); })
              .catch(function(e) { b.disabled = false; alert((e && e.message) || 'Link failed'); });
          });
        });
        document.querySelectorAll('.adm-pf-unlink').forEach(function(b) {
          b.addEventListener('click', function() {
            var pf = b.getAttribute('data-pf'), member = b.getAttribute('data-member');
            if (!confirm('Unlink this member org from the portfolio?')) return;
            b.disabled = true;
            fetch('/api/v1/admin/portfolios/' + pf + '/members/' + member, { method: 'DELETE', credentials: 'same-origin' })
              .then(readJson).then(function() { loadPortfolios(); })
              .catch(function(e) { b.disabled = false; alert((e && e.message) || 'Unlink failed'); });
          });
        });
      }

      var aboveBtn = document.getElementById('adm-pf-above-btn');
      aboveBtn.addEventListener('click', function() {
        var msg = document.getElementById('adm-pf-above-msg'); msg.textContent = '';
        var orgId = document.getElementById('adm-pf-above-org').value.trim();
        var name = document.getElementById('adm-pf-above-name').value.trim();
        if (!orgId) { msg.textContent = 'Enter an org ID.'; return; }
        var body = { existingOrgId: orgId };
        if (name) body.name = name;
        aboveBtn.disabled = true;
        fetch('/api/v1/admin/portfolios/create-above', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
          body: JSON.stringify(body)
        }).then(readJson).then(function() {
          document.getElementById('adm-pf-above-org').value = '';
          document.getElementById('adm-pf-above-name').value = '';
          aboveBtn.disabled = false;
          loadPortfolios();
        }).catch(function(e) { aboveBtn.disabled = false; renderError(msg, e); });
      });

      var promoteBtn = document.getElementById('adm-pf-promote-btn');
      promoteBtn.addEventListener('click', function() {
        var msg = document.getElementById('adm-pf-promote-msg'); msg.textContent = '';
        var orgId = document.getElementById('adm-pf-promote-org').value.trim();
        if (!orgId) { msg.textContent = 'Enter an org ID.'; return; }
        promoteBtn.disabled = true;
        fetch('/api/v1/admin/portfolios/promote', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
          body: JSON.stringify({ orgId: orgId })
        }).then(readJson).then(function() {
          document.getElementById('adm-pf-promote-org').value = '';
          promoteBtn.disabled = false;
          loadPortfolios();
        }).catch(function(e) { promoteBtn.disabled = false; renderError(msg, e); });
      });

      loadPortfolios();
    })();
  </script>

  <!-- OOS Files -->
  <h3 class="font-semibold mb-3">All OOS Files (<%= oosFiles.length %>)</h3>
  <div class="bg-white border rounded-lg overflow-hidden mb-8">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-left text-xs text-gray-500">
        <tr>
          <th class="px-4 py-2">Name</th>
          <th class="px-4 py-2">Organization</th>
          <th class="px-4 py-2">Template</th>
          <th class="px-4 py-2">Version</th>
          <th class="px-4 py-2">Claims</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2">Created</th>
          <th class="px-4 py-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% oosFiles.forEach(function(f) { %>
          <tr class="border-t hover:bg-gray-50" id="admin-oos-row-<%= f.id %>">
            <td class="px-4 py-2">
              <a href="/oos/<%= f.id %>" class="text-otp-600 hover:underline">
                <span class="admin-oos-name"><%= f.name || (f.template.replace('_', ' ') + ' OOS') %></span>
              </a>
            </td>
            <td class="px-4 py-2 text-gray-500"><%= f.org_name %></td>
            <td class="px-4 py-2 text-gray-500 capitalize"><%= f.template.replace('_', ' ') %></td>
            <td class="px-4 py-2 text-gray-500">v<%= f.version %></td>
            <td class="px-4 py-2 text-gray-500"><%= f.claim_count %></td>
            <td class="px-4 py-2">
              <span class="text-xs px-1.5 py-0.5 rounded capitalize
                <% if (f.status === 'published') { %>bg-green-100 text-green-700<% } %>
                <% if (f.status === 'draft') { %>bg-yellow-100 text-yellow-700<% } %>
                <% if (f.status === 'archived') { %>bg-gray-100 text-gray-500<% } %>
              "><%= f.status %></span>
            </td>
            <td class="px-4 py-2 text-gray-400 text-xs"><%= new Date(f.created_at).toLocaleDateString() %></td>
            <td class="px-4 py-2">
              <div class="flex items-center gap-1">
                <button onclick="adminRenameOos('<%= f.id %>')" class="text-gray-400 hover:text-otp-600 p-1" title="Rename">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                </button>
                <button onclick="adminDeleteOos('<%= f.id %>', '<%= (f.name || f.template.replace('_', ' ') + ' OOS').replace(/'/g, "\\'") %>')" class="text-gray-400 hover:text-red-600 p-1" title="Delete">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <!-- Open Tickets -->
  <% if (tickets.length > 0) { %>
  <h3 class="font-semibold mb-3">Open Tickets (<%= tickets.length %>)</h3>
  <div class="bg-white border rounded-lg overflow-hidden mb-8">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-left text-xs text-gray-500">
        <tr>
          <th class="px-4 py-2">Title</th>
          <th class="px-4 py-2">Category</th>
          <th class="px-4 py-2">Priority</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2">Created</th>
        </tr>
      </thead>
      <tbody>
        <% tickets.forEach(function(t) { %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-2 font-medium"><%= t.title %></td>
            <td class="px-4 py-2 text-gray-500 capitalize"><%= t.category %></td>
            <td class="px-4 py-2">
              <span class="text-xs px-1.5 py-0.5 rounded capitalize
                <% if (t.priority === 'critical') { %>bg-red-100 text-red-700<% } %>
                <% if (t.priority === 'high') { %>bg-orange-100 text-orange-700<% } %>
                <% if (t.priority === 'medium') { %>bg-yellow-100 text-yellow-700<% } %>
                <% if (t.priority === 'low') { %>bg-gray-100 text-gray-500<% } %>
              "><%= t.priority %></span>
            </td>
            <td class="px-4 py-2 capitalize text-gray-500"><%= t.status.replace('_', ' ') %></td>
            <td class="px-4 py-2 text-gray-400 text-xs"><%= new Date(t.created_at).toLocaleDateString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
  async function adminRenameOos(id) {
    var currentName = document.querySelector('#admin-oos-row-' + id + ' .admin-oos-name');
    var newName = prompt('Enter a new name for this OOS file:', currentName ? currentName.textContent.trim() : '');
    if (!newName || !newName.trim()) return;

    try {
      var res = await fetch('/api/v1/admin/oos/' + id + '/rename', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: newName.trim() }),
      });
      if (!res.ok) {
        var err = await res.json();
        alert('Rename failed: ' + (err.error?.message || 'Unknown error'));
        return;
      }
      if (currentName) currentName.textContent = newName.trim();
    } catch (e) {
      alert('Rename failed: ' + e.message);
    }
  }

  async function adminDeleteOos(id, name) {
    if (!confirm('ADMIN DELETE: Are you sure you want to delete "' + name + '"? This cannot be undone.')) return;

    try {
      var res = await fetch('/api/v1/admin/oos/' + id, {
        method: 'DELETE',
      });
      if (!res.ok) {
        var err = await res.json();
        alert('Delete failed: ' + (err.error?.message || 'Unknown error'));
        return;
      }
      var row = document.getElementById('admin-oos-row-' + id);
      if (row) row.remove();
    } catch (e) {
      alert('Delete failed: ' + e.message);
    }
  }
</script>
