    <div class="text-center mt-12 max-w-[640px] mx-auto">
      <div class="eyebrow mb-3" style="color:var(--blue-deep);">The thing nobody else has</div>
      <p class="font-display text-[var(--ink)] leading-[1.3]" style="font-size:clamp(1.2rem,2.4vw,1.55rem); font-weight:700;">
        An infrastructure of learning. Every client makes every other client better. Your playbook compounds.
      </p>
    </div>
  </div>
</section>

