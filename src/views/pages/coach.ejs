      ]; %>
      <% steps.forEach(function(s){ %>
        <div class="card p-7 sm:p-9 grid sm:grid-cols-[auto,1fr] gap-6 sm:gap-9 items-start">
          <span class="font-display leading-none" style="font-size:clamp(2.6rem,5vw,3.6rem); font-weight:800; color:var(--blue);"><%= s.n %></span>
          <div>
            <h3 class="font-display text-[var(--ink)] leading-tight" style="font-size:clamp(1.25rem,2.4vw,1.6rem); font-weight:700;"><%= s.title %></h3>
            <p class="text-[15px] text-[var(--ink-soft)] leading-[1.72] mt-3"><%= s.body %></p>
          </div>
        </div>
      <% }); %>
