<!-- ============================================================
     /coach — landing page for coaches, consultants, advisors with
     clients. Pitch: stop watching your clients bolt AI on broken
     systems. OTP is the operating protocol your playbook lives in.
     MIT 2025 anchor stat. Coach mascot. Calendly CTA.
     ============================================================ -->

<style>
  /* === Local animations for /coach landing === */
  @keyframes coach-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .coach-float { animation: coach-float 5s ease-in-out infinite; }

  @keyframes coach-ring {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 0.15; transform: scale(1.1); }
  }
  .coach-ring-1 { animation: coach-ring 3.5s ease-in-out infinite; }
  .coach-ring-2 { animation: coach-ring 3.5s ease-in-out 0.5s infinite; }
  .coach-ring-3 { animation: coach-ring 3.5s ease-in-out 1s infinite; }

  @keyframes coach-sparkle {
    0%, 100% { opacity: 0; transform: scale(0.4) rotate(0); }
    25% { opacity: 1; transform: scale(1) rotate(90deg); }
    50% { opacity: 0.4; transform: scale(0.85) rotate(0); }
    75% { opacity: 1; transform: scale(1.1) rotate(-90deg); }
  }
  .coach-sparkle { animation: coach-sparkle 4s ease-in-out infinite; }

  @keyframes coach-red-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.55), 0 0 32px -4px rgba(239, 68, 68, 0.55); }
    50% { box-shadow: 0 0 0 14px rgba(239, 68, 68, 0), 0 0 64px -4px rgba(239, 68, 68, 0.9); }
  }
  .coach-red-pulse { animation: coach-red-pulse 2.4s ease-in-out infinite; }

  .coach-gradient-red {
    background: linear-gradient(135deg, #fecaca 0%, #ef4444 35%, #dc2626 70%, #b91c1c 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .coach-gradient-otp {
    background: linear-gradient(135deg, #b9dffe 0%, #4db8ff 50%, #0095ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .coach-hazard-stripe {
    background: repeating-linear-gradient(45deg, transparent 0, transparent 14px, rgba(0,0,0,0.5) 14px, rgba(0,0,0,0.5) 28px);
  }

  .coach-alarm-stripe {
    background: linear-gradient(90deg, rgba(220,38,38,0.95) 0%, rgba(239,68,68,1) 50%, rgba(220,38,38,0.95) 100%);
    position: relative;
    overflow: hidden;
  }
  .coach-alarm-stripe::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(45deg, transparent 0, transparent 18px, rgba(0,0,0,0.12) 18px, rgba(0,0,0,0.12) 36px);
    pointer-events: none;
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .coach-float, .coach-ring-1, .coach-ring-2, .coach-ring-3,
    .coach-sparkle, .coach-red-pulse {
      animation: none !important;
    }
  }
</style>

<!-- =====================================================
     HERO — alarm eyebrow + headline + mascot + CTAs
     ===================================================== -->
<section class="bg-otp-950 relative overflow-hidden pt-28 pb-12 sm:pt-32 sm:pb-16">
  <!-- subtle grid backdrop -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background-image: linear-gradient(to right, rgba(255,255,255,0.4) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- ambient red glow -->
  <div class="pointer-events-none absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full opacity-50 blur-3xl" style="background: radial-gradient(circle, rgba(239,68,68,0.18), transparent 60%);"></div>

  <div class="relative max-w-5xl mx-auto px-6 sm:px-8 text-center">
    <!-- Red alarm eyebrow -->
    <div class="mb-6 flex justify-center">
      <div class="inline-flex items-center gap-2 rounded-full px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white" style="background: linear-gradient(90deg, rgba(220,38,38,0.95), rgba(239,68,68,1) 50%, rgba(220,38,38,0.95)); box-shadow: 0 0 0 1px rgba(239,68,68,0.5), 0 8px 24px -6px rgba(239,68,68,0.55);">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243a3 3 0 014.243 0l7.65 7.65a3 3 0 010 4.244l-3.408 3.408a3 3 0 01-4.243 0l-7.65-7.65a3 3 0 010-4.243l3.408-3.409zM12 8v4m0 4h.01"/></svg>
        <span>For coaches, consultants &amp; operators with clients</span>
      </div>
    </div>

    <h1 class="font-extrabold leading-[0.95] tracking-tight text-white" style="font-size: clamp(2.5rem, 6vw, 4.75rem);">
      <span class="block">Stop watching your clients</span>
      <span class="mt-1 block coach-gradient-red">bolt AI on broken systems.</span>
    </h1>

    <p class="mx-auto mt-5 max-w-2xl text-base sm:text-lg leading-relaxed text-gray-300">
      OTP is the operating protocol your clients run on &mdash; and the one their AI plugs into.
      <span class="font-semibold text-white">Your playbook defines the protocol.</span>
      One operating layer per client. An infrastructure of learning across your whole book.
    </p>

    <!-- Mascot with sparkles -->
    <div class="relative mx-auto mt-10 flex w-full items-center justify-center md:mt-12">
      <!-- Sparkles (inner ring) -->
      <% const sparkles = [
        { pos: 'left:8%; top:12%;', size: 28, color: '#ef4444', delay: 0.5 },
        { pos: 'right:6%; top:8%;', size: 22, color: '#0095ff', delay: 0.9 },
        { pos: 'left:14%; top:42%;', size: 18, color: '#0095ff', delay: 1.4 },
        { pos: 'right:12%; top:36%;', size: 26, color: '#ef4444', delay: 1.8 },
        { pos: 'left:4%; bottom:18%;', size: 20, color: '#d4ad32', delay: 2.2 },
        { pos: 'right:4%; bottom:14%;', size: 24, color: '#0095ff', delay: 2.6 },
        { pos: 'left:24%; top:2%;', size: 14, color: '#d4ad32', delay: 3.0 },
        { pos: 'right:24%; bottom:2%;', size: 16, color: '#ef4444', delay: 3.4 },
        { pos: 'left:-2%; top:28%;', size: 12, color: '#0095ff', delay: 0.2 },
        { pos: 'right:-2%; top:20%;', size: 14, color: '#d4ad32', delay: 1.1 },
        { pos: 'left:18%; bottom:6%;', size: 12, color: '#ef4444', delay: 1.6 },
        { pos: 'right:18%; top:18%;', size: 16, color: '#0095ff', delay: 2.0 },
        { pos: 'left:36%; top:-2%;', size: 18, color: '#ef4444', delay: 2.4 },
        { pos: 'right:36%; top:-2%;', size: 14, color: '#0095ff', delay: 2.8 },
        { pos: 'left:42%; bottom:-1%;', size: 20, color: '#d4ad32', delay: 3.2 },
        { pos: 'right:42%; bottom:-1%;', size: 16, color: '#0095ff', delay: 3.6 },
        { pos: 'left:30%; top:28%;', size: 10, color: '#d4ad32', delay: 0.7 },
        { pos: 'right:30%; top:52%;', size: 10, color: '#0095ff', delay: 1.3 },
        { pos: 'left:38%; bottom:20%;', size: 12, color: '#ef4444', delay: 2.1 },
        { pos: 'right:38%; bottom:28%;', size: 10, color: '#d4ad32', delay: 3.1 },
      ]; %>
      <% sparkles.forEach(s => { %>
        <div class="pointer-events-none absolute coach-sparkle z-20" style="<%= s.pos %> animation-delay: <%= s.delay %>s; filter: drop-shadow(0 0 8px <%= s.color %>aa) drop-shadow(0 0 16px <%= s.color %>66);">
          <svg width="<%= s.size %>" height="<%= s.size %>" viewBox="0 0 24 24" fill="<%= s.color %>" stroke="<%= s.color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
            <path d="M20 3v4"/>
            <path d="M22 5h-4"/>
            <path d="M4 17v2"/>
            <path d="M5 18H3"/>
          </svg>
        </div>
      <% }); %>

      <!-- Mascot -->
      <div class="relative z-10 coach-float" style="filter: drop-shadow(0 32px 56px rgba(0,0,0,0.6)) drop-shadow(0 0 32px rgba(239,68,68,0.3));">
        <img src="/public/images/coach-mascot.png" alt="OTP mascot. Half human in a red coach jersey with whistle and football, half AI circuit board with headset and playbook. One being. Two halves. Same playbook." class="h-auto w-[320px] sm:w-[460px] md:w-[560px]" />
      </div>
    </div>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="https://calendly.com/davidsteel/performance-call" target="_blank" rel="noopener noreferrer" class="coach-red-pulse group inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-bold text-white transition-transform duration-200 hover:scale-[1.03] active:scale-[0.98]" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span>Book a 15-minute call</span>
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#how" class="inline-flex items-center gap-2 rounded-xl border border-otp-500/40 bg-white/5 px-6 py-3.5 text-base font-medium text-otp-300 backdrop-blur transition-all duration-200 hover:border-otp-400 hover:bg-white/10">See how it works</a>
    </div>

    <p class="mt-8 text-[11px] uppercase tracking-[0.25em] text-gray-500">
      <span class="font-semibold text-red-400">Your Playbook</span> &middot;
      <span class="text-white">Your Clients</span> &middot;
      <span class="text-otp-400">One Protocol</span>
    </p>
  </div>
</section>

<!-- =====================================================
     JOEL 101 — friendly plain-English explainer BEFORE the alarm content.
     Triggered by Joel Swanson's first-claim feedback 2026-05-14:
     "Who are you? What is this? Why should a non-AI expert care?"
     Coach mascot delivers a 90-second playbook in three plays.
     Designed to catch the EOS coach who isn't an AI native, before the
     punchier MIT/95% content lower down the page.
     ===================================================== -->
<section class="bg-gradient-to-b from-amber-50 via-white to-amber-50 relative py-14 sm:py-20 border-y-2 border-amber-200/60">
  <div class="absolute inset-0 pointer-events-none opacity-[0.06]" style="background-image: radial-gradient(circle at 20% 30%, #d4ad32 0, transparent 40%), radial-gradient(circle at 80% 70%, #ef4444 0, transparent 40%);"></div>

  <div class="relative mx-auto max-w-6xl px-6 sm:px-8">

    <!-- Eyebrow with mascot -->
    <div class="flex flex-col items-center text-center mb-10">
      <div class="relative mb-5">
        <div class="absolute -inset-2 rounded-full coach-ring-1" style="background: radial-gradient(circle, rgba(212,173,50,0.35), transparent 70%);"></div>
        <img src="/public/images/coach-mascot.png" alt="Coach mascot" class="relative h-24 w-24 sm:h-28 sm:w-28 object-contain coach-float" style="filter: drop-shadow(0 12px 24px rgba(212,173,50,0.3));"/>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full bg-amber-100 px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-amber-800 mb-3">
        <span aria-hidden>📋</span>
        <span>New here? Coach's 90-second playbook</span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900">
        Three answers,
        <span class="coach-gradient-red">plain English.</span>
      </h2>
      <p class="mt-3 max-w-xl text-base text-gray-600">
        Not an AI expert? Good. Most of your clients aren't either. Here's the whole thing in 90 seconds.
      </p>
    </div>

    <!-- Three plays -->
    <div class="grid gap-5 sm:gap-6 md:grid-cols-3">

      <!-- Play 1: WHERE THIS CAME FROM (proof-of-concept origin, not personal bio) -->
      <div class="group relative rounded-2xl bg-white border-2 border-amber-200/80 p-6 sm:p-7 transition-all duration-200 hover:border-amber-400 hover:shadow-xl hover:shadow-amber-200/40 hover:-translate-y-0.5">
        <div class="absolute -top-4 left-6 inline-flex h-9 w-9 items-center justify-center rounded-xl bg-amber-400 text-white font-extrabold shadow-md">1</div>
        <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-amber-700 mb-2 mt-2">Where this came from</div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">A working operating system &mdash; not a deck.</h3>
        <p class="text-sm leading-relaxed text-gray-700">
          OTP started inside a real, running operating system: <strong class="text-gray-900">14 AI agents working alongside 12 humans</strong>, every Tuesday in the same L10, every seat with a name, a KPI, and an SOP. Once the pattern proved out, we opened the protocol up.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">
          EOS coaches are a natural fit because the tools your clients already use &mdash; <strong class="text-gray-900">accountability chart, scorecard, SOPs, L10</strong> &mdash; are exactly the tools OTP runs on. The Founding 25 cohort is shaping what ships next.
        </p>
      </div>

      <!-- Play 2: WHAT -->
      <div class="group relative rounded-2xl bg-white border-2 border-red-200/80 p-6 sm:p-7 transition-all duration-200 hover:border-red-400 hover:shadow-xl hover:shadow-red-200/40 hover:-translate-y-0.5">
        <div class="absolute -top-4 left-6 inline-flex h-9 w-9 items-center justify-center rounded-xl bg-red-500 text-white font-extrabold shadow-md">2</div>
        <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-red-700 mb-2 mt-2">What OTP is</div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">An accountability chart with AI seats next to human seats.</h3>
        <p class="text-sm leading-relaxed text-gray-700">
          Each seat &mdash; AI or human &mdash; has a name, a role, a KPI, and an SOP. Click an AI seat: you see what it does, the number it hits, who it reports to. Click a human seat: same.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">
          Under the hood it does more (carries SOPs into the AI's runtime so they don't drift, lets agents talk to each other without you in the middle). <strong class="text-gray-900">But the surface is the chart.</strong>
        </p>
      </div>

      <!-- Play 3: WHY -->
      <div class="group relative rounded-2xl bg-white border-2 border-otp-200/80 p-6 sm:p-7 transition-all duration-200 hover:border-otp-400 hover:shadow-xl hover:shadow-otp-200/40 hover:-translate-y-0.5">
        <div class="absolute -top-4 left-6 inline-flex h-9 w-9 items-center justify-center rounded-xl bg-otp-500 text-white font-extrabold shadow-md">3</div>
        <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-otp-700 mb-2 mt-2">Why a non-AI expert should care</div>
        <h3 class="text-lg font-bold text-gray-900 mb-3">Your clients are adding AI &mdash; messily.</h3>
        <p class="text-sm leading-relaxed text-gray-700">
          Right now it lives in Notion docs, Zaps, ChatGPT tabs, and Mike-the-IT-guy's head. It's becoming a People &amp; Process issue &mdash; except the EOS toolkit doesn't have a seat type for "AI agent" yet.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">
          <strong class="text-gray-900">OTP fills that gap</strong> with tools your clients already speak fluently. We just add the AI seats.
        </p>
      </div>

    </div>

    <!-- What you get as a Founding 25 coach -->
    <div class="mt-10 sm:mt-12 rounded-2xl bg-gray-900 p-6 sm:p-8 text-white relative overflow-hidden">
      <div class="absolute -right-12 -top-12 h-56 w-56 rounded-full opacity-20" style="background: radial-gradient(circle, #d4ad32, transparent 70%);"></div>
      <div class="relative grid gap-6 md:grid-cols-[1fr,auto] md:items-center">
        <div>
          <div class="text-[11px] font-bold uppercase tracking-[0.22em] text-amber-300 mb-2">★ The Founding 25 perk</div>
          <h3 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-4">Your own coach view. Your whole book in one place.</h3>
          <p class="text-base leading-relaxed text-gray-300 mb-4">
            Every leadership team you work with shows up on one screen &mdash; their chart, their AI footprint, their KPIs. Side-by-side. The patterns get visible.
          </p>
          <ul class="space-y-1.5 text-sm text-gray-300">
            <li class="flex gap-2"><span class="text-amber-300">→</span> Client A has 5 AI tools and nobody owns them. Client B has them on one chart and is humming.</li>
            <li class="flex gap-2"><span class="text-amber-300">→</span> Client C's KPIs went red the same week they added an agent.</li>
            <li class="flex gap-2"><span class="text-amber-300">→</span> The breakthrough Client A had Tuesday is visible when you walk into Client B on Thursday.</li>
          </ul>
          <p class="mt-4 text-xs text-gray-400 italic">
            Each client's data stays private to them. You have visibility because you're their coach.
          </p>
        </div>
        <div class="md:max-w-[200px] flex flex-col items-center md:items-end gap-4 md:border-l md:border-white/10 md:pl-6">
          <a href="/public/images/founder-coach-badge.png" target="_blank" rel="noopener" title="Founder Certified Coach badge — claim your profile to get yours" class="block transition-transform hover:scale-105">
            <img src="/public/images/founder-coach-badge-preview.png" alt="OTP Founder Certified Coach Badge" class="w-32 md:w-36 h-auto drop-shadow-2xl" />
          </a>
          <div class="text-xs text-gray-400 md:text-right">
            <div class="font-semibold text-white mb-1">You also get:</div>
            Founder badge (yours forever) · Monthly roadmap voting · Direct line to David · Perpetual attribution on every client
          </div>
        </div>
      </div>
    </div>

    <!-- CTAs: scroll down OR book -->
    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="https://calendly.com/davidsteel/performance-call" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 rounded-xl bg-gray-900 px-7 py-3.5 text-base font-bold text-white transition-transform duration-200 hover:scale-[1.03] active:scale-[0.98] hover:bg-gray-800">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span>Book a 15-min call</span>
      </a>
      <a href="#how" class="inline-flex items-center gap-2 rounded-xl border-2 border-gray-300 bg-white px-6 py-3.5 text-base font-medium text-gray-900 transition-all duration-200 hover:border-gray-400 hover:bg-gray-50">
        <span>Keep scrolling for the pitch</span>
        <span aria-hidden>↓</span>
      </a>
    </div>
  </div>
</section>

