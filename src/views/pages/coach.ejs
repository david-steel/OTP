      <div class="relative z-10 px-8 py-14 text-center sm:py-20">
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-red-200/90">MIT 2025 &middot; The GenAI Divide</p>
        <div class="mt-4 font-extrabold leading-none tracking-tighter text-white" style="font-size: clamp(7rem, 22vw, 18rem); text-shadow: 0 0 40px rgba(255,200,200,0.5), 0 0 80px rgba(239,68,68,0.7), 0 8px 24px rgba(0,0,0,0.6);">
