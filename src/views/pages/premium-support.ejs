<%# /premium-support -- v7 layout, light editorial styling (matches
    otp-vs-ninety-eos-one). Premium Support offer page: hero, three pillars,
    before/after, Standard vs Premium table, pricing card, why section.
    v7.css is PREBUILT: arbitrary Tailwind classes silently no-op, so ALL
    layout/color is scoped CSS + design tokens (--blue #0d7df2, --orgy #a8e63a).
    Conversion page: the ONLY in-page links are the two Calendly CTAs.
    No testimonials, no stats, no email addresses. %>
<style>
  .ps-sec   { padding-top: 80px; padding-bottom: 80px; }
  .ps-hero  { padding-top: 132px; padding-bottom: 56px; }   /* clears 64px fixed nav */
  .ps-wrap  { max-width: 1040px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .ps-center{ text-align: center; }
  .ps-paper { background: var(--white, #fcfcfd); }
  .ps-grey  { background: var(--grey, #f0f1f3); }
  @media (max-width: 640px) { .ps-sec { padding-top: 52px; padding-bottom: 52px; } .ps-hero { padding-top: 100px; padding-bottom: 40px; } }

  .ps-eyebrow { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-mute,#888c96); display:flex; align-items:center; gap:10px; }
  .ps-tick { width:8px; height:8px; border-radius:50%; background:var(--orgy,#a8e63a); display:inline-block; }
  .ps-h1 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.025em; line-height:1.05; font-size:clamp(2.1rem,4.4vw,3.4rem); color:var(--ink,#14161c); margin:0; }
  .ps-h2 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.02em; line-height:1.1; font-size:clamp(1.7rem,3.3vw,2.45rem); color:var(--ink,#14161c); }
  .ps-h3 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:1.12rem; color:var(--ink,#14161c); }
  .ps-lead { font-size:18px; line-height:1.62; color:var(--ink-soft,#494d57); }
  .ps-body { font-size:16px; line-height:1.65; color:var(--ink-soft,#494d57); }
  .ps-max640 { max-width:640px; } .ps-max40 { max-width:40rem; }
  .ps-mt5{margin-top:20px;} .ps-mt7{margin-top:28px;} .ps-mt8{margin-top:32px;} .ps-mb4{margin-bottom:16px;} .ps-mb10{margin-bottom:40px;}
  .accent { color:var(--blue,#0d7df2); }

  /* two-column hero (copy left, mascot right) */
  .ps-hgrid { display:flex; gap:44px; align-items:center; flex-wrap:wrap; }
  .ps-hcopy { flex:1 1 460px; min-width:320px; text-align:left; }
  .ps-hcopy .ps-lead { max-width:34rem; }
  .ps-hart  { flex:1 1 280px; min-width:240px; text-align:center; }
  .ps-hart img { width:min(260px,70%); height:auto; display:inline-block; filter:drop-shadow(0 18px 32px rgba(20,22,28,.16)); }
  .ps-hartcap { font-size:13px; color:var(--ink-mute,#888c96); margin-top:12px; }
  @media (max-width:860px){
    .ps-hcopy { flex-basis:100%; text-align:center; }
    .ps-hcopy .ps-eyebrow { justify-content:center; }
    .ps-hcopy .ps-lead { margin-left:auto; margin-right:auto; }
    .ps-hcopy .ps-cta { justify-content:center; }
    .ps-hart { flex-basis:100%; }
  }
  .ps-cta { display:flex; flex-wrap:wrap; gap:12px; }

  /* subtle float on the mascot (matches home/vs pages) */
  @media (prefers-reduced-motion: no-preference){
    .ps-float { animation:ps-float 5.5s ease-in-out infinite; }
    @keyframes ps-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-10px);} }
  }

  /* three pillars */
  .ps-pillars { display:grid; gap:18px; }
  @media (min-width:768px){ .ps-pillars { grid-template-columns:repeat(3,1fr); } }
  .ps-pillar { border-radius:14px; background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); padding:26px; box-shadow:0 8px 22px rgba(20,22,28,.05); }
  .ps-pillar-n { font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:12px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:var(--blue,#0d7df2); }
  .ps-pillar .ps-h3 { margin-top:8px; }
  .ps-pillar .ps-body { margin-top:8px; }

  /* before / after */
  .ps-ba { display:grid; gap:18px; }
  @media (min-width:768px){ .ps-ba { grid-template-columns:repeat(2,1fr); } }
  .ps-bacard { border-radius:14px; padding:28px; }
  .ps-bacard.before { background:var(--grey,#f0f1f3); }
  .ps-bacard.after  { background:rgba(13,125,242,0.07); border:1px solid rgba(13,125,242,0.18); }
  .ps-balabel { font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:12px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; }
  .ps-bacard.before .ps-balabel { color:var(--ink-mute,#888c96); }
  .ps-bacard.after  .ps-balabel { color:var(--blue,#0d7df2); }
  .ps-balist { list-style:none; margin:16px 0 0; padding:0; }
  .ps-balist li { display:flex; align-items:flex-start; gap:10px; font-size:15.5px; line-height:1.55; color:var(--ink-soft,#494d57); padding:7px 0; }
  .ps-balist .mark { flex:none; font-weight:800; width:18px; text-align:center; }
  .ps-bacard.before .mark { color:#c2c6cd; }
  .ps-bacard.after  .mark { color:var(--blue,#0d7df2); }

  /* Standard vs Premium table */
  .cmp-card { border-radius:14px; background:var(--white,#fcfcfd); box-shadow:0 1px 0 rgba(20,22,28,.04), 0 18px 40px rgba(20,22,28,.06); overflow:hidden; }
  .cmp-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; }
  .cmp { width:100%; border-collapse:separate; border-spacing:0; min-width:520px; font-size:15px; }
  .cmp th, .cmp td { padding:14px 16px; text-align:center; border-bottom:1px solid var(--line,#e6e8ec); vertical-align:middle; }
  .cmp th { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:14px; color:var(--ink,#14161c); }
  .cmp td:first-child, .cmp th:first-child { text-align:left; color:var(--ink-soft,#494d57); font-weight:600; }
  .cmp .col-prem { background:rgba(13,125,242,0.08); }
  .cmp thead .col-prem { color:var(--blue,#0d7df2); box-shadow: inset 0 -3px 0 var(--blue,#0d7df2); }
  .cmp .yes { color:var(--blue,#0d7df2); font-weight:800; }
  .cmp .no  { color:#c2c6cd; font-weight:700; }
  .cmp .strong { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; color:var(--blue,#0d7df2); }
  .cmp tr:last-child td { border-bottom:none; }
  @media (max-width:640px){
    .cmp { min-width:0; font-size:12.5px; }
    .cmp th { font-size:11.5px; }
    .cmp th, .cmp td { padding:9px 8px; }
  }

  /* pricing card */
  .ps-price { max-width:520px; margin:0 auto; border-radius:18px; background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); box-shadow:0 24px 60px rgba(20,22,28,.12); padding:40px 34px; text-align:center; }
  .ps-chip { display:inline-block; font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:11.5px; font-weight:800; letter-spacing:.14em; text-transform:uppercase; color:var(--blue,#0d7df2); background:rgba(13,125,242,0.1); border-radius:999px; padding:7px 16px; }
  .ps-amount { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.03em; font-size:clamp(2.6rem,6vw,3.6rem); color:var(--ink,#14161c); margin-top:18px; line-height:1; }
  .ps-amount .per { font-size:.34em; font-weight:700; letter-spacing:0; color:var(--ink-mute,#888c96); }
  .ps-annual { margin-top:12px; font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:15px; color:var(--blue,#0d7df2); background:rgba(13,125,242,0.07); border-radius:10px; padding:10px 14px; display:inline-block; }
  .ps-price .ps-body { margin-top:18px; }
  .ps-fineprint { font-size:13px; color:var(--ink-mute,#888c96); margin-top:14px; line-height:1.6; }
</style>

<%# In-shell trim: when rendered inside the authed main layout (renderInShell
    passes through server.ts's wrapped reply.view, which injects authUserId),
    the layout's own fixed nav + pt already clear 65px, so the v7 hero's
    132px nav-clearing padding would double the gap. The v7 path never gets
    authUserId, so this block is a no-op for marketing visitors. %>
<% if (typeof authUserId !== 'undefined' && authUserId) { %>
<style>.ps-hero { padding-top: 56px; }</style>
<% } %>

<!-- ================= HERO ================= -->
<section class="ps-paper">
  <div class="ps-wrap ps-hero">
    <div class="ps-hgrid">
      <div class="ps-hcopy">
        <div class="ps-eyebrow ps-mb4"><span class="ps-tick"></span>Premium Support</div>
        <h1 class="ps-h1">The speed, clarity, and strategic help of a full team, <span class="accent">without the headcount.</span></h1>
        <p class="ps-lead ps-mt5">Expert guidance and fast answers in a dedicated Slack channel, direct from the people (and agents) who built OTP.</p>
        <div class="ps-cta ps-mt8">
          <a href="https://calendly.com/davidsteel/performance-call" target="_blank" rel="noopener" class="btn-primary px-8 py-4 text-[16px]">Speak with our team &rarr;</a>
        </div>
      </div>
      <div class="ps-hart">
        <img class="ps-float" src="/public/images/orgy/coach.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="Orgy, the OTP mascot, in a coach's cap giving a thumbs up">
        <p class="ps-hartcap">Your support specialist is already on the bench.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= THREE PILLARS ================= -->
<section class="ps-grey">
  <div class="ps-wrap ps-sec">
    <div class="ps-max640 ps-mb10">
      <div class="ps-eyebrow ps-mb4">What you get</div>
      <h2 class="ps-h2">Three things change the day you switch on Premium Support.</h2>
    </div>
    <div class="ps-pillars">
      <div class="ps-pillar">
        <div class="ps-pillar-n">01</div>
        <h3 class="ps-h3">Speed</h3>
        <p class="ps-body">No more waiting. Direct access via a dedicated Slack channel, answers in minutes, not days.</p>
      </div>
      <div class="ps-pillar">
        <div class="ps-pillar-n">02</div>
        <h3 class="ps-h3">Clarity</h3>
        <p class="ps-body">We don't just fix problems, we help prevent them. Your support comes from the team that built the product.</p>
      </div>
      <div class="ps-pillar">
        <div class="ps-pillar-n">03</div>
        <h3 class="ps-h3">Bandwidth</h3>
        <p class="ps-body">Premium Support acts like extra hands on your team, solving problems quickly so you can lead, sell, and execute.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= BEFORE / AFTER ================= -->
<section class="ps-paper">
  <div class="ps-wrap ps-sec">
    <div class="ps-max640 ps-mb10">
      <div class="ps-eyebrow ps-mb4">The difference you feel</div>
      <h2 class="ps-h2">Support that knows your setup, not a ticket queue.</h2>
    </div>
    <div class="ps-ba">
      <div class="ps-bacard before">
        <div class="ps-balabel">Before</div>
        <ul class="ps-balist">
          <li><span class="mark">&#10007;</span>Waiting on tickets</li>
          <li><span class="mark">&#10007;</span>Repeating your issue</li>
          <li><span class="mark">&#10007;</span>Digging through articles</li>
          <li><span class="mark">&#10007;</span>Guessing at best practices</li>
        </ul>
      </div>
      <div class="ps-bacard after">
        <div class="ps-balabel">After</div>
        <ul class="ps-balist">
          <li><span class="mark">&#10003;</span>Instant help via a dedicated Slack channel</li>
          <li><span class="mark">&#10003;</span>People who already know your setup</li>
          <li><span class="mark">&#10003;</span>Human walkthroughs over Zoom</li>
          <li><span class="mark">&#10003;</span>Expert EOS + agent guidance</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ================= STANDARD VS PREMIUM ================= -->
<section class="ps-grey">
  <div class="ps-wrap ps-sec">
    <div class="ps-max640 ps-mb10">
      <div class="ps-eyebrow ps-mb4">Side by side</div>
      <h2 class="ps-h2">Standard vs Premium, in one look.</h2>
    </div>
    <div class="cmp-card cmp-wrap" style="max-width:780px;">
      <table class="cmp">
        <thead><tr><th></th><th>Standard</th><th class="col-prem">Premium</th></tr></thead>
        <tbody>
          <tr><td>Response time</td><td>Up to 24 hrs</td><td class="col-prem strong">Under 15 minutes</td></tr>
          <tr><td>Dedicated Slack channel</td><td class="no">&#10007;</td><td class="col-prem yes">&#10003;</td></tr>
          <tr><td>Founder-led kick-off call</td><td class="no">&#10007;</td><td class="col-prem yes">&#10003;</td></tr>
          <tr><td>Quarterly business reviews (run inside OTP)</td><td class="no">&#10007;</td><td class="col-prem yes">&#10003;</td></tr>
          <tr><td>End-to-end ticket resolution</td><td class="no">&#10007;</td><td class="col-prem yes">&#10003;</td></tr>
          <tr><td>Direct call booking</td><td class="no">&#10007;</td><td class="col-prem yes">&#10003;</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ================= PRICING ================= -->
<section class="ps-paper">
  <div class="ps-wrap ps-sec">
    <div class="ps-price">
      <span class="ps-chip">Premium Support</span>
      <div class="ps-amount">$199 <span class="per">/month</span></div>
      <div class="ps-annual">$1,990 / year, save 17%</div>
      <p class="ps-body">Keep your org running smoothly with dedicated support, strategic insight, and minimal downtime.</p>
      <div class="ps-mt7" style="display:flex;justify-content:center;">
        <a href="https://calendly.com/davidsteel/performance-call" target="_blank" rel="noopener" class="btn-primary px-8 py-4 text-[16px]">Speak with our team &rarr;</a>
      </div>
      <p class="ps-fineprint">Founding-member pricing. Limited seats while we keep response times under 15 minutes.</p>
    </div>
  </div>
</section>

<!-- ================= WHY ================= -->
<section class="ps-grey">
  <div class="ps-wrap ps-sec ps-center" style="max-width:760px;">
    <h2 class="ps-h2">Why Premium Support? Because your time is too valuable.</h2>
    <p class="ps-lead ps-mt5 ps-max40" style="margin-left:auto;margin-right:auto;">Every hour you spend waiting on answers is an hour your business isn't growing. With Premium Support, our team, human and agent, becomes your team.</p>
  </div>
</section>
