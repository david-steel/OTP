<%# /industries/:industry -- v7 layout (light, editorial). One industry, list of orgs.
    Route locals: industry (string), orgs [{ id, name, badge, quality_tier,
    agentic_level, claim_count, size, template }].
    Render via reply.view('pages/industry-detail', data, { layout: 'layouts/v7' }). %>
<style>
  .id-float { animation:id-float 6.5s ease-in-out infinite; }
  @keyframes id-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-11px);} }
  .id-glow {
    position:absolute; left:50%; top:52%; width:80%; height:62%;
    transform:translate(-50%,-50%); z-index:0; pointer-events:none;
    background:radial-gradient(ellipse, rgba(189,214,34,0.26), transparent 70%);
  }
  @media (prefers-reduced-motion:reduce){ .id-float{ animation:none; } }
</style>

<!-- ================= INDUSTRY HEADER ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16">
    <a href="/industries" class="inline-flex items-center gap-1.5 font-mono text-[12px] text-[var(--ink-mute)] hover:text-[var(--ink)] transition-colors mb-7 group">
      <span class="group-hover:-translate-x-1 transition-transform">&larr;</span>
      All Industries
    </a>
    <div class="flex flex-col-reverse md:flex-row items-center gap-10">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--orgy);"></span>Industry
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.1rem,4.4vw,3.4rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
          <%= industry %> <span class="text-[var(--blue)]">AI agent coordination.</span>
        </h1>
        <p class="text-[16px] sm:text-[17px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mx-auto md:mx-0 mt-5">
          <%= orgs.length %> organization<%= orgs.length > 1 ? 's' : '' %> publishing coordination intelligence in <%= industry %>.
        </p>
      </div>
      <div class="relative shrink-0" style="width:170px; max-width:44vw;">
        <div class="id-glow"></div>
        <img src="/public/orgy-cut.png" alt="Orgy, the OTP mascot"
             class="id-float relative block w-full" style="z-index:1; filter:drop-shadow(0 18px 28px rgba(20,22,28,.18));">
      </div>
    </div>
  </div>
</section>

<!-- ================= ORG LIST ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">

    <div class="eyebrow mb-6">Organizations</div>
    <div class="grid sm:grid-cols-2 gap-4">
      <% orgs.forEach(function(org) { %>
        <a href="/org/<%= org.id %>" class="card lift p-6 block">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="flex flex-wrap items-center gap-2 min-w-0">
              <span class="font-display text-[var(--ink)] text-[1.1rem] font-bold leading-snug"><%= org.name %></span>
              <% if (org.badge === 'founding') { %>
                <span class="badge-founding text-white text-[10px] px-2 py-0.5 rounded-full">Founding</span>
              <% } %>
              <% if (org.quality_tier) { %>
                <span class="badge-<%= org.quality_tier %> text-white text-[10px] px-2 py-0.5 rounded-full capitalize"><%= org.quality_tier %></span>
              <% } %>
              <% if (org.agentic_level) { %>
                <span class="badge-level badge-level-<%= org.agentic_level %>">L<%= org.agentic_level %></span>
              <% } %>
            </div>
            <span class="font-mono text-[11px] text-[var(--ink-mute)] shrink-0 whitespace-nowrap"><%= org.claim_count %> claims</span>
          </div>
          <div class="font-mono text-[11px] uppercase tracking-[0.1em] text-[var(--ink-mute)]">
            <%= org.size %> &middot; <%= org.template.replace('_', ' ') %> template
          </div>
        </a>
      <% }); %>
    </div>

    <div class="mt-14 text-center">
      <a href="/publish" class="btn-primary inline-flex items-center gap-2 px-8 py-4 text-[16px] group">
        Publish your OOS
        <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>
    </div>
  </div>
</section>
