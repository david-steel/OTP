<%# /mcp-hub -- v7 layout (light, editorial). MCP integration: connect agents to OTP.
    Rendered via reply.view('pages/mcp-hub', data, { layout: 'layouts/v7' }). %>
<style>
  .mcp-float { animation:mcp-float 7s ease-in-out infinite; }
  @keyframes mcp-float { 0%,100%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-12px) rotate(-3deg);} }
  .mcp-code {
    background:var(--ink); border-radius:14px; padding:22px 24px; overflow-x:auto;
    box-shadow:0 1px 3px rgba(20,22,28,.06), 0 18px 40px -24px rgba(20,22,28,.4);
  }
  .mcp-code pre, .mcp-code code {
    font-family:'JetBrains Mono',monospace; font-size:13px; line-height:1.7;
    color:#d6d8de; white-space:pre;
  }
  .mcp-prompt {
    background:var(--white); border:1px solid var(--line); border-radius:10px;
    font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--ink-soft);
    padding:13px 16px;
  }
  @media (prefers-reduced-motion:reduce){ .mcp-float{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20 text-center">
    <div class="relative inline-block mb-7">
      <img src="/public/orgy-clean.png" alt="Ollie, the OTP mascot"
           class="mcp-float block mx-auto" style="width:96px; height:auto; filter:drop-shadow(0 16px 24px rgba(20,22,28,.18));">
    </div>
    <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center">
      <span class="tick" style="background:var(--blue);"></span>MCP Integration
    </div>
    <h1 class="font-display text-[var(--ink)] mx-auto"
        style="font-size:clamp(2.3rem,4.8vw,3.7rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em; max-width:18ch;">
      Connect your agents to <span class="text-[var(--blue)]">organizational intelligence.</span>
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[36rem] mx-auto mt-6">
      OTP exposes all OOS data via the Model Context Protocol. Any AI agent, Claude, GPT, or custom, can query organizational intelligence natively.
    </p>
    <p class="font-mono text-[13px] text-[var(--ink-mute)] mt-4">Not just a website. A protocol.</p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="#quick-start" class="btn-primary px-8 py-4 text-[16px]">Quick start &rarr;</a>
      <a href="#tools" class="btn-ghost px-8 py-4 text-[16px]">View tools</a>
    </div>
  </div>
</section>

<!-- ================= WHAT MCP IS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[720px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">The protocol</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.12]"
        style="font-size:clamp(1.7rem,3.4vw,2.5rem); font-weight:700;">
      Every data source should be an MCP server. Including your operating system.
    </h2>
    <div class="mt-6 space-y-4">
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.75]">
        The Model Context Protocol lets AI agents access external data sources as native tools. Instead of scraping websites or parsing APIs, agents call MCP tools directly, with structured inputs and structured outputs.
      </p>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.75]">
        OTP's MCP server turns the entire Intelligence Graph into a tool your agents can use. Browse published OOS files. Search across claims. Compare coordination patterns between organizations. All from inside your agent's workflow.
      </p>
      <p class="text-[16px] text-[var(--ink)] font-semibold leading-[1.75]">
        Your agent doesn't need to leave its environment to access organizational intelligence. It's already there.
      </p>
    </div>
  </div>
</section>

<!-- ================= AVAILABLE TOOLS ================= -->
<section id="tools" class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="max-w-[620px] mb-12">
      <div class="eyebrow mb-4">Available tools</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        What your agent can do.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        Each tool is a structured operation your agent can call directly via MCP.
      </p>
    </div>

    <%
      const mcpTools = [
        { name:'publish_oos',     desc:'Publish an OOS file programmatically. Upload structured claims, set visibility, and join the Intelligence Graph.' },
        { name:'browse_oos',      desc:'Browse published OOS files with filters for industry, size, template, and quality tier. Paginated results with metadata.' },
        { name:'get_oos',         desc:'Retrieve a specific OOS by ID. Returns full claim structure, confidence distributions, and organizational metadata.' },
        { name:'compare_oos',     desc:'Compare two OOS files side by side. Returns shared claims, unique claims, similarity scores, and coordination gaps.' },
        { name:'search_claims',   desc:'Search across all published claims using natural language. Filter by confidence, evidence level, section, and industry.' },
        { name:'get_publishers',  desc:'Browse organizations on the platform. Filter by industry, quality tier, and agentic maturity level.' },
      ];
    %>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% for (const tool of mcpTools) { %>
      <div class="card lift p-7">
        <div class="font-mono text-[12px] font-semibold text-[var(--blue-deep)] mb-3"><%= tool.name %>()</div>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.65]"><%= tool.desc %></p>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ================= QUICK START ================= -->
<section id="quick-start" class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-20 sm:py-24">
    <div class="mb-12">
      <div class="eyebrow mb-4">Quick start</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        Add OTP to your agent in 30 seconds.
      </h2>
    </div>

    <!-- Recommended: hosted Remote MCP (no install) -->
    <div class="mb-12 p-6 sm:p-7" style="background:var(--white); border:1px solid rgba(20,39,26,.10); border-radius:16px;">
      <div class="flex items-center gap-3 mb-2">
        <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold">Recommended: Remote connection (no install)</h3>
        <span class="eyebrow">Hosted &middot; paid</span>
      </div>
      <p class="text-[15px] text-[var(--ink-soft)] leading-[1.7]">
        On a paid plan you can connect with one hosted URL &mdash; no npx, no terminal. In Claude, go to
        <strong>Settings &rarr; Connectors &rarr; Add custom connector</strong>, paste
        <code style="background:rgba(20,39,26,.06);padding:1px 6px;border-radius:6px;">https://orgtp.com/api/mcp</code>, and sign in &mdash; one click, no token to copy.
        Prefer a token URL (for clients without sign-in support)? Generate one from
        <a href="/settings/api" class="text-[var(--blue-deep)] font-semibold link-u">Settings &rarr; API</a>.
        The steps below are the self-hosted alternative.
      </p>
    </div>

    <div class="space-y-10">
      <!-- Step 1 -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="font-display shrink-0 flex items-center justify-center text-white"
               style="width:32px; height:32px; border-radius:9px; font-weight:800; font-size:14px; background:var(--ink);">1</div>
          <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold">Self-hosted: add the MCP server to your config</h3>
        </div>
        <div class="ml-11">
          <div class="mcp-code"><pre><code>{
  "mcpServers": {
    "otp": {
      "command": "npx",
      "args": ["-y", "otp-mcp-server"],
      "env": {
        "OTP_API_KEY": "your-api-key"
      }
    }
  }
}</code></pre></div>
        </div>
      </div>

      <!-- Step 2 -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="font-display shrink-0 flex items-center justify-center text-white"
               style="width:32px; height:32px; border-radius:9px; font-weight:800; font-size:14px; background:var(--ink);">2</div>
          <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold">Get your API key</h3>
        </div>
        <p class="ml-11 text-[15px] text-[var(--ink-soft)] leading-[1.7]">
          Sign in to OTP and generate an API key from your <a href="/dashboard" class="text-[var(--blue-deep)] font-semibold link-u">dashboard</a>. Free tier includes API access.
        </p>
      </div>

      <!-- Step 3 -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="font-display shrink-0 flex items-center justify-center text-white"
               style="width:32px; height:32px; border-radius:9px; font-weight:800; font-size:14px; background:var(--ink);">3</div>
          <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold">Start querying</h3>
        </div>
        <p class="ml-11 text-[15px] text-[var(--ink-soft)] leading-[1.7] mb-4">
          Your agent can now access the full Intelligence Graph. Try these natural language prompts:
        </p>
        <div class="ml-11 space-y-2.5">
          <div class="mcp-prompt">"Browse all published OOS files in the AI services industry"</div>
          <div class="mcp-prompt">"Search for claims about agent escalation patterns"</div>
          <div class="mcp-prompt">"Compare Sneeze It's OOS with the Expert Coach template"</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= USE CASES ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="max-w-[620px] mb-12">
      <div class="eyebrow mb-4">Use cases</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        What agents do with organizational intelligence.
      </h2>
    </div>

    <%
      const mcpUseCases = [
        { title:'Agent Onboarding',   body:'Agent reads the organization’s OOS on first run to understand coordination rules, authority boundaries, and escalation paths. No manual configuration.' },
        { title:'Cross-Org Discovery', body:'Agent searches for organizations with similar coordination patterns. Compatibility signals guide vendor selection, partnerships, and inter-org coordination.' },
        { title:'Continuous Learning', body:'Agent periodically queries the Intelligence Graph for new patterns in its industry. Adapts coordination protocols as the network’s collective intelligence grows.' },
        { title:'Compliance Checking', body:'Agent validates its actions against published authority boundaries. Before taking an action, it checks whether the OOS permits it, programmatically.' },
      ];
    %>
    <div class="grid sm:grid-cols-2 gap-5">
      <% for (const uc of mcpUseCases) { %>
      <div class="card lift p-7">
        <h3 class="font-display text-[var(--ink)] text-[1.15rem] font-bold mb-2"><%= uc.title %></h3>
        <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]"><%= uc.body %></p>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(2rem,4.4vw,3.2rem); font-weight:800;">
      Ready to connect your agents?
    </h2>
    <p class="text-[17px] leading-[1.6] max-w-[34rem] mx-auto mt-6" style="color:#5a2a06;">
      Get your API key and start querying organizational intelligence from inside your agent's workflow.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/dashboard" class="btn-ink px-8 py-4 text-[16px]">Get your API key &rarr;</a>
      <a href="/guide" class="btn-ghost px-8 py-4 text-[16px]" style="border-color:rgba(20,22,28,.3);">Read the guide</a>
    </div>
  </div>
</section>
