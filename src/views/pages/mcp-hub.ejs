<!-- Section 3: Quick Start -->
<section id="quick-start" class="bg-white py-16 sm:py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <p class="text-otp-500 text-sm font-semibold uppercase tracking-widest mb-4">Quick start</p>
      <h2 class="text-3xl font-extrabold text-gray-900">Add OTP to your agent in 30 seconds.</h2>
    </div>

    <div class="space-y-8">
      <!-- Step 1 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-full bg-otp-500 text-white flex items-center justify-center text-sm font-bold shrink-0">1</div>
          <h3 class="font-bold text-gray-900">Add the MCP server to your config</h3>
        </div>
        <div class="ml-11 bg-otp-950 rounded-xl p-5 overflow-x-auto">
          <pre class="text-sm text-gray-300 font-mono leading-relaxed"><code>{
  "mcpServers": {
    "otp": {
      "command": "npx",
      "args": ["-y", "otp-mcp-server"],
      "env": {
        "OTP_API_KEY": "your-api-key"
      }
    }
  }
}</code></pre>
        </div>
      </div>

      <!-- Step 2 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-full bg-otp-500 text-white flex items-center justify-center text-sm font-bold shrink-0">2</div>
          <h3 class="font-bold text-gray-900">Get your API key</h3>
        </div>
        <p class="ml-11 text-gray-600">Sign in to OTP and generate an API key from your <a href="/dashboard" class="text-otp-500 hover:text-otp-400 font-medium">dashboard</a>. Free tier includes API access.</p>
      </div>

      <!-- Step 3 -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-full bg-otp-500 text-white flex items-center justify-center text-sm font-bold shrink-0">3</div>
          <h3 class="font-bold text-gray-900">Start querying</h3>
        </div>
        <p class="ml-11 text-gray-600 mb-3">Your agent can now access the full Intelligence Graph. Try these natural language prompts:</p>
        <div class="ml-11 space-y-2">
          <div class="bg-gray-50 rounded-lg px-4 py-3 text-sm text-gray-700 font-mono">"Browse all published OOS files in the AI services industry"</div>
          <div class="bg-gray-50 rounded-lg px-4 py-3 text-sm text-gray-700 font-mono">"Search for claims about agent escalation patterns"</div>
          <div class="bg-gray-50 rounded-lg px-4 py-3 text-sm text-gray-700 font-mono">"Compare Sneeze It's OOS with the Expert Coach template"</div>
        </div>
      </div>
    </div>
  </div>
</section>

