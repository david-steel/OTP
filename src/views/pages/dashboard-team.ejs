<% if (teamNodes.length > 1) { %>
<script>
  (function() {
    var nodes = <%- JSON.stringify(teamNodes) %>;
    var edges = <%- JSON.stringify(teamEdges) %>;
    var claimedTileMap = <%- JSON.stringify(typeof claimedTileMap !== 'undefined' ? claimedTileMap : {}) %>;
    var tileTeamsMap = <%- JSON.stringify(typeof tileTeamsMap !== 'undefined' ? tileTeamsMap : {}) %>;
    var pendingInviteByTile = <%- JSON.stringify(typeof pendingInviteByTile !== 'undefined' ? pendingInviteByTile : {}) %>;
    var viewerRole = <%- JSON.stringify(typeof viewerRole !== 'undefined' ? viewerRole : null) %>;
    var viewerClaimedEntityId = <%- JSON.stringify(typeof viewerClaimedEntityId !== 'undefined' ? viewerClaimedEntityId : null) %>;
    var viewerClaimedEntityIds = <%- JSON.stringify(typeof viewerClaimedEntityIds !== 'undefined' ? viewerClaimedEntityIds : []) %>;
    // Phase 3: gated edit. The server precomputes which chart tiles this
    // viewer is allowed to edit (whole tree visible, edit gated by role +
    // chain of command + claimed seats). The Set lookup keeps client gates
    // O(1). Server-side enforcement still runs on every mutation API call.
    var EDITABLE_TILES = new Set(<%- JSON.stringify(typeof editableTiles !== 'undefined' ? editableTiles : []) %>);
    function canEditTile(externalId) {
      // Owners pre-Phase-1-backfill have viewerRole='owner' but no member
      // row, so editableTiles may be empty. Fall back to viewerRole.
      if (viewerRole === 'owner') return true;
      return EDITABLE_TILES.has(externalId);
    }

    // Skill / command highlight: arriving from /admin/skills with
    // ?highlightSkill= or ?highlightCommand= dims every tile that doesn't
    // declare the relevant skill or slash command.
    var HIGHLIGHT_SKILL = <%- JSON.stringify(typeof highlightSkill !== 'undefined' ? (highlightSkill || '') : '') %>;
    var HIGHLIGHT_COMMAND = <%- JSON.stringify(typeof highlightCommand !== 'undefined' ? (highlightCommand || '') : '') %>;

    function readListLoose(raw) {
      if (Array.isArray(raw)) return raw.map(function(s) { return String(s || '').trim(); }).filter(Boolean);
      if (typeof raw === 'string') return raw.split(/[,;\n]/).map(function(s) { return s.trim(); }).filter(Boolean);
      return [];
    }
    function nodeHasSkill(n, skillLower) {
      if (!skillLower) return true;
      var skills = readListLoose(n && n.properties && n.properties.skills);
      for (var i = 0; i < skills.length; i++) {
        if (skills[i].toLowerCase() === skillLower) return true;
      }
      return false;
    }
    function nodeHasCommand(n, cmdLower) {
      if (!cmdLower) return true;
      var commands = readListLoose(n && n.properties && n.properties.slashCommands);
      var target = cmdLower.replace(/^\//, '');
      for (var i = 0; i < commands.length; i++) {
        var c = commands[i].toLowerCase().replace(/^\//, '');
        if (c === target) return true;
      }
      return false;
    }
    function nodeMatchesHighlight(n) {
      if (HIGHLIGHT_SKILL && !nodeHasSkill(n, HIGHLIGHT_SKILL.toLowerCase())) return false;
      if (HIGHLIGHT_COMMAND && !nodeHasCommand(n, HIGHLIGHT_COMMAND.toLowerCase())) return false;
      return true;
    }
    if (HIGHLIGHT_SKILL || HIGHLIGHT_COMMAND) {
      window.addEventListener('DOMContentLoaded', function() {
        var label = HIGHLIGHT_COMMAND
          ? ('command <strong>/' + HIGHLIGHT_COMMAND.replace(/^\//, '') + '</strong>')
          : ('skill <strong>' + HIGHLIGHT_SKILL + '</strong>');
        var banner = document.createElement('div');
        banner.style.cssText = 'position:sticky;top:0;z-index:50;background:#fef3c7;border-bottom:1px solid #fcd34d;padding:0.5rem 1rem;font-size:13px;color:#92400e;display:flex;justify-content:space-between;align-items:center;';
        banner.innerHTML = 'Highlighting tiles with ' + label +
          '<a href="/dashboard/team" style="text-decoration:underline;color:#92400e;font-size:12px;">clear filter</a>';
        document.body.insertBefore(banner, document.body.firstChild);
      });
    }
    var comparisonPairs = <%- JSON.stringify(typeof comparisonPairs !== 'undefined' ? comparisonPairs : []) %>;
    var SKILLS_CATALOG = <%- JSON.stringify(typeof skillsCatalog !== 'undefined' ? skillsCatalog : []) %>;
    var ALL_CATALOG_SKILLS = SKILLS_CATALOG.reduce(function(acc, c) { return acc.concat(c.skills); }, []);
    var ALL_CATALOG_SKILLS_LOWER = new Set(ALL_CATALOG_SKILLS.map(function(s) { return s.toLowerCase(); }));
    var currentSkills = []; // working array, edited in the panel
    var currentMcps = []; // MCP servers / integrations on this seat

    // Show / hide custom authority input based on dropdown choice.
    document.addEventListener('DOMContentLoaded', function() {
      // Publish-draft button (only present when there's an unpublished draft).
      // All response handling -- including the chart-contacts choice
      // modal, real-PII bullets, and any future error code -- lives in
      // the shared OTP.publishOOS helper from the include below. Drift
      // between publish surfaces is impossible by construction.
      var publishBtn = document.getElementById('btn-publish-team');
      var publishMsg = document.getElementById('publish-team-msg');
      if (publishBtn) {
        publishBtn.addEventListener('click', function() {
          var oosFileId = publishBtn.getAttribute('data-oos-file-id');
          if (!oosFileId) return;
          OTP.publishOOS({
            oosFileId: oosFileId,
            msgEl: publishMsg,
            btnEl: publishBtn,
            initialConfirm: 'Publish this team chart draft as the new live OOS for your org? Other agents reading the OOS will see the new structure.',
          });
        });
      }

      var authSel = document.getElementById('ef-authority');
      var authCustom = document.getElementById('ef-authority-custom');
      if (authSel && authCustom) {
        authSel.addEventListener('change', function() {
          if (authSel.value === '__custom__') {
            authCustom.style.display = '';
            authCustom.focus();
          } else {
            authCustom.style.display = 'none';
            authCustom.value = '';
          }
        });
      }

      // MCP tag-input wiring (mirrors skills, no catalog autocomplete).
      var mcpInput = document.getElementById('ef-mcps-input');
      if (mcpInput) {
        mcpInput.addEventListener('keydown', function(ev) {
          if (ev.key === 'Enter' || ev.key === ',') {
            ev.preventDefault();
            addMcp(mcpInput.value);
            mcpInput.value = '';
          } else if (ev.key === 'Backspace' && !mcpInput.value && currentMcps.length > 0) {
            currentMcps.pop();
            renderMcpTags();
          }
        });
        mcpInput.addEventListener('blur', function() {
          if (mcpInput.value.trim()) { addMcp(mcpInput.value); mcpInput.value = ''; }
        });
      }
    });

    function renderMcpTags() {
      var box = document.getElementById('ef-mcps-tag-input');
      var input = document.getElementById('ef-mcps-input');
      if (!box || !input) return;
      // Remove all chips (keep input element only)
      Array.from(box.querySelectorAll('.skill-chip')).forEach(function(el) { el.remove(); });
      currentMcps.forEach(function(m, idx) {
        var chip = document.createElement('span');
        chip.className = 'skill-chip';
        chip.style.background = '#d1fae5';
        chip.style.color = '#065f46';
        chip.style.borderColor = '#a7f3d0';
        chip.innerHTML = escapeHtml(m) + ' <button type="button" aria-label="Remove" style="margin-left:0.3rem; cursor:pointer; border:none; background:transparent; color:inherit; font-weight:700;">&times;</button>';
        chip.querySelector('button').addEventListener('click', function() {
          currentMcps.splice(idx, 1);
          renderMcpTags();
        });
        box.insertBefore(chip, input);
      });
    }

    function addMcp(raw) {
      var v = String(raw || '').trim().toLowerCase();
      if (!v) return;
      if (currentMcps.some(function(x) { return String(x).toLowerCase() === v; })) return;
      currentMcps.push(v);
      renderMcpTags();
    }
    var skillSuggestionActive = -1;

    function renderSkillTags() {
      var box = document.getElementById('ef-skills-tag-input');
      var input = document.getElementById('ef-skills-input');
      if (!box || !input) return;
      // Clear all children except the input
      Array.from(box.children).forEach(function(c) { if (c !== input) c.remove(); });
      currentSkills.forEach(function(skill, idx) {
        var isCustom = !ALL_CATALOG_SKILLS_LOWER.has(String(skill).toLowerCase());
        var pill = document.createElement('span');
        pill.className = 'skill-tag' + (isCustom ? ' custom' : '');
        pill.innerHTML = escapeHtml(skill) + ' <span class="remove" onclick="removeSkill(' + idx + ')" title="Remove">&times;</span>';
        box.insertBefore(pill, input);
      });
    }

    window.removeSkill = function(idx) {
      currentSkills.splice(idx, 1);
      renderSkillTags();
    };

    function addSkillNormalized(raw) {
      var s = String(raw || '').trim();
      if (!s) return false;
      // Match canonical case if it's in the catalog
      var lower = s.toLowerCase();
      var canonical = ALL_CATALOG_SKILLS.find(function(x) { return x.toLowerCase() === lower; });
      var toAdd = canonical || s;
      // Dedupe (case-insensitive)
      var has = currentSkills.some(function(x) { return String(x).toLowerCase() === toAdd.toLowerCase(); });
      if (has) return false;
      currentSkills.push(toAdd);
      renderSkillTags();
      return true;
    }

    function showSkillSuggestions(query) {
      var list = document.getElementById('ef-skills-suggestions');
      var q = String(query || '').trim().toLowerCase();
      var html = '';
      var matchCount = 0;
      SKILLS_CATALOG.forEach(function(cat) {
        var matches = cat.skills.filter(function(s) {
          if (currentSkills.some(function(x) { return String(x).toLowerCase() === s.toLowerCase(); })) return false;
          return q === '' || s.toLowerCase().indexOf(q) !== -1;
        });
        if (matches.length === 0) return;
        html += '<div class="skill-suggestion-cat">' + escapeHtml(cat.category) + '</div>';
        matches.forEach(function(s) {
          html += '<div class="skill-suggestion" data-skill="' + escapeHtml(s) + '" onclick="acceptSkillSuggestion(\'' + s.replace(/'/g, "\\'") + '\')">' + escapeHtml(s) + '</div>';
          matchCount++;
        });
      });
      // Custom-add row when the query is non-empty and not already in catalog
      if (q && !ALL_CATALOG_SKILLS_LOWER.has(q) && !currentSkills.some(function(x) { return String(x).toLowerCase() === q; })) {
        html += '<div class="skill-suggestion add-custom" onclick="acceptCustomSkill()">+ Add &quot;' + escapeHtml(q) + '&quot; as a custom skill</div>';
      }
      if (html) {
        list.innerHTML = html;
        list.classList.add('open');
        skillSuggestionActive = -1;
      } else {
        list.classList.remove('open');
      }
    }

    function hideSkillSuggestions() {
      var list = document.getElementById('ef-skills-suggestions');
      if (list) list.classList.remove('open');
      skillSuggestionActive = -1;
    }

    window.acceptSkillSuggestion = function(skill) {
      addSkillNormalized(skill);
      var input = document.getElementById('ef-skills-input');
      if (input) { input.value = ''; input.focus(); }
      hideSkillSuggestions();
    };

    window.acceptCustomSkill = function() {
      var input = document.getElementById('ef-skills-input');
      if (!input) return;
      addSkillNormalized(input.value);
      input.value = '';
      input.focus();
      hideSkillSuggestions();
    };

    document.addEventListener('DOMContentLoaded', function() {
      var input = document.getElementById('ef-skills-input');
      if (!input) return;
      input.addEventListener('input', function() { showSkillSuggestions(input.value); });
      input.addEventListener('focus', function() { showSkillSuggestions(input.value); });
      input.addEventListener('keydown', function(ev) {
        if (ev.key === 'Enter') {
          ev.preventDefault();
          if (input.value.trim()) {
            addSkillNormalized(input.value);
            input.value = '';
            hideSkillSuggestions();
          }
        } else if (ev.key === 'Backspace' && !input.value && currentSkills.length > 0) {
          currentSkills.pop();
          renderSkillTags();
        } else if (ev.key === 'Escape') {
          hideSkillSuggestions();
        }
      });
      // Close suggestions when clicking outside
      document.addEventListener('click', function(ev) {
        var box = document.getElementById('ef-skills-tag-input');
        var list = document.getElementById('ef-skills-suggestions');
        if (!box || !list) return;
        if (!box.contains(ev.target) && !list.contains(ev.target)) hideSkillSuggestions();
      });
    });

    var byId = {};
    nodes.forEach(function(n) { byId[n.id] = n; });

    // ---- Build parent map from escalation edges + sensible defaults ----
    function computeParents(filterFn) {
      var parent = {};
      var allowed = {};
      nodes.forEach(function(n) { if (filterFn(n)) allowed[n.id] = true; });

      // explicit hierarchy edges (child -> parent)
      edges.forEach(function(e) {
        if (e.type !== 'escalates_to' && e.type !== 'reports_to') return;
        if (!allowed[e.sourceId] || !allowed[e.targetId]) return;
        // reports_to wins over escalates_to if both present (humans use reports_to)
        if (e.type === 'reports_to' || !parent[e.sourceId]) {
          parent[e.sourceId] = e.targetId;
        }
      });

      // Find CEO-ish humans to anchor unparented nodes. MULTIPLE co-equal
      // leaders (co-owners, co-CEOs, EOS Visionary + Integrator) all sit
      // directly under the org, side by side -- not nested under the first
      // one. `ceo` is just the first of them, used as the fallback parent for
      // executives/operators/agents that have no explicit reports_to.
      var ceo = null, coo = null;
      var topHumans = {};
      nodes.forEach(function(n) {
        if (!allowed[n.id]) return;
        if (n.type !== 'human') return;
        var p = n.properties || {};
        if (p.authorityLevel === 'full' || /CEO|founder|visionary/i.test(p.role || '')) {
          topHumans[n.id] = true;
          if (!ceo) ceo = n.id;
        }
        if (p.authorityLevel === 'executive' || /COO/i.test(p.role || '')) { if (!coo) coo = n.id; }
      });
      var orgNode = nodes.find(function(n) { return n.type === 'organization' && allowed[n.id]; });
      var orgId = orgNode ? orgNode.id : null;

      // For everyone without a parent (other than the org node itself) wire to:
      //   CEO if found, else ORG. Operators-without-parent prefer COO if present.
      nodes.forEach(function(n) {
        if (!allowed[n.id]) return;
        if (n.id === orgId) return;
        if (parent[n.id]) return;
        var p = n.properties || {};
        if (n.type === 'human') {
          if (topHumans[n.id]) {
            parent[n.id] = orgId; // co-equal leaders: direct children of org, side by side
          } else if (n.id === coo) {
            parent[n.id] = ceo || orgId;
          } else {
            // operator humans: prefer COO, else CEO, else ORG
            parent[n.id] = coo || ceo || orgId;
          }
        } else if (n.type === 'agent') {
          parent[n.id] = ceo || orgId;
        }
      });

      // Org node has no parent (it is the root)
      return { parent: parent, rootId: orgId };
    }

    // ---- Layout + render ----
    // NODE_H = 104 fits the worst-case employee tile (2-line role +
    // meta + contacts row); was 80 and the bottom was getting clipped
    // for humans with contact pills. David flagged 2026-05-24.
    var NODE_W = 200;
    var NODE_H = 104;
    var H_GAP  = 18;
    var V_GAP  = 44;

    function buildHierarchy(filterFn) {
      var pm = computeParents(filterFn);
      var allowedNodes = nodes.filter(filterFn);
      // d3.stratify needs a single rooted tree
      try {
        return d3.stratify().id(function(d) { return d.id; }).parentId(function(d) { return d.id === pm.rootId ? null : pm.parent[d.id]; })(allowedNodes);
      } catch (e) {
        // Fallback: synthesize a virtual root if multiple roots exist
        var data = allowedNodes.slice();
        var virtId = '__VIRT__';
        data.unshift({ id: virtId, externalId: virtId, type: 'organization', label: 'Team', properties: {} });
        var pm2 = pm.parent;
        return d3.stratify().id(function(d) { return d.id; }).parentId(function(d) {
          if (d.id === virtId) return null;
          return pm2[d.id] || virtId;
        })(data);
      }
    }

    var stage = document.getElementById('org-stage');
    var shell = document.getElementById('org-shell');
    var tooltip = document.getElementById('org-tooltip');

    function renderChart(filterFn) {
      stage.innerHTML = '';
      // If the active filter matches no people (e.g. "Agents only" on an org
      // that has only humans, or vice versa), show a helpful message instead
      // of a blank canvas that reads as broken. (2026-06-02 -- Clear Skies had
      // 7 humans, 0 agents; a stale "Agents" filter rendered nothing.)
      var visiblePeople = nodes.filter(function(n) { return n.type !== 'organization' && filterFn(n); });
      if (visiblePeople.length === 0) {
        var labelFor = (currentFilter === 'agent') ? 'agents' : (currentFilter === 'human') ? 'humans' : 'people';
        var empty = document.createElement('div');
        empty.style.cssText = 'padding:3rem 2rem; text-align:center; color:#6b7280; font-size:14px;';
        empty.textContent = 'No ' + labelFor + ' on this chart yet. ';
        var showAll = document.createElement('button');
        showAll.type = 'button';
        showAll.textContent = 'Show all';
        showAll.style.cssText = 'color:#2563eb; font-weight:600; text-decoration:underline; background:none; border:none; cursor:pointer;';
        showAll.addEventListener('click', function() {
          var b = document.querySelector('.filter-btn[data-filter="all"]');
          if (b) b.click();
        });
        empty.appendChild(showAll);
        stage.appendChild(empty);
        return;
      }
      var root;
      try { root = buildHierarchy(filterFn); }
      catch (e) { stage.innerHTML = '<div style="padding:2rem;color:#6b7280;font-size:14px;">Could not build hierarchy: ' + e.message + '</div>'; return; }

      var layout = d3.tree().nodeSize([NODE_W + H_GAP, NODE_H + V_GAP]);
      layout(root);

      var minX = Infinity, maxX = -Infinity, maxY = 0;
      root.each(function(d) {
        if (d.x < minX) minX = d.x;
        if (d.x > maxX) maxX = d.x;
        if (d.y > maxY) maxY = d.y;
      });
      var pad = 24;
      var offsetX = -minX + pad;
      var totalWidth  = (maxX - minX) + NODE_W + pad * 2;
      var totalHeight = maxY + NODE_H + pad * 2;
      stage.style.width  = totalWidth  + 'px';
      stage.style.height = totalHeight + 'px';

      // SVG layer for connectors
      var svgNS = 'http://www.w3.org/2000/svg';
      var svg = document.createElementNS(svgNS, 'svg');
      svg.setAttribute('width', totalWidth);
      svg.setAttribute('height', totalHeight);
      svg.style.position = 'absolute';
      svg.style.inset = '0';
      svg.style.pointerEvents = 'none';
      stage.appendChild(svg);

      root.each(function(d) {
        if (!d.parent) return;
        var px = d.parent.x + offsetX + NODE_W / 2;
        var py = d.parent.y + NODE_H + pad;
        var cx = d.x + offsetX + NODE_W / 2;
        var cy = d.y + pad;
        var midY = py + (cy - py) / 2;
        var path = document.createElementNS(svgNS, 'path');
        var edgeType;
        if (d.parent.data.id === '__VIRT__') edgeType = 'part_of';
        else if (d.data.type === 'human') edgeType = 'reports_to';
        else edgeType = 'escalates_to';
        path.setAttribute('d', 'M ' + px + ',' + py + ' L ' + px + ',' + midY + ' L ' + cx + ',' + midY + ' L ' + cx + ',' + cy);
        path.setAttribute('class', 'org-connector ' + edgeType);
        svg.appendChild(path);
      });

      // ---- Same-role comparison curves (Phase 4.8) ----
      // Map node ids to layout coordinates for paired lookups.
      var coordsById = {};
      root.each(function(d) {
        if (d.data.id === '__VIRT__') return;
        coordsById[d.data.id] = { x: d.x + offsetX, y: d.y + pad };
      });
      comparisonPairs.forEach(function(pair) {
        var a = coordsById[pair.a];
        var b = coordsById[pair.b];
        if (!a || !b) return;
        var ax = a.x + NODE_W / 2;
        var ay = a.y + NODE_H / 2;
        var bx = b.x + NODE_W / 2;
        var by = b.y + NODE_H / 2;
        // Curved bezier above the midpoint -- distinguishes from orthogonal connectors
        var midX = (ax + bx) / 2;
        var topY = Math.min(ay, by) - Math.max(60, Math.abs(bx - ax) / 4);
        var path = document.createElementNS(svgNS, 'path');
        path.setAttribute('d', 'M ' + ax + ',' + ay + ' Q ' + midX + ',' + topY + ' ' + bx + ',' + by);
        path.setAttribute('class', 'org-comparison');
        path.dataset.pairA = pair.a;
        path.dataset.pairB = pair.b;
        path.dataset.reason = pair.reason || '';
        path.addEventListener('click', function(ev) {
          ev.stopPropagation();
          openCompare(pair.a, pair.b, pair.reason);
        });
        path.addEventListener('mouseenter', function(ev) {
          showTooltip(ev, { label: 'Compare these agents', type: 'comparison', properties: { role: pair.reason } });
        });
        path.addEventListener('mouseleave', function() { hideTooltip(); });
        svg.appendChild(path);
      });

      root.each(function(d) {
        if (d.data.id === '__VIRT__') return;
        var x = d.x + offsetX;
        var y = d.y + pad;
        var n = d.data;
        var p2 = n.properties || {};
        var statusLower = String(p2.status || '').toLowerCase();
        var isInactive = ['inactive', 'retired', 'terminated'].indexOf(statusLower) !== -1;
        var isClaimed = (n.type === 'human' && claimedTileMap[n.externalId]);
        var box = document.createElement('div');
        var dimByHighlight = (HIGHLIGHT_SKILL || HIGHLIGHT_COMMAND) && !nodeMatchesHighlight(n);
        box.className = 'org-node type-' + n.type + (isInactive ? ' inactive' : '') + (isClaimed ? ' claimed' : '') + (dimByHighlight ? ' skill-dim' : '');
        box.style.left = x + 'px';
        box.style.top  = y + 'px';
        box.style.width  = NODE_W + 'px';
        box.style.height = NODE_H + 'px';

        var inner = '';
        if (n.type !== 'organization') inner += '<div class="stripe"></div>';
        var p = n.properties || {};
        var typeLabel = n.type === 'agent' ? 'Agent' : (n.type === 'human' ? 'Human' : 'Org');
        var sopCount = Array.isArray(p.sops) ? p.sops.length : 0;
        inner += '<div class="row-top">';
        inner += '<div class="name" title="' + escapeHtml(n.label) + '">' + escapeHtml(n.label) + '</div>';
        if (n.type !== 'organization') {
          var typePill = '<div class="badge-type">' + typeLabel + '</div>';
          var sopPill = sopCount > 0 ? '<div class="sop-badge" title="' + sopCount + ' SOP' + (sopCount === 1 ? '' : 's') + '">' + sopCount + ' SOP' + (sopCount === 1 ? '' : 's') + '</div>' : '';
          var claimPill = isClaimed ? '<div class="claimed-badge" title="Claimed by member">claimed</div>' : '';
          inner += '<div style="display:flex; align-items:center; gap:0.25rem; flex-shrink:0;">' + claimPill + sopPill + typePill + '</div>';
        }
        inner += '</div>';
        if (p.role) inner += '<div class="role" title="' + escapeHtml(String(p.role)) + '">' + escapeHtml(String(p.role)) + '</div>';
        var meta = [];
        if (p.authorityLevel) meta.push(escapeHtml(String(p.authorityLevel)));
        if (p.platform) meta.push(escapeHtml(String(p.platform)));
        if (p.status) meta.push(escapeHtml(String(p.status)));
        if (meta.length) inner += '<div class="meta">' + meta.map(function(m) { return '<span>' + m + '</span>'; }).join('') + '</div>';

        if (n.type === 'human') {
          var contacts = [];
          if (p.contactEmail) contacts.push('<span class="contact-pill" title="' + escapeHtml(String(p.contactEmail)) + '">@</span>');
          if (p.contactPhone) contacts.push('<span class="contact-pill" title="' + escapeHtml(String(p.contactPhone)) + '">tel</span>');
          if (p.slackId) contacts.push('<span class="contact-pill" title="Slack: ' + escapeHtml(String(p.slackId)) + '">slack</span>');
          if (contacts.length) inner += '<div class="contacts">' + contacts.join('') + '</div>';
        }

        box.innerHTML = inner;

        // Phase 3: append a "+" button to add a child report under this tile.
        // Visible whenever the viewer can edit this tile (owner/admin/implementer
        // see it everywhere; managers see it on tiles in their subtree).
        // Clicking the button does not propagate to the tile click (which would open edit).
        if (canEditTile(n.externalId) && n.type !== 'organization') {
          var addBtn = document.createElement('button');
          addBtn.type = 'button';
          addBtn.className = 'org-add-child-btn';
          addBtn.title = 'Add a tile that reports to / escalates to this one';
          addBtn.textContent = '+';
          addBtn.addEventListener('click', function(ev) {
            ev.stopPropagation();
            // For human parents, suggest creating an agent under them (the common pattern).
            // For agent parents, suggest another agent (escalation chain).
            var suggested = (n.type === 'human') ? 'agent' : 'agent';
            openCreateDrawer(suggested, n.externalId);
          });
          box.appendChild(addBtn);
        }

        box.addEventListener('mouseenter', function(ev) { showTooltip(ev, n); });
        box.addEventListener('mousemove',  function(ev) { positionTooltip(ev); });
        box.addEventListener('mouseleave', function() { hideTooltip(); });
        if (n.type !== 'organization') {
          box.addEventListener('click', function(ev) {
            ev.stopPropagation();
            document.querySelectorAll('.org-node.selected').forEach(function(el) { el.classList.remove('selected'); });
            box.classList.add('selected');
            openEditPanel(n);
          });

          // ---- Drag-and-drop hierarchy editing ----
          box.setAttribute('draggable', 'true');
          box.dataset.nodeId = n.id;
          box.dataset.nodeType = n.type;
          box.dataset.externalId = n.externalId;

          box.addEventListener('dragstart', function(ev) {
            ev.dataTransfer.effectAllowed = 'move';
            ev.dataTransfer.setData('text/plain', n.id);
            box.classList.add('dragging');
            window.__dragSource = { node: n, descendants: collectDescendantIds(d) };
            hideTooltip();
            showDragStatus('Drag onto a target to make it the new parent.');
          });
          box.addEventListener('dragend', function() {
            box.classList.remove('dragging');
            document.querySelectorAll('.org-node.drop-target,.org-node.drop-invalid').forEach(function(el) {
              el.classList.remove('drop-target','drop-invalid');
            });
            window.__dragSource = null;
            hideDragStatus();
          });
          box.addEventListener('dragover', function(ev) {
            if (!window.__dragSource) return;
            var src = window.__dragSource;
            if (n.id === src.node.id) return;
            ev.preventDefault();
            var invalid = src.descendants.has(n.id);
            ev.dataTransfer.dropEffect = invalid ? 'none' : 'move';
            box.classList.toggle('drop-target', !invalid);
            box.classList.toggle('drop-invalid', invalid);
          });
          box.addEventListener('dragleave', function() {
            box.classList.remove('drop-target','drop-invalid');
          });
          box.addEventListener('drop', function(ev) {
            ev.preventDefault();
            box.classList.remove('drop-target','drop-invalid');
            var src = window.__dragSource;
            if (!src) return;
            if (n.id === src.node.id) return;
            if (src.descendants.has(n.id)) {
              showDragStatus('Cannot drop ' + src.node.label + ' onto its own descendant.', true);
              setTimeout(hideDragStatus, 2400);
              return;
            }
            handleHierarchyDrop(src.node, n);
          });
        }

        stage.appendChild(box);
      });
    }

    function collectDescendantIds(d) {
      var set = new Set();
      d.descendants().forEach(function(x) { set.add(x.data.id); });
      return set;
    }

    var dragStatusEl = null;
    function showDragStatus(msg, isError) {
      if (!dragStatusEl) {
        dragStatusEl = document.createElement('div');
        dragStatusEl.className = 'drag-status';
        document.body.appendChild(dragStatusEl);
      }
      dragStatusEl.textContent = msg;
      dragStatusEl.style.background = isError ? 'rgba(153,27,27,0.95)' : 'rgba(15,23,42,0.92)';
      dragStatusEl.classList.add('visible');
    }
    function hideDragStatus() { if (dragStatusEl) dragStatusEl.classList.remove('visible'); }

    function handleHierarchyDrop(srcNode, targetNode) {
      var fieldKey = srcNode.type === 'agent' ? 'escalates_to' : 'reports_to';
      var patch = {};
      patch[fieldKey] = targetNode.externalId;
      showDragStatus('Saving ' + srcNode.label + ' -> ' + targetNode.label + '…');
      OTP.apiSave({
        method: 'PATCH', url: '/api/v1/team/entity',
        body: { type: srcNode.type, externalId: srcNode.externalId, patch: patch },
        onSuccess: function() {
          showDragStatus('Saved. Reloading…');
          window.location.reload();
        },
        onError: function(err) {
          showDragStatus(OTP.formatError(err, 'Save failed'), true);
          setTimeout(hideDragStatus, 2400);
          return true;
        },
      });
    }

    function escapeHtml(s) { return String(s).replace(/[&<>"']/g, function(c) { return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c]; }); }
    function showTooltip(ev, n) {
      var p = n.properties || {};
      var html = '<div class="ttl">' + escapeHtml(n.label) + '</div>';
      html += '<div class="row"><strong>Type:</strong> ' + n.type + '</div>';
      if (p.role) html += '<div class="row"><strong>Role:</strong> ' + escapeHtml(String(p.role)) + '</div>';
      if (p.mission) html += '<div class="row"><strong>Mission:</strong> ' + escapeHtml(String(p.mission)) + '</div>';
      if (p.authorityLevel) html += '<div class="row"><strong>Authority:</strong> ' + escapeHtml(String(p.authorityLevel)) + '</div>';
      if (Array.isArray(p.skills) && p.skills.length) html += '<div class="row"><strong>Skills:</strong> ' + escapeHtml(p.skills.join(', ')) + '</div>';
      var ownSops = Array.isArray(p.sops) ? p.sops.length : 0;
      if (ownSops > 0) html += '<div class="row"><strong>SOPs:</strong> ' + ownSops + '</div>';
      if (n.type === 'agent') {
        var inh = getInheritedFor(n);
        if (inh && inh.sops.length > 0) html += '<div class="row"><strong>Inherits:</strong> ' + inh.sops.length + ' SOP' + (inh.sops.length === 1 ? '' : 's') + ' from ' + escapeHtml(inh.parent.label) + '</div>';
      }
      if (n.type !== 'organization') html += '<div class="row" style="margin-top:0.25rem; color:#94a3b8;">Click to edit</div>';
      tooltip.innerHTML = html;
      tooltip.classList.add('visible');
      positionTooltip(ev);
    }
    function positionTooltip(ev) {
      var x = ev.clientX + 14;
      var y = ev.clientY + 14;
      tooltip.style.left = x + 'px';
      tooltip.style.top = y + 'px';
    }
    function hideTooltip() { tooltip.classList.remove('visible'); }

    // ---- Initial render ----
    var FILTER_STORAGE_KEY = 'otp-team-chart-filter';
    var savedFilter = (function() {
      try { return localStorage.getItem(FILTER_STORAGE_KEY); } catch (e) { return null; }
    })();
    var currentFilter = (savedFilter && ['all','agent','human'].indexOf(savedFilter) !== -1) ? savedFilter : 'all';
    var filterFns = {
      all:   function(n) { return true; },
      agent: function(n) { return n.type === 'agent' || n.type === 'organization' || (n.type === 'human' && (n.properties || {}).authorityLevel === 'full'); },
      human: function(n) { return n.type === 'human' || n.type === 'organization'; },
    };

    function setActiveFilterBtn(f) {
      document.querySelectorAll('.filter-btn').forEach(function(b) {
        if (b.getAttribute('data-filter') === f) {
          b.classList.add('bg-gray-900','text-white');
          b.classList.remove('text-gray-600');
        } else {
          b.classList.remove('bg-gray-900','text-white');
          b.classList.add('text-gray-600');
        }
      });
    }

    setActiveFilterBtn(currentFilter);
    renderChart(filterFns[currentFilter]);

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var f = btn.getAttribute('data-filter');
        currentFilter = f;
        try { localStorage.setItem(FILTER_STORAGE_KEY, f); } catch (e) {}
        setActiveFilterBtn(f);
        renderChart(filterFns[f]);
      });
    });

    window.addEventListener('resize', function() { /* no-op for now; layout stays fixed */ });

    // ---- Edit panel wiring ----
    var currentNode = null;
    var currentSops = [];   // working copy edited in the panel; PATCH sends this on save
    var editingSopIdx = -1; // which SOP card is open for editing (-1 = none)

    function genSopId(title) {
      var slug = String(title || 'sop').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 40) || 'sop';
      return 'SOP_' + slug.toUpperCase().replace(/-/g, '_') + '_' + Math.random().toString(36).slice(2, 6).toUpperCase();
    }

    window.addSop = function() {
      currentSops.push({ id: genSopId('new-sop'), title: '', trigger: '', steps: [], outputs: [], tools: [], notes: '' });
      editingSopIdx = currentSops.length - 1;
      renderSopList();
    };

    var SOP_TEMPLATE_GROUPS = <%- JSON.stringify(typeof sopTemplateGroups !== 'undefined' ? sopTemplateGroups : []) %>;
    window.insertTemplate = function(value) {
      if (!value) return;
      var parts = value.split(':');
      if (parts.length !== 2) return;
      var roleId = parts[0], templateId = parts[1];
      var group = SOP_TEMPLATE_GROUPS.find(function(g) { return g.roleId === roleId; });
      if (!group) return;
      var tpl = group.templates.find(function(t) { return t.id === templateId; });
      if (!tpl) return;
      // Deep copy + assign a fresh runtime id so the SOP is unique on save
      var copy = JSON.parse(JSON.stringify(tpl));
      copy.id = genSopId(tpl.title);
      currentSops.push(copy);
      editingSopIdx = currentSops.length - 1;
      renderSopList();
    };
    window.toggleSop = function(idx) {
      editingSopIdx = (editingSopIdx === idx ? -1 : idx);
      renderSopList();
    };
    window.deleteSop = function(idx) {
      if (!confirm('Delete this SOP from the draft?')) return;
      currentSops.splice(idx, 1);
      if (editingSopIdx === idx) editingSopIdx = -1;
      else if (editingSopIdx > idx) editingSopIdx--;
      renderSopList();
    };
    window.updateSopField = function(idx, field, value) {
      if (!currentSops[idx]) return;
      if (field === 'steps' || field === 'outputs' || field === 'tools') {
        currentSops[idx][field] = (value || '').split(/\n+/).map(function(s) { return s.trim(); }).filter(Boolean);
      } else {
        currentSops[idx][field] = value;
      }
    };

    function renderSopList() {
      var list = document.getElementById('ef-sop-list');
      var countEl = document.getElementById('ef-sop-count');
      countEl.textContent = currentSops.length === 0 ? '' : '(' + currentSops.length + ')';
      if (currentSops.length === 0) {
        list.innerHTML = '<div class="sop-empty">No SOPs yet. Click "+ Add SOP" to author one.</div>';
        return;
      }
      list.innerHTML = '';
      currentSops.forEach(function(sop, idx) {
        var card = document.createElement('div');
        card.className = 'sop-card' + (editingSopIdx === idx ? ' editing' : '');
        var titleSafe = escapeHtml(sop.title || '(untitled SOP)');
        var titleVal = String(sop.title || '');
        var triggerVal = String(sop.trigger || '');
        var stepsVal = Array.isArray(sop.steps) ? sop.steps.join('\n') : '';
        var outputsVal = Array.isArray(sop.outputs) ? sop.outputs.join('\n') : '';
        var toolsVal = Array.isArray(sop.tools) ? sop.tools.join('\n') : '';
        var notesVal = String(sop.notes || '');
        card.innerHTML = ''
          + '<div class="sop-card-header" onclick="toggleSop(' + idx + ')">'
          +   '<div class="sop-card-title">' + titleSafe + '</div>'
          +   '<div class="sop-card-actions">'
          +     '<button type="button" class="sop-card-btn" onclick="event.stopPropagation(); toggleSop(' + idx + ')">' + (editingSopIdx === idx ? 'Close' : 'Edit') + '</button>'
          +     '<button type="button" class="sop-card-btn delete" onclick="event.stopPropagation(); deleteSop(' + idx + ')">Delete</button>'
          +   '</div>'
          + '</div>'
          + '<div class="sop-card-body">'
          +   '<div class="sop-field"><label>Title</label><input type="text" value="' + escapeHtml(titleVal) + '" oninput="updateSopField(' + idx + ', \'title\', this.value)" placeholder="e.g. Daily inbox triage" /></div>'
          +   '<div class="sop-field"><label>Trigger (when to invoke)</label><input type="text" value="' + escapeHtml(triggerVal) + '" oninput="updateSopField(' + idx + ', \'trigger\', this.value)" placeholder="e.g. Every weekday at 8 AM" /></div>'
          +   '<div class="sop-field"><label>Steps (one per line)</label><textarea rows="4" oninput="updateSopField(' + idx + ', \'steps\', this.value)" placeholder="Mark obvious spam\nDraft replies for routine client emails\nEscalate financial >$5K">' + escapeHtml(stepsVal) + '</textarea></div>'
          +   '<div class="sop-field"><label>Outputs (one per line)</label><textarea rows="2" oninput="updateSopField(' + idx + ', \'outputs\', this.value)" placeholder="Drafted replies\nDaily inbox health summary">' + escapeHtml(outputsVal) + '</textarea></div>'
          +   '<div class="sop-field"><label>Tools (one per line)</label><textarea rows="2" oninput="updateSopField(' + idx + ', \'tools\', this.value)" placeholder="Gmail MCP\nTodoist">' + escapeHtml(toolsVal) + '</textarea></div>'
          +   '<div class="sop-field"><label>Notes (optional)</label><textarea rows="2" oninput="updateSopField(' + idx + ', \'notes\', this.value)">' + escapeHtml(notesVal) + '</textarea></div>'
          + '</div>';
        list.appendChild(card);
      });
    }

    function getInheritedFor(d) {
      if (d.type !== 'agent') return null;
      var p = d.properties || {};
      var parentExtId = p.escalatesTo;
      if (!parentExtId) return null;
      var parent = nodes.find(function(n) { return n.externalId === String(parentExtId); });
      if (!parent) return null;
      var pp = parent.properties || {};
      var sops = Array.isArray(pp.sops) ? pp.sops : [];
      return { parent: parent, sops: sops };
    }

    // ---- KPI section (Phase 2) ----
    var currentKpis = [];
    var editingKpiId = null;
    var currentEntityForKpi = null; // { type: 'agent'|'human', externalId: string }

    var KPI_GOAL_OPS = [
      { value: '',    label: '(no goal)' },
      { value: 'gte', label: '≥' },
      { value: 'gt',  label: '>' },
      { value: 'eq',  label: '=' },
      { value: 'lt',  label: '<' },
      { value: 'lte', label: '≤' },
    ];
    var KPI_GRAINS = [
      { value: 'weekly', label: 'Weekly' },
      { value: 'monthly', label: 'Monthly' },
      { value: 'quarterly', label: 'Quarterly' },
      { value: 'annual', label: 'Annual' },
    ];
    var KPI_AGGS = [
      { value: 'sum', label: 'Sum' },
      { value: 'avg', label: 'Average' },
      { value: 'last', label: 'Last' },
      { value: 'first', label: 'First' },
      { value: 'min', label: 'Min' },
      { value: 'max', label: 'Max' },
    ];

    function formatGoalDisplay(kpi) {
      if (!kpi.goalOperator || kpi.goalValue === null || kpi.goalValue === undefined) return '';
      var opMap = { gte: '≥', lte: '≤', gt: '>', lt: '<', eq: '=' };
      var unit = kpi.unit || '';
      return opMap[kpi.goalOperator] + ' ' + kpi.goalValue + (unit ? ' ' + unit : '');
    }

    function loadSlashCommands(d) {
      var block = document.getElementById('ef-commands-block');
      if (!block) return;
      var p = d.properties || {};
      var cmds = Array.isArray(p.slashCommands) ? p.slashCommands : [];
      var listEl = document.getElementById('ef-commands-list');
      var emptyEl = document.getElementById('ef-commands-empty');
      var countEl = document.getElementById('ef-commands-count');
      block.style.display = '';
      if (cmds.length === 0) {
        emptyEl.style.display = '';
        listEl.innerHTML = '';
        countEl.textContent = '';
        return;
      }
      emptyEl.style.display = 'none';
      countEl.textContent = '(' + cmds.length + ')';
      // Sort by command name for stable display
      cmds = cmds.slice().sort(function(a, b) { return String(a.command || '').localeCompare(String(b.command || '')); });
      listEl.innerHTML = cmds.map(function(c) {
        var cmd = String(c.command || '');
        var desc = String(c.description || '');
        var safeCmd = cmd.replace(/[<>&"']/g, function(ch) { return ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;' })[ch]; });
        var safeDesc = desc.replace(/[<>&"']/g, function(ch) { return ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;' })[ch]; });
        return '<div style="border:1px solid #e5e7eb; border-radius:0.4rem; padding:0.45rem 0.6rem; margin-bottom:0.35rem; background:#fff;">'
          + '<div style="font-family:ui-monospace, Menlo, monospace; font-size:0.75rem; font-weight:600; color:#0f172a; margin-bottom:0.15rem;">' + safeCmd + '</div>'
          + '<div style="font-size:0.7rem; color:#475569; line-height:1.45;">' + safeDesc + '</div>'
          + '</div>';
      }).join('');
    }

    // Track the currently-open tile so inviteFromTile() can pre-fill the
    // invite modal with the right external_id + name.
    var currentTile = null;

    function populateTeamsBlock(d) {
      var block = document.getElementById('ef-teams-block');
      if (!block) return;
      currentTile = d;
      // Org tile + brand-new (un-saved) tiles can't be on a team yet.
      var hasExternal = d && d.externalId && d.type !== 'organization';
      if (!hasExternal) {
        block.style.display = 'none';
        return;
      }
      block.style.display = '';

      // Team chips (de-dup by teamId).
      var chipsEl = document.getElementById('ef-teams-chips');
      var emptyEl = document.getElementById('ef-teams-empty');
      var teams = (tileTeamsMap && tileTeamsMap[d.externalId]) || [];
      chipsEl.innerHTML = '';
      if (teams.length === 0) {
        emptyEl.style.display = '';
      } else {
        emptyEl.style.display = 'none';
        teams.forEach(function(t) {
          var chip = document.createElement('a');
          chip.href = '/dashboard/teams';
          chip.title = 'Manage team in /dashboard/teams';
          chip.textContent = t.teamName + (t.roleOnTeam === 'leader' ? ' (leader)' : '');
          chip.style.cssText = 'display:inline-flex; align-items:center; padding:0.2rem 0.55rem; background:#eef2ff; color:#3730a3; border:1px solid #c7d2fe; border-radius:9999px; font-size:0.7rem; text-decoration:none; font-weight:500;';
          chipsEl.appendChild(chip);
        });
      }

      // Invite row: only for human tiles that aren't already claimed.
      var inviteRow = document.getElementById('ef-invite-row');
      var inviteBtn = document.getElementById('ef-tile-invite-btn');
      var pendingEl = document.getElementById('ef-invite-pending');
      var pendingEmailEl = document.getElementById('ef-invite-pending-email');
      var claimedEl = document.getElementById('ef-invite-claimed');
      var canInvite = (viewerRole === 'owner' || viewerRole === 'admin') && d.type === 'human';
      if (!canInvite) {
        inviteRow.style.display = 'none';
        return;
      }
      inviteRow.style.display = '';
      var claimed = claimedTileMap && claimedTileMap[d.externalId];
      var pending = pendingInviteByTile && pendingInviteByTile[d.externalId];
      inviteBtn.style.display = 'none';
      pendingEl.style.display = 'none';
      claimedEl.style.display = 'none';
      if (claimed) {
        claimedEl.style.display = '';
      } else if (pending) {
        pendingEmailEl.textContent = pending.email;
        pendingEl.style.display = '';
      } else {
        inviteBtn.style.display = '';
      }
    }

    // Opens the existing "Invite a new member" modal pre-filled with the
    // currently-open tile so the admin can send an invite in one click.
    // Invite the EXISTING tile to OTP. Janine (and every other person already
    // on the chart) has a tile -- inviting them must tie the invitation to
    // that tile's externalId, NOT create a new tile. The old implementation
    // opened the "create new tile" modal via modal.classList.add('open'),
    // but that modal is shown/hidden by inline styles (opacity/pointer-
    // events), so the class toggle was a no-op and nothing appeared --
    // "the button does nothing." And even if it had opened, submitInviteNew
    // would have POSTed /api/v1/team/entity and created a DUPLICATE tile.
    // Rewritten 2026-05-28 to invite the existing tile directly, mirroring
    // sendInvite(). Email comes from the tile's contactEmail; if absent, we
    // prompt for it once.
    window.inviteFromTile = function() {
      if (!currentTile || !currentTile.externalId) return;
      var match = nodes.find(function(n) { return n.id === currentTile.id; });
      var props = match && match.properties ? match.properties : {};
      var email = (props.contactEmail || '').trim();
      if (!email) {
        email = (window.prompt('Email to invite ' + (currentTile.label || 'this person') + ' to OTP:') || '').trim();
        if (!email) return;
      }
      var btn = document.getElementById('ef-tile-invite-btn');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
      OTP.apiSave({
        method: 'POST', url: '/api/v1/team/invite',
        body: { email: email, claimedEntityId: currentTile.externalId, role: 'member' },
        btnEl: btn,
        onSuccess: function(data) {
          var pendingEl = document.getElementById('ef-invite-pending');
          var pendingEmailEl = document.getElementById('ef-invite-pending-email');
          if (pendingEmailEl) pendingEmailEl.textContent = data.email;
          if (pendingEl) pendingEl.style.display = '';
          if (btn) btn.style.display = 'none';
          setTimeout(function() { window.location.reload(); }, 1500);
        },
        onError: function(err) {
          if (btn) { btn.disabled = false; btn.textContent = '✉️ Invite to OTP'; }
          window.alert(OTP.formatError ? OTP.formatError(err, 'Invite failed') : 'Invite failed. Try again.');
          return true;
        },
      });
    };

    async function loadMeetingsForEntity(externalId) {
      var block = document.getElementById('ef-meetings-block');
      if (!block) return;
      block.style.display = '';
      var loading = document.getElementById('ef-meetings-loading');
      var empty = document.getElementById('ef-meetings-empty');
      var upcomingWrap = document.getElementById('ef-meetings-upcoming-wrap');
      var pastWrap = document.getElementById('ef-meetings-past-wrap');
      var upcomingDiv = document.getElementById('ef-meetings-upcoming');
      var pastDiv = document.getElementById('ef-meetings-past');
      var profileLink = document.getElementById('ef-profile-link');
      // Reset UI state
      loading.style.display = '';
      empty.style.display = 'none';
      upcomingWrap.style.display = 'none';
      pastWrap.style.display = 'none';
      upcomingDiv.innerHTML = '';
      pastDiv.innerHTML = '';
      // Profile link always points to the dedicated page (preserving any ?orgId override)
      var qs = new URLSearchParams(window.location.search);
      var passOrg = qs.get('orgId') || qs.get('org') || '';
      profileLink.href = '/team/' + encodeURIComponent(externalId) + (passOrg ? ('?orgId=' + encodeURIComponent(passOrg)) : '');
      try {
        var resp = await fetch('/api/v1/team/' + encodeURIComponent(externalId) + '/profile' + (passOrg ? ('?orgId=' + encodeURIComponent(passOrg)) : ''), { credentials: 'include' });
        if (!resp.ok) { loading.textContent = 'Could not load meetings.'; return; }
        var data = await resp.json();
        loading.style.display = 'none';
        // Summary tiles
        document.getElementById('ef-sum-rocks').textContent    = data.summary.rocksOwned + '';
        document.getElementById('ef-sum-todos').textContent    = data.summary.openTodos + '';
        document.getElementById('ef-sum-issues').textContent   = data.summary.openIssues + '';
        document.getElementById('ef-sum-meetings').textContent = data.summary.meetingsAttended + '';

        function renderMeetingItem(m) {
          var dt = new Date(m.scheduledAt);
          var dateStr = dt.toLocaleDateString() + ' ' + dt.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
          var statusBg = m.status === 'completed' ? '#d1fae5'
                       : m.status === 'in_progress' ? '#dbeafe'
                       : m.status === 'cancelled' ? '#fee2e2' : '#f3f4f6';
          var statusFg = m.status === 'completed' ? '#065f46'
                       : m.status === 'in_progress' ? '#1e40af'
                       : m.status === 'cancelled' ? '#991b1b' : '#374151';
          var contributionHtml = '';
          if (m.contribution && (m.contribution.todosOwned > 0 || m.contribution.issuesSolved > 0)) {
            var bits = [];
            if (m.contribution.todosOwned > 0) bits.push('<span style="background:#dbeafe; color:#1e40af; padding:0.1rem 0.4rem; border-radius:0.25rem; font-size:0.6rem; margin-right:0.3rem;">' + m.contribution.todosOwned + ' to-do' + (m.contribution.todosOwned === 1 ? '' : 's') + '</span>');
            if (m.contribution.issuesSolved > 0) bits.push('<span style="background:#d1fae5; color:#065f46; padding:0.1rem 0.4rem; border-radius:0.25rem; font-size:0.6rem;">' + m.contribution.issuesSolved + ' solved</span>');
            contributionHtml = '<div style="margin-top:0.25rem;">' + bits.join('') + '</div>';
          }
          var href = '/l8/meeting/' + encodeURIComponent(m.id) + (passOrg ? ('?orgId=' + encodeURIComponent(passOrg)) : '');
          return '<a href="' + href + '" style="display:block; border:1px solid #e5e7eb; border-radius:0.4rem; padding:0.4rem 0.55rem; margin-bottom:0.3rem; text-decoration:none; color:#111827;">'
            + '<div style="display:flex; justify-content:space-between; gap:0.4rem; align-items:center;">'
            + '<div style="font-size:0.75rem; font-weight:600;">' + (m.title || '(untitled)') + '</div>'
            + '<span style="background:' + statusBg + '; color:' + statusFg + '; padding:0.1rem 0.4rem; border-radius:0.6rem; font-size:0.6rem;">' + m.status + '</span>'
            + '</div>'
            + '<div style="font-size:0.65rem; color:#6b7280; margin-top:0.1rem;">' + dateStr + '</div>'
            + contributionHtml
            + '</a>';
        }

        if (data.meetings.upcoming.length > 0) {
          upcomingWrap.style.display = '';
          upcomingDiv.innerHTML = data.meetings.upcoming.map(renderMeetingItem).join('');
        }
        if (data.meetings.past.length > 0) {
          pastWrap.style.display = '';
          // Cap at the 5 most-recent in the drawer; full timeline is on /team/:externalId
          pastDiv.innerHTML = data.meetings.past.slice(0, 5).map(renderMeetingItem).join('');
        }
        if (data.meetings.upcoming.length === 0 && data.meetings.past.length === 0) {
          empty.style.display = '';
        }
      } catch (e) {
        loading.textContent = 'Error loading meetings.';
      }
    }

    async function loadKpisForEntity(type, externalId) {
      currentEntityForKpi = { type: type, externalId: externalId };
      try {
        var resp = await fetch('/api/v1/kpis?ownerEntityType=' + encodeURIComponent(type) + '&ownerExternalId=' + encodeURIComponent(externalId), { credentials: 'include' });
        if (!resp.ok) {
          currentKpis = [];
          renderKpiList();
          return;
        }
        var data = await resp.json();
        currentKpis = Array.isArray(data.kpis) ? data.kpis : [];
        editingKpiId = null;
        renderKpiList();
      } catch (e) {
        currentKpis = [];
        renderKpiList();
      }
    }

    function selectHtml(name, options, current, onchange) {
      var html = '<select onchange="' + onchange + '" style="padding: 0.4rem 0.5rem; border: 1px solid #e5e7eb; border-radius: 6px; font-size: 12px; color: #111827; background: #fff; width: 100%;">';
      options.forEach(function(o) {
        var sel = (String(o.value) === String(current === null || current === undefined ? '' : current)) ? ' selected' : '';
        html += '<option value="' + o.value + '"' + sel + '>' + o.label + '</option>';
      });
      html += '</select>';
      return html;
    }

    function renderKpiList() {
      var list = document.getElementById('ef-kpi-list');
      var countEl = document.getElementById('ef-kpi-count');
      if (!list) return;
      countEl.textContent = currentKpis.length === 0 ? '' : '(' + currentKpis.length + ')';
      if (currentKpis.length === 0) {
        list.innerHTML = '<div class="kpi-empty">No KPIs yet. Click "+ Add KPI" to define one.</div>';
        return;
      }
      list.innerHTML = '';
      currentKpis.forEach(function(kpi) {
        var card = document.createElement('div');
        var editing = editingKpiId === kpi.id;
        card.className = 'kpi-card' + (editing ? ' editing' : '');
        var titleSafe = escapeHtml(kpi.title || '(untitled KPI)');
        var goal = formatGoalDisplay(kpi);
        var goalPill = goal ? '<span class="kpi-goal-pill">' + escapeHtml(goal) + '</span>' : '';
        var fxPill = kpi.formula ? '<span class="kpi-formula-pill">fx</span>' : '';
        var meta = (kpi.timeGrain || 'weekly') + (kpi.groupName ? ' · ' + kpi.groupName : '');

        var headerHtml = ''
          + '<div class="kpi-card-header" onclick="toggleKpi(\'' + escapeHtml(kpi.id) + '\')">'
          +   '<div class="kpi-card-title">' + titleSafe + '<div style="font-size:10px; color:#9ca3af; font-weight:400; margin-top:0.1rem;">' + escapeHtml(meta) + '</div></div>'
          +   '<div style="display:flex; align-items:center; gap:0.4rem;">' + goalPill + fxPill
          +     '<button type="button" class="sop-card-btn" onclick="event.stopPropagation(); toggleKpi(\'' + escapeHtml(kpi.id) + '\')">' + (editing ? 'Close' : 'Edit') + '</button>'
          +   '</div>'
          + '</div>';

        var bodyHtml = '<div class="kpi-card-body">'
          + '<div class="sop-field"><label>Title</label><input type="text" value="' + escapeHtml(kpi.title || '') + '" oninput="updateKpiField(\'' + kpi.id + '\', \'title\', this.value)" placeholder="e.g. Weekly net new MRR" /></div>'
          + '<div class="sop-field"><label>Description</label><textarea rows="2" oninput="updateKpiField(\'' + kpi.id + '\', \'description\', this.value)" placeholder="What this measures and why it matters">' + escapeHtml(kpi.description || '') + '</textarea></div>'
          + '<div class="kpi-grid-2">'
          +   '<div class="sop-field"><label>Group</label><input type="text" value="' + escapeHtml(kpi.groupName || '') + '" oninput="updateKpiField(\'' + kpi.id + '\', \'groupName\', this.value)" placeholder="Winning Scoreboard" /></div>'
          +   '<div class="sop-field"><label>Time grain</label>' + selectHtml('timeGrain', KPI_GRAINS, kpi.timeGrain || 'weekly', 'updateKpiField(\'' + kpi.id + '\', \'timeGrain\', this.value)') + '</div>'
          + '</div>'
          + '<div class="kpi-grid-3">'
          +   '<div class="sop-field"><label>Goal operator</label>' + selectHtml('goalOperator', KPI_GOAL_OPS, kpi.goalOperator || '', 'updateKpiField(\'' + kpi.id + '\', \'goalOperator\', this.value)') + '</div>'
          +   '<div class="sop-field"><label>Goal value</label><input type="number" step="any" value="' + (kpi.goalValue === null || kpi.goalValue === undefined ? '' : kpi.goalValue) + '" oninput="updateKpiField(\'' + kpi.id + '\', \'goalValue\', this.value)" placeholder="e.g. 30" /></div>'
          +   '<div class="sop-field"><label>Unit</label><input type="text" value="' + escapeHtml(kpi.unit || '') + '" oninput="updateKpiField(\'' + kpi.id + '\', \'unit\', this.value)" placeholder="%, $, count" /></div>'
          + '</div>'
          + '<div class="sop-field"><label>Aggregation (used for cross-grain rollups)</label>' + selectHtml('aggregationMethod', KPI_AGGS, kpi.aggregationMethod || 'sum', 'updateKpiField(\'' + kpi.id + '\', \'aggregationMethod\', this.value)') + '</div>'
          + '<div class="sop-field"><label>Formula (optional, evaluated in Phase 4)</label><textarea rows="2" oninput="updateKpiField(\'' + kpi.id + '\', \'formula\', this.value)" placeholder="e.g. {{kpi_id_a}} / {{kpi_id_b}} * 100">' + escapeHtml(kpi.formula || '') + '</textarea></div>'
          + '<div class="sop-card-footer">'
          +   '<button type="button" class="sop-card-btn delete" onclick="deleteKpi(\'' + kpi.id + '\')">Delete</button>'
          +   '<button type="button" class="sop-card-btn" style="background:#ec4899; color:#fff;" onclick="saveKpi(\'' + kpi.id + '\')">Save KPI</button>'
          + '</div>'
          + '</div>';

        card.innerHTML = headerHtml + bodyHtml;
        list.appendChild(card);
      });
    }

    window.toggleKpi = function(id) {
      editingKpiId = (editingKpiId === id) ? null : id;
      renderKpiList();
    };

    window.updateKpiField = function(id, field, value) {
      var kpi = currentKpis.find(function(k) { return k.id === id; });
      if (!kpi) return;
      if (field === 'goalValue') {
        kpi[field] = (value === '' || value === null) ? null : Number(value);
      } else if (field === 'goalOperator' || field === 'groupName' || field === 'unit' || field === 'description' || field === 'formula') {
        kpi[field] = value === '' ? null : value;
      } else {
        kpi[field] = value;
      }
    };

    window.addKpi = async function() {
      if (!currentEntityForKpi) return;
      var draft = {
        ownerEntityType: currentEntityForKpi.type,
        ownerExternalId: currentEntityForKpi.externalId,
        title: 'New KPI',
        timeGrain: 'weekly',
        aggregationMethod: 'sum',
        groupName: 'Winning Scoreboard',
      };
      OTP.apiSave({
        method: 'POST', url: '/api/v1/kpis', body: draft,
        errorContext: 'Create KPI',
        onSuccess: function(created) {
          currentKpis.unshift(created);
          editingKpiId = created.id;
          renderKpiList();
        },
      });
    };

    window.saveKpi = function(id) {
      var kpi = currentKpis.find(function(k) { return k.id === id; });
      if (!kpi) return;
      var patch = {
        title: kpi.title || 'New KPI',
        description: kpi.description || null,
        groupName: kpi.groupName || null,
        goalOperator: kpi.goalOperator || null,
        goalValue: (kpi.goalValue === '' || kpi.goalValue === null || kpi.goalValue === undefined) ? null : Number(kpi.goalValue),
        unit: kpi.unit || null,
        timeGrain: kpi.timeGrain || 'weekly',
        aggregationMethod: kpi.aggregationMethod || 'sum',
        formula: kpi.formula || null,
      };
      OTP.apiSave({
        method: 'PATCH', url: '/api/v1/kpis/' + encodeURIComponent(id), body: patch,
        errorContext: 'Save KPI',
        onSuccess: function(updated) {
          var idx = currentKpis.findIndex(function(k) { return k.id === id; });
          if (idx >= 0) currentKpis[idx] = updated;
          editingKpiId = null;
          renderKpiList();
        },
      });
    };

    window.deleteKpi = function(id) {
      if (!confirm('Delete this KPI? Time-series values will be archived but the definition will be removed from the scorecard.')) return;
      OTP.apiSave({
        method: 'DELETE', url: '/api/v1/kpis/' + encodeURIComponent(id),
        errorContext: 'Delete KPI',
        onSuccess: function() {
          currentKpis = currentKpis.filter(function(k) { return k.id !== id; });
          if (editingKpiId === id) editingKpiId = null;
          renderKpiList();
        },
      });
    };

    function renderInheritedFor(d) {
      var section = document.getElementById('ef-inherited-section');
      var inh = getInheritedFor(d);
      if (!inh || inh.sops.length === 0) {
        section.style.display = 'none';
        return;
      }
      section.style.display = '';
      document.getElementById('ef-inherited-count').textContent = '(' + inh.sops.length + ')';
      document.getElementById('ef-inherited-source').textContent = 'Inherited from ' + inh.parent.label + ' (' + inh.parent.type + ')';
      var list = document.getElementById('ef-inherited-list');
      list.innerHTML = '';
      inh.sops.forEach(function(sop) {
        var card = document.createElement('div');
        card.className = 'sop-card';
        var titleSafe = escapeHtml(sop.title || '(untitled SOP)');
        var bodyParts = [];
        if (sop.trigger) bodyParts.push('<div class="sop-field"><label>Trigger</label><div style="font-size:12px;color:#374151;">' + escapeHtml(sop.trigger) + '</div></div>');
        if (Array.isArray(sop.steps) && sop.steps.length) {
          bodyParts.push('<div class="sop-field"><label>Steps</label><ol style="margin:0;padding-left:1.25rem;font-size:12px;color:#374151;">' + sop.steps.map(function(s) { return '<li>' + escapeHtml(String(s)) + '</li>'; }).join('') + '</ol></div>');
        }
        if (Array.isArray(sop.outputs) && sop.outputs.length) {
          bodyParts.push('<div class="sop-field"><label>Outputs</label><ul style="margin:0;padding-left:1.25rem;font-size:12px;color:#374151;">' + sop.outputs.map(function(o) { return '<li>' + escapeHtml(String(o)) + '</li>'; }).join('') + '</ul></div>');
        }
        card.innerHTML = '<div class="sop-card-header" style="cursor:default;"><div class="sop-card-title">' + titleSafe + '</div></div>'
          + (bodyParts.length ? '<div class="sop-card-body" style="display:block;">' + bodyParts.join('') + '</div>' : '');
        list.appendChild(card);
      });
    }

    window.copyAgentContext = async function() {
      if (!currentNode || currentNode.type !== 'agent') return;
      var status = document.getElementById('ef-copy-context-status');
      var fmt = (document.getElementById('ef-context-format') || {}).value || 'agents-md';
      var labelByFmt = { 'agents-md': 'AGENTS.md', 'claude-md': 'CLAUDE.md', 'cursor': '.cursorrules', 'generic': 'system prompt' };
      status.textContent = 'Loading…';
      status.style.color = '#6b7280';
      try {
        var res = await fetch('/api/v1/team/agent/' + encodeURIComponent(currentNode.externalId) + '/context?format=' + encodeURIComponent(fmt), { method: 'GET' });
        if (!res.ok) {
          status.style.color = '#b91c1c';
          status.textContent = 'Failed (' + res.status + ')';
          return;
        }
        var md = await res.text();
        await navigator.clipboard.writeText(md);
        status.style.color = '#059669';
        status.textContent = 'Copied as ' + labelByFmt[fmt] + ' (' + md.length + ' chars)';
        setTimeout(function() { status.textContent = ''; }, 2800);
      } catch (e) {
        status.style.color = '#b91c1c';
        status.textContent = 'Error: ' + e.message;
      }
    };

    // Phase 3: gated edit. When the viewer can't edit this tile, make the
    // drawer read-only so they can still SEE everything (whole chart visible)
    // but can't save / delete / invite.
    function applyChartEditGate(d) {
      var canEdit = canEditTile(d.externalId);
      var panel = document.getElementById('edit-form');
      // Read-only the inputs + selects + textareas inside the panel
      var inputs = panel ? panel.querySelectorAll('input, textarea, select') : [];
      Array.prototype.forEach.call(inputs, function(el) {
        if (canEdit) {
          el.removeAttribute('readonly');
          if (el.tagName === 'SELECT') el.disabled = false;
        } else {
          if (el.tagName === 'SELECT') el.disabled = true;
          else el.setAttribute('readonly', 'readonly');
        }
      });
      var saveBtn = document.getElementById('ef-save');
      if (saveBtn) {
        saveBtn.disabled = !canEdit;
        saveBtn.title = canEdit ? '' : 'You do not have permission to edit this tile';
      }
      var delBtn = document.getElementById('ef-delete');
      if (delBtn) delBtn.style.display = canEdit ? '' : 'none';
      var inviteBtn = document.getElementById('ef-invite-btn');
      if (inviteBtn) inviteBtn.disabled = !canEdit;
      // Header badge
      var badge = document.getElementById('ef-readonly-badge');
      if (!badge) {
        badge = document.createElement('span');
        badge.id = 'ef-readonly-badge';
        badge.className = 'ml-2 inline-block px-2 py-0.5 text-[10px] uppercase tracking-wide font-semibold rounded bg-gray-100 text-gray-600';
        badge.textContent = 'Read-only';
        var headerName = document.getElementById('edit-name-display');
        if (headerName && headerName.parentNode) headerName.parentNode.appendChild(badge);
      }
      badge.style.display = canEdit ? 'none' : 'inline-block';
    }

    // ---- Agent runtime: manual trigger + run history (Agent Timer Stage 1)
    function escapeHtmlForRun(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function fmtRunTime(iso) {
      try { return new Date(iso).toLocaleString([], { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }); }
      catch (e) { return iso; }
    }
    window.runAgentNow = async function() {
      if (!currentNode || currentNode.type !== 'agent') return;
      var btn = document.getElementById('ef-run-btn');
      var statusEl = document.getElementById('ef-run-status');
      var outEl = document.getElementById('ef-run-output');
      var prompt = (document.getElementById('ef-run-prompt').value || '').trim();
      btn.disabled = true; btn.textContent = 'Running...';
      statusEl.textContent = 'sending to anthropic';
      outEl.style.display = 'none';
      try {
        var res = await fetch('/api/v1/agents/' + encodeURIComponent(currentNode.externalId) + '/run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt: prompt || undefined }),
        });
        var data = await res.json();
        if (!res.ok) throw new Error((data && data.error && data.error.message) || ('HTTP ' + res.status));
        outEl.style.display = '';
        if (data.status === 'succeeded') {
          statusEl.textContent = (data.tokensInput || 0) + ' in / ' + (data.tokensOutput || 0) + ' out';
          outEl.textContent = data.output || '(empty response)';
        } else {
          statusEl.textContent = 'failed';
          outEl.textContent = '[ERROR] ' + (data.error || 'Unknown failure');
        }
        loadAgentRuns();
      } catch (e) {
        outEl.style.display = '';
        outEl.textContent = '[ERROR] ' + (e && e.message ? e.message : String(e));
        statusEl.textContent = 'error';
      } finally {
        btn.disabled = false; btn.textContent = 'Run now';
      }
    };
    window.loadAgentRuns = async function() {
      if (!currentNode || currentNode.type !== 'agent') return;
      var hist = document.getElementById('ef-run-history');
      if (!hist) return;
      hist.innerHTML = '<span class="text-gray-400 italic">Loading...</span>';
      try {
        var res = await fetch('/api/v1/agents/' + encodeURIComponent(currentNode.externalId) + '/runs?limit=10');
        var data = await res.json();
        var runs = (data && data.runs) || [];
        if (runs.length === 0) {
          hist.innerHTML = '<span class="text-gray-400 italic">No runs yet. Click "Run now" to fire this agent.</span>';
          return;
        }
        var rows = runs.map(function(r) {
          var color = r.status === 'succeeded' ? '#059669' : (r.status === 'failed' ? '#dc2626' : '#6b7280');
          var when = fmtRunTime(r.created_at);
          var tokens = (r.tokens_input != null ? (r.tokens_input + '/' + r.tokens_output) : '');
          return '<div style="border-top:1px solid #f3f4f6; padding:0.4rem 0; display:flex; gap:0.5rem; align-items:flex-start;">' +
                   '<span style="display:inline-block; width:0.5rem; height:0.5rem; border-radius:9999px; background:' + color + '; margin-top:0.4rem; flex-shrink:0;"></span>' +
                   '<div style="flex:1; min-width:0;">' +
                     '<div style="display:flex; gap:0.5rem; align-items:baseline; font-size:11px;">' +
                       '<span style="font-weight:600; color:#111827;">' + escapeHtmlForRun(r.status) + '</span>' +
                       '<span style="color:#6b7280;">' + escapeHtmlForRun(when) + '</span>' +
                       (tokens ? '<span style="color:#9ca3af; font-family: ui-monospace, monospace;">' + escapeHtmlForRun(tokens) + ' tok</span>' : '') +
                       '<span style="color:#9ca3af; font-size:10px;">' + escapeHtmlForRun(r.trigger || 'manual') + '</span>' +
                     '</div>' +
                     (r.output ? '<div style="font-family: ui-monospace, monospace; font-size:10.5px; color:#374151; margin-top:0.2rem; max-height:80px; overflow:hidden; text-overflow:ellipsis; white-space:pre-wrap;">' + escapeHtmlForRun(String(r.output).slice(0, 400)) + (r.output.length > 400 ? '…' : '') + '</div>' : '') +
                     (r.error ? '<div style="color:#dc2626; font-size:11px; margin-top:0.2rem;">' + escapeHtmlForRun(r.error) + '</div>' : '') +
                   '</div>' +
                 '</div>';
        }).join('');
        hist.innerHTML = rows;
      } catch (e) {
        hist.innerHTML = '<span class="text-red-600">Failed to load run history.</span>';
      }
    };

    window.openEditPanel = function(d) {
      currentNode = d;
      var p = d.properties || {};
      currentSops = Array.isArray(p.sops) ? JSON.parse(JSON.stringify(p.sops)) : [];
      editingSopIdx = -1;
      renderSopList();
      renderInheritedFor(d);
      loadKpisForEntity(d.type, d.externalId);
      loadMeetingsForEntity(d.externalId);
      loadSlashCommands(d);
      populateTeamsBlock(d);
      document.getElementById('ef-context-section').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-runtime-section').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-runtime-body').value = (d.type === 'agent' ? (p.runtimeBody || '') : '');
      // Agent runtime trigger panel (Coming Soon for now): show only on agent tiles
      var runtimeTrigger = document.getElementById('ef-runtime-trigger');
      if (runtimeTrigger) runtimeTrigger.style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('edit-type-label').textContent = (d.type === 'agent' ? 'Edit agent' : 'Edit human');
      document.getElementById('edit-name-display').textContent = d.label + ' (' + d.externalId + ')';
      document.getElementById('ef-name').value = d.label || '';
      document.getElementById('ef-role').value = p.role || '';
      document.getElementById('ef-mission').value = p.mission || '';
      document.getElementById('ef-jobdesc').value = p.jobDescription || '';
      // Authority dropdown: pick standard option, fall back to custom field for legacy values.
      var authSelect = document.getElementById('ef-authority');
      var authCustom = document.getElementById('ef-authority-custom');
      var authVal = p.authorityLevel || '';
      var STANDARD_AUTH = ['view-only', 'recommend', 'execute-with-approval', 'autonomous'];
      if (!authVal) {
        authSelect.value = '';
        authCustom.style.display = 'none';
        authCustom.value = '';
      } else if (STANDARD_AUTH.indexOf(authVal) >= 0) {
        authSelect.value = authVal;
        authCustom.style.display = 'none';
        authCustom.value = '';
      } else {
        authSelect.value = '__custom__';
        authCustom.style.display = '';
        authCustom.value = authVal;
      }
      document.getElementById('ef-maturity').value = (typeof p.maturityLevel === 'number' && p.maturityLevel >= 1 && p.maturityLevel <= 8) ? String(p.maturityLevel) : '';
      document.getElementById('ef-maturity-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-platform').value = p.platform || '';
      document.getElementById('ef-status').value = p.status || '';
      currentSkills = Array.isArray(p.skills) ? p.skills.slice() : [];
      renderSkillTags();
      hideSkillSuggestions();
      currentMcps = Array.isArray(p.mcps) ? p.mcps.slice() : [];
      renderMcpTags();
      document.getElementById('ef-contact-email').value = p.contactEmail || '';
      document.getElementById('ef-contact-phone').value = p.contactPhone || '';
      document.getElementById('ef-slackid').value = p.slackId || '';
      document.getElementById('ef-mission-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-jobdesc-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-platform-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-status-wrap').style.display = '';
      document.getElementById('ef-escalates-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-reportsto-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-contact-email-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-contact-phone-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-slackid-wrap').style.display = (d.type === 'human' ? '' : 'none');

      // Invite section: only visible to owner viewing a human tile
      var inviteSection = document.getElementById('ef-invite-section');
      if (inviteSection) {
        var canInvite = (viewerRole === 'owner' && d.type === 'human');
        inviteSection.style.display = canInvite ? '' : 'none';
        if (canInvite) {
          var claimedByEl = document.getElementById('ef-invite-claimed-by');
          var existing = claimedTileMap[d.externalId];
          if (existing) {
            claimedByEl.style.display = '';
            claimedByEl.textContent = 'Already claimed by member ' + existing.clerkUserId + '. New invitations would replace nothing -- you can revoke pending invites from the drawer.';
            document.getElementById('ef-invite-email').value = (p.contactEmail || '');
          } else {
            claimedByEl.style.display = 'none';
            // Pre-fill with the tile's contact email if known
            document.getElementById('ef-invite-email').value = (p.contactEmail || '');
          }
          document.getElementById('ef-invite-status').textContent = '';
        }
      }

      var fillSelect = function(selectEl, currentValue) {
        selectEl.innerHTML = '<option value="">(none)</option>';
        nodes.forEach(function(n) {
          if (n.type === 'organization') return;
          if (n.id === d.id) return;
          var opt = document.createElement('option');
          opt.value = n.externalId;
          opt.textContent = n.label + ' (' + n.type + ')';
          if (currentValue && String(currentValue) === n.externalId) opt.selected = true;
          selectEl.appendChild(opt);
        });
      };
      fillSelect(document.getElementById('ef-escalates'), p.escalatesTo);
      fillSelect(document.getElementById('ef-reportsto'), p.reportsTo);
      document.getElementById('edit-banner').style.display = 'none';
      document.getElementById('edit-panel').classList.add('open');
      document.getElementById('edit-overlay').classList.add('open');
      document.getElementById('edit-panel').setAttribute('aria-hidden', 'false');
      applyChartEditGate(d);
    };
    window.closeEdit = function() {
