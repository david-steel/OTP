    // submitCreate -- POST then PATCH the new entity
    async function submitCreate() {
      var btn = document.getElementById('ef-save');
      var banner = document.getElementById('edit-banner');
      banner.style.display = 'none';
      banner.classList.remove('error');

      var name = (document.getElementById('ef-name').value || '').trim();
      if (!name) {
        banner.textContent = 'Name is required.';
        banner.classList.add('error');
        banner.style.display = '';
        return;
      }
      var t = currentCreateType;
      var role = (document.getElementById('ef-role').value || '').trim();
      var contactEmail = (document.getElementById('ef-contact-email').value || '').trim();
      var reportsTo = (document.getElementById('ef-reportsto').value || '').trim();
      var escalatesTo = (document.getElementById('ef-escalates').value || '').trim();
      var authSelectVal = document.getElementById('ef-authority').value;
      var authority = '';
      if (authSelectVal === '__custom__') {
        authority = (document.getElementById('ef-authority-custom').value || '').trim();
      } else if (authSelectVal) {
        authority = authSelectVal;
      }

      var createBody = { type: t, name: name };
      if (role) createBody.role = role;
      if (t === 'human' && contactEmail) createBody.contactEmail = contactEmail;
      if (t === 'human' && reportsTo) createBody.reportsTo = reportsTo;
      if (t === 'agent' && escalatesTo) createBody.escalatesTo = escalatesTo;
      if (authority) createBody.authorityLevel = authority;

      btn.disabled = true; btn.textContent = 'Creating…';

      try {
        var createRes = await fetch('/api/v1/team/entity', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(createBody),
        });
        if (!createRes.ok) {
          var ce = await createRes.json().catch(function() { return {}; });
          banner.textContent = (ce.error && ce.error.message) || ('Create failed (' + createRes.status + ')');
          banner.classList.add('error');
          banner.style.display = '';
          btn.disabled = false; btn.textContent = 'Create tile';
          return;
        }
        var created = await createRes.json();
        var newExternalId = created.externalId || (created.entity && created.entity.externalId);
        if (!newExternalId) {
          banner.textContent = 'Created but external ID missing in response. Reload to see the tile.';
          banner.classList.add('error');
          banner.style.display = '';
          setTimeout(function() { window.location.reload(); }, 1500);
          return;
        }

        // Build PATCH for fields the create endpoint does not accept
        var patch = {};
        if (t === 'agent') {
          var mission = (document.getElementById('ef-mission').value || '').trim();
          var platform = (document.getElementById('ef-platform').value || '').trim();
          var matVal = document.getElementById('ef-maturity').value;
          if (mission) patch.mission = mission;
          if (platform) patch.platform = platform;
          if (matVal !== '') patch.maturity_level = Number(matVal);
        } else {
          var jobdesc = (document.getElementById('ef-jobdesc').value || '').trim();
          var contactPhone = (document.getElementById('ef-contact-phone').value || '').trim();
          var slackId = (document.getElementById('ef-slackid').value || '').trim();
          if (jobdesc) patch.job_description = jobdesc;
          if (contactPhone) patch.contact_phone = contactPhone;
          if (slackId) patch.slack_id = slackId;
        }
        var statusVal = (document.getElementById('ef-status').value || '').trim();
        if (statusVal) patch.status = statusVal;
        if (currentSkills && currentSkills.length > 0) patch.skills = currentSkills.slice();
        if (currentMcps && currentMcps.length > 0) patch.mcps = currentMcps.slice();
        var cleanSops = (currentSops || [])
          .filter(function(s) { return s && String(s.title || '').trim().length > 0; })
          .map(function(s) {
            var out = { title: String(s.title).trim() };
            if (s.id) out.id = s.id;
            if (s.trigger && s.trigger.trim()) out.trigger = s.trigger.trim();
            if (Array.isArray(s.steps) && s.steps.length) out.steps = s.steps;
            if (Array.isArray(s.outputs) && s.outputs.length) out.outputs = s.outputs;
            if (Array.isArray(s.tools) && s.tools.length) out.tools = s.tools;
            if (s.notes && s.notes.trim()) out.notes = s.notes.trim();
            return out;
          });
        if (cleanSops.length > 0) patch.sops = cleanSops;

        if (Object.keys(patch).length > 0) {
          btn.textContent = 'Saving details…';
          var patchRes = await fetch('/api/v1/team/entity', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: t, externalId: newExternalId, patch: patch }),
          });
          if (!patchRes.ok) {
            var pe = await patchRes.json().catch(function() { return {}; });
            banner.textContent = 'Tile created but saving details failed: ' + ((pe.error && pe.error.message) || patchRes.status) + '. Reload to edit it.';
            banner.classList.add('error');
            banner.style.display = '';
            setTimeout(function() { window.location.reload(); }, 2000);
            return;
          }
        }

        btn.textContent = 'Created!';
        setTimeout(function() { window.location.reload(); }, 600);
      } catch (e) {
        banner.textContent = 'Network error: ' + e.message;
        banner.classList.add('error');
        banner.style.display = '';
        btn.disabled = false; btn.textContent = 'Create tile';
      }
    }
