    // Minimal RFC-4180-ish CSV parser: handles quoted fields, escaped quotes, embedded newlines + commas.
    function parseCSV(text) {
      var rows = [];
      var row = [];
      var field = '';
      var inQuotes = false;
      var i = 0;
      // Strip BOM if present
      if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);
      while (i < text.length) {
        var c = text[i];
        if (inQuotes) {
          if (c === '"') {
            if (text[i+1] === '"') { field += '"'; i += 2; continue; }
            inQuotes = false; i++; continue;
          }
          field += c; i++; continue;
        }
        if (c === '"') { inQuotes = true; i++; continue; }
        if (c === ',') { row.push(field); field = ''; i++; continue; }
        if (c === '\r') { i++; continue; }
        if (c === '\n') { row.push(field); rows.push(row); row = []; field = ''; i++; continue; }
        field += c; i++;
      }
      // Final field/row
      if (field.length > 0 || row.length > 0) { row.push(field); rows.push(row); }
      return rows;
    }

    var KNOWN_COLS = ['name','role','contact_email','contact_phone','slack_id','reports_to','job_description','authority_level','skills','mcps','status'];

    window.onImportFileChange = function() {
      var fileInput = document.getElementById('imp-file');
      var statusEl = document.getElementById('imp-file-status');
      var banner = document.getElementById('imp-banner');
      banner.style.display = 'none';
      if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
        statusEl.textContent = '';
        return;
      }
      var file = fileInput.files[0];
      if (file.size > 2 * 1024 * 1024) {
        statusEl.textContent = '';
        showImportBanner('File too large (>2MB).', 'error');
        return;
      }
      var reader = new FileReader();
      reader.onload = function(ev) {
        var text = String(ev.target.result || '');
        try {
          var raw = parseCSV(text);
          // Drop empty trailing rows
          raw = raw.filter(function(r) { return r.length > 0 && !(r.length === 1 && r[0].trim() === ''); });
          if (raw.length < 2) {
            statusEl.textContent = '';
            showImportBanner('CSV must have a header row and at least one data row.', 'error');
            return;
          }
          var header = raw[0].map(function(h) { return String(h || '').trim().toLowerCase().replace(/\s+/g, '_'); });
          // Validate header
          if (header.indexOf('name') === -1) {
            showImportBanner('CSV missing required column: name', 'error');
            return;
          }
          var unknown = header.filter(function(h) { return KNOWN_COLS.indexOf(h) === -1; });
          if (unknown.length > 0) {
            showImportBanner('Unknown columns will be ignored: ' + unknown.join(', '), 'warn');
          }
          // Build rows
          var rows = [];
          for (var r = 1; r < raw.length; r++) {
            var line = raw[r];
            var obj = {};
            header.forEach(function(col, idx) {
              if (KNOWN_COLS.indexOf(col) === -1) return;
              var val = (line[idx] !== undefined ? String(line[idx]) : '').trim();
              if (val.length > 0) obj[col] = val;
            });
            // Skip totally empty rows
            if (Object.keys(obj).length === 0) continue;
            rows.push(obj);
          }
          if (rows.length === 0) {
            showImportBanner('No data rows found.', 'error');
            return;
          }
          importedRows = rows;
          statusEl.textContent = file.name + ' — ' + rows.length + ' row' + (rows.length === 1 ? '' : 's') + ' parsed';
          renderImportPreview(rows);
          document.getElementById('imp-preview-wrap').style.display = '';
          document.getElementById('imp-mode-wrap').style.display = '';
          document.getElementById('imp-submit').disabled = false;
        } catch (e) {
          showImportBanner('Failed to parse CSV: ' + e.message, 'error');
        }
      };
      reader.onerror = function() { showImportBanner('Could not read file.', 'error'); };
      reader.readAsText(file);
    };

    function renderImportPreview(rows) {
      var tbody = document.getElementById('imp-preview-tbody');
      var summary = document.getElementById('imp-preview-summary');
      tbody.innerHTML = '';

      // Build name index of existing humans + batch names so we can preview reports_to resolution
      var existingNamesLc = {};
      var existingByExtId = {};
      nodes.forEach(function(n) {
        if (n.type === 'human') {
          existingNamesLc[String(n.label || '').toLowerCase()] = n;
          existingByExtId[n.externalId] = n;
        }
      });
      var batchNamesLc = {};
      rows.forEach(function(r) {
        if (r.name) batchNamesLc[String(r.name).toLowerCase()] = r;
      });

      var willCreate = 0, willUpdate = 0, warnings = 0;

      rows.forEach(function(row, idx) {
        var nameLc = String(row.name || '').toLowerCase();
        var match = existingNamesLc[nameLc] || null;
        var isUpdate = !!match;
        if (isUpdate) willUpdate++; else willCreate++;

        // reports_to resolution preview
        var rtNote = '';
        if (row.reports_to) {
          var rt = String(row.reports_to).trim();
          var rtLc = rt.toLowerCase();
          if (existingNamesLc[rtLc] || batchNamesLc[rtLc]) {
            rtNote = '✓ ' + rt;
          } else if (existingByExtId[rt]) {
            rtNote = '✓ ' + rt;
          } else {
            rtNote = '⚠ ' + rt + ' (no match)';
            warnings++;
          }
        } else {
          rtNote = '—';
        }

        var tr = document.createElement('tr');
        tr.innerHTML =
          '<td style="padding:5px 8px; border-bottom:1px solid #f3f4f6; color:#6b7280;">' + (idx + 1) + '</td>' +
          '<td style="padding:5px 8px; border-bottom:1px solid #f3f4f6; color:#0f172a;">' + escapeHtml(row.name || '') + (isUpdate ? ' <span style="color:#0369a1; font-size:10px;">(update)</span>' : ' <span style="color:#059669; font-size:10px;">(new)</span>') + '</td>' +
          '<td style="padding:5px 8px; border-bottom:1px solid #f3f4f6; color:#374151;">' + escapeHtml(row.role || '') + '</td>' +
          '<td style="padding:5px 8px; border-bottom:1px solid #f3f4f6; color:#374151;">' + escapeHtml(rtNote) + '</td>' +
          '<td style="padding:5px 8px; border-bottom:1px solid #f3f4f6; color:#374151;">' + escapeHtml(row.status || '') + '</td>';
        tbody.appendChild(tr);
      });

      // Count humans that will be deleted in overwrite mode
      var batchNamesLcSet = batchNamesLc;
      var willDelete = 0;
      Object.keys(existingNamesLc).forEach(function(k) {
        if (!batchNamesLcSet[k]) willDelete++;
      });

      summary.innerHTML =
        '<span style="color:#059669;">' + willCreate + ' new</span> · ' +
        '<span style="color:#0369a1;">' + willUpdate + ' update' + (willUpdate === 1 ? '' : 's') + '</span> · ' +
        '<span style="color:#b91c1c;">' + willDelete + ' would be deleted in NEW mode</span>' +
        (warnings > 0 ? ' · <span style="color:#b45309;">' + warnings + ' warning' + (warnings === 1 ? '' : 's') + '</span>' : '');
    }

    function showImportBanner(msg, kind) {
      var banner = document.getElementById('imp-banner');
      banner.textContent = msg;
      banner.style.display = '';
      if (kind === 'error') {
        banner.style.background = '#fef2f2';
        banner.style.color = '#991b1b';
        banner.style.border = '1px solid #fecaca';
      } else if (kind === 'warn') {
        banner.style.background = '#fffbeb';
        banner.style.color = '#92400e';
        banner.style.border = '1px solid #fde68a';
      } else {
        banner.style.background = '#eff6ff';
        banner.style.color = '#1e40af';
        banner.style.border = '1px solid #bfdbfe';
      }
    }

    window.submitImport = async function() {
      if (!importedRows || importedRows.length === 0) return;
      var modeRadios = document.getElementsByName('imp-mode');
      var mode = 'addition';
      for (var i = 0; i < modeRadios.length; i++) { if (modeRadios[i].checked) { mode = modeRadios[i].value; break; } }
      if (mode === 'overwrite') {
        var ok = window.confirm('NEW / Overwrite mode will DELETE every human not present in your CSV. This cannot be undone (without restoring from a published OOS). Proceed?');
        if (!ok) return;
      }
      var btn = document.getElementById('imp-submit');
      btn.disabled = true; btn.textContent = 'Importing…';
      document.getElementById('imp-banner').style.display = 'none';

      var importBtn = btn;
      var importResult = await OTP.apiSave({
        method: 'POST', url: '/api/v1/team/import',
        body: { mode: mode, rows: importedRows },
        btnEl: importBtn,
        onError: function(err) {
          showImportBanner(OTP.formatError(err, 'Import failed'), 'error');
          importBtn.textContent = 'Import';
          return true;
        },
      });
      if (!importResult || !importResult.ok) return;
      var data = importResult.data;
      var resultEl = document.getElementById('imp-result');
      var warnHtml = '';
      if (data.warnings && data.warnings.length > 0) {
        warnHtml = '<div style="margin-top:0.5rem; color:#92400e;"><strong>' + data.warnings.length + ' warning' + (data.warnings.length === 1 ? '' : 's') + ':</strong><ul style="margin:0.25rem 0 0 1rem; padding:0; list-style:disc;">' +
          data.warnings.slice(0, 10).map(function(w) {
            return '<li>Row ' + (w.rowIndex + 1) + ' (' + escapeHtml(w.field) + '): ' + escapeHtml(w.message) + '</li>';
          }).join('') +
          (data.warnings.length > 10 ? '<li>… and ' + (data.warnings.length - 10) + ' more</li>' : '') +
          '</ul></div>';
      }
      resultEl.innerHTML = '<strong>Done.</strong> ' +
        (data.created || 0) + ' created · ' +
        (data.updated || 0) + ' updated' +
        (data.deleted ? ' · ' + data.deleted + ' deleted' : '') +
        '. Reloading…' + warnHtml;
      resultEl.style.display = '';
      importBtn.textContent = 'Imported';
      setTimeout(function() { window.location.reload(); }, 1800);
    };

