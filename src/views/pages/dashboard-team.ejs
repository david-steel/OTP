<!-- Invite-new-member modal -->
<div id="invite-new-overlay" class="edit-overlay" onclick="closeInviteNewModal()"></div>
<div id="invite-new-modal" role="dialog" aria-hidden="true" style="position:fixed; top:50%; left:50%; transform:translate(-50%, -50%) scale(0.96); opacity:0; pointer-events:none; transition: transform 200ms ease, opacity 200ms ease; z-index: 70; background:#fff; border:1px solid #e5e7eb; border-radius:14px; box-shadow: 0 30px 80px rgba(15,23,42,0.20); width: 92%; max-width: 460px;">
  <div style="padding:1.25rem 1.5rem 0.75rem 1.5rem; border-bottom: 1px solid #f3f4f6;">
    <div style="font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280; font-weight:700; margin-bottom: 0.2rem;">Invite new member</div>
    <h3 style="font-size:18px; font-weight:800; color:#0f172a; margin:0;">Create a tile and send the invite</h3>
    <p style="font-size:12px; color:#6b7280; margin:0.5rem 0 0 0;">A new human tile will be added to the chart with this name and role. The recipient will claim it on signup.</p>
  </div>
  <div style="padding:1rem 1.5rem;">
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-name">Name <span style="color:#ef4444;">*</span></label><input id="inv-new-name" type="text" placeholder="Jane Doe" /></div>
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-email">Email <span style="color:#ef4444;">*</span></label><input id="inv-new-email" type="email" placeholder="jane@company.com" /></div>
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-role">Role</label><input id="inv-new-role" type="text" placeholder="e.g. Marketing Lead, Sales Engineer" /></div>
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-reportsto">Reports to (optional)</label><select id="inv-new-reportsto"><option value="">(no parent assigned)</option></select></div>
    <div id="inv-new-status" style="font-size:12px; margin-top: 0.75rem; min-height: 1em;"></div>
  </div>
  <div style="padding:0.75rem 1.5rem 1.25rem 1.5rem; border-top: 1px solid #f3f4f6; display:flex; gap:0.5rem; justify-content:flex-end;">
    <button onclick="closeInviteNewModal()" class="px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-100">Cancel</button>
    <button id="inv-new-submit" onclick="submitInviteNew()" class="px-4 py-1.5 text-sm bg-otp-500 hover:bg-otp-400 text-white font-semibold rounded-lg disabled:opacity-50">Create tile &amp; send invite</button>
  </div>
</div>

<aside id="invites-drawer" class="invites-drawer" aria-hidden="true">
  <div class="invites-drawer-header">
    <div>
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-1">Pending invitations</div>
      <div class="text-base font-bold text-gray-900">Invitations sent, not yet accepted</div>
    </div>
    <button onclick="closeInvitesDrawer()" class="text-gray-400 hover:text-gray-700 p-1 rounded-md hover:bg-gray-100" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="invites-drawer-body" id="invites-drawer-body">
    <% if (!pendingInvites || pendingInvites.length === 0) { %>
      <div style="text-align:center; padding: 2rem 0; color: #9ca3af; font-size: 13px;">No pending invitations.<br/>Open a human tile and click "Invite to claim" to send one.</div>
    <% } else { %>
      <% pendingInvites.forEach(function(inv) { %>
        <div class="invite-row" data-invite-id="<%= inv.id %>">
          <div>
            <div class="font-semibold text-sm text-gray-900"><%= inv.email %></div>
            <div class="meta">
              <% if (inv.claimedEntityId) { %>Tile: <code class="text-[10px] bg-gray-100 px-1 rounded"><%= inv.claimedEntityId %></code> &middot; <% } %>
              Expires <%= new Date(inv.expiresAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
            </div>
          </div>
          <div class="actions">
            <button onclick="revokeInvite('<%= inv.id %>')">Revoke</button>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</aside>
<% } %>

