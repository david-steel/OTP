    </button>
  </div>
  <div class="edit-panel-body">
    <div id="edit-banner" class="edit-banner" style="display:none"></div>

    <!-- Meetings & Accountability (existing-node only; populated by JS on open) -->
    <div id="ef-meetings-block" style="display:none; margin-bottom: 1rem; padding-bottom: 0.9rem; border-bottom: 1px solid #f3f4f6;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.5rem;">
        <div style="font-size:0.7rem; text-transform:uppercase; letter-spacing:0.05em; color:#374151; font-weight:600;">Meetings &amp; Accountability</div>
        <a id="ef-profile-link" href="#" style="font-size:0.7rem; padding:0.2rem 0.55rem; background:#10b981; color:#fff; border-radius:0.35rem; text-decoration:none;">View full profile →</a>
      </div>

      <!-- Summary tiles (4 small numbers) -->
      <div id="ef-meetings-summary" style="display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:0.4rem; margin-bottom:0.6rem;">
        <div style="border:1px solid #e5e7eb; border-radius:0.4rem; padding:0.4rem; text-align:center;">
          <div id="ef-sum-rocks" style="font-size:1.05rem; font-weight:700;">—</div>
