<% if (teamNodes.length > 1) { %>
<script>
  (function() {
    var nodes = <%- JSON.stringify(teamNodes) %>;
    var edges = <%- JSON.stringify(teamEdges) %>;
    var claimedTileMap = <%- JSON.stringify(typeof claimedTileMap !== 'undefined' ? claimedTileMap : {}) %>;
    var viewerRole = <%- JSON.stringify(typeof viewerRole !== 'undefined' ? viewerRole : null) %>;
    var viewerClaimedEntityId = <%- JSON.stringify(typeof viewerClaimedEntityId !== 'undefined' ? viewerClaimedEntityId : null) %>;
    var comparisonPairs = <%- JSON.stringify(typeof comparisonPairs !== 'undefined' ? comparisonPairs : []) %>;
    var SKILLS_CATALOG = <%- JSON.stringify(typeof skillsCatalog !== 'undefined' ? skillsCatalog : []) %>;
    var ALL_CATALOG_SKILLS = SKILLS_CATALOG.reduce(function(acc, c) { return acc.concat(c.skills); }, []);
    var ALL_CATALOG_SKILLS_LOWER = new Set(ALL_CATALOG_SKILLS.map(function(s) { return s.toLowerCase(); }));
    var currentSkills = []; // working array, edited in the panel
    var skillSuggestionActive = -1;

    function renderSkillTags() {
      var box = document.getElementById('ef-skills-tag-input');
      var input = document.getElementById('ef-skills-input');
      if (!box || !input) return;
      // Clear all children except the input
      Array.from(box.children).forEach(function(c) { if (c !== input) c.remove(); });
      currentSkills.forEach(function(skill, idx) {
        var isCustom = !ALL_CATALOG_SKILLS_LOWER.has(String(skill).toLowerCase());
        var pill = document.createElement('span');
        pill.className = 'skill-tag' + (isCustom ? ' custom' : '');
        pill.innerHTML = escapeHtml(skill) + ' <span class="remove" onclick="removeSkill(' + idx + ')" title="Remove">&times;</span>';
        box.insertBefore(pill, input);
      });
    }

    window.removeSkill = function(idx) {
      currentSkills.splice(idx, 1);
      renderSkillTags();
    };

    function addSkillNormalized(raw) {
      var s = String(raw || '').trim();
      if (!s) return false;
      // Match canonical case if it's in the catalog
      var lower = s.toLowerCase();
      var canonical = ALL_CATALOG_SKILLS.find(function(x) { return x.toLowerCase() === lower; });
      var toAdd = canonical || s;
      // Dedupe (case-insensitive)
      var has = currentSkills.some(function(x) { return String(x).toLowerCase() === toAdd.toLowerCase(); });
      if (has) return false;
      currentSkills.push(toAdd);
      renderSkillTags();
      return true;
    }

    function showSkillSuggestions(query) {
      var list = document.getElementById('ef-skills-suggestions');
      var q = String(query || '').trim().toLowerCase();
      var html = '';
      var matchCount = 0;
      SKILLS_CATALOG.forEach(function(cat) {
        var matches = cat.skills.filter(function(s) {
          if (currentSkills.some(function(x) { return String(x).toLowerCase() === s.toLowerCase(); })) return false;
          return q === '' || s.toLowerCase().indexOf(q) !== -1;
        });
        if (matches.length === 0) return;
        html += '<div class="skill-suggestion-cat">' + escapeHtml(cat.category) + '</div>';
        matches.forEach(function(s) {
          html += '<div class="skill-suggestion" data-skill="' + escapeHtml(s) + '" onclick="acceptSkillSuggestion(\'' + s.replace(/'/g, "\\'") + '\')">' + escapeHtml(s) + '</div>';
          matchCount++;
        });
      });
      // Custom-add row when the query is non-empty and not already in catalog
      if (q && !ALL_CATALOG_SKILLS_LOWER.has(q) && !currentSkills.some(function(x) { return String(x).toLowerCase() === q; })) {
        html += '<div class="skill-suggestion add-custom" onclick="acceptCustomSkill()">+ Add &quot;' + escapeHtml(q) + '&quot; as a custom skill</div>';
      }
      if (html) {
        list.innerHTML = html;
        list.classList.add('open');
        skillSuggestionActive = -1;
      } else {
        list.classList.remove('open');
      }
    }

    function hideSkillSuggestions() {
      var list = document.getElementById('ef-skills-suggestions');
      if (list) list.classList.remove('open');
      skillSuggestionActive = -1;
    }

    window.acceptSkillSuggestion = function(skill) {
      addSkillNormalized(skill);
      var input = document.getElementById('ef-skills-input');
      if (input) { input.value = ''; input.focus(); }
      hideSkillSuggestions();
    };

    window.acceptCustomSkill = function() {
      var input = document.getElementById('ef-skills-input');
      if (!input) return;
      addSkillNormalized(input.value);
      input.value = '';
      input.focus();
      hideSkillSuggestions();
    };

    document.addEventListener('DOMContentLoaded', function() {
      var input = document.getElementById('ef-skills-input');
      if (!input) return;
      input.addEventListener('input', function() { showSkillSuggestions(input.value); });
      input.addEventListener('focus', function() { showSkillSuggestions(input.value); });
      input.addEventListener('keydown', function(ev) {
        if (ev.key === 'Enter') {
          ev.preventDefault();
          if (input.value.trim()) {
            addSkillNormalized(input.value);
            input.value = '';
            hideSkillSuggestions();
          }
        } else if (ev.key === 'Backspace' && !input.value && currentSkills.length > 0) {
          currentSkills.pop();
          renderSkillTags();
        } else if (ev.key === 'Escape') {
          hideSkillSuggestions();
        }
      });
      // Close suggestions when clicking outside
      document.addEventListener('click', function(ev) {
        var box = document.getElementById('ef-skills-tag-input');
        var list = document.getElementById('ef-skills-suggestions');
        if (!box || !list) return;
        if (!box.contains(ev.target) && !list.contains(ev.target)) hideSkillSuggestions();
      });
    });

    var byId = {};
    nodes.forEach(function(n) { byId[n.id] = n; });

    // ---- Build parent map from escalation edges + sensible defaults ----
    function computeParents(filterFn) {
      var parent = {};
      var allowed = {};
      nodes.forEach(function(n) { if (filterFn(n)) allowed[n.id] = true; });

      // explicit hierarchy edges (child -> parent)
      edges.forEach(function(e) {
        if (e.type !== 'escalates_to' && e.type !== 'reports_to') return;
        if (!allowed[e.sourceId] || !allowed[e.targetId]) return;
        // reports_to wins over escalates_to if both present (humans use reports_to)
        if (e.type === 'reports_to' || !parent[e.sourceId]) {
          parent[e.sourceId] = e.targetId;
        }
      });

      // Find a CEO-ish human to anchor unparented nodes
      var ceo = null, coo = null;
      nodes.forEach(function(n) {
        if (!allowed[n.id]) return;
        if (n.type !== 'human') return;
        var p = n.properties || {};
        if (p.authorityLevel === 'full' || /CEO|founder/i.test(p.role || '')) { if (!ceo) ceo = n.id; }
        if (p.authorityLevel === 'executive' || /COO/i.test(p.role || '')) { if (!coo) coo = n.id; }
      });
      var orgNode = nodes.find(function(n) { return n.type === 'organization' && allowed[n.id]; });
      var orgId = orgNode ? orgNode.id : null;

      // For everyone without a parent (other than the org node itself) wire to:
      //   CEO if found, else ORG. Operators-without-parent prefer COO if present.
      nodes.forEach(function(n) {
        if (!allowed[n.id]) return;
        if (n.id === orgId) return;
        if (parent[n.id]) return;
        var p = n.properties || {};
        if (n.type === 'human') {
          if (n.id === ceo) {
            parent[n.id] = orgId; // CEO is direct child of organization
          } else if (n.id === coo) {
            parent[n.id] = ceo || orgId;
          } else {
            // operator humans: prefer COO, else CEO, else ORG
            parent[n.id] = coo || ceo || orgId;
          }
        } else if (n.type === 'agent') {
          parent[n.id] = ceo || orgId;
        }
      });

      // Org node has no parent (it is the root)
      return { parent: parent, rootId: orgId };
    }

    // ---- Layout + render ----
    var NODE_W = 200;
    var NODE_H = 80;
    var H_GAP  = 18;
    var V_GAP  = 56;

    function buildHierarchy(filterFn) {
      var pm = computeParents(filterFn);
      var allowedNodes = nodes.filter(filterFn);
      // d3.stratify needs a single rooted tree
      try {
        return d3.stratify().id(function(d) { return d.id; }).parentId(function(d) { return d.id === pm.rootId ? null : pm.parent[d.id]; })(allowedNodes);
      } catch (e) {
        // Fallback: synthesize a virtual root if multiple roots exist
        var data = allowedNodes.slice();
        var virtId = '__VIRT__';
        data.unshift({ id: virtId, externalId: virtId, type: 'organization', label: 'Team', properties: {} });
        var pm2 = pm.parent;
        return d3.stratify().id(function(d) { return d.id; }).parentId(function(d) {
          if (d.id === virtId) return null;
          return pm2[d.id] || virtId;
        })(data);
      }
    }

    var stage = document.getElementById('org-stage');
    var shell = document.getElementById('org-shell');
    var tooltip = document.getElementById('org-tooltip');

    function renderChart(filterFn) {
      stage.innerHTML = '';
      var root;
      try { root = buildHierarchy(filterFn); }
      catch (e) { stage.innerHTML = '<div style="padding:2rem;color:#6b7280;font-size:14px;">Could not build hierarchy: ' + e.message + '</div>'; return; }

      var layout = d3.tree().nodeSize([NODE_W + H_GAP, NODE_H + V_GAP]);
      layout(root);

      var minX = Infinity, maxX = -Infinity, maxY = 0;
      root.each(function(d) {
        if (d.x < minX) minX = d.x;
        if (d.x > maxX) maxX = d.x;
        if (d.y > maxY) maxY = d.y;
      });
      var pad = 24;
      var offsetX = -minX + pad;
      var totalWidth  = (maxX - minX) + NODE_W + pad * 2;
      var totalHeight = maxY + NODE_H + pad * 2;
      stage.style.width  = totalWidth  + 'px';
      stage.style.height = totalHeight + 'px';

      // SVG layer for connectors
      var svgNS = 'http://www.w3.org/2000/svg';
      var svg = document.createElementNS(svgNS, 'svg');
      svg.setAttribute('width', totalWidth);
      svg.setAttribute('height', totalHeight);
      svg.style.position = 'absolute';
      svg.style.inset = '0';
      svg.style.pointerEvents = 'none';
      stage.appendChild(svg);

      root.each(function(d) {
        if (!d.parent) return;
        var px = d.parent.x + offsetX + NODE_W / 2;
        var py = d.parent.y + NODE_H + pad;
        var cx = d.x + offsetX + NODE_W / 2;
        var cy = d.y + pad;
        var midY = py + (cy - py) / 2;
        var path = document.createElementNS(svgNS, 'path');
        var edgeType;
        if (d.parent.data.id === '__VIRT__') edgeType = 'part_of';
        else if (d.data.type === 'human') edgeType = 'reports_to';
        else edgeType = 'escalates_to';
        path.setAttribute('d', 'M ' + px + ',' + py + ' L ' + px + ',' + midY + ' L ' + cx + ',' + midY + ' L ' + cx + ',' + cy);
        path.setAttribute('class', 'org-connector ' + edgeType);
        svg.appendChild(path);
      });

      // ---- Same-role comparison curves (Phase 4.8) ----
      // Map node ids to layout coordinates for paired lookups.
      var coordsById = {};
      root.each(function(d) {
        if (d.data.id === '__VIRT__') return;
        coordsById[d.data.id] = { x: d.x + offsetX, y: d.y + pad };
      });
      comparisonPairs.forEach(function(pair) {
        var a = coordsById[pair.a];
        var b = coordsById[pair.b];
        if (!a || !b) return;
        var ax = a.x + NODE_W / 2;
        var ay = a.y + NODE_H / 2;
        var bx = b.x + NODE_W / 2;
        var by = b.y + NODE_H / 2;
        // Curved bezier above the midpoint -- distinguishes from orthogonal connectors
        var midX = (ax + bx) / 2;
        var topY = Math.min(ay, by) - Math.max(60, Math.abs(bx - ax) / 4);
        var path = document.createElementNS(svgNS, 'path');
        path.setAttribute('d', 'M ' + ax + ',' + ay + ' Q ' + midX + ',' + topY + ' ' + bx + ',' + by);
        path.setAttribute('class', 'org-comparison');
        path.dataset.pairA = pair.a;
        path.dataset.pairB = pair.b;
        path.dataset.reason = pair.reason || '';
        path.addEventListener('click', function(ev) {
          ev.stopPropagation();
          openCompare(pair.a, pair.b, pair.reason);
        });
        path.addEventListener('mouseenter', function(ev) {
          showTooltip(ev, { label: 'Compare these agents', type: 'comparison', properties: { role: pair.reason } });
        });
        path.addEventListener('mouseleave', function() { hideTooltip(); });
        svg.appendChild(path);
      });

      root.each(function(d) {
        if (d.data.id === '__VIRT__') return;
        var x = d.x + offsetX;
        var y = d.y + pad;
        var n = d.data;
        var p2 = n.properties || {};
        var statusLower = String(p2.status || '').toLowerCase();
        var isInactive = ['inactive', 'retired', 'terminated'].indexOf(statusLower) !== -1;
        var isClaimed = (n.type === 'human' && claimedTileMap[n.externalId]);
        var box = document.createElement('div');
        box.className = 'org-node type-' + n.type + (isInactive ? ' inactive' : '') + (isClaimed ? ' claimed' : '');
        box.style.left = x + 'px';
        box.style.top  = y + 'px';
        box.style.width  = NODE_W + 'px';
        box.style.height = NODE_H + 'px';

        var inner = '';
        if (n.type !== 'organization') inner += '<div class="stripe"></div>';
        var p = n.properties || {};
        var typeLabel = n.type === 'agent' ? 'Agent' : (n.type === 'human' ? 'Human' : 'Org');
        var sopCount = Array.isArray(p.sops) ? p.sops.length : 0;
        inner += '<div class="row-top">';
        inner += '<div class="name" title="' + escapeHtml(n.label) + '">' + escapeHtml(n.label) + '</div>';
        if (n.type !== 'organization') {
          var typePill = '<div class="badge-type">' + typeLabel + '</div>';
          var sopPill = sopCount > 0 ? '<div class="sop-badge" title="' + sopCount + ' SOP' + (sopCount === 1 ? '' : 's') + '">' + sopCount + ' SOP' + (sopCount === 1 ? '' : 's') + '</div>' : '';
          var claimPill = isClaimed ? '<div class="claimed-badge" title="Claimed by member">claimed</div>' : '';
          inner += '<div style="display:flex; align-items:center; gap:0.25rem; flex-shrink:0;">' + claimPill + sopPill + typePill + '</div>';
        }
        inner += '</div>';
        if (p.role) inner += '<div class="role" title="' + escapeHtml(String(p.role)) + '">' + escapeHtml(String(p.role)) + '</div>';
        var meta = [];
        if (p.authorityLevel) meta.push(escapeHtml(String(p.authorityLevel)));
        if (p.platform) meta.push(escapeHtml(String(p.platform)));
        if (p.status) meta.push(escapeHtml(String(p.status)));
        if (meta.length) inner += '<div class="meta">' + meta.map(function(m) { return '<span>' + m + '</span>'; }).join('') + '</div>';

        if (n.type === 'human') {
          var contacts = [];
          if (p.contactEmail) contacts.push('<span class="contact-pill" title="' + escapeHtml(String(p.contactEmail)) + '">@</span>');
          if (p.contactPhone) contacts.push('<span class="contact-pill" title="' + escapeHtml(String(p.contactPhone)) + '">tel</span>');
          if (p.slackId) contacts.push('<span class="contact-pill" title="Slack: ' + escapeHtml(String(p.slackId)) + '">slack</span>');
          if (contacts.length) inner += '<div class="contacts">' + contacts.join('') + '</div>';
        }

        box.innerHTML = inner;

        box.addEventListener('mouseenter', function(ev) { showTooltip(ev, n); });
        box.addEventListener('mousemove',  function(ev) { positionTooltip(ev); });
        box.addEventListener('mouseleave', function() { hideTooltip(); });
        if (n.type !== 'organization') {
          box.addEventListener('click', function(ev) {
            ev.stopPropagation();
            document.querySelectorAll('.org-node.selected').forEach(function(el) { el.classList.remove('selected'); });
            box.classList.add('selected');
            openEditPanel(n);
          });

          // ---- Drag-and-drop hierarchy editing ----
          box.setAttribute('draggable', 'true');
          box.dataset.nodeId = n.id;
          box.dataset.nodeType = n.type;
          box.dataset.externalId = n.externalId;

          box.addEventListener('dragstart', function(ev) {
            ev.dataTransfer.effectAllowed = 'move';
            ev.dataTransfer.setData('text/plain', n.id);
            box.classList.add('dragging');
            window.__dragSource = { node: n, descendants: collectDescendantIds(d) };
            hideTooltip();
            showDragStatus('Drag onto a target to make it the new parent.');
          });
          box.addEventListener('dragend', function() {
            box.classList.remove('dragging');
            document.querySelectorAll('.org-node.drop-target,.org-node.drop-invalid').forEach(function(el) {
              el.classList.remove('drop-target','drop-invalid');
            });
            window.__dragSource = null;
            hideDragStatus();
          });
          box.addEventListener('dragover', function(ev) {
            if (!window.__dragSource) return;
            var src = window.__dragSource;
            if (n.id === src.node.id) return;
            ev.preventDefault();
            var invalid = src.descendants.has(n.id);
            ev.dataTransfer.dropEffect = invalid ? 'none' : 'move';
            box.classList.toggle('drop-target', !invalid);
            box.classList.toggle('drop-invalid', invalid);
          });
          box.addEventListener('dragleave', function() {
            box.classList.remove('drop-target','drop-invalid');
          });
          box.addEventListener('drop', function(ev) {
            ev.preventDefault();
            box.classList.remove('drop-target','drop-invalid');
            var src = window.__dragSource;
            if (!src) return;
            if (n.id === src.node.id) return;
            if (src.descendants.has(n.id)) {
              showDragStatus('Cannot drop ' + src.node.label + ' onto its own descendant.', true);
              setTimeout(hideDragStatus, 2400);
              return;
            }
            handleHierarchyDrop(src.node, n);
          });
        }

        stage.appendChild(box);
      });
    }

    function collectDescendantIds(d) {
      var set = new Set();
      d.descendants().forEach(function(x) { set.add(x.data.id); });
      return set;
    }

    var dragStatusEl = null;
    function showDragStatus(msg, isError) {
      if (!dragStatusEl) {
        dragStatusEl = document.createElement('div');
        dragStatusEl.className = 'drag-status';
        document.body.appendChild(dragStatusEl);
      }
      dragStatusEl.textContent = msg;
      dragStatusEl.style.background = isError ? 'rgba(153,27,27,0.95)' : 'rgba(15,23,42,0.92)';
      dragStatusEl.classList.add('visible');
    }
    function hideDragStatus() { if (dragStatusEl) dragStatusEl.classList.remove('visible'); }

    async function handleHierarchyDrop(srcNode, targetNode) {
      var fieldKey = srcNode.type === 'agent' ? 'escalates_to' : 'reports_to';
      var patch = {};
      patch[fieldKey] = targetNode.externalId;
      showDragStatus('Saving ' + srcNode.label + ' -> ' + targetNode.label + '…');
      try {
        var res = await fetch('/api/v1/team/entity', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: srcNode.type, externalId: srcNode.externalId, patch: patch }),
        });
        if (!res.ok) {
          var err = await res.json().catch(function() { return {}; });
          showDragStatus('Save failed: ' + ((err.error && err.error.message) || res.status), true);
          setTimeout(hideDragStatus, 2400);
          return;
        }
        showDragStatus('Saved. Reloading…');
        window.location.reload();
      } catch (e) {
        showDragStatus('Network error: ' + e.message, true);
        setTimeout(hideDragStatus, 2400);
      }
    }

    function escapeHtml(s) { return String(s).replace(/[&<>"']/g, function(c) { return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c]; }); }
    function showTooltip(ev, n) {
      var p = n.properties || {};
      var html = '<div class="ttl">' + escapeHtml(n.label) + '</div>';
      html += '<div class="row"><strong>Type:</strong> ' + n.type + '</div>';
      if (p.role) html += '<div class="row"><strong>Role:</strong> ' + escapeHtml(String(p.role)) + '</div>';
      if (p.mission) html += '<div class="row"><strong>Mission:</strong> ' + escapeHtml(String(p.mission)) + '</div>';
      if (p.authorityLevel) html += '<div class="row"><strong>Authority:</strong> ' + escapeHtml(String(p.authorityLevel)) + '</div>';
      if (Array.isArray(p.skills) && p.skills.length) html += '<div class="row"><strong>Skills:</strong> ' + escapeHtml(p.skills.join(', ')) + '</div>';
      var ownSops = Array.isArray(p.sops) ? p.sops.length : 0;
      if (ownSops > 0) html += '<div class="row"><strong>SOPs:</strong> ' + ownSops + '</div>';
      if (n.type === 'agent') {
        var inh = getInheritedFor(n);
        if (inh && inh.sops.length > 0) html += '<div class="row"><strong>Inherits:</strong> ' + inh.sops.length + ' SOP' + (inh.sops.length === 1 ? '' : 's') + ' from ' + escapeHtml(inh.parent.label) + '</div>';
      }
      if (n.type !== 'organization') html += '<div class="row" style="margin-top:0.25rem; color:#94a3b8;">Click to edit</div>';
      tooltip.innerHTML = html;
      tooltip.classList.add('visible');
      positionTooltip(ev);
    }
    function positionTooltip(ev) {
      var x = ev.clientX + 14;
      var y = ev.clientY + 14;
      tooltip.style.left = x + 'px';
      tooltip.style.top = y + 'px';
    }
    function hideTooltip() { tooltip.classList.remove('visible'); }

    // ---- Initial render ----
    var FILTER_STORAGE_KEY = 'otp-team-chart-filter';
    var savedFilter = (function() {
      try { return localStorage.getItem(FILTER_STORAGE_KEY); } catch (e) { return null; }
    })();
    var currentFilter = (savedFilter && ['all','agent','human'].indexOf(savedFilter) !== -1) ? savedFilter : 'all';
    var filterFns = {
      all:   function(n) { return true; },
      agent: function(n) { return n.type === 'agent' || n.type === 'organization' || (n.type === 'human' && (n.properties || {}).authorityLevel === 'full'); },
      human: function(n) { return n.type === 'human' || n.type === 'organization'; },
    };

    function setActiveFilterBtn(f) {
      document.querySelectorAll('.filter-btn').forEach(function(b) {
        if (b.getAttribute('data-filter') === f) {
          b.classList.add('bg-gray-900','text-white');
          b.classList.remove('text-gray-600');
        } else {
          b.classList.remove('bg-gray-900','text-white');
          b.classList.add('text-gray-600');
        }
      });
    }

    setActiveFilterBtn(currentFilter);
    renderChart(filterFns[currentFilter]);

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var f = btn.getAttribute('data-filter');
        currentFilter = f;
        try { localStorage.setItem(FILTER_STORAGE_KEY, f); } catch (e) {}
        setActiveFilterBtn(f);
        renderChart(filterFns[f]);
      });
    });

    window.addEventListener('resize', function() { /* no-op for now; layout stays fixed */ });

    // ---- Edit panel wiring ----
    var currentNode = null;
    var currentSops = [];   // working copy edited in the panel; PATCH sends this on save
    var editingSopIdx = -1; // which SOP card is open for editing (-1 = none)

    function genSopId(title) {
      var slug = String(title || 'sop').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 40) || 'sop';
      return 'SOP_' + slug.toUpperCase().replace(/-/g, '_') + '_' + Math.random().toString(36).slice(2, 6).toUpperCase();
    }

    window.addSop = function() {
      currentSops.push({ id: genSopId('new-sop'), title: '', trigger: '', steps: [], outputs: [], tools: [], notes: '' });
      editingSopIdx = currentSops.length - 1;
      renderSopList();
    };

    var SOP_TEMPLATE_GROUPS = <%- JSON.stringify(typeof sopTemplateGroups !== 'undefined' ? sopTemplateGroups : []) %>;
    window.insertTemplate = function(value) {
      if (!value) return;
      var parts = value.split(':');
      if (parts.length !== 2) return;
      var roleId = parts[0], templateId = parts[1];
      var group = SOP_TEMPLATE_GROUPS.find(function(g) { return g.roleId === roleId; });
      if (!group) return;
      var tpl = group.templates.find(function(t) { return t.id === templateId; });
      if (!tpl) return;
      // Deep copy + assign a fresh runtime id so the SOP is unique on save
      var copy = JSON.parse(JSON.stringify(tpl));
      copy.id = genSopId(tpl.title);
      currentSops.push(copy);
      editingSopIdx = currentSops.length - 1;
      renderSopList();
    };
    window.toggleSop = function(idx) {
      editingSopIdx = (editingSopIdx === idx ? -1 : idx);
      renderSopList();
    };
    window.deleteSop = function(idx) {
      if (!confirm('Delete this SOP from the draft?')) return;
      currentSops.splice(idx, 1);
      if (editingSopIdx === idx) editingSopIdx = -1;
      else if (editingSopIdx > idx) editingSopIdx--;
      renderSopList();
    };
    window.updateSopField = function(idx, field, value) {
      if (!currentSops[idx]) return;
      if (field === 'steps' || field === 'outputs' || field === 'tools') {
        currentSops[idx][field] = (value || '').split(/\n+/).map(function(s) { return s.trim(); }).filter(Boolean);
      } else {
        currentSops[idx][field] = value;
      }
    };

    function renderSopList() {
      var list = document.getElementById('ef-sop-list');
      var countEl = document.getElementById('ef-sop-count');
      countEl.textContent = currentSops.length === 0 ? '' : '(' + currentSops.length + ')';
      if (currentSops.length === 0) {
        list.innerHTML = '<div class="sop-empty">No SOPs yet. Click "+ Add SOP" to author one.</div>';
        return;
      }
      list.innerHTML = '';
      currentSops.forEach(function(sop, idx) {
        var card = document.createElement('div');
        card.className = 'sop-card' + (editingSopIdx === idx ? ' editing' : '');
        var titleSafe = escapeHtml(sop.title || '(untitled SOP)');
        var titleVal = String(sop.title || '');
        var triggerVal = String(sop.trigger || '');
        var stepsVal = Array.isArray(sop.steps) ? sop.steps.join('\n') : '';
        var outputsVal = Array.isArray(sop.outputs) ? sop.outputs.join('\n') : '';
        var toolsVal = Array.isArray(sop.tools) ? sop.tools.join('\n') : '';
        var notesVal = String(sop.notes || '');
        card.innerHTML = ''
          + '<div class="sop-card-header" onclick="toggleSop(' + idx + ')">'
          +   '<div class="sop-card-title">' + titleSafe + '</div>'
          +   '<div class="sop-card-actions">'
          +     '<button type="button" class="sop-card-btn" onclick="event.stopPropagation(); toggleSop(' + idx + ')">' + (editingSopIdx === idx ? 'Close' : 'Edit') + '</button>'
          +     '<button type="button" class="sop-card-btn delete" onclick="event.stopPropagation(); deleteSop(' + idx + ')">Delete</button>'
          +   '</div>'
          + '</div>'
          + '<div class="sop-card-body">'
          +   '<div class="sop-field"><label>Title</label><input type="text" value="' + escapeHtml(titleVal) + '" oninput="updateSopField(' + idx + ', \'title\', this.value)" placeholder="e.g. Daily inbox triage" /></div>'
          +   '<div class="sop-field"><label>Trigger (when to invoke)</label><input type="text" value="' + escapeHtml(triggerVal) + '" oninput="updateSopField(' + idx + ', \'trigger\', this.value)" placeholder="e.g. Every weekday at 8 AM" /></div>'
          +   '<div class="sop-field"><label>Steps (one per line)</label><textarea rows="4" oninput="updateSopField(' + idx + ', \'steps\', this.value)" placeholder="Mark obvious spam\nDraft replies for routine client emails\nEscalate financial >$5K">' + escapeHtml(stepsVal) + '</textarea></div>'
          +   '<div class="sop-field"><label>Outputs (one per line)</label><textarea rows="2" oninput="updateSopField(' + idx + ', \'outputs\', this.value)" placeholder="Drafted replies\nDaily inbox health summary">' + escapeHtml(outputsVal) + '</textarea></div>'
          +   '<div class="sop-field"><label>Tools (one per line)</label><textarea rows="2" oninput="updateSopField(' + idx + ', \'tools\', this.value)" placeholder="Gmail MCP\nTodoist">' + escapeHtml(toolsVal) + '</textarea></div>'
          +   '<div class="sop-field"><label>Notes (optional)</label><textarea rows="2" oninput="updateSopField(' + idx + ', \'notes\', this.value)">' + escapeHtml(notesVal) + '</textarea></div>'
          + '</div>';
        list.appendChild(card);
      });
    }

    function getInheritedFor(d) {
      if (d.type !== 'agent') return null;
      var p = d.properties || {};
      var parentExtId = p.escalatesTo;
      if (!parentExtId) return null;
      var parent = nodes.find(function(n) { return n.externalId === String(parentExtId); });
      if (!parent) return null;
      var pp = parent.properties || {};
      var sops = Array.isArray(pp.sops) ? pp.sops : [];
      return { parent: parent, sops: sops };
    }

    function renderInheritedFor(d) {
      var section = document.getElementById('ef-inherited-section');
      var inh = getInheritedFor(d);
      if (!inh || inh.sops.length === 0) {
        section.style.display = 'none';
        return;
      }
      section.style.display = '';
      document.getElementById('ef-inherited-count').textContent = '(' + inh.sops.length + ')';
      document.getElementById('ef-inherited-source').textContent = 'Inherited from ' + inh.parent.label + ' (' + inh.parent.type + ')';
      var list = document.getElementById('ef-inherited-list');
      list.innerHTML = '';
      inh.sops.forEach(function(sop) {
        var card = document.createElement('div');
        card.className = 'sop-card';
        var titleSafe = escapeHtml(sop.title || '(untitled SOP)');
        var bodyParts = [];
        if (sop.trigger) bodyParts.push('<div class="sop-field"><label>Trigger</label><div style="font-size:12px;color:#374151;">' + escapeHtml(sop.trigger) + '</div></div>');
        if (Array.isArray(sop.steps) && sop.steps.length) {
          bodyParts.push('<div class="sop-field"><label>Steps</label><ol style="margin:0;padding-left:1.25rem;font-size:12px;color:#374151;">' + sop.steps.map(function(s) { return '<li>' + escapeHtml(String(s)) + '</li>'; }).join('') + '</ol></div>');
        }
        if (Array.isArray(sop.outputs) && sop.outputs.length) {
          bodyParts.push('<div class="sop-field"><label>Outputs</label><ul style="margin:0;padding-left:1.25rem;font-size:12px;color:#374151;">' + sop.outputs.map(function(o) { return '<li>' + escapeHtml(String(o)) + '</li>'; }).join('') + '</ul></div>');
        }
        card.innerHTML = '<div class="sop-card-header" style="cursor:default;"><div class="sop-card-title">' + titleSafe + '</div></div>'
          + (bodyParts.length ? '<div class="sop-card-body" style="display:block;">' + bodyParts.join('') + '</div>' : '');
        list.appendChild(card);
      });
    }

    window.copyAgentContext = async function() {
      if (!currentNode || currentNode.type !== 'agent') return;
      var status = document.getElementById('ef-copy-context-status');
      status.textContent = 'Loading…';
      try {
        var res = await fetch('/api/v1/team/agent/' + encodeURIComponent(currentNode.externalId) + '/context?format=md', { method: 'GET' });
        if (!res.ok) {
          status.style.color = '#b91c1c';
          status.textContent = 'Failed (' + res.status + ')';
          return;
        }
        var md = await res.text();
        await navigator.clipboard.writeText(md);
        status.style.color = '#059669';
        status.textContent = 'Copied (' + md.length + ' chars)';
        setTimeout(function() { status.textContent = ''; }, 2400);
      } catch (e) {
        status.style.color = '#b91c1c';
        status.textContent = 'Error: ' + e.message;
      }
    };

    window.openEditPanel = function(d) {
      currentNode = d;
      var p = d.properties || {};
      currentSops = Array.isArray(p.sops) ? JSON.parse(JSON.stringify(p.sops)) : [];
      editingSopIdx = -1;
      renderSopList();
      renderInheritedFor(d);
      document.getElementById('ef-context-section').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-runtime-section').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-runtime-body').value = (d.type === 'agent' ? (p.runtimeBody || '') : '');
      document.getElementById('edit-type-label').textContent = (d.type === 'agent' ? 'Edit agent' : 'Edit human');
      document.getElementById('edit-name-display').textContent = d.label + ' (' + d.externalId + ')';
      document.getElementById('ef-name').value = d.label || '';
      document.getElementById('ef-role').value = p.role || '';
      document.getElementById('ef-mission').value = p.mission || '';
      document.getElementById('ef-jobdesc').value = p.jobDescription || '';
      document.getElementById('ef-authority').value = p.authorityLevel || '';
      document.getElementById('ef-platform').value = p.platform || '';
      document.getElementById('ef-status').value = p.status || '';
      currentSkills = Array.isArray(p.skills) ? p.skills.slice() : [];
      renderSkillTags();
      hideSkillSuggestions();
      document.getElementById('ef-contact-email').value = p.contactEmail || '';
      document.getElementById('ef-contact-phone').value = p.contactPhone || '';
      document.getElementById('ef-slackid').value = p.slackId || '';
      document.getElementById('ef-mission-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-jobdesc-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-platform-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-status-wrap').style.display = '';
      document.getElementById('ef-escalates-wrap').style.display = (d.type === 'agent' ? '' : 'none');
      document.getElementById('ef-reportsto-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-contact-email-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-contact-phone-wrap').style.display = (d.type === 'human' ? '' : 'none');
      document.getElementById('ef-slackid-wrap').style.display = (d.type === 'human' ? '' : 'none');

      // Invite section: only visible to owner viewing a human tile
      var inviteSection = document.getElementById('ef-invite-section');
      if (inviteSection) {
        var canInvite = (viewerRole === 'owner' && d.type === 'human');
        inviteSection.style.display = canInvite ? '' : 'none';
        if (canInvite) {
          var claimedByEl = document.getElementById('ef-invite-claimed-by');
          var existing = claimedTileMap[d.externalId];
          if (existing) {
            claimedByEl.style.display = '';
            claimedByEl.textContent = 'Already claimed by member ' + existing.clerkUserId + '. New invitations would replace nothing -- you can revoke pending invites from the drawer.';
            document.getElementById('ef-invite-email').value = (p.contactEmail || '');
          } else {
            claimedByEl.style.display = 'none';
            // Pre-fill with the tile's contact email if known
            document.getElementById('ef-invite-email').value = (p.contactEmail || '');
          }
          document.getElementById('ef-invite-status').textContent = '';
        }
      }

      var fillSelect = function(selectEl, currentValue) {
        selectEl.innerHTML = '<option value="">(none)</option>';
        nodes.forEach(function(n) {
          if (n.type === 'organization') return;
          if (n.id === d.id) return;
          var opt = document.createElement('option');
          opt.value = n.externalId;
          opt.textContent = n.label + ' (' + n.type + ')';
          if (currentValue && String(currentValue) === n.externalId) opt.selected = true;
          selectEl.appendChild(opt);
        });
      };
      fillSelect(document.getElementById('ef-escalates'), p.escalatesTo);
      fillSelect(document.getElementById('ef-reportsto'), p.reportsTo);
      document.getElementById('edit-banner').style.display = 'none';
      document.getElementById('edit-panel').classList.add('open');
      document.getElementById('edit-overlay').classList.add('open');
      document.getElementById('edit-panel').setAttribute('aria-hidden', 'false');
    };
    window.closeEdit = function() {
      document.getElementById('edit-panel').classList.remove('open');
      document.getElementById('edit-overlay').classList.remove('open');
      document.getElementById('edit-panel').setAttribute('aria-hidden', 'true');
      document.querySelectorAll('.org-node.selected').forEach(function(el) { el.classList.remove('selected'); });
      currentNode = null;
    };
    window.saveEdit = async function() {
      if (!currentNode) return;
      var btn = document.getElementById('ef-save');
      var banner = document.getElementById('edit-banner');
      banner.style.display = 'none';
      banner.classList.remove('error');
      var skills = (currentSkills && currentSkills.length > 0) ? currentSkills.slice() : [];
      var patch = {};
      var setIfPresent = function(key, val) { if (val !== undefined && val !== null) patch[key] = val; };
      setIfPresent('name',           document.getElementById('ef-name').value.trim());
      setIfPresent('role',           document.getElementById('ef-role').value.trim());
      setIfPresent('authority_level', document.getElementById('ef-authority').value.trim());
      if (currentNode.type === 'agent') {
        setIfPresent('mission',        document.getElementById('ef-mission').value.trim());
        setIfPresent('platform',       document.getElementById('ef-platform').value.trim());
        setIfPresent('status',         document.getElementById('ef-status').value.trim());
        var esc = document.getElementById('ef-escalates').value.trim();
        patch.escalates_to = esc === '' ? null : esc;
        var rb = (document.getElementById('ef-runtime-body').value || '').trim();
        patch.runtime_body = rb === '' ? null : rb;
      } else if (currentNode.type === 'human') {
        setIfPresent('job_description', document.getElementById('ef-jobdesc').value.trim());
        var rep = document.getElementById('ef-reportsto').value.trim();
        patch.reports_to = rep === '' ? null : rep;
        var ce = document.getElementById('ef-contact-email').value.trim();
        var cp = document.getElementById('ef-contact-phone').value.trim();
        var sid = document.getElementById('ef-slackid').value.trim();
        patch.contact_email = ce === '' ? null : ce;
        patch.contact_phone = cp === '' ? null : cp;
        patch.slack_id = sid === '' ? null : sid;
      }
      var statusVal = document.getElementById('ef-status').value.trim();
      if (statusVal) patch.status = statusVal;
      patch.skills = skills;

      // Send the full SOP array. Drop SOPs without a title (incomplete adds).
      var cleanSops = currentSops
        .filter(function(s) { return s && String(s.title || '').trim().length > 0; })
        .map(function(s) {
          var out = { title: String(s.title).trim() };
          if (s.id) out.id = s.id;
          if (s.trigger && s.trigger.trim()) out.trigger = s.trigger.trim();
          if (Array.isArray(s.steps) && s.steps.length) out.steps = s.steps;
          if (Array.isArray(s.outputs) && s.outputs.length) out.outputs = s.outputs;
          if (Array.isArray(s.tools) && s.tools.length) out.tools = s.tools;
          if (s.notes && s.notes.trim()) out.notes = s.notes.trim();
          return out;
        });
      patch.sops = cleanSops;
      btn.disabled = true; btn.textContent = 'Saving…';
      try {
        var res = await fetch('/api/v1/team/entity', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: currentNode.type, externalId: currentNode.externalId, patch: patch }),
        });
        if (!res.ok) {
          var err = await res.json().catch(function() { return {}; });
          banner.textContent = (err.error && err.error.message) || ('Save failed (' + res.status + ')');
          banner.classList.add('error');
          banner.style.display = '';
          btn.disabled = false; btn.textContent = 'Save to draft';
          return;
        }
        window.location.reload();
      } catch (e) {
        banner.textContent = 'Network error: ' + e.message;
        banner.classList.add('error');
        banner.style.display = '';
        btn.disabled = false; btn.textContent = 'Save to draft';
      }
    };
    document.addEventListener('keydown', function(ev) {
      if (ev.key === 'Escape') {
        closeEdit();
        if (typeof closeInvitesDrawer === 'function') closeInvitesDrawer();
        if (typeof closeCompare === 'function') closeCompare();
      }
    });

    function renderSopMini(sop, isMatch) {
      var lines = [];
      lines.push('<div class="sop-mini' + (isMatch ? '' : '') + '">');
      lines.push('<div class="t">' + escapeHtml(sop.title || '(untitled)') + '</div>');
      if (sop.trigger) lines.push('<div class="tr">' + escapeHtml(String(sop.trigger)) + '</div>');
      lines.push('</div>');
      return lines.join('');
    }

    function renderCompareCol(node, otherTitleSet) {
      var p = node.properties || {};
      var sops = Array.isArray(p.sops) ? p.sops : [];
      var html = '';
      html += '<div class="compare-col">';
      html += '<h4>' + escapeHtml(node.label) + '</h4>';
      html += '<div class="role">' + escapeHtml(String(p.role || '(no role)')) + '</div>';
      if (p.mission) html += '<div class="role" style="font-style:italic;">' + escapeHtml(String(p.mission)) + '</div>';
      html += '<div class="sop-list-mini">';
      if (sops.length === 0) {
        html += '<div class="compare-empty">No SOPs authored yet.</div>';
      } else {
        sops.forEach(function(s) {
          var titleNorm = String(s.title || '').toLowerCase().trim();
          var isMatch = otherTitleSet.has(titleNorm);
          html += renderSopMini(s, isMatch);
        });
      }
      html += '</div>';
      // Inherited section if present
      var parentExtId = p.escalatesTo;
      var parent = parentExtId ? nodes.find(function(n) { return n.externalId === String(parentExtId); }) : null;
      var inherited = parent && Array.isArray((parent.properties || {}).sops) ? parent.properties.sops : [];
      if (inherited.length) {
        html += '<div style="margin-top:0.6rem; padding-top:0.6rem; border-top:1px dashed #e5e7eb;">';
        html += '<div class="role" style="margin-bottom:0.3rem;">Inherits from ' + escapeHtml(parent.label) + ' (' + inherited.length + ')</div>';
        html += '<div class="sop-list-mini">';
        inherited.forEach(function(s) { html += renderSopMini(s, false); });
        html += '</div></div>';
      }
      html += '</div>';
      return html;
    }

    window.openCompare = function(idA, idB, reason) {
      var a = nodes.find(function(n) { return n.id === idA; });
      var b = nodes.find(function(n) { return n.id === idB; });
      if (!a || !b) return;
      document.getElementById('compare-title').textContent = a.label + ' vs ' + b.label + (reason ? ' — ' + reason : '');
      var aSops = Array.isArray((a.properties || {}).sops) ? (a.properties || {}).sops : [];
      var bSops = Array.isArray((b.properties || {}).sops) ? (b.properties || {}).sops : [];
      var aTitles = new Set(aSops.map(function(s) { return String(s.title || '').toLowerCase().trim(); }));
      var bTitles = new Set(bSops.map(function(s) { return String(s.title || '').toLowerCase().trim(); }));
      var cols = document.getElementById('compare-cols');
      cols.innerHTML = renderCompareCol(a, bTitles) + renderCompareCol(b, aTitles);
      document.getElementById('compare-overlay').classList.add('open');
      var modal = document.getElementById('compare-modal');
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
    };

    window.closeCompare = function() {
      document.getElementById('compare-overlay').classList.remove('open');
      var modal = document.getElementById('compare-modal');
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
    };

    window.openInvitesDrawer = function() {
      var d = document.getElementById('invites-drawer');
      if (d) { d.classList.add('open'); d.setAttribute('aria-hidden', 'false'); }
    };
    window.closeInvitesDrawer = function() {
      var d = document.getElementById('invites-drawer');
      if (d) { d.classList.remove('open'); d.setAttribute('aria-hidden', 'true'); }
    };

    window.openInviteNewModal = function() {
      var modal = document.getElementById('invite-new-modal');
      var overlay = document.getElementById('invite-new-overlay');
      if (!modal) return;
      // Reset
      ['inv-new-name','inv-new-email','inv-new-role'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; });
      var status = document.getElementById('inv-new-status');
      if (status) { status.textContent = ''; status.style.color = '#6b7280'; }
      // Populate reports-to dropdown with all current humans
      var sel = document.getElementById('inv-new-reportsto');
      if (sel) {
        sel.innerHTML = '<option value="">(no parent assigned)</option>';
        nodes.forEach(function(n) {
          if (n.type !== 'human') return;
          var opt = document.createElement('option');
          opt.value = n.externalId;
          opt.textContent = n.label + ' (human)';
          sel.appendChild(opt);
        });
      }
      modal.style.opacity = '1';
      modal.style.pointerEvents = 'auto';
      modal.style.transform = 'translate(-50%, -50%) scale(1)';
      modal.setAttribute('aria-hidden', 'false');
      if (overlay) overlay.classList.add('open');
      var nameInput = document.getElementById('inv-new-name'); if (nameInput) setTimeout(function(){ nameInput.focus(); }, 100);
    };
    window.closeInviteNewModal = function() {
      var modal = document.getElementById('invite-new-modal');
      var overlay = document.getElementById('invite-new-overlay');
      if (!modal) return;
      modal.style.opacity = '0';
      modal.style.pointerEvents = 'none';
      modal.style.transform = 'translate(-50%, -50%) scale(0.96)';
      modal.setAttribute('aria-hidden', 'true');
      if (overlay) overlay.classList.remove('open');
    };

    window.submitInviteNew = async function() {
      var nameEl = document.getElementById('inv-new-name');
      var emailEl = document.getElementById('inv-new-email');
      var roleEl = document.getElementById('inv-new-role');
      var reportsEl = document.getElementById('inv-new-reportsto');
      var btn = document.getElementById('inv-new-submit');
      var status = document.getElementById('inv-new-status');

      var name = (nameEl.value || '').trim();
      var email = (emailEl.value || '').trim();
      var role = (roleEl.value || '').trim();
      var reportsTo = (reportsEl.value || '').trim();

      if (!name) { status.style.color = '#b91c1c'; status.textContent = 'Name required.'; return; }
      if (!email) { status.style.color = '#b91c1c'; status.textContent = 'Email required.'; return; }

      btn.disabled = true; btn.textContent = 'Creating tile…';
      status.style.color = '#6b7280';
      status.textContent = '';

      try {
        // Step 1: create the human tile in the draft
        var createBody = { type: 'human', name: name, contactEmail: email };
        if (role) createBody.role = role;
        if (reportsTo) createBody.reportsTo = reportsTo;
        var createRes = await fetch('/api/v1/team/entity', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(createBody),
        });
        if (!createRes.ok) {
          var ce = await createRes.json().catch(function() { return {}; });
          status.style.color = '#b91c1c';
          status.textContent = 'Tile creation failed: ' + ((ce.error && ce.error.message) || createRes.status);
          btn.disabled = false; btn.textContent = 'Create tile & send invite';
          return;
        }
        var created = await createRes.json();

        // Step 2: issue the invitation tied to the new tile
        btn.textContent = 'Sending invite…';
        var inviteRes = await fetch('/api/v1/team/invite', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, claimedEntityId: created.externalId, role: 'member' }),
        });
        if (!inviteRes.ok) {
          var ie = await inviteRes.json().catch(function() { return {}; });
          status.style.color = '#b91c1c';
          status.textContent = 'Tile created but invite failed: ' + ((ie.error && ie.error.message) || inviteRes.status) + '. You can resend from the tile.';
          btn.disabled = false; btn.textContent = 'Create tile & send invite';
          // Don't reload yet -- let the owner read the message
          return;
        }
        var invited = await inviteRes.json();
        status.style.color = '#059669';
        status.textContent = 'Tile created and invite sent to ' + invited.email + '. Reloading…';
        setTimeout(function() { window.location.reload(); }, 1500);
      } catch (e) {
        status.style.color = '#b91c1c';
        status.textContent = 'Network error: ' + e.message;
        btn.disabled = false; btn.textContent = 'Create tile & send invite';
      }
    };

    window.sendInvite = async function() {
      if (!currentNode || currentNode.type !== 'human') return;
      var emailInput = document.getElementById('ef-invite-email');
      var btn = document.getElementById('ef-invite-btn');
      var status = document.getElementById('ef-invite-status');
      var email = (emailInput.value || '').trim();
      if (!email) { status.style.color = '#b91c1c'; status.textContent = 'Email required.'; return; }
      btn.disabled = true; btn.textContent = 'Sending…';
      status.style.color = '#6b7280';
      status.textContent = '';
      try {
        var res = await fetch('/api/v1/team/invite', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, claimedEntityId: currentNode.externalId, role: 'member' }),
        });
        if (!res.ok) {
          var err = await res.json().catch(function() { return {}; });
          status.style.color = '#b91c1c';
          status.textContent = (err.error && err.error.message) || ('Send failed (' + res.status + ')');
          btn.disabled = false; btn.textContent = 'Send invite';
          return;
        }
        var data = await res.json();
        status.style.color = '#059669';
        status.textContent = 'Invite sent to ' + data.email + '. Expires ' + new Date(data.expiresAt).toLocaleDateString() + '.';
        emailInput.value = '';
        btn.disabled = false; btn.textContent = 'Send invite';
        // Soft refresh after 2.5s so the pending-invites drawer reflects reality
        setTimeout(function() { window.location.reload(); }, 2500);
      } catch (e) {
        status.style.color = '#b91c1c';
        status.textContent = 'Network error: ' + e.message;
        btn.disabled = false; btn.textContent = 'Send invite';
      }
    };

    window.revokeInvite = async function(invitationId) {
      if (!confirm('Revoke this invitation? The link in the email stops working immediately.')) return;
      try {
        var res = await fetch('/api/v1/team/invitations/' + invitationId, { method: 'DELETE' });
        if (!res.ok) {
          var err = await res.json().catch(function() { return {}; });
          alert('Revoke failed: ' + ((err.error && err.error.message) || res.status));
          return;
        }
        // Remove the row visually
        var row = document.querySelector('.invite-row[data-invite-id="' + invitationId + '"]');
        if (row) row.remove();
        // If empty now, soft-reload to update the count badge in header
        var body = document.getElementById('invites-drawer-body');
        if (body && body.querySelectorAll('.invite-row').length === 0) {
          window.location.reload();
        }
      } catch (e) {
        alert('Network error: ' + e.message);
      }
    };

    window.deleteCurrentEntity = async function() {
      if (!currentNode) return;
      if (currentNode.type === 'organization') return;
      if (!confirm('Delete ' + currentNode.label + ' from your draft? This removes the entity from the OOS YAML and clears any references to it (escalates_to, reports_to, override_authority).')) return;
      var btn = document.getElementById('ef-delete');
      btn.disabled = true; btn.textContent = 'Deleting…';
      try {
        var qs = '?type=' + encodeURIComponent(currentNode.type) + '&externalId=' + encodeURIComponent(currentNode.externalId);
        var res = await fetch('/api/v1/team/entity' + qs, { method: 'DELETE' });
        if (!res.ok) {
          var err = await res.json().catch(function() { return {}; });
          alert('Delete failed: ' + ((err.error && err.error.message) || res.status));
          btn.disabled = false; btn.textContent = 'Delete';
          return;
        }
        window.location.reload();
      } catch (e) {
        alert('Network error: ' + e.message);
        btn.disabled = false; btn.textContent = 'Delete';
      }
    };
  })();
</script>
<% } %>
