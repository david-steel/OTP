            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Run L8 Meeting
          </a>
          <a href="/team/review" class="text-xs px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium inline-flex items-center gap-1.5" title="Rate each person against their seat and your organization's values.">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            People Review
          </a>
          <button onclick="openCreateDrawer('human')" class="text-xs px-3 py-1.5 bg-orgy-blue hover:bg-orgy-blue-deep text-white rounded-lg font-semibold inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Add to chart
          </button>
          <button onclick="openInviteNewModal()" class="text-xs px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12h2m-2 4h2m-6-8a4 4 0 11-8 0 4 4 0 018 0zM6 14a4 4 0 00-4 4v2h12v-2a4 4 0 00-4-4H6z"/></svg>
            Invite member
          </button>
          <button onclick="openImportDrawer()" class="text-xs px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
            Import CSV
          </button>
          <button onclick="openInvitesDrawer()" class="text-xs px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium">
            Pending invites
            <% if (typeof pendingInvites !== 'undefined' && pendingInvites && pendingInvites.length > 0) { %>
              <span class="ml-1 px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-700 text-[10px] font-bold"><%= pendingInvites.length %></span>
            <% } %>
          </button>
        <% } %>
        <% if (typeof memberCount !== 'undefined' && memberCount > 1) { %>
          <span class="text-xs px-2 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200 font-medium"><%= memberCount %> members</span>
        <% } %>
        <div class="inline-flex rounded-lg border border-gray-200 bg-white p-0.5 text-xs font-medium" role="group">
          <button data-filter="all" class="filter-btn px-3 py-1.5 rounded-md bg-gray-900 text-white">All <span class="opacity-70 ml-1"><%= counts.agents + counts.humans %></span></button>
          <button data-filter="agent" class="filter-btn px-3 py-1.5 rounded-md text-gray-600 hover:text-gray-900">Agents <span class="opacity-70 ml-1"><%= counts.agents %></span></button>
          <button data-filter="human" class="filter-btn px-3 py-1.5 rounded-md text-gray-600 hover:text-gray-900">Humans <span class="opacity-70 ml-1"><%= counts.humans %></span></button>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-gray-50 py-6 sm:py-8 min-h-[60vh]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
