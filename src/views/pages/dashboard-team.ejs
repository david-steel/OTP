        <p class="text-sm text-gray-500 max-w-md mx-auto mb-5">Publish an OOS with an `agents` or `humans` section and they'll appear here automatically.</p>
        <a href="/dashboard" class="inline-flex items-center gap-2 px-4 py-2 bg-orgy-blue hover:bg-orgy-blue-deep text-white rounded-lg font-semibold text-sm transition-colors">
          Back to Dashboard
        </a>
      </div>
    <% } else { %>
      <div id="org-shell" class="org-chart-shell border border-gray-200" style="height: 75vh; min-height: 540px;">
        <div id="org-stage" class="org-chart-stage"></div>
      </div>
      <div class="mt-3 text-[11px] text-gray-500 flex items-center gap-4 flex-wrap">
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-sky-500"></span>Agent</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-amber-500"></span>Human</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-slate-900"></span>Organization</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-6 h-0.5 bg-amber-500" style="background-image:linear-gradient(to right, #f59e0b 50%, transparent 50%); background-size: 6px 2px;"></span>escalation</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-6 h-0.5 bg-gray-300"></span>part of</span>
      </div>
    <% } %>
  </div>
</section>

<div id="org-tooltip" class="org-tooltip"></div>

<% if (typeof viewerRole !== 'undefined' && viewerRole === 'owner') { %>
<!-- CSV Import side drawer -->
<div id="imp-overlay" class="ab-modal-overlay" onclick="closeImportDrawer()"></div>
<aside id="imp-drawer" class="ab-modal" role="dialog" aria-hidden="true">
  <div class="ab-modal-header">
    <div>
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-1">Import</div>
      <div class="text-base font-bold text-gray-900">Import humans from CSV</div>
    </div>
    <button onclick="closeImportDrawer()" class="text-gray-400 hover:text-gray-700 p-1 rounded-md hover:bg-gray-100" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div style="flex:1; overflow-y:auto; padding: 1.25rem 1.5rem;">

    <!-- Step 1: templates -->
    <div style="margin-bottom: 1.25rem;">
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">1. Download a template</div>
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
        <a href="/api/v1/team/import/template/simple" download class="text-xs px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Simple
        </a>
        <a href="/api/v1/team/import/template/full" download class="text-xs px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Full
        </a>
      </div>
      <div style="font-size:11px; color:#6b7280; margin-top:0.4rem; line-height:1.5;">
        <strong>Simple:</strong> name, role, reports_to.<br/>
        <strong>Full:</strong> contact email/phone, Slack ID, job description, authority level, skills, MCPs, status.<br/>
        <code>reports_to</code> matches by name (or by external ID like <code>HUM_JANEDOE</code>).
      </div>
    </div>

    <!-- Step 2: upload -->
    <div style="margin-bottom: 1.25rem;">
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">2. Choose a CSV file</div>
      <input id="imp-file" type="file" accept=".csv,text/csv" onchange="onImportFileChange()" style="font-size:13px;" />
      <div id="imp-file-status" style="font-size:11px; color:#6b7280; margin-top:0.4rem;"></div>
    </div>

    <!-- Step 3: preview -->
    <div id="imp-preview-wrap" style="margin-bottom: 1.25rem; display:none;">
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">3. Preview</div>
      <div id="imp-preview-summary" style="font-size:12px; color:#374151; margin-bottom:0.5rem;"></div>
      <div style="max-height: 280px; overflow:auto; border:1px solid #e5e7eb; border-radius:8px;">
        <table style="width:100%; font-size:11px; border-collapse:collapse;">
          <thead style="background:#f9fafb; position:sticky; top:0;">
            <tr>
              <th style="padding:6px 8px; text-align:left; border-bottom:1px solid #e5e7eb; font-weight:600; color:#374151;">#</th>
              <th style="padding:6px 8px; text-align:left; border-bottom:1px solid #e5e7eb; font-weight:600; color:#374151;">Name</th>
              <th style="padding:6px 8px; text-align:left; border-bottom:1px solid #e5e7eb; font-weight:600; color:#374151;">Role</th>
              <th style="padding:6px 8px; text-align:left; border-bottom:1px solid #e5e7eb; font-weight:600; color:#374151;">Reports to</th>
              <th style="padding:6px 8px; text-align:left; border-bottom:1px solid #e5e7eb; font-weight:600; color:#374151;">Status</th>
            </tr>
          </thead>
          <tbody id="imp-preview-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Step 4: mode -->
    <div id="imp-mode-wrap" style="margin-bottom: 1.25rem; display:none;">
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">4. Import mode</div>
      <label style="display:flex; gap:0.5rem; align-items:flex-start; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:8px; cursor:pointer; margin-bottom:0.4rem;">
        <input type="radio" name="imp-mode" value="addition" checked style="margin-top:3px;" />
        <div>
          <div style="font-size:13px; font-weight:600; color:#0f172a;">Addition (safe)</div>
          <div style="font-size:11px; color:#6b7280;">Add new humans; refresh fields on humans whose names already exist. Nothing is deleted.</div>
        </div>
      </label>
      <label style="display:flex; gap:0.5rem; align-items:flex-start; padding:0.5rem 0.75rem; border:1px solid #fecaca; background:#fff5f5; border-radius:8px; cursor:pointer;">
        <input type="radio" name="imp-mode" value="overwrite" style="margin-top:3px;" />
        <div>
          <div style="font-size:13px; font-weight:600; color:#991b1b;">New / Overwrite (destructive)</div>
          <div style="font-size:11px; color:#7f1d1d;">Refresh matched humans, create new ones, <strong>and delete any human not in the CSV</strong>. Affected agents lose their escalates_to link.</div>
        </div>
      </label>
    </div>

    <div id="imp-banner" style="display:none; padding:0.5rem 0.75rem; border-radius:8px; font-size:12px; margin-bottom: 0.75rem;"></div>
    <div id="imp-result" style="display:none; padding:0.75rem; border-radius:8px; background:#ecfdf5; border:1px solid #a7f3d0; font-size:12px; color:#065f46; margin-bottom: 0.75rem; line-height:1.5;"></div>
  </div>
  <div class="edit-panel-footer" style="justify-content: flex-end;">
    <button onclick="closeImportDrawer()" class="px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-100">Cancel</button>
    <button id="imp-submit" onclick="submitImport()" disabled class="px-4 py-1.5 text-sm bg-orgy-blue hover:bg-orgy-blue-deep text-white font-semibold rounded-lg disabled:opacity-50">Import</button>
  </div>
</aside>
<% } %>

<!-- Agent Builder side drawer (slides over the edit panel from the right) -->
<div id="ab-modal-overlay" class="ab-modal-overlay" onclick="closeAgentBuilderModal()"></div>
<aside id="ab-modal" class="ab-modal" role="dialog" aria-hidden="true">
  <div class="ab-modal-header">
    <div>
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-1">Agent Builder</div>
      <div class="text-base font-bold text-gray-900">Generate, then auto-fill the form</div>
    </div>
    <button onclick="closeAgentBuilderModal()" class="text-gray-400 hover:text-gray-700 p-1 rounded-md hover:bg-gray-100" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <iframe id="ab-modal-iframe" class="ab-modal-iframe" title="Agent Builder" src="about:blank"></iframe>
</aside>

<!-- Compare-agents modal (Phase 4.8) -->
<div id="compare-overlay" class="compare-modal-overlay" onclick="closeCompare()"></div>
<div id="compare-modal" class="compare-modal" role="dialog" aria-hidden="true">
  <div class="compare-modal-header">
    <div>
      <div class="text-xs uppercase tracking-wider text-purple-600 font-bold mb-0.5">Same-role comparison</div>
      <div class="text-base font-bold text-gray-900" id="compare-title">&mdash;</div>
    </div>
    <button onclick="closeCompare()" class="text-gray-400 hover:text-gray-700 p-1 rounded-md hover:bg-gray-100" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="compare-modal-body">
    <div id="compare-cols" class="compare-cols"></div>
  </div>
</div>

<% if (typeof viewerRole !== 'undefined' && viewerRole === 'owner') { %>

<!-- Invite-new-member modal -->
<div id="invite-new-overlay" class="edit-overlay" onclick="closeInviteNewModal()"></div>
<div id="invite-new-modal" role="dialog" aria-hidden="true" style="position:fixed; top:50%; left:50%; transform:translate(-50%, -50%) scale(0.96); opacity:0; pointer-events:none; transition: transform 200ms ease, opacity 200ms ease; z-index: 70; background:#fff; border:1px solid #e5e7eb; border-radius:14px; box-shadow: 0 30px 80px rgba(15,23,42,0.20); width: 92%; max-width: 460px;">
  <div style="padding:1.25rem 1.5rem 0.75rem 1.5rem; border-bottom: 1px solid #f3f4f6;">
    <div style="font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280; font-weight:700; margin-bottom: 0.2rem;">Invite new member</div>
    <h3 style="font-size:18px; font-weight:800; color:#0f172a; margin:0;">Create a tile and send the invite</h3>
    <p style="font-size:12px; color:#6b7280; margin:0.5rem 0 0 0;">A new human tile will be added to the chart with this name and role. The recipient will claim it on signup.</p>
  </div>
  <div style="padding:1rem 1.5rem;">
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-name">Name <span style="color:#ef4444;">*</span></label><input id="inv-new-name" type="text" placeholder="Jane Doe" /></div>
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-email">Email <span style="color:#ef4444;">*</span></label><input id="inv-new-email" type="email" placeholder="jane@company.com" /></div>
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-role">Role</label><input id="inv-new-role" type="text" placeholder="e.g. Marketing Lead, Sales Engineer" /></div>
    <div class="edit-field" style="margin-bottom: 0.75rem;"><label for="inv-new-reportsto">Reports to (optional)</label><select id="inv-new-reportsto"><option value="">(no parent assigned)</option></select></div>
    <div id="inv-new-status" style="font-size:12px; margin-top: 0.75rem; min-height: 1em;"></div>
  </div>
  <div style="padding:0.75rem 1.5rem 1.25rem 1.5rem; border-top: 1px solid #f3f4f6; display:flex; gap:0.5rem; justify-content:flex-end;">
    <button onclick="closeInviteNewModal()" class="px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-100">Cancel</button>
    <button id="inv-new-submit" onclick="submitInviteNew()" class="px-4 py-1.5 text-sm bg-orgy-blue hover:bg-orgy-blue-deep text-white font-semibold rounded-lg disabled:opacity-50">Create tile &amp; send invite</button>
  </div>
</div>

<aside id="invites-drawer" class="invites-drawer" aria-hidden="true">
  <div class="invites-drawer-header">
    <div>
      <div class="text-xs uppercase tracking-wider text-gray-400 font-semibold mb-1">Pending invitations</div>
      <div class="text-base font-bold text-gray-900">Invitations sent, not yet accepted</div>
    </div>
    <button onclick="closeInvitesDrawer()" class="text-gray-400 hover:text-gray-700 p-1 rounded-md hover:bg-gray-100" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="invites-drawer-body" id="invites-drawer-body">
    <% if (!pendingInvites || pendingInvites.length === 0) { %>
      <div style="text-align:center; padding: 2rem 0; color: #9ca3af; font-size: 13px;">No pending invitations.<br/>Open a human tile and click "Invite to claim" to send one.</div>
    <% } else { %>
      <% pendingInvites.forEach(function(inv) { %>
        <div class="invite-row" data-invite-id="<%= inv.id %>">
          <div>
            <div class="font-semibold text-sm text-gray-900"><%= inv.email %></div>
            <div class="meta">
              <% if (inv.claimedEntityId) { %>Tile: <code class="text-[10px] bg-gray-100 px-1 rounded"><%= inv.claimedEntityId %></code> &middot; <% } %>
              Expires <%= new Date(inv.expiresAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
            </div>
          </div>
          <div class="actions">
            <button class="resend" onclick="resendInvite('<%= inv.id %>', this)">Resend</button>
            <button onclick="revokeInvite('<%= inv.id %>')">Revoke</button>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</aside>
<% } %>

<!-- Edit panel (unchanged) -->
