    // ========================================================
    // CREATE MODE -- "+ Add to chart" / "+ Add direct report"
    // Opens the same edit panel in create mode: empty fields,
    // Human/Agent toggle visible, delete hidden, save → POST + PATCH.
    // ========================================================
    var isCreateMode = false;
    var currentCreateType = null;     // 'human' | 'agent'
    var currentCreateParentId = null; // optional externalId to preselect as parent

    window.openCreateDrawer = function(suggestedType, parentExternalId) {
      isCreateMode = true;
      currentNode = null;
      currentCreateType = (suggestedType === 'agent' ? 'agent' : 'human');
      currentCreateParentId = parentExternalId || null;

      // Reset SOPs / skills / MCPs state
      currentSops = [];
      editingSopIdx = -1;
      currentSkills = [];
      currentMcps = [];
      renderSopList();
      renderSkillTags();
      hideSkillSuggestions();
      renderMcpTags();

      // Show create controls; hide invite section + delete button
      document.getElementById('ef-create-controls').style.display = '';
      var inviteSection = document.getElementById('ef-invite-section');
      if (inviteSection) inviteSection.style.display = 'none';
      var delBtn = document.getElementById('ef-delete');
      if (delBtn) delBtn.style.display = 'none';
      var saveBtn = document.getElementById('ef-save');
      if (saveBtn) saveBtn.textContent = 'Create tile';

      // Header
      document.getElementById('edit-type-label').textContent = 'Add to chart';
      document.getElementById('edit-name-display').textContent = 'New ' + currentCreateType;

      // Clear fields
      document.getElementById('ef-name').value = '';
      document.getElementById('ef-role').value = '';
      document.getElementById('ef-mission').value = '';
      document.getElementById('ef-jobdesc').value = '';
      document.getElementById('ef-authority').value = '';
      document.getElementById('ef-authority-custom').value = '';
      document.getElementById('ef-authority-custom').style.display = 'none';
      document.getElementById('ef-maturity').value = '';
      document.getElementById('ef-platform').value = '';
      document.getElementById('ef-status').value = '';
      document.getElementById('ef-contact-email').value = '';
      document.getElementById('ef-contact-phone').value = '';
      document.getElementById('ef-slackid').value = '';

      // Hide context/runtime sections that are agent-only and depend on existing entity
      var ctxSection = document.getElementById('ef-context-section');
      if (ctxSection) ctxSection.style.display = 'none';
      var runtimeSection = document.getElementById('ef-runtime-section');
      if (runtimeSection) runtimeSection.style.display = 'none';

      // Fill reportsTo / escalatesTo selects from nodes; preselect parent if provided
      var fillSelectEmpty = function(selectEl, preselectExternalId) {
        selectEl.innerHTML = '<option value="">(none)</option>';
        nodes.forEach(function(n) {
          if (n.type === 'organization') return;
          var opt = document.createElement('option');
          opt.value = n.externalId;
          opt.textContent = n.label + ' (' + n.type + ')';
          if (preselectExternalId && String(preselectExternalId) === n.externalId) opt.selected = true;
          selectEl.appendChild(opt);
