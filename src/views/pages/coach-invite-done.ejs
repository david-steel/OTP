<%-
  /* /join/:token/done — post-accept confirmation.
     Variables: coach, dashboardUrl */
%>
<section class="bg-gradient-to-b from-emerald-50 via-white to-amber-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20 text-center">

    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-100 mb-6">
      <span class="text-emerald-600 text-3xl">✓</span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3">You're in.</h1>
    <% if (coach) { %>
      <p class="text-base sm:text-lg text-gray-700 mb-2">
        Your workspace is set up and you're linked to <strong><%= coach.displayName %></strong>.
      </p>
    <% } else { %>
      <p class="text-base sm:text-lg text-gray-700 mb-2">
        Your workspace is set up.
      </p>
    <% } %>
    <p class="text-sm text-gray-600 mb-10">
      Five-minute setup: map yourself, one teammate, and one AI tool. That's the smallest chart that makes the protocol actually useful.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto mb-10">
      <a href="/welcome" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold">
        Start the 5-minute setup →
      </a>
      <a href="<%= dashboardUrl %>" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-white border-2 border-gray-300 text-gray-900 font-semibold hover:border-gray-400">
        Skip to dashboard
      </a>
    </div>

    <% if (coach) { %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-left max-w-md mx-auto">
        <div class="text-xs font-bold uppercase tracking-wider text-amber-700 mb-2">What happens now</div>
        <ul class="text-sm text-gray-700 space-y-1.5">
          <li>★ <%= (coach.displayName||'Your coach').split(' ')[0] %> has been notified you joined.</li>
          <li>★ They'll see your workspace in their coach view (rolling out this week).</li>
          <li>★ Your data is private to you — they have visibility because they're your coach. You can revoke access from settings anytime.</li>
        </ul>
      </div>
    <% } %>

  </div>
</section>
