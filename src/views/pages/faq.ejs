<%# /faq -- v7 layout (light, editorial). Frequently asked questions, grouped accordions.
    Rendered via reply.view('pages/faq', data, { layout: 'layouts/v7' }). %>
<style>
  .faq-q {
    border:1px solid var(--line); border-radius:13px; background:var(--card);
    transition:border-color .18s ease, box-shadow .18s ease;
  }
  .faq-q[open] {
    border-color:rgba(13,125,242,.35);
    box-shadow:0 1px 3px rgba(20,22,28,.05), 0 14px 30px -22px rgba(20,22,28,.22);
  }
  .faq-q summary {
    list-style:none; cursor:pointer;
    display:flex; align-items:center; justify-content:space-between; gap:1rem;
    padding:18px 20px;
    font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700;
    font-size:15.5px; color:var(--ink); line-height:1.35;
  }
  .faq-q summary::-webkit-details-marker { display:none; }
  .faq-q summary:hover { color:var(--blue-deep); }
  .faq-chev {
    flex:none; width:20px; height:20px; color:var(--ink-mute);
    transition:transform .2s ease;
  }
  .faq-q[open] .faq-chev { transform:rotate(180deg); color:var(--blue-deep); }
  .faq-a {
    padding:0 20px 18px; font-size:14.5px; color:var(--ink-soft); line-height:1.72;
  }
  .faq-a a { color:var(--blue-deep); font-weight:600; border-bottom:1.5px solid currentColor; }
  .faq-a strong { color:var(--ink); font-weight:600; }
  .faq-bob { animation:faq-bob 5.5s ease-in-out infinite; transform-origin:center bottom; }
  @keyframes faq-bob { 0%,100%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-9px) rotate(4deg);} }
  @media (prefers-reduced-motion:reduce){ .faq-bob{ animation:none; } }
</style>

<!-- ================= HEADER ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[760px] mx-auto px-6 pt-[124px] pb-12 sm:pt-[148px] sm:pb-14">
    <div class="flex items-start gap-5">
      <div class="flex-1">
        <div class="eyebrow mb-4 flex items-center gap-2.5">
          <span class="tick" style="background:var(--blue);"></span>Help
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.1rem,4.4vw,3.3rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
          Frequently asked questions
        </h1>
        <p class="text-[16px] sm:text-[17px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mt-5">
          Everything you need to know about OTP, Organizational Operating Systems, and coordination intelligence.
        </p>
      </div>
      <img src="/public/orgy-clean.png" alt="" aria-hidden="true"
           class="faq-bob hidden sm:block shrink-0" style="width:78px; height:auto; margin-top:6px;">
    </div>
  </div>
</section>

<!-- ================= FAQ BODY ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-16 sm:py-20">
    <%
      const faqGroups = [
        {
          group: 'About OTP',
          items: [
            { q:'What is OTP?', open:true,
              a:'OTP (Organization Transport Protocol) is a platform where organizations map their humans and AI agents in one accountability graph, author SOPs the agents inherit, and publish a structured <a href="/glossary#organizational-operating-system">Organizational Operating System</a> their network can compare against. OTP sits at the organizational layer of the AI work-stack, above MCP (agent-to-tool) and A2A (agent-to-agent), and unlike those two it covers humans as first-class entities. Learn more in our <a href="/blog/why-we-built-otp">founding essay</a>.' },
            { q:'What is coordination intelligence?',
              a:'<a href="/glossary#coordination-intelligence">Coordination intelligence</a> is the collective, structured knowledge of how humans and AI agents within and across organizations should coordinate. It is captured in operational rules, documented failure modes, evidence-backed patterns, and the SOPs each role owns. It is to hybrid human-and-AI organizations what institutional knowledge is to traditional ones, except it is machine-readable, comparable, and inheritable. Read the <a href="/blog/what-is-coordination-intelligence">full explanation</a>.' },
            { q:'How is OTP different from CrewAI, AutoGen, or LangGraph?',
              a:'CrewAI, AutoGen, and LangGraph are <strong>agent orchestration frameworks</strong>. They handle the plumbing of how agents execute tasks and pass messages. OTP operates at a different layer entirely. OTP captures the <strong>organizational intelligence</strong> that tells agents what to do, who owns what, and what happens when rules are broken. Think of it this way: CrewAI is how agents run. OTP is how agents know what the rules are. See the <a href="/glossary#three-layer-stack">three-layer stack</a>.' },
            { q:'How is OTP different from MCP or A2A?',
              a:'MCP (Model Context Protocol) connects agents to tools. A2A (Agent-to-Agent) connects agents to each other. OTP connects whole organizations, humans, AI agents, and the SOPs they share, to a network where accountability is queryable across orgs. MCP and A2A move bytes between agents; OTP moves accountability across organizations. Complementary, not competitive.' },
            { q:'What is the Token Efficiency Ratio?',
              a:'The <a href="/glossary#token-efficiency-ratio">Token Efficiency Ratio</a> measures whether an operational rule is worth the tokens it consumes. Every claim loaded into an agent\'s context costs tokens. But a good rule prevents wasted cycles downstream. The ratio is: tokens saved by having the rule divided by tokens the rule costs to load. A ratio above 1.0 means the rule pays for itself. Below 1.0 means it should be cut or compressed.' },
          ]
        },
        {
          group: 'Publishing',
          items: [
            { q:'How do I publish my OOS?',
              a:'Sign up, choose a template (Agent Army, Value Chain, or Org Chart), generate your OOS using the prompt on our <a href="/guide">guide page</a>, and paste it into the publish form. The platform validates the format, extracts claims, scores quality, and publishes it to the Intelligence Graph.' },
            { q:'What templates are available?',
              a:'Three templates: <strong>Agent Army</strong> for organizations with multiple specialized AI agents, <strong>Value Chain</strong> for process-oriented organizations, and <strong>Org Chart</strong> for traditional hierarchies integrating AI. See the <a href="/glossary#oos-templates">glossary</a> for details.' },
            { q:'What are confidence ratings and evidence types?',
              a:'<a href="/glossary#confidence-levels">Confidence levels</a> (HIGH/MEDIUM/LOW) express how certain you are about a claim. <a href="/glossary#evidence-types">Evidence types</a> describe how the claim was validated: measured results, repeated observation, human-defined rules, inference, or speculation. Together they make knowledge quality explicit and comparable.' },
            { q:'What does the Founding Publisher badge mean?',
              a:'The Founding Publisher badge is given to the first 50 organizations that publish on OTP. It is permanent and cannot be earned later. Founding Publishers get early access to Phase 2 features and help shape the protocol itself.' },
          ]
        },
        {
          group: 'Using OTP',
          items: [
            { q:'How do I compare two organizations?',
              a:'From the <a href="/browse">browse page</a>, select any two published OOS files to compare. The diff engine shows what is unique to each organization, what is similar, and where they conflict. This helps you learn from how others coordinate their AI teams.' },
            { q:'What is the Intelligence Graph?',
              a:'The <a href="/graph">Intelligence Graph</a> is a network visualization showing how coordination patterns connect across organizations. When two organizations share similar claims, those claims are linked. The graph reveals shared operational truths and unique approaches that no single organization could discover alone.' },
            { q:'What are agentic maturity levels?',
              a:'An <a href="/glossary#agentic-maturity-levels">8-level framework</a> (L1 through L8) measuring how sophisticated an organization\'s AI agent coordination is, from basic tab completion to fully autonomous agent teams. Based on the framework by Bassim Eledath. OTP displays each publisher\'s agentic level alongside their OOS. Read more in our <a href="/blog/agentic-levels">blog post</a>.' },
          ]
        },
        {
          group: 'For Organizations',
          items: [
            { q:'What size organization can use OTP?',
              a:'Any organization running AI agents. Solo operators with a single agent, small teams with 3-5 agents, and enterprises with dozens. The OOS format scales. If you have AI agents that need to coordinate, OTP captures how they should work together.' },
            { q:'Is my data private?',
              a:'Published OOS files are visible to the community. You control what you publish. Use pseudonyms for your organization name if you prefer. Do not include proprietary information, trade secrets, or PII in your OOS. The platform includes a PII scanner that flags potential issues before publishing.' },
            { q:'Does OTP have an API?',
              a:'Yes. OTP provides a REST API and an MCP server for programmatic access to published OOS data, claims, search, and the Intelligence Graph. Publishers can generate API keys from their <a href="/settings/api">dashboard</a>.' },
          ]
        },
      ];
    %>

    <% faqGroups.forEach(function(grp){ %>
    <div class="mb-12 last:mb-0">
      <h2 class="eyebrow mb-5" style="font-size:12px;"><%= grp.group %></h2>
      <div class="space-y-3">
        <% grp.items.forEach(function(item){ %>
        <details class="faq-q"<%= item.open ? ' open' : '' %>>
          <summary>
            <span><%= item.q %></span>
            <svg class="faq-chev" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="faq-a"><%- item.a %></div>
        </details>
        <% }); %>
      </div>
    </div>
    <% }); %>
  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[680px] mx-auto px-6 py-20 sm:py-24 text-center">
    <p class="text-[15px] text-[var(--ink-soft)] leading-[1.7]">
      Have a question not answered here? <a href="/tickets" class="text-[var(--blue-deep)] link-u">Submit it</a> and we will add it.
    </p>
    <div class="mt-8">
      <a href="/publish" class="btn-primary inline-flex items-center gap-2 px-8 py-4 text-[16px]">
        Publish your OOS &rarr;
      </a>
    </div>
  </div>
</section>
