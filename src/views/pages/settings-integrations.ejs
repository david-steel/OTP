<%- include('../partials/orgy-palette'); %>
<%
  // ---- Settings: Integrations (User Settings) ----
  // Auto-injected: memberRole, currentPath, assetVersion, authState.
  // Everything below is typeof-guarded so the page never throws on a missing local.
  var _auth = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';

  // Planned integrations -- shown as muted, non-clickable "Coming soon" items.
  // These do NOT work yet. Do not imply otherwise.
  var _comingSoon = [
    { name: 'Slack',            note: 'Push agent updates and standups into channels.' },
    { name: 'Google Workspace', note: 'Calendar, Drive, and Gmail context for agents.' },
    { name: 'Microsoft 365',    note: 'Outlook, Teams, and OneDrive context for agents.' }
  ];
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%- include('../partials/ui-page-header', { helpKey: 'settings.integrations', title: 'Integrations', eyebrow: 'User Settings', subtitle: 'Connect OTP to the tools your agents use.', mascot: 'mcp-api' }) %>


    <% if (_auth === 'unauthenticated') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Sign in to manage your integrations.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Sign In</a>
      </div>
    <% } else if (_auth === 'no_org') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Complete your organization profile first.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Set Up Profile</a>
      </div>
    <% } else { %>

      <!-- two-column: nav stacks above content on mobile, sidebar on >=md -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">

        <!-- left: settings nav -->
        <%- include('../partials/settings-nav') %>

        <!-- right: content -->
        <div class="flex-1 min-w-0 w-full space-y-6">

          <h2 class="font-bold text-gray-900 text-lg">Connected Tools</h2>

          <!-- Card 1: MCP / API (the real integration surface) -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">MCP &amp; API</h3>
            <p class="text-sm text-gray-500 mb-4">
              OTP's primary integration surface today is the MCP / API connection. Your agents
              authenticate with an API key and read and write coordination intelligence through
              the OTP MCP server. Manage your keys and connection details below.
            </p>
            <a href="/settings/api"
               class="inline-block px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
              Manage API &amp; MCP keys
            </a>
          </div>

          <!-- Card 2: Coming soon -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">Coming soon</h3>
            <p class="text-sm text-gray-500 mb-4">Planned native integrations. These are not available yet.</p>
            <ul class="space-y-2.5">
              <% _comingSoon.forEach(function(i) { %>
                <li class="flex items-center justify-between gap-3 opacity-60 cursor-not-allowed select-none">
                  <span>
                    <span class="text-sm text-gray-800 font-medium"><%= i.name %></span>
                    <span class="block text-sm text-gray-400"><%= i.note %></span>
                  </span>
                  <span class="text-xs font-semibold uppercase tracking-wide text-gray-400 border rounded-full px-2.5 py-1 whitespace-nowrap">Coming soon</span>
                </li>
              <% }); %>
            </ul>
          </div>

        </div>
      </div>

    <% } %>
</div>
