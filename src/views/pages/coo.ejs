<%# /coo -- role-specific sales page for COOs / heads of operations. Sells OTP on
    its own. Sibling of /cio + /cfo, reframed for the execution owner: the work
    between meetings is where execution dies; the COO is the bottleneck; agents
    run unmanaged. The operating cadence (chart -> scorecard -> meeting -> to-dos
    -> done) for people AND agents. v7 layout, v7.css PREBUILT -> scoped .coo-*
    CSS + inline styles only (no new Tailwind utils). %>
<% var _v = (typeof assetVersion !== 'undefined' ? assetVersion : 'dev'); %>
<style>
  .coo-sec   { padding-top: 84px; padding-bottom: 84px; }
  .coo-wrap  { max-width: 1100px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .coo-center{ text-align: center; }
  .coo-paper { background: var(--white, #fcfcfd); }
  .coo-grey  { background: var(--grey, #f0f1f3); }
  @media (max-width: 640px){ .coo-sec { padding-top: 54px; padding-bottom: 54px; } }

  .coo-eyebrow { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-mute,#888c96); display:flex; align-items:center; gap:10px; }
  .coo-tick { width:8px; height:8px; border-radius:50%; background:var(--orgy,#a8e63a); display:inline-block; }
  .coo-h1 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.025em; line-height:1.05; font-size:clamp(2.2rem,4.6vw,3.5rem); color:var(--ink,#14161c); margin:0; max-width:18ch; }
  .coo-h2 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.02em; line-height:1.12; font-size:clamp(1.7rem,3.2vw,2.5rem); color:var(--ink,#14161c); }
  .coo-lead { font-size:18px; line-height:1.62; color:var(--ink-soft,#494d57); }
  .coo-body { font-size:16px; line-height:1.65; color:var(--ink-soft,#494d57); }
  .coo-max720 { max-width:720px; }
  .accent { color:var(--blue,#0d7df2); } .accent-g { color:var(--green-deep,#06724a); }

  .coo-btn  { display:inline-flex; align-items:center; gap:8px; padding:14px 28px; font-size:16px; font-weight:700; border-radius:12px; text-decoration:none; white-space:nowrap; }
  .coo-btn.primary { background:var(--blue,#0d7df2); color:#fff; box-shadow:0 10px 26px -10px rgba(13,125,242,.6); transition:transform .15s ease, box-shadow .15s ease; }
  .coo-btn.primary:hover { transform:translateY(-1px); box-shadow:0 14px 30px -10px rgba(13,125,242,.7); }
  .coo-btn.ghost { background:transparent; color:var(--ink,#14161c); border:1px solid var(--line,#e6e8ec); }
  .coo-btn.ghost:hover { border-color:#c8ccd4; }
  .coo-cta-row { display:flex; gap:12px; flex-wrap:wrap; margin-top:30px; }

  .coo-grid3 { display:grid; gap:18px; grid-template-columns:1fr; margin-top:36px; }
  @media (min-width:780px){ .coo-grid3 { grid-template-columns:repeat(3,1fr); } }
  .coo-grid2 { display:grid; gap:18px; grid-template-columns:1fr; margin-top:36px; }
  @media (min-width:780px){ .coo-grid2 { grid-template-columns:repeat(2,1fr); } }
  .coo-card { background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); border-radius:16px; padding:24px 22px; box-shadow:0 10px 28px rgba(20,22,28,.05); }
  .coo-card h3 { font-family:'Schibsted Grotesk',sans-serif; font-weight:700; font-size:18px; color:var(--ink,#14161c); margin:0 0 8px; }
  .coo-card p { font-size:14.5px; line-height:1.6; color:var(--ink-soft,#494d57); margin:0; }
  .coo-chip { display:inline-flex; width:38px; height:38px; border-radius:11px; align-items:center; justify-content:center; margin-bottom:14px; }

  .coo-feat { display:grid; gap:2px 28px; grid-template-columns:1fr; margin-top:34px; }
  @media (min-width:720px){ .coo-feat { grid-template-columns:1fr 1fr; } }
  .coo-feat-row { display:flex; gap:13px; align-items:flex-start; padding:15px 0; border-bottom:1px solid var(--line,#e6e8ec); }
  .coo-feat-row svg { flex:none; margin-top:2px; }
  .coo-feat-row b { font-family:'Schibsted Grotesk',sans-serif; font-weight:700; font-size:15px; color:var(--ink,#14161c); display:block; }
  .coo-feat-row span { font-size:13.5px; line-height:1.55; color:var(--ink-soft,#494d57); }

  .coo-quoteband { background:linear-gradient(180deg,#f2f7ff 0%, #eef3fb 100%); border-top:1px solid var(--line,#e6e8ec); border-bottom:1px solid var(--line,#e6e8ec); }
  .coo-qmark { display:block; font-family:'Schibsted Grotesk',serif; font-weight:900; font-size:64px; line-height:.3; color:var(--orgy-deep,#8BC42A); }
  .coo-quote { font-family:'Schibsted Grotesk',sans-serif; font-weight:600; font-size:clamp(1.35rem,2.6vw,1.9rem); line-height:1.4; letter-spacing:-0.01em; color:var(--ink,#14161c); }
  .coo-quote .accent { color:var(--blue,#0d7df2); }

  .coo-trust-strip { display:flex; align-items:center; flex-wrap:wrap; gap:8px 14px; margin-top:30px; font-size:12px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-mute,#888c96); }
  .coo-trust-strip b { color:var(--ink-soft,#494d57); }

  @media (prefers-reduced-motion: no-preference){
    body.coo-anim .reveal { opacity:0; transform:translateY(18px); transition:opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); }
    body.coo-anim .reveal.in { opacity:1; transform:none; }
  }

  /* ===== animated hero scene: seats roll up into this week's execution ===== */
  .coo-hero { background:var(--white,#fcfcfd); overflow:hidden; }
  .coo-hero-wrap { max-width:1240px; margin:0 auto; padding:120px 24px 60px; }
  .coo-hero-grid { display:flex; gap:40px; align-items:center; flex-wrap:wrap; }
  .coo-hero-copy { flex:1 1 430px; min-width:330px; padding-top:8px; }
  .coo-stage { flex:0 0 560px; position:relative; width:560px; height:500px; }
  .rise { opacity:0; animation:o-rise .7s cubic-bezier(.16,1,.3,1) forwards; }
  @keyframes o-rise { from{opacity:0; transform:translateY(16px);} to{opacity:1; transform:translateY(0);} }
  .pop { opacity:0; animation:o-pop .55s cubic-bezier(.34,1.4,.5,1) forwards; }
  @keyframes o-pop { from{opacity:0; transform:scale(.9);} to{opacity:1; transform:scale(1);} }

  .o-conn { position:absolute; inset:0; z-index:1; pointer-events:none; overflow:visible; }
  .o-conn path { fill:none; stroke-width:2; stroke-linecap:round; stroke-dasharray:1; stroke-dashoffset:1; animation:o-draw 1.1s ease forwards; }
  @keyframes o-draw { to{stroke-dashoffset:0;} }

  .o-board { position:absolute; left:120px; top:6px; width:320px; z-index:4; background:var(--card,#fff); border:1px solid var(--line,#e6e8ec); border-radius:16px; box-shadow:0 18px 44px -16px rgba(20,22,28,.28); padding:14px 16px; }
  .o-board-h { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
  .o-board-t { font-family:'Schibsted Grotesk',sans-serif; font-weight:800; font-size:12.5px; letter-spacing:.04em; color:var(--ink,#14161c); }
  .o-live { display:inline-flex; align-items:center; gap:5px; font-size:10px; font-weight:800; letter-spacing:.04em; color:var(--green-deep,#06724a); }
  .o-live i { width:6px; height:6px; border-radius:50%; background:var(--green,#0a9d63); animation:o-dot 1.8s ease-in-out infinite; }
  @keyframes o-dot { 0%,100%{box-shadow:0 0 0 0 rgba(10,157,99,.5);} 50%{box-shadow:0 0 0 5px rgba(10,157,99,0);} }
  .o-kpi { display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 0; border-top:1px solid var(--line,#eef0f3); }
  .o-kpi:first-of-type { border-top:0; }
  .o-kpi-name { font-size:12.5px; color:var(--ink-soft,#494d57); display:flex; align-items:center; gap:7px; }
  .o-owner { width:17px; height:17px; border-radius:5px; display:flex; align-items:center; justify-content:center; font-size:9px; font-weight:800; color:#fff; font-family:'Schibsted Grotesk',sans-serif; }
  .o-kpi-val { font-family:'JetBrains Mono',monospace; font-size:12.5px; font-weight:600; color:var(--ink,#14161c); }
  .o-pill { font-size:10px; font-weight:800; padding:2px 8px; border-radius:999px; }
  .o-on { color:#0a7d3f; background:#dcfce7; } .o-watch { color:#b4690e; background:#fef3c7; }

  .o-seat { position:absolute; width:186px; z-index:3; background:var(--card,#fff); border:1px solid var(--line,#e6e8ec); border-radius:13px; padding:10px 12px; box-shadow:0 8px 22px -10px rgba(20,22,28,.22); }
  .o-seat-top { display:flex; gap:9px; align-items:center; }
  .o-av { width:30px; height:30px; border-radius:8px; flex:none; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:12px; color:#fff; font-family:'Schibsted Grotesk',sans-serif; }
  .o-nm { font-family:'Schibsted Grotesk',sans-serif; font-weight:700; font-size:12.5px; color:var(--ink,#14161c); line-height:1.1; }
  .o-rl { font-size:10px; color:var(--ink-mute,#888c96); margin-top:1px; }
  .o-tag { font-size:8.5px; font-weight:800; letter-spacing:.05em; text-transform:uppercase; padding:1px 6px; border-radius:999px; margin-left:auto; }
  .o-tag.hu { color:var(--orange-deep,#d4540a); background:rgba(255,122,26,.12); }
  .o-tag.ag { color:var(--blue-deep,#0a56b0); background:rgba(13,125,242,.12); }
  .o-meter { margin-top:9px; }
  .o-meter-l { display:flex; justify-content:space-between; font-size:9.5px; color:var(--ink-mute,#888c96); margin-bottom:3px; }
  .o-meter-l b { font-family:'JetBrains Mono',monospace; color:var(--ink-soft,#494d57); font-weight:600; }
  .o-bar { height:5px; border-radius:3px; background:var(--grey,#f0f1f3); overflow:hidden; }
  .o-bar i { display:block; height:100%; border-radius:3px; transform:scaleX(0); transform-origin:left; animation:o-grow 1.3s cubic-bezier(.16,1,.3,1) forwards; }
  @keyframes o-grow { to{transform:scaleX(1);} }
  .o-seat.s1 { left:0;   top:250px; } .o-seat.s2 { left:0;   top:372px; }
  .o-seat.s3 { right:0;  top:250px; } .o-seat.s4 { right:0;  top:372px; }

  @media (max-width:980px){ .coo-stage{ transform:scale(.84); transform-origin:top center; margin:0 auto -70px; } }
  @media (max-width:860px){
    .coo-hero-grid{ justify-content:center; }
    .coo-hero-copy{ text-align:center; min-width:0; }
    .coo-cta-row{ justify-content:center; }
    .coo-trust-strip{ justify-content:center; }
    .coo-stage{ display:none; }
  }
</style>

<!-- ================= HERO ================= -->
<section class="coo-hero">
  <div class="coo-hero-wrap">
    <div class="coo-hero-grid">
      <div class="coo-hero-copy">
        <div class="coo-eyebrow" style="margin-bottom:16px;"><span class="coo-tick"></span>For COOs &amp; heads of operations</div>
        <h1 class="coo-h1">How much of your business still runs <span class="accent">on you</span>?</h1>
        <p class="coo-lead" style="margin-top:20px;max-width:36rem;">Every meeting ends with commitments. Most of them dissolve into inboxes and good intentions, and the ones that don't wait on you to chase them. OTP is the operating layer where every person <em>and</em> every agent has a seat, a number, and the work between meetings actually <em class="accent-g">closes</em> &mdash; so the business runs on the system, not on you.</p>
        <div class="coo-cta-row">
          <a href="https://calendly.com/dawson-orgtp/30min" target="_blank" rel="noopener" class="coo-btn primary">Book a walkthrough &rarr;</a>
          <a href="/sign-up" class="coo-btn ghost">Start free</a>
        </div>
        <div class="coo-trust-strip">
          <span>Built on the <b>EOS you run</b></span><span style="color:#cfd3da;">&middot;</span>
          <span>180+ meeting templates</span><span style="color:#cfd3da;">&middot;</span>
          <span>People &amp; agents, one chart</span>
        </div>
      </div>

      <!-- animated scene: every seat closes its loop, rolling up to this week's execution -->
      <div class="coo-stage">
        <svg class="o-conn" viewBox="0 0 560 500">
          <path pathLength="1" d="M150,300 C150,210 250,150 282,128" stroke="var(--orange,#ff7a1a)" style="animation-delay:.7s"/>
          <path pathLength="1" d="M150,400 C150,250 250,160 282,134" stroke="var(--orange,#ff7a1a)" style="animation-delay:.85s"/>
          <path pathLength="1" d="M410,300 C410,210 310,150 278,128" stroke="var(--blue,#0d7df2)" style="animation-delay:.9s"/>
          <path pathLength="1" d="M410,400 C410,250 310,160 278,134" stroke="var(--blue,#0d7df2)" style="animation-delay:1.05s"/>
          <circle r="3.5" fill="var(--orange,#ff7a1a)"><animateMotion dur="3s" repeatCount="indefinite" begin="1.8s" path="M150,300 C150,210 250,150 282,128"/></circle>
          <circle r="3.5" fill="var(--blue,#0d7df2)"><animateMotion dur="3s" repeatCount="indefinite" begin="2.4s" path="M410,400 C410,250 310,160 278,134"/></circle>
        </svg>

        <div class="o-board pop" style="animation-delay:.4s">
          <div class="o-board-h"><div class="o-board-t">This week &middot; execution</div><span class="o-live"><i></i>LIVE</span></div>
          <div class="o-kpi"><div class="o-kpi-name"><span class="o-owner" style="background:#e07a3a">B</span>To-dos closed</div><span class="o-kpi-val">41/46</span><span class="o-pill o-on">on&nbsp;track</span></div>
          <div class="o-kpi"><div class="o-kpi-name"><span class="o-owner" style="background:#0d7df2">D</span>Issues resolved</div><span class="o-kpi-val">7/9</span><span class="o-pill o-on">on&nbsp;track</span></div>
          <div class="o-kpi"><div class="o-kpi-name"><span class="o-owner" style="background:#0a9d63">T</span>Runs without me</div><span class="o-kpi-val">63%</span><span class="o-pill o-watch">watch</span></div>
        </div>

        <div class="o-seat s1 rise" style="animation-delay:.7s">
          <div class="o-seat-top"><div class="o-av" style="background:#e07a3a">SK</div><div><div class="o-nm">Sarah Kim</div><div class="o-rl">Product Manager</div></div><span class="o-tag hu">Human</span></div>
          <div class="o-meter"><div class="o-meter-l"><span>Commitments closed</span><b>9/10</b></div><div class="o-bar"><i style="width:90%;background:var(--orange,#ff7a1a);animation-delay:1.2s"></i></div></div>
        </div>
        <div class="o-seat s2 rise" style="animation-delay:.85s">
          <div class="o-seat-top"><div class="o-av" style="background:#c4612a">AR</div><div><div class="o-nm">Alex Rivera</div><div class="o-rl">Ops Lead</div></div><span class="o-tag hu">Human</span></div>
          <div class="o-meter"><div class="o-meter-l"><span>Commitments closed</span><b>6/9</b></div><div class="o-bar"><i style="width:66%;background:var(--orange,#ff7a1a);animation-delay:1.35s"></i></div></div>
        </div>
        <div class="o-seat s3 rise" style="animation-delay:.95s">
          <div class="o-seat-top"><div class="o-av" style="background:#0d7df2">RA</div><div><div class="o-nm">Reporting Agent</div><div class="o-rl">Runs autonomously</div></div><span class="o-tag ag">Agent</span></div>
          <div class="o-meter"><div class="o-meter-l"><span>Tasks shipped</span><b>24/24</b></div><div class="o-bar"><i style="width:100%;background:var(--blue,#0d7df2);animation-delay:1.45s"></i></div></div>
        </div>
        <div class="o-seat s4 rise" style="animation-delay:1.1s">
          <div class="o-seat-top"><div class="o-av" style="background:#0a64c4">WF</div><div><div class="o-nm">Workflow Agent</div><div class="o-rl">Runs autonomously</div></div><span class="o-tag ag">Agent</span></div>
          <div class="o-meter"><div class="o-meter-l"><span>Tasks shipped</span><b>18/20</b></div><div class="o-bar"><i style="width:90%;background:var(--blue,#0d7df2);animation-delay:1.55s"></i></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= THE GAP ================= -->
<section class="coo-grey">
  <div class="coo-wrap coo-sec">
    <div class="coo-max720">
      <div class="coo-eyebrow" style="margin-bottom:16px;">Where execution dies</div>
      <h2 class="coo-h2">The work between meetings is where it all falls apart.</h2>
      <p class="coo-body" style="margin-top:18px;max-width:44rem;">You don't have a strategy problem. You have a follow-through problem &mdash; commitments made in a room on Monday, half-remembered by Thursday, and the only thing keeping them alive is you, chasing.</p>
    </div>
    <div class="coo-grid3 reveal">
      <div class="coo-card">
        <span class="coo-chip" style="background:rgba(220,38,38,.1);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M8 6V4h8v2M6 6l1 14h10l1-14"/></svg></span>
        <h3>Commitments evaporate</h3>
        <p>To-dos live in a dozen inboxes, a whiteboard photo, and someone's memory. No single owner, no due date that bites, no place that shows what actually got done.</p>
      </div>
      <div class="coo-card">
        <span class="coo-chip" style="background:rgba(217,119,6,.12);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg></span>
        <h3>You are the dependency</h3>
        <p>Too much of the business waits on you to unblock it, decide it, or chase it. You can feel the bottleneck &mdash; you just can't see exactly where it is or how big.</p>
      </div>
      <div class="coo-card">
        <span class="coo-chip" style="background:rgba(13,125,242,.1);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d7df2" stroke-width="2" stroke-linecap="round"><rect x="5" y="8" width="14" height="11" rx="3"/><path d="M12 4v4M9 13h.01M15 13h.01"/></svg></span>
        <h3>Agents run unmanaged</h3>
        <p>Your team has started wiring up agents that do real work &mdash; with no seat, no owner, and no line into the operation. Work is happening that you can't see, account for, or repeat.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= ONE OPERATING SYSTEM ================= -->
<section class="coo-paper">
  <div class="coo-wrap coo-sec">
    <div class="coo-max720">
      <div class="coo-eyebrow" style="margin-bottom:16px;">One operating system</div>
      <h2 class="coo-h2">Chart, scorecard, meeting, to-dos, done &mdash; for people <em>and</em> agents.</h2>
      <p class="coo-body" style="margin-top:18px;max-width:44rem;">OTP runs your whole operating cadence in one place. The accountability chart says who owns what. The scorecard says whether it's working. The weekly meeting drives the issues to a decision &mdash; and every commitment lands as an owned to-do that you can watch close. Humans and agents sit on the same chart, driving the same numbers.</p>
    </div>
    <div class="coo-grid2 reveal">
      <div class="coo-card">
        <h3>Every commitment closes the loop</h3>
        <p>Issues become decisions, decisions become to-dos with a named owner and a date, and you see the whole list move &mdash; closed, slipping, or stuck &mdash; without sending a single "any update?" message.</p>
      </div>
      <div class="coo-card">
        <h3>See your dependency, then shrink it</h3>
        <p>Watch how much of the business runs without you in the room, where work waits on one person, and which accountability gaps quietly cost you throughput. Then close them on purpose.</p>
      </div>
      <div class="coo-card">
        <h3>Agents take real seats</h3>
        <p>Give an agent a role, the SOPs it owns, who it reports to, and the number it's accountable for &mdash; the same scorecard as a person. Now the work it does is visible, repeatable, and yours to keep.</p>
      </div>
      <div class="coo-card">
        <h3>Process that doesn't walk out</h3>
        <p>SOPs and agent setups are housed in OTP. When someone leaves, the way the work gets done doesn't leave with them &mdash; you re-seat it, or port a great one from one team to another.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= THE EXECUTION ENGINE (meetings) ================= -->
<section class="coo-grey">
  <div class="coo-wrap coo-sec">
    <div class="coo-max720">
      <div class="coo-eyebrow" style="margin-bottom:16px;">The execution engine</div>
      <h2 class="coo-h2">The weekly meeting that actually produces action.</h2>
      <p class="coo-body" style="margin-top:18px;max-width:44rem;">Run your weekly leadership meeting inside OTP &mdash; on the system you already use (EOS, Scaling Up, or your own, with 180+ templates). The agenda, scorecard, quarterly priorities, headlines, and issues are all live and pulled from real data. Conclude, and it cascades.</p>
    </div>
    <div class="coo-feat">
