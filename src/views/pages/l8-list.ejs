<%
  var teamsList = locals.teamsList || [];
  var filterTeamId = locals.filterTeamId || '';
  var defaultTeamId = locals.defaultTeamId || '';
  var teamLookup = {};
  teamsList.forEach(function(t) { teamLookup[t.id] = t; });
%>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-8">
    <%- include('../partials/ui-page-header', { mascot: 'meetings', eyebrow: 'L8 Meetings — the cadence that drives your org to agentic maturity', title: org.name, subtitle: 'Run your weekly leadership meeting from one page. Check-in, Scorecard, Quarterly Priorities, Headlines, To-Dos, Issues, Conclude.' }) %>
  </div>

  <!-- Team filter -->
  <% if (teamsList.length > 1) { %>
    <form method="GET" action="/l8" class="mb-4 flex items-center gap-2 text-sm">
      <label class="text-xs uppercase tracking-wide text-gray-600 font-semibold">Team:</label>
      <select name="teamId" onchange="this.form.submit()" class="border rounded p-1.5 text-sm">
        <option value="">All teams</option>
        <% teamsList.forEach(function(t) { %>
          <option value="<%= t.id %>" <%= filterTeamId === t.id ? 'selected' : '' %>><%= t.name %></option>
        <% }) %>
      </select>
      <% if (devOrgIdParam) { %><input type="hidden" name="orgId" value="<%= devOrgIdParam %>"><% } %>
    </form>
  <% } %>

  <!-- Quick create -->
  <form action="/l8/create<%= devOrgIdParam ? ('?orgId=' + devOrgIdParam) : '' %>" method="POST" class="border rounded-lg p-4 mb-8 bg-gray-50">
    <div class="flex items-center gap-2 mb-3">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-700">New Meeting</h2>
      <button type="button" id="meeting-help" aria-label="About the meeting cadence" title="What are these meeting types?"
              class="w-[18px] h-[18px] inline-flex items-center justify-center rounded-full border border-gray-400 text-gray-500 text-[11px] font-bold leading-none hover:bg-gray-200 hover:text-gray-700">?</button>
    </div>
    <div class="grid grid-cols-3 gap-3">
      <input name="title" type="text" required placeholder="e.g. Leadership Meeting -- 2026-05-05"
             class="col-span-2 border rounded p-2 text-sm"
             value="Leadership Meeting -- <%= new Date().toISOString().slice(0,10) %>">
      <input name="scheduledAt" type="datetime-local" required
             class="border rounded p-2 text-sm"
             value="<%= new Date(Date.now() + 86400000).toISOString().slice(0,16) %>">
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3">
      <select name="meetingType" class="border rounded p-2 text-sm" title="Which meeting in the cadence is this? See the (?) next to New Meeting.">
        <optgroup label="Weekly">
          <option value="leadership">Leadership Meeting (Weekly)</option>
          <option value="departmental">Departmental Meeting (Weekly)</option>
        </optgroup>
        <optgroup label="By quarter / year">
          <option value="quarterly">Quarterly Session</option>
          <option value="annual">Annual Planning (2-day)</option>
        </optgroup>
        <optgroup label="Leadership 1-on-1s">
          <option value="same_page">Same Page Meeting</option>
          <option value="1on1">One-on-One</option>
        </optgroup>
        <option value="other">Other</option>
      </select>
      <select name="recurrenceRule" class="border rounded p-2 text-sm" title="Repeat this meeting? OTP rolls the next one forward automatically.">
        <option value="">Does not repeat</option>
        <option value="FREQ=WEEKLY">Weekly</option>
        <option value="FREQ=WEEKLY;INTERVAL=2">Every 2 weeks</option>
        <option value="FREQ=MONTHLY">Monthly</option>
      </select>
      <% if (teamsList.length > 0) { %>
        <select name="teamId" class="border rounded p-2 text-sm" title="Which team is meeting?">
          <% teamsList.forEach(function(t) { %>
            <option value="<%= t.id %>" <%= (filterTeamId ? t.id === filterTeamId : t.id === defaultTeamId) ? 'selected' : '' %>><%= t.name %></option>
          <% }) %>
        </select>
      <% } %>
      <button class="ml-auto px-4 py-2 bg-otp-500 text-white rounded text-sm font-medium hover:bg-otp-400">
        Create + Open
      </button>
    </div>
  </form>

  <!-- Meeting list -->
  <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-gray-700">Recent Meetings</h2>
  <% if (!meetings || meetings.length === 0) { %>
    <div class="bg-yellow-50 border border-yellow-200 rounded p-4 text-sm">
      No meetings yet. Create one above to begin running your weekly leadership meeting from OTP.
    </div>
  <% } else { %>
    <div class="space-y-2">
      <% meetings.forEach(function(m) { %>
        <a href="/l8/meeting/<%= m.id %><%= devOrgIdParam ? ('?orgId=' + devOrgIdParam) : '' %>" class="block border rounded p-4 hover:bg-gray-50">
          <div class="flex items-center justify-between">
            <div>
              <div class="font-medium"><%= m.title %></div>
              <div class="text-xs text-gray-500 mt-1">
                <% var teamName = m.teamId && teamLookup[m.teamId] ? teamLookup[m.teamId].name : ''; %>
                <% if (teamName) { %><span class="text-otp-700 font-medium"><%= teamName %></span> &middot; <% } %>
                <%= m.meetingType %> &middot; <%= new Date(m.scheduledAt).toLocaleString() %>
              </div>
            </div>
            <div class="text-xs">
              <span class="px-2 py-0.5 rounded
                <%= m.status === 'scheduled' ? 'bg-gray-100 text-gray-700' :
                   m.status === 'in_progress' ? 'bg-blue-100 text-blue-800' :
                   m.status === 'completed' ? 'bg-emerald-100 text-emerald-800' :
                   'bg-red-100 text-red-800' %>">
                <%= m.status %>
              </span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  // (?) next to New Meeting -- explains the meeting cadence in OTP's own words.
  // Genericized + EOS attribution per trademark guidance; links inward to the
  // OTP explainer rather than out to a competitor.
  (function () {
    var btn = document.getElementById('meeting-help');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var ov = document.createElement('div');
      ov.style.cssText = 'position:fixed;inset:0;background:rgba(15,27,20,.55);display:flex;align-items:center;justify-content:center;z-index:9999;padding:16px;';
      ov.innerHTML =
        '<div style="background:#fff;border-radius:12px;max-width:520px;width:100%;max-height:85vh;overflow:auto;padding:26px;font-family:Inter,system-ui,sans-serif;box-shadow:0 20px 60px rgba(0,0,0,.3);">' +
          '<div style="font-weight:800;font-size:19px;color:#16241b;margin-bottom:4px;">The meeting cadence</div>' +
          '<div style="font-size:11.5px;color:#8a8472;margin-bottom:16px;">Modeled on EOS&reg;. EOS&reg; and Level 10 Meeting&reg; are trademarks of EOS Worldwide, LLC.</div>' +
          '<div style="font-size:14px;color:#3a3a32;line-height:1.6;">' +
            '<p style="margin:0 0 12px;">Pick the type that matches the rhythm you are running:</p>' +
            '<ul style="list-style:none;padding:0;margin:0 0 14px;display:flex;flex-direction:column;gap:10px;">' +
              '<li><strong style="color:#16241b;">Weekly &mdash; Leadership &amp; Departmental.</strong> The 90-minute weekly meeting, same agenda every time: check-in, scorecard, quarterly priorities, headlines, to-dos, then solve issues.</li>' +
              '<li><strong style="color:#16241b;">Quarterly Session.</strong> Step back every 90 days: review the quarter, reset your Rocks, solve the bigger issues.</li>' +
              '<li><strong style="color:#16241b;">Annual Planning.</strong> Two days a year on vision and the year ahead.</li>' +
              '<li><strong style="color:#16241b;">Same Page / One-on-One.</strong> Keep leaders aligned between the bigger sessions.</li>' +
            '</ul>' +
            '<p style="margin:0 0 16px;color:#5d6b60;">New to the rhythm? A typical rollout runs an intro meeting &rarr; a focus day &rarr; two vision-building days, then settles into the weekly / quarterly / annual pulse above.</p>' +
          '</div>' +
          '<div style="display:flex;gap:10px;align-items:center;">' +
            '<a href="/level-10-meetings" style="font-size:13px;font-weight:600;color:#0d7df2;text-decoration:none;">See the full agenda &amp; cadence &rarr;</a>' +
            '<button data-close style="margin-left:auto;padding:8px 14px;border:1px solid #d9e2da;background:#f7faf6;border-radius:8px;font-size:13px;font-weight:600;color:#16241b;cursor:pointer;">Got it</button>' +
          '</div>' +
        '</div>';
      var close = function () { ov.remove(); };
      ov.addEventListener('click', function (e) { if (e.target === ov || e.target.closest('[data-close]')) close(); });
      document.body.appendChild(ov);
    });
  })();
</script>
