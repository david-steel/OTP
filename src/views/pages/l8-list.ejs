<%
  var teamsList = locals.teamsList || [];
  var filterTeamId = locals.filterTeamId || '';
  var defaultTeamId = locals.defaultTeamId || '';
  var teamLookup = {};
  teamsList.forEach(function(t) { teamLookup[t.id] = t; });
  var meetingTypeLabels = {
    leadership: 'Leadership Meeting',
    departmental: 'Departmental Meeting',
    quarterly: 'Quarterly Session',
    annual: 'Annual Planning',
    same_page: 'Same Page Meeting',
    '1on1': 'One-on-One',
    strategy_reset: 'Strategy Reset',
    other: 'Other',
  };
  function meetingTypeLabel(t) { return meetingTypeLabels[t] || t; }
%>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-8">
    <%- include('../partials/ui-page-header', { mascot: 'meetings', eyebrow: 'L8 Meetings — the cadence that drives your org to agentic maturity', title: org.name, subtitle: 'Run your weekly leadership meeting from one page. Check-in, Scorecard, Quarterly Priorities, Headlines, To-Dos, Issues, Conclude.' }) %>
    <% if (typeof meetingFormatsEnabled !== 'undefined' && meetingFormatsEnabled) { %>
    <div class="mt-2 flex justify-end">
      <a href="/dashboard/meeting-formats" class="inline-flex items-center gap-1.5 text-sm font-semibold text-gray-600 border border-gray-200 rounded-lg px-3 py-2 hover:bg-gray-50 hover:text-otp-600">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h10M4 18h7"/></svg>
        Meeting formats
      </a>
    </div>
    <% } %>
  </div>

  <div class="flex items-center justify-end mb-6">
    <button type="button" id="open-newmtg" class="px-4 py-2 bg-otp-500 text-white rounded-lg text-sm font-semibold hover:bg-otp-400">+ New meeting</button>
  </div>

  <!-- Team filter -->
  <% if (teamsList.length > 1) { %>
    <form method="GET" action="/l8" class="mb-4 flex items-center gap-2 text-sm">
      <label class="text-xs uppercase tracking-wide text-gray-600 font-semibold">Team:</label>
      <select name="teamId" onchange="this.form.submit()" class="border rounded p-1.5 text-sm">
        <option value="">All teams</option>
        <% teamsList.forEach(function(t) { %>
          <option value="<%= t.id %>" <%= filterTeamId === t.id ? 'selected' : '' %>><%= t.name %></option>
        <% }) %>
      </select>
      <% if (devOrgIdParam) { %><input type="hidden" name="orgId" value="<%= devOrgIdParam %>"><% } %>
    </form>
  <% } %>

  <!-- New meeting (modal) -->
  <div id="newmtg-modal" class="mtg-modal" hidden>
    <div class="mtg-modal-card">
      <div class="mtg-modal-head">
        <h3 class="mtg-modal-title">New meeting <button type="button" class="help-q" data-help="l8.cadence" aria-label="About the meeting cadence">?</button></h3>
        <button type="button" class="mtg-modal-x" id="close-newmtg" aria-label="Close">&times;</button>
      </div>
      <div class="mtg-modal-body">
        <form action="/l8/create<%= devOrgIdParam ? ('?orgId=' + devOrgIdParam) : '' %>" method="POST">
          <div class="grid grid-cols-3 gap-3">
      <input name="title" type="text" placeholder="Title (optional) — defaults to type + team"
             class="col-span-2 border rounded p-2 text-sm">
      <input name="scheduledAt" type="datetime-local" required
             class="border rounded p-2 text-sm"
             value="<%= new Date(Math.round(Date.now() / 1800000) * 1800000).toISOString().slice(0,16) %>">
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3">
      <select name="meetingType" class="border rounded p-2 text-sm" title="Which meeting in the cadence is this? See the (?) next to New Meeting.">
        <optgroup label="Weekly">
          <option value="leadership">Leadership Meeting (Weekly)</option>
          <option value="departmental">Departmental Meeting (Weekly)</option>
        </optgroup>
        <optgroup label="By quarter / year">
          <option value="quarterly">Quarterly Session</option>
          <option value="annual">Annual Planning (2-day)</option>
        </optgroup>
        <optgroup label="Leadership 1-on-1s">
          <option value="same_page">Same Page Meeting</option>
          <option value="1on1">One-on-One</option>
        </optgroup>
        <option value="strategy_reset">Strategy Reset</option>
        <option value="other">Other</option>
        <% if (typeof meetingFormatsEnabled !== 'undefined' && meetingFormatsEnabled && typeof meetingFormatsList !== 'undefined' && meetingFormatsList.length) { %>
          <optgroup label="Your formats">
            <% meetingFormatsList.forEach(function(f) { %>
              <option value="format:<%= f.id %>"><%= f.name %></option>
            <% }) %>
          </optgroup>
        <% } %>
      </select>
      <select name="recurrenceRule" class="border rounded p-2 text-sm" title="Repeat this meeting? OTP rolls the next one forward automatically.">
        <option value="">Does not repeat</option>
        <option value="FREQ=WEEKLY">Weekly</option>
        <option value="FREQ=WEEKLY;INTERVAL=2">Every 2 weeks</option>
        <option value="FREQ=MONTHLY">Monthly</option>
      </select>
      <% if (teamsList.length > 0) { %>
        <select name="teamId" class="border rounded p-2 text-sm" title="Which team is meeting?">
          <% teamsList.forEach(function(t) { %>
            <option value="<%= t.id %>" <%= (filterTeamId ? t.id === filterTeamId : t.id === defaultTeamId) ? 'selected' : '' %>><%= t.name %></option>
          <% }) %>
        </select>
      <% } %>
      <button class="ml-auto px-4 py-2 bg-otp-500 text-white rounded text-sm font-medium hover:bg-otp-400">
        Create + Open
      </button>
    </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Meeting list -->
  <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-gray-700">Recent Meetings</h2>
  <% if (!meetings || meetings.length === 0) { %>
    <div class="bg-yellow-50 border border-yellow-200 rounded p-4 text-sm">
      No meetings yet. Create one above to begin running your weekly leadership meeting from OTP.
    </div>
  <% } else { %>
    <div class="space-y-2">
      <% meetings.forEach(function(m) { %>
        <% var teamName = m.teamId && teamLookup[m.teamId] ? teamLookup[m.teamId].name : ''; %>
        <% var _joinHref = '/l8/meeting/' + m.id + (devOrgIdParam ? ('?orgId=' + devOrgIdParam) : ''); %>
        <%# Manage menu (Edit / Delete) shows to everyone who is not a read-only
            role. The API (checkMeetingEdit) is the real gate -- it allows the
            founder, the meeting's creator, owners/admins, and team managers, and
            rejects anyone else with a clear message. A null role = legacy founder,
            so default to showing it (never hide management from the owner). %>
        <% var _ro = ['observer','inactive','free']; %>
        <% var _canManage = (typeof memberRole === 'undefined' || memberRole === null) ? true : (_ro.indexOf(memberRole) === -1); %>
        <div class="mtg-card relative border rounded p-4 <%= m.locked ? 'bg-gray-50' : 'hover:bg-gray-50' %>"<% if (m.locked || m.status === 'scheduled') { %> data-starts-at="<%= new Date(m.scheduledAt).toISOString() %>"<% } %>>
          <%# Non-locked cards open on click via a stretched link underneath, so the
              manage menu can sit above it without nesting a button inside an anchor.
              Locked (future) cards are not openable yet -- no stretched link. %>
          <% if (!m.locked) { %><a href="<%= _joinHref %>" class="absolute inset-0 z-0" aria-label="Open <%= m.title %>"></a><% } %>
          <div class="relative z-10 flex items-center justify-between gap-3 pointer-events-none">
            <div>
              <div class="font-medium <%= m.locked ? 'text-gray-700' : '' %>"><%= m.title %></div>
              <div class="text-xs text-gray-500 mt-1">
                <% if (teamName) { %><span class="text-otp-700 font-medium"><%= teamName %></span> &middot; <% } %>
                <%= meetingTypeLabel(m.meetingType) %> &middot; <%= new Date(m.scheduledAt).toLocaleString() %>
              </div>
            </div>
            <div class="flex items-center gap-2 text-xs shrink-0 pointer-events-auto">
              <% if (m.locked) { %>
                <span class="mtg-countdown text-gray-500 font-medium"></span>
                <a class="mtg-join hidden px-3 py-1.5 rounded bg-otp-500 text-white font-semibold hover:bg-otp-400" href="<%= _joinHref %>">Join &rarr;</a>
                <span class="mtg-upcoming px-2 py-0.5 rounded bg-amber-100 text-amber-800">Upcoming</span>
              <% } else { %>
                <% if (m.status === 'scheduled') { %><span class="mtg-countdown text-gray-500 font-medium"></span><% } %>
                <span class="px-2 py-0.5 rounded
                  <%= m.status === 'scheduled' ? 'bg-gray-100 text-gray-700' :
                     m.status === 'in_progress' ? 'bg-blue-100 text-blue-800' :
                     m.status === 'completed' ? 'bg-emerald-100 text-emerald-800' :
                     'bg-red-100 text-red-800' %>">
                  <%= m.status === 'in_progress' ? 'live' : m.status %>
                </span>
              <% } %>
              <% if (_canManage) { %>
                <div class="relative mtg-menu-wrap">
                  <button type="button" class="mtg-menu-btn px-2 py-0.5 rounded text-gray-400 hover:text-gray-700 hover:bg-gray-200 text-base leading-none" aria-label="Manage meeting" title="Manage">&#8943;</button>
                  <div class="mtg-menu hidden absolute right-0 mt-1 w-36 bg-white border border-gray-200 rounded-lg shadow-lg z-30 py-1 text-left">
                    <button type="button" class="mtg-edit block w-full text-left px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50" data-id="<%= m.id %>" data-title="<%= m.title %>" data-at="<%= new Date(m.scheduledAt).toISOString() %>" data-rrule="<%= m.recurrenceRule || '' %>">Edit details</button>
                    <button type="button" class="mtg-delete block w-full text-left px-3 py-1.5 text-sm text-rose-600 hover:bg-rose-50" data-id="<%= m.id %>" data-title="<%= m.title %>"<% if (m.recurrenceRule || m.recurrenceParentId) { %> data-recurring="1"<% } %>>Delete</button>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
// Live "Starts in …" countdown on upcoming/scheduled meetings; reveal Join in the
// last 10 minutes so people can jump in right before it begins (success.co-style).
(function () {
  function fmt(ms) {
    var s = Math.floor(ms / 1000), h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), r = s % 60;
    if (h > 0) return 'Starts in ' + h + 'h ' + m + 'm';
    if (m > 0) return 'Starts in ' + m + ':' + String(r).padStart(2, '0');
    return 'Starts in ' + r + 's';
  }
  function tick() {
    var now = Date.now();
    document.querySelectorAll('.mtg-card[data-starts-at]').forEach(function (card) {
      var t = Date.parse(card.getAttribute('data-starts-at'));
      if (isNaN(t)) return;
      var rem = t - now;
      var cd = card.querySelector('.mtg-countdown');
      var join = card.querySelector('.mtg-join');
      var up = card.querySelector('.mtg-upcoming');
      if (cd) cd.textContent = rem > 0 ? fmt(rem) : 'Starting now';
      if (join && rem <= 10 * 60 * 1000) { join.classList.remove('hidden'); if (up) up.classList.add('hidden'); }
    });
  }
  tick();
  setInterval(tick, 1000);
})();
</script>


<script>
// New-meeting modal: present the create form (which already includes Labs custom
// formats) as a centered modal instead of an inline block.
(function () {
  var openBtn = document.getElementById('open-newmtg');
  var modal = document.getElementById('newmtg-modal');
  var closeBtn = document.getElementById('close-newmtg');
  if (!openBtn || !modal) return;
  function show() {
    modal.hidden = false;
    // Default the date to today, rounded to the nearest half-hour (local time),
    // freshly each time the modal opens -- so hitting Create drops you into a
    // meeting starting about now.
    var s = modal.querySelector('input[name="scheduledAt"]');
    if (s) {
      var ms = 30 * 60 * 1000;
      var d = new Date(Math.round(Date.now() / ms) * ms);
      var p = function (n) { return (n < 10 ? '0' : '') + n; };
      s.value = d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate()) + 'T' + p(d.getHours()) + ':' + p(d.getMinutes());
    }
    var t = modal.querySelector('input[name="title"]'); if (t) setTimeout(function () { t.focus(); }, 10);
  }
  function hide() { modal.hidden = true; }
  openBtn.addEventListener('click', show);
  if (closeBtn) closeBtn.addEventListener('click', hide);
  modal.addEventListener('mousedown', function (e) { if (e.target === modal) hide(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.hidden) hide(); });
})();
</script>

<!-- Edit-meeting modal (shown after picking "Edit details" from a card's menu) -->
<div id="mtg-edit-modal" hidden class="fixed inset-0 z-[90] flex items-center justify-center p-4" style="background:rgba(15,23,42,0.45);">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md p-6" role="dialog" aria-modal="true">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg font-bold text-gray-900">Edit meeting</h3>
      <button type="button" id="mtg-edit-x" class="text-gray-400 hover:text-gray-700 text-2xl leading-none">&times;</button>
    </div>
    <div class="mt-4 space-y-3">
      <label class="block text-sm text-gray-700">Title
        <input type="text" id="mtg-edit-title" maxlength="255" class="mt-1 w-full border rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-otp-500">
      </label>
      <label class="block text-sm text-gray-700">Date &amp; time
        <input type="datetime-local" id="mtg-edit-at" class="mt-1 w-full border rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-otp-500">
      </label>
      <p id="mtg-edit-rrule-note" class="hidden text-xs text-gray-500">This meeting is part of a recurring series. Changing the date moves this occurrence only.</p>
    </div>
    <div class="mt-5 flex justify-end gap-2">
      <button type="button" id="mtg-edit-cancel" class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
      <button type="button" id="mtg-edit-save" class="px-4 py-2 text-sm bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400">Save changes</button>
    </div>
    <p id="mtg-edit-msg" class="mt-2 text-xs text-rose-600"></p>
  </div>
</div>

<!-- Delete-scope modal: only shown for recurring meetings, so the user can choose
     this occurrence / this + future / the whole series. Non-recurring meetings use
     a plain confirm() instead. -->
<div id="mtg-del-modal" hidden class="fixed inset-0 z-[90] flex items-center justify-center p-4" style="background:rgba(15,23,42,0.45);">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md p-6" role="dialog" aria-modal="true">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg font-bold text-gray-900">Delete recurring meeting</h3>
      <button type="button" id="mtg-del-x" class="text-gray-400 hover:text-gray-700 text-2xl leading-none">&times;</button>
    </div>
    <p class="text-sm text-gray-600 mt-1"><span id="mtg-del-title" class="font-semibold"></span> is part of a recurring series. What should be deleted?</p>
    <div class="mt-4 space-y-2">
      <button type="button" data-scope="occurrence" class="mtg-del-go block w-full text-left px-3 py-2 text-sm border border-gray-200 rounded-lg hover:bg-gray-50">Just this occurrence</button>
      <button type="button" data-scope="following" class="mtg-del-go block w-full text-left px-3 py-2 text-sm border border-gray-200 rounded-lg hover:bg-gray-50">This and all future occurrences</button>
      <button type="button" data-scope="series" class="mtg-del-go block w-full text-left px-3 py-2 text-sm border border-rose-200 text-rose-700 rounded-lg hover:bg-rose-50">The entire series</button>
    </div>
    <div class="mt-4 flex justify-end">
      <button type="button" id="mtg-del-cancel" class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
    </div>
    <p id="mtg-del-msg" class="mt-2 text-xs text-rose-600"></p>
  </div>
</div>

<script>
// Per-card manage menu: Edit details (title + date) and Delete. The API enforces
// who may actually do it; the UI just surfaces the affordance and the messages.
(function () {
  function closeAllMenus() { document.querySelectorAll('.mtg-menu').forEach(function (el) { el.classList.add('hidden'); }); }
  document.querySelectorAll('.mtg-menu-wrap').forEach(function (wrap) {
    var btn = wrap.querySelector('.mtg-menu-btn');
    var menu = wrap.querySelector('.mtg-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function (e) {
      e.preventDefault(); e.stopPropagation();
      var wasHidden = menu.classList.contains('hidden');
      closeAllMenus();
      if (wasHidden) menu.classList.remove('hidden');
    });
  });
  document.addEventListener('click', function () { closeAllMenus(); });

  // ---- Edit ----
  var modal = document.getElementById('mtg-edit-modal');
  var fTitle = document.getElementById('mtg-edit-title');
  var fAt = document.getElementById('mtg-edit-at');
  var note = document.getElementById('mtg-edit-rrule-note');
  var msg = document.getElementById('mtg-edit-msg');
  var saveBtn = document.getElementById('mtg-edit-save');
  var editingId = null;
  function toLocalInput(iso) {
    var d = new Date(iso); if (isNaN(d)) return '';
    var off = d.getTimezoneOffset() * 60000;
    return new Date(d.getTime() - off).toISOString().slice(0, 16);
  }
  function openEdit(id, title, atISO, rrule) {
    editingId = id; msg.textContent = '';
    fTitle.value = title || ''; fAt.value = toLocalInput(atISO);
    if (note) note.classList.toggle('hidden', !rrule);
    saveBtn.disabled = false; saveBtn.textContent = 'Save changes';
    modal.hidden = false; setTimeout(function () { fTitle.focus(); }, 10);
  }
  function closeEdit() { modal.hidden = true; editingId = null; }
  document.querySelectorAll('.mtg-edit').forEach(function (b) {
    b.addEventListener('click', function (e) {
      e.preventDefault(); e.stopPropagation(); closeAllMenus();
      openEdit(this.getAttribute('data-id'), this.getAttribute('data-title'), this.getAttribute('data-at'), this.getAttribute('data-rrule'));
    });
  });
  document.getElementById('mtg-edit-x').addEventListener('click', closeEdit);
  document.getElementById('mtg-edit-cancel').addEventListener('click', closeEdit);
  modal.addEventListener('mousedown', function (e) { if (e.target === modal) closeEdit(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.hidden) closeEdit(); });
  saveBtn.addEventListener('click', function () {
    if (!editingId) return;
    var title = fTitle.value.trim();
    if (!title) { msg.textContent = 'Title is required.'; return; }
    if (!fAt.value) { msg.textContent = 'Pick a date and time.'; return; }
    var iso;
    try { iso = new Date(fAt.value).toISOString(); } catch (e) { msg.textContent = 'That date is not valid.'; return; }
    saveBtn.disabled = true; saveBtn.textContent = 'Saving...';
    fetch('/api/v1/meetings/' + editingId, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
      body: JSON.stringify({ title: title, scheduledAt: iso })
    })
      .then(function (r) { return r.json().catch(function () { return {}; }).then(function (j) { if (!r.ok) throw (j.error || { message: 'HTTP ' + r.status }); return j; }); })
      .then(function () { window.location.reload(); })
      .catch(function (err) { msg.textContent = (err && err.message) || 'Could not save.'; saveBtn.disabled = false; saveBtn.textContent = 'Save changes'; });
  });

  // ---- Delete ----
  var delModal = document.getElementById('mtg-del-modal');
  var delTitleEl = document.getElementById('mtg-del-title');
  var delMsg = document.getElementById('mtg-del-msg');
  var deletingId = null;
  function doDelete(id, body) {
    return fetch('/api/v1/meetings/' + id, {
      method: 'DELETE', credentials: 'same-origin',
      headers: body ? { 'Content-Type': 'application/json' } : undefined,
      body: body ? JSON.stringify(body) : undefined
    })
      .then(function (r) { return r.json().catch(function () { return {}; }).then(function (j) { if (!r.ok) throw (j.error || { message: 'HTTP ' + r.status }); return j; }); });
  }
  function closeDel() { delModal.hidden = true; deletingId = null; }
  document.querySelectorAll('.mtg-delete').forEach(function (b) {
    b.addEventListener('click', function (e) {
      e.preventDefault(); e.stopPropagation(); closeAllMenus();
      var id = this.getAttribute('data-id');
      var title = this.getAttribute('data-title') || 'this meeting';
      var recurring = this.getAttribute('data-recurring') === '1';
      if (recurring) {
        deletingId = id; delMsg.textContent = '';
        delTitleEl.textContent = '"' + title + '"';
        delModal.hidden = false;
        return;
      }
      if (!window.confirm('Delete "' + title + '"? This cannot be undone.')) return;
      doDelete(id)
        .then(function () { window.location.reload(); })
        .catch(function (err) { window.alert((err && err.message) || 'Could not delete this meeting.'); });
    });
  });
  document.querySelectorAll('.mtg-del-go').forEach(function (b) {
    b.addEventListener('click', function () {
      if (!deletingId) return;
      var scope = this.getAttribute('data-scope');
      delMsg.textContent = 'Deleting...';
      doDelete(deletingId, { scope: scope })
        .then(function () { window.location.reload(); })
        .catch(function (err) { delMsg.textContent = (err && err.message) || 'Could not delete.'; });
    });
  });
  document.getElementById('mtg-del-x').addEventListener('click', closeDel);
  document.getElementById('mtg-del-cancel').addEventListener('click', closeDel);
  delModal.addEventListener('mousedown', function (e) { if (e.target === delModal) closeDel(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !delModal.hidden) closeDel(); });
})();
</script>
