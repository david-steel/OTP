      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      <% founderPosts.forEach(function(post) { %>
        <a href="/blog/<%= post.slug %>" class="card lift bg-card group">
          <div class="bg-card-cap cap-orange h-[124px]">
            <div class="text-center px-5">
              <div class="font-mono text-[10px] font-medium tracking-[0.16em] uppercase mb-1.5" style="color:var(--orange-deep);">Founder Notes</div>
              <div class="font-display text-[var(--ink)] text-[13.5px] font-bold leading-tight line-clamp-2 max-w-[220px] mx-auto"><%= post.title %></div>
            </div>
          </div>
          <div class="p-5 sm:p-6 flex flex-col flex-1">
            <div class="bg-card-meta mb-2.5" style="color:var(--orange-deep);">
              <span>David Steel</span><span class="dot" style="background:var(--line);"></span>
              <span style="color:var(--ink-mute);"><%= post.date %></span>
            </div>
            <h3 class="bg-card-title mb-2" style="font-size:1.05rem;"><%= post.title %></h3>
            <p class="bg-card-desc"><%= post.description %></p>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

