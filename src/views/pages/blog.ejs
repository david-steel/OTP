<%# /blog -- v7 layout (light, editorial). Blog index / listing.
    Rendered via reply.view('pages/blog', data, { layout: 'layouts/v7' }).
    Restyled to v7. Every post link, EJS loop, and data reference preserved. %>
<style>
  .bg-float { animation:bg-float 6.5s ease-in-out infinite; }
  @keyframes bg-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12px);} }
  .bg-glow {
    position:absolute; left:50%; top:52%; width:80%; height:62%;
    transform:translate(-50%,-50%); z-index:0; pointer-events:none;
    background:radial-gradient(ellipse, rgba(189,214,34,0.26), transparent 70%);
    animation:bg-breathe 6.5s ease-in-out infinite;
  }
  @keyframes bg-breathe { 0%,100%{opacity:.5;} 50%{opacity:1;} }
  @media (prefers-reduced-motion:reduce){ .bg-float,.bg-glow{ animation:none; } }

  /* post card -- v7 editorial */
  .bg-card { display:flex; flex-direction:column; height:100%; overflow:hidden; }
  .bg-card-cap {
    position:relative; overflow:hidden;
    display:flex; align-items:center; justify-content:center;
    border-bottom:1px solid var(--line-soft);
  }
  .bg-card-cat {
    font-family:'JetBrains Mono',monospace; font-size:10.5px; font-weight:500;
    letter-spacing:0.15em; text-transform:uppercase; color:var(--ink-mute);
  }
  .bg-card-title {
    font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700;
    color:var(--ink); line-height:1.24; letter-spacing:-0.012em;
    transition:color .15s ease;
  }
  .bg-card:hover .bg-card-title { color:var(--blue-deep); }
  .bg-card-desc {
    color:var(--ink-soft); font-size:13.5px; line-height:1.62;
    display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;
  }
  .bg-card-meta {
    font-family:'JetBrains Mono',monospace; font-size:11px;
    color:var(--ink-mute); display:flex; align-items:center; gap:8px; flex-wrap:wrap;
  }
  .bg-card-meta .dot { width:3px; height:3px; border-radius:50%; background:var(--line); }

  /* tinted caption blocks -- soft v7 wash instead of dark gradients */
  .cap-blue   { background:linear-gradient(135deg, rgba(13,125,242,.10), rgba(10,86,176,.07)); }
  .cap-orgy   { background:linear-gradient(135deg, rgba(189,214,34,.20), rgba(163,186,23,.12)); }
  .cap-orange { background:linear-gradient(135deg, rgba(255,122,26,.13), rgba(212,84,10,.08)); }
  .cap-green  { background:linear-gradient(135deg, rgba(10,157,99,.13), rgba(6,114,74,.08)); }
  .cap-grey   { background:linear-gradient(135deg, var(--grey), #e8e9ec); }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16">
    <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-12">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--orgy);"></span>The Knowledge Plane
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.2rem,4.4vw,3.5rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
          Where AI stops working alone and starts <span class="text-[var(--blue)]">learning from every organization</span> that came before it.
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[36rem] mx-auto md:mx-0 mt-5">
          Dispatches from the frontier of organizational intelligence. Notes from inside the build, not from the conference circuit.
        </p>
      </div>
      <div class="relative shrink-0" style="width:212px; max-width:54vw;">
        <div class="bg-glow"></div>
        <img src="/public/orgy-cut.png" alt="Orgy, the OTP mascot"
             class="bg-float relative block w-full" style="z-index:1; filter:drop-shadow(0 22px 32px rgba(20,22,28,.18));">
      </div>
    </div>
  </div>
</section>

<!-- ================= FEATURED POST ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-16 sm:py-20">
    <div class="eyebrow mb-5 flex items-center gap-2.5">
      <span class="tick" style="background:var(--blue);"></span>Featured
    </div>
    <a href="/blog/why-we-built-otp" class="card lift bg-card group block">
      <div class="grid grid-cols-1 sm:grid-cols-[1.05fr_1fr]">
        <div class="bg-card-cap cap-blue min-h-[220px] sm:min-h-0 p-8">
          <div class="text-center transition-transform duration-500 group-hover:-translate-y-1">
            <div class="inline-flex items-center justify-center mx-auto mb-4"
                 style="width:84px; height:84px; border-radius:20px; background:var(--card); border:1px solid var(--line); box-shadow:0 14px 30px -16px rgba(20,22,28,.3);">
              <svg class="w-9 h-9" fill="none" stroke="var(--blue)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <div class="font-mono text-[10.5px] font-medium uppercase tracking-[0.15em]" style="color:var(--blue-deep);">Coordination, not intelligence</div>
          </div>
        </div>
        <div class="p-7 sm:p-10 flex flex-col justify-center">
          <div class="bg-card-cat mb-3" style="color:var(--blue-deep);">Founding Essay</div>
          <h2 class="bg-card-title mb-3" style="font-size:clamp(1.4rem,2.6vw,1.95rem); font-weight:700;">The Hard Problem in AI Is Not Intelligence. It Is Coordination.</h2>
          <p class="bg-card-desc mb-5" style="-webkit-line-clamp:4;">I run 14 AI agents for a digital marketing agency. The hard part was never building one good agent. It was getting all of them to stop stepping on each other. That problem led to OTP.</p>
          <div class="bg-card-meta">
            <span>David Steel</span><span class="dot"></span><span>March 2026</span><span class="dot"></span><span>8 min read</span>
          </div>
        </div>
      </div>
    </a>
  </div>
</section>

<!-- ================= FOUNDER NOTES ================= -->
<% if (typeof founderPosts !== 'undefined' && founderPosts && founderPosts.length > 0) { %>
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-16 sm:py-20">
    <div class="max-w-[640px] mb-10">
      <div class="eyebrow mb-3" style="color:var(--orange-deep);">Founder Notes</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.12]"
          style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
        From the operator who is building this.
      </h2>
      <p class="text-[15px] text-[var(--ink-soft)] leading-[1.65] mt-4">
