<!-- Graph canvas -->
<script>
(function() {
  var canvas = document.getElementById('graph-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var dpr = window.devicePixelRatio || 1;
  var nodes = [], W, H;
  var colors = ['0,149,255','124,58,237','5,150,105','217,119,6','239,68,68','6,182,212','156,163,175','245,158,11'];
  var labels = ['Radar','Dash','Dirk','Pepper','Crystal','Neil','Jeff','Pulse'];
  function resize() { var r = canvas.parentElement.getBoundingClientRect(); W = r.width; H = r.height; canvas.width = W*dpr; canvas.height = H*dpr; canvas.style.width = W+'px'; canvas.style.height = H+'px'; ctx.setTransform(dpr,0,0,dpr,0,0); }
  function init() { nodes = []; var cx = W/2, cy = H/2; for (var i = 0; i < 8; i++) { var a = (i/8)*Math.PI*2-Math.PI/2, r = Math.min(W,H)*0.3; nodes.push({x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,baseAngle:a,r:4+Math.random()*3,color:colors[i],label:labels[i],phase:Math.random()*Math.PI*2}); } }
  resize(); init(); window.addEventListener('resize', function() { resize(); init(); });
  var t = 0;
  function draw() {
    ctx.clearRect(0,0,W,H); t += 0.005;
    var cx = W/2, cy = H/2;
    for (var i = 0; i < nodes.length; i++) { var n = nodes[i], r = Math.min(W,H)*0.3, w = Math.sin(t*2+n.phase)*8; n.x = cx+Math.cos(n.baseAngle+t*0.3)*(r+w); n.y = cy+Math.sin(n.baseAngle+t*0.3)*(r+w); }
    for (var i = 0; i < nodes.length; i++) for (var j = i+1; j < nodes.length; j++) { var p = (Math.sin(t*3+i+j)+1)/2; ctx.beginPath(); ctx.moveTo(nodes[i].x,nodes[i].y); ctx.lineTo(nodes[j].x,nodes[j].y); ctx.strokeStyle='rgba(0,149,255,'+(0.03+p*0.07)+')'; ctx.lineWidth=0.5; ctx.stroke(); }
    for (var i = 0; i < nodes.length; i++) { var n = nodes[i], g = (Math.sin(t*2+n.phase)+1)/2; ctx.beginPath(); ctx.arc(n.x,n.y,n.r*5,0,Math.PI*2); ctx.fillStyle='rgba('+n.color+','+(0.04+g*0.04)+')'; ctx.fill(); ctx.beginPath(); ctx.arc(n.x,n.y,n.r,0,Math.PI*2); ctx.fillStyle='rgba('+n.color+','+(0.5+g*0.3)+')'; ctx.fill(); ctx.font='10px Inter,sans-serif'; ctx.fillStyle='rgba(255,255,255,'+(0.25+g*0.15)+')'; ctx.textAlign='center'; ctx.fillText(n.label,n.x,n.y+n.r+14); }
    var hg = (Math.sin(t)+1)/2;
    ctx.beginPath(); ctx.arc(cx,cy,6,0,Math.PI*2); ctx.fillStyle='rgba(0,149,255,'+(0.3+hg*0.4)+')'; ctx.fill();
    ctx.beginPath(); ctx.arc(cx,cy,20,0,Math.PI*2); ctx.fillStyle='rgba(0,149,255,'+(0.03+hg*0.04)+')'; ctx.fill();
    for (var i = 0; i < nodes.length; i++) { var p = (Math.sin(t*2+i*0.7)+1)/2; ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(nodes[i].x,nodes[i].y); ctx.strokeStyle='rgba(0,149,255,'+(0.05+p*0.1)+')'; ctx.lineWidth=1; ctx.stroke(); }
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

