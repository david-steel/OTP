<section class="relative overflow-hidden bg-otp-950 py-16 sm:py-24">
  <canvas id="graph-canvas" class="absolute inset-0 w-full h-full" style="opacity: 0.5;"></canvas>
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center reveal">
    <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">The Intelligence Graph</h2>
    <p class="text-gray-400 max-w-lg mx-auto mb-8 leading-relaxed">See how coordination patterns connect across organizations. Discover shared operational truths and unique approaches.</p>
    <a href="/graph" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white border border-white/10 rounded-lg font-semibold hover:bg-white/15 transition-all group">Explore the Graph<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></a>
  </div>
</section>
<script>
(function(){var c=document.getElementById('graph-canvas');if(!c)return;var ctx=c.getContext('2d'),dpr=window.devicePixelRatio||1,nodes=[],W,H;var colors=['0,149,255','124,58,237','5,150,105','217,119,6','239,68,68','6,182,212','156,163,175','245,158,11'];var labels=['Radar','Dash','Dirk','Pepper','Crystal','Neil','Jeff','Pulse'];
function resize(){var r=c.parentElement.getBoundingClientRect();W=r.width;H=r.height;c.width=W*dpr;c.height=H*dpr;c.style.width=W+'px';c.style.height=H+'px';ctx.setTransform(dpr,0,0,dpr,0,0);}
function init(){nodes=[];var cx=W/2,cy=H/2;for(var i=0;i<8;i++){var a=(i/8)*Math.PI*2-Math.PI/2,r=Math.min(W,H)*0.3;nodes.push({x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,baseAngle:a,r:4+Math.random()*3,color:colors[i],label:labels[i],phase:Math.random()*6.28});}}
resize();init();window.addEventListener('resize',function(){resize();init();});var t=0;
function draw(){ctx.clearRect(0,0,W,H);t+=.005;var cx=W/2,cy=H/2;for(var i=0;i<nodes.length;i++){var n=nodes[i],r=Math.min(W,H)*.3,w=Math.sin(t*2+n.phase)*8;n.x=cx+Math.cos(n.baseAngle+t*.3)*(r+w);n.y=cy+Math.sin(n.baseAngle+t*.3)*(r+w);}
for(var i=0;i<nodes.length;i++)for(var j=i+1;j<nodes.length;j++){var p=(Math.sin(t*3+i+j)+1)/2;ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle='rgba(0,149,255,'+(0.03+p*.07)+')';ctx.lineWidth=.5;ctx.stroke();}
for(var i=0;i<nodes.length;i++){var n=nodes[i],g=(Math.sin(t*2+n.phase)+1)/2;ctx.beginPath();ctx.arc(n.x,n.y,n.r*5,0,6.28);ctx.fillStyle='rgba('+n.color+','+(0.04+g*.04)+')';ctx.fill();ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,6.28);ctx.fillStyle='rgba('+n.color+','+(0.5+g*.3)+')';ctx.fill();ctx.font='10px Inter,sans-serif';ctx.fillStyle='rgba(255,255,255,'+(0.25+g*.15)+')';ctx.textAlign='center';ctx.fillText(n.label,n.x,n.y+n.r+14);}
var hg=(Math.sin(t)+1)/2;ctx.beginPath();ctx.arc(cx,cy,6,0,6.28);ctx.fillStyle='rgba(0,149,255,'+(0.3+hg*.4)+')';ctx.fill();ctx.beginPath();ctx.arc(cx,cy,20,0,6.28);ctx.fillStyle='rgba(0,149,255,'+(0.03+hg*.04)+')';ctx.fill();
for(var i=0;i<nodes.length;i++){var p=(Math.sin(t*2+i*.7)+1)/2;ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(nodes[i].x,nodes[i].y);ctx.strokeStyle='rgba(0,149,255,'+(0.05+p*.1)+')';ctx.lineWidth=1;ctx.stroke();}requestAnimationFrame(draw);}draw();})();
</script>

