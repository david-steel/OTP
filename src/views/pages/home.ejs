<!-- Hero canvas animation -->
<script>
(function() {
  var canvas = document.getElementById('hero-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var dpr = window.devicePixelRatio || 1;
  var nodes = [];
  var particles = [];
  var mouse = { x: -1000, y: -1000 };
  var W, H;

  function resize() {
    var rect = canvas.parentElement.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function initNodes() {
    nodes = [];
    var count = Math.min(Math.floor(W * H / 18000), 60);
    for (var i = 0; i < count; i++) {
      nodes.push({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 2 + 1.5,
        color: Math.random() > 0.5 ? '0, 149, 255' : '124, 58, 237',
        pulse: Math.random() * Math.PI * 2
      });
    }
  }

  function spawnParticle(x1, y1, x2, y2) {
    if (particles.length > 30) return;
    particles.push({
      x: x1, y: y1, tx: x2, ty: y2,
      progress: 0, speed: 0.008 + Math.random() * 0.012,
      color: '0, 149, 255'
    });
  }

  resize(); initNodes();
  window.addEventListener('resize', function() { resize(); initNodes(); });
  canvas.addEventListener('mousemove', function(e) {
    var rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left; mouse.y = e.clientY - rect.top;
  });
  canvas.addEventListener('mouseleave', function() { mouse.x = -1000; mouse.y = -1000; });

  var spawnTimer = 0;

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Update nodes
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      n.x += n.vx; n.y += n.vy;
      n.pulse += 0.02;
      if (n.x < 0 || n.x > W) n.vx *= -1;
      if (n.y < 0 || n.y > H) n.vy *= -1;

      // Mouse repulsion
      var dx = n.x - mouse.x, dy = n.y - mouse.y;
      var dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 150) {
        var force = (150 - dist) / 150 * 0.5;
        n.vx += (dx / dist) * force * 0.3;
        n.vy += (dy / dist) * force * 0.3;
      }
      // Damping
      n.vx *= 0.998; n.vy *= 0.998;
    }

    // Draw edges
    for (var i = 0; i < nodes.length; i++) {
      for (var j = i + 1; j < nodes.length; j++) {
        var dx = nodes[i].x - nodes[j].x;
        var dy = nodes[i].y - nodes[j].y;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 160) {
          var alpha = (1 - dist / 160) * 0.15;
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.strokeStyle = 'rgba(0, 149, 255, ' + alpha + ')';
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }

    // Draw nodes
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var glow = Math.sin(n.pulse) * 0.3 + 0.7;

      // Outer glow
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r * 4, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + n.color + ', ' + (0.03 * glow) + ')';
      ctx.fill();

      // Core
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r * glow, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + n.color + ', ' + (0.6 * glow) + ')';
      ctx.fill();
    }

    // Spawn data particles periodically
    spawnTimer++;
    if (spawnTimer > 60 && nodes.length > 1) {
      spawnTimer = 0;
      var a = Math.floor(Math.random() * nodes.length);
      var b = Math.floor(Math.random() * nodes.length);
      if (a !== b) {
        var dx = nodes[a].x - nodes[b].x;
        var dy = nodes[a].y - nodes[b].y;
        if (Math.sqrt(dx * dx + dy * dy) < 200) {
          spawnParticle(nodes[a].x, nodes[a].y, nodes[b].x, nodes[b].y);
        }
      }
    }

    // Update & draw particles
    for (var i = particles.length - 1; i >= 0; i--) {
      var p = particles[i];
      p.progress += p.speed;
      if (p.progress >= 1) { particles.splice(i, 1); continue; }

      var px = p.x + (p.tx - p.x) * p.progress;
      var py = p.y + (p.ty - p.y) * p.progress;
      var alpha = Math.sin(p.progress * Math.PI);

      // Trail
      ctx.beginPath();
      ctx.arc(px, py, 2, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(0, 149, 255, ' + (alpha * 0.8) + ')';
      ctx.fill();

      // Glow
      ctx.beginPath();
      ctx.arc(px, py, 6, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(0, 149, 255, ' + (alpha * 0.15) + ')';
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

