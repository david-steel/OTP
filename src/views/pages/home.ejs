<!-- Graph section canvas -->
<script>
(function() {
  var canvas = document.getElementById('graph-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var dpr = window.devicePixelRatio || 1;
  var nodes = [];
  var W, H;
  var colors = ['0, 149, 255', '124, 58, 237', '5, 150, 105', '217, 119, 6'];
  var labels = ['Radar', 'Dash', 'Dirk', 'Pepper', 'Crystal', 'Neil', 'Jeff', 'Pulse'];

  function resize() {
    var rect = canvas.parentElement.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function init() {
    nodes = [];
    var cx = W / 2, cy = H / 2;
    var count = 8;
    for (var i = 0; i < count; i++) {
      var angle = (i / count) * Math.PI * 2 - Math.PI / 2;
      var radius = Math.min(W, H) * 0.3;
      nodes.push({
        x: cx + Math.cos(angle) * radius + (Math.random() - 0.5) * 40,
        y: cy + Math.sin(angle) * radius + (Math.random() - 0.5) * 40,
        baseAngle: angle,
        r: 4 + Math.random() * 3,
        color: colors[i % colors.length],
        label: labels[i],
        phase: Math.random() * Math.PI * 2
      });
    }
  }

  resize(); init();
  window.addEventListener('resize', function() { resize(); init(); });

  var t = 0;
  function draw() {
    ctx.clearRect(0, 0, W, H);
    t += 0.005;
    var cx = W / 2, cy = H / 2;

    // Orbit nodes slowly
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var radius = Math.min(W, H) * 0.3;
      var wobble = Math.sin(t * 2 + n.phase) * 8;
      n.x = cx + Math.cos(n.baseAngle + t * 0.3) * (radius + wobble);
      n.y = cy + Math.sin(n.baseAngle + t * 0.3) * (radius + wobble);
    }

    // Draw edges with animated opacity
    for (var i = 0; i < nodes.length; i++) {
      for (var j = i + 1; j < nodes.length; j++) {
        var pulse = (Math.sin(t * 3 + i + j) + 1) / 2;
        var alpha = 0.03 + pulse * 0.07;
        ctx.beginPath();
        ctx.moveTo(nodes[i].x, nodes[i].y);
        ctx.lineTo(nodes[j].x, nodes[j].y);
        ctx.strokeStyle = 'rgba(0, 149, 255, ' + alpha + ')';
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }

    // Draw nodes
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var glow = (Math.sin(t * 2 + n.phase) + 1) / 2;

      // Outer glow
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r * 5, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + n.color + ', ' + (0.04 + glow * 0.04) + ')';
      ctx.fill();

      // Core
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + n.color + ', ' + (0.5 + glow * 0.3) + ')';
      ctx.fill();

      // Label
      ctx.font = '10px Inter, sans-serif';
      ctx.fillStyle = 'rgba(255, 255, 255, ' + (0.25 + glow * 0.15) + ')';
      ctx.textAlign = 'center';
      ctx.fillText(n.label, n.x, n.y + n.r + 14);
    }

    // Center hub
    var hubGlow = (Math.sin(t) + 1) / 2;
    ctx.beginPath();
    ctx.arc(cx, cy, 6, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(0, 149, 255, ' + (0.3 + hubGlow * 0.4) + ')';
    ctx.fill();
    ctx.beginPath();
    ctx.arc(cx, cy, 20, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(0, 149, 255, ' + (0.03 + hubGlow * 0.04) + ')';
    ctx.fill();

    // Hub connections
    for (var i = 0; i < nodes.length; i++) {
      var pulse = (Math.sin(t * 2 + i * 0.7) + 1) / 2;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(nodes[i].x, nodes[i].y);
      ctx.strokeStyle = 'rgba(0, 149, 255, ' + (0.05 + pulse * 0.1) + ')';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

