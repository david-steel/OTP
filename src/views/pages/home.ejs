              </div>
              <div id="agent-list" class="p-2.5 space-y-1.5"></div>
            </div>
          </div>

          <!-- Layer 3: Quality + claims card (front-bottom) -->
          <div id="hero-l3" class="hero-layer absolute bottom-[10px] right-[30px]" data-depth="0.12" style="opacity: 0; transform: translateY(30px) scale(0.95);">
            <div class="bg-white/95 rounded-xl shadow-2xl shadow-black/25 border border-gray-200/50 overflow-hidden" style="backdrop-filter: blur(8px);">
              <div class="px-4 py-3 flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-amber-300 via-amber-400 to-amber-600 flex items-center justify-center shadow-lg shadow-amber-500/30">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                </div>
                <div>
                  <div class="text-[10px] text-gray-400 font-medium">Sneeze It Digital Agency</div>
                  <div class="text-sm font-bold text-gray-900">Platinum Publisher</div>
                  <div class="flex gap-0.5 mt-1"><div class="w-7 h-1 rounded-full bg-amber-400"></div><div class="w-7 h-1 rounded-full bg-amber-400"></div><div class="w-7 h-1 rounded-full bg-amber-400"></div><div class="w-7 h-1 rounded-full bg-amber-400"></div></div>
                </div>
                <div class="ml-auto text-right">
                  <div id="claim-counter" class="text-2xl font-extrabold text-otp-600">0</div>
                  <div class="text-[9px] text-gray-400">claims</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Layer 4: Floating connection particles canvas -->
          <canvas id="hero-connections" class="absolute inset-0 w-full h-full pointer-events-none" style="z-index: 5;"></canvas>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Hero interaction engine -->
<script>
(function() {
  var scene = document.getElementById('hero-scene');
  if (!scene) return;
  var layers = scene.querySelectorAll('.hero-layer');
  var mx = 0.5, my = 0.5;

  // Mouse parallax
  scene.parentElement.addEventListener('mousemove', function(e) {
    var r = scene.getBoundingClientRect();
    mx = (e.clientX - r.left) / r.width;
    my = (e.clientY - r.top) / r.height;
  });
  scene.parentElement.addEventListener('mouseleave', function() { mx = 0.5; my = 0.5; });

  var cx = 0.5, cy = 0.5;
  function updateParallax() {
    cx += (mx - cx) * 0.06;
    cy += (my - cy) * 0.06;
    var dx = (cx - 0.5) * 2;
    var dy = (cy - 0.5) * 2;
    for (var i = 0; i < layers.length; i++) {
      var d = parseFloat(layers[i].getAttribute('data-depth')) || 0.05;
      var tx = dx * d * 300;
      var ty = dy * d * 200;
      var rY = dx * d * 8;
      var rX = -dy * d * 5;
      layers[i].style.transform = 'translate3d(' + tx + 'px,' + ty + 'px,0) rotateY(' + rY + 'deg) rotateX(' + rX + 'deg)';
    }
    requestAnimationFrame(updateParallax);
  }
  updateParallax();

  // Staggered entrance
  var entrances = [
    { el: document.getElementById('hero-l0'), delay: 200, y: 0, x: 0, s: 1 },
    { el: document.getElementById('hero-l1'), delay: 400, y: 40, x: -30, s: 1 },
    { el: document.getElementById('hero-l2'), delay: 700, y: 30, x: 30, s: 1 },
    { el: document.getElementById('hero-l3'), delay: 1000, y: 30, x: 0, s: 0.95 },
  ];
  entrances.forEach(function(e) {
    if (!e.el) return;
    setTimeout(function() {
      e.el.style.transition = 'opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1)';
      e.el.style.opacity = '1';
    }, e.delay);
  });

  // Terminal typing animation
  var codeLines = [
    '<span class="text-gray-600">---</span>',
    '<span class="text-purple-400">oos_version</span><span class="text-gray-600">:</span> <span class="text-green-400">"1.0"</span>',
    '<span class="text-purple-400">org_pseudonym</span><span class="text-gray-600">:</span> <span class="text-green-400">"Sneeze It"</span>',
    '<span class="text-purple-400">template</span><span class="text-gray-600">:</span> <span class="text-green-400">"agent_army"</span>',
    '<span class="text-purple-400">agent_count</span><span class="text-gray-600">:</span> <span class="text-amber-300">12</span>',
    '<span class="text-gray-600">---</span>',
    '',
    '<span class="text-otp-400 font-bold">[C001]</span> <span class="text-gray-500">core_operating_rules</span>',
    '<span class="text-gray-300">Rule: Every agent writes to a</span>',
    '<span class="text-gray-300">shared state file.</span>',
    '<span class="text-green-400">Confidence</span><span class="text-gray-600">:</span> <span class="text-green-300">HIGH</span>',
    '<span class="text-purple-400">Evidence</span><span class="text-gray-600">:</span> <span class="text-purple-300">MEASURED_RESULT</span>',
    '',
    '<span class="text-otp-400 font-bold">[C002]</span> <span class="text-gray-500">coordination</span>',
    '<span class="text-gray-300">Rule: No agent reads another</span>',
    '<span class="text-gray-300">agent\'s state file directly.</span>',
  ];
  var terminal = document.getElementById('terminal-code');
  if (terminal) {
    var lineIdx = 0;
    function typeLine() {
      if (lineIdx >= codeLines.length) {
        terminal.innerHTML += '<span class="text-otp-400 animate-pulse">|</span>';
        return;
      }
      var div = document.createElement('div');
      div.style.opacity = '0';
      div.style.transform = 'translateX(-5px)';
      div.innerHTML = codeLines[lineIdx] || '&nbsp;';
      terminal.appendChild(div);
      setTimeout(function() {
        div.style.transition = 'all 0.3s ease-out';
        div.style.opacity = '1';
        div.style.transform = 'translateX(0)';
      }, 30);
      lineIdx++;
      setTimeout(typeLine, 120 + Math.random() * 80);
    }
    setTimeout(typeLine, 800);
  }

  // Agent list population
  var agents = [
    { name: 'Radar', role: 'Chief of Staff', color: 'from-green-400 to-green-600', shadow: 'shadow-green-500/30' },
    { name: 'Dash', role: 'Performance Analyst', color: 'from-cyan-400 to-cyan-600', shadow: 'shadow-cyan-500/30' },
    { name: 'Dirk', role: 'Revenue Operator', color: 'from-amber-400 to-amber-600', shadow: 'shadow-amber-500/30' },
    { name: 'Dan', role: 'Strategic Co-Founder', color: 'from-purple-400 to-purple-600', shadow: 'shadow-purple-500/30' },
    { name: 'Pepper', role: 'Executive Assistant', color: 'from-red-400 to-red-600', shadow: 'shadow-red-500/30' },
    { name: 'Jeff', role: 'Chief Info Officer', color: 'from-indigo-400 to-indigo-600', shadow: 'shadow-indigo-500/30' },
  ];
  var agentList = document.getElementById('agent-list');
  if (agentList) {
    agents.forEach(function(a, i) {
      setTimeout(function() {
        var row = document.createElement('div');
        row.className = 'flex items-center gap-2 py-0.5';
        row.style.opacity = '0';
        row.style.transform = 'translateX(10px)';
        row.innerHTML = '<div class="w-5 h-5 rounded-md bg-gradient-to-br ' + a.color + ' flex items-center justify-center shadow ' + a.shadow + '"><svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></div><div class="flex-1"><div class="text-[10px] font-semibold text-gray-800">' + a.name + '</div><div class="text-[8px] text-gray-400">' + a.role + '</div></div><div class="w-1.5 h-1.5 bg-green-400 rounded-full"></div>';
        agentList.appendChild(row);
        setTimeout(function() {
          row.style.transition = 'all 0.4s cubic-bezier(0.16,1,0.3,1)';
          row.style.opacity = '1';
          row.style.transform = 'translateX(0)';
        }, 50);
      }, 900 + i * 200);
    });
  }

  // Claim counter
  var claimEl = document.getElementById('claim-counter');
  if (claimEl) {
    setTimeout(function() {
      var start = performance.now();
      function tick(now) {
        var p = Math.min((now - start) / 2000, 1);
        var eased = 1 - Math.pow(1 - p, 4);
        claimEl.textContent = Math.round(24 * eased);
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }, 1200);
  }

  // Connection particles canvas
  var cc = document.getElementById('hero-connections');
  if (cc) {
    var ctx = cc.getContext('2d'), dpr = window.devicePixelRatio || 1;
    var W, H, particles = [];
    function resizeCC() {
      var r = cc.parentElement.getBoundingClientRect();
      W = r.width; H = r.height;
      cc.width = W * dpr; cc.height = H * dpr;
      cc.style.width = W + 'px'; cc.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resizeCC();
    window.addEventListener('resize', resizeCC);

    // Connection paths (terminal -> agent card, terminal -> quality card)
    var paths = [
      { x1: 370, y1: 100, x2: 430, y2: 60, color: '0,149,255' },
      { x1: 370, y1: 180, x2: 430, y2: 120, color: '124,58,237' },
      { x1: 350, y1: 280, x2: 420, y2: 360, color: '217,119,6' },
      { x1: 200, y1: 50, x2: 380, y2: 80, color: '0,149,255' },
      { x1: 100, y1: 350, x2: 350, y2: 300, color: '124,58,237' },
    ];

    function spawnParticle() {
      var path = paths[Math.floor(Math.random() * paths.length)];
      particles.push({
        x: path.x1, y: path.y1,
        tx: path.x2, ty: path.y2,
        p: 0, s: 0.005 + Math.random() * 0.008,
        color: path.color,
        size: 1.5 + Math.random() * 1.5,
        trail: []
      });
    }

    var t = 0;
    function drawCC() {
      ctx.clearRect(0, 0, W, H);
      t++;
      if (t % 25 === 0 && particles.length < 12) spawnParticle();

      for (var i = particles.length - 1; i >= 0; i--) {
        var p = particles[i];
        p.p += p.s;
        if (p.p >= 1) { particles.splice(i, 1); continue; }

        var px = p.x + (p.tx - p.x) * p.p;
        var py = p.y + (p.ty - p.y) * p.p;
        p.trail.push({ x: px, y: py });
        if (p.trail.length > 12) p.trail.shift();

        // Draw trail
        for (var j = 0; j < p.trail.length; j++) {
          var ta = (j / p.trail.length) * Math.sin(p.p * Math.PI);
          ctx.beginPath();
          ctx.arc(p.trail[j].x, p.trail[j].y, p.size * (j / p.trail.length), 0, 6.28);
          ctx.fillStyle = 'rgba(' + p.color + ',' + (ta * 0.5) + ')';
          ctx.fill();
        }

        // Head glow
        var alpha = Math.sin(p.p * Math.PI);
        ctx.beginPath();
        ctx.arc(px, py, p.size * 3, 0, 6.28);
        ctx.fillStyle = 'rgba(' + p.color + ',' + (alpha * 0.15) + ')';
        ctx.fill();
        ctx.beginPath();
        ctx.arc(px, py, p.size, 0, 6.28);
        ctx.fillStyle = 'rgba(' + p.color + ',' + (alpha * 0.9) + ')';
        ctx.fill();
      }
      requestAnimationFrame(drawCC);
    }
    drawCC();
  }
})();
</script>

<!-- Stats -->
<section class="relative bg-otp-900 border-y border-white/5">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="grid grid-cols-3 gap-4 sm:gap-8">
      <div class="text-center reveal"><div class="text-2xl sm:text-4xl font-extrabold text-white counter" data-target="<%= typeof publisherCount !== 'undefined' ? publisherCount : '0' %>">0</div><div class="text-xs sm:text-sm text-gray-500 mt-1 font-medium">Publishers</div></div>
      <div class="text-center reveal delay-100"><div class="text-2xl sm:text-4xl font-extrabold text-white counter" data-target="<%= typeof claimCount !== 'undefined' ? claimCount : '0' %>">0</div><div class="text-xs sm:text-sm text-gray-500 mt-1 font-medium">Knowledge Claims</div></div>
      <div class="text-center reveal delay-200"><div class="text-2xl sm:text-4xl font-extrabold text-white counter" data-target="<%= typeof templateCount !== 'undefined' ? templateCount : '3' %>">0</div><div class="text-xs sm:text-sm text-gray-500 mt-1 font-medium">Templates</div></div>
    </div>
  </div>
</section>
<script>(function(){var c=false;var o=new IntersectionObserver(function(e){if(e[0].isIntersecting&&!c){c=true;document.querySelectorAll('.counter').forEach(function(el){var t=parseInt(el.getAttribute('data-target'))||0,s=performance.now();function tick(n){var p=Math.min((n-s)/1200,1);el.textContent=Math.round(t*(1-Math.pow(1-p,3)));if(p<1)requestAnimationFrame(tick);}requestAnimationFrame(tick);});}},{threshold:0.3});var e=document.querySelector('.counter');if(e)o.observe(e.parentElement.parentElement.parentElement);})();</script>

<!-- How it works -->
<section class="bg-gray-50 py-16 sm:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12 sm:mb-16 reveal">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-4">How It Works</h2>
      <p class="text-gray-500 max-w-lg mx-auto">Three steps from tribal knowledge to shared coordination intelligence.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8">
      <!-- Publish -->
      <div class="reveal bg-white rounded-2xl overflow-hidden border border-gray-100 card-hover group">
        <div class="h-48 bg-gradient-to-br from-otp-400 via-otp-500 to-otp-700 relative overflow-hidden flex items-center justify-center p-6">
          <div class="absolute inset-0 bg-grid opacity-10"></div>
          <div class="absolute top-[-30px] right-[-30px] w-40 h-40 border-2 border-white/10 rotate-45 rounded-xl"></div>
          <div class="absolute bottom-[-40px] left-[-20px] w-32 h-32 bg-white/5 rounded-full"></div>
          <div class="absolute top-3 left-4 w-2.5 h-2.5 bg-white/25 rounded-full"></div>
          <div class="absolute bottom-5 right-5 w-2 h-2 bg-white/30 rotate-45"></div>
          <div class="absolute top-8 right-12 w-1.5 h-1.5 border border-white/30 rotate-45"></div>
          <!-- Publish scene: browser window with OOS editor -->
          <div class="relative group-hover:-translate-y-1 transition-transform duration-500">
            <div class="w-[160px] bg-white rounded-lg shadow-2xl shadow-black/20 overflow-hidden">
              <div class="flex items-center gap-1 px-2 py-1.5 bg-gray-50 border-b border-gray-100"><div class="w-1.5 h-1.5 rounded-full bg-red-400"></div><div class="w-1.5 h-1.5 rounded-full bg-amber-400"></div><div class="w-1.5 h-1.5 rounded-full bg-green-400"></div><div class="text-[7px] text-gray-400 ml-1.5">Publish OOS</div></div>
              <div class="p-2 space-y-1">
                <div class="h-1 bg-gray-200 rounded-full w-3/4"></div>
