<!-- Hero canvas -->
<script>
(function() {
  var c = document.getElementById('hero-canvas'); if (!c) return;
  var ctx = c.getContext('2d'), dpr = window.devicePixelRatio||1, nodes=[], particles=[], mouse={x:-1e3,y:-1e3}, W, H;
  function resize() { var r=c.parentElement.getBoundingClientRect(); W=r.width; H=r.height; c.width=W*dpr; c.height=H*dpr; c.style.width=W+'px'; c.style.height=H+'px'; ctx.setTransform(dpr,0,0,dpr,0,0); }
  function init() { nodes=[]; var n=Math.min(Math.floor(W*H/25000),45); for(var i=0;i<n;i++) nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.25,vy:(Math.random()-.5)*.25,r:Math.random()*1.5+.8,c:Math.random()>.5?'0,149,255':'124,58,237',p:Math.random()*6.28}); }
  resize(); init();
  window.addEventListener('resize',function(){resize();init();});
  c.addEventListener('mousemove',function(e){var r=c.getBoundingClientRect();mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;});
  c.addEventListener('mouseleave',function(){mouse.x=-1e3;mouse.y=-1e3;});
  var st=0;
  function draw() {
    ctx.clearRect(0,0,W,H);
    for(var i=0;i<nodes.length;i++){var n=nodes[i];n.x+=n.vx;n.y+=n.vy;n.p+=.015;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1;var dx=n.x-mouse.x,dy=n.y-mouse.y,d=Math.sqrt(dx*dx+dy*dy);if(d<100){n.vx+=(dx/d)*.08;n.vy+=(dy/d)*.08;}n.vx*=.999;n.vy*=.999;}
    for(var i=0;i<nodes.length;i++)for(var j=i+1;j<nodes.length;j++){var dx=nodes[i].x-nodes[j].x,dy=nodes[i].y-nodes[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<130){ctx.beginPath();ctx.moveTo(nodes[i].x,nodes[i].y);ctx.lineTo(nodes[j].x,nodes[j].y);ctx.strokeStyle='rgba(0,149,255,'+(1-d/130)*.1+')';ctx.lineWidth=.5;ctx.stroke();}}
    for(var i=0;i<nodes.length;i++){var n=nodes[i],g=Math.sin(n.p)*.3+.7;ctx.beginPath();ctx.arc(n.x,n.y,n.r*g,0,6.28);ctx.fillStyle='rgba('+n.c+','+(0.4*g)+')';ctx.fill();}
    st++;if(st>60&&nodes.length>1){st=0;var a=0|Math.random()*nodes.length,b=0|Math.random()*nodes.length;if(a!==b){var dx=nodes[a].x-nodes[b].x,dy=nodes[a].y-nodes[b].y;if(Math.sqrt(dx*dx+dy*dy)<160&&particles.length<20)particles.push({x:nodes[a].x,y:nodes[a].y,tx:nodes[b].x,ty:nodes[b].y,p:0,s:.01+Math.random()*.01});}}
    for(var i=particles.length-1;i>=0;i--){var p=particles[i];p.p+=p.s;if(p.p>=1){particles.splice(i,1);continue;}var px=p.x+(p.tx-p.x)*p.p,py=p.y+(p.ty-p.y)*p.p,a=Math.sin(p.p*3.14);ctx.beginPath();ctx.arc(px,py,1.5,0,6.28);ctx.fillStyle='rgba(0,149,255,'+a*.6+')';ctx.fill();}
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

<!-- Stats -->
<section class="relative bg-otp-900 border-y border-white/5">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="grid grid-cols-3 gap-4 sm:gap-8">
      <div class="text-center reveal"><div class="text-2xl sm:text-4xl font-extrabold text-white counter" data-target="<%= typeof publisherCount !== 'undefined' ? publisherCount : '0' %>">0</div><div class="text-xs sm:text-sm text-gray-500 mt-1 font-medium">Publishers</div></div>
      <div class="text-center reveal delay-100"><div class="text-2xl sm:text-4xl font-extrabold text-white counter" data-target="<%= typeof claimCount !== 'undefined' ? claimCount : '0' %>">0</div><div class="text-xs sm:text-sm text-gray-500 mt-1 font-medium">Knowledge Claims</div></div>
      <div class="text-center reveal delay-200"><div class="text-2xl sm:text-4xl font-extrabold text-white counter" data-target="<%= typeof templateCount !== 'undefined' ? templateCount : '3' %>">0</div><div class="text-xs sm:text-sm text-gray-500 mt-1 font-medium">Templates</div></div>
    </div>
  </div>
</section>
<script>(function(){var c=false;var o=new IntersectionObserver(function(e){if(e[0].isIntersecting&&!c){c=true;document.querySelectorAll('.counter').forEach(function(el){var t=parseInt(el.getAttribute('data-target'))||0,s=performance.now();function tick(n){var p=Math.min((n-s)/1200,1);el.textContent=Math.round(t*(1-Math.pow(1-p,3)));if(p<1)requestAnimationFrame(tick);}requestAnimationFrame(tick);});}},{threshold:0.3});var e=document.querySelector('.counter');if(e)o.observe(e.parentElement.parentElement.parentElement);})();</script>

<!-- How it works -->
