<!-- Hero -->
<section class="relative overflow-hidden bg-otp-950">
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" style="opacity: 0.4;"></canvas>
  <div class="absolute top-[-200px] left-[-100px] w-[600px] h-[600px] bg-otp-500/15 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute bottom-[-100px] right-[-150px] w-[500px] h-[500px] bg-purple-500/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-20 sm:pt-28 pb-16 sm:pb-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-8 items-center">
      <!-- Left: text (5 cols) -->
      <div class="lg:col-span-5">
        <div class="animate-fade-in-up">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs text-otp-300 mb-6">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
            <span><%= typeof publisherCount !== 'undefined' ? publisherCount : '0' %> publishers live</span>
          </div>
        </div>
        <h1 class="text-3xl sm:text-[2.75rem] lg:text-5xl font-extrabold text-white leading-[1.15] mb-6 animate-fade-in-up delay-100">
          Where Agents Learn to
          <span class="gradient-text">Work as a Team</span>
        </h1>
        <p class="text-base sm:text-lg text-gray-400 mb-8 animate-fade-in-up delay-200 leading-relaxed max-w-md">
          The hard problem in AI isn't building one good agent.
          It's getting twelve of them to not step on each other.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 animate-fade-in-up delay-300">
          <a href="/browse" class="px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-all hover:shadow-lg hover:shadow-otp-500/25 text-center">Browse Intelligence</a>
          <a href="/publish" class="px-6 py-3 bg-white/5 text-white border border-white/10 rounded-lg font-semibold hover:bg-white/10 transition-all text-center">Publish Your OOS</a>
        </div>
      </div>

      <!-- Right: Interactive 3D parallax illustration (7 cols) -->
      <div class="hidden lg:block lg:col-span-7">
        <div id="hero-scene" class="relative ml-8" style="perspective: 1000px; height: 440px;">

          <!-- Layer 0: Background grid (deepest) -->
          <svg id="hero-l0" class="absolute inset-0 w-full h-full hero-layer" data-depth="0.02" viewBox="0 0 560 440" fill="none">
            <line x1="0" y1="70" x2="560" y2="70" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="0" y1="140" x2="560" y2="140" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="0" y1="210" x2="560" y2="210" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="0" y1="280" x2="560" y2="280" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="0" y1="350" x2="560" y2="350" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="70" y1="0" x2="70" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="140" y1="0" x2="140" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="210" y1="0" x2="210" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="280" y1="0" x2="280" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="350" y1="0" x2="350" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="420" y1="0" x2="420" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <line x1="490" y1="0" x2="490" y2="440" stroke="white" stroke-width="0.5" stroke-dasharray="4 8" opacity="0.12"/>
            <rect x="138" y="68" width="5" height="5" fill="#7c3aed" opacity="0.5" transform="rotate(45 140 70)"/>
            <rect x="348" y="138" width="5" height="5" fill="#0095ff" opacity="0.5" transform="rotate(45 350 140)"/>
            <rect x="488" y="278" width="5" height="5" fill="#059669" opacity="0.35" transform="rotate(45 490 280)"/>
            <circle cx="210" cy="350" r="2.5" fill="#d97706" opacity="0.4"/>
            <rect x="68" y="278" width="4" height="4" stroke="#0095ff" stroke-width="1" fill="none" opacity="0.3" transform="rotate(45 70 280)"/>
            <circle cx="420" cy="70" r="2" fill="#7c3aed" opacity="0.35"/>
            <circle cx="140" cy="210" r="1.5" fill="#059669" opacity="0.3"/>
            <rect x="418" y="348" width="4" height="4" stroke="#d97706" stroke-width="1" fill="none" opacity="0.3" transform="rotate(45 420 350)"/>
          </svg>

          <!-- Layer 1: Terminal window (mid) -->
          <div id="hero-l1" class="hero-layer absolute top-[40px] left-0" data-depth="0.05" style="opacity: 0; transform: translateY(40px) translateX(-30px);">
            <div class="bg-otp-900/95 rounded-2xl border border-white/10 shadow-2xl shadow-black/50 overflow-hidden w-[370px]" style="backdrop-filter: blur(8px);">
              <div class="flex items-center gap-2 px-4 py-2.5 bg-black/20 border-b border-white/5">
                <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-red-500/70"></div><div class="w-3 h-3 rounded-full bg-amber-500/70"></div><div class="w-3 h-3 rounded-full bg-green-500/70"></div></div>
                <div class="text-[10px] text-gray-500 font-mono ml-3 flex-1">sneeze-it.oos.md</div>
                <div class="text-[9px] text-gray-600 font-mono">24 claims</div>
              </div>
              <div id="terminal-code" class="p-4 font-mono text-[11px] leading-[1.7] h-[240px] overflow-hidden"></div>
            </div>
          </div>

          <!-- Layer 2: Agent dashboard (front-right) -->
          <div id="hero-l2" class="hero-layer absolute top-[10px] right-[-10px]" data-depth="0.09" style="opacity: 0; transform: translateY(30px) translateX(30px);">
            <div class="w-[215px] bg-white/95 rounded-xl shadow-2xl shadow-black/25 border border-gray-200/50 overflow-hidden" style="backdrop-filter: blur(8px);">
