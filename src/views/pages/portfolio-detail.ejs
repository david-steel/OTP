<%- include('../partials/orgy-palette'); %>
<%
  // ---- Portfolio detail ----
  // Locals:
  //   authState: 'authenticated' | 'not_found' | 'feature_off'
  //   portfolio: organizations row
  //   memberOrgs: [{ id, name }]
  //   superMetrics: [{ ...kpi, sources: [{ memberOrgId, memberKpiId, weight }] }]
  //   latestByKpi: { [kpiId]: number | null }
  //   memberNameById: { [orgId]: name }
  // Plain JS line comments only -- never an EJS close-delimiter in a comment.
  var _auth = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _portfolio = (typeof portfolio !== 'undefined' && portfolio) ? portfolio : null;
  var _members = (typeof memberOrgs !== 'undefined' && Array.isArray(memberOrgs)) ? memberOrgs : [];
  var _metrics = (typeof superMetrics !== 'undefined' && Array.isArray(superMetrics)) ? superMetrics : [];
  var _latest = (typeof latestByKpi !== 'undefined' && latestByKpi) ? latestByKpi : {};
  var _nameById = (typeof memberNameById !== 'undefined' && memberNameById) ? memberNameById : {};
  function _opLabel(op) {
    if (op === 'gte') return '≥'; if (op === 'lte') return '≤';
    if (op === 'gt') return '>'; if (op === 'lt') return '<';
    if (op === 'eq') return '='; return '';
  }
  function _fmt(v) {
    if (v === null || typeof v === 'undefined') return '—';
    return (Math.round(v * 100) / 100).toLocaleString();
  }
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <% if (_auth === 'not_found') { %>
    <div class="bg-white border rounded-xl p-10 text-center">
      <h1 class="text-xl font-extrabold text-gray-900 mb-2">Portfolio not found</h1>
      <p class="text-sm text-gray-600 mb-5">This portfolio does not exist, or you do not have access to it.</p>
      <a href="/portfolio" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Back to portfolios</a>
    </div>

  <% } else if (_auth === 'feature_off') { %>
    <div class="bg-white border rounded-xl p-10 text-center">
      <h1 class="text-xl font-extrabold text-gray-900 mb-2">Portfolios are in Labs</h1>
      <p class="text-sm text-gray-600 mb-5">Turn the Portfolio feature on in Labs to view this portfolio.</p>
      <a href="/settings/labs" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Enable in Labs</a>
    </div>

  <% } else { %>

    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <div class="min-w-0">
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">
          <a href="/portfolio" class="hover:underline">Portfolios</a>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= _portfolio ? _portfolio.name : 'Portfolio' %></h1>
      </div>
      <div class="shrink-0 flex items-center gap-2">
        <button type="button" id="recompute-btn"
                class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium transition-colors">
          Recompute
        </button>
        <button type="button" id="start-meeting-btn"
                class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">
          Start portfolio meeting
        </button>
      </div>
    </div>

    <!-- ===== Member organizations ===== -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Member organizations</h2>
        <button type="button" id="add-member-btn"
                class="text-sm font-semibold text-otp-600 hover:underline">Add member org</button>
      </div>

      <!-- Add-member affordance (POSTs to the link API; wired by a later task) -->
      <div id="add-member-form" class="bg-white border rounded-xl p-5 mb-4" style="display:none;">
        <label for="add-member-org-id" class="block text-sm font-semibold text-gray-900 mb-2">Member organization ID</label>
        <div class="flex flex-wrap gap-2 items-center">
          <input type="text" id="add-member-org-id" placeholder="Organization UUID"
                 class="flex-1 min-w-[18rem] px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500/40">
          <button type="button" id="add-member-submit"
                  class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Add</button>
          <button type="button" id="add-member-cancel"
                  class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium transition-colors">Cancel</button>
        </div>
        <p id="add-member-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
        <p class="text-xs text-gray-500 mt-3 border-t pt-3">
          <span class="font-semibold text-gray-700">Where do I find an organization's ID?</span>
          Each organization's owner or admin can find it in
          <span class="font-medium text-gray-700">Settings → Company</span>, under
          <span class="font-mono text-gray-700">Company ID</span> — they copy it there and send it to you.
          Already-linked orgs below show their ID; click it to copy.
        </p>
      </div>

      <% if (_members.length === 0) { %>
        <div class="bg-white border rounded-xl p-8 text-center">
          <p class="text-sm text-gray-600">No member organizations linked yet. Add one to start rolling KPIs up.</p>
        </div>
      <% } else { %>
        <div class="bg-white border rounded-xl overflow-hidden">
          <% _members.forEach(function(m) { %>
            <div class="flex items-center justify-between gap-4 px-5 py-4 border-b last:border-b-0">
              <div class="font-medium text-gray-900 truncate"><%= m.name %></div>
              <button type="button" class="member-id-copy text-xs text-gray-400 hover:text-otp-600 font-mono truncate transition-colors"
                      data-org-id="<%= m.id %>" title="Click to copy organization ID"><%= m.id %></button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- ===== Portfolio team ===== -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Portfolio team</h2>
        <span class="text-xs text-gray-500">People from member orgs who attend portfolio meetings</span>
      </div>
      <div class="bg-white border rounded-xl p-5">
        <div id="team-list" class="space-y-2 mb-4">
          <p class="text-sm text-gray-500">Loading team…</p>
        </div>
        <div class="border-t pt-4">
          <label for="team-add-select" class="block text-sm font-semibold text-gray-900 mb-2">Add from member organizations</label>
          <div class="flex flex-wrap gap-2 items-center">
            <select id="team-add-select"
                    class="flex-1 min-w-[18rem] px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500/40">
              <option value="">Select a person…</option>
            </select>
            <button type="button" id="team-add-btn"
                    class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Add to team</button>
          </div>
          <p id="team-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
          <p class="text-xs text-gray-400 mt-2">Only people who belong to a member organization can be added.</p>
        </div>
      </div>
    </section>

    <!-- ===== Super-metrics ===== -->
    <section>
      <h2 class="text-lg font-bold text-gray-900 mb-3">Super-metrics</h2>

      <% if (_metrics.length === 0) { %>
        <div class="bg-white border rounded-xl p-8 text-center">
          <p class="text-sm text-gray-600">No super-metrics yet. A super-metric rolls one KPI per member org up into a single number.</p>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% _metrics.forEach(function(sm) {
            var latest = _latest[sm.id];
            var goalText = (sm.goalValue !== null && typeof sm.goalValue !== 'undefined')
              ? (_opLabel(sm.goalOperator) + ' ' + _fmt(sm.goalValue)).trim()
              : null;
          %>
            <div class="bg-white border rounded-xl p-6">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <h3 class="font-bold text-gray-900 text-base"><%= sm.title %></h3>
                  <div class="text-xs text-gray-500 mt-0.5 flex flex-wrap gap-x-3 gap-y-0.5">
                    <% if (sm.unit) { %><span>Unit: <%= sm.unit %></span><% } %>
                    <% if (goalText) { %><span>Goal: <%= goalText %></span><% } %>
                    <% if (sm.timeGrain) { %><span><%= sm.timeGrain %></span><% } %>
                  </div>
                </div>
                <div class="shrink-0 text-right">
                  <div class="text-2xl font-extrabold text-gray-900"><%= _fmt(latest) %></div>
                  <div class="text-[11px] uppercase tracking-wide text-gray-400">latest</div>
                </div>
              </div>

              <% if (sm.sources && sm.sources.length > 0) { %>
                <div class="mt-4 border-t pt-3">
                  <div class="text-[11px] uppercase tracking-wide text-gray-500 font-semibold mb-2">Contributing orgs</div>
                  <div class="space-y-1.5">
                    <% sm.sources.forEach(function(s) { %>
                      <div class="flex items-center justify-between gap-3 text-sm">
                        <span class="text-gray-700 truncate"><%= _nameById[s.memberOrgId] || s.memberOrgId %></span>
                        <span class="text-xs text-gray-500 shrink-0">weight <%= _fmt(s.weight) %></span>
                      </div>
                    <% }); %>
                  </div>
                </div>
              <% } else { %>
                <p class="mt-3 text-xs text-gray-400">No source KPIs mapped yet.</p>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- ===== Presets (inherited by member orgs) ===== -->
    <section class="mt-8">
      <h2 class="text-lg font-bold text-gray-900 mb-3">Presets (inherited by member orgs)</h2>
      <div class="bg-white border rounded-xl p-6">
        <p class="text-sm text-gray-600 mb-4">
          Standardize the sidebar across member organizations. Lock it to prevent members from overriding.
        </p>

        <label class="flex items-start gap-2 text-sm text-gray-700">
          <input type="checkbox" id="presets-inherit-sidebar"
                 class="mt-0.5 h-4 w-4 rounded border-gray-300 text-otp-500 focus:ring-otp-500/40">
          <span>
            <span class="font-semibold text-gray-900">Member organizations inherit the portfolio sidebar</span><br>
            <span class="text-xs text-gray-500">Member orgs use this portfolio's standardized sidebar instead of their own.</span>
          </span>
        </label>

        <label class="flex items-start gap-2 mt-3 text-sm text-gray-700">
          <input type="checkbox" id="presets-lock-sidebar"
                 class="mt-0.5 h-4 w-4 rounded border-gray-300 text-otp-500 focus:ring-otp-500/40">
          <span>
            <span class="font-semibold text-gray-900">Lock it</span><br>
            <span class="text-xs text-gray-500">Members cannot override the inherited sidebar.</span>
          </span>
        </label>

        <div class="flex items-center gap-3 mt-4">
          <button type="button" id="presets-save-btn"
                  class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Save presets</button>
          <span id="presets-status" class="text-xs text-gray-500" style="display:none;"></span>
        </div>
        <p id="presets-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
      </div>
    </section>

  <% } %>
</div>

<% if (_auth === 'authenticated' && _portfolio) { %>
<script>
  (function () {
    var portfolioId = <%- JSON.stringify(_portfolio.id) %>;

    // ---- Recompute ----
    var recomputeBtn = document.getElementById('recompute-btn');
    if (recomputeBtn) recomputeBtn.addEventListener('click', function () {
      recomputeBtn.disabled = true;
      var orig = recomputeBtn.textContent;
      recomputeBtn.textContent = 'Recomputing…';
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/recompute', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Recompute failed.');
          });
          location.reload();
        })
        .catch(function (err) {
          recomputeBtn.disabled = false;
          recomputeBtn.textContent = orig;
          alert(err.message || 'Recompute failed.');
        });
    });

    // ---- Start portfolio meeting ----
    var meetingBtn = document.getElementById('start-meeting-btn');
    if (meetingBtn) meetingBtn.addEventListener('click', function () {
      meetingBtn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/meeting', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          return r.ok ? r.json() : r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not start meeting.');
          });
        })
        .then(function (data) {
          var mid = data && (data.meetingId || (data.meeting && data.meeting.id));
          if (mid) window.location.href = '/l8/meeting/' + mid;
          else throw new Error('No meeting id returned.');
        })
        .catch(function (err) {
          meetingBtn.disabled = false;
          alert(err.message || 'Could not start meeting.');
        });
    });

    // ---- Add member org ----
    var addBtn = document.getElementById('add-member-btn');
    var addForm = document.getElementById('add-member-form');
    var addInput = document.getElementById('add-member-org-id');
    var addSubmit = document.getElementById('add-member-submit');
    var addCancel = document.getElementById('add-member-cancel');
    var addErr = document.getElementById('add-member-error');

    function showAddErr(msg) { addErr.textContent = msg; addErr.style.display = 'block'; }
    function clearAddErr() { addErr.textContent = ''; addErr.style.display = 'none'; }

    if (addBtn) addBtn.addEventListener('click', function () {
      addForm.style.display = 'block';
      addInput.focus();
    });
    if (addCancel) addCancel.addEventListener('click', function () {
      addForm.style.display = 'none';
      addInput.value = '';
      clearAddErr();
    });
    if (addSubmit) addSubmit.addEventListener('click', function () {
      var memberOrgId = (addInput.value || '').trim();
      clearAddErr();
      if (!memberOrgId) { showAddErr('A member organization ID is required.'); return; }
      addSubmit.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ memberOrgId: memberOrgId })
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not add member org.');
          });
          location.reload();
        })
        .catch(function (err) {
          addSubmit.disabled = false;
          showAddErr(err.message || 'Could not add member org.');
        });
    });

    // ---- Presets (sidebar inherited by member orgs) ----
    var presetsInherit = document.getElementById('presets-inherit-sidebar');
    var presetsLock = document.getElementById('presets-lock-sidebar');
    var presetsSaveBtn = document.getElementById('presets-save-btn');
    var presetsStatus = document.getElementById('presets-status');
    var presetsError = document.getElementById('presets-error');

    function showPresetsErr(msg) {
      if (!presetsError) return;
      presetsError.textContent = msg;
      presetsError.style.display = 'block';
    }
    function clearPresetsErr() {
      if (!presetsError) return;
      presetsError.textContent = '';
      presetsError.style.display = 'none';
    }
    function showPresetsStatus(msg) {
      if (!presetsStatus) return;
      presetsStatus.textContent = msg;
      presetsStatus.style.display = 'inline';
    }

    // Prefill the inherit + lock checkboxes from the saved presets. A non-null
    // sidebar preset means "member orgs inherit the portfolio sidebar".
    if (presetsInherit) {
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/presets', {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data) return;
          var sb = (data && typeof data.sidebar !== 'undefined') ? data.sidebar : null;
          presetsInherit.checked = (sb !== null && typeof sb !== 'undefined');
          var locked = (data && Array.isArray(data.locked)) ? data.locked : [];
          if (presetsLock) presetsLock.checked = locked.indexOf('sidebar') !== -1;
        })
        .catch(function () { /* leave defaults on failure */ });
    }

    if (presetsSaveBtn) presetsSaveBtn.addEventListener('click', function () {
      clearPresetsErr();
      // Checkbox -> a simple inherit marker; null when off. Lock only applies
      // when inheriting.
      var sidebar = (presetsInherit && presetsInherit.checked) ? { inherit: true } : null;
      var locked = (sidebar && presetsLock && presetsLock.checked) ? ['sidebar'] : [];
      presetsSaveBtn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/presets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ sidebar: sidebar, locked: locked })
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not save presets.');
          });
          presetsSaveBtn.disabled = false;
          showPresetsStatus('Saved.');
        })
        .catch(function (err) {
          presetsSaveBtn.disabled = false;
          showPresetsErr(err.message || 'Could not save presets.');
        });
    });

    // ---- Portfolio team (people from member orgs) ----
    var teamList = document.getElementById('team-list');
    var teamSelect = document.getElementById('team-add-select');
    var teamAddBtn = document.getElementById('team-add-btn');
    var teamError = document.getElementById('team-error');

    function showTeamErr(msg) { if (teamError) { teamError.textContent = msg; teamError.style.display = 'block'; } }
    function clearTeamErr() { if (teamError) { teamError.textContent = ''; teamError.style.display = 'none'; } }

    function teamLabel(p) {
      var name = p.displayName || p.email || p.clerkUserId;
      if (p.email && p.displayName) name += ' (' + p.email + ')';
      return name;
    }

    function renderTeam(data) {
      var team = (data && Array.isArray(data.team)) ? data.team : [];
      var candidates = (data && Array.isArray(data.candidates)) ? data.candidates : [];

      // Current members list.
      if (!teamList) return;
      teamList.innerHTML = '';
      if (team.length === 0) {
        var empty = document.createElement('p');
        empty.className = 'text-sm text-gray-500';
        empty.textContent = 'No team members yet. Add people from the member organizations below.';
        teamList.appendChild(empty);
      } else {
        team.forEach(function (m) {
          var row = document.createElement('div');
          row.className = 'flex items-center justify-between gap-3 py-1.5';
          var left = document.createElement('div');
          left.className = 'min-w-0';
          var nm = document.createElement('div');
          nm.className = 'text-sm font-medium text-gray-900 truncate';
          nm.textContent = m.displayName || m.email || m.clerkUserId;
          var sub = document.createElement('div');
          sub.className = 'text-xs text-gray-500 truncate';
          sub.textContent = (m.role === 'owner' ? 'Owner' : 'Member') + (m.email ? ' · ' + m.email : '');
          left.appendChild(nm); left.appendChild(sub);
          row.appendChild(left);
          if (m.role !== 'owner') {
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'text-xs font-semibold text-red-600 hover:underline shrink-0';
            rm.textContent = 'Remove';
            rm.addEventListener('click', function () { removeTeamMember(m.id, rm); });
            row.appendChild(rm);
          }
          teamList.appendChild(row);
        });
      }

      // Candidate dropdown.
      if (teamSelect) {
        teamSelect.innerHTML = '';
        var ph = document.createElement('option');
        ph.value = '';
        ph.textContent = candidates.length ? 'Select a person…' : 'No one available to add';
        teamSelect.appendChild(ph);
        candidates.forEach(function (c) {
          var opt = document.createElement('option');
          opt.value = c.clerkUserId;
          var label = teamLabel(c);
          if (c.sourceOrgs && c.sourceOrgs.length) label += ' — ' + c.sourceOrgs.join(', ');
          opt.textContent = label;
          teamSelect.appendChild(opt);
        });
        teamSelect.disabled = candidates.length === 0;
      }
    }

    function loadTeam() {
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/team', {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) { if (data) renderTeam(data); else if (teamList) teamList.innerHTML = '<p class="text-sm text-gray-500">Could not load team.</p>'; })
        .catch(function () { if (teamList) teamList.innerHTML = '<p class="text-sm text-gray-500">Could not load team.</p>'; });
    }

    function removeTeamMember(memberId, btn) {
      clearTeamErr();
      if (btn) btn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/team/' + encodeURIComponent(memberId), {
        method: 'DELETE',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not remove member.');
          });
          loadTeam();
        })
        .catch(function (err) { if (btn) btn.disabled = false; showTeamErr(err.message || 'Could not remove member.'); });
    }

    if (teamAddBtn) teamAddBtn.addEventListener('click', function () {
      clearTeamErr();
      var clerkUserId = teamSelect ? (teamSelect.value || '') : '';
      if (!clerkUserId) { showTeamErr('Select a person to add.'); return; }
      teamAddBtn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/team', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ clerkUserId: clerkUserId })
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not add member.');
          });
          teamAddBtn.disabled = false;
          loadTeam();
        })
        .catch(function (err) { teamAddBtn.disabled = false; showTeamErr(err.message || 'Could not add member.'); });
    });

    loadTeam();

    // ---- Click-to-copy member org IDs ----
    Array.prototype.forEach.call(document.querySelectorAll('.member-id-copy'), function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-org-id') || '';
        var orig = btn.textContent;
        var done = function () { btn.textContent = 'Copied!'; setTimeout(function () { btn.textContent = orig; }, 1200); };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(id).then(done).catch(function () { done(); });
        } else {
          var t = document.createElement('textarea'); t.value = id; document.body.appendChild(t);
          t.select(); try { document.execCommand('copy'); } catch (e) {} document.body.removeChild(t); done();
        }
      });
    });
  })();
</script>
<% } %>
