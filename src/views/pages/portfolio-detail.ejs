<%- include('../partials/orgy-palette'); %>
<%
  // ---- Portfolio detail ----
  // Locals:
  //   authState: 'authenticated' | 'not_found' | 'feature_off'
  //   portfolio: organizations row
  //   memberOrgs: [{ id, name }]
  //   superMetrics: [{ ...kpi, sources: [{ memberOrgId, memberKpiId, weight }] }]
  //   latestByKpi: { [kpiId]: number | null }
  //   memberNameById: { [orgId]: name }
  // Plain JS line comments only -- never an EJS close-delimiter in a comment.
  var _auth = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _portfolio = (typeof portfolio !== 'undefined' && portfolio) ? portfolio : null;
  var _members = (typeof memberOrgs !== 'undefined' && Array.isArray(memberOrgs)) ? memberOrgs : [];
  var _metrics = (typeof superMetrics !== 'undefined' && Array.isArray(superMetrics)) ? superMetrics : [];
  var _latest = (typeof latestByKpi !== 'undefined' && latestByKpi) ? latestByKpi : {};
  var _nameById = (typeof memberNameById !== 'undefined' && memberNameById) ? memberNameById : {};
  var _memberStats = (typeof memberStats !== 'undefined' && Array.isArray(memberStats)) ? memberStats : [];
  var _statsById = {};
  _memberStats.forEach(function (s) { _statsById[s.id] = s; });
  function _opLabel(op) {
    if (op === 'gte') return '≥'; if (op === 'lte') return '≤';
    if (op === 'gt') return '>'; if (op === 'lt') return '<';
    if (op === 'eq') return '='; return '';
  }
  function _fmt(v) {
    if (v === null || typeof v === 'undefined') return '—';
    return (Math.round(v * 100) / 100).toLocaleString();
  }
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <% if (_auth === 'not_found') { %>
    <div class="bg-white border rounded-xl p-10 text-center">
      <h1 class="text-xl font-extrabold text-gray-900 mb-2">Portfolio not found</h1>
      <p class="text-sm text-gray-600 mb-5">This portfolio does not exist, or you do not have access to it.</p>
      <a href="/portfolio" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Back to portfolios</a>
    </div>

  <% } else if (_auth === 'feature_off') { %>
    <div class="bg-white border rounded-xl p-10 text-center">
      <h1 class="text-xl font-extrabold text-gray-900 mb-2">Portfolios are in Labs</h1>
      <p class="text-sm text-gray-600 mb-5">Turn the Portfolio feature on in Labs to view this portfolio.</p>
      <a href="/settings/labs" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Enable in Labs</a>
    </div>

  <% } else { %>

    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <div class="min-w-0">
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">
          <a href="/portfolio" class="hover:underline">Portfolios</a>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= _portfolio ? _portfolio.name : 'Portfolio' %></h1>
      </div>
      <div class="shrink-0 flex items-center gap-2">
        <button type="button" id="recompute-btn"
                class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium transition-colors">
          Recompute
        </button>
        <button type="button" id="start-meeting-btn"
                class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">
          Start portfolio meeting
        </button>
      </div>
    </div>

    <!-- ===== Member organizations ===== -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Member organizations</h2>
        <button type="button" id="add-member-btn"
                class="text-sm font-semibold text-otp-600 hover:underline">Add member org</button>
      </div>

      <!-- Add-member affordance (POSTs to the link API; wired by a later task) -->
      <div id="add-member-form" class="bg-white border rounded-xl p-5 mb-4" style="display:none;">
        <label for="add-member-org-id" class="block text-sm font-semibold text-gray-900 mb-2">Member organization ID</label>
        <div class="flex flex-wrap gap-2 items-center">
          <input type="text" id="add-member-org-id" placeholder="Organization UUID"
                 class="flex-1 min-w-[18rem] px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500/40">
          <button type="button" id="add-member-submit"
                  class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Add</button>
          <button type="button" id="add-member-cancel"
                  class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium transition-colors">Cancel</button>
        </div>
        <p id="add-member-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
        <p class="text-xs text-gray-500 mt-3 border-t pt-3">
          <span class="font-semibold text-gray-700">Where do I find an organization's ID?</span>
          Each organization's owner or admin can find it in
          <span class="font-medium text-gray-700">Settings → Company</span>, under
          <span class="font-mono text-gray-700">Company ID</span> — they copy it there and send it to you.
          Click a member card below to open its panel, where you can copy its ID.
        </p>
      </div>

      <% if (_members.length === 0) { %>
        <div class="bg-white border rounded-xl p-8 text-center">
          <p class="text-sm text-gray-600">No member organizations linked yet. Add one to start rolling KPIs up.</p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% _members.forEach(function(m) {
               var st = _statsById[m.id] || { humanCount: 0, agentCount: 0, kpiCount: 0 };
          %>
            <button type="button"
                    class="member-card text-left bg-white border rounded-xl p-4 hover:border-otp-400 hover:shadow-sm transition-all"
                    data-org-id="<%= m.id %>" data-org-name="<%= m.name %>"
                    data-humans="<%= st.humanCount %>" data-agents="<%= st.agentCount %>" data-kpis="<%= st.kpiCount %>">
              <div class="flex items-center justify-between gap-2 mb-3">
                <div class="font-bold text-gray-900 truncate"><%= m.name %></div>
                <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
              </div>
              <div class="flex items-center gap-4 text-sm">
                <span class="text-gray-700"><span class="font-bold"><%= st.humanCount %></span> <span class="text-gray-500">humans</span></span>
                <span class="text-gray-700"><span class="font-bold"><%= st.agentCount %></span> <span class="text-gray-500">agents</span></span>
                <span class="text-gray-700"><span class="font-bold"><%= st.kpiCount %></span> <span class="text-gray-500">KPIs</span></span>
              </div>
            </button>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Member side panel (org-map style drawer) -->
    <div id="member-panel-overlay" class="fixed inset-0 bg-black/30 z-40" style="display:none;"></div>
    <aside id="member-panel" class="fixed top-0 right-0 h-full w-full sm:w-96 bg-white border-l shadow-xl z-50 overflow-y-auto"
           style="transform: translateX(100%); transition: transform 0.2s ease;" aria-hidden="true">
      <div class="p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 id="mp-name" class="text-lg font-bold text-gray-900 truncate pr-2">Member</h3>
          <button type="button" id="mp-close" class="p-1 text-gray-400 hover:text-gray-700 shrink-0" aria-label="Close panel">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
        <div class="grid grid-cols-3 gap-2 mb-5">
          <div class="bg-gray-50 rounded-lg p-3 text-center"><div id="mp-humans" class="text-2xl font-extrabold text-gray-900">0</div><div class="text-xs text-gray-500">Humans</div></div>
          <div class="bg-gray-50 rounded-lg p-3 text-center"><div id="mp-agents" class="text-2xl font-extrabold text-gray-900">0</div><div class="text-xs text-gray-500">Agents</div></div>
          <div class="bg-gray-50 rounded-lg p-3 text-center"><div id="mp-kpis" class="text-2xl font-extrabold text-gray-900">0</div><div class="text-xs text-gray-500">KPIs</div></div>
        </div>
        <div class="mb-4">
          <div class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-1">Organization ID</div>
          <button type="button" id="mp-id-copy" class="text-xs text-gray-500 hover:text-otp-600 font-mono break-all text-left" title="Click to copy">—</button>
        </div>
        <p class="text-xs text-gray-400 border-t pt-4">More detail lands here as we build it out — recent activity, this org's contribution to each super-metric, and quick links into the member org.</p>
      </div>
    </aside>

    <!-- ===== Portfolio team ===== -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Portfolio team</h2>
        <span class="text-xs text-gray-500">People from member orgs who attend portfolio meetings</span>
      </div>
      <div class="bg-white border rounded-xl p-5">
        <div id="team-list" class="space-y-2 mb-4">
          <p class="text-sm text-gray-500">Loading team…</p>
        </div>
        <div class="border-t pt-4">
          <label for="team-add-select" class="block text-sm font-semibold text-gray-900 mb-2">Add from member organizations</label>
          <div class="flex flex-wrap gap-2 items-center">
            <select id="team-add-select"
                    class="flex-1 min-w-[18rem] px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500/40">
              <option value="">Select a person…</option>
            </select>
            <button type="button" id="team-add-btn"
                    class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Add to team</button>
          </div>
          <p id="team-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
          <p class="text-xs text-gray-400 mt-2">Only people who belong to a member organization can be added.</p>
        </div>
      </div>
    </section>

    <!-- ===== Bring in a location (invite a champion) ===== -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Bring in a location</h2>
        <span class="text-xs text-gray-500">Invite a champion; a new org is created from this template on accept</span>
      </div>
      <div class="bg-white border rounded-xl p-5">
        <p class="text-sm text-gray-600 mb-4 max-w-[70ch]">
          Invite a person by email. They get a link to accept; when they do, a brand-new organization is
          created from this portfolio's template (starter KPIs + sidebar), they become its owner, and it
          joins this portfolio automatically. Send them the accept link yourself — no email is sent from here.
        </p>

        <div class="flex flex-wrap gap-2 items-center">
          <input type="email" id="champ-email" placeholder="champion@example.com"
                 class="flex-1 min-w-[16rem] px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500/40">
          <input type="text" id="champ-org-name" placeholder="Org name (optional)"
                 class="flex-1 min-w-[12rem] px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500/40">
          <button type="button" id="champ-create-btn"
                  class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Create invite</button>
        </div>
        <p id="champ-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>

        <!-- New-link callout shown right after a successful create -->
        <div id="champ-new-link" class="mt-4 border border-otp-200 bg-otp-50 rounded-lg p-3" style="display:none;">
          <div class="text-xs font-semibold text-gray-700 mb-1">Accept link — send this to your champion</div>
          <div class="flex flex-wrap gap-2 items-center">
            <input type="text" id="champ-new-link-url" readonly
                   class="flex-1 min-w-[18rem] px-3 py-2 border border-gray-300 rounded-lg text-xs font-mono bg-white">
            <button type="button" id="champ-new-link-copy"
                    class="px-3 py-2 border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 text-xs font-medium transition-colors">Copy</button>
          </div>
        </div>

        <!-- Pending + accepted invites list (fetched client-side) -->
        <div class="border-t mt-5 pt-4">
          <div class="text-[11px] uppercase tracking-wide text-gray-500 font-semibold mb-2">Invites</div>
          <div id="champ-list" class="space-y-2">
            <p class="text-sm text-gray-500">Loading invites…</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Super-metrics ===== -->
    <section>
      <h2 class="text-lg font-bold text-gray-900 mb-3">Super-metrics</h2>

      <% if (_metrics.length === 0) { %>
        <div class="bg-white border rounded-xl p-8 text-center">
          <p class="text-sm text-gray-600">No super-metrics yet. A super-metric rolls one KPI per member org up into a single number.</p>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% _metrics.forEach(function(sm) {
            var latest = _latest[sm.id];
            var goalText = (sm.goalValue !== null && typeof sm.goalValue !== 'undefined')
              ? (_opLabel(sm.goalOperator) + ' ' + _fmt(sm.goalValue)).trim()
              : null;
          %>
            <div class="bg-white border rounded-xl p-6">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <h3 class="font-bold text-gray-900 text-base"><%= sm.title %></h3>
                  <div class="text-xs text-gray-500 mt-0.5 flex flex-wrap gap-x-3 gap-y-0.5">
                    <% if (sm.unit) { %><span>Unit: <%= sm.unit %></span><% } %>
                    <% if (goalText) { %><span>Goal: <%= goalText %></span><% } %>
                    <% if (sm.timeGrain) { %><span><%= sm.timeGrain %></span><% } %>
                  </div>
                </div>
                <div class="shrink-0 text-right">
                  <div class="text-2xl font-extrabold text-gray-900"><%= _fmt(latest) %></div>
                  <div class="text-[11px] uppercase tracking-wide text-gray-400">latest</div>
                </div>
              </div>

              <% if (sm.sources && sm.sources.length > 0) { %>
                <div class="mt-4 border-t pt-3">
                  <div class="text-[11px] uppercase tracking-wide text-gray-500 font-semibold mb-2">Contributing orgs</div>
                  <div class="space-y-1.5">
                    <% sm.sources.forEach(function(s) { %>
                      <div class="flex items-center justify-between gap-3 text-sm">
                        <span class="text-gray-700 truncate"><%= _nameById[s.memberOrgId] || s.memberOrgId %></span>
                        <span class="text-xs text-gray-500 shrink-0">weight <%= _fmt(s.weight) %></span>
                      </div>
                    <% }); %>
                  </div>
                </div>
              <% } else { %>
                <p class="mt-3 text-xs text-gray-400">No source KPIs mapped yet.</p>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- ===== Organization template ===== -->
    <section class="mt-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold text-gray-900">Organization template</h2>
        <span class="text-xs text-gray-500">Standard setup inherited by member orgs and seeded into new ones</span>
      </div>
      <div class="bg-white border rounded-xl p-6 space-y-6">

        <!-- Sidebar & menus -->
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Sidebar &amp; menus</h3>
          <p class="text-sm text-gray-600 mb-3">Standardize the sidebar across member organizations. Lock it to prevent overrides.</p>

          <label class="flex items-start gap-2 text-sm text-gray-700">
            <input type="checkbox" id="presets-inherit-sidebar"
                   class="mt-0.5 h-4 w-4 rounded border-gray-300 text-otp-500 focus:ring-otp-500/40">
            <span>
              <span class="font-semibold text-gray-900">Member organizations inherit the portfolio sidebar</span><br>
              <span class="text-xs text-gray-500">Member orgs use this portfolio's standardized sidebar instead of their own.</span>
            </span>
          </label>

          <label class="flex items-start gap-2 mt-3 text-sm text-gray-700">
            <input type="checkbox" id="presets-lock-sidebar"
                   class="mt-0.5 h-4 w-4 rounded border-gray-300 text-otp-500 focus:ring-otp-500/40">
            <span>
              <span class="font-semibold text-gray-900">Lock it</span><br>
              <span class="text-xs text-gray-500">Members cannot override the inherited sidebar.</span>
            </span>
          </label>
        </div>

        <!-- Starter KPIs -->
        <div class="border-t pt-5">
          <div class="flex items-center justify-between mb-1">
            <h3 class="font-semibold text-gray-900">Starter KPIs</h3>
            <button type="button" id="tpl-kpi-add" class="text-sm font-semibold text-otp-600 hover:underline">+ Add KPI</button>
          </div>
          <p class="text-sm text-gray-600 mb-3">Scorecard metrics seeded into a new organization created from this template.</p>
          <div id="tpl-kpi-list" class="space-y-2"></div>
          <p id="tpl-kpi-empty" class="text-sm text-gray-400" style="display:none;">No starter KPIs yet. Add the metrics every location should track.</p>
        </div>

        <!-- AI key policy -->
        <div class="border-t pt-5">
          <h3 class="font-semibold text-gray-900 mb-1">AI key policy</h3>
          <p class="text-sm text-gray-600 mb-3">
            The portfolio's own API key (set in <span class="font-medium text-gray-700">Settings → Company → Bring your own AI key</span>)
            is the default for member organizations. Keys are never used to train or teach.
          </p>
          <label class="flex items-start gap-2 text-sm text-gray-700">
            <input type="checkbox" id="tpl-allow-override"
                   class="mt-0.5 h-4 w-4 rounded border-gray-300 text-otp-500 focus:ring-otp-500/40">
            <span>
              <span class="font-semibold text-gray-900">Locations may set their own AI key</span><br>
              <span class="text-xs text-gray-500">A member org can override the portfolio default with its own Anthropic / OpenAI key.</span>
            </span>
          </label>
        </div>

        <div class="flex items-center gap-3 border-t pt-5">
          <button type="button" id="presets-save-btn"
                  class="px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-semibold transition-colors">Save template</button>
          <span id="presets-status" class="text-xs text-gray-500" style="display:none;"></span>
        </div>
        <p id="presets-error" class="text-xs text-red-600 mt-2" style="display:none;"></p>
      </div>
    </section>

  <% } %>
</div>

<% if (_auth === 'authenticated' && _portfolio) { %>
<script>
  (function () {
    var portfolioId = <%- JSON.stringify(_portfolio.id) %>;

    // ---- Recompute ----
    var recomputeBtn = document.getElementById('recompute-btn');
    if (recomputeBtn) recomputeBtn.addEventListener('click', function () {
      recomputeBtn.disabled = true;
      var orig = recomputeBtn.textContent;
      recomputeBtn.textContent = 'Recomputing…';
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/recompute', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Recompute failed.');
          });
          location.reload();
        })
        .catch(function (err) {
          recomputeBtn.disabled = false;
          recomputeBtn.textContent = orig;
          alert(err.message || 'Recompute failed.');
        });
    });

    // ---- Start portfolio meeting ----
    var meetingBtn = document.getElementById('start-meeting-btn');
    if (meetingBtn) meetingBtn.addEventListener('click', function () {
      meetingBtn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/meeting', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          return r.ok ? r.json() : r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not start meeting.');
          });
        })
        .then(function (data) {
          var mid = data && (data.meetingId || (data.meeting && data.meeting.id));
          if (mid) window.location.href = '/l8/meeting/' + mid;
          else throw new Error('No meeting id returned.');
        })
        .catch(function (err) {
          meetingBtn.disabled = false;
          alert(err.message || 'Could not start meeting.');
        });
    });

    // ---- Add member org ----
    var addBtn = document.getElementById('add-member-btn');
    var addForm = document.getElementById('add-member-form');
    var addInput = document.getElementById('add-member-org-id');
    var addSubmit = document.getElementById('add-member-submit');
    var addCancel = document.getElementById('add-member-cancel');
    var addErr = document.getElementById('add-member-error');

    function showAddErr(msg) { addErr.textContent = msg; addErr.style.display = 'block'; }
    function clearAddErr() { addErr.textContent = ''; addErr.style.display = 'none'; }

    if (addBtn) addBtn.addEventListener('click', function () {
      addForm.style.display = 'block';
      addInput.focus();
    });
    if (addCancel) addCancel.addEventListener('click', function () {
      addForm.style.display = 'none';
      addInput.value = '';
      clearAddErr();
    });
    if (addSubmit) addSubmit.addEventListener('click', function () {
      var memberOrgId = (addInput.value || '').trim();
      clearAddErr();
      if (!memberOrgId) { showAddErr('A member organization ID is required.'); return; }
      addSubmit.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ memberOrgId: memberOrgId })
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not add member org.');
          });
          location.reload();
        })
        .catch(function (err) {
          addSubmit.disabled = false;
          showAddErr(err.message || 'Could not add member org.');
        });
    });

    // ---- Presets (sidebar inherited by member orgs) ----
    var presetsInherit = document.getElementById('presets-inherit-sidebar');
    var presetsLock = document.getElementById('presets-lock-sidebar');
    var presetsSaveBtn = document.getElementById('presets-save-btn');
    var presetsStatus = document.getElementById('presets-status');
    var presetsError = document.getElementById('presets-error');
    var tplKpiList = document.getElementById('tpl-kpi-list');
    var tplKpiAdd = document.getElementById('tpl-kpi-add');
    var tplKpiEmpty = document.getElementById('tpl-kpi-empty');
    var tplAllowOverride = document.getElementById('tpl-allow-override');

    var KPI_OPS = [['', '—'], ['gte', '≥'], ['lte', '≤'], ['gt', '>'], ['lt', '<'], ['eq', '=']];
    var KPI_GRAINS = ['weekly', 'monthly', 'quarterly'];

    function refreshKpiEmpty() {
      if (!tplKpiList || !tplKpiEmpty) return;
      tplKpiEmpty.style.display = tplKpiList.children.length ? 'none' : 'block';
    }
    function addKpiRow(kpi) {
      if (!tplKpiList) return;
      kpi = kpi || {};
      var inp = 'px-2 py-1.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500/40';
      var row = document.createElement('div');
      row.className = 'tpl-kpi-row flex flex-wrap items-center gap-2';

      var title = document.createElement('input');
      title.type = 'text'; title.placeholder = 'KPI title';
      title.className = 'tpl-kpi-title flex-1 min-w-[12rem] ' + inp;
      title.value = kpi.title || '';

      var unit = document.createElement('input');
      unit.type = 'text'; unit.placeholder = 'Unit';
      unit.className = 'tpl-kpi-unit w-24 ' + inp;
      unit.value = kpi.unit || '';

      var op = document.createElement('select');
      op.className = 'tpl-kpi-op ' + inp;
      KPI_OPS.forEach(function (o) {
        var opt = document.createElement('option'); opt.value = o[0]; opt.textContent = o[1];
        if ((kpi.goalOperator || '') === o[0]) opt.selected = true;
        op.appendChild(opt);
      });

      var goal = document.createElement('input');
      goal.type = 'number'; goal.step = 'any'; goal.placeholder = 'Goal';
      goal.className = 'tpl-kpi-goal w-24 ' + inp;
      if (kpi.goalValue !== null && typeof kpi.goalValue !== 'undefined') goal.value = kpi.goalValue;

      var grain = document.createElement('select');
      grain.className = 'tpl-kpi-grain ' + inp;
      KPI_GRAINS.forEach(function (g) {
        var opt = document.createElement('option'); opt.value = g; opt.textContent = g;
        if ((kpi.timeGrain || 'weekly') === g) opt.selected = true;
        grain.appendChild(opt);
      });

      var rm = document.createElement('button');
      rm.type = 'button'; rm.textContent = '✕'; rm.setAttribute('aria-label', 'Remove KPI');
      rm.className = 'tpl-kpi-remove px-2 py-1 text-gray-400 hover:text-red-600 text-sm';
      rm.addEventListener('click', function () { tplKpiList.removeChild(row); refreshKpiEmpty(); });

      row.appendChild(title); row.appendChild(unit); row.appendChild(op);
      row.appendChild(goal); row.appendChild(grain); row.appendChild(rm);
      tplKpiList.appendChild(row);
      refreshKpiEmpty();
    }
    function collectKpis() {
      if (!tplKpiList) return [];
      var out = [];
      Array.prototype.forEach.call(tplKpiList.querySelectorAll('.tpl-kpi-row'), function (row) {
        var title = (row.querySelector('.tpl-kpi-title').value || '').trim();
        if (!title) return;
        var unit = (row.querySelector('.tpl-kpi-unit').value || '').trim();
        var op = row.querySelector('.tpl-kpi-op').value || '';
        var goalRaw = row.querySelector('.tpl-kpi-goal').value;
        var grain = row.querySelector('.tpl-kpi-grain').value || 'weekly';
        var k = { title: title, timeGrain: grain };
        if (unit) k.unit = unit;
        if (op) k.goalOperator = op;
        if (goalRaw !== '' && !isNaN(parseFloat(goalRaw))) k.goalValue = parseFloat(goalRaw);
        out.push(k);
      });
      return out;
    }
    if (tplKpiAdd) tplKpiAdd.addEventListener('click', function () { addKpiRow({}); });
    refreshKpiEmpty();

    function showPresetsErr(msg) {
      if (!presetsError) return;
      presetsError.textContent = msg;
      presetsError.style.display = 'block';
    }
    function clearPresetsErr() {
      if (!presetsError) return;
      presetsError.textContent = '';
      presetsError.style.display = 'none';
    }
    function showPresetsStatus(msg) {
      if (!presetsStatus) return;
      presetsStatus.textContent = msg;
      presetsStatus.style.display = 'inline';
    }

    // Prefill the inherit + lock checkboxes from the saved presets. A non-null
    // sidebar preset means "member orgs inherit the portfolio sidebar".
    if (presetsInherit) {
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/presets', {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data) return;
          var sb = (data && typeof data.sidebar !== 'undefined') ? data.sidebar : null;
          presetsInherit.checked = (sb !== null && typeof sb !== 'undefined');
          var locked = (data && Array.isArray(data.locked)) ? data.locked : [];
          if (presetsLock) presetsLock.checked = locked.indexOf('sidebar') !== -1;
          // Starter KPIs
          if (tplKpiList) {
            tplKpiList.innerHTML = '';
            var kpis = (data && Array.isArray(data.kpis)) ? data.kpis : [];
            kpis.forEach(function (k) { addKpiRow(k); });
            refreshKpiEmpty();
          }
          // API key policy (default: override allowed)
          if (tplAllowOverride) {
            var apk = (data && data.apiKeyPolicy) ? data.apiKeyPolicy : null;
            tplAllowOverride.checked = apk ? (apk.allowLocationOverride !== false) : true;
          }
        })
        .catch(function () { /* leave defaults on failure */ });
    }

    if (presetsSaveBtn) presetsSaveBtn.addEventListener('click', function () {
      clearPresetsErr();
      // Checkbox -> a simple inherit marker; null when off. Lock only applies
      // when inheriting.
      var sidebar = (presetsInherit && presetsInherit.checked) ? { inherit: true } : null;
      var locked = (sidebar && presetsLock && presetsLock.checked) ? ['sidebar'] : [];
      var kpis = collectKpis();
      var apiKeyPolicy = { allowLocationOverride: !!(tplAllowOverride && tplAllowOverride.checked) };
      presetsSaveBtn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/presets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ sidebar: sidebar, locked: locked, kpis: kpis, apiKeyPolicy: apiKeyPolicy })
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not save presets.');
          });
          presetsSaveBtn.disabled = false;
          showPresetsStatus('Saved.');
        })
        .catch(function (err) {
          presetsSaveBtn.disabled = false;
          showPresetsErr(err.message || 'Could not save presets.');
        });
    });

    // ---- Portfolio team (people from member orgs) ----
    var teamList = document.getElementById('team-list');
    var teamSelect = document.getElementById('team-add-select');
    var teamAddBtn = document.getElementById('team-add-btn');
    var teamError = document.getElementById('team-error');

    function showTeamErr(msg) { if (teamError) { teamError.textContent = msg; teamError.style.display = 'block'; } }
    function clearTeamErr() { if (teamError) { teamError.textContent = ''; teamError.style.display = 'none'; } }

    function teamLabel(p) {
      var name = p.displayName || p.email || p.clerkUserId;
      if (p.email && p.displayName) name += ' (' + p.email + ')';
      return name;
    }

    function renderTeam(data) {
      var team = (data && Array.isArray(data.team)) ? data.team : [];
      var candidates = (data && Array.isArray(data.candidates)) ? data.candidates : [];

      // Current members list.
      if (!teamList) return;
      teamList.innerHTML = '';
      if (team.length === 0) {
        var empty = document.createElement('p');
        empty.className = 'text-sm text-gray-500';
        empty.textContent = 'No team members yet. Add people from the member organizations below.';
        teamList.appendChild(empty);
      } else {
        team.forEach(function (m) {
          var row = document.createElement('div');
          row.className = 'flex items-center justify-between gap-3 py-1.5';
          var left = document.createElement('div');
          left.className = 'min-w-0';
          var nm = document.createElement('div');
          nm.className = 'text-sm font-medium text-gray-900 truncate';
          nm.textContent = m.displayName || m.email || m.clerkUserId;
          var sub = document.createElement('div');
          sub.className = 'text-xs text-gray-500 truncate';
          sub.textContent = (m.role === 'owner' ? 'Owner' : 'Member') + (m.email ? ' · ' + m.email : '');
          left.appendChild(nm); left.appendChild(sub);
          row.appendChild(left);
          if (m.role !== 'owner') {
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'text-xs font-semibold text-red-600 hover:underline shrink-0';
            rm.textContent = 'Remove';
            rm.addEventListener('click', function () { removeTeamMember(m.id, rm); });
            row.appendChild(rm);
          }
          teamList.appendChild(row);
        });
      }

      // Candidate dropdown.
      if (teamSelect) {
        teamSelect.innerHTML = '';
        var ph = document.createElement('option');
        ph.value = '';
        ph.textContent = candidates.length ? 'Select a person…' : 'No one available to add';
        teamSelect.appendChild(ph);
        candidates.forEach(function (c) {
          var opt = document.createElement('option');
          opt.value = c.clerkUserId;
          var label = teamLabel(c);
          if (c.sourceOrgs && c.sourceOrgs.length) label += ' — ' + c.sourceOrgs.join(', ');
          opt.textContent = label;
          teamSelect.appendChild(opt);
        });
        teamSelect.disabled = candidates.length === 0;
      }
    }

    function loadTeam() {
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/team', {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) { if (data) renderTeam(data); else if (teamList) teamList.innerHTML = '<p class="text-sm text-gray-500">Could not load team.</p>'; })
        .catch(function () { if (teamList) teamList.innerHTML = '<p class="text-sm text-gray-500">Could not load team.</p>'; });
    }

    function removeTeamMember(memberId, btn) {
      clearTeamErr();
      if (btn) btn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/team/' + encodeURIComponent(memberId), {
        method: 'DELETE',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not remove member.');
          });
          loadTeam();
        })
        .catch(function (err) { if (btn) btn.disabled = false; showTeamErr(err.message || 'Could not remove member.'); });
    }

    if (teamAddBtn) teamAddBtn.addEventListener('click', function () {
      clearTeamErr();
      var clerkUserId = teamSelect ? (teamSelect.value || '') : '';
      if (!clerkUserId) { showTeamErr('Select a person to add.'); return; }
      teamAddBtn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/team', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ clerkUserId: clerkUserId })
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not add member.');
          });
          teamAddBtn.disabled = false;
          loadTeam();
        })
        .catch(function (err) { teamAddBtn.disabled = false; showTeamErr(err.message || 'Could not add member.'); });
    });

    loadTeam();

    // ---- Bring in a location (champion invites) ----
    var champEmail = document.getElementById('champ-email');
    var champOrgName = document.getElementById('champ-org-name');
    var champCreateBtn = document.getElementById('champ-create-btn');
    var champError = document.getElementById('champ-error');
    var champList = document.getElementById('champ-list');
    var champNewLink = document.getElementById('champ-new-link');
    var champNewLinkUrl = document.getElementById('champ-new-link-url');
    var champNewLinkCopy = document.getElementById('champ-new-link-copy');

    function showChampErr(msg) { if (champError) { champError.textContent = msg; champError.style.display = 'block'; } }
    function clearChampErr() { if (champError) { champError.textContent = ''; champError.style.display = 'none'; } }

    function copyToClipboard(text, doneEl) {
      var orig = doneEl ? doneEl.textContent : '';
      var done = function () { if (doneEl) { doneEl.textContent = 'Copied!'; setTimeout(function () { doneEl.textContent = orig; }, 1200); } };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function () { done(); });
      } else {
        var t = document.createElement('textarea'); t.value = text; document.body.appendChild(t);
        t.select(); try { document.execCommand('copy'); } catch (e) {} document.body.removeChild(t); done();
      }
    }

    function renderChampInvites(invites) {
      if (!champList) return;
      champList.innerHTML = '';
      if (!invites || invites.length === 0) {
        var empty = document.createElement('p');
        empty.className = 'text-sm text-gray-500';
        empty.textContent = 'No invites yet.';
        champList.appendChild(empty);
        return;
      }
      invites.forEach(function (inv) {
        var row = document.createElement('div');
        row.className = 'flex flex-wrap items-center justify-between gap-2 py-1.5 border-b last:border-b-0';

        var left = document.createElement('div');
        left.className = 'min-w-0';
        var nm = document.createElement('div');
        nm.className = 'text-sm font-medium text-gray-900 truncate';
        nm.textContent = inv.email + (inv.orgName ? ' · ' + inv.orgName : '');
        var sub = document.createElement('div');
        sub.className = 'text-xs text-gray-500';
        sub.textContent = inv.status === 'accepted' ? 'Accepted' : 'Pending';
        left.appendChild(nm); left.appendChild(sub);
        row.appendChild(left);

        var actions = document.createElement('div');
        actions.className = 'flex items-center gap-2 shrink-0';
        if (inv.status === 'pending') {
          var copyBtn = document.createElement('button');
          copyBtn.type = 'button';
          copyBtn.className = 'text-xs font-semibold text-otp-600 hover:underline';
          copyBtn.textContent = 'Copy link';
          copyBtn.addEventListener('click', function () { copyToClipboard(inv.acceptUrl, copyBtn); });
          actions.appendChild(copyBtn);

          var revokeBtn = document.createElement('button');
          revokeBtn.type = 'button';
          revokeBtn.className = 'text-xs font-semibold text-red-600 hover:underline';
          revokeBtn.textContent = 'Revoke';
          revokeBtn.addEventListener('click', function () { revokeChampInvite(inv.id, revokeBtn); });
          actions.appendChild(revokeBtn);
        } else if (inv.status === 'accepted') {
          var done = document.createElement('span');
          done.className = 'text-xs text-gray-400';
          done.textContent = '✓';
          actions.appendChild(done);
        }
        row.appendChild(actions);
        champList.appendChild(row);
      });
    }

    function loadChampInvites() {
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/champion-invites', {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (data) renderChampInvites(data.invites);
          else if (champList) champList.innerHTML = '<p class="text-sm text-gray-500">Could not load invites.</p>';
        })
        .catch(function () { if (champList) champList.innerHTML = '<p class="text-sm text-gray-500">Could not load invites.</p>'; });
    }

    function revokeChampInvite(inviteId, btn) {
      if (btn) btn.disabled = true;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/champion-invites/' + encodeURIComponent(inviteId), {
        method: 'DELETE',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin',
      })
        .then(function (r) {
          if (!r.ok) return r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not revoke invite.');
          });
          loadChampInvites();
        })
        .catch(function (err) { if (btn) btn.disabled = false; showChampErr(err.message || 'Could not revoke invite.'); });
    }

    if (champCreateBtn) champCreateBtn.addEventListener('click', function () {
      clearChampErr();
      var email = (champEmail && champEmail.value || '').trim();
      var orgName = (champOrgName && champOrgName.value || '').trim();
      if (!email) { showChampErr('A champion email is required.'); return; }
      champCreateBtn.disabled = true;
      var body = { email: email };
      if (orgName) body.orgName = orgName;
      fetch('/api/v1/portfolios/' + encodeURIComponent(portfolioId) + '/champion-invites', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(body)
      })
        .then(function (r) {
          return r.ok ? r.json() : r.json().then(function (e) {
            throw new Error((e && e.error && (e.error.message || e.error.code)) || 'Could not create invite.');
          });
        })
        .then(function (data) {
          champCreateBtn.disabled = false;
          if (champEmail) champEmail.value = '';
          if (champOrgName) champOrgName.value = '';
          var url = data && data.invite && data.invite.acceptUrl;
          if (url && champNewLink && champNewLinkUrl) {
            champNewLinkUrl.value = url;
            champNewLink.style.display = 'block';
          }
          loadChampInvites();
        })
        .catch(function (err) { champCreateBtn.disabled = false; showChampErr(err.message || 'Could not create invite.'); });
    });

    if (champNewLinkCopy) champNewLinkCopy.addEventListener('click', function () {
      copyToClipboard(champNewLinkUrl ? champNewLinkUrl.value : '', champNewLinkCopy);
    });

    loadChampInvites();

    // ---- Member org chart: card click -> side panel ----
    var memberPanel = document.getElementById('member-panel');
    var memberOverlay = document.getElementById('member-panel-overlay');
    var mpName = document.getElementById('mp-name');
    var mpHumans = document.getElementById('mp-humans');
    var mpAgents = document.getElementById('mp-agents');
    var mpKpis = document.getElementById('mp-kpis');
    var mpIdCopy = document.getElementById('mp-id-copy');
    var mpClose = document.getElementById('mp-close');

    function openMemberPanel(data) {
      if (!memberPanel) return;
      if (mpName) mpName.textContent = data.name || 'Member';
      if (mpHumans) mpHumans.textContent = data.humans || '0';
      if (mpAgents) mpAgents.textContent = data.agents || '0';
      if (mpKpis) mpKpis.textContent = data.kpis || '0';
      if (mpIdCopy) { mpIdCopy.textContent = data.id || '—'; mpIdCopy.setAttribute('data-org-id', data.id || ''); }
      memberPanel.style.transform = 'translateX(0)';
      memberPanel.setAttribute('aria-hidden', 'false');
      if (memberOverlay) memberOverlay.style.display = 'block';
    }
    function closeMemberPanel() {
      if (!memberPanel) return;
      memberPanel.style.transform = 'translateX(100%)';
      memberPanel.setAttribute('aria-hidden', 'true');
      if (memberOverlay) memberOverlay.style.display = 'none';
    }
    Array.prototype.forEach.call(document.querySelectorAll('.member-card'), function (card) {
      card.addEventListener('click', function () {
        openMemberPanel({
          id: card.getAttribute('data-org-id') || '',
          name: card.getAttribute('data-org-name') || '',
          humans: card.getAttribute('data-humans') || '0',
          agents: card.getAttribute('data-agents') || '0',
          kpis: card.getAttribute('data-kpis') || '0'
        });
      });
    });
    if (mpClose) mpClose.addEventListener('click', closeMemberPanel);
    if (memberOverlay) memberOverlay.addEventListener('click', closeMemberPanel);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMemberPanel(); });
    if (mpIdCopy) mpIdCopy.addEventListener('click', function () {
      var id = mpIdCopy.getAttribute('data-org-id') || '';
      var orig = mpIdCopy.textContent;
      var done = function () { mpIdCopy.textContent = 'Copied!'; setTimeout(function () { mpIdCopy.textContent = orig; }, 1200); };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(id).then(done).catch(done);
      } else {
        var t = document.createElement('textarea'); t.value = id; document.body.appendChild(t);
        t.select(); try { document.execCommand('copy'); } catch (e) {} document.body.removeChild(t); done();
      }
    });
  })();
</script>
<% } %>
