<div class="max-w-md mx-auto px-4 py-16">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Sign in to OTP</h1>
    <p class="text-gray-500 text-sm">Access your dashboard, publish OOS files, and explore best practices.</p>
  </div>
  <div id="clerk-sign-in" class="flex justify-center"></div>
</div>

<script>
  // If the unauthed visitor was bounced here from a protected page (e.g. /l10),
  // the bouncing route appends ?redirect=<url>. Persist it so the existing
  // localStorage-based post-signin flow respects it.
  (function captureRedirectParam() {
    try {
      var qs = new URLSearchParams(window.location.search);
      var redirectParam = qs.get('redirect');
      if (redirectParam && redirectParam.startsWith('/')) {
        localStorage.setItem('otp_return_after_signin', redirectParam);
      }
    } catch (_) { /* localStorage may be blocked */ }
  })();

  (function waitForClerk() {
    if (!window.Clerk) return setTimeout(waitForClerk, 100);
    window.Clerk.load().then(function() {
      var returnUrl = localStorage.getItem('otp_return_after_signin') || '/dashboard';
      if (window.Clerk.user) {
        localStorage.removeItem('otp_return_after_signin');
        window.location.href = returnUrl;
        return;
      }
      window.Clerk.mountSignIn(document.getElementById('clerk-sign-in'), {
        afterSignInUrl: returnUrl,
        afterSignUpUrl: '/register',
      });
    }).catch(function() {
      document.getElementById('clerk-sign-in').innerHTML =
        '<div class="text-center py-8">' +
        '<p class="text-gray-500 text-sm mb-4">Authentication is loading...</p>' +
        '<button onclick="location.reload()" class="px-4 py-2 bg-otp-500 text-white rounded-lg text-sm hover:bg-otp-400">Retry</button>' +
        '</div>';
    });
  })();
</script>
