<%# /machine-commerce -- v7 layout (light, editorial). The agent economy discovery layer.
    Rendered via reply.view('pages/machine-commerce', data, { layout: 'layouts/v7' }). %>
<style>
  .mc-peek {
    animation:mc-peek 8s ease-in-out infinite;
  }
  @keyframes mc-peek {
    0%,100%{ transform:translateY(0); }
    50%{ transform:translateY(-14px); }
  }
  .mc-step-line {
    position:absolute; top:27px; left:calc(50% + 34px); right:calc(-50% + 34px);
    height:2px; background:var(--line);
  }
  @media (max-width:767px){ .mc-step-line{ display:none; } }
  @media (prefers-reduced-motion:reduce){ .mc-peek{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1180px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--orange);"></span>Machine Commerce
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.3rem,4.6vw,3.7rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
          The agent economy needs a <span class="text-[var(--orange-deep)]">discovery layer.</span>
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[35rem] mx-auto md:mx-0 mt-5">
          AI agents are starting to transact with each other autonomously. Before an agent works with another organization, it needs to understand how that organization operates.
        </p>
        <p class="font-mono text-[13px] text-[var(--ink-mute)] mt-4">
          OTP is the layer where agents discover organizations they can trust.
        </p>
        <div class="flex flex-wrap gap-3 justify-center md:justify-start mt-8">
          <a href="/publish" class="btn-primary px-8 py-4 text-[16px]">Position your organization &rarr;</a>
          <a href="#agent-economy" class="btn-ghost px-8 py-4 text-[16px]">Learn more</a>
        </div>
      </div>
      <div class="relative shrink-0" style="width:240px; max-width:58vw;">
        <img src="/public/orgy-cut.png" alt="Ollie, the OTP mascot"
             class="mc-peek block w-full" style="filter:drop-shadow(0 22px 34px rgba(20,22,28,.2));">
      </div>
    </div>
  </div>
</section>

<!-- ================= THE SHIFT ================= -->
<section id="agent-economy" class="bg-[var(--grey)]">
  <div class="max-w-[720px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">The shift</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.12]"
        style="font-size:clamp(1.8rem,3.6vw,2.7rem); font-weight:700;">
      Agents are becoming the customer.
    </h2>
    <div class="mt-6 space-y-4">
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.75]">
        Today, a human decides which vendors to work with. They read reviews, check references, get on a call. Tomorrow, an AI agent will make that evaluation, autonomously, at scale, in seconds.
      </p>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.75]">
        But an agent can't get on a call. It can't read body language. It can't ask a friend for a referral. <strong class="text-[var(--ink)] font-semibold">It needs structured, machine-readable intelligence about how an organization operates.</strong>
      </p>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.75]">
        Before an agent transacts with another organization, it needs answers: How do they coordinate internally? What are their failure modes? How do they handle escalations? What's their track record?
      </p>
      <p class="text-[16px] text-[var(--ink)] font-semibold leading-[1.75]">
        The organization that publishes this intelligence is the one that gets discovered. The one that doesn't is invisible to the agent economy.
      </p>
    </div>
  </div>
</section>

<!-- ================= THE DISCOVERY LAYER ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="max-w-[640px] mb-12">
      <div class="eyebrow mb-4">The discovery layer</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        The Intelligence Graph is built for agents.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        It's not just a website for humans to browse. It's the protocol layer where agents discover organizations they can coordinate with.
      </p>
    </div>

    <%
      const mcFeatures = [
        { title:'Machine-Readable Trust Profiles', body:'Published OOS files are structured, queryable, and comparable. An agent doesn’t need to interpret a website. It reads claims, evidence, and confidence scores directly.' },
        { title:'Compatibility Signals',           body:'Claim similarities reveal coordination compatibility. When two organizations share similar patterns, their agents already speak the same language.' },
        { title:'Semantic Search',                 body:'Agents search across all published claims using natural language. "Find organizations with documented agent escalation patterns" returns ranked, relevant results.' },
        { title:'Track Record Visibility',         body:'Quality tiers, agentic maturity levels, and evidence distributions give agents a quantified view of organizational capability.' },
      ];
    %>
    <div class="grid sm:grid-cols-2 gap-5">
      <% for (const f of mcFeatures) { %>
      <div class="card lift p-7">
        <h3 class="font-display text-[var(--ink)] text-[1.15rem] font-bold mb-2"><%= f.title %></h3>
        <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]"><%= f.body %></p>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ================= HOW IT WORKS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[980px] mx-auto px-6 py-20 sm:py-24">
    <div class="text-center mb-14">
      <div class="eyebrow mb-4">How it works</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        Three steps to agent-to-agent discovery.
      </h2>
    </div>

    <%
      const mcSteps = [
        { n:'1', title:'Publish',  body:'Organization publishes its OOS with structured claims about how it operates. Coordination patterns, authority boundaries, failure modes, all machine-readable.' },
        { n:'2', title:'Discover', body:'Agents query the Intelligence Graph for compatible organizations. Similarity scores, claim overlap, and evidence quality guide the selection.' },
        { n:'3', title:'Transact', body:'Armed with coordination intelligence, agents engage with confidence. They understand the other org’s patterns, boundaries, and escalation paths before the first interaction.' },
      ];
    %>
    <div class="grid md:grid-cols-3 gap-8">
      <% mcSteps.forEach(function(s, i){ %>
      <div class="relative text-center">
        <% if (i < 2) { %><div class="mc-step-line"></div><% } %>
        <div class="relative font-display flex items-center justify-center text-white mx-auto mb-5"
             style="width:54px; height:54px; border-radius:15px; font-weight:800; font-size:20px; background:linear-gradient(135deg,var(--orange),var(--orange-deep)); z-index:1;">
          <%= s.n %>
        </div>
        <h3 class="font-display text-[var(--ink)] text-[1.2rem] font-bold mb-2"><%= s.title %></h3>
        <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]"><%= s.body %></p>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= OPEN STANDARDS ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[860px] mx-auto px-6 py-20 sm:py-24">
    <div class="text-center mb-12">
      <div class="eyebrow mb-4">Open infrastructure</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        Built on open standards. No lock-in.
      </h2>
    </div>

    <%
      const mcStandards = [
        { label:'OOS Format',   note:'CC BY 4.0. Open, portable, yours.' },
        { label:'MCP Protocol', note:'Native agent integration via Model Context Protocol.' },
        { label:'API Access',   note:'REST + MCP server. Use whichever fits.' },
        { label:'No Lock-In',   note:'Your OOS is yours. Export anytime, use anywhere.' },
      ];
    %>
    <div class="grid sm:grid-cols-2 gap-4">
      <% for (const s of mcStandards) { %>
      <div class="card p-6 flex items-start gap-4">
        <span class="tick mt-1.5 shrink-0" style="background:var(--green);"></span>
        <div>
          <div class="font-display text-[var(--ink)] text-[1.02rem] font-bold"><%= s.label %></div>
          <div class="text-[13.5px] text-[var(--ink-soft)] leading-[1.6] mt-1"><%= s.note %></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(2rem,4.4vw,3.2rem); font-weight:800;">
      Position your organization for the agent economy.
    </h2>
    <p class="text-[17px] leading-[1.6] max-w-[35rem] mx-auto mt-6" style="color:#5a2a06;">
      The organizations that publish their coordination intelligence today will be the ones agents discover tomorrow.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/publish" class="btn-ink px-8 py-4 text-[16px]">Publish your OOS &rarr;</a>
      <a href="/graph" class="btn-ghost px-8 py-4 text-[16px]" style="border-color:rgba(20,22,28,.3);">Explore the Intelligence Graph</a>
    </div>
  </div>
</section>
