<%-
  /* /coaches — public Founder Certified Coach directory.
     Variables: coaches[], coachCount, remainingSeats */
%>
<style>
  .ccard:hover .ccard-img { transform: scale(1.04); }
</style>

<!-- Hero -->
<section class="bg-otp-950 relative overflow-hidden pt-28 pb-14 sm:pt-32 sm:pb-20">
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background-image: linear-gradient(to right, rgba(255,255,255,0.4) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 80px 80px;"></div>
  <div class="pointer-events-none absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full opacity-50 blur-3xl" style="background: radial-gradient(circle, rgba(212,173,50,0.18), transparent 60%);"></div>

  <div class="relative max-w-5xl mx-auto px-6 sm:px-8 text-center">
    <!-- Founder badge -->
    <div class="flex justify-center mb-6">
      <img src="/public/images/founder-coach-badge-preview.png" alt="OTP Founder Certified Coach badge" class="h-32 sm:h-40 w-auto drop-shadow-[0_12px_32px_rgba(212,173,50,0.45)]"/>
    </div>

    <div class="inline-flex items-center gap-2 rounded-full px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-200 mb-5 border border-amber-400/30 bg-amber-400/10">
      <span aria-hidden>★</span>
      <span>The Founding 25 cohort</span>
    </div>

    <h1 class="font-extrabold leading-[1.0] tracking-tight text-white mb-5" style="font-size: clamp(2.5rem, 5.5vw, 4rem);">
      Founder Certified Coaches.
    </h1>
    <p class="mx-auto max-w-2xl text-base sm:text-lg leading-relaxed text-gray-300 mb-7">
      Twenty-five coaches helping shape the operating protocol for AI-augmented teams. Each one runs OTP with their clients. Each one shapes what ships next.
    </p>

    <!-- Cohort progress -->
    <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 text-sm">
      <div class="flex items-center gap-1.5">
        <span class="text-amber-300 font-bold text-lg"><%= coachCount %></span>
        <span class="text-gray-400">of 25 seats filled</span>
      </div>
      <span class="text-white/20">·</span>
      <a href="/coach" class="text-amber-200 hover:text-amber-100 font-semibold underline">Claim a seat →</a>
    </div>
  </div>
</section>

<!-- Coach grid -->
<% if (coaches && coaches.length > 0) { %>
  <section class="bg-gradient-to-b from-white to-amber-50 py-14 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% coaches.forEach(function(c){
             var loc = [c.geo_city, c.geo_state, c.geo_country].filter(function(p){return p && p.trim();}).join(', ');
             var avatar = c.avatar_url || c.photo_url;
             var initials = (c.display_name || '?').split(' ').map(function(p){return p[0]||'';}).join('').substring(0,2).toUpperCase();
             var bioPreview = c.bio ? (c.bio.length > 140 ? c.bio.substring(0, 140) + '…' : c.bio) : '';
             var tags = Array.isArray(c.expertise_tags) ? c.expertise_tags.slice(0,3) : [];
        %>
          <a href="/expert/<%= c.slug %>" class="ccard group block bg-white rounded-2xl border-2 border-amber-200/60 hover:border-amber-400 hover:shadow-xl hover:shadow-amber-200/40 transition-all overflow-hidden">
            <!-- Top: avatar + badge -->
            <div class="relative bg-gradient-to-br from-amber-50 to-orange-50 p-5 pb-4">
              <!-- Small founder badge top-right -->
              <img src="/public/images/founder-coach-badge-sm.png" alt="" class="absolute top-3 right-3 h-12 w-auto drop-shadow-md"/>
              <div class="flex items-center gap-4">
                <% if (avatar) { %>
                  <div class="relative overflow-hidden rounded-full h-16 w-16 ring-2 ring-amber-200 flex-shrink-0">
                    <img src="<%= avatar %>" alt="<%= c.display_name %>" class="ccard-img w-full h-full object-cover transition-transform duration-300"/>
                  </div>
                <% } else { %>
                  <div class="flex-shrink-0 h-16 w-16 rounded-full bg-gradient-to-br from-amber-300 to-orange-400 flex items-center justify-center text-white text-xl font-extrabold ring-2 ring-amber-200">
                    <%= initials %>
                  </div>
                <% } %>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-bold text-gray-900 truncate"><%= c.display_name %></h3>
                  <% if (loc) { %>
                    <div class="text-xs text-gray-500 truncate"><%= loc %></div>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Bio + tags -->
            <div class="p-5 pt-4">
              <% if (c.headline) { %>
                <p class="text-sm font-semibold text-gray-900 mb-2"><%= c.headline %></p>
              <% } %>
              <% if (bioPreview) { %>
                <p class="text-xs text-gray-600 leading-relaxed mb-3"><%= bioPreview %></p>
              <% } %>
              <% if (tags && tags.length > 0) { %>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <% tags.forEach(function(t){ %>
                    <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-700 text-[10px] font-medium"><%= t %></span>
                  <% }); %>
                </div>
              <% } %>
              <div class="flex items-center justify-between pt-2 border-t border-gray-100 mt-2">
                <div class="text-[11px] font-bold uppercase tracking-wider text-amber-700">★ Founder Certified</div>
                <div class="text-xs text-gray-500 group-hover:text-amber-700 transition-colors">View profile →</div>
              </div>
            </div>
          </a>
        <% }); %>
      </div>

      <!-- CTA strip below grid -->
      <% if (remainingSeats > 0) { %>
        <div class="mt-12 text-center bg-white rounded-2xl border-2 border-amber-300 p-8 max-w-2xl mx-auto">
          <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2">
            <%= remainingSeats %> Founding seat<%= remainingSeats === 1 ? '' : 's' %> still open.
          </h2>
          <p class="text-sm text-gray-600 mb-5">
            Founding 25 coaches keep the badge, the perpetual attribution on every client they bring, and a vote on what ships next.
          </p>
          <a href="/coach" class="inline-flex items-center gap-2 px-7 py-3 rounded-xl bg-gray-900 hover:bg-gray-800 text-white font-bold transition-transform hover:scale-[1.02]">
            See the Coach playbook <span aria-hidden>→</span>
          </a>
        </div>
      <% } else { %>
        <div class="mt-12 text-center bg-gray-900 rounded-2xl p-8 max-w-2xl mx-auto text-white">
          <h2 class="text-xl sm:text-2xl font-bold mb-2">Founding 25 is full.</h2>
          <p class="text-sm text-gray-300">
            The next cohort opens after we ship the v1 protocol. Want a heads-up?
          </p>
          <a href="/coach" class="inline-flex items-center gap-2 mt-4 px-6 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-400 text-gray-900 font-bold">Join the waitlist</a>
        </div>
      <% } %>

    </div>
  </section>
<% } else { %>
  <!-- Empty state (shouldn't normally appear once at least one coach is claimed) -->
  <section class="bg-gradient-to-b from-white to-amber-50 py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Founding 25 in formation.</h2>
      <p class="text-base text-gray-600 mb-6">The cohort is filling. Want to be the first?</p>
      <a href="/coach" class="inline-flex items-center gap-2 px-7 py-3 rounded-xl bg-gray-900 hover:bg-gray-800 text-white font-bold">See the playbook →</a>
    </div>
  </section>
<% } %>
