<%# /coaches -- v7 layout (light, editorial). Public Founder Certified
    Coach directory. Variables: coaches[], coachCount, remainingSeats %>
<style>
  .cd-card:hover .cd-img { transform:scale(1.05); }
  .cd-img { transition:transform .35s cubic-bezier(.16,1,.3,1); }
  .cd-float { animation:cd-float 6s ease-in-out infinite; }
  @keyframes cd-float { 0%,100%{transform:translateY(0) rotate(-2deg);} 50%{transform:translateY(-10px) rotate(3deg);} }
  @media (prefers-reduced-motion:reduce){ .cd-float{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[860px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20 text-center">
    <div class="relative inline-block mb-6">
      <img src="/public/images/founder-coach-badge-preview.png" alt="OTP Founder Certified Coach badge"
           class="h-32 sm:h-40 w-auto" style="filter:drop-shadow(0 14px 30px rgba(20,22,28,.2));">
      <img src="/public/hand-1.png" alt="" aria-hidden="true"
           class="cd-float absolute -right-9 -bottom-3" style="width:62px; height:auto;">
    </div>
    <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center">
      <span class="tick" style="background:var(--orange);"></span>The Founding 25 cohort
    </div>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(2.3rem,4.6vw,3.6rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
      Founder Certified Coaches.
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mx-auto mt-5">
      Twenty-five coaches helping shape the operating protocol for AI-augmented teams. Each one runs OTP with their clients. Each one shapes what ships next.
    </p>
    <div class="inline-flex items-center gap-3 mt-8 px-5 py-2.5 rounded-full bg-[var(--card)] border border-[var(--line)]">
      <span class="font-display text-[var(--orange-deep)] font-bold text-[18px]"><%= coachCount %></span>
      <span class="text-[14px] text-[var(--ink-soft)]">of 25 seats filled</span>
      <span class="text-[var(--ink-mute)]">&middot;</span>
      <a href="/coach" class="text-[14px] link-u text-[var(--ink)]">Claim a seat &rarr;</a>
    </div>
  </div>
</section>

<!-- ================= COACH GRID ================= -->
<% if (coaches && coaches.length > 0) { %>
<section class="bg-[var(--grey)]">
  <div class="max-w-[1180px] mx-auto px-6 py-20 sm:py-24">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% coaches.forEach(function(c){
           var loc = [c.geo_city, c.geo_state, c.geo_country].filter(function(p){return p && p.trim();}).join(', ');
           var avatar = c.avatar_url || c.photo_url;
           var initials = (c.display_name || '?').split(' ').map(function(p){return p[0]||'';}).join('').substring(0,2).toUpperCase();
           var bioPreview = c.bio ? (c.bio.length > 140 ? c.bio.substring(0, 140) + '…' : c.bio) : '';
           var tags = Array.isArray(c.expertise_tags) ? c.expertise_tags.slice(0,3) : [];
      %>
        <a href="/expert/<%= c.slug %>" class="cd-card card lift block overflow-hidden">
          <!-- Top: avatar + badge -->
          <div class="relative p-5 pb-4" style="background:linear-gradient(135deg,rgba(255,122,26,.08),rgba(255,122,26,.02));">
            <img src="/public/images/founder-coach-badge-sm.png" alt="" class="absolute top-3 right-3 h-12 w-auto" style="filter:drop-shadow(0 4px 8px rgba(20,22,28,.12));">
            <div class="flex items-center gap-4">
              <% if (avatar) { %>
                <div class="relative overflow-hidden rounded-full h-16 w-16 flex-shrink-0" style="box-shadow:0 0 0 2px rgba(255,122,26,.3);">
                  <img src="<%= avatar %>" alt="<%= c.display_name %>" class="cd-img w-full h-full object-cover">
                </div>
              <% } else { %>
                <div class="flex-shrink-0 h-16 w-16 rounded-full flex items-center justify-center text-white font-display text-[20px] font-extrabold"
                     style="background:linear-gradient(135deg,var(--orange),var(--orange-deep)); box-shadow:0 0 0 2px rgba(255,122,26,.3);">
                  <%= initials %>
                </div>
              <% } %>
              <div class="flex-1 min-w-0">
                <h3 class="font-display text-[16px] font-bold text-[var(--ink)] truncate"><%= c.display_name %></h3>
                <% if (loc) { %>
                  <div class="font-mono text-[11px] text-[var(--ink-mute)] truncate mt-0.5"><%= loc %></div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Bio + tags -->
          <div class="p-5 pt-4">
            <% if (c.headline) { %>
              <p class="text-[14px] font-semibold text-[var(--ink)] mb-2 leading-snug"><%= c.headline %></p>
            <% } %>
            <% if (bioPreview) { %>
              <p class="text-[13px] text-[var(--ink-soft)] leading-[1.6] mb-3"><%= bioPreview %></p>
            <% } %>
            <% if (tags && tags.length > 0) { %>
              <div class="flex flex-wrap gap-1.5 mb-3">
                <% tags.forEach(function(t){ %>
                  <span class="px-2 py-0.5 rounded-full bg-[var(--grey)] text-[var(--ink-soft)] font-mono text-[10px]"><%= t %></span>
                <% }); %>
              </div>
            <% } %>
            <div class="flex items-center justify-between pt-3 border-t border-[var(--line)] mt-2">
              <div class="eyebrow" style="color:var(--orange-deep);">&#9733; Founder Certified</div>
              <div class="text-[12px] text-[var(--ink-mute)]">View profile &rarr;</div>
            </div>
          </div>
        </a>
      <% }); %>
    </div>

    <!-- CTA strip below grid -->
    <% if (remainingSeats > 0) { %>
      <div class="card p-8 sm:p-10 mt-12 max-w-[640px] mx-auto text-center">
        <h2 class="font-display text-[var(--ink)] leading-tight" style="font-size:clamp(1.4rem,2.6vw,1.9rem); font-weight:700;">
          <%= remainingSeats %> Founding seat<%= remainingSeats === 1 ? '' : 's' %> still open.
        </h2>
        <p class="text-[14.5px] text-[var(--ink-soft)] leading-[1.65] mt-3 mb-6">
          Founding 25 coaches keep the badge, the perpetual attribution on every client they bring, and a vote on what ships next.
        </p>
        <a href="/coach" class="btn-ink px-7 py-3.5 text-[15px] inline-block">See the Coach playbook &rarr;</a>
      </div>
    <% } else { %>
      <div class="card p-8 sm:p-10 mt-12 max-w-[640px] mx-auto text-center" style="background:var(--ink);">
        <h2 class="font-display text-white leading-tight" style="font-size:clamp(1.4rem,2.6vw,1.9rem); font-weight:700;">
          Founding 25 is full.
        </h2>
        <p class="text-[14.5px] leading-[1.65] mt-3 mb-6" style="color:rgba(255,255,255,.7);">
          The next cohort opens after we ship the v1 protocol. Want a heads-up?
        </p>
        <a href="/coach" class="btn-primary px-7 py-3.5 text-[15px] inline-block">Join the waitlist</a>
      </div>
    <% } %>
  </div>
</section>
<% } else { %>
<!-- Empty state -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[640px] mx-auto px-6 py-24 sm:py-28 text-center">
    <h2 class="font-display text-[var(--ink)] leading-tight" style="font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700;">
      Founding 25 in formation.
    </h2>
    <p class="text-[15px] text-[var(--ink-soft)] leading-[1.65] mt-4 mb-7">The cohort is filling. Want to be the first?</p>
    <a href="/coach" class="btn-ink px-7 py-3.5 text-[15px] inline-block">See the playbook &rarr;</a>
  </div>
</section>
<% } %>
