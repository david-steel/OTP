<section class="bg-gray-50 min-h-screen">
<div class="max-w-7xl mx-auto px-6 sm:px-8 py-8">

  <!-- Page header card -->
  <%
    // Coverage year: prefer a year embedded in the plan title (e.g. "Operating Plan 2026"),
    // fall back to plan.createdAt year. This lets users encode the year in the title
    // without requiring a DB migration; the copy-forward action below sets the title
    // explicitly with the new year.
    var coverageYear = null;
    if (plan) {
      var yearMatch = (plan.title || '').match(/(20\d{2})/);
      coverageYear = yearMatch ? yearMatch[1] : new Date(plan.createdAt).getFullYear().toString();
    }
  %>
  <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-7 mb-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-3 mb-1">
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-none">Plan</h1>
          <% if (plan) { %>
            <span class="text-sm font-semibold text-gray-700 bg-gray-100 border border-gray-200 px-2.5 py-1 rounded-md"><%= coverageYear %></span>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-otp-700 bg-otp-50 border border-otp-100 px-2 py-1 rounded"><%= plan.status %></span>
          <% } %>
        </div>
        <p class="text-sm text-gray-500 leading-relaxed max-w-2xl">A live, structured system that turns strategy into execution by aligning people, agents, and operating rules around measurable outcomes.</p>
      </div>
      <% if (plan) { %>
        <div class="flex items-start gap-3">
          <div class="text-right text-xs text-gray-500">
            <div class="font-semibold text-gray-700 mb-0.5">Last synced</div>
            <%= plan.lastSyncedToOosAt ? new Date(plan.lastSyncedToOosAt).toLocaleString() : 'never' %>
          </div>
          <!-- Copy plan forward to next year — calls POST /api/v1/oos-operating-plan/copy-forward -->
          <button id="btn-copy-forward" data-plan-id="<%= plan.id %>" data-current-year="<%= coverageYear %>"
                  class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:border-otp-400 hover:text-otp-700 transition-colors"
                  title="Archive this plan and create a fresh copy for next year">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/>
            </svg>
            Copy to next year
          </button>
        </div>
      <% } %>
    </div>
  </div>

  <% if (!plan) { %>

    <!-- Empty state: no plan yet -->
    <div class="bg-white border border-gray-200 rounded-2xl p-12 text-center">
      <div class="mx-auto w-12 h-12 rounded-full bg-otp-50 flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-otp-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <h2 class="text-xl font-bold text-gray-900 mb-2">No operating plan yet</h2>
      <p class="text-gray-600 text-sm mb-6 max-w-md mx-auto leading-relaxed">Create your organization's first Plan. We'll seed the eight standard sections and you can fill them in or auto-generate from your existing OOS.</p>
      <button id="btn-create-plan" type="button" class="px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-600 text-sm transition-colors">
        Create Plan
      </button>
      <div id="create-plan-msg" class="mt-3 text-sm text-gray-500"></div>
      <script>
        (function() {
          var btn = document.getElementById('btn-create-plan');
          var msg = document.getElementById('create-plan-msg');
          if (!btn) return;
          btn.addEventListener('click', async function() {
            btn.disabled = true;
            msg.textContent = 'Creating...';
            try {
              var res = await fetch('/dashboard/oos-operating-plan/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: '{}',
              });
              if (res.redirected) { window.location.href = res.url; return; }
              if (res.ok) { window.location.reload(); return; }
              var data = await res.json().catch(function() { return null; });
              msg.textContent = 'Error: ' + (data && data.error && data.error.message ? data.error.message : ('HTTP ' + res.status));
              btn.disabled = false;
            } catch (e) {
              msg.textContent = 'Error: ' + e.message;
              btn.disabled = false;
            }
          });
        })();
      </script>
    </div>

  <% } else { %>

    <!-- Plan header actions toolbar -->
    <%
      // Show the "Seed Sneeze It example" button only when:
      //   1. The user is a super admin (sanity gate, server enforces too)
      //   2. NONE of the 4 strategic sections already has any content
      //      (the seed endpoint refuses if any does — surface that as hidden button instead of error)
      var strategicSeedKeys = ['foundation', 'market_command', 'destination', 'annual_game_plan'];
      var strategicSeedable = isSuperAdmin && sections.every(function(sec) {
        if (strategicSeedKeys.indexOf(sec.sectionKey) === -1) return true;
        var c = (sec.contentJson && typeof sec.contentJson === 'object') ? sec.contentJson : {};
        return !Object.values(c).some(function(v) { return v !== null && v !== undefined && String(v).trim() !== ''; });
      });
    %>
    <div class="bg-white rounded-2xl border border-gray-200 p-4 mb-6 flex flex-wrap gap-2 text-xs">
      <a href="/dashboard/ceo" class="px-3 py-1.5 bg-white text-otp-700 border border-otp-300 rounded-lg hover:bg-otp-50 transition-colors font-semibold">CEO Dashboard &rarr;</a>
      <button id="btn-generate" class="px-3 py-1.5 bg-otp-50 text-otp-700 border border-otp-200 rounded-lg hover:bg-otp-100 transition-colors font-medium" data-action="generate" data-plan-id="<%= plan.id %>">Generate 90-Day Plan</button>
      <button id="btn-recalc" class="px-3 py-1.5 bg-gray-50 text-gray-700 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors font-medium" data-action="recalculate" data-plan-id="<%= plan.id %>">Recalculate Assignments</button>
      <button id="btn-preview" class="px-3 py-1.5 bg-blue-50 text-blue-700 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors font-medium" data-action="preview" data-plan-id="<%= plan.id %>">Preview OOS Update</button>
      <% if (isSuperAdmin) { %>
        <button id="btn-push" class="px-3 py-1.5 bg-amber-50 text-amber-800 border border-amber-300 rounded-lg hover:bg-amber-100 transition-colors font-semibold" data-action="push" data-plan-id="<%= plan.id %>">Push to OOS</button>
      <% } else { %>
        <button class="px-3 py-1.5 bg-gray-100 text-gray-400 border border-gray-200 rounded-lg cursor-not-allowed" title="Super admin only">Push to OOS (super-admin)</button>
      <% } %>
      <button id="btn-export" class="px-3 py-1.5 bg-gray-50 text-gray-700 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors font-medium" data-action="export" data-plan-id="<%= plan.id %>">Export / Copy Markdown</button>
      <% if (strategicSeedable) { %>
        <button id="btn-seed-example"
                class="px-3 py-1.5 bg-purple-50 text-purple-800 border border-purple-300 rounded-lg hover:bg-purple-100 transition-colors font-semibold"
                title="One-click: populate the 4 strategic sections with the Sneeze It example content from /plan">
          ✦ Seed Sneeze It example
        </button>
      <% } %>
    </div>

    <div id="action-msg" class="hidden mb-4 px-3 py-2 rounded-lg text-sm"></div>

    <!-- Preview-sync panel (hidden until Preview clicked) -->
    <div id="preview-panel" class="hidden mb-6 bg-white border-2 border-blue-200 rounded-lg p-4">
      <div class="flex items-baseline justify-between mb-3">
        <h3 class="font-semibold text-base">Preview: claims that would push to OOS</h3>
        <button id="preview-close" class="text-xs text-gray-500 hover:text-gray-700">Close</button>
      </div>
      <div id="preview-summary" class="text-xs text-gray-600 mb-3"></div>
      <div id="preview-claims" class="space-y-2 max-h-96 overflow-auto"></div>
      <div class="mt-3 text-xs text-gray-500" id="preview-event-id"></div>
    </div>

    <!-- Glossary: system-level terms used across the plan -->
    <details class="mb-6 bg-blue-50 border border-blue-200 rounded-lg overflow-hidden">
      <summary class="px-4 py-2 cursor-pointer hover:bg-blue-100 text-sm font-semibold text-blue-900">
        Terms used in this plan (click to expand)
      </summary>
      <div class="px-4 py-3 border-t border-blue-200 text-xs text-blue-900 space-y-2">
        <div><strong>OOS (Organizational Operating System):</strong> The shared file that captures how this organization actually works: rules, authority boundaries, escalation paths, and evidence-backed operating practices that humans and agents both read.</div>
        <div><strong>OOS File:</strong> A single instance of an OOS for one organization. Has a draft and (optionally) a published version.</div>
        <div><strong>Operating Plan:</strong> This page. The strategy layer above the OOS. Sections capture intent; selected items get pushed into the OOS as durable rules.</div>
        <div><strong>Claim (OOS):</strong> A structured, evidence-backed statement about how the organization operates. Contains a rule, a why, a failure mode, a confidence level, and an evidence type.</div>
        <div><strong>Section:</strong> One of the 8 standard parts of the Operating Plan (Core Foundation, Market Command, Destination, Annual Game Plan, 90-Day Execution Engine, Performance Scorecard, Constraints &amp; Leverage Points, Alignment &amp; Accountability).</div>
        <div><strong>Execution Item:</strong> A unit of work tied to a measurable outcome and owned by a specific person or agent. Lives in the 90-Day Execution Engine table.</div>
        <div><strong>Owner Assignment Engine:</strong> The logic that recommends who should be responsible for execution based on roles, agents, and OOS rules.</div>
        <div><strong>Owner Type:</strong> Whether responsibility sits with a human, an agent, both (Hybrid), or no one yet (Unassigned).</div>
        <div><strong>Hybrid Ownership:</strong> A shared responsibility between a human and an agent. Primary owner has authority; secondary backs them up.</div>
        <div><strong>Confidence Level:</strong> A 0-100 score indicating how reliable a claim or assignment is based on available data. Below 70% triggers "needs human assignment."</div>
        <div><strong>Assignment Reason:</strong> A plain-English explanation of why a particular owner was recommended for an item.</div>
        <div><strong>Source References:</strong> The agents, humans, or OOS rules used to justify a recommendation or claim.</div>
        <div><strong>Quarter Label:</strong> The calendar quarter an execution item belongs to (Q1-2026, Q2-2026, etc.). Items never get deleted at quarter end; they keep their quarter and a status like "completed" or "deferred."</div>
        <div><strong>Preview Sync:</strong> A read-only diff that shows which OOS claims would be added or updated if you pushed right now. Saves an audit event but writes nothing.</div>
        <div><strong>Push to OOS / OOS Sync:</strong> The process of converting plan elements into structured operating rules and claims inside the OOS. Super-admin gated because the OOS is load-bearing.</div>
        <div><strong>Sync Event:</strong> An audit-trail entry recording every preview, push, and rollback. Includes before/after snapshots so any change can be traced or reverted.</div>
        <div><strong>Claim-by-claim Revert:</strong> Selectively undo a single pushed claim without rolling back the whole sync. Limited to claims sourced from the Operating Plan.</div>
        <div><strong>KPI Rollup:</strong> Agent-level and user-level KPIs aggregate upward into the Performance Scorecard section. Each owner's metrics show in their own row; the scorecard reads them.</div>
      </div>
    </details>

    <!-- Tabs — functional (JS at bottom of file wires click handlers) -->
    <div class="mb-6 flex items-center gap-6 -mb-px border-b border-gray-200">
      <button type="button" data-tab="vision"   class="plan-tab text-sm font-semibold pb-3 text-gray-900 border-b-2 border-pink-500">Vision</button>
      <button type="button" data-tab="traction" class="plan-tab text-sm font-medium pb-3 text-gray-500 border-b-2 border-transparent hover:text-gray-700">Traction</button>
      <button type="button" data-tab="swot"     class="plan-tab text-sm font-medium pb-3 text-gray-500 border-b-2 border-transparent hover:text-gray-700">SWOT</button>
    </div>

    <%
      // Section distribution across tabs.
      // Vision   = strategic foundation: who we are, where we're going, how we win.
      // Traction = execution layer: 90-day engine, scorecard, accountability + the execution items table.
      // SWOT     = constraints_leverage: bottlenecks/risks/opportunities/required resources.
      var visionKeys   = ['foundation', 'market_command', 'destination', 'annual_game_plan'];
      var tractionKeys = ['ninety_day_engine', 'performance_scorecard', 'alignment_accountability'];
      var swotKeys     = ['constraints_leverage'];

      // Per-tab left/right column split (2/3 + 1/3 grid).
      var visionLeftKeys  = ['foundation', 'market_command'];
      var visionRightKeys = ['destination', 'annual_game_plan'];
      var visionLeft  = sections.filter(function(s){ return visionLeftKeys.indexOf(s.sectionKey) !== -1; });
      var visionRight = sections.filter(function(s){ return visionRightKeys.indexOf(s.sectionKey) !== -1; });

      var tractionLeftKeys  = ['ninety_day_engine', 'performance_scorecard'];
      var tractionRightKeys = ['alignment_accountability'];
      var tractionLeft  = sections.filter(function(s){ return tractionLeftKeys.indexOf(s.sectionKey) !== -1; });
      var tractionRight = sections.filter(function(s){ return tractionRightKeys.indexOf(s.sectionKey) !== -1; });

      var swotSections = sections.filter(function(s){ return swotKeys.indexOf(s.sectionKey) !== -1; });

      // Section metadata — tagline + field schema per section key.
      // Field key is the storage slot in content_json; never change it once
      // data exists, or migrate explicitly. Used by the partial to render
      // both view-mode (definition list) and editor-mode (form inputs).
      var sectionMeta = {
        foundation: {
          tagline: "The non-negotiable identity of the organization: why it exists, how it operates, and who it serves.",
          fields: [
            { label: "Purpose", desc: "The fundamental reason the organization exists beyond profit.", key: "purpose", multiline: true },
            { label: "Mission", desc: "What the organization does daily to fulfill its purpose.", key: "mission", multiline: true },
            { label: "Values", desc: "The standards that guide decisions and behavior. One per line.", key: "values", multiline: true },
            { label: "Ideal Customer", desc: "The specific type of customer the organization is built to serve best.", key: "ideal_customer", multiline: true },
          ],
        },
        market_command: {
          tagline: "Defines how the organization positions itself to win in the market.",
          fields: [
            { label: "Category", desc: "The space the organization competes in.", key: "category", multiline: false },
            { label: "Unique Advantage", desc: "What the organization does better or differently than competitors.", key: "unique_advantage", multiline: true },
            { label: "Brand Promise", desc: "The consistent result customers can expect.", key: "brand_promise", multiline: true },
            { label: "Proof Points", desc: "Evidence that validates the organization's claims. One per line.", key: "proof_points", multiline: true },
          ],
        },
        destination: {
          tagline: "The long-term target that aligns all decisions and execution.",
          fields: [
            { label: "3-5 Year Target", desc: "The measurable future state the organization is building toward.", key: "year_target", multiline: true },
            { label: "3-5 Year Target Year", desc: "The specific year the 3-5 year target lands in (e.g., 2029).", key: "year_target_year", multiline: false },
            { label: "10 Year Target", desc: "The longer-range vision — where the organization is heading 10 years out.", key: "ten_year_target", multiline: true },
            { label: "10 Year Target Year", desc: "The specific year the 10 year target lands in (e.g., 2034).", key: "ten_year_target_year", multiline: false },
            { label: "Revenue Goal", desc: "The financial growth target.", key: "revenue_goal", multiline: false },
            { label: "Profit Goal", desc: "The profitability target.", key: "profit_goal", multiline: false },
            { label: "Defining Metric", desc: "The single most important number that indicates success.", key: "defining_metric", multiline: false },
          ],
        },
        annual_game_plan: {
          tagline: "The strategic focus for the current year.",
          fields: [
            { label: "Primary Objective", desc: "The most important outcome to achieve this year.", key: "primary_objective", multiline: true },
            { label: "Strategic Initiatives", desc: "The key efforts required to reach the objective. One per line.", key: "strategic_initiatives", multiline: true },
            { label: "Key Outcomes", desc: "Specific, measurable results that define success. One per line.", key: "key_outcomes", multiline: true },
          ],
        },
        ninety_day_engine: {
          tagline: "The system that converts strategy into immediate, accountable action.",
          fields: [
            { label: "Quarter Narrative", desc: "Plain-English context for this quarter's plan: theme, key bets, where the leverage is. Per-item details (Owner, Confidence, Status, etc.) live in the 90-Day table below.", key: "quarter_narrative", multiline: true },
            { label: "Quarterly Targets", desc: "The outcomes to achieve in the next 90 days. One per line.", key: "quarterly_targets", multiline: true },
          ],
        },
        performance_scorecard: {
          tagline: "A real-time measurement system that tracks whether execution is working.",
          fields: [
            { label: "Weekly KPIs", desc: "Core numbers tracked consistently. One per line, e.g. 'Dirk: 30 cold emails / day'.", key: "weekly_kpis", multiline: true },
            { label: "Leading Indicators", desc: "Predictive metrics that signal future outcomes. One per line.", key: "leading_indicators", multiline: true },
            { label: "Lagging Indicators", desc: "Results that confirm past performance. One per line.", key: "lagging_indicators", multiline: true },
            { label: "Benchmarks", desc: "Target ranges used to evaluate performance. One per line.", key: "benchmarks", multiline: true },
          ],
        },
        constraints_leverage: {
          tagline: "Identifies what is slowing the organization down and where it can accelerate.",
          fields: [
            { label: "Bottlenecks", desc: "Points of friction limiting progress. One per line.", key: "bottlenecks", multiline: true },
            { label: "Risks", desc: "Potential issues that could impact outcomes. One per line.", key: "risks", multiline: true },
            { label: "Required Resources", desc: "What is needed to execute successfully. One per line.", key: "required_resources", multiline: true },
            { label: "Opportunities", desc: "Areas where the organization can gain advantage quickly. One per line.", key: "opportunities", multiline: true },
          ],
        },
        alignment_accountability: {
          tagline: "Ensures clarity, ownership, and forward movement across the organization.",
          fields: [
            { label: "Key Decisions", desc: "Confirmed choices that guide execution. One per line.", key: "key_decisions", multiline: true },
            { label: "Open Issues", desc: "Unresolved items requiring attention. One per line.", key: "open_issues", multiline: true },
            { label: "Ownership Clarity", desc: "Clear accountability for each initiative.", key: "ownership_clarity", multiline: true },
            { label: "Next Review Date", desc: "When progress and alignment will be reassessed.", key: "next_review_date", multiline: false },
          ],
        },
      };
    %>

    <!-- VISION TAB PANEL -->
    <div data-tab-panel="vision" class="mb-8">
      <div class="grid lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
          <% visionLeft.forEach(function(s) { %>
            <%- include('../partials/plan-section-card', { s: s, sectionMeta: sectionMeta }) %>
          <% }) %>
        </div>
        <div class="space-y-6">
          <% visionRight.forEach(function(s) { %>
            <%- include('../partials/plan-section-card', { s: s, sectionMeta: sectionMeta }) %>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- TRACTION TAB PANEL (hidden by default; 90-Day table is rendered inside, see below) -->
    <div data-tab-panel="traction" class="hidden mb-8">
      <div class="grid lg:grid-cols-3 gap-6 mb-8">
        <div class="lg:col-span-2 space-y-6">
          <% tractionLeft.forEach(function(s) { %>
            <%- include('../partials/plan-section-card', { s: s, sectionMeta: sectionMeta }) %>
          <% }) %>
        </div>
        <div class="space-y-6">
          <% tractionRight.forEach(function(s) { %>
            <%- include('../partials/plan-section-card', { s: s, sectionMeta: sectionMeta }) %>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- SWOT TAB PANEL (hidden by default) -->
    <div data-tab-panel="swot" class="hidden mb-8">
      <div class="bg-otp-50 border border-otp-100 rounded-2xl p-5 mb-6 text-sm text-gray-700 leading-relaxed">
        <p class="font-bold text-gray-900 mb-1">SWOT-style analysis</p>
        <p>The Constraints &amp; Leverage section maps to a SWOT framework. Bottlenecks = weaknesses. Risks = threats. Opportunities = opportunities. Required Resources = what you need to convert weakness into strength. Edit below to refresh the picture.</p>
      </div>
      <div class="space-y-6">
        <% swotSections.forEach(function(s) { %>
          <%- include('../partials/plan-section-card', { s: s, sectionMeta: sectionMeta }) %>
        <% }) %>
      </div>
    </div>


    <!-- 90-Day Execution Engine table — second half of the Traction tab.
         Shares data-tab-panel="traction" with the Traction sections grid above
         so both toggle together when tabs switch. -->
    <div data-tab-panel="traction" class="hidden mb-8">
      <div class="flex items-baseline justify-between mb-3">
        <h2 class="text-sm font-semibold uppercase text-gray-600 tracking-wide">90-Day Execution Engine: <%= currentQuarter %></h2>
        <div class="flex items-center gap-3">
          <span class="text-xs text-gray-500"><%= executionItems.length %> item<%= executionItems.length === 1 ? '' : 's' %></span>
          <button id="btn-add-item" class="px-2.5 py-1 bg-otp-500 text-white rounded text-xs hover:bg-otp-600">+ Add item</button>
        </div>
      </div>

      <!-- Add-item inline form (toggleable) -->
      <div id="add-item-form" class="hidden mb-3 bg-white border-2 border-otp-200 rounded-lg p-4">
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
            <input id="ai-title" type="text" required maxlength="500" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="e.g., Ship pre-signup admin UI">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Quarter</label>
            <input id="ai-quarter" type="text" value="<%= currentQuarter %>" pattern="^Q[1-4]-\d{4}$" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500">
          </div>
        </div>
        <div class="mb-3">
          <label class="block text-xs font-semibold text-gray-700 mb-1">Desired outcome</label>
          <textarea id="ai-outcome" rows="2" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="What does done look like?"></textarea>
        </div>
        <div class="grid grid-cols-3 gap-3 mb-3">
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Priority</label>
            <select id="ai-priority" class="w-full px-3 py-2 border rounded text-sm">
              <option value="critical">Critical</option>
              <option value="high">High</option>
              <option value="medium" selected>Medium</option>
              <option value="low">Low</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Owner type</label>
            <select id="ai-owner-type" class="w-full px-3 py-2 border rounded text-sm">
              <option value="unassigned" selected>Unassigned</option>
              <option value="employee">Employee</option>
              <option value="agent">Agent</option>
              <option value="hybrid">Hybrid (Primary + Secondary)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Due date</label>
            <input id="ai-due" type="date" class="w-full px-3 py-2 border rounded text-sm">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-3" id="ai-owner-fields">
          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-1">Primary owner name</label>
            <input id="ai-owner-name" type="text" maxlength="255" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="e.g., David Steel or Dirk">
          </div>
          <div id="ai-secondary-row" class="hidden">
            <label class="block text-xs font-semibold text-gray-700 mb-1">Secondary owner name (Hybrid only)</label>
            <input id="ai-secondary-name" type="text" maxlength="255" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="e.g., Pepper">
          </div>
        </div>
        <div class="flex items-center gap-2">
          <button id="ai-save" class="px-4 py-2 bg-otp-500 text-white rounded text-sm hover:bg-otp-600 font-medium">Add item</button>
          <button id="ai-cancel" class="px-4 py-2 bg-gray-100 text-gray-700 border rounded text-sm hover:bg-gray-200">Cancel</button>
          <span id="ai-msg" class="text-xs text-gray-500"></span>
        </div>
      </div>
      <div class="bg-white border rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-xs uppercase text-gray-600">
            <tr>
              <th class="text-left px-3 py-2">Priority / Initiative</th>
              <th class="text-left px-3 py-2">Desired outcome</th>
              <th class="text-left px-3 py-2">Recommended owner</th>
              <th class="text-left px-3 py-2">Type</th>
              <th class="text-left px-3 py-2">Confidence</th>
              <th class="text-left px-3 py-2">Why assigned</th>
              <th class="text-left px-3 py-2">Due</th>
              <th class="text-left px-3 py-2">Status</th>
              <th class="text-left px-3 py-2">KPI</th>
              <th class="text-left px-3 py-2"></th>
            </tr>
          </thead>
          <tbody>
            <% if (executionItems.length === 0) { %>
              <tr>
                <td colspan="10" class="px-3 py-12 text-center text-gray-400 text-sm">
                  No execution items yet for <%= currentQuarter %>.<br/>
                  Click <span class="font-semibold">Generate 90-Day Plan</span> to auto-generate from your OOS, agents, employees, and goals (Phase 7).
                </td>
              </tr>
            <% } %>
            <% executionItems.forEach(function(item) { %>
              <tr class="border-t hover:bg-gray-50"
                  data-item-id="<%= item.id %>"
                  data-item-title="<%= item.title %>"
                  data-owner-type="<%= item.assignedOwnerType %>"
                  data-owner-id="<%= item.assignedOwnerId || '' %>"
                  data-owner-name="<%= item.assignedOwnerName || '' %>">
                <td class="px-3 py-2">
                  <div class="font-semibold"><%= item.title %></div>
                  <div class="text-xs">
                    <% var prioBadge = { critical: 'bg-red-100 text-red-700', high: 'bg-amber-100 text-amber-700', medium: 'bg-blue-100 text-blue-700', low: 'bg-gray-100 text-gray-600' }[item.priority] || 'bg-gray-100 text-gray-600'; %>
                    <span class="px-2 py-0.5 rounded-full <%= prioBadge %>"><%= item.priority %></span>
                    <% if (item.createdByAi) { %>
                      <span class="ml-1 px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">AI</span>
                    <% } %>
                  </div>
                </td>
                <td class="px-3 py-2 text-xs text-gray-600 max-w-sm"><%= item.outcome || '—' %></td>
                <td class="px-3 py-2 text-xs"><%= item.assignedOwnerName || '—' %><% if (item.assignedOwnerType === 'hybrid' && item.secondaryOwnerName) { %><br/><span class="text-gray-400">+ <%= item.secondaryOwnerName %></span><% } %></td>
                <td class="px-3 py-2">
                  <% var typeBadge = { employee: 'bg-blue-100 text-blue-700', agent: 'bg-purple-100 text-purple-700', hybrid: 'bg-indigo-100 text-indigo-700', unassigned: 'bg-gray-100 text-gray-500' }[item.assignedOwnerType] || 'bg-gray-100 text-gray-500'; %>
                  <span class="px-2 py-0.5 rounded-full text-xs <%= typeBadge %>"><%= item.assignedOwnerType %></span>
                </td>
                <td class="px-3 py-2 text-xs">
                  <% if (item.confidenceScore !== null && item.confidenceScore !== undefined) { %>
                    <% var c = Math.round(item.confidenceScore); %>
                    <% var confColor = c >= 70 ? 'text-green-600' : c >= 40 ? 'text-amber-600' : 'text-red-600'; %>
                    <span class="font-mono <%= confColor %>"><%= c %>%</span>
                  <% } else { %>
                    <span class="text-gray-400">—</span>
                  <% } %>
                </td>
                <td class="px-3 py-2 text-xs text-gray-600 max-w-xs truncate" title="<%= item.assignmentReason || '' %>"><%= item.assignmentReason || '—' %></td>
                <td class="px-3 py-2 text-xs text-gray-500"><%= item.dueDate ? new Date(item.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '—' %></td>
                <td class="px-3 py-2">
                  <% var statusBadge = { proposed: 'bg-gray-100 text-gray-600', accepted: 'bg-blue-100 text-blue-700', in_progress: 'bg-otp-100 text-otp-700', at_risk: 'bg-amber-100 text-amber-700', completed: 'bg-green-100 text-green-700', deferred: 'bg-gray-100 text-gray-500' }[item.status] || 'bg-gray-100 text-gray-600'; %>
                  <span class="px-2 py-0.5 rounded-full text-xs <%= statusBadge %>"><%= item.status.replace('_', ' ') %></span>
                </td>
                <td class="px-3 py-2 text-xs">
                  <% var attached = (typeof kpisByItemId !== 'undefined' && kpisByItemId[item.id]) ? kpisByItemId[item.id] : []; %>
                  <% if (attached.length === 0) { %>
                    <button class="text-xs text-pink-600 hover:underline" data-action="attach-kpi" data-item-id="<%= item.id %>">+ Attach KPI</button>
                  <% } else { %>
                    <% attached.forEach(function(k) {
                         var pillClass = k.meetsGoal === true ? 'bg-emerald-50 text-emerald-700 border-emerald-200'
                                       : k.meetsGoal === false ? 'bg-red-50 text-red-700 border-red-200'
                                       : 'bg-gray-50 text-gray-600 border-gray-200';
                         var goalText = (k.goalOperator && k.goalValue !== null) ? ({ gte: '≥', lte: '≤', gt: '>', lt: '<', eq: '=' })[k.goalOperator] + ' ' + k.goalValue + (k.unit ? ' ' + k.unit : '') : '';
                         var valText = k.latestValue === null || k.latestValue === undefined ? '—' : k.latestValue + (k.unit ? ' ' + k.unit : '');
                    %>
                      <div class="inline-flex flex-col gap-0.5 mb-1 mr-1">
                        <a href="/dashboard/kpis" class="font-medium text-gray-800 hover:underline" title="View on scoreboard"><%= k.title %></a>
                        <span class="inline-flex items-center gap-1">
                          <span class="px-2 py-0.5 rounded-full border text-[10px] <%= pillClass %>"><%= valText %></span>
                          <% if (goalText) { %><span class="text-[10px] text-gray-400">vs <%= goalText %></span><% } %>
                        </span>
                      </div>
                    <% }) %>
                    <div><button class="text-[10px] text-pink-600 hover:underline" data-action="attach-kpi" data-item-id="<%= item.id %>">+ Add another</button></div>
                  <% } %>
                </td>
                <td class="px-3 py-2">
                  <button class="text-xs text-otp-600 hover:underline" data-action="edit-item" data-item-id="<%= item.id %>" disabled>Edit</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Build status footer -->
    <div class="mt-12 bg-gray-50 border rounded-lg p-4 text-xs text-gray-500">
      <strong class="text-gray-700">Build status:</strong> Phase 2 (UI skeleton) live. Phases 3-7 ship next: section editing, execution-item CRUD, owner-assignment recommender, preview-sync, push-to-OOS, agent context endpoint.
    </div>

  <% } %>
</div>

<script>
  (function() {

    // ---------- Seed Sneeze It example content ----------
    // One-click: populate the 4 strategic sections (foundation, market_command,
    // destination, annual_game_plan) with the Sneeze It content from /plan.
    // Backend refuses if any of those 4 already has content — the button is
    // also server-hidden in that case, so this is belt-and-suspenders.
    var seedBtn = document.getElementById('btn-seed-example');
    if (seedBtn) {
      seedBtn.addEventListener('click', async function() {
        if (!window.confirm(
          'Populate the 4 strategic sections with Sneeze It example content?\n\n' +
          'Sections affected: Foundation, Market Command, Destination, Annual Game Plan.\n' +
          'Source: the /plan public preview (mapped to OOS field keys).\n\n' +
          'Existing content will be preserved — the backend refuses to overwrite. ' +
          'This is a one-shot operation; once any of these sections has content, ' +
          'the button disappears.'
        )) return;

        seedBtn.disabled = true;
        var originalLabel = seedBtn.innerHTML;
        seedBtn.innerHTML = 'Seeding...';
        try {
          var res = await fetch('/dashboard/oos-operating-plan/seed-example', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: '{}',
          });
          var data = await res.json();
          if (!res.ok || !data.ok) {
            window.alert('Seed failed: ' + (data.error && data.error.message ? data.error.message : 'HTTP ' + res.status));
            seedBtn.disabled = false;
            seedBtn.innerHTML = originalLabel;
            return;
          }
          window.location.reload();
        } catch (e) {
          window.alert('Seed failed: ' + e.message);
          seedBtn.disabled = false;
          seedBtn.innerHTML = originalLabel;
        }
      });
    }

    // ---------- Copy plan forward to next year ----------
    // Archives current plan, creates a new active one with year+1 in the title,
    // and duplicates all section content into the new plan. New year = fresh
    // execution items (none copied), same strategic foundation (all copied).
    var copyBtn = document.getElementById('btn-copy-forward');
    if (copyBtn) {
      copyBtn.addEventListener('click', async function() {
        var currentYear = copyBtn.getAttribute('data-current-year');
        var nextYear = parseInt(currentYear, 10) + 1;
        if (!window.confirm(
          'Archive the ' + currentYear + ' plan and create a fresh ' + nextYear + ' plan?\n\n' +
          'Sections will be copied with their content. Execution items will NOT — ' +
          'a new year means new quarterly execution. The ' + currentYear + ' plan will ' +
          'remain in the archive for reference.'
        )) return;

        copyBtn.disabled = true;
        var originalLabel = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="text-xs">Creating ' + nextYear + ' plan...</span>';
        try {
          var res = await fetch('/dashboard/oos-operating-plan/copy-forward', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: '{}',
          });
          var data = await res.json();
          if (!res.ok || !data.ok) {
            window.alert('Copy failed: ' + (data.error && data.error.message ? data.error.message : 'HTTP ' + res.status));
            copyBtn.disabled = false;
            copyBtn.innerHTML = originalLabel;
            return;
          }
          window.location.reload();
        } catch (e) {
          window.alert('Copy failed: ' + e.message);
          copyBtn.disabled = false;
          copyBtn.innerHTML = originalLabel;
        }
      });
    }

    // ---------- Tab switching (Vision / Traction / SWOT) ----------
    // Each tab button has data-tab="vision|traction|swot".
    // Each panel (or panel half) has data-tab-panel matching the same value.
    // Multiple elements can share the same data-tab-panel value (the Traction tab
    // has two: the section grid and the 90-Day Execution Engine table).
    document.querySelectorAll('[data-tab]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tab = btn.getAttribute('data-tab');
        // Hide every panel, then unhide the ones matching this tab.
        document.querySelectorAll('[data-tab-panel]').forEach(function(p) { p.classList.add('hidden'); });
        document.querySelectorAll('[data-tab-panel="' + tab + '"]').forEach(function(p) { p.classList.remove('hidden'); });
        // Update active/inactive styling on the tab buttons themselves.
        document.querySelectorAll('[data-tab]').forEach(function(b) {
          if (b.getAttribute('data-tab') === tab) {
            b.classList.remove('text-gray-500', 'font-medium', 'border-transparent');
            b.classList.add('text-gray-900', 'font-semibold', 'border-pink-500');
          } else {
            b.classList.remove('text-gray-900', 'font-semibold', 'border-pink-500');
            b.classList.add('text-gray-500', 'font-medium', 'border-transparent');
          }
        });
      });
    });

    var msg = document.getElementById('action-msg');
    function showMsg(text, kind) {
      if (!msg) return;
      msg.textContent = text;
      msg.className = 'mb-4 px-3 py-2 rounded-lg text-sm ' + (
        kind === 'error' ? 'bg-red-50 text-red-700 border border-red-200' :
        kind === 'ok' ? 'bg-green-50 text-green-700 border border-green-200' :
        'bg-blue-50 text-blue-700 border border-blue-200'
      );
    }

    // Header action buttons (Generate / Recalculate / Preview / Push / Export)
    document.querySelectorAll('[data-action]').forEach(function(btn) {
      btn.addEventListener('click', async function(e) {
        var action = btn.getAttribute('data-action');
        var planId = btn.getAttribute('data-plan-id');
        e.preventDefault();

        if (action === 'attach-kpi') {
          var itemId = btn.getAttribute('data-item-id');
          var tr = btn.closest('tr[data-item-id]');
          if (!tr) return;
          var ownerType = tr.getAttribute('data-owner-type');
          var ownerId = tr.getAttribute('data-owner-id') || '';
          var ownerName = tr.getAttribute('data-owner-name') || '';
          var itemTitle = tr.getAttribute('data-item-title') || 'execution item';
          if (ownerType === 'unassigned' || !ownerId) {
            alert('Assign an owner to this execution item first, then you can attach a KPI to that owner.');
            return;
          }
          if (ownerType === 'hybrid') ownerType = 'agent'; // hybrid -> attach to primary as agent
          var kpiOwnerType = ownerType === 'employee' ? 'human' : 'agent';
          var defaultTitle = window.prompt('KPI title:', 'KPI for: ' + itemTitle);
          if (!defaultTitle) return;
          try {
            var res = await fetch('/api/v1/kpis', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({
                ownerEntityType: kpiOwnerType,
                ownerExternalId: ownerId,
                title: defaultTitle,
                description: 'Success metric for ' + itemTitle,
                groupName: 'Operating Plan',
                timeGrain: 'weekly',
                aggregationMethod: 'sum',
                executionItemId: itemId,
              }),
            });
            if (!res.ok) {
              var err = await res.json().catch(function() { return {}; });
              alert('Failed to create KPI: ' + (err.error && err.error.message ? err.error.message : res.status));
              return;
            }
            window.location.reload();
          } catch (err) {
            alert('Network error: ' + err.message);
          }
          return;
        }

        if (action === 'recalculate') {
          if (!confirm('Recalculate owner assignments for all unassigned and AI-generated items this quarter? Items you have explicitly edited will not be touched.')) return;
          showMsg('Recalculating...', 'info');
          btn.disabled = true;
          try {
            var res = await fetch('/api/v1/oos-operating-plan/' + planId + '/recalculate-assignments', { method: 'POST' });
            var data = await res.json();
            if (!res.ok || data.error) {
              showMsg('Error: ' + (data.error?.message || 'recalculate failed'), 'error');
              btn.disabled = false;
              return;
            }
            showMsg(
              'Considered ' + data.itemsConsidered + ' items: ' + data.recommended +
              ' assigned, ' + data.lowConfidence + ' need human review (confidence < 70%), ' +
              data.unassigned + ' unassignable. Reloading...',
              'ok'
            );
            setTimeout(function() { window.location.reload(); }, 1200);
          } catch (err) {
            showMsg('Error: ' + err.message, 'error');
            btn.disabled = false;
          }
          return;
        }

        if (action === 'preview') {
          showMsg('Building preview...', 'info');
          btn.disabled = true;
          try {
            var res = await fetch('/api/v1/oos-operating-plan/' + planId + '/preview-sync', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({}),
            });
            var data = await res.json();
            if (!res.ok || data.error) {
              showMsg('Error: ' + (data.error?.message || 'preview failed'), 'error');
              btn.disabled = false;
              return;
            }
            renderPreview(data);
            showMsg('Preview ready: ' + data.summary.total + ' claim' + (data.summary.total === 1 ? '' : 's') + '.', 'ok');
          } catch (err) {
            showMsg('Error: ' + err.message, 'error');
          } finally {
            btn.disabled = false;
          }
          return;
        }

        if (action === 'push') {
          if (!confirm('Push this quarter\'s execution items into the OOS as structured claims? This is a load-bearing write. Make sure you have run Preview first and reviewed what would change.')) return;
          if (!confirm('SECOND CONFIRM: This writes to the OOS. Reverting is per-claim and audit-logged but cannot un-publish. Proceed?')) return;
          showMsg('Pushing to OOS...', 'info');
          btn.disabled = true;
          try {
            var res = await fetch('/api/v1/oos-operating-plan/' + planId + '/push-to-oos', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({}),
            });
            var data = await res.json();
            if (!res.ok || data.error) {
              showMsg('Error: ' + (data.error?.message || 'push failed'), 'error');
              btn.disabled = false;
              return;
            }
            showMsg(
              'Pushed: ' + data.claimsCreated + ' new claim' + (data.claimsCreated === 1 ? '' : 's') +
              ', ' + data.claimsUpdated + ' updated. Sync event ' + data.syncEventId + ' saved. Reloading...',
              'ok'
            );
            setTimeout(function() { window.location.reload(); }, 1500);
          } catch (err) {
            showMsg('Error: ' + err.message, 'error');
            btn.disabled = false;
          }
          return;
        }

        showMsg('Action "' + action + '" ships in Phase ' + (
          action === 'generate' ? '7' :
          action === 'export' ? '3.5' : '?'
        ) + '.', 'info');
      });
    });

    function renderPreview(data) {
      var panel = document.getElementById('preview-panel');
      var summary = document.getElementById('preview-summary');
      var claims = document.getElementById('preview-claims');
      var eventId = document.getElementById('preview-event-id');
      if (!panel || !summary || !claims) return;

      summary.innerHTML =
        '<strong>' + data.summary.total + '</strong> proposed claim' + (data.summary.total === 1 ? '' : 's') +
        ' &middot; <span class="text-green-700">' + data.summary.add + ' add</span>' +
        ' &middot; <span class="text-blue-700">' + data.summary.update + ' update</span>' +
        ' &middot; <span class="text-amber-700">' + data.summary.lowConfidence + ' low confidence</span>' +
        ' &middot; <span class="text-gray-500">' + data.summary.unassigned + ' unassigned</span>' +
        (data.oosFileId ? '' : ' <br/><span class="text-amber-700">No published OOS file yet for this org. Push will create the first one.</span>');

      claims.innerHTML = '';
      data.proposedClaims.forEach(function(c) {
        var actionBadge = c.proposedAction === 'add'
          ? '<span class="px-2 py-0.5 rounded-full bg-green-100 text-green-700 text-xs">add</span>'
          : '<span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs">update</span>';
        var confColor = c.confidence === 'HIGH' ? 'text-green-700' : c.confidence === 'MEDIUM' ? 'text-blue-700' : 'text-amber-700';
        var div = document.createElement('div');
        div.className = 'border rounded p-3 bg-gray-50 text-xs';
        div.innerHTML =
          '<div class="flex items-center justify-between mb-1">' +
            '<span class="font-mono font-bold">' + c.claimId + '</span>' +
            actionBadge +
          '</div>' +
          '<div class="text-gray-500 font-mono mb-1">' + c.section + '</div>' +
          '<div class="font-semibold mb-1">' + escapeHtml(c.rule) + '</div>' +
          '<div class="text-gray-700 mb-1"><strong>Why:</strong> ' + escapeHtml(c.why) + '</div>' +
          '<div class="text-gray-700 mb-1"><strong>Failure mode:</strong> ' + escapeHtml(c.failureMode) + '</div>' +
          '<div class="text-gray-600 mb-1"><strong>Scope:</strong> ' + escapeHtml(c.scope) + '</div>' +
          '<div class="flex gap-3 mt-2">' +
            '<span class="' + confColor + '">conf: ' + c.confidence + '</span>' +
            '<span class="text-gray-500">evidence: ' + c.evidence + '</span>' +
            (c.agentName ? '<span class="text-purple-700">agent: ' + escapeHtml(c.agentName) + '</span>' : '') +
          '</div>';
        claims.appendChild(div);
      });

      eventId.textContent = 'Sync event: ' + data.syncEventId + ' (saved as preview)';
      panel.classList.remove('hidden');
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function escapeHtml(s) {
      if (s === null || s === undefined) return '';
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    var pcBtn = document.getElementById('preview-close');
    if (pcBtn) pcBtn.addEventListener('click', function() {
      document.getElementById('preview-panel').classList.add('hidden');
    });

    // ---------- Section editor (inline textarea -> PATCH) ----------
    function getRow(sectionId) {
      return document.querySelector('[data-section-row="' + sectionId + '"]');
    }
    document.querySelectorAll('[data-section-edit]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-section-edit');
        var row = getRow(id);
        row.querySelector('[data-section-view]').classList.add('hidden');
        row.querySelector('[data-section-editor]').classList.remove('hidden');
      });
    });
    document.querySelectorAll('[data-section-cancel]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-section-cancel');
        var row = getRow(id);
        row.querySelector('[data-section-editor]').classList.add('hidden');
        row.querySelector('[data-section-view]').classList.remove('hidden');
        row.querySelector('[data-section-msg="' + id + '"]').textContent = '';
      });
    });
    document.querySelectorAll('[data-section-save]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var id = btn.getAttribute('data-section-save');
        var row = getRow(id);
        var msgEl = row.querySelector('[data-section-msg="' + id + '"]');

        // Collect prose + text fields (one input/textarea each).
        var inputs = row.querySelectorAll('[data-section-input="' + id + '"]');
        var contentJson = {};
        inputs.forEach(function(el) {
          var k = el.getAttribute('data-field-key');
          var v = el.value;
          // Store empty string as omitted so view-mode treats it as missing.
          if (v === null || v === undefined || String(v).trim() === '') return;
          contentJson[k] = v;
        });
        // Collect list fields: each [data-list-field] container holds one row
        // per entry. Non-empty rows become a string array; empty fields omitted.
        row.querySelectorAll('[data-list-field="' + id + '"]').forEach(function(container) {
          var k = container.getAttribute('data-field-key');
          var vals = [];
          container.querySelectorAll('[data-list-input="' + id + '"]').forEach(function(inp) {
            var t = String(inp.value || '').trim();
            if (t) vals.push(t);
          });
          if (vals.length > 0) contentJson[k] = vals;
        });

        msgEl.textContent = 'Saving...';
        msgEl.className = 'text-xs text-gray-500';
        try {
          var res = await fetch('/api/v1/oos-operating-plan/sections/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contentJson: contentJson }),
          });
          var data = await res.json();
          if (!res.ok || data.error) {
            msgEl.textContent = 'Error: ' + (data.error?.message || 'save failed');
            msgEl.className = 'text-xs text-red-600';
            return;
          }
          msgEl.textContent = 'Saved. Reloading...';
          msgEl.className = 'text-xs text-green-600';
          setTimeout(function() { window.location.reload(); }, 600);
        } catch (e) {
          msgEl.textContent = 'Error: ' + e.message;
          msgEl.className = 'text-xs text-red-600';
        }
      });
    });

    // ---------- List-field rows: add / remove ----------
    // Delegated click handler so rows added after page load also work.
    document.addEventListener('click', function(e) {
      var listAddBtn = e.target.closest('[data-list-add]');
      if (listAddBtn) {
        var sid = listAddBtn.getAttribute('data-list-add');
        var fkey = listAddBtn.getAttribute('data-field-key');
        var newRow = document.createElement('div');
        newRow.setAttribute('data-list-row', '');
        newRow.className = 'flex items-center gap-2';
        newRow.innerHTML =
          '<input data-list-input="' + sid + '" data-field-key="' + fkey + '" type="text" ' +
          'class="flex-1 px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="One more entry">' +
          '<button type="button" data-list-remove aria-label="Remove entry" ' +
          'class="shrink-0 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded p-1.5 transition-colors">' +
          '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>' +
          '</button>';
        listAddBtn.parentNode.insertBefore(newRow, listAddBtn);
        var ni = newRow.querySelector('input');
        if (ni) ni.focus();
        return;
      }
      var listRmBtn = e.target.closest('[data-list-remove]');
      if (listRmBtn) {
        var listRow = listRmBtn.closest('[data-list-row]');
        var fieldC = listRmBtn.closest('[data-list-field]');
        if (listRow && fieldC) {
          if (fieldC.querySelectorAll('[data-list-row]').length > 1) {
            listRow.remove();
          } else {
            var onlyInput = listRow.querySelector('input');
            if (onlyInput) onlyInput.value = '';
          }
        }
        return;
      }
    });

    // ---------- Add execution item ----------
    var addBtn = document.getElementById('btn-add-item');
    var addForm = document.getElementById('add-item-form');
    var ownerType = document.getElementById('ai-owner-type');
    var secRow = document.getElementById('ai-secondary-row');
    var aiMsg = document.getElementById('ai-msg');

    if (addBtn && addForm) {
      addBtn.addEventListener('click', function() { addForm.classList.toggle('hidden'); });
      document.getElementById('ai-cancel').addEventListener('click', function() { addForm.classList.add('hidden'); });
    }
    if (ownerType && secRow) {
      ownerType.addEventListener('change', function() {
        if (ownerType.value === 'hybrid') secRow.classList.remove('hidden');
        else secRow.classList.add('hidden');
      });
    }

    var saveBtn = document.getElementById('ai-save');
    if (saveBtn) {
      saveBtn.addEventListener('click', async function() {
        var title = document.getElementById('ai-title').value.trim();
        var quarter = document.getElementById('ai-quarter').value.trim();
        var outcome = document.getElementById('ai-outcome').value.trim();
        var priority = document.getElementById('ai-priority').value;
        var ot = ownerType.value;
        var ownerName = document.getElementById('ai-owner-name').value.trim();
        var dueRaw = document.getElementById('ai-due').value;
        var secondaryName = document.getElementById('ai-secondary-name').value.trim();

        if (!title) { aiMsg.textContent = 'Title required'; aiMsg.className = 'text-xs text-red-600'; return; }
        if (!/^Q[1-4]-\d{4}$/.test(quarter)) { aiMsg.textContent = 'Quarter must look like Q1-2026'; aiMsg.className = 'text-xs text-red-600'; return; }

        var body = {
          title: title,
          quarter: quarter,
          outcome: outcome || null,
          priority: priority,
          assignedOwnerType: ot,
          assignedOwnerName: ownerName || null,
          dueDate: dueRaw ? new Date(dueRaw + 'T00:00:00Z').toISOString() : null,
        };
        if (ot === 'hybrid' && secondaryName) {
          body.secondaryOwnerType = 'employee';
          body.secondaryOwnerName = secondaryName;
        }

        aiMsg.textContent = 'Saving...';
        aiMsg.className = 'text-xs text-gray-500';

        try {
          var planId = document.querySelector('[data-plan-id]').getAttribute('data-plan-id');
          var res = await fetch('/api/v1/oos-operating-plan/' + planId + '/items', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          var data = await res.json();
          if (!res.ok || data.error) {
            aiMsg.textContent = 'Error: ' + (data.error?.message || 'create failed');
            aiMsg.className = 'text-xs text-red-600';
            return;
          }
          aiMsg.textContent = 'Added. Reloading...';
          aiMsg.className = 'text-xs text-green-600';
          setTimeout(function() { window.location.reload(); }, 500);
        } catch (e) {
          aiMsg.textContent = 'Error: ' + e.message;
          aiMsg.className = 'text-xs text-red-600';
        }
      });
    }
  })();
</script>
</section>
