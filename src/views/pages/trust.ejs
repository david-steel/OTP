<%# /trust -- Trust & Security (public, v7 light/editorial layout).
    Rendered via renderV7(reply, 'trust', { trust, ... }). Data: src/config/trust.ts.
    Source of truth + code citations: /trust.yaml. %>
<%
  // Status pill styling: color = meaning (DESIGN.md). Green for certified/
  // supported, amber for in-progress/planned, neutral otherwise.
  function pill(status) {
    var s = String(status || '').toLowerCase();
    if (s.indexOf('soc 2') === 0 || s.indexOf('supported') === 0 || s.indexOf('hipaa') > -1 || s.indexOf('certified') > -1)
      return 'color:var(--green-deep); background:rgba(10,157,99,0.10);';
    if (s.indexOf('progress') > -1 || s.indexOf('planned') > -1)
      return 'color:#b45309; background:#fef3c7;';
    return 'color:var(--ink-mute); background:var(--grey);';
  }
%>
<style>
  .tr-row { border-top:1px solid var(--line-soft, rgba(20,22,28,.08)); }
  .tr-row:first-child { border-top:none; }
  .tr-key { color:var(--ink); font-weight:600; }
  .tr-tick { width:7px; height:7px; border-radius:50%; background:var(--green); display:inline-block; flex:none; margin-top:9px; }
  .tr-x { color:var(--ink-mute); }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[860px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16">
    <div class="eyebrow mb-4 flex items-center gap-2.5">
      <span class="tick" style="background:var(--green);"></span>Trust &amp; Security
    </div>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(2.2rem,4.6vw,3.6rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
      What we do with your data, <span class="text-[var(--blue)]">stated plainly.</span>
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[42rem] mt-5">
      <%= trust.hero.statusMessage %>
    </p>
    <p class="text-[13px] text-[var(--ink-mute)] font-mono mt-4">Last updated <%= trust.hero.lastUpdate %></p>

    <ul class="mt-8 space-y-2.5 max-w-[40rem]">
      <% trust.hero.commitments.forEach(function (c) { %>
        <li class="flex items-start gap-3 text-[15px] text-[var(--ink-soft)] leading-[1.55]">
          <span class="tr-tick"></span><span><%= c %></span>
        </li>
      <% }); %>
    </ul>
  </div>
</section>

<!-- ================= NETWORK BOUNDARY (the headline claim) ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">The network boundary</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      If you publish to OTP, here is exactly who sees what.
    </h2>
    <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] max-w-[44rem] mt-4 mb-9">
      <%= trust.network.defaultPosture %>
    </p>

    <div class="grid md:grid-cols-2 gap-5">
      <div class="card p-7">
        <h3 class="font-display text-[var(--ink)] text-[1.15rem] font-bold mb-4">Stays private to you</h3>
        <ul class="space-y-2.5">
          <% trust.network.staysPrivate.forEach(function (p) { %>
            <li class="flex items-start gap-3 text-[14px] text-[var(--ink-soft)] leading-[1.5]">
              <span class="tr-tick"></span><span><%= p %></span>
            </li>
          <% }); %>
        </ul>
      </div>
      <div class="card p-7 border-t-[3px]" style="border-top-color:var(--blue);">
        <h3 class="font-display text-[var(--ink)] text-[1.15rem] font-bold mb-1.5">Visible only when you publish</h3>
        <p class="text-[12.5px] text-[var(--ink-mute)] leading-[1.5] mb-4">Each of these requires an explicit action by you.</p>
        <ul class="space-y-3.5">
          <% trust.network.canBecomeVisible.forEach(function (v) { %>
            <li class="text-[14px] leading-[1.5]">
              <span class="tr-key"><%= v.item %></span>
              <span class="block text-[13px] text-[var(--ink-mute)] mt-0.5"><%= v.condition %></span>
            </li>
          <% }); %>
        </ul>
      </div>
    </div>

    <!-- Private organizations callout -->
    <div class="card p-7 mt-5" style="background:linear-gradient(180deg,rgba(13,125,242,.06),var(--card));">
      <div class="flex items-center gap-2.5 mb-2">
        <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] px-2 py-1 rounded-md"
              style="color:var(--blue-deep); background:rgba(13,125,242,0.10);">private organizations</span>
      </div>
      <p class="text-[15px] text-[var(--ink-soft)] leading-[1.65]"><%= trust.network.privatePlan.description %></p>
      <p class="text-[13.5px] text-[var(--ink-mute)] leading-[1.6] mt-3"><%= trust.network.privatePlan.mechanism %></p>
      <p class="text-[13.5px] text-[var(--ink-mute)] leading-[1.6] mt-2"><%= trust.network.privatePlan.limitation %></p>
    </div>

    <p class="text-[13.5px] text-[var(--ink-mute)] leading-[1.65] mt-6 max-w-[46rem]"><%= trust.network.isolationMechanism %></p>
    <p class="text-[13.5px] text-[var(--ink-mute)] leading-[1.65] mt-2 max-w-[46rem]"><%= trust.network.isolationCaveat %></p>
  </div>
</section>

<!-- ================= INFRASTRUCTURE ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[860px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Infrastructure &amp; encryption</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] mb-8"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      Where your data lives and how it is protected.
    </h2>
    <div>
      <% [
        ['Hosting', trust.infrastructure.hosting],
        ['Data residency', trust.infrastructure.dataResidency],
        ['Encryption', trust.infrastructure.encryption],
        ['Retention', trust.infrastructure.retention],
        ['Backups & recovery', trust.infrastructure.backups]
      ].forEach(function (r) { %>
        <div class="tr-row grid sm:grid-cols-[180px_1fr] gap-x-6 gap-y-1 py-5">
          <div class="tr-key text-[14px]"><%= r[0] %></div>
          <div class="text-[14px] text-[var(--ink-soft)] leading-[1.65]"><%= r[1] %></div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= DATA HANDLING ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[860px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Data handling</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] mb-8"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      Deletion, export, and AI processing.
    </h2>
    <div>
      <% [
        ['Deletion', trust.dataHandling.deletion],
        ['Export', trust.dataHandling.export],
        ['AI processing', trust.dataHandling.aiProcessing],
        ['Abuse protection', trust.dataHandling.rateLimiting]
      ].forEach(function (r) { %>
        <div class="tr-row grid sm:grid-cols-[180px_1fr] gap-x-6 gap-y-1 py-5">
          <div class="tr-key text-[14px]"><%= r[0] %></div>
          <div class="text-[14px] text-[var(--ink-soft)] leading-[1.65]"><%= r[1] %></div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= ACCESS CONTROLS ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Access &amp; security controls</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] mb-9"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      The controls running on every request.
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% trust.policies.forEach(function (p) { %>
        <div class="card p-6">
          <div class="font-display text-[var(--ink)] text-[1.05rem] font-bold mb-1.5"><%= p.name %></div>
          <div class="text-[13px] text-[var(--ink-soft)] leading-[1.6]"><%= p.coverage %></div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= COMPLIANCE ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[860px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Compliance</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] mb-3"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      Honest status, not borrowed badges.
    </h2>
    <p class="text-[15px] text-[var(--ink-soft)] leading-[1.65] max-w-[42rem] mb-8">
      We are an early-stage protocol. We tell you exactly where we are.
    </p>
    <div>
      <% trust.compliance.forEach(function (c) { %>
        <div class="tr-row flex items-start justify-between gap-4 py-5">
          <div>
            <div class="tr-key text-[15px] mb-0.5"><%= c.name %></div>
            <div class="text-[13px] text-[var(--ink-mute)] leading-[1.55] max-w-[40rem]"><%= c.scope %></div>
          </div>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.06em] px-2.5 py-1 rounded-full whitespace-nowrap"
                style="<%= pill(c.status) %>"><%= c.status %></span>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= SUBPROCESSORS ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Subprocessors</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] mb-8"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      Every third party that may process data.
    </h2>
    <div>
      <% trust.subprocessors.forEach(function (s) { %>
        <div class="tr-row grid sm:grid-cols-[160px_180px_1fr] gap-x-6 gap-y-1 py-5">
          <div class="tr-key text-[14px]"><%= s.name %></div>
          <div class="text-[13px] text-[var(--ink-mute)] leading-[1.5]"><%= s.category %></div>
          <div class="text-[13.5px] text-[var(--ink-soft)] leading-[1.6]">
            <%= s.description %>
            <span class="block text-[12px] text-[var(--ink-mute)] mt-0.5"><%= s.location %></span>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= INCIDENT RESPONSE ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Incident response</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.15] mb-5"
        style="font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700;">
      If something goes wrong, you hear from us in three hours.
    </h2>
    <p class="text-[16px] text-[var(--ink-soft)] leading-[1.75] mb-3"><%= trust.monitoring.responseCommitment %></p>
    <p class="text-[14px] text-[var(--ink-mute)] leading-[1.6]"><%= trust.monitoring.incidentHistory %></p>
  </div>
</section>

<!-- ================= FAQ ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[820px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Questions teams ask us</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1] mb-9"
        style="font-size:clamp(1.7rem,3.2vw,2.4rem); font-weight:700;">
      The answers your reviewers want.
    </h2>
    <div class="space-y-7">
      <% trust.faqs.forEach(function (f) { %>
        <div>
          <h3 class="font-display text-[var(--ink)] text-[1.1rem] font-bold mb-1.5"><%= f.question %></h3>
          <p class="text-[15px] text-[var(--ink-soft)] leading-[1.7]"><%= f.answer %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= CONTACT ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-20 sm:py-24 text-center">
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.1]"
        style="font-size:clamp(1.8rem,3.6vw,2.6rem); font-weight:800;">
      Reviewing OTP for your team?
    </h2>
    <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] max-w-[36rem] mx-auto mt-5">
      <%= trust.contacts.sla %> Our Data Processing Agreement is available on request.
    </p>
    <div class="mt-8">
      <a href="mailto:<%= trust.contacts.email %>?subject=OTP%20security%20review" class="btn-ink inline-block px-8 py-4 text-[16px]">
        Contact security &rarr;
      </a>
    </div>
    <p class="text-[13px] text-[var(--ink-mute)] font-mono mt-5"><%= trust.contacts.email %></p>
    <p class="text-[12px] text-[var(--ink-mute)] leading-[1.6] mt-8 max-w-[40rem] mx-auto">
      <%= trust.company.legalEntity %> · <%= trust.company.headquarters %>
    </p>
  </div>
</section>
