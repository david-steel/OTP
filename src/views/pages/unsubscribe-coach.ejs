<%-
  /* /unsubscribe?slug=... — Confirmation page after one-click unsubscribe.
     Variables: profile (may be null), slug, takedownUrl */
%>
<section class="bg-gradient-to-b from-gray-50 via-white to-white">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20 text-center">

    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-6">
      <span class="text-green-600 text-3xl">✓</span>
    </div>

    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">You're unsubscribed.</h1>

    <% if (profile) { %>
      <p class="text-base sm:text-lg text-gray-700 mb-2">
        We won't email <strong><%= profile.displayName %></strong> about OTP again.
      </p>
    <% } else { %>
      <p class="text-base sm:text-lg text-gray-700 mb-2">
        We won't email you about OTP again.
      </p>
    <% } %>

    <p class="text-sm text-gray-600 mb-10">
      Logged. Done. No further action needed from you.
    </p>

    <% if (profile && takedownUrl) { %>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 text-left max-w-md mx-auto mb-8">
        <div class="text-xs font-bold uppercase tracking-wider text-gray-500 mb-2">One more thing</div>
        <p class="text-sm text-gray-700 leading-relaxed mb-4">
          Your profile is still listed in the OTP coach directory at <code class="text-xs bg-white px-1 py-0.5 rounded border border-gray-200">/expert/<%= slug %></code>. Unsubscribe only stops emails. If you also want your profile removed from the public directory, click below.
        </p>
        <a href="<%= takedownUrl %>" class="inline-flex items-center text-sm text-gray-900 underline font-medium hover:text-gray-700">
          Remove my profile from the directory →
        </a>
      </div>
    <% } %>

    <a href="/" class="inline-flex items-center px-6 py-3 rounded-xl bg-gray-900 text-white font-semibold hover:bg-gray-800">
      Back to OTP home
    </a>

  </div>
</section>
