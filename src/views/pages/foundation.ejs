<%# /foundation -- v7 layout (light, editorial). Track 1 destination:
    Build the Foundation (L1-L3). Four-step guided onboarding for orgs
    that don't have agents yet. Org Chart -> OOS -> KPIs -> SOPs.
    Rendered via reply.view('pages/foundation', data, { layout: 'layouts/v7' }). %>
<style>
  .fdn-num {
    width:42px; height:42px; border-radius:12px;
    display:flex; align-items:center; justify-content:center;
    font-family:'Schibsted Grotesk',sans-serif; font-weight:800; font-size:17px;
    background:rgba(13,125,242,.1); color:var(--blue-deep);
    border:1px solid rgba(13,125,242,.22); flex-shrink:0;
  }
  .fdn-rung {
    display:inline-flex; align-items:center; gap:6px;
    padding:6px 11px; border-radius:8px;
    font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:500;
    letter-spacing:0.04em;
  }
  .fdn-rung-current { background:rgba(13,125,242,.1); color:var(--blue-deep); border:1px solid rgba(13,125,242,.25); }
  .fdn-rung-next { background:var(--card); color:var(--ink-mute); border:1px solid var(--line); }
  .fdn-hand { animation:fdn-hand 4s ease-in-out infinite; transform-origin:60% 90%; }
  @keyframes fdn-hand { 0%,72%,100%{transform:rotate(0);} 82%{transform:rotate(-12deg);} 92%{transform:rotate(6deg);} }
  @media (prefers-reduced-motion:reduce){ .fdn-hand{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[920px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16">
    <div class="eyebrow mb-7 flex items-center gap-2 flex-wrap">
      <a href="/" class="link-u" style="color:var(--ink-mute); border-bottom-width:1.5px;">OTP</a>
      <span style="color:var(--line);">/</span>
      <span style="color:var(--ink);">Build the Foundation</span>
    </div>

    <div class="flex flex-wrap items-center gap-2 mb-8">
      <span class="fdn-rung fdn-rung-current">
        <span class="w-1.5 h-1.5 rounded-full" style="background:var(--blue);"></span>
        You are here &middot; L1&ndash;L3
      </span>
      <span class="text-[var(--ink-mute)] text-xs">&rarr;</span>
      <span class="fdn-rung fdn-rung-next">L4&ndash;L6 &middot; Deploy</span>
      <span class="text-[var(--ink-mute)] text-xs">&rarr;</span>
      <span class="fdn-rung fdn-rung-next">L7&ndash;L8 &middot; Teams</span>
    </div>

    <div class="flex items-start gap-4">
      <h1 class="font-display text-[var(--ink)] max-w-[44rem]"
          style="font-size:clamp(2.2rem,4.4vw,3.4rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
        Build the foundation your first agent will land on.
      </h1>
      <img src="/public/hand-1.png" alt="" aria-hidden="true"
           class="fdn-hand shrink-0 hidden md:block mt-1" style="width:54px; height:auto;">
    </div>
    <p class="text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[40rem] mt-6">
      Most companies bring agents into a broken org chart and wonder why nothing sticks. You're going to do it differently.
    </p>
    <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] max-w-[40rem] mt-3">
      Four steps. Each one is valuable on its own, even if you never deploy an agent. By the time you're ready for one, the chart, the operating system, the KPIs, and the SOPs are already in place. The agent slots in. The chart doesn't break.
    </p>
  </div>
</section>

<!-- ================= FOUR STEPS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[920px] mx-auto px-6 py-20 sm:py-24">
    <% const fdnSteps = [
      { n:'1', href:'/graph', time:'~ 15 min', title:'Build your org chart',
        body:'Start with the humans you have today. Every seat, every accountability. This becomes the chart that agents will eventually sit on alongside your team.',
        cta:'Open the chart builder' },
      { n:'2', href:'/publish', time:'~ 30 min', title:'Define your operating system',
        body:'Publish your OOS file, how your org actually runs. Meetings, decision rights, escalation paths, what gets measured. This is the operating manual the next layer (agents) will inherit.',
        cta:'Publish your OOS' },
      { n:'3', href:'/dashboard/kpis', time:'~ 20 min', title:'Set your KPI scorecard',
        body:"One KPI per seat. If a seat doesn't have a number, the work isn't measurable, and an agent that fills that seat later won't be either. Get this right now and the agent layer becomes accountable from day one.",
        cta:'Open the scorecard' },
      { n:'4', href:'/publish', time:'Ongoing', title:'Document your SOPs',
        body:'Standard operating procedures, one per repeatable task. Start with the three things your team does most often. These are the prompts and playbooks your future agents will run from. SOPs first, agents second.',
        cta:'Add an SOP' },
    ]; %>

    <div class="space-y-4">
      <% fdnSteps.forEach((s) => { %>
        <a href="<%= s.href %>" class="card lift block p-7 sm:p-8">
          <div class="flex items-start gap-5">
            <div class="fdn-num"><%= s.n %></div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <h3 class="font-display text-[var(--ink)] text-[1.3rem] sm:text-[1.45rem] font-bold tracking-[-0.01em]"><%= s.title %></h3>
                <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--ink-mute)]"><%= s.time %></span>
              </div>
              <p class="text-[14.5px] text-[var(--ink-soft)] leading-[1.7] mb-4"><%= s.body %></p>
              <span class="inline-flex items-center gap-1.5 text-[14px] text-[var(--blue-deep)] link-u">
                <%= s.cta %> &rarr;
              </span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= WHAT'S NEXT ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[920px] mx-auto px-6 py-20 sm:py-24">
    <div class="card p-8 sm:p-11" style="background:linear-gradient(180deg,rgba(13,125,242,.05),var(--card));">
      <div class="eyebrow mb-3" style="color:var(--blue-deep);">When this track is no longer your reality</div>
      <h2 class="font-display text-[var(--ink)] leading-[1.12] mb-3"
          style="font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; letter-spacing:-0.02em;">
        Track 2 &middot; Bring your agents in
      </h2>
      <p class="text-[15.5px] text-[var(--ink-soft)] leading-[1.7] max-w-[42rem] mb-6">
        The day you deploy your first agent is the day Track 1 stops being your track and Track 2 starts. The foundation you built here doesn't go away. The chart receives the agent without breaking, the KPI is already defined, the SOP is already written. You don't restart. You shift tracks.
      </p>
      <a href="/deploy" class="inline-flex items-center gap-2 text-[15px] text-[var(--blue-deep)] link-u">
        See Track 2 &rarr;
      </a>
    </div>
  </div>
</section>
