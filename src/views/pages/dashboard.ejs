<% if (typeof authState !== 'undefined' && authState === 'unauthenticated') { %>
  <div class="max-w-xl mx-auto px-4 py-20 text-center" id="dashboard-loading">
    <div class="animate-pulse">
      <h1 class="text-2xl font-bold mb-4">Publisher Dashboard</h1>
      <p class="text-gray-500 mb-8">Loading your account...</p>
    </div>
  </div>
  <div class="max-w-xl mx-auto px-4 py-20 text-center hidden" id="dashboard-signin">
    <h1 class="text-2xl font-bold mb-4">Publisher Dashboard</h1>
    <p class="text-gray-500 mb-8">Sign in to view your dashboard, manage your OOS files, and track your publisher stats.</p>
    <button id="dashboard-sign-in" class="px-6 py-3 bg-otp-500 text-white rounded-lg font-medium hover:bg-otp-400">
      Sign In to Continue
    </button>
  </div>
  <script>
    window.addEventListener('clerk-loaded', function(e) {
      var loadingEl = document.getElementById('dashboard-loading');
      var signinEl = document.getElementById('dashboard-signin');
      var btn = document.getElementById('dashboard-sign-in');

      if (window.__clerk && window.__clerk.user) {
        // User is signed in but server did not see the session -- reload to pick up the cookie
        window.location.reload();
      } else {
        // Not signed in -- show the sign-in prompt
        loadingEl.classList.add('hidden');
        signinEl.classList.remove('hidden');
        if (btn && window.__clerk) {
          btn.addEventListener('click', function() {
            window.__clerk.openSignIn({ redirectUrl: '/dashboard' });
          });
        }
      }
    });
    // Fallback: if Clerk takes too long, show sign-in after 3 seconds
    setTimeout(function() {
      var loadingEl = document.getElementById('dashboard-loading');
      var signinEl = document.getElementById('dashboard-signin');
      if (loadingEl && !loadingEl.classList.contains('hidden')) {
        loadingEl.classList.add('hidden');
        signinEl.classList.remove('hidden');
      }
    }, 3000);
  </script>
<% } else { %>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-2">Publisher Dashboard</h1>
    <p class="text-gray-500 text-sm mb-8">Your OTP intelligence overview.</p>

    <!-- Profile Card -->
    <div class="bg-white p-6 rounded-lg border mb-6">
      <div class="flex items-start justify-between">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <h2 class="text-xl font-bold"><%= dashboard.profile.name %></h2>
            <% if (dashboard.profile.badge === 'founding') { %>
              <span class="badge-founding text-white text-xs px-2 py-0.5 rounded">Founding Publisher</span>
            <% } %>
            <% if (dashboard.profile.qualityTier) { %>
              <span class="badge-<%= dashboard.profile.qualityTier %> text-white text-xs px-2 py-0.5 rounded capitalize"><%= dashboard.profile.qualityTier %></span>
            <% } %>
            <% if (dashboard.profile.agenticLevel) { %>
              <span class="badge-level badge-level-<%= dashboard.profile.agenticLevel %>" title="Bassim Eledath's 8 Levels of Agentic Engineering">L<%= dashboard.profile.agenticLevel %> <%= dashboard.profile.agenticLabel %></span>
            <% } %>
          </div>
          <div class="text-sm text-gray-500"><%= dashboard.profile.industry %> &middot; <%= dashboard.profile.size %></div>
        </div>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-2xl font-bold text-otp-600"><%= dashboard.stats.publishedFiles %></div>
        <div class="text-xs text-gray-500">Published Files</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-2xl font-bold text-otp-600"><%= dashboard.stats.totalClaims %></div>
        <div class="text-xs text-gray-500">Total Claims</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-2xl font-bold text-otp-600"><%= dashboard.stats.connectedOrgs %></div>
        <div class="text-xs text-gray-500">Connected Orgs</div>
      </div>
      <div class="bg-white p-4 border rounded-lg text-center">
        <div class="text-2xl font-bold text-otp-600"><%= dashboard.stats.views30d %></div>
        <div class="text-xs text-gray-500">Views (30d)</div>
      </div>
    </div>

    <!-- Published Files -->
    <h3 class="font-semibold mb-3">Your OOS Files</h3>
    <% if (dashboard.oosFiles.length > 0) { %>
      <% dashboard.oosFiles.forEach(function(oos) { %>
        <div class="bg-white p-4 rounded-lg border mb-3 flex items-center justify-between" id="oos-row-<%= oos.id %>">
          <div>
            <a href="/oos/<%= oos.id %>" class="font-medium text-otp-600 hover:underline capitalize">
              <span class="oos-name"><%= oos.name || (oos.template.replace('_', ' ') + ' OOS') %></span>
            </a>
            <div class="text-xs text-gray-400">v<%= oos.version %> &middot; <%= oos.claimCount %> claims &middot; <%= oos.publishedAt ? 'Published ' + new Date(oos.publishedAt).toLocaleDateString() : 'Draft' %></div>
          </div>
          <div class="flex items-center gap-2">
            <button onclick="renameOos('<%= oos.id %>')" class="text-gray-400 hover:text-otp-600 p-1" title="Rename">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            </button>
            <% if (oos.status === 'draft') { %>
              <a href="/publish?edit=<%= oos.id %>" class="text-gray-400 hover:text-otp-600 p-1" title="Edit draft">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </a>
            <% } else if (oos.status === 'published') { %>
              <button onclick="newVersion('<%= oos.id %>')" class="text-gray-400 hover:text-otp-600 p-1" title="Create new version">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
              </button>
            <% } %>
            <button onclick="deleteOos('<%= oos.id %>', '<%= (oos.name || oos.template.replace('_', ' ') + ' OOS').replace(/'/g, "\\'") %>')" class="text-gray-400 hover:text-red-600 p-1" title="Delete">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
            <span class="text-xs px-2 py-1 rounded capitalize
              <% if (oos.status === 'published') { %>bg-green-100 text-green-700<% } %>
              <% if (oos.status === 'draft') { %>bg-yellow-100 text-yellow-700<% } %>
              <% if (oos.status === 'archived') { %>bg-gray-100 text-gray-500<% } %>
            "><%= oos.status %></span>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="text-center py-8 text-gray-400 text-sm">
        <p>No OOS files yet. <a href="/publish" class="text-otp-500 hover:underline">Publish your first one.</a></p>
      </div>
    <% } %>

    <!-- Update History -->
    <h3 class="font-semibold mt-8 mb-3">Version History</h3>
    <div class="bg-white border rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left text-xs text-gray-500">
          <tr>
            <th class="px-4 py-2">Version</th>
            <th class="px-4 py-2">Claims</th>
            <th class="px-4 py-2">Status</th>
            <th class="px-4 py-2">Date</th>
          </tr>
        </thead>
        <tbody>
          <% dashboard.updateHistory.forEach(function(v) { %>
            <tr class="border-t">
              <td class="px-4 py-2">v<%= v.version %></td>
              <td class="px-4 py-2"><%= v.claimCount %></td>
              <td class="px-4 py-2 capitalize"><%= v.status %></td>
              <td class="px-4 py-2 text-gray-400"><%= v.publishedAt ? new Date(v.publishedAt).toLocaleDateString() : 'Not published' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    async function renameOos(id) {
      var currentName = document.querySelector('#oos-row-' + id + ' .oos-name');
      var newName = prompt('Enter a new name for this OOS file:', currentName ? currentName.textContent.trim() : '');
      if (!newName || !newName.trim()) return;

      try {
        var res = await fetch('/api/v1/oos/' + id + '/rename', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: newName.trim() }),
        });
        if (!res.ok) {
          var err = await res.json();
          alert('Rename failed: ' + (err.error?.message || 'Unknown error'));
          return;
        }
        if (currentName) currentName.textContent = newName.trim();
      } catch (e) {
        alert('Rename failed: ' + e.message);
      }
    }

    async function deleteOos(id, name) {
      if (!confirm('Are you sure you want to delete "' + name + '"? This cannot be undone.')) return;

      try {
        var res = await fetch('/api/v1/oos/' + id, {
          method: 'DELETE',
        });
        if (!res.ok) {
          var err = await res.json();
          alert('Delete failed: ' + (err.error?.message || 'Unknown error'));
          return;
        }
        var row = document.getElementById('oos-row-' + id);
        if (row) row.remove();
      } catch (e) {
        alert('Delete failed: ' + e.message);
      }
    }

    async function newVersion(id) {
      if (!confirm('Create a new draft version from this published file?')) return;

      try {
        var res = await fetch('/api/v1/oos/' + id + '/new-version', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({}),
        });
        if (!res.ok) {
          var err = await res.json();
          alert('Failed to create new version: ' + (err.error?.message || 'Unknown error'));
          return;
        }
        var data = await res.json();
        window.location.href = '/publish?edit=' + data.oosFile.id;
      } catch (e) {
        alert('Failed to create new version: ' + e.message);
      }
    }
  </script>
<% } %>
