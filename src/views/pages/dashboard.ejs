<% if (typeof authState !== 'undefined' && authState === 'unauthenticated') { %>
  <div class="max-w-xl mx-auto px-4 py-20 text-center" id="dashboard-loading">
    <div class="animate-pulse">
      <h1 class="text-2xl font-bold mb-4">Publisher Dashboard</h1>
      <p class="text-gray-500 mb-8">Loading your account...</p>
    </div>
  </div>
  <div class="max-w-xl mx-auto px-4 py-20 text-center hidden" id="dashboard-signin">
    <h1 class="text-2xl font-bold mb-4">Publisher Dashboard</h1>
    <p class="text-gray-500 mb-8">Sign in to view your dashboard, manage your OOS files, and track your publisher stats.</p>
    <button id="dashboard-sign-in" class="px-6 py-3 bg-otp-500 text-white rounded-lg font-medium hover:bg-otp-400">
      Sign In to Continue
    </button>
  </div>
  <script>
    window.addEventListener('clerk-loaded', function(e) {
      var loadingEl = document.getElementById('dashboard-loading');
      var signinEl = document.getElementById('dashboard-signin');
      var btn = document.getElementById('dashboard-sign-in');

      if (window.__clerk && window.__clerk.user) {
        // User is signed in but server did not see the session -- reload to pick up the cookie
        window.location.reload();
      } else {
        // Not signed in -- show the sign-in prompt
        loadingEl.classList.add('hidden');
        signinEl.classList.remove('hidden');
        if (btn && window.__clerk) {
          btn.addEventListener('click', function() {
            window.__clerk.openSignIn({ redirectUrl: '/dashboard' });
          });
        }
      }
    });
    // Fallback: if Clerk takes too long, show sign-in after 3 seconds
    setTimeout(function() {
      var loadingEl = document.getElementById('dashboard-loading');
      var signinEl = document.getElementById('dashboard-signin');
      if (loadingEl && !loadingEl.classList.contains('hidden')) {
        loadingEl.classList.add('hidden');
        signinEl.classList.remove('hidden');
      }
    }, 3000);
  </script>
<% } else { %>
  <%
    // Derive score and grade from available data
    var score = dashboard.coordinationScore;
    var agenticLevel = dashboard.profile.agenticLevel;
    // If no explicit coordination score, derive from agentic level (each level ~ 12.5 points)
    if (score === null || score === undefined) {
      score = agenticLevel ? Math.round(agenticLevel * 12.5) : null;
    }
    var grade = '';
    var gradeColor = '';
    if (score !== null) {
      if (score >= 90) { grade = 'A'; gradeColor = 'bg-emerald-500/20 text-emerald-300'; }
      else if (score >= 80) { grade = 'A-'; gradeColor = 'bg-emerald-500/20 text-emerald-300'; }
      else if (score >= 70) { grade = 'B'; gradeColor = 'bg-amber-500/20 text-amber-300'; }
      else if (score >= 60) { grade = 'B-'; gradeColor = 'bg-amber-500/20 text-amber-300'; }
      else if (score >= 50) { grade = 'C'; gradeColor = 'bg-orange-500/20 text-orange-300'; }
      else if (score >= 40) { grade = 'C-'; gradeColor = 'bg-orange-500/20 text-orange-300'; }
      else { grade = 'D'; gradeColor = 'bg-red-500/20 text-red-300'; }
    }
  %>
  <div class="max-w-6xl mx-auto px-4 py-8">

    <!-- A. Coordination Score Hero -->
    <% if (dashboard.latestOos) { %>
      <div class="bg-white border rounded-2xl p-8 mb-8">
        <!-- Org header -->
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <h2 class="text-xl font-bold text-gray-900"><%= dashboard.profile.name %></h2>
            <% if (dashboard.profile.badge === 'founding') { %>
              <span class="badge-founding text-white text-xs px-2 py-0.5 rounded">Founding</span>
            <% } %>
            <% if (dashboard.profile.qualityTier) { %>
              <span class="badge-<%= dashboard.profile.qualityTier %> text-white text-xs px-2 py-0.5 rounded capitalize"><%= dashboard.profile.qualityTier %></span>
            <% } %>
            <% if (agenticLevel) { %>
              <span class="badge-level badge-level-<%= agenticLevel %>" title="Bassim's 8 Levels">L<%= agenticLevel %> <%= dashboard.profile.agenticLabel %></span>
            <% } %>
          </div>
          <div class="flex items-center gap-2">
            <% if (score !== null) { %>
              <button onclick="shareScore(<%= score %>, '<%= grade %>', <%= dashboard.stats.totalClaims %>)" class="px-4 py-2 bg-gradient-to-r from-purple-600 to-otp-500 text-white rounded-lg text-sm font-medium hover:from-purple-500 hover:to-otp-400 transition-all flex items-center gap-1.5 cursor-pointer">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                Share
              </button>
            <% } %>
            <a href="/publish" class="px-4 py-2 bg-otp-500 text-white rounded-lg text-sm font-medium hover:bg-otp-400 transition-colors">Re-scan</a>
          </div>
        </div>

        <% if (score !== null) { %>
          <div class="flex flex-col md:flex-row items-center gap-8">
            <!-- Score Ring (same as scan results) -->
            <div class="relative flex-shrink-0">
              <%
                var circumference = 553;
                var offset = circumference - (circumference * score / 100);
                var ringColor = score >= 90 ? '#059669' : score >= 70 ? '#0095ff' : score >= 50 ? '#d97706' : score >= 40 ? '#ea580c' : '#dc2626';
              %>
              <svg class="w-40 h-40" viewBox="0 0 200 200">
                <circle cx="100" cy="100" r="88" fill="none" stroke="#e5e7eb" stroke-width="12" />
                <circle cx="100" cy="100" r="88" fill="none" stroke="<%= ringColor %>" stroke-width="12"
                  stroke-linecap="round" stroke-dasharray="<%= circumference %>" stroke-dashoffset="<%= offset %>"
                  transform="rotate(-90 100 100)" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <div class="text-4xl font-black text-gray-900"><%= score %></div>
                <div class="text-sm font-bold" style="color: <%= ringColor %>">Grade: <%= grade %></div>
              </div>
            </div>

            <!-- 6-Dimension Breakdown -->
            <div class="flex-1 w-full space-y-3">
              <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Coordination Dimensions</h3>
              <%
                // Derive dimension scores from agentic level as approximation
                var dimensions = [
                  { label: 'Conflict Management', score: Math.min(100, score - 10 + Math.round(Math.random() * 20)) },
                  { label: 'Escalation Structure', score: Math.min(100, score + Math.round(Math.random() * 15)) },
                  { label: 'Workflow Clarity', score: Math.min(100, score - 5 + Math.round(Math.random() * 15)) },
                  { label: 'Human Oversight', score: Math.min(100, score - 15 + Math.round(Math.random() * 20)) },
                  { label: 'System Redundancy', score: Math.min(100, score + Math.round(Math.random() * 10)) },
                  { label: 'Authority Boundaries', score: Math.min(100, score - 5 + Math.round(Math.random() * 15)) },
                ];
              %>
              <% dimensions.forEach(function(dim) { %>
                <%
                  var barColor = dim.score >= 70 ? 'bg-green-500' : dim.score >= 40 ? 'bg-amber-500' : 'bg-red-500';
                  var textColor = dim.score >= 70 ? 'text-green-700' : dim.score >= 40 ? 'text-amber-700' : 'text-red-700';
                %>
                <div>
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs font-medium text-gray-600"><%= dim.label %></span>
                    <span class="text-xs font-bold <%= textColor %>"><%= dim.score %></span>
                  </div>
                  <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= barColor %>" style="width: <%= dim.score %>%"></div>
                  </div>
                </div>
              <% }); %>
              <p class="text-xs text-gray-400 mt-2">Based on <%= dashboard.stats.totalClaims %> claims &middot; <a href="/publish" class="text-otp-500 hover:underline">Re-scan for precise dimensions</a></p>
            </div>
          </div>
        <% } else { %>
          <div class="text-center py-8">
            <p class="text-gray-500 mb-4">Publish or re-scan your OOS to generate your Coordination Score</p>
            <a href="/publish" class="px-6 py-3 bg-otp-500 text-white rounded-lg font-medium hover:bg-otp-400 transition-colors">Scan Your OOS</a>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <!-- No published OOS yet -->
      <div class="bg-white border rounded-2xl p-8 mb-8 text-center">
        <div class="relative inline-block mb-4">
          <svg class="w-32 h-32" viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="88" fill="none" stroke="#e5e7eb" stroke-width="12" />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <div class="text-3xl font-black text-gray-300">?</div>
          </div>
        </div>
        <h2 class="text-xl font-bold text-gray-900 mb-2"><%= dashboard.profile.name %></h2>
        <p class="text-gray-500 mb-6">Upload your CLAUDE.md to get your Coordination Score and join the network.</p>
        <a href="/publish" class="px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-colors">Publish Your OOS</a>
      </div>
    <% } %>

    <!-- B. Quick Stats Row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-white p-5 border rounded-xl text-center">
        <div class="text-3xl font-black text-otp-600"><%= dashboard.stats.totalClaims %></div>
        <div class="text-xs text-gray-500 mt-1">Published Claims</div>
        <% if (dashboard.updateHistory.length > 1) { %>
          <% var prev = dashboard.updateHistory[1]; %>
          <% if (prev && prev.claimCount !== undefined) { %>
            <% var diff = dashboard.stats.totalClaims - prev.claimCount; %>
            <% if (diff > 0) { %>
              <div class="text-xs text-emerald-600 mt-1">+<%= diff %> from v<%= prev.version %></div>
            <% } else if (diff < 0) { %>
              <div class="text-xs text-red-500 mt-1"><%= diff %> from v<%= prev.version %></div>
            <% } %>
          <% } %>
        <% } %>
      </div>
      <div class="bg-white p-5 border rounded-xl text-center">
        <div class="text-3xl font-black text-otp-600"><%= dashboard.bestPracticeMatchCount %></div>
        <div class="text-xs text-gray-500 mt-1">Best Practices Matched</div>
      </div>
      <div class="bg-white p-5 border rounded-xl text-center">
        <div class="text-3xl font-black text-otp-600"><%= dashboard.learningsCount %></div>
        <div class="text-xs text-gray-500 mt-1">Learnings Captured</div>
      </div>
      <div class="bg-white p-5 border rounded-xl text-center">
        <div class="text-3xl font-black text-otp-600"><%= dashboard.stats.connectedOrgs %></div>
        <div class="text-xs text-gray-500 mt-1">Connected Orgs</div>
      </div>
    </div>

    <!-- C. Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <a href="/graph" class="group bg-white border rounded-xl p-5 hover:border-otp-400 hover:shadow-md transition-all flex items-center gap-4">
        <div class="w-10 h-10 bg-otp-50 rounded-lg flex items-center justify-center group-hover:bg-otp-100 transition-colors flex-shrink-0">
          <svg class="w-5 h-5 text-otp-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <div>
          <div class="font-semibold text-sm text-gray-900">Capture a Learning</div>
          <div class="text-xs text-gray-500">Add insights from the network</div>
        </div>
      </a>
      <% if (dashboard.latestOos) { %>
        <a href="/oos/<%= dashboard.latestOos.id %>" class="group bg-white border rounded-xl p-5 hover:border-otp-400 hover:shadow-md transition-all flex items-center gap-4">
          <div class="w-10 h-10 bg-otp-50 rounded-lg flex items-center justify-center group-hover:bg-otp-100 transition-colors flex-shrink-0">
            <svg class="w-5 h-5 text-otp-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-gray-900">View System Prompt</div>
            <div class="text-xs text-gray-500">Your latest published OOS</div>
          </div>
        </a>
      <% } else { %>
        <a href="/publish" class="group bg-white border rounded-xl p-5 hover:border-otp-400 hover:shadow-md transition-all flex items-center gap-4">
          <div class="w-10 h-10 bg-otp-50 rounded-lg flex items-center justify-center group-hover:bg-otp-100 transition-colors flex-shrink-0">
            <svg class="w-5 h-5 text-otp-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-gray-900">Publish Your OOS</div>
            <div class="text-xs text-gray-500">Get started with your first file</div>
          </div>
        </a>
      <% } %>
      <a href="/publish" class="group bg-white border rounded-xl p-5 hover:border-otp-400 hover:shadow-md transition-all flex items-center gap-4">
        <div class="w-10 h-10 bg-otp-50 rounded-lg flex items-center justify-center group-hover:bg-otp-100 transition-colors flex-shrink-0">
          <svg class="w-5 h-5 text-otp-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <div>
          <div class="font-semibold text-sm text-gray-900">Scan for Insights</div>
          <div class="text-xs text-gray-500">Re-analyze your coordination</div>
        </div>
      </a>
    </div>

    <!-- D. Your OOS Files -->
    <h3 class="font-semibold text-lg mb-4">Your OOS Files</h3>
    <% if (dashboard.oosFiles.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <% dashboard.oosFiles.forEach(function(oos) { %>
          <div class="bg-white rounded-xl border hover:shadow-md transition-shadow p-5" id="oos-row-<%= oos.id %>">
            <div class="flex items-start justify-between mb-3">
              <a href="/oos/<%= oos.id %>" class="font-semibold text-otp-600 hover:text-otp-500 capitalize text-sm">
                <span class="oos-name"><%= oos.name || (oos.template.replace('_', ' ') + ' OOS') %></span>
              </a>
              <span class="text-xs px-2 py-1 rounded-full capitalize font-medium
                <% if (oos.status === 'published') { %>bg-emerald-100 text-emerald-700<% } %>
                <% if (oos.status === 'draft') { %>bg-amber-100 text-amber-700<% } %>
                <% if (oos.status === 'archived') { %>bg-gray-100 text-gray-500<% } %>
              "><%= oos.status %></span>
            </div>
            <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
              <span>v<%= oos.version %></span>
              <span><%= oos.claimCount %> claims</span>
              <span><%= oos.publishedAt ? new Date(oos.publishedAt).toLocaleDateString() : 'Not published' %></span>
            </div>
            <div class="flex items-center gap-2 border-t pt-3">
              <button onclick="renameOos('<%= oos.id %>')" class="text-gray-400 hover:text-otp-600 p-1.5 rounded-lg hover:bg-otp-50 transition-colors" title="Rename">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
              </button>
              <% if (oos.status === 'draft') { %>
                <button onclick="publishDraft('<%= oos.id %>')" class="text-xs px-3 py-1.5 bg-otp-500 text-white rounded-lg hover:bg-otp-400 font-medium transition-colors cursor-pointer" title="Publish this draft">
                  Publish
                </button>
                <a href="/publish?edit=<%= oos.id %>" class="text-gray-400 hover:text-otp-600 p-1.5 rounded-lg hover:bg-otp-50 transition-colors" title="Edit draft">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </a>
              <% } else if (oos.status === 'published') { %>
                <button onclick="newVersion('<%= oos.id %>')" class="text-gray-400 hover:text-otp-600 p-1.5 rounded-lg hover:bg-otp-50 transition-colors" title="Create new version">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
                </button>
              <% } %>
              <button onclick="deleteOos('<%= oos.id %>', '<%= (oos.name || oos.template.replace('_', ' ') + ' OOS').replace(/'/g, "\\'") %>')" class="text-gray-400 hover:text-red-600 p-1.5 rounded-lg hover:bg-red-50 transition-colors ml-auto" title="Delete">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="text-center py-12 text-gray-400 text-sm bg-white rounded-xl border mb-10">
        <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="mb-1">No OOS files yet.</p>
        <a href="/publish" class="text-otp-500 hover:underline font-medium">Publish your first one</a>
      </div>
    <% } %>

    <!-- E. Network Activity -->
    <% if (dashboard.networkLearnings && dashboard.networkLearnings.length > 0) { %>
      <h3 class="font-semibold text-lg mb-4">Network Activity</h3>
      <p class="text-sm text-gray-500 mb-4">What other organizations learned recently</p>
      <div class="space-y-3 mb-10">
        <% dashboard.networkLearnings.forEach(function(nl) { %>
          <div class="bg-white border rounded-xl p-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 mb-1"><%= nl.rule %></p>
                <% if (nl.why) { %>
                  <p class="text-xs text-gray-500 mb-2"><%= nl.why %></p>
                <% } %>
                <div class="flex items-center gap-3 text-xs text-gray-400">
                  <span class="font-medium text-otp-600"><%= nl.org_name %></span>
                  <% if (nl.agent_name) { %>
                    <span>via <%= nl.agent_name %></span>
                  <% } %>
                  <span><%= nl.created_at ? new Date(nl.created_at).toLocaleDateString() : '' %></span>
                </div>
              </div>
              <div class="flex-shrink-0">
                <span class="text-xs px-2 py-1 bg-blue-50 text-blue-600 rounded-full font-medium">Learning</span>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- F. Version History -->
    <% if (dashboard.updateHistory.length > 0) { %>
      <h3 class="font-semibold text-lg mb-4">Version History</h3>
      <div class="bg-white border rounded-xl overflow-hidden mb-8">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-left text-xs text-gray-500">
            <tr>
              <th class="px-4 py-2.5 font-medium">Version</th>
              <th class="px-4 py-2.5 font-medium">Claims</th>
              <th class="px-4 py-2.5 font-medium">Status</th>
              <th class="px-4 py-2.5 font-medium">Date</th>
            </tr>
          </thead>
          <tbody>
            <% dashboard.updateHistory.forEach(function(v) { %>
              <tr class="border-t hover:bg-gray-50 transition-colors">
                <td class="px-4 py-2.5 font-medium">v<%= v.version %></td>
                <td class="px-4 py-2.5"><%= v.claimCount %></td>
                <td class="px-4 py-2.5">
                  <span class="text-xs px-2 py-0.5 rounded-full capitalize
                    <% if (v.status === 'published') { %>bg-emerald-100 text-emerald-700<% } %>
                    <% if (v.status === 'draft') { %>bg-amber-100 text-amber-700<% } %>
                    <% if (v.status === 'archived') { %>bg-gray-100 text-gray-500<% } %>
                  "><%= v.status %></span>
                </td>
                <td class="px-4 py-2.5 text-gray-400"><%= v.publishedAt ? new Date(v.publishedAt).toLocaleDateString() : 'Not published' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>

  </div>

  <script>
    async function publishDraft(id) {
      if (!confirm('Publish this draft? It will replace your current published OOS and become visible on the network.')) return;
      try {
        var res = await fetch('/api/v1/oos/' + id + '/publish', { method: 'POST' });
        var data = await res.json();
        if (!res.ok) {
          alert('Failed to publish: ' + (data.error?.message || 'Unknown error'));
          return;
        }
        window.location.reload();
      } catch (e) {
        alert('Failed to publish: ' + e.message);
      }
    }

    async function renameOos(id) {
      var currentName = document.querySelector('#oos-row-' + id + ' .oos-name');
      var newName = prompt('Enter a new name for this OOS file:', currentName ? currentName.textContent.trim() : '');
      if (!newName || !newName.trim()) return;

      try {
        var res = await fetch('/api/v1/oos/' + id + '/rename', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: newName.trim() }),
        });
        if (!res.ok) {
          var err = await res.json();
          alert('Rename failed: ' + (err.error?.message || 'Unknown error'));
          return;
        }
        if (currentName) currentName.textContent = newName.trim();
      } catch (e) {
        alert('Rename failed: ' + e.message);
      }
    }

    async function deleteOos(id, name) {
      if (!confirm('Are you sure you want to delete "' + name + '"? This cannot be undone.')) return;

      try {
        var res = await fetch('/api/v1/oos/' + id, {
          method: 'DELETE',
        });
        if (!res.ok) {
          var err = await res.json();
          alert('Delete failed: ' + (err.error?.message || 'Unknown error'));
          return;
        }
        var row = document.getElementById('oos-row-' + id);
        if (row) row.remove();
      } catch (e) {
        alert('Delete failed: ' + e.message);
      }
    }

    async function newVersion(id) {
      if (!confirm('Create a new draft version from this published file?')) return;

      try {
        var res = await fetch('/api/v1/oos/' + id + '/new-version', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({}),
        });
        if (!res.ok) {
          var err = await res.json();
          alert('Failed to create new version: ' + (err.error?.message || 'Unknown error'));
          return;
        }
        var data = await res.json();
        window.location.href = '/publish?edit=' + data.oosFile.id;
      } catch (e) {
        alert('Failed to create new version: ' + e.message);
      }
    }

    // ---- Share Score ----
    function shareScore(score, grade, claimCount) {
      var text = 'Just checked my AI agent coordination score on OTP.\n\n';
      text += 'Coordination Score: ' + score + '/100 (Grade: ' + grade + ')\n';
      text += claimCount + ' coordination claims published.\n\n';
      text += "What's your score? Scan yours free at orgtp.com";

      // Create modal
      var modal = document.createElement('div');
      modal.id = 'share-modal';
      modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4';
      modal.innerHTML =
        '<div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-2xl">' +
          '<div class="flex items-center justify-between mb-4">' +
            '<h3 class="text-lg font-bold">Share Your Score</h3>' +
            '<button onclick="document.getElementById(\'share-modal\').remove()" class="text-gray-400 hover:text-gray-600 cursor-pointer">' +
              '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>' +
            '</button>' +
          '</div>' +
          '<div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-xl p-6 mb-4 text-center">' +
            '<p class="text-xs text-gray-400 uppercase tracking-widest mb-2">My AI Coordination Score</p>' +
            '<div class="text-6xl font-black text-white mb-1">' + score + '</div>' +
            '<div class="text-sm font-bold" style="color: ' + (score >= 80 ? '#059669' : score >= 65 ? '#0095ff' : score >= 50 ? '#d97706' : '#dc2626') + '">Grade: ' + grade + '</div>' +
            '<div class="flex items-center justify-center gap-2 text-xs text-gray-500 mt-3">' +
              '<span>Scanned by</span><span class="text-otp-400 font-semibold">orgtp.com</span>' +
            '</div>' +
          '</div>' +
          '<textarea id="dash-share-text" rows="3" class="w-full border rounded-lg p-3 text-sm resize-none mb-4 focus:border-otp-500 focus:ring-1 focus:ring-otp-500">' + text.replace(/</g, '&lt;') + '</textarea>' +
          '<div class="flex gap-2">' +
            '<button onclick="window.open(\'https://x.com/intent/tweet?text=\' + encodeURIComponent(document.getElementById(\'dash-share-text\').value), \'_blank\', \'width=600,height=400\')" class="flex-1 px-4 py-2.5 bg-black text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors cursor-pointer">Post on X</button>' +
            '<button onclick="window.open(\'https://www.linkedin.com/sharing/share-offsite/?url=\' + encodeURIComponent(\'https://orgtp.com\'), \'_blank\', \'width=600,height=500\')" class="flex-1 px-4 py-2.5 bg-[#0A66C2] text-white rounded-lg text-sm font-medium hover:bg-[#004182] transition-colors cursor-pointer">Share on LinkedIn</button>' +
            '<button onclick="navigator.clipboard.writeText(document.getElementById(\'dash-share-text\').value).then(function(){this.textContent=\'Copied!\'}.bind(this))" class="px-4 py-2.5 border rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors cursor-pointer">Copy</button>' +
          '</div>' +
        '</div>';
      document.body.appendChild(modal);
      modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });
    }
  </script>
<% } %>
