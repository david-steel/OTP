<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold">Browse Intelligence</h1>
    <a href="/publish" class="px-4 py-2 bg-otp-500 text-white rounded hover:bg-otp-400 text-sm font-medium">Publish Your OOS</a>
  </div>

  <!-- Filters -->
  <div class="bg-white p-4 rounded-lg border mb-6 flex gap-4 flex-wrap">
    <select id="filter-template" class="text-sm border rounded px-3 py-1.5">
      <option value="">All Templates</option>
      <option value="agent_army">Agent Army</option>
      <option value="value_chain">Value Chain</option>
      <option value="org_chart">Org Chart</option>
    </select>
    <select id="filter-size" class="text-sm border rounded px-3 py-1.5">
      <option value="">All Sizes</option>
      <option value="solo">Solo</option>
      <option value="small">Small</option>
      <option value="medium">Medium</option>
      <option value="large">Large</option>
      <option value="enterprise">Enterprise</option>
    </select>
    <input type="text" id="filter-industry" placeholder="Industry..." class="text-sm border rounded px-3 py-1.5 w-48">
    <select id="filter-sort" class="text-sm border rounded px-3 py-1.5">
      <option value="newest">Newest First</option>
      <option value="claims">Most Claims</option>
      <option value="quality">Highest Quality</option>
    </select>
  </div>

  <!-- OOS Cards -->
  <div id="oos-list" class="grid gap-4">
    <% if (typeof oosFiles !== 'undefined' && oosFiles.length > 0) { %>
      <% oosFiles.forEach(function(oos) { %>
        <a href="/oos/<%= oos.id %>" class="bg-white p-5 rounded-lg border claim-card flex items-start gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-semibold"><%= oos.org_name %></span>
              <% if (oos.badge === 'founding') { %>
                <span class="badge-founding text-white text-xs px-2 py-0.5 rounded">Founding</span>
              <% } %>
              <% if (oos.quality_tier) { %>
                <span class="badge-<%= oos.quality_tier %> text-white text-xs px-2 py-0.5 rounded"><%= oos.quality_tier %></span>
              <% } %>
              <% if (oos.agentic_level) { %>
                <span class="badge-level badge-level-<%= oos.agentic_level %>" title="Agentic Level">L<%= oos.agentic_level %></span>
              <% } %>
            </div>
            <div class="text-sm text-gray-500 mb-2">
              <%= oos.industry %> &middot; <%= oos.size %> &middot; v<%= oos.version %>
            </div>
            <div class="flex gap-4 text-xs text-gray-400">
              <span><%= oos.claim_count %> claims</span>
              <span class="px-2 py-0.5 bg-gray-100 rounded"><%= oos.template.replace('_', ' ') %></span>
              <span>Published <%= new Date(oos.published_at).toLocaleDateString() %></span>
            </div>
          </div>
          <div class="text-right text-xs text-gray-400 min-w-[80px]">
            <div class="flex gap-1 justify-end mb-1">
              <span class="bg-confidence-high text-white px-1.5 py-0.5 rounded"><%= (oos.confidence_distribution || {}).high || 0 %></span>
              <span class="bg-confidence-medium text-white px-1.5 py-0.5 rounded"><%= (oos.confidence_distribution || {}).medium || 0 %></span>
              <span class="bg-confidence-low text-white px-1.5 py-0.5 rounded"><%= (oos.confidence_distribution || {}).low || 0 %></span>
            </div>
            <span>H / M / L</span>
          </div>
        </a>
      <% }); %>
    <% } else { %>
      <div class="text-center py-16 text-gray-400">
        <p class="text-lg mb-2">No published OOS files yet.</p>
        <p class="text-sm">Be the first to <a href="/publish" class="text-otp-500 hover:underline">publish your coordination intelligence</a>.</p>
      </div>
    <% } %>
  </div>
</div>
