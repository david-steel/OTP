<%# /browse -- v7 layout (light, editorial). Network of published OOS files.
    Content sections only -- layout supplies head/nav/footer. %>
<style>
  .br-float { animation:br-float 7s ease-in-out infinite; }
  @keyframes br-float { 0%,100%{transform:translateY(0) rotate(-3deg);} 50%{transform:translateY(-12px) rotate(-3deg);} }
  @media (prefers-reduced-motion:reduce){ .br-float{ animation:none; } }
  .br-select {
    font-family:'JetBrains Mono',monospace; font-size:12px;
    color:var(--ink); background:var(--card);
    border:1px solid var(--line); border-radius:9px;
    padding:8px 12px; transition:border-color .15s ease;
  }
  .br-select:focus, .br-input:focus { outline:none; border-color:var(--blue); }
  .br-input {
    font-family:'Inter',sans-serif; font-size:13px;
    color:var(--ink); background:var(--card);
    border:1px solid var(--line); border-radius:9px;
    padding:8px 12px; transition:border-color .15s ease;
  }
  .br-input::placeholder { color:var(--ink-mute); }
  .br-conf {
    font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:500;
    padding:2px 6px; border-radius:5px; color:#fff;
  }
  .br-pill {
    font-family:'JetBrains Mono',monospace; font-size:9.5px; font-weight:500;
    letter-spacing:0.08em; text-transform:uppercase;
    color:var(--ink-mute); background:var(--grey);
    border:1px solid var(--line-soft); padding:3px 8px; border-radius:6px;
  }
  .br-badge {
    font-family:'JetBrains Mono',monospace; font-size:9.5px; font-weight:600;
    letter-spacing:0.06em; text-transform:uppercase;
    padding:3px 8px; border-radius:6px;
  }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16">
    <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-12">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--blue);"></span>The network
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.1rem,4.4vw,3.4rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
          Browse the <span class="text-[var(--blue)]">coordination intelligence</span> of real organizations.
        </h1>
        <p class="text-[16px] sm:text-[17px] text-[var(--ink-soft)] leading-[1.65] max-w-[36rem] mx-auto md:mx-0 mt-5">
          Every listing is a structured OOS &mdash; an Organizational Operating System with evidence-typed claims you can evaluate, compare, and learn from. Filter by industry, size, or template type. Open any card to see the full operational intelligence inside.
        </p>
        <div class="mt-7">
          <a href="/publish" class="btn-primary inline-block px-6 py-3 text-[15px]">Publish your OOS &rarr;</a>
        </div>
      </div>
      <div class="relative shrink-0" style="width:150px; max-width:38vw;">
        <img src="/public/orgy-clean.png" alt="Orgy, the OTP mascot"
             class="br-float block w-full" style="filter:drop-shadow(0 16px 26px rgba(20,22,28,.18));">
      </div>
    </div>
  </div>
</section>

<!-- ================= FILTERS + LISTINGS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-16 sm:py-20">

    <!-- Filters -->
    <div class="card p-4 sm:p-5 mb-7 flex gap-3 flex-wrap items-center">
      <div class="eyebrow mr-1 hidden sm:block">Filter</div>
      <select id="filter-template" class="br-select">
        <option value="">All Templates</option>
        <option value="agent_army">Agent Army</option>
        <option value="value_chain">Value Chain</option>
        <option value="org_chart">Org Chart</option>
      </select>
      <select id="filter-size" class="br-select">
        <option value="">All Sizes</option>
        <option value="solo">Solo</option>
        <option value="small">Small</option>
        <option value="medium">Medium</option>
        <option value="large">Large</option>
        <option value="enterprise">Enterprise</option>
      </select>
      <input type="text" id="filter-industry" placeholder="Industry..." class="br-input w-48">
      <select id="filter-sort" class="br-select sm:ml-auto">
        <option value="newest">Newest First</option>
        <option value="claims">Most Claims</option>
        <option value="quality">Highest Quality</option>
      </select>
    </div>

    <!-- OOS Cards -->
    <div id="oos-list" class="grid gap-4">
      <% if (typeof oosFiles !== 'undefined' && oosFiles.length > 0) { %>
        <% oosFiles.forEach(function(oos) { %>
          <a href="/oos/<%= oos.id %>" class="card lift p-5 sm:p-6 flex items-start gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1.5">
                <span class="font-display font-bold text-[15px] text-[var(--ink)]"><%= oos.org_name %></span>
                <% if (oos.badge === 'founding') { %>
                  <span class="br-badge" style="background:var(--orgy);color:var(--ink);">Founding</span>
                <% } %>
                <% if (oos.quality_tier) { %>
                  <span class="br-badge" style="background:var(--blue);color:#fff;"><%= oos.quality_tier %></span>
                <% } %>
                <% if (oos.agentic_level) { %>
                  <span class="br-badge" style="background:var(--ink);color:#fff;" title="Agentic Level">L<%= oos.agentic_level %></span>
                <% } %>
              </div>
              <div class="font-mono text-[12px] text-[var(--ink-mute)] mb-2.5">
                <%= oos.industry %> &middot; <%= oos.size %> &middot; v<%= oos.version %>
              </div>
              <div class="flex gap-2 flex-wrap items-center">
                <span class="br-pill"><%= oos.claim_count %> claims</span>
                <span class="br-pill"><%= oos.template.replace('_', ' ') %></span>
                <span class="text-[11px] text-[var(--ink-mute)]">Published <%= new Date(oos.published_at).toLocaleDateString() %></span>
              </div>
            </div>
            <div class="text-right shrink-0 min-w-[110px]">
              <div class="flex gap-1 justify-end mb-2">
                <span class="br-conf" style="background:var(--green);"><%= (oos.confidence_distribution || {}).high || 0 %></span>
                <span class="br-conf" style="background:var(--blue);"><%= (oos.confidence_distribution || {}).medium || 0 %></span>
                <span class="br-conf" style="background:var(--orange);"><%= (oos.confidence_distribution || {}).low || 0 %></span>
              </div>
              <%
                var bH = (oos.confidence_distribution || {}).high || 0;
                var bM = (oos.confidence_distribution || {}).medium || 0;
                var bL = (oos.confidence_distribution || {}).low || 0;
                var bT = bH + bM + bL;
                var bEff = bT > 0 ? ((bH * 7) + (bM * 3) + (bL * 1)) / bT : 0;
                var bEffClr = bEff >= 5 ? 'var(--green-deep)' : bEff >= 2 ? 'var(--blue-deep)' : bEff >= 1 ? 'var(--orange-deep)' : '#c0392b';
              %>
              <div class="font-mono text-[13px] font-semibold" style="color:<%= bEffClr %>;"><%= bEff.toFixed(1) %>x efficiency</div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="card p-12 sm:p-16 text-center">
          <div class="font-display text-[1.2rem] font-bold text-[var(--ink)] mb-2">No published OOS files yet.</div>
          <p class="text-[14px] text-[var(--ink-soft)] leading-[1.6]">
            Be the first to <a href="/publish" class="text-[var(--blue-deep)] font-semibold link-u">publish your coordination intelligence</a>.
          </p>
        </div>
      <% } %>
    </div>
  </div>
</section>
