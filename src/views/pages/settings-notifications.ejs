<% /* XSS guard: embed a value in an inline <script> via jsonForScript() -- escapes < and > so a value containing </script> can't break out of the script context. */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%- include('../partials/orgy-palette'); %>
<%
  // ---- Settings: Notifications (User Settings) ----
  // Locals: notifications { assignedToYou:{email,web,mobile}, comments:{...}, mentions:{...}, headlines:{...} }
  //   (may be empty {} -- every missing key defaults to false).
  // Auto-injected: memberRole, currentPath, assetVersion, authState.
  // Everything below is typeof-guarded so the page never throws on a missing local.
  var _av    = (typeof assetVersion !== 'undefined') ? assetVersion : 'dev';
  var _auth  = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _notif = (typeof notifications !== 'undefined' && notifications && typeof notifications === 'object') ? notifications : {};

  // Normalize a single event row into {email,web,mobile} booleans, defaulting missing keys to false.
  function _chan(key) {
    var row = (_notif[key] && typeof _notif[key] === 'object') ? _notif[key] : {};
    return {
      email:  row.email  === true,
      web:    row.web    === true,
      mobile: row.mobile === true
    };
  }

  var _events = [
    { id: 'assignedToYou', label: 'Assigned to you',               desc: 'A Rock, To-Do, Issue, or Milestone is assigned to you.' },
    { id: 'comments',      label: 'Comments',                      desc: 'Someone comments on an item you own or follow.' },
    { id: 'mentions',      label: 'Mentions',                      desc: 'Someone mentions you in a comment or description.' },
    { id: 'headlines',     label: 'Headlines & Cascading Messages', desc: 'A headline or cascading message is sent to your team(s).' }
  ];

  var _channels = [
    { id: 'email',  label: 'Email' },
    { id: 'web',    label: 'Web' },
    { id: 'mobile', label: 'Mobile' }
  ];
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%- include('../partials/ui-page-header', { helpKey: 'settings.notifications', title: 'Notifications', eyebrow: 'User Settings', subtitle: 'Choose what you get notified about and where.', mascot: 'mcp-api' }) %>


    <% if (_auth === 'unauthenticated') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Sign in to manage your notifications.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Sign In</a>
      </div>
    <% } else if (_auth === 'no_org') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Complete your organization profile first.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Set Up Profile</a>
      </div>
    <% } else { %>

      <!-- two-column: nav stacks above content on mobile, sidebar on >=md -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">

        <!-- left: settings nav -->
        <%- include('../partials/settings-nav') %>

        <!-- right: content -->
        <form id="notifications-form" class="flex-1 min-w-0 w-full space-y-6">

          <div class="flex items-center justify-between gap-4">
            <h2 class="font-bold text-gray-900 text-lg">Notification Events</h2>
            <button type="submit"
                    class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
              Save Changes
            </button>
          </div>

          <!-- Notification matrix card -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">What you get notified about</h3>
            <p class="text-sm text-gray-500 mb-4">Pick a delivery channel for each event.</p>

            <div class="overflow-x-auto -mx-2 px-2">
              <table class="w-full min-w-[28rem] text-sm">
                <thead>
                  <tr class="text-left text-gray-500 border-b">
                    <th class="py-2 pr-4 font-semibold">Event</th>
                    <% _channels.forEach(function(c) { %>
                      <th class="py-2 px-3 font-semibold text-center w-20"><%= c.label %></th>
                    <% }); %>
                  </tr>
                </thead>
                <tbody>
                  <% _events.forEach(function(ev) { %>
                    <% var _v = _chan(ev.id); %>
                    <tr class="border-b last:border-0 align-top">
                      <td class="py-3 pr-4">
                        <div class="font-medium text-gray-900"><%= ev.label %></div>
                        <div class="text-gray-500 text-xs mt-0.5"><%= ev.desc %></div>
                      </td>
                      <% _channels.forEach(function(c) { %>
                        <td class="py-3 px-3 text-center">
                          <label class="inline-flex items-center justify-center cursor-pointer">
                            <input type="checkbox"
                                   data-event="<%= ev.id %>"
                                   data-channel="<%= c.id %>"
                                   name="<%= ev.id %>.<%= c.id %>"
                                   class="notif-cell h-4 w-4 text-otp-500 focus:ring-otp-500 rounded"
                                   <%= _v[c.id] ? 'checked' : '' %>>
                          </label>
                        </td>
                      <% }); %>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <button type="submit"
                    class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
              Save Changes
            </button>
            <span id="notif-saved" class="hidden text-sm font-semibold text-green-600">Saved</span>
          </div>

        </form>
      </div>

    <% } %>
</div>

<script>
  (function () {
    var form = document.getElementById('notifications-form');
    if (!form) return;
    var saved = document.getElementById('notif-saved');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      // Gather every cell into a nested { event: { channel: bool } } object.
      var notifications = {};
      var cells = form.querySelectorAll('input.notif-cell');
      cells.forEach(function (el) {
        var ev = el.getAttribute('data-event');
        var ch = el.getAttribute('data-channel');
        if (!ev || !ch) return;
        if (!notifications[ev]) notifications[ev] = {};
        notifications[ev][ch] = el.checked;
      });

      try {
        var res = await fetch('/settings/notifications', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ notifications: notifications })
        });

        if (!res.ok) {
          var data = {};
          try { data = await res.json(); } catch (_) {}
          alert((data && data.error && data.error.message) || (data && data.error) || 'Failed to save notifications');
          return;
        }

        if (saved) {
          saved.classList.remove('hidden');
          setTimeout(function () { saved.classList.add('hidden'); }, 2500);
        }
      } catch (err) {
        alert('Failed to save notifications');
      }
    });
  })();
</script>
