<div class="max-w-4xl mx-auto px-4 py-8">

  <!-- Loading State -->
  <div id="loading-state" class="text-center py-20">
    <div class="inline-block w-12 h-12 border-4 border-gray-200 border-t-otp-500 rounded-full animate-spin mb-4"></div>
    <p class="text-gray-500 text-sm">Loading your scan results...</p>
  </div>

  <!-- No Data State -->
  <div id="no-data-state" class="hidden text-center py-20">
    <p class="text-gray-500 mb-4">No scan data found. Run the wizard first.</p>
    <a href="/publish" class="inline-block px-6 py-2.5 bg-otp-500 text-white rounded-lg font-medium text-sm hover:bg-otp-400 transition-colors">Go to Publish Wizard</a>
  </div>

  <!-- Results Container -->
  <div id="results-container" class="hidden">

    <!-- Back Link -->
    <div class="mb-6">
      <a href="/publish" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">&larr; Back to wizard</a>
    </div>

    <!-- Coordination Score Hero -->
    <div class="text-center py-10 mb-8">
      <div class="relative inline-block mb-4">
        <svg id="score-ring" class="w-48 h-48" viewBox="0 0 200 200">
          <circle cx="100" cy="100" r="88" fill="none" stroke="#e5e7eb" stroke-width="12" />
          <circle id="score-arc" cx="100" cy="100" r="88" fill="none" stroke="#0095ff" stroke-width="12"
            stroke-linecap="round" stroke-dasharray="553" stroke-dashoffset="553"
            transform="rotate(-90 100 100)" style="transition: stroke-dashoffset 1.5s ease-out, stroke 0.5s ease;" />
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl font-black text-gray-900" id="score-value">--</div>
          <div class="text-lg font-bold mt-1" id="score-grade" style="color: #0095ff;">--</div>
        </div>
      </div>
      <p class="text-gray-400 text-sm font-medium tracking-wide uppercase">Coordination Score</p>
      <p class="text-gray-500 text-xs mt-2 max-w-md mx-auto" id="score-tagline"></p>
    </div>

    <!-- Vulnerability Scan (pre-publish gate) -->
    <div id="vuln-section" class="hidden mb-8">
      <div id="vuln-blocked" class="hidden bg-red-50 border-2 border-red-300 rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-red-800">Vulnerability Scan</h2>
            <p class="text-sm text-red-600" id="vuln-subtitle">Sensitive data detected. Fix before publishing.</p>
          </div>
        </div>
        <div class="space-y-2" id="vuln-flags"></div>
        <p class="text-xs text-red-500 mt-4" id="vuln-footer">Remove or redact flagged items before publishing to the OTP network.</p>
      </div>
      <div id="vuln-clean" class="hidden bg-green-50 border border-green-200 rounded-xl p-4">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <p class="text-sm font-medium text-green-800">Vulnerability scan clean. No sensitive data detected.</p>
        </div>
      </div>
    </div>

    <!-- Foundation Score -->
    <div id="foundation-section" class="hidden mb-8">
      <div class="bg-white border rounded-xl p-6">
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <h2 class="text-lg font-bold">Foundation Score</h2>
            <span id="foundation-badge" class="text-xs font-bold px-2.5 py-1 rounded-full"></span>
          </div>
          <div class="text-right">
            <div class="text-3xl font-black" id="foundation-value">--</div>
            <div class="text-xs text-gray-500">/ 100</div>
          </div>
        </div>
        <p class="text-sm text-gray-500 mb-4" id="foundation-tagline"></p>
        <!-- Critical fixes -->
        <div id="foundation-critical" class="hidden mb-4">
          <h3 class="text-sm font-semibold text-red-700 mb-2 flex items-center gap-1.5">
            <span class="w-2 h-2 bg-red-500 rounded-full"></span>
            <span id="foundation-critical-label">Fix Now</span>
          </h3>
          <div class="space-y-2" id="foundation-critical-list"></div>
        </div>
        <!-- Warnings -->
        <div id="foundation-warnings" class="hidden mb-4">
          <h3 class="text-sm font-semibold text-amber-700 mb-2 flex items-center gap-1.5">
            <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
            <span id="foundation-warning-label">Should Fix</span>
          </h3>
          <div class="space-y-2" id="foundation-warning-list"></div>
        </div>
        <!-- Passed -->
        <div id="foundation-passed" class="hidden">
          <h3 class="text-sm font-semibold text-green-700 mb-2 flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
            <span id="foundation-passed-label">Looking Good</span>
          </h3>
          <div class="space-y-1" id="foundation-passed-list"></div>
        </div>
      </div>
    </div>

    <!-- 6-Dimension Breakdown -->
    <div class="bg-white border rounded-xl p-6 mb-8">
      <h2 class="text-lg font-bold mb-5">Coordination Breakdown</h2>
      <div class="space-y-4" id="dimension-bars"></div>
    </div>

    <!-- Insights Section -->
    <div id="insights-section" class="mb-8">
      <h2 class="text-lg font-bold mb-5">Insights</h2>

      <!-- Critical -->
      <div id="insights-critical" class="hidden mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2 h-2 bg-red-500 rounded-full"></span>
          <h3 class="text-sm font-semibold text-red-700" id="critical-label">Critical</h3>
        </div>
        <div class="space-y-3" id="critical-cards"></div>
      </div>

      <!-- Warnings -->
      <div id="insights-warning" class="hidden mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
          <h3 class="text-sm font-semibold text-amber-700" id="warning-label">Warnings</h3>
        </div>
        <div class="space-y-3" id="warning-cards"></div>
      </div>

      <!-- Info -->
      <div id="insights-info" class="hidden mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
          <h3 class="text-sm font-semibold text-blue-700" id="info-label">Info</h3>
        </div>
        <div class="space-y-3" id="info-cards"></div>
      </div>

      <!-- Positive -->
      <div id="insights-positive" class="hidden mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2 h-2 bg-green-500 rounded-full"></span>
          <h3 class="text-sm font-semibold text-green-700" id="positive-label">Strengths</h3>
        </div>
        <div class="space-y-3" id="positive-cards"></div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t">
      <button type="button" onclick="publishNow()" id="continue-btn" class="flex-1 px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold text-sm hover:bg-otp-400 transition-colors cursor-pointer">
        Publish to OTP Network
      </button>
      <button type="button" onclick="shareScore()" id="share-btn" class="flex-1 px-6 py-3 bg-gradient-to-r from-purple-600 to-otp-500 text-white rounded-lg font-semibold text-sm hover:from-purple-500 hover:to-otp-400 transition-all cursor-pointer flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        Share Your Score
      </button>
      <button type="button" onclick="scrollToVulnerabilities()" id="vuln-btn" class="hidden flex-1 px-6 py-3 border border-amber-300 text-amber-700 rounded-lg font-medium text-sm hover:bg-amber-50 transition-colors cursor-pointer flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        Review Vulnerabilities
      </button>
      <button type="button" onclick="scrollToIssues()" id="fix-btn" class="hidden flex-1 px-6 py-3 border border-red-200 text-red-700 rounded-lg font-medium text-sm hover:bg-red-50 transition-colors cursor-pointer">
        Fix Issues First
      </button>
    </div>
    <p class="text-xs text-gray-400 text-center mt-2" id="publish-status"></p>

    <!-- Share Modal -->
    <div id="share-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
      <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-2xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold">Share Your Score</h3>
          <button onclick="closeShareModal()" class="text-gray-400 hover:text-gray-600 cursor-pointer">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- Score preview card -->
        <div id="share-card" class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-xl p-6 mb-4 text-center">
          <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">My AI Coordination Score</p>
          <div class="text-6xl font-black text-white mb-1" id="share-score-val">--</div>
          <div class="text-sm font-bold mb-3" id="share-grade" style="color: #0095ff;">--</div>
          <div class="flex items-center justify-center gap-2 text-xs text-gray-500">
            <span>Scanned by</span>
            <span class="text-otp-400 font-semibold">orgtp.com</span>
          </div>
        </div>

        <!-- Share text -->
        <textarea id="share-text" rows="3" class="w-full border rounded-lg p-3 text-sm resize-none mb-4 focus:border-otp-500 focus:ring-1 focus:ring-otp-500"></textarea>

        <!-- Platform buttons -->
        <div class="flex gap-2">
          <button onclick="shareToX()" class="flex-1 px-4 py-2.5 bg-black text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors cursor-pointer flex items-center justify-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Post on X
          </button>
          <button onclick="shareToLinkedIn()" class="flex-1 px-4 py-2.5 bg-[#0A66C2] text-white rounded-lg text-sm font-medium hover:bg-[#004182] transition-colors cursor-pointer flex items-center justify-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Share on LinkedIn
          </button>
          <button onclick="copyShareText()" id="copy-btn" class="px-4 py-2.5 border rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors cursor-pointer flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            Copy
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var DIMENSION_LABELS = {
    conflictManagement: 'Conflict Management',
    escalationStructure: 'Escalation Structure',
    workflowClarity: 'Workflow Clarity',
    humanOversight: 'Human Oversight',
    systemRedundancy: 'System Redundancy',
    authorityBoundaries: 'Authority Boundaries'
  };

  var GRADE_COLORS = {
    A: '#059669',
    B: '#0095ff',
    C: '#d97706',
    D: '#ea580c',
    F: '#dc2626'
  };

  var GRADE_TAGLINES = {
    A: 'Your AI coordination is well-structured. Small refinements ahead.',
    B: 'Solid foundation with clear improvement opportunities.',
    C: 'Functional but exposed. Several gaps need attention.',
    D: 'Significant coordination gaps. Address critical issues before scaling.',
    F: 'Your AI agents are operating without meaningful coordination. Start here.'
  };

  function init() {
    var raw = localStorage.getItem('otp_scan_result');
    var loading = document.getElementById('loading-state');
    var noData = document.getElementById('no-data-state');
    var container = document.getElementById('results-container');

    if (!raw) {
      loading.classList.add('hidden');
      noData.classList.remove('hidden');
      return;
    }

    var data;
    try { data = JSON.parse(raw); } catch(e) {
      loading.classList.add('hidden');
      noData.classList.remove('hidden');
      return;
    }

    loading.classList.add('hidden');
    container.classList.remove('hidden');

    // Build and cache the complete OOS document for the resolve-insight flow
    var built = buildOOSFromScanResult();
    if (built) {
      localStorage.setItem('otp_generated_oos', built.content);
    }

    renderScore(data.score);
    renderVulnerabilityScan(data.vulnerabilityScan);
    renderFoundationScore(data.foundationScore);
    renderDimensions(data.score.breakdown);
    renderInsights(data.insights || []);

    // Auto-publish if returning from sign-in
    if (localStorage.getItem('otp_auto_publish') === 'true') {
      localStorage.removeItem('otp_auto_publish');
      setTimeout(function() { publishNow(); }, 1000);
    }
  }

  function renderScore(score) {
    var value = score.overall;
    var grade = score.grade;
    var color = GRADE_COLORS[grade] || '#0095ff';

    // Animate the number
    var el = document.getElementById('score-value');
    animateNumber(el, 0, value, 1200);

    // Set grade
    var gradeEl = document.getElementById('score-grade');
    gradeEl.textContent = 'Grade: ' + grade;
    gradeEl.style.color = color;

    // Set tagline
    document.getElementById('score-tagline').textContent = GRADE_TAGLINES[grade] || '';

    // Animate the ring
    var arc = document.getElementById('score-arc');
    var circumference = 553; // 2 * PI * 88
    var offset = circumference - (circumference * value / 100);
    arc.setAttribute('stroke', color);
    setTimeout(function() {
      arc.style.strokeDashoffset = offset;
    }, 100);
  }

  function animateNumber(el, from, to, duration) {
    var start = performance.now();
    function tick(now) {
      var progress = Math.min((now - start) / duration, 1);
      // Ease out cubic
      var eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(from + (to - from) * eased);
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function renderDimensions(breakdown) {
    var container = document.getElementById('dimension-bars');
    var keys = ['conflictManagement', 'escalationStructure', 'workflowClarity', 'humanOversight', 'systemRedundancy', 'authorityBoundaries'];

    keys.forEach(function(key, index) {
      var val = breakdown[key] || 0;
      var label = DIMENSION_LABELS[key] || key;
      var barColor = val >= 70 ? 'bg-green-500' : val >= 40 ? 'bg-amber-500' : 'bg-red-500';
      var textColor = val >= 70 ? 'text-green-700' : val >= 40 ? 'text-amber-700' : 'text-red-700';

      var row = document.createElement('div');
      row.innerHTML =
        '<div class="flex items-center justify-between mb-1.5">' +
          '<span class="text-sm font-medium text-gray-700">' + escapeHtml(label) + '</span>' +
          '<span class="text-sm font-bold ' + textColor + '">' + val + '</span>' +
        '</div>' +
        '<div class="h-2.5 bg-gray-100 rounded-full overflow-hidden">' +
          '<div class="h-full rounded-full transition-all duration-1000 ease-out ' + barColor + '" style="width: 0%;" data-target="' + val + '"></div>' +
        '</div>';

      container.appendChild(row);

      // Animate bar width
      setTimeout(function() {
        var bar = row.querySelector('[data-target]');
        bar.style.width = val + '%';
      }, 200 + (index * 100));
    });
  }

  function renderInsights(insights) {
    var groups = { critical: [], warning: [], info: [], positive: [] };
    insights.forEach(function(ins) {
      if (groups[ins.severity]) groups[ins.severity].push(ins);
    });

    var hasCritical = groups.critical.length > 0;

    renderInsightGroup('critical', groups.critical, 'border-red-200 bg-red-50', 'bg-red-100 text-red-800');
    renderInsightGroup('warning', groups.warning, 'border-amber-200 bg-amber-50', 'bg-amber-100 text-amber-800');
    renderInsightGroup('info', groups.info, 'border-blue-200 bg-blue-50', 'bg-blue-100 text-blue-800');
    renderInsightGroup('positive', groups.positive, 'border-green-200 bg-green-50', 'bg-green-100 text-green-800');

    // Show "Fix Issues First" button if there are critical insights
    if (hasCritical) {
      document.getElementById('fix-btn').classList.remove('hidden');
    }

    // Update labels with counts
    if (groups.critical.length) document.getElementById('critical-label').textContent = 'Critical (' + groups.critical.length + ')';
    if (groups.warning.length) document.getElementById('warning-label').textContent = 'Warnings (' + groups.warning.length + ')';
    if (groups.info.length) document.getElementById('info-label').textContent = 'Info (' + groups.info.length + ')';
    if (groups.positive.length) document.getElementById('positive-label').textContent = 'Strengths (' + groups.positive.length + ')';
  }

  function renderInsightGroup(severity, items, cardClasses, badgeClasses) {
    if (items.length === 0) return;
    var section = document.getElementById('insights-' + severity);
    var container = document.getElementById(severity + '-cards');
    section.classList.remove('hidden');

    items.forEach(function(ins) {
      var card = document.createElement('div');
      card.className = 'insight-card border rounded-lg p-4 ' + cardClasses;
      card.setAttribute('data-insight-id', ins.id || '');
      card.setAttribute('data-severity', severity);
      card.setAttribute('data-title', ins.title || '');
      card.setAttribute('data-description', ins.description || '');
      card.setAttribute('data-recommendation', ins.recommendation || '');

      var html =
        '<div class="flex items-start gap-3">' +
          '<div class="flex-1">' +
            '<div class="flex items-center gap-2 mb-1">' +
              '<span class="text-xs font-semibold px-2 py-0.5 rounded-full ' + badgeClasses + '">' + severity.charAt(0).toUpperCase() + severity.slice(1) + '</span>' +
              '<h4 class="text-sm font-bold text-gray-900">' + escapeHtml(ins.title) + '</h4>' +
            '</div>' +
            '<p class="text-sm text-gray-700 mb-2">' + escapeHtml(ins.description) + '</p>';

      if (ins.recommendation) {
        html += '<p class="text-xs text-gray-600 mb-3"><span class="font-semibold">Recommendation:</span> ' + escapeHtml(ins.recommendation) + '</p>';
      }

      // Resolve input for critical and warning insights
      if (severity === 'critical' || severity === 'warning') {
        html += '<div class="resolve-area mt-3 pt-3 border-t border-gray-200/50">' +
          '<div class="resolve-input-area hidden">' +
            '<label class="text-xs font-semibold text-gray-600 mb-1 block">How will you fix this?</label>' +
            '<textarea class="resolve-input w-full text-sm border rounded-lg p-3 mb-2 resize-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500" rows="2" placeholder="' + escapeHtml(ins.recommendation || 'Describe your resolution...') + '">' + escapeHtml(ins.recommendation || '') + '</textarea>' +
            '<div class="flex items-center gap-2">' +
              '<button class="resolve-submit px-4 py-1.5 bg-otp-500 text-white rounded-lg text-xs font-medium hover:bg-otp-400 transition-colors cursor-pointer">Save as Claim</button>' +
              '<button class="resolve-cancel px-3 py-1.5 text-gray-500 text-xs hover:text-gray-700 cursor-pointer">Cancel</button>' +
              '<span class="resolve-status text-xs"></span>' +
            '</div>' +
          '</div>' +
          '<button class="resolve-trigger px-4 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-xs font-medium hover:bg-gray-50 transition-colors cursor-pointer">Resolve This</button>' +
        '</div>';
      }

      if (ins.affectedEntities && ins.affectedEntities.length > 0) {
        html += '<div class="flex flex-wrap gap-1.5 mt-2">';
        ins.affectedEntities.forEach(function(entity) {
          html += '<span class="text-xs px-2 py-0.5 bg-white/70 border rounded-full text-gray-600">' + escapeHtml(entity) + '</span>';
        });
        html += '</div>';
      }

      html += '</div></div>';
      card.innerHTML = html;
      container.appendChild(card);
    });
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // ---- Vulnerability Scan ----
  function renderVulnerabilityScan(scan) {
    if (!scan) return;
    var section = document.getElementById('vuln-section');
    section.classList.remove('hidden');

    if (scan.clean) {
      document.getElementById('vuln-clean').classList.remove('hidden');
      return;
    }

    document.getElementById('vuln-blocked').classList.remove('hidden');
    var subtitle = document.getElementById('vuln-subtitle');
    subtitle.textContent = scan.summary.critical + ' critical, ' + scan.summary.high + ' high, ' + scan.summary.medium + ' medium, ' + scan.summary.low + ' low';

    // If no critical items, soften the styling to amber warning instead of red block
    if (scan.summary.critical === 0) {
      var blocked = document.getElementById('vuln-blocked');
      blocked.className = 'bg-amber-50 border-2 border-amber-300 rounded-xl p-6';
      subtitle.textContent = 'Sensitive data detected. Review before publishing.';
      subtitle.className = 'text-sm text-amber-600';
      blocked.querySelector('h2').className = 'text-lg font-bold text-amber-800';
      blocked.querySelector('.w-10').className = 'w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0';
      blocked.querySelector('svg').className = 'w-5 h-5 text-amber-600';
      var footer = document.getElementById('vuln-footer');
      footer.className = 'text-xs text-amber-500 mt-4';
      footer.textContent = 'These items are flagged for review. You can still publish, but consider redacting sensitive data first.';
    }

    var container = document.getElementById('vuln-flags');
    var SEVERITY_STYLES = {
      critical: 'bg-red-100 border-red-300 text-red-900',
      high: 'bg-orange-50 border-orange-200 text-orange-900',
      medium: 'bg-amber-50 border-amber-200 text-amber-900',
      low: 'bg-gray-50 border-gray-200 text-gray-700',
    };
    var SEVERITY_BADGES = {
      critical: 'bg-red-600 text-white',
      high: 'bg-orange-500 text-white',
      medium: 'bg-amber-500 text-white',
      low: 'bg-gray-400 text-white',
    };
    var CATEGORY_ICONS = {
      financial: '$',
      personal: 'person',
      credentials: 'key',
      infrastructure: 'server',
      business: 'briefcase',
    };

    // Sort by severity
    var order = { critical: 0, high: 1, medium: 2, low: 3 };
    var sorted = (scan.flags || []).slice().sort(function(a, b) { return (order[a.severity] || 4) - (order[b.severity] || 4); });

    sorted.forEach(function(flag, idx) {
      var div = document.createElement('div');
      div.className = 'vuln-flag border rounded-lg p-3 ' + (SEVERITY_STYLES[flag.severity] || SEVERITY_STYLES.low);
      div.setAttribute('data-vuln-idx', idx);
      div.innerHTML =
        '<div class="flex items-start gap-3">' +
          '<span class="text-xs font-bold px-2 py-0.5 rounded-full flex-shrink-0 ' + (SEVERITY_BADGES[flag.severity] || '') + '">' + flag.severity.toUpperCase() + '</span>' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-center gap-2 mb-1">' +
              '<span class="text-xs font-semibold uppercase opacity-70">' + escapeHtml(flag.type.replace(/_/g, ' ')) + '</span>' +
              '<span class="text-xs opacity-50">' + escapeHtml(flag.category) + '</span>' +
            '</div>' +
            '<p class="text-sm font-mono break-all mb-1 vuln-text">' + escapeHtml(flag.text) + '</p>' +
            '<p class="text-xs opacity-75">' + escapeHtml(flag.suggestion) + '</p>' +
          '</div>' +
          '<button class="vuln-remove flex-shrink-0 px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-xs font-medium hover:bg-red-50 hover:border-red-300 hover:text-red-700 transition-colors cursor-pointer" data-flag-text="' + escapeHtml(flag.text) + '" data-flag-type="' + escapeHtml(flag.type) + '">Remove</button>' +
        '</div>';
      container.appendChild(div);
    });

    // Show "Review Vulnerabilities" button if there are findings
    if (scan.flags && scan.flags.length > 0) {
      document.getElementById('vuln-btn').classList.remove('hidden');
    }

    // Track removed count
    var vulnRemovedCount = 0;
    var vulnTotalCount = sorted.length;

    // Handle remove button clicks
    container.addEventListener('click', function(e) {
      var removeBtn = e.target.closest('.vuln-remove');
      if (!removeBtn) return;

      var flagText = removeBtn.getAttribute('data-flag-text');
      var flagType = removeBtn.getAttribute('data-flag-type');
      var card = removeBtn.closest('.vuln-flag');

      // Remove the flagged text from the stored OOS content
      var scanRaw = localStorage.getItem('otp_scan_result');
      if (scanRaw) {
        try {
          var scanObj = JSON.parse(scanRaw);
          if (scanObj.oos && scanObj.oos.rawMarkdown) {
            scanObj.oos.rawMarkdown = scanObj.oos.rawMarkdown.split(flagText).join('[REDACTED]');
            localStorage.setItem('otp_scan_result', JSON.stringify(scanObj));
          }
        } catch(ex) {}
      }

      // Also update otp_generated_oos
      var oosContent = localStorage.getItem('otp_generated_oos');
      if (oosContent) {
        localStorage.setItem('otp_generated_oos', oosContent.split(flagText).join('[REDACTED]'));
      }

      // Mark card as resolved
      card.style.opacity = '0.4';
      card.style.pointerEvents = 'none';
      removeBtn.textContent = 'Removed';
      removeBtn.disabled = true;
      removeBtn.className = 'flex-shrink-0 px-3 py-1.5 bg-green-100 border border-green-300 text-green-700 rounded-lg text-xs font-medium';

      vulnRemovedCount++;

      // Update subtitle
      var remaining = vulnTotalCount - vulnRemovedCount;
      subtitle.textContent = remaining > 0
        ? remaining + ' remaining (' + vulnRemovedCount + ' removed)'
        : 'All items resolved!';

      // If all resolved, update styling to green
      if (remaining === 0) {
        var blocked = document.getElementById('vuln-blocked');
        blocked.className = 'bg-green-50 border-2 border-green-300 rounded-xl p-6';
        blocked.querySelector('h2').className = 'text-lg font-bold text-green-800';
        blocked.querySelector('h2').textContent = 'Vulnerability Scan Complete';
        var footer = document.getElementById('vuln-footer');
        footer.className = 'text-xs text-green-500 mt-4';
        footer.textContent = 'All flagged items have been redacted. Safe to publish.';
        document.getElementById('vuln-btn').classList.add('hidden');
      }
    });
  }

  // ---- Foundation Score ----
  function renderFoundationScore(fs) {
    if (!fs) return;
    var section = document.getElementById('foundation-section');
    section.classList.remove('hidden');

    // Score + badge
    var valueEl = document.getElementById('foundation-value');
    animateNumber(valueEl, 0, fs.score, 800);

    var badge = document.getElementById('foundation-badge');
    var BADGE_STYLES = {
      A: 'bg-green-100 text-green-800',
      B: 'bg-blue-100 text-blue-800',
      C: 'bg-amber-100 text-amber-800',
      D: 'bg-orange-100 text-orange-800',
      F: 'bg-red-100 text-red-800',
    };
    badge.textContent = fs.grade;
    badge.className = 'text-xs font-bold px-2.5 py-1 rounded-full ' + (BADGE_STYLES[fs.grade] || BADGE_STYLES.C);

    var TAGLINES = {
      A: 'Your foundation is solid. Minor refinements possible.',
      B: 'Good structural foundation. A few things to tighten up.',
      C: 'Functional but exposed. Fix the critical items below.',
      D: 'Significant structural gaps. Address these before scaling.',
      F: 'Your AI system is missing fundamental safety structures. Fix these now.',
    };
    document.getElementById('foundation-tagline').textContent = TAGLINES[fs.grade] || '';

    // Render checks by category
    var critical = (fs.checks || []).filter(function(c) { return !c.passed && c.severity === 'critical'; });
    var warnings = (fs.checks || []).filter(function(c) { return !c.passed && c.severity === 'warning'; });
    var passed = (fs.checks || []).filter(function(c) { return c.passed; });

    if (critical.length > 0) {
