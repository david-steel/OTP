    if (warnings.length > 0) {
      document.getElementById('foundation-warnings').classList.remove('hidden');
      document.getElementById('foundation-warning-label').textContent = 'Should Fix (' + warnings.length + ')';
      var wList = document.getElementById('foundation-warning-list');
      warnings.forEach(function(c) {
        var div = document.createElement('div');
        div.className = 'bg-amber-50 border border-amber-200 rounded-lg p-3';
        div.innerHTML =
          '<div class="flex items-start gap-2">' +
            '<span class="text-xs font-mono text-amber-400 flex-shrink-0 mt-0.5">' + escapeHtml(c.id) + '</span>' +
            '<div>' +
              '<p class="text-sm font-medium text-amber-800">' + escapeHtml(c.message) + '</p>' +
              '<p class="text-xs text-amber-600 mt-1">' + escapeHtml(c.fix) + '</p>' +
            '</div>' +
          '</div>';
        wList.appendChild(div);
      });
    }

    if (passed.length > 0) {
      document.getElementById('foundation-passed').classList.remove('hidden');
      document.getElementById('foundation-passed-label').textContent = 'Looking Good (' + passed.length + ')';
      var pList = document.getElementById('foundation-passed-list');
      passed.forEach(function(c) {
        var div = document.createElement('div');
        div.className = 'flex items-center gap-2 py-1';
        div.innerHTML =
          '<svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>' +
          '<span class="text-sm text-gray-600">' + escapeHtml(c.name) + '</span>';
        pList.appendChild(div);
      });
    }

    // Color the foundation score value
    valueEl.style.color = fs.score >= 80 ? '#059669' : fs.score >= 50 ? '#d97706' : '#dc2626';
  }

