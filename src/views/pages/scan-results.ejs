  // Resolve insight handlers
  var resolvedCount = 0;
  var totalActionable = 0;
  var oosContent = localStorage.getItem('otp_generated_oos') || '';

  document.addEventListener('click', function(e) {
    // Open resolve input
    var trigger = e.target.closest('.resolve-trigger');
    if (trigger) {
      var card = trigger.closest('.insight-card');
      card.querySelector('.resolve-input-area').classList.remove('hidden');
      trigger.classList.add('hidden');
      card.querySelector('.resolve-input').focus();
      return;
    }

    // Cancel resolve
    var cancel = e.target.closest('.resolve-cancel');
    if (cancel) {
      var card = cancel.closest('.insight-card');
      card.querySelector('.resolve-input-area').classList.add('hidden');
      card.querySelector('.resolve-trigger').classList.remove('hidden');
      return;
    }

    // Submit resolve
    var submit = e.target.closest('.resolve-submit');
    if (submit) {
      var card = submit.closest('.insight-card');
      var resolution = card.querySelector('.resolve-input').value.trim();
      if (!resolution) return;

      var status = card.querySelector('.resolve-status');
      submit.disabled = true;
      submit.textContent = 'Saving...';
      status.textContent = '';

      fetch('/api/v1/scanner/resolve-insight', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          insight_id: card.dataset.insightId,
          insight_title: card.dataset.title,
          insight_description: card.dataset.description,
          resolution: resolution,
          oos_content: oosContent,
        }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.claim) {
          // Success -- mark card as resolved
          oosContent = data.updatedOosContent || oosContent;
          localStorage.setItem('otp_generated_oos', oosContent);

          card.querySelector('.resolve-area').innerHTML =
            '<div class="flex items-center gap-2 text-xs text-green-700 font-medium">' +
              '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>' +
              'Resolved as claim ' + escapeHtml(data.claim.claimId) + ' in ' + escapeHtml(data.section || 'your OOS') +
            '</div>';
          card.style.opacity = '0.6';

          resolvedCount++;
          updateResolvedCounter();

          // Bump score display
          var scoreEl = document.getElementById('score-value');
          var currentScore = parseInt(scoreEl.textContent) || 0;
          var bump = card.dataset.severity === 'critical' ? 8 : 4;
          var newScore = Math.min(100, currentScore + bump);
          animateNumber(scoreEl, currentScore, newScore, 500);
        } else {
          status.textContent = data.error?.message || 'Failed to save';
          status.style.color = '#dc2626';
          submit.disabled = false;
          submit.textContent = 'Save as Claim';
        }
      })
      .catch(function() {
        status.textContent = 'Network error';
        status.style.color = '#dc2626';
        submit.disabled = false;
        submit.textContent = 'Save as Claim';
      });
    }
  });

  // Build a complete OOS document from scan result data
  function buildOOSFromScanResult() {
    var scanRaw = localStorage.getItem('otp_scan_result');
    if (!scanRaw) { console.log('[OTP] No scan result in localStorage'); return null; }
    var scanData;
    try { scanData = JSON.parse(scanRaw); } catch(e) { console.log('[OTP] Failed to parse scan result'); return null; }
    if (!scanData.oos) { console.log('[OTP] No oos in scan data'); return null; }
    if (!scanData.oos.rawMarkdown) { console.log('[OTP] No rawMarkdown in oos'); return null; }

    var fm = scanData.oos.frontmatter || {};
    var body = scanData.oos.rawMarkdown;
    var template = scanData.oos.template || 'agent_army';

    var yaml = '---\n';
    yaml += 'oos_version: "' + (fm.oos_version || '1.0') + '"\n';
    yaml += 'org_pseudonym: "' + (fm.org_pseudonym || 'Unknown') + '"\n';
    yaml += 'industry: "' + (fm.industry || 'technology') + '"\n';
    yaml += 'org_size: ' + (fm.org_size || 'small') + '\n';
    yaml += 'template: ' + template + '\n';
    yaml += 'agent_count: ' + (fm.agent_count || 0) + '\n';
    yaml += 'platforms: [' + (fm.platforms || []).map(function(p) { return '"' + p + '"'; }).join(', ') + ']\n';
    yaml += 'mcp_servers: [' + (fm.mcp_servers || []).map(function(s) { return '"' + s + '"'; }).join(', ') + ']\n';
    yaml += 'generated_at: "' + (fm.generated_at || new Date().toISOString()) + '"\n';
    yaml += 'version: ' + (fm.version || 1) + '\n';
    yaml += 'parent_version: null\n';
    yaml += 'word_count: ' + (body.split(/\s+/).length) + '\n';
    yaml += 'claim_count: ' + (fm.claim_count || 0) + '\n';
    yaml += 'confidence_distribution:\n';
    var cd = fm.confidence_distribution || { high: 0, medium: 0, low: 0 };
    yaml += '  high: ' + (cd.high || 0) + '\n';
    yaml += '  medium: ' + (cd.medium || 0) + '\n';
    yaml += '  low: ' + (cd.low || 0) + '\n';
    yaml += 'evidence_distribution:\n';
    var ed = fm.evidence_distribution || {};
    for (var ek in ed) { yaml += '  ' + ek + ': ' + ed[ek] + '\n'; }
    yaml += '---\n\n';

    console.log('[OTP] Built OOS: ' + (yaml + body).length + ' chars, template=' + template);
    return { content: yaml + body, template: template };
  }

  window.publishNow = async function() {
    var btn = document.getElementById('continue-btn');
    var status = document.getElementById('publish-status');

    // Build OOS from scan result (always fresh, never stale localStorage)
    var built = buildOOSFromScanResult();
    var content = built ? built.content : null;
    var template = built ? built.template : 'agent_army';

    // Fallback: if build failed, try re-scanning the raw text on the fly
    if (!content) {
      console.log('[OTP] buildOOSFromScanResult returned null, trying raw re-scan');
      var rawOos = localStorage.getItem('otp_generated_oos');
      if (rawOos && rawOos.length > 50) {
        status.textContent = 'Preparing your OOS...';
        status.style.color = '#6b7280';
        try {
          var scanResp = await fetch('/api/v1/scanner/from-text', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: rawOos }),
          });
          var scanData = await scanResp.json();
          if (scanData.oos && scanData.oos.rawMarkdown) {
            localStorage.setItem('otp_scan_result', JSON.stringify(scanData));
            built = buildOOSFromScanResult();
            content = built ? built.content : null;
            template = built ? built.template : 'agent_army';
          }
        } catch(e) { console.log('[OTP] Re-scan failed:', e); }
      }
    }

    if (!content) {
      status.textContent = 'Could not build OOS. Go to the homepage and re-upload your CLAUDE.md.';
      status.style.color = '#dc2626';
      return;
    }

    btn.textContent = 'Publishing...';
    btn.disabled = true;
    status.textContent = '';

    try {
      // Step 1: Auto-fix
      var fixResp = await fetch('/api/v1/oos/fix', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rawContent: content, template: template }),
      });
      var fixData = await fixResp.json();
      var fixedContent = fixData.fixed || content;

      // Step 2: Create OOS
      var createResp = await fetch('/api/v1/oos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ template: template, rawContent: fixedContent }),
      });
      var createData = await createResp.json();

      if (!createResp.ok) {
        if (createResp.status === 401 || createData.error?.code === 'AUTH_REQUIRED') {
          // Not signed in -- flag auto-publish, redirect to sign in, come back and retry
          localStorage.setItem('otp_return_after_signin', '/scan-results');
          localStorage.setItem('otp_auto_publish', 'true');
          window.location.href = '/sign-in';
          return;
        }
        status.textContent = createData.error?.message || 'Failed to create OOS. Try publishing from the publish page.';
        status.style.color = '#dc2626';
        btn.textContent = 'Publish to OTP Network';
        btn.disabled = false;
        return;
      }

      // Step 3: Publish
      var pubResp = await fetch('/api/v1/oos/' + createData.oosFile.id + '/publish', { method: 'POST' });
      var pubData = await pubResp.json();

      if (!pubResp.ok) {
        status.textContent = pubData.error?.message || 'Failed to publish. Try from the publish page.';
        status.style.color = '#dc2626';
        btn.textContent = 'Publish to OTP Network';
        btn.disabled = false;
        return;
      }

      // Success!
      localStorage.removeItem('otp_generated_oos');
      localStorage.removeItem('otp_scan_result');
      btn.textContent = 'Published!';
      btn.classList.remove('bg-otp-500', 'hover:bg-otp-400');
      btn.classList.add('bg-green-600');
      status.textContent = 'Your OOS is live on the network.';
      status.style.color = '#059669';

      // Redirect to OOS detail after 2 seconds
      setTimeout(function() {
        window.location.href = '/oos/' + createData.oosFile.id;
      }, 2000);

    } catch (e) {
      status.textContent = 'Network error: ' + e.message;
      status.style.color = '#dc2626';
      btn.textContent = 'Publish to OTP Network';
      btn.disabled = false;
    }
  };

  function updateResolvedCounter() {
    if (!totalActionable) {
      totalActionable = document.querySelectorAll('.insight-card[data-severity="critical"], .insight-card[data-severity="warning"]').length;
    }
    var counter = document.getElementById('resolved-counter');
    if (!counter) {
      counter = document.createElement('div');
      counter.id = 'resolved-counter';
      counter.className = 'text-center text-sm font-medium text-green-700 mb-4';
      var section = document.getElementById('insights-section');
      if (section) section.insertBefore(counter, section.firstChild.nextSibling);
    }
    counter.textContent = resolvedCount + ' of ' + totalActionable + ' issue' + (totalActionable !== 1 ? 's' : '') + ' resolved';
  }

  // Run on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
