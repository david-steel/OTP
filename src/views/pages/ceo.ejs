  .e-live i { width:6px; height:6px; border-radius:50%; background:var(--green,#0a9d63); animation:e-dot 1.8s ease-in-out infinite; }
  @keyframes e-dot { 0%,100%{box-shadow:0 0 0 0 rgba(10,157,99,.5);} 50%{box-shadow:0 0 0 5px rgba(10,157,99,0);} }
  .e-kpi { display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 0; border-top:1px solid var(--line,#eef0f3); }
  .e-kpi:first-of-type { border-top:0; }
  .e-kpi-name { font-size:12.5px; color:var(--ink-soft,#494d57); display:flex; align-items:center; gap:7px; }
  .e-owner { width:17px; height:17px; border-radius:5px; display:flex; align-items:center; justify-content:center; font-size:9px; font-weight:800; color:#fff; font-family:'Schibsted Grotesk',sans-serif; }
  .e-kpi-val { font-family:'JetBrains Mono',monospace; font-size:12.5px; font-weight:600; color:var(--ink,#14161c); }
  .e-pill { font-size:10px; font-weight:800; padding:2px 8px; border-radius:999px; }
  .e-on { color:#0a7d3f; background:#dcfce7; } .e-watch { color:#b4690e; background:#fef3c7; }

  .e-seat { position:absolute; width:186px; z-index:3; background:var(--card,#fff); border:1px solid var(--line,#e6e8ec); border-radius:13px; padding:10px 12px; box-shadow:0 8px 22px -10px rgba(20,22,28,.22); }
  .e-seat-top { display:flex; gap:9px; align-items:center; }
  .e-av { width:30px; height:30px; border-radius:8px; flex:none; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:12px; color:#fff; font-family:'Schibsted Grotesk',sans-serif; }
