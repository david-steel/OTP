  @keyframes e-draw { to{stroke-dashoffset:0;} }

  .e-board { position:absolute; left:120px; top:6px; width:320px; z-index:4; background:var(--card,#fff); border:1px solid var(--line,#e6e8ec); border-radius:16px; box-shadow:0 18px 44px -16px rgba(20,22,28,.28); padding:14px 16px; }
  .e-board-h { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
