  .e-tag.ag { color:var(--blue-deep,#0a56b0); background:rgba(13,125,242,.12); }
  .e-meter { margin-top:9px; }
  .e-meter-l { display:flex; justify-content:space-between; font-size:9.5px; color:var(--ink-mute,#888c96); margin-bottom:3px; }
  .e-meter-l b { font-family:'JetBrains Mono',monospace; color:var(--ink-soft,#494d57); font-weight:600; }
  .e-bar { height:5px; border-radius:3px; background:var(--grey,#f0f1f3); overflow:hidden; }
