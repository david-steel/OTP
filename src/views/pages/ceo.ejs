  .ceo-trust-strip { display:flex; align-items:center; flex-wrap:wrap; gap:8px 14px; margin-top:30px; font-size:12px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-mute,#888c96); }
