  .ceo-h1 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.025em; line-height:1.05; font-size:clamp(2.2rem,4.6vw,3.5rem); color:var(--ink,#14161c); margin:0; max-width:18ch; }
  .ceo-h2 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.02em; line-height:1.12; font-size:clamp(1.7rem,3.2vw,2.5rem); color:var(--ink,#14161c); }
  .ceo-lead { font-size:18px; line-height:1.62; color:var(--ink-soft,#494d57); }
  .ceo-body { font-size:16px; line-height:1.65; color:var(--ink-soft,#494d57); }
  .ceo-max720 { max-width:720px; }
  .accent { color:var(--blue,#0d7df2); } .accent-g { color:var(--green-deep,#06724a); }

  .ceo-btn  { display:inline-flex; align-items:center; gap:8px; padding:14px 28px; font-size:16px; font-weight:700; border-radius:12px; text-decoration:none; white-space:nowrap; }
  .ceo-btn.primary { background:var(--blue,#0d7df2); color:#fff; box-shadow:0 10px 26px -10px rgba(13,125,242,.6); transition:transform .15s ease, box-shadow .15s ease; }
  .ceo-btn.primary:hover { transform:translateY(-1px); box-shadow:0 14px 30px -10px rgba(13,125,242,.7); }
