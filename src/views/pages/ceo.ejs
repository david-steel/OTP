    body.ceo-anim .reveal { opacity:0; transform:translateY(18px); transition:opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); }
    body.ceo-anim .reveal.in { opacity:1; transform:none; }
  }

  /* ===== animated hero scene: seats roll up into the operating plan ===== */
  .ceo-hero { background:var(--white,#fcfcfd); overflow:hidden; }
