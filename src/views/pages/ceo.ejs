  .ceo-grid3 { display:grid; gap:18px; grid-template-columns:1fr; margin-top:36px; }
  @media (min-width:780px){ .ceo-grid3 { grid-template-columns:repeat(3,1fr); } }
  .ceo-grid2 { display:grid; gap:18px; grid-template-columns:1fr; margin-top:36px; }
  @media (min-width:780px){ .ceo-grid2 { grid-template-columns:repeat(2,1fr); } }
  .ceo-card { background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); border-radius:16px; padding:24px 22px; box-shadow:0 10px 28px rgba(20,22,28,.05); }
