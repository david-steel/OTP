<% /* XSS guard: embed a value in an inline <script> via jsonForScript() -- escapes < and > so a value containing </script> can't break out of the script context (stored-XSS guard). */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%- include('../partials/orgy-palette') %>
<style>
  /* L8 meeting: EOS-clean card treatment. Scoped to this page via the
     #l8-meeting root so it touches nothing else. CSS-only (no DOM
     surgery) so all section forms and their JS wiring stay intact. */
  #l8-meeting #segue, #l8-meeting #scorecard, #l8-meeting #rocks,
  #l8-meeting #headlines, #l8-meeting #todos, #l8-meeting #ids,
  #l8-meeting #conclude {
    background: #fff; border: 1px solid var(--line, #e6e8ec); border-radius: 18px;
    padding: 20px 26px 24px; margin-bottom: 18px;
    box-shadow: 0 1px 2px rgba(16,24,40,.04), 0 1px 3px rgba(16,24,40,.05);
  }
  /* neutralize the old IDS inline highlight (-mx-4 / blue-soft / rounded-lg) */
  #l8-meeting #ids { margin-left: 0 !important; margin-right: 0 !important; }
  /* section header -> compact uppercase card-head */
  #l8-meeting section > h2 {
    font-size: 14px !important; font-weight: 800 !important; text-transform: uppercase;
    letter-spacing: .06em; color: var(--ink, #14161c) !important;
    margin: 0 0 16px !important; padding-bottom: 13px; border-bottom: 1px solid #f1f3f6;
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  }
  /* icon-circle before each section header */
  #l8-meeting section > h2::before {
    content: ""; flex: none; width: 40px; height: 40px; border-radius: 50%;
    background-repeat: no-repeat; background-position: center; background-size: 36px 36px;
  }
  #l8-meeting #segue > h2::before     { background-color: transparent; background-image: url("/public/images/orgy/meeting.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting #scorecard > h2::before { background-color: transparent; background-image: url("/public/images/orgy/scorecard.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting #rocks > h2::before     { background-color: transparent; background-image: url("/public/images/orgy/quarterly-priorities.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting #headlines > h2::before { background-color: transparent; background-image: url("/public/images/orgy/headlines.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting #todos > h2::before     { background-color: transparent; background-image: url("/public/images/orgy/todos.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting #ids > h2::before       { background-color: transparent; background-image: url("/public/images/orgy/issues.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting #conclude > h2::before  { background-color: transparent; background-image: url("/public/images/orgy/conclusional.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>"); }
  #l8-meeting section > h2 > span {
    text-transform: none !important; letter-spacing: 0 !important; font-weight: 500 !important;
    color: var(--ink-mute, #888c96) !important; font-size: 12.5px !important;
  }
  /* agenda strip -> clean stepper chips */
  #l8-meeting .agenda-chip {
    background: #fff !important; border: 1px solid var(--line, #e6e8ec);
    border-radius: 10px; color: var(--ink-soft, #494d57) !important; font-weight: 600;
  }
  #l8-meeting .agenda-chip:hover { background: #f4f6f8 !important; border-color: #d6dbe2; }
  #l8-meeting .agenda-chip.bg-orgy-blue-soft {
    background: var(--orgy-tint, #f1fadd) !important; border-color: var(--orgy-soft, #D6F59C);
    color: var(--orgy-onlight, #5a7d1f) !important;
  }
</style>
<div class="max-w-6xl mx-auto px-4 py-8<%= (typeof meetingStepped !== 'undefined' && meetingStepped) ? ' meeting-stepped' : '' %>" id="l8-meeting" data-meeting-id="<%= meeting.id %>" data-team-id="<%= meeting.teamId || '' %>">

  <!-- Header -->
  <div class="mtg-header flex items-center justify-between mb-6 border-b border-gray-200 pb-5">
    <div>
      <div class="mtg-eyebrow text-[11px] font-bold uppercase tracking-[0.2em] text-orgy-blue mb-1.5"><%= (org && org.name) ? org.name : 'Your company' %> &middot; Weekly Leadership Meeting</div>
      <div class="flex items-start gap-2">
        <h1 id="meeting-title" class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-[1.1] tracking-tight"><%= meeting.title %></h1>
        <button id="title-edit-btn" type="button" class="mt-1 text-xs text-orgy-blue hover:underline shrink-0" title="Edit the meeting title">Edit</button>
      </div>
      <div id="title-editor" class="hidden mt-2 flex flex-wrap items-center gap-2">
        <input id="title-input" type="text" maxlength="255" value="<%= meeting.title %>" class="border border-gray-300 rounded px-2 py-1.5 text-sm w-full max-w-md">
        <button id="title-save" type="button" class="px-3 py-1 bg-orgy-blue text-white rounded text-xs font-semibold hover:bg-orgy-blue-deep">Save</button>
        <button id="title-cancel" type="button" class="text-xs text-gray-500 hover:text-gray-700">Cancel</button>
        <span id="title-status" class="text-xs text-gray-500"></span>
      </div>
      <p class="mtg-sched text-sm text-gray-600 mt-1.5">
        Scheduled <span id="sched-display"><%= new Date(meeting.scheduledAt).toLocaleString() %></span>
        <button id="sched-edit-btn" type="button" class="text-xs text-orgy-blue hover:underline ml-1">Edit time</button>
        <span class="mx-1.5 text-gray-300">&middot;</span>
        Status <span class="font-semibold text-gray-800" id="meeting-status"><%= meeting.status %></span>
        <span class="mx-1.5 text-gray-300">&middot;</span>
        <span id="meeting-recurrence-label" class="<%= meeting.recurrenceRule ? 'font-semibold text-gray-800' : 'text-gray-400' %>"><%= meeting.recurrenceRule ? (typeof recurrenceLabel !== 'undefined' && recurrenceLabel ? recurrenceLabel : 'Repeats') : 'One-time' %></span>
      </p>
      <div id="sched-editor" class="hidden mt-2 flex flex-wrap items-center gap-2">
        <input id="sched-input" type="datetime-local" value="<%= new Date(meeting.scheduledAt).toISOString().slice(0,16) %>" class="border border-gray-300 rounded px-2 py-1 text-sm">
        <button id="sched-save" type="button" class="px-3 py-1 bg-orgy-blue text-white rounded text-xs font-semibold hover:bg-orgy-blue-deep">Save</button>
        <button id="sched-cancel" type="button" class="text-xs text-gray-500 hover:text-gray-700">Cancel</button>
        <span id="sched-status" class="text-xs text-gray-500"></span>
      </div>
    </div>
    <div class="flex gap-2 items-center">
      <%
        // Average meeting rating (each attendee, 1-10). Shown on the Ended badge.
        var _ratingVals = (meeting.ratings && typeof meeting.ratings === 'object') ? Object.values(meeting.ratings).filter(function(v){ return typeof v === 'number'; }) : [];
        var _ratingAvg = _ratingVals.length ? (_ratingVals.reduce(function(a,b){ return a + b; }, 0) / _ratingVals.length) : null;
      %>
      <% if (meeting.status === 'scheduled') { %>
        <button class="js-start-meeting px-4 py-2 bg-orgy-blue text-white rounded-lg text-sm font-semibold hover:bg-orgy-blue-deep" title="Snapshots the scorecard and rocks so the discussion is anchored to what's true right now">▶ Start meeting</button>
      <% } else if (meeting.status === 'in_progress') { %>
        <button class="js-end-meeting px-4 py-2 bg-orgy-blue text-white rounded-lg text-sm font-semibold hover:bg-orgy-blue-deep">✓ End meeting</button>
      <% } else if (meeting.status === 'completed') { %>
        <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-medium" title="Meeting ended; data is frozen as the historical record">Ended<% if (_ratingAvg != null) { %> &middot; <%= _ratingAvg.toFixed(1) %>/10<% } %></span>
      <% } %>
      <!-- Secondary actions live in one overflow so the header has a single clear
           primary (DESIGN.md: one primary per screen). Same ids/classes/handlers. -->
      <details class="hdr-overflow">
        <summary class="hdr-overflow-btn" aria-label="More meeting actions" title="More actions">Actions <span class="hdr-caret" aria-hidden="true">&#9662;</span></summary>
        <div class="hdr-overflow-menu">
          <a href="/l8" class="hdr-mi" title="Leave this meeting and go back to your meetings">&larr; Exit to meetings</a>
          <% if (meeting.status === 'scheduled') { %>
            <button class="js-end-meeting hdr-mi" title="Mark this meeting complete (you don't have to Start it first)">✓ End meeting</button>
          <% } else if (meeting.status === 'in_progress') { %>
            <button class="js-extend-meeting hdr-mi" title="Push the 1-hour auto-end out by another hour">⏱ Extend meeting</button>
          <% } %>
          <button id="cal-toggle" class="hdr-mi" title="Get a link to paste into a Google Calendar or Outlook invite">Add to calendar</button>
          <button id="delete-meeting" class="hdr-mi hdr-mi-danger" title="Delete this meeting permanently (soft delete)">Delete meeting</button>
        </div>
      </details>
    </div>
  </div>

  <% if (typeof locked !== 'undefined' && locked) { %>
  <!-- Locked: a future-dated occurrence opened directly. Read-only with a
       banner so data goes into the CURRENT meeting, not next week's. Editing
       is also rejected server-side (423 MEETING_LOCKED); the script below
       disables the inputs so it reads clearly as not-yet-open. -->
  <div class="mb-6 border border-amber-300 bg-amber-50 rounded-lg px-4 py-3 flex items-start justify-between gap-3">
    <div>
      <div class="text-sm font-semibold text-amber-900">This is an upcoming meeting</div>
      <div class="text-xs text-amber-800 mt-0.5">Scheduled for <%= new Date(meeting.scheduledAt).toLocaleString() %>. It opens on its own when that time arrives. Use your current meeting until then — or start this one now if you mean to run it early.</div>
    </div>
    <button class="js-start-meeting shrink-0 px-4 py-2 bg-orgy-blue text-white rounded-lg text-sm font-semibold hover:bg-orgy-blue-deep">▶ Start now</button>
  </div>
  <% } %>

  <!-- Add to calendar (Phase 0: manual paste path -- no OAuth). Hand the user
       a copyable block to drop into a recurring invite they build themselves
       in Google Calendar or Microsoft 365 (Outlook). Provider-neutral. -->
  <div id="cal-panel" class="hidden mb-6 border border-orgy bg-orgy-soft rounded-lg px-4 py-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <div class="text-[11px] font-bold uppercase tracking-[0.2em] text-orgy-blue mb-1">Add to calendar <button type="button" class="help-q" data-help="l8meeting.calendar" aria-label="About Add to calendar">?</button></div>
        <p class="text-xs text-gray-600 max-w-xl">Create your recurring invite in Google Calendar or Outlook, set the recurrence and attendees there, then paste the block below into the invite. Works whether your team is on Google or Microsoft 365.</p>
      </div>
      <button id="cal-close" class="text-xs text-gray-400 hover:text-gray-700" title="Close">Close</button>
    </div>

    <div class="mt-3 flex flex-wrap items-end gap-2">
      <label class="min-w-[200px]">
        <span class="block text-xs font-medium text-orgy-blue mb-1">Repeats</span>
        <select id="cal-repeat-select" class="w-full border border-orgy rounded px-2 py-1.5 text-sm">
          <% (typeof recurrenceOptions !== 'undefined' ? recurrenceOptions : []).forEach(function(opt){ %>
            <option value="<%= opt.value %>" <%= (meeting.recurrenceRule || '') === opt.value ? 'selected' : '' %>><%= opt.label %></option>
          <% }); %>
        </select>
      </label>
      <span id="cal-repeat-status" class="text-xs text-gray-500 pb-2"></span>
    </div>
    <p class="mt-1 text-[11px] text-gray-500">When this is set, OTP creates the next meeting automatically once you end the current one. Set the matching recurrence in your Google or Outlook invite too.</p>

    <div class="mt-3 flex flex-wrap items-end gap-2">
      <label class="flex-1 min-w-[240px]">
        <span class="block text-xs font-medium text-orgy-blue mb-1">Video link (optional)</span>
        <input id="cal-video-input" type="url" placeholder="Paste a Meet, Teams, or Zoom link" value="<%= meeting.videoLink || '' %>" class="w-full border border-orgy rounded px-2 py-1.5 text-sm" />
      </label>
      <button id="cal-video-save" class="px-3 py-1.5 bg-orgy-blue text-white rounded text-xs font-semibold hover:bg-orgy-blue-deep">Save link</button>
    </div>

    <div class="mt-3">
      <span class="block text-xs font-medium text-orgy-blue mb-1">Paste this into your calendar invite</span>
      <textarea id="cal-block" readonly rows="3" class="w-full border border-orgy rounded px-2 py-1.5 text-xs font-mono bg-white text-gray-800"></textarea>
      <div class="mt-2 flex items-center gap-2">
        <button id="cal-copy" class="px-3 py-1.5 border border-gray-300 text-orgy-blue bg-white rounded text-xs font-semibold hover:bg-orgy-blue-soft">Copy</button>
        <span id="cal-copy-status" class="text-xs text-gray-500"></span>
      </div>
    </div>
  </div>

  <!-- Direction strip: the plan's destination, framing the meeting. -->
  <% if (typeof planDirection !== 'undefined' && planDirection && (planDirection.threeYear || planDirection.annualObjective || planDirection.tenYear)) { %>
    <div class="mtg-prelude mb-6 border border-orgy bg-orgy-soft rounded-lg px-4 py-2.5 flex flex-wrap items-baseline gap-x-6 gap-y-1 text-xs">
      <span class="uppercase tracking-wider text-orgy-blue font-semibold">Driving toward</span> <button type="button" class="help-q" data-help="l8meeting.driving" aria-label="About Driving toward">?</button>
      <% if (planDirection.threeYear) { %>
        <span><span class="text-gray-500">3-5yr<%= planDirection.threeYearYear ? ' (' + planDirection.threeYearYear + ')' : '' %>:</span> <span class="text-gray-800 font-medium"><%= planDirection.threeYear %></span></span>
      <% } %>
      <% if (planDirection.annualObjective) { %>
        <span><span class="text-gray-500">This year:</span> <span class="text-gray-800 font-medium"><%= planDirection.annualObjective %></span></span>
      <% } %>
      <% var _role = (locals.memberRole || '').toString(); if (_role === 'owner' || _role === 'visionary') { %>
        <a href="/dashboard/ceo" class="text-orgy-blue hover:underline font-medium ml-auto">CEO Dashboard &rarr;</a>
      <% } %>
    </div>
  <% } %>

  <!-- Attendees panel -->
  <%
    // Normalize attendees to a single shape. meeting.attendees jsonb entries
    // come in two shapes: the editor shape { entityType, externalId, name } and
    // the auto-populate shape { type, memberId, externalIds, name } (agents:
    // { type:'agent', externalId, name }). Collapse both to { entityType, externalId, name }.
    const normalizedAttendees = (meeting.attendees || []).map(function(a) {
      const entityType = a.entityType || a.type;
      const externalId = a.externalId || (Array.isArray(a.externalIds) && a.externalIds[0]) || a.memberId || '';
      const name = a.name || a.externalId || '';
      return {
        entityType: entityType,
        externalId: externalId,
        name: name,
        memberId: a.memberId || '',
        checkinText: a.checkinText || '',
        checkinAt: a.checkinAt || null,
      };
    }).filter(function(a) { return !!a.externalId; });
    const attendeeKeys = {};
    normalizedAttendees.forEach(function(a) { attendeeKeys[a.entityType + ':' + a.externalId] = true; });
    const ownersNotAttending = (availableOwners || []).filter(function(o) {
      return !attendeeKeys[o.entityType + ':' + o.externalId];
    });
  %>
  <div class="mtg-prelude mb-6 border rounded-lg p-3 bg-gray-50">
    <div class="flex items-center justify-between mb-2">
      <div class="text-xs uppercase tracking-wider text-gray-700 font-medium flex items-center gap-2">
        Attendees &amp; Access
        <button type="button" class="help-q" data-help="l8meeting.attendees" aria-label="About Attendees and Access">?</button>
        <span id="meeting-live-indicator" class="hidden text-[10px] px-1.5 py-0.5 rounded-full bg-orgy-soft text-orgy-on-light font-medium" title="Connected to live updates">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-orgy align-middle animate-pulse"></span>
          Live <span id="meeting-watcher-count">1</span>
        </span>
      </div>
      <button id="edit-attendees-btn" class="text-xs px-2 py-1 bg-white border rounded hover:bg-gray-100">Edit</button>
    </div>
    <div id="attendees-display" class="flex flex-wrap gap-2">
      <% normalizedAttendees.forEach(function(a) {
           const isAgent = a.entityType === 'agent';
           const run = (isAgent && typeof agentRuns !== 'undefined' && agentRuns && agentRuns[a.externalId]) ? agentRuns[a.externalId] : null;
      %>
        <span class="text-xs px-2 py-1 rounded-full <%= a.entityType === 'agent' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>" data-attendee="<%= a.entityType + ':' + a.externalId %>">
          <%= a.name || a.externalId %>
          <span class="text-gray-500">(<%= a.entityType %>)</span>
          <% if (run) { %>
            <span class="text-gray-500"> &middot; last run <%= run.status %> <%= run.lastRunAt ? new Date(run.lastRunAt).toLocaleDateString() : '' %></span>
          <% } %>
        </span>
      <% }); %>
      <% if (normalizedAttendees.length === 0) { %>
        <span class="text-xs text-gray-500 italic">No attendees yet -- click Edit to add</span>
      <% } %>
    </div>
    <% if ((teamMembers || []).length > 0) { %>
      <div class="text-xs text-gray-500 mt-2">
        Team (has meeting access): <%= (teamMembers || []).map(function(m) { return (m.name || m.memberId) + (m.role ? ' (' + m.role + ')' : ''); }).join(', ') %>
      </div>
    <% } %>
    <div id="attendees-editor" class="hidden mt-3">
      <div id="attendees-chips" class="flex flex-wrap gap-2 mb-2"></div>
      <div class="flex gap-2">
        <select id="attendee-add-select" class="flex-1 border rounded p-2 text-sm">
          <option value="">-- add attendee --</option>
          <% ownersNotAttending.forEach(function(o) { %>
            <option value="<%= o.entityType %>:<%= o.externalId %>:<%= o.name || o.externalId %>"><%= o.name || o.externalId %> (<%= o.entityType %>)</option>
          <% }); %>
        </select>
        <button id="attendee-add-btn" class="px-3 py-1 bg-orgy-blue text-white text-xs rounded hover:bg-orgy-blue-deep">Add</button>
      </div>
    </div>
  </div>

  <!-- Agent reports: per-agent view of what each AI seat carries into the meeting. -->
  <%
    var agentAttendees = normalizedAttendees.filter(function(a){ return a.entityType === 'agent'; });
    var scKpis = (scorecard && scorecard.kpis) ? scorecard.kpis : [];
    var scLatest = (scorecard && scorecard.latestValues) ? scorecard.latestValues : {};
    var allRocks = (rocks && rocks.rocks) ? rocks.rocks : [];
    function agentKpiOnTrack(k){
      var v = scLatest[k.id];
      if (!v || k.goalValue == null || !k.goalOperator) return null;
      var l = v.value, r = k.goalValue, op = k.goalOperator;
      return (op==='gte'&&l>=r)||(op==='gt'&&l>r)||(op==='lte'&&l<=r)||(op==='lt'&&l<r)||(op==='eq'&&l===r);
    }
  %>
  <% if (agentAttendees.length > 0) { %>
    <details class="mtg-prelude mb-6 border rounded-lg bg-white" open>
      <summary class="cursor-pointer px-3 py-2 text-xs uppercase tracking-wider text-gray-700 font-medium hover:bg-gray-50">
        Agent Reports &mdash; what your <%= agentAttendees.length %> AI seat<%= agentAttendees.length === 1 ? '' : 's' %> carry into this meeting
        <button type="button" class="help-q" data-help="l8meeting.agentReports" aria-label="About Agent Reports">?</button>
      </summary>
      <div class="px-3 pb-3 grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% agentAttendees.forEach(function(a){
             var run = (typeof agentRuns !== 'undefined' && agentRuns && agentRuns[a.externalId]) ? agentRuns[a.externalId] : null;
             var myKpis = scKpis.filter(function(k){ return k.ownerExternalId === a.externalId; });
             var myRocks = allRocks.filter(function(r){ return r.ownerExternalId === a.externalId; });
             var myIssues = (issues || []).filter(function(i){ return i.ownerExternalId === a.externalId && i.idsStatus !== 'solved'; });
             var myTodos = (todos || []).filter(function(t){ return t.ownerExternalId === a.externalId && !t.doneAt; });
             var kpiOff = myKpis.filter(function(k){ return agentKpiOnTrack(k) === false; }).length;
             var rockOff = myRocks.filter(function(r){ return !r.onTrack; }).length;
        %>
          <div class="border rounded-lg p-3">
            <div class="flex items-center justify-between gap-2 mb-2">
              <span class="text-sm font-semibold text-purple-800"><%= a.name || a.externalId %></span>
              <% if (run) { %>
                <span class="text-[10px] px-1.5 py-0.5 rounded <%= (run.status === 'completed' || run.status === 'success') ? 'bg-emerald-100 text-emerald-700' : (run.status === 'failed' || run.status === 'error') ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= run.status %><%= run.lastRunAt ? ' ' + new Date(run.lastRunAt).toLocaleDateString() : '' %>
                </span>
              <% } else { %>
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-500">no recent run</span>
              <% } %>
            </div>
            <div class="grid grid-cols-4 gap-1 text-center">
              <div><div class="text-sm font-bold text-gray-900"><%= myKpis.length %></div><div class="text-[10px] text-gray-500">KPIs</div></div>
              <div><div class="text-sm font-bold <%= kpiOff > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= kpiOff %></div><div class="text-[10px] text-gray-500">off goal</div></div>
              <div><div class="text-sm font-bold <%= rockOff > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= rockOff %>/<%= myRocks.length %></div><div class="text-[10px] text-gray-500">rocks off</div></div>
              <div><div class="text-sm font-bold <%= myIssues.length > 0 ? 'text-amber-700' : 'text-gray-900' %>"><%= myIssues.length %></div><div class="text-[10px] text-gray-500">issues</div></div>
            </div>
            <% if (myKpis.length || myTodos.length) { %>
              <div class="mt-2 pt-2 border-t border-gray-100 text-xs text-gray-600 space-y-0.5">
                <% myKpis.slice(0,3).forEach(function(k){ var ot = agentKpiOnTrack(k); %>
                  <div class="flex items-center gap-1.5">
                    <span class="<%= ot === true ? 'text-emerald-600' : ot === false ? 'text-red-600' : 'text-gray-300' %>"><%= ot === false ? '✗' : ot === true ? '✓' : '–' %></span>
                    <span class="truncate"><%= k.title %></span>
                  </div>
                <% }); %>
                <% if (myTodos.length) { %><div class="text-gray-500"><%= myTodos.length %> open to-do<%= myTodos.length === 1 ? '' : 's' %></div><% } %>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </details>
  <% } %>

  <!-- Live-preview banner: a scheduled meeting renders the team's CURRENT
       live scorecard/priorities/to-dos/issues (so edits flow through before
       the meeting). This makes that explicit so a future meeting doesn't read
       as today's meeting. The data freezes into a snapshot on Start. -->
  <% if (meeting.status === 'scheduled') { %>
    <div class="mtg-prelude mb-5 flex items-start gap-3 rounded-xl border border-orgy-soft bg-orgy-tint px-4 py-3">
      <svg class="w-5 h-5 mt-0.5 shrink-0 text-orgy-on-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 8h.01M11 12h1v4h1"/></svg>
      <div class="text-sm leading-relaxed">
        <span class="font-bold text-orgy-on-light">Live preview &middot; not started.</span>
        <span class="text-gray-700">The scorecard, priorities, to-dos, and issues below show your team's <strong>current</strong> data and update live as you edit. They snapshot into this meeting's record when you press <strong>Start meeting</strong>.</span>
      </div>
    </div>
  <% } %>

  <% if (meeting.status === 'completed') { %>
  <!-- Post-meeting: transcript + recording (source-agnostic) and the AI
       follow-ups wizard. The wizard endpoint is Labs-gated server-side, so the
       button handles a 503 (coming soon) rather than the view needing a flag. -->
  <section id="post-meeting" class="mb-6 rounded-xl border border-gray-200 bg-white px-4 py-4">
    <div class="text-[11px] font-bold uppercase tracking-[0.2em] text-orgy-blue mb-2">Transcript &amp; recording</div>
    <p class="text-xs text-gray-500 mb-3">Attach the transcript and a recording link from any tool &mdash; Plaud, Fireflies, Gemini, or your own notes.</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-3">
      <label class="block">
        <span class="block text-xs font-medium text-gray-600 mb-1">Recording link</span>
        <input id="pm-recording" type="url" value="<%= meeting.recordingUrl || '' %>" placeholder="https://..." class="w-full border rounded px-2 py-1.5 text-sm">
      </label>
      <label class="block">
        <span class="block text-xs font-medium text-gray-600 mb-1">Transcript file (fills the box below)</span>
        <input id="pm-file" type="file" accept=".txt,.vtt,.srt,.md,text/plain" class="w-full text-xs text-gray-600">
      </label>
    </div>
    <textarea id="pm-transcript" rows="6" placeholder="Paste the transcript here..." class="w-full border rounded p-2 text-sm font-mono"><%= meeting.transcript || '' %></textarea>
    <div class="mt-2 flex flex-wrap items-center gap-2">
      <button id="pm-save" class="text-xs px-3 py-1.5 bg-gray-100 rounded hover:bg-gray-200 font-medium">Save</button>
      <span id="pm-save-msg" class="text-xs text-gray-500"></span>
      <button id="pm-generate" class="text-xs px-3 py-1.5 bg-orgy-blue text-white rounded hover:bg-orgy-blue-deep font-semibold ml-auto">&#10024; Generate follow-ups</button>
    </div>
    <% if (meeting.aiSummary) { %>
      <div class="mt-3 rounded-lg bg-orgy-tint border border-orgy-soft px-3 py-2">
        <div class="text-[11px] font-bold uppercase tracking-wide text-orgy-on-light mb-1">Summary</div>
        <div class="text-sm text-gray-700 whitespace-pre-wrap"><%= meeting.aiSummary %></div>
      </div>
    <% } %>
    <div class="mt-3" data-att-host data-att-type="meeting" data-att-id="<%= meeting.id %>"></div>
    <select id="pm-owner-tpl" class="hidden">
      <option value="">(no owner)</option>
      <% (availableOwners || []).forEach(function(a) { %>
        <option value="<%= a.entityType %>:<%= a.externalId %>"><%= a.name || a.externalId %></option>
      <% }); %>
    </select>
    <div id="pm-review" class="hidden mt-4 border-t border-gray-200 pt-4"></div>
  </section>
  <%- include('../partials/attachments-ui.ejs'); %>
  <script>
  (function(){
    var root = document.getElementById('post-meeting');
    if (!root) return;
    var mId = (document.querySelector('#l8-meeting')||{dataset:{}}).dataset.meetingId;
    var teamIdVal = (document.querySelector('[data-team-id]')||{dataset:{}}).dataset.teamId || null;
    function api(method, path, body){
      return fetch('/api/v1'+path, { method:method, credentials:'include', headers: body?{'Content-Type':'application/json'}:{}, body: body?JSON.stringify(body):undefined })
        .then(function(r){ return r.json().catch(function(){return {};}).then(function(j){ if(!r.ok) throw (j.error||{message:'HTTP '+r.status}); return j; }); });
    }
    function esc(s){ var d=document.createElement('div'); d.textContent=String(s==null?'':s); return d.innerHTML; }
    var rec=document.getElementById('pm-recording'), txt=document.getElementById('pm-transcript'), file=document.getElementById('pm-file');
    var saveBtn=document.getElementById('pm-save'), saveMsg=document.getElementById('pm-save-msg'), genBtn=document.getElementById('pm-generate');
    var review=document.getElementById('pm-review'), ownerTpl=document.getElementById('pm-owner-tpl');

    if (file) file.addEventListener('change', function(){
      var f = file.files && file.files[0]; if(!f) return;
      var rd = new FileReader(); rd.onload=function(){ txt.value = String(rd.result||''); }; rd.readAsText(f);
    });
    saveBtn.addEventListener('click', function(){
      saveBtn.disabled=true; saveMsg.textContent='Saving...';
      api('PUT','/meetings/'+mId, { transcript: txt.value, recordingUrl: rec.value })
        .then(function(){ saveMsg.textContent='Saved'; setTimeout(function(){saveMsg.textContent='';},1500); })
        .catch(function(e){ saveMsg.textContent=(e&&e.message)||'Save failed'; })
        .then(function(){ saveBtn.disabled=false; });
    });
    genBtn.addEventListener('click', function(){
      if (!txt.value.trim()){ alert('Add a transcript first.'); return; }
      var orig=genBtn.textContent; genBtn.disabled=true; genBtn.textContent='Generating...';
      api('PUT','/meetings/'+mId, { transcript: txt.value, recordingUrl: rec.value })
        .then(function(){ return api('POST','/meetings/'+mId+'/ai/followups'); })
        .then(function(res){ renderReview(res.followups||{}); })
        .catch(function(e){
          if (e && e.code === 'COMING_SOON') alert('AI meeting follow-ups is in early access. Turn it on under Settings, Labs.');
          else alert('Could not generate follow-ups: ' + ((e&&e.message)||'error'));
        })
        .then(function(){ genBtn.disabled=false; genBtn.textContent=orig; });
    });
    function ownerSelect(suggested){
      var sel=ownerTpl.cloneNode(true); sel.removeAttribute('id'); sel.className='border rounded px-1.5 py-1 text-xs';
      if (suggested){ for (var i=0;i<sel.options.length;i++){ if (sel.options[i].textContent.toLowerCase()===String(suggested).toLowerCase()){ sel.selectedIndex=i; break; } } }
      return sel;
    }
    function renderReview(fu){
      var todos=fu.todos||[], issues=fu.issues||[], heads=fu.headlines||[], summary=fu.summary||'';
      var h='<div class="text-sm font-bold text-gray-800 mb-2">Review &amp; create</div>';
      if (summary) h+='<label class="flex items-start gap-2 mb-3 text-sm"><input type="checkbox" class="pm-sum mt-0.5" checked> <span><strong>Summary:</strong> <span class="pm-sum-text">'+esc(summary)+'</span></span></label>';
      if (todos.length){ h+='<div class="text-[11px] font-bold uppercase text-gray-500 mt-2 mb-1">To-dos</div>'; todos.forEach(function(t){ h+='<div class="pm-todo flex items-center gap-2 mb-1.5"><input type="checkbox" class="pm-chk" checked><input class="pm-title flex-1 border rounded px-1.5 py-1 text-xs" value="'+esc(t.title)+'"><span class="pm-owner" data-suggest="'+esc(t.owner||'')+'"></span></div>'; }); }
      if (issues.length){ h+='<div class="text-[11px] font-bold uppercase text-gray-500 mt-3 mb-1">Issues</div>'; issues.forEach(function(t){ h+='<div class="pm-issue flex items-center gap-2 mb-1.5"><input type="checkbox" class="pm-chk" checked><input class="pm-title flex-1 border rounded px-1.5 py-1 text-xs" value="'+esc(t.title)+'" data-desc="'+esc(t.description||'')+'"></div>'; }); }
      if (heads.length){ h+='<div class="text-[11px] font-bold uppercase text-gray-500 mt-3 mb-1">Headlines</div>'; heads.forEach(function(t){ h+='<div class="pm-head flex items-center gap-2 mb-1.5"><input type="checkbox" class="pm-chk" checked><input class="pm-title flex-1 border rounded px-1.5 py-1 text-xs" value="'+esc(t.body)+'" data-kind="'+esc(t.kind||'other')+'"></div>'; }); }
      if (!todos.length && !issues.length && !heads.length && !summary){ h+='<div class="text-sm text-gray-500">Nothing actionable found in the transcript.</div>'; }
      else { h+='<div class="mt-3 flex items-center gap-2"><button id="pm-create" class="text-xs px-3 py-1.5 bg-orgy-blue text-white rounded font-semibold hover:bg-orgy-blue-deep">Create selected</button><button id="pm-discard" class="text-xs px-3 py-1.5 bg-gray-100 rounded hover:bg-gray-200">Discard</button><span id="pm-create-msg" class="text-xs text-gray-500"></span></div>'; }
      review.innerHTML=h; review.classList.remove('hidden');
      review.querySelectorAll('.pm-owner').forEach(function(span){ span.appendChild(ownerSelect(span.getAttribute('data-suggest'))); });
      var c=document.getElementById('pm-create'), d=document.getElementById('pm-discard');
      if (d) d.addEventListener('click', function(){ review.classList.add('hidden'); review.innerHTML=''; });
      if (c) c.addEventListener('click', function(){ createSelected(c); });
    }
    function createSelected(btn){
      btn.disabled=true; var msg=document.getElementById('pm-create-msg'); if(msg) msg.textContent='Creating...';
      var tasks=[];
      var sum=review.querySelector('.pm-sum');
      if (sum && sum.checked){ var st=review.querySelector('.pm-sum-text'); if (st) tasks.push(api('PUT','/meetings/'+mId,{ aiSummary: st.textContent })); }
      review.querySelectorAll('.pm-todo').forEach(function(row){
        if (!row.querySelector('.pm-chk').checked) return;
        var title=row.querySelector('.pm-title').value.trim(); if(!title) return;
        var ownerVal=(row.querySelector('select')||{}).value||'';
        var body={ kind:'l10', title:title, meetingId:mId }; if (teamIdVal) body.teamId=teamIdVal;
        if (ownerVal){ var p=ownerVal.split(':'); body.ownerEntityType=p[0]; body.ownerExternalId=p.slice(1).join(':'); }
        tasks.push(api('POST','/todos', body).catch(function(){}));
      });
      review.querySelectorAll('.pm-issue').forEach(function(row){
        if (!row.querySelector('.pm-chk').checked) return;
        var t=row.querySelector('.pm-title'); var title=t.value.trim(); if(!title) return;
        var body={ title:title, description: t.getAttribute('data-desc')||title }; if (teamIdVal) body.teamId=teamIdVal;
        tasks.push(api('POST','/tickets', body).catch(function(){}));
      });
      review.querySelectorAll('.pm-head').forEach(function(row){
        if (!row.querySelector('.pm-chk').checked) return;
        var t=row.querySelector('.pm-title'); var b=t.value.trim(); if(!b) return;
        tasks.push(api('POST','/meetings/'+mId+'/headlines', { body:b, kind: t.getAttribute('data-kind')||'other' }).catch(function(){}));
      });
      Promise.all(tasks).then(function(){ window.location.reload(); }).catch(function(){ window.location.reload(); });
    }
  })();
  </script>
  <% } %>

<%
  // Section metadata for the agenda-driven rail (custom-format meetings). id =
  // the DOM anchor the section partial renders (issues -> #ids); label = chip
  // text. 'notes' (free-form discussion) is intentionally absent: it needs
  // per-section persistence the unified runner does not yet provide, so it is
  // skipped in BOTH the rail and the section loop until that follow-up lands.
  var _secMeta = {
    segue:     { id: 'segue',     label: 'Check-in' },
    scorecard: { id: 'scorecard', label: 'Scorecard' },
    rocks:     { id: 'rocks',     label: 'Quarterly Priorities' },
    headlines: { id: 'headlines', label: 'Headlines' },
    todos:     { id: 'todos',     label: 'To-Dos' },
    issues:    { id: 'ids',       label: 'Issues' },
    conclude:  { id: 'conclude',  label: 'Conclude' },
  };
  var _railAgenda = (Array.isArray(meeting.agenda) && meeting.agenda.length && meeting.meetingType === 'custom')
    ? meeting.agenda : null;
%>
<% if (_railAgenda) { %>
  <!-- Agenda-driven rail (custom-format meetings): chips come from the saved
       agenda, anchored to each section partial's DOM id via _secMeta. Reuses the
       same control ids (meeting-clock, timer-*) so the core timer/focus JS drives
       it unchanged. -->
  <nav id="agenda-nav" class="flex items-center gap-1 mb-6 text-xs whitespace-nowrap overflow-x-auto" data-active="">
    <% _railAgenda.forEach(function(_rs, _ri){ var _rm = _secMeta[_rs.type]; if (!_rm) return; %>
      <a href="#<%= _rm.id %>" data-section="<%= _rm.id %>" data-budget="<%= Number(_rs.minutes) || 0 %>" class="agenda-chip flex-1 px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0"><%= _ri + 1 %>. <%= _rm.label %> <span class="text-gray-500"><%= Number(_rs.minutes) || 0 %>m</span></a>
    <% }); %>
    <span id="meeting-clock" class="ml-3 px-2 py-1 rounded bg-gray-900 text-white font-mono text-xs whitespace-nowrap">--:--</span>
    <button id="timer-toggle" class="ml-1 px-2 py-1 bg-orgy-blue text-white rounded text-xs hover:bg-orgy-blue-deep">Start</button>
    <button id="timer-prev"   class="ml-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300" title="Previous section">&larr; Prev</button>
    <button id="timer-skip"   class="ml-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300" title="Next section">Next &rarr;</button>
    <button id="focus-toggle" class="ml-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300" title="Focus mode">Focus</button>
  </nav>
<% } else if (typeof meetingStepped !== 'undefined' && meetingStepped) { %>
  <!-- Agenda rail (Labs: meetings_broken_out). Same .agenda-chip ids + data so the
       core timer/focus JS drives it unchanged; only the chrome is the focused rail. -->
  <nav id="agenda-nav" class="otp-rail" data-active="">
    <div class="rail-timer">
      <div class="rail-ring">
        <svg viewBox="0 0 120 120" aria-hidden="true"><circle class="ring-bg" cx="60" cy="60" r="54" fill="none" stroke-width="8"/><circle id="ring-arc" cx="60" cy="60" r="54" fill="none" stroke-width="8" stroke-linecap="round" stroke-dasharray="339" stroke-dashoffset="339" transform="rotate(-90 60 60)"/></svg>
        <div class="rail-ring-t">
          <span id="meeting-clock">--:--</span>
          <small id="ring-budget"></small>
          <button id="timer-toggle" class="rail-toggle" title="Start / pause ( space )">Start</button>
        </div>
      </div>
    </div>
    <div class="rail-steps">
      <a href="#segue"     data-section="segue"     data-budget="5"  class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">Check-in</span></span><span class="st-tm">5m</span><span class="st-go" title="Next section">&darr;</span></a>
      <a href="#scorecard" data-section="scorecard" data-budget="5"  class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><rect x="7" y="11" width="3" height="6"/><rect x="12" y="7" width="3" height="10"/><rect x="17" y="13" width="3" height="4"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">Scorecard</span></span><span class="st-tm">5m</span><span class="st-go" title="Next section">&darr;</span></a>
      <a href="#rocks"     data-section="rocks"     data-budget="5"  class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">Quarterly Priorities</span></span><span class="st-tm">5m</span><span class="st-go" title="Next section">&darr;</span></a>
      <a href="#headlines" data-section="headlines" data-budget="5"  class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h13v16H6a2 2 0 0 1-2-2z"/><path d="M17 8h3v10a2 2 0 0 1-2 2"/><line x1="7" y1="9" x2="13" y2="9"/><line x1="7" y1="13" x2="13" y2="13"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">Headlines</span></span><span class="st-tm">5m</span><span class="st-go" title="Next section">&darr;</span></a>
      <a href="#todos"     data-section="todos"     data-budget="5"  class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">To-Dos</span></span><span class="st-tm">5m</span><span class="st-go" title="Next section">&darr;</span></a>
      <a href="#ids"       data-section="ids"       data-budget="60" class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l7 3v5c0 4-3 7-7 8-4-1-7-4-7-8V6z"/><path d="M9 12l2 2 4-4"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">Issues</span></span><span class="st-tm">60m</span><span class="st-go" title="Next section">&darr;</span></a>
      <a href="#conclude"  data-section="conclude"  data-budget="5"  class="agenda-chip"><span class="st-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span><span class="st-body"><span class="st-eyebrow">Currently on</span><span class="st-nm">Conclude</span></span><span class="st-tm">5m</span><span class="st-go" title="Next section">&darr;</span></a>
    </div>
    <div class="rail-actions">
      <button type="button" class="rail-act" id="rail-add"><span class="ra-ico">+</span> Add</button>
      <button type="button" class="rail-act" id="rail-tools"><span class="ra-ico">▤</span> Tools</button>
      <button type="button" class="rail-act" id="rail-tangent"><span class="ra-ico">&#9888;</span> Tangent</button>
      <button type="button" class="rail-act" id="rail-notes"><span class="ra-ico">&#9998;</span> Notes</button>
    </div>
    <button type="button" class="rail-finish" id="rail-finish">Finish meeting <span aria-hidden="true">&rarr;]</span></button>
    <button id="timer-prev"  type="button" hidden aria-hidden="true">Back</button>
    <button id="timer-skip"  type="button" hidden aria-hidden="true">Next</button>
    <button id="focus-toggle" type="button" hidden aria-hidden="true">Focus</button>
  </nav>
<% } else { %>
  <!-- Agenda nav (single-line, with per-section start-timer) -->
  <nav id="agenda-nav" class="flex items-center gap-1 mb-6 text-xs whitespace-nowrap overflow-x-auto" data-active="">
    <a href="#segue"     data-section="segue"     data-budget="5"  class="agenda-chip flex-1 px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0">1. Checkin <span class="text-gray-500">5m</span></a>
    <a href="#scorecard" data-section="scorecard" data-budget="5"  class="agenda-chip flex-1 px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0">2. Scorecard <span class="text-gray-500">5m</span></a>
    <a href="#rocks"     data-section="rocks"     data-budget="5"  class="agenda-chip flex-[1.5] px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0">3. Quarterly Priorities <span class="text-gray-500">5m</span></a>
    <a href="#headlines" data-section="headlines" data-budget="5"  class="agenda-chip flex-1 px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0">4. Headlines <span class="text-gray-500">5m</span></a>
    <a href="#todos"     data-section="todos"     data-budget="5"  class="agenda-chip flex-1 px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0">5. To-Dos <span class="text-gray-500">5m</span></a>
    <a href="#ids"       data-section="ids"       data-budget="60" class="agenda-chip flex-[2] px-2 py-1.5 bg-orgy-blue-soft rounded hover:bg-orgy-soft text-center font-medium min-w-0">6. Issues <span class="text-gray-600">60m</span></a>
    <a href="#conclude"  data-section="conclude"  data-budget="5"  class="agenda-chip flex-1 px-2 py-1.5 bg-gray-100 rounded hover:bg-gray-200 text-center min-w-0">7. Conclude <span class="text-gray-500">5m</span></a>
    <span id="meeting-clock" class="ml-3 px-2 py-1 rounded bg-gray-900 text-white font-mono text-xs whitespace-nowrap">--:--</span>
    <button id="timer-toggle" class="ml-1 px-2 py-1 bg-orgy-blue text-white rounded text-xs hover:bg-orgy-blue-deep">Start</button>
    <button id="timer-prev"   class="ml-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300" title="Previous section  (  [  )">← Prev</button>
    <button id="timer-skip"   class="ml-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300" title="Next section  (  ]  )  ·  space toggles the timer">Next →</button>
    <button id="focus-toggle" class="ml-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300" title="Focus mode: show only the active section  (  F  )">Focus</button>
  </nav>
<% } %>

  <!-- 1. Segue / Check-in -- one card per attendee, saves with name + time -->
  <%
    // Agenda-driven section rendering (meeting-runner convergence). Built-in
    // meetings use the standard EOS order; custom meetings drive off their own
    // saved agenda. Each section renders the shared partial in
    // src/views/partials/meeting/<type>.ejs -- ONE component per type, used by
    // built-in + custom alike. _validSec is a whitelist (defense-in-depth: the
    // include path is built from the section type, so never include an
    // unknown/traversal value). 'notes' has no built-in partial (custom-only).
    var _builtinOrder = ['segue','scorecard','rocks','headlines','todos','issues','conclude'];
    var _validSec = { segue:1, scorecard:1, rocks:1, headlines:1, todos:1, issues:1, conclude:1 };
    var _secOrder = (Array.isArray(meeting.agenda) && meeting.agenda.length && meeting.meetingType === 'custom')
      ? meeting.agenda.map(function(_s){ return _s && _s.type; })
      : _builtinOrder;
    _secOrder.forEach(function(_secType){
      if (_validSec[_secType]) {
  %><%- include('../partials/meeting/' + _secType, { normalizedAttendees: normalizedAttendees }) %><%
      }
    });
  %>


  <!-- Shared flag-to-issue form (hidden; moved next to the flagged item on click) -->
  <div id="flag-issue-form" class="hidden border border-orgy rounded p-3 bg-orgy-blue-soft mb-3">
    <div class="text-xs uppercase tracking-wider text-orgy-blue font-medium mb-2">Flag as an issue</div>
    <input id="flag-title" type="text" placeholder="Issue title" class="w-full border rounded p-2 text-sm mb-2">
    <div class="grid grid-cols-2 gap-2 mb-2">
      <select id="flag-team" class="border rounded p-2 text-sm">
        <option value="">(no team)</option>
        <% (orgTeams || []).forEach(function(tm) { %>
          <option value="<%= tm.id %>" <%= tm.id === meeting.teamId ? 'selected' : '' %>><%= tm.name %></option>
        <% }); %>
      </select>
      <select id="flag-owner" class="border rounded p-2 text-sm">
        <option value="">(no owner)</option>
        <% (availableOwners || []).forEach(function(a) { %>
          <option value="<%= a.entityType %>:<%= a.externalId %>:<%= a.name || a.externalId %>"><%= a.name || a.externalId %><%= a.isAttendee ? '' : ' (not in room)' %></option>
        <% }); %>
      </select>
    </div>
    <div class="flex gap-2">
      <button id="flag-create" class="text-xs px-3 py-1.5 bg-orgy-blue text-white rounded hover:bg-orgy-blue-deep font-medium">Create Issue</button>
      <button id="flag-cancel" class="text-xs px-3 py-1.5 bg-gray-200 rounded hover:bg-gray-300">Cancel</button>
    </div>
  </div>


  <!-- The foot-of-page End bar was removed: ending now lives in the header's
       Actions menu (and the rail's Finish meeting in focus mode), so the page
       has one clear place to finish instead of a bolted-on bottom bar. -->

  <!-- Add modals (Labs): one shell. The +Add palette opens it; the section's own
       add-form is MOVED in (its delegated handler + reloadKeep on success are
       reused), except Measurable which has its own KPI form below. -->
  <div id="mtg-modal" class="mtg-modal" hidden>
    <div class="mtg-modal-card">
      <div class="mtg-modal-head">
        <h3 class="mtg-modal-title" id="mtg-modal-title">Add</h3>
        <button type="button" class="mtg-modal-x" id="mtg-modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="mtg-modal-body" id="mtg-modal-body"></div>
      <!-- Measurable (KPI) -- a dedicated in-meeting add form (no section form exists) -->
      <div id="kpi-add-form" class="hidden">
        <input id="new-kpi-title" type="text" placeholder="Measurable title (e.g. Weekly Revenue)" class="w-full border rounded-lg p-2.5 text-sm mb-2">
        <textarea id="new-kpi-desc" rows="2" placeholder="Description (optional)" class="w-full border rounded-lg p-2.5 text-sm mb-3"></textarea>
        <div class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1">Goal</div>
        <div class="grid grid-cols-12 gap-2 mb-3">
          <select id="new-kpi-op" class="col-span-3 border rounded-lg p-2.5 text-sm">
            <option value="gte" selected>&ge;</option>
            <option value="lte">&le;</option>
            <option value="eq">=</option>
            <option value="gt">&gt;</option>
            <option value="lt">&lt;</option>
          </select>
          <input id="new-kpi-goal" type="number" step="any" placeholder="100" class="col-span-5 border rounded-lg p-2.5 text-sm">
          <input id="new-kpi-unit" type="text" placeholder="unit (e.g. $, %)" class="col-span-4 border rounded-lg p-2.5 text-sm">
        </div>
        <div class="grid grid-cols-3 gap-2 mb-1">
          <div>
            <div class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1">Cadence</div>
            <select id="new-kpi-grain" class="w-full border rounded-lg p-2.5 text-sm">
              <option value="weekly" selected>Weekly</option>
              <option value="daily">Daily</option>
              <option value="monthly">Monthly</option>
              <option value="quarterly">Quarterly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
          <div>
            <div class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1">Owner</div>
            <select id="new-kpi-owner" class="w-full border rounded-lg p-2.5 text-sm">
              <% (availableOwners || []).filter(function(a){ return a.entityType === 'human'; }).forEach(function(a) { %>
                <option value="<%= a.entityType %>:<%= a.externalId %>:<%= a.name || a.externalId %>"><%= a.name || a.externalId %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <div class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1">Team</div>
            <select id="new-kpi-team" class="w-full border rounded-lg p-2.5 text-sm">
              <% (orgTeams || []).forEach(function(tm) { %>
                <option value="<%= tm.id %>" <%= tm.id === meeting.teamId ? 'selected' : '' %>><%= tm.name %></option>
              <% }); %>
            </select>
          </div>
        </div>
        <div class="mtg-modal-foot">
          <span id="kpi-add-status" class="text-xs text-gray-500"></span>
          <button id="kpi-add-save" type="button" class="px-4 py-2 bg-orgy-blue text-white rounded-lg text-sm font-semibold hover:bg-orgy-blue-deep">+ Add measurable</button>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
(function(){
  const meetingId = document.querySelector('#l8-meeting').dataset.meetingId;
  const teamId = document.querySelector('[data-team-id]').dataset.teamId || null;
  const DEV_ORG = <%- jsonForScript(devOrgIdParam || '') %>;
  function withOrg(path) {
    if (!DEV_ORG) return path;
    return path + (path.includes('?') ? '&' : '?') + 'orgId=' + encodeURIComponent(DEV_ORG);
  }
  const api = (path, opts) => {
    const hasBody = !!(opts && opts.body);
    const headers = { ...((opts && opts.headers) || {}) };
    // Only set JSON content-type when there's actually a body. Fastify rejects
    // DELETE/GET with Content-Type:application/json and an empty body
    // (FST_ERR_CTP_EMPTY_JSON_BODY).
    if (hasBody) headers['Content-Type'] = 'application/json';
    // Hard 30s timeout so a hanging request never leaves a Saving... button
    // stuck on screen during a slow deploy.
    const ctl = new AbortController();
    const timer = setTimeout(function () { ctl.abort(); }, 30000);
    return fetch('/api/v1' + withOrg(path), {
      method: 'GET',
      credentials: 'include',
      ...opts,
      headers,
      signal: ctl.signal,
    }).then(async function (r) {
      // Always try to parse JSON, even on error responses (server errors come
      // back as { error: {...} } JSON). Fall back to the HTTP status.
      let parsed = null;
      try { parsed = await r.json(); } catch (e) { parsed = null; }
      if (!r.ok) {
        if (parsed && parsed.error) return parsed;
        return { error: { code: 'HTTP_' + r.status, message: (parsed && parsed.message) || r.statusText || ('HTTP ' + r.status) } };
      }
      return parsed === null ? { ok: true } : parsed;
    }).catch(function (err) {
      if (err && err.name === 'AbortError') return { error: { code: 'TIMEOUT', message: 'Request timed out after 30s.' } };
      return { error: { code: 'NETWORK', message: (err && err.message) || 'network error' } };
    }).finally(function () { clearTimeout(timer); });
  };
  function errMsg(res) {
    // Normalize both shapes: my own {error:{code,message}} and Fastify's {error,message,statusCode}.
    if (!res) return 'unknown error';
    if (res.error && typeof res.error === 'object') return res.error.message || res.error.code || 'unknown error';
    if (res.message) return res.message;
    if (typeof res.error === 'string') return res.error;
    return 'unknown error';
  }

  function parseOwner(val) {
    if (!val) return null;
    const [entityType, externalId, ...rest] = val.split(':');
    return { entityType, externalId, name: rest.join(':') || externalId };
  }

  // ===== Add to calendar (Phase 0: manual paste path) =====
  // No OAuth. Hand the user a copyable block (OTP meeting link + an optional
  // pasted video link) to drop into a recurring invite they build in Google
  // Calendar or Outlook. Reuses api()/errMsg() from this IIFE.
  (function initAddToCalendar(){
    const toggle = document.getElementById('cal-toggle');
    const panel = document.getElementById('cal-panel');
    const closeBtn = document.getElementById('cal-close');
    const block = document.getElementById('cal-block');
    const copyBtn = document.getElementById('cal-copy');
    const copyStatus = document.getElementById('cal-copy-status');
    const videoInput = document.getElementById('cal-video-input');
    const videoSave = document.getElementById('cal-video-save');
    const repeatSelect = document.getElementById('cal-repeat-select');
    const repeatStatus = document.getElementById('cal-repeat-status');
    const recurrenceLabelEl = document.getElementById('meeting-recurrence-label');
    if (!toggle || !panel || !block) return;

    const meetingTitle = <%- jsonForScript(meeting.title || 'Meeting') %>;
    const meetingUrl = location.origin + '/l8/meeting/' + meetingId;

    function buildBlock() {
      const lines = [meetingTitle, '', 'Open in OTP: ' + meetingUrl];
      const v = ((videoInput && videoInput.value) || '').trim();
      if (v) lines.push('Join video: ' + v);
      if (repeatSelect && repeatSelect.value) {
        const opt = repeatSelect.options[repeatSelect.selectedIndex];
        lines.push('Repeats: ' + (opt ? opt.text : 'yes'));
      }
      block.value = lines.join('\n');
    }
    function flash(msg) {
      if (!copyStatus) return;
      copyStatus.textContent = msg;
      setTimeout(function(){ copyStatus.textContent = ''; }, 2000);
    }

    toggle.addEventListener('click', function(){
      panel.classList.toggle('hidden');
      if (!panel.classList.contains('hidden')) buildBlock();
    });
    if (closeBtn) closeBtn.addEventListener('click', function(){ panel.classList.add('hidden'); });
    if (videoInput) videoInput.addEventListener('input', buildBlock);

    if (copyBtn) copyBtn.addEventListener('click', function(){
      block.select();
      const done = function(){ flash('Copied'); };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(block.value).then(done).catch(function(){ try { document.execCommand('copy'); done(); } catch(e){} });
      } else {
        try { document.execCommand('copy'); done(); } catch(e){}
      }
    });

    if (videoSave) videoSave.addEventListener('click', async function(){
      if (videoSave.disabled) return;
      videoSave.disabled = true;
      const label = videoSave.textContent;
      videoSave.textContent = 'Saving...';
      const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ videoLink: ((videoInput.value) || '').trim() }) });
      videoSave.disabled = false;
      videoSave.textContent = label;
      if (res && res.error) { flash(errMsg(res)); return; }
      buildBlock();
      flash('Link saved');
    });

    if (repeatSelect) repeatSelect.addEventListener('change', async function(){
      repeatSelect.disabled = true;
      if (repeatStatus) repeatStatus.textContent = 'Saving...';
      const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ recurrenceRule: repeatSelect.value }) });
      repeatSelect.disabled = false;
      if (res && res.error) { if (repeatStatus) repeatStatus.textContent = errMsg(res); return; }
      if (repeatStatus) { repeatStatus.textContent = 'Saved'; setTimeout(function(){ repeatStatus.textContent = ''; }, 2000); }
      if (recurrenceLabelEl) {
        const opt = repeatSelect.options[repeatSelect.selectedIndex];
        if (repeatSelect.value) {
          recurrenceLabelEl.textContent = (opt ? opt.text : 'Repeats');
          recurrenceLabelEl.className = 'font-semibold text-gray-800';
        } else {
          recurrenceLabelEl.textContent = 'One-time';
          recurrenceLabelEl.className = 'text-gray-400';
        }
      }
      buildBlock();
    });
  })();

  // ===== Edit scheduled time =====
  // The API PUT validates scheduledAt as an ISO datetime, so we send the typed
  // wall-clock as UTC (value + ':00Z'). This matches how /l8/create + the
  // server-rendered display treat the naive timestamp, so the time doesn't
  // shift by the browser's offset on save.
  (function initScheduleEditor(){
    const btn = document.getElementById('sched-edit-btn');
    const editor = document.getElementById('sched-editor');
    const input = document.getElementById('sched-input');
    const save = document.getElementById('sched-save');
    const cancel = document.getElementById('sched-cancel');
    const status = document.getElementById('sched-status');
    if (!btn || !editor || !input || !save) return;
    btn.addEventListener('click', function(){ editor.classList.toggle('hidden'); });
    if (cancel) cancel.addEventListener('click', function(){ editor.classList.add('hidden'); });
    save.addEventListener('click', async function(){
      if (!input.value) { if (status) status.textContent = 'Pick a date and time'; return; }
      if (save.disabled) return;
      let v = input.value;
      if (v.length === 16) v += ':00';
      const iso = v + 'Z';
      save.disabled = true; const label = save.textContent; save.textContent = 'Saving...';
      const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ scheduledAt: iso }) });
      save.disabled = false; save.textContent = label;
      if (res && res.error) { if (status) status.textContent = errMsg(res); return; }
      reloadKeep();
    });
  })();

  // ===== Edit meeting title =====
  (function initTitleEditor(){
    const btn = document.getElementById('title-edit-btn');
    const editor = document.getElementById('title-editor');
    const input = document.getElementById('title-input');
    const save = document.getElementById('title-save');
    const cancel = document.getElementById('title-cancel');
    const status = document.getElementById('title-status');
    if (!btn || !editor || !input || !save) return;
    btn.addEventListener('click', function(){
      editor.classList.toggle('hidden');
      if (!editor.classList.contains('hidden')) { input.focus(); input.select(); }
    });
    if (cancel) cancel.addEventListener('click', function(){ editor.classList.add('hidden'); });
    input.addEventListener('keydown', function(e){ if (e.key === 'Enter') { e.preventDefault(); save.click(); } });
    save.addEventListener('click', async function(){
      const v = (input.value || '').trim();
      if (!v) { if (status) status.textContent = 'Title required'; return; }
      if (save.disabled) return;
      save.disabled = true; const label = save.textContent; save.textContent = 'Saving...';
      const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ title: v }) });
      save.disabled = false; save.textContent = label;
      if (res && res.error) { if (status) status.textContent = errMsg(res); return; }
      reloadKeep();
    });
  })();

  // ===== Reload helpers =====
  // Some actions still re-render via a full reload. reloadKeep() stashes the
  // scroll position first and restoreScroll() puts it back on load, so a live
  // meeting on a shared screen does not jump to the top on every change.
  const SCROLL_KEY = 'otp-l8-scroll-' + meetingId;
  const FOCUS_KEY = 'otp-l8-focus-' + meetingId;
  const DRAFT_KEY = 'otp-l8-drafts-' + meetingId;

  // Snapshot every textarea / text-shaped input / contenteditable that has
  // a stable id and a non-empty value. Restored on the next page load so
  // typed content survives both manual reloadKeep() saves AND SSE-triggered
  // reloads from teammates. Before 2026-05-26 only scroll + focus were
  // preserved; David lost mid-segue typing when Kristen saved hers.
  function snapshotDrafts() {
    try {
      const drafts = {};
      const sel = 'textarea, input[type="text"], input[type="date"], input[type="number"], [contenteditable="true"]';
      document.querySelectorAll(sel).forEach(function(el) {
        if (!el.id) return;
        const v = el.isContentEditable ? el.innerHTML : el.value;
        if (typeof v === 'string' && v.length > 0) drafts[el.id] = v;
      });
      if (Object.keys(drafts).length > 0) {
        sessionStorage.setItem(DRAFT_KEY, JSON.stringify(drafts));
      }
    } catch (e) {}
  }
  function restoreDrafts() {
    try {
      const raw = sessionStorage.getItem(DRAFT_KEY);
      if (!raw) return;
      sessionStorage.removeItem(DRAFT_KEY);
      const drafts = JSON.parse(raw) || {};
      Object.keys(drafts).forEach(function(id) {
        const el = document.getElementById(id);
        if (!el) return;
        if (el.isContentEditable) {
          el.innerHTML = drafts[id];
        } else {
          el.value = drafts[id];
        }
      });
    } catch (e) {}
  }

  function reloadKeep() {
    try { sessionStorage.setItem(SCROLL_KEY, String(window.scrollY)); } catch (e) {}
    try {
      const ae = document.activeElement;
      if (ae && ae.id) sessionStorage.setItem(FOCUS_KEY, ae.id);
    } catch (e) {}
    snapshotDrafts();
    window.location.assign(window.location.href);
  }
  (function restoreScrollAndFocus() {
    try {
      const y = sessionStorage.getItem(SCROLL_KEY);
      if (y !== null) {
        sessionStorage.removeItem(SCROLL_KEY);
        window.requestAnimationFrame(function () { window.scrollTo(0, parseInt(y, 10) || 0); });
      }
      const fid = sessionStorage.getItem(FOCUS_KEY);
      if (fid) {
        sessionStorage.removeItem(FOCUS_KEY);
        window.requestAnimationFrame(function () {
          const el = document.getElementById(fid);
          if (el && typeof el.focus === 'function') el.focus();
        });
      }
      // Restore draft content AFTER scroll/focus so input.focus() doesn't
      // accidentally clear the value we just put back.
      window.requestAnimationFrame(restoreDrafts);
    } catch (e) {}
  })();

  // Realtime (R2.3): live-swap ONLY the Issues (#ids) section when a teammate
  // changes an issue -- no full-page reload. Safe because the IDS + add-issue
  // handlers below are event-delegated on document, so the freshly-fetched nodes
  // work without rebinding (and the issue handlers read state from the DOM, not
  // baked closures). Fetches the page, lifts out the new #ids, and swaps it in.
  // Any failure falls back to the same full reload everything else uses.
  let issuesRefreshing = false;
  async function refreshIssuesSection() {
    const current = document.getElementById('ids');
    if (!current || issuesRefreshing) return;
    issuesRefreshing = true;
    try {
      const resp = await fetch(window.location.href, { credentials: 'same-origin' });
      if (!resp.ok) throw new Error('status ' + resp.status);
      const html = await resp.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const fresh = doc.getElementById('ids');
      const live = document.getElementById('ids');
      if (!fresh || !live) throw new Error('no #ids');
      rehomeFlagForm();
      live.replaceWith(fresh);
    } catch (e) {
      // Safe fallback: the exact reload path every other kind uses.
      try { snapshotDrafts(); } catch (e2) {}
      window.location.reload();
    } finally {
      issuesRefreshing = false;
    }
  }

  // Same live-swap for the Rocks (#rocks) section. The full-page fetch renders
  // milestones inside the rock cards, so the swapped #rocks is complete -- the
  // agenda endpoint's missing-milestones limitation doesn't apply here.
  let rocksRefreshing = false;
  async function refreshRocksSection() {
    const current = document.getElementById('rocks');
    if (!current || rocksRefreshing) return;
    rocksRefreshing = true;
    try {
      const resp = await fetch(window.location.href, { credentials: 'same-origin' });
      if (!resp.ok) throw new Error('status ' + resp.status);
      const html = await resp.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const fresh = doc.getElementById('rocks');
      const live = document.getElementById('rocks');
      if (!fresh || !live) throw new Error('no #rocks');
      rehomeFlagForm();
      live.replaceWith(fresh);
    } catch (e) {
      try { snapshotDrafts(); } catch (e2) {}
      window.location.reload();
    } finally {
      rocksRefreshing = false;
    }
  }

  // The shared flag-to-issue form (#flag-issue-form) lives between #ids and
  // #conclude -- outside every swappable section. But openFlagForm RELOCATES it
  // next to the flagged KPI/headline (into #scorecard or #headlines). Before any
  // swap, move it back home so a swap can never destroy it (captured refs in
  // openFlagForm/flag-create then stay valid). Hoisted, so the refresh helpers
  // above can call it.
  function rehomeFlagForm() {
    const ff = document.getElementById('flag-issue-form');
    const conclude = document.getElementById('conclude');
    if (ff && conclude && conclude.parentNode && ff.parentNode !== conclude.parentNode) {
      ff.classList.add('hidden');
      conclude.parentNode.insertBefore(ff, conclude);
    }
  }

  // Same live-swap for the Scorecard (#scorecard) section.
  let scorecardRefreshing = false;
  async function refreshScorecardSection() {
    const current = document.getElementById('scorecard');
    if (!current || scorecardRefreshing) return;
    scorecardRefreshing = true;
    try {
      const resp = await fetch(window.location.href, { credentials: 'same-origin' });
      if (!resp.ok) throw new Error('status ' + resp.status);
      const html = await resp.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const fresh = doc.getElementById('scorecard');
      const live = document.getElementById('scorecard');
      if (!fresh || !live) throw new Error('no #scorecard');
      rehomeFlagForm();
      live.replaceWith(fresh);
    } catch (e) {
      try { snapshotDrafts(); } catch (e2) {}
      window.location.reload();
    } finally {
      scorecardRefreshing = false;
    }
  }

  // Same live-swap for the Headlines (#headlines) section.
  let headlinesRefreshing = false;
  async function refreshHeadlinesSection() {
    const current = document.getElementById('headlines');
    if (!current || headlinesRefreshing) return;
    headlinesRefreshing = true;
    try {
      const resp = await fetch(window.location.href, { credentials: 'same-origin' });
      if (!resp.ok) throw new Error('status ' + resp.status);
      const html = await resp.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const fresh = doc.getElementById('headlines');
      const live = document.getElementById('headlines');
      if (!fresh || !live) throw new Error('no #headlines');
      rehomeFlagForm();
      live.replaceWith(fresh);
    } catch (e) {
      try { snapshotDrafts(); } catch (e2) {}
      window.location.reload();
    } finally {
      headlinesRefreshing = false;
    }
  }

  // Same live-swap for the To-dos (#todos) section.
  let todosRefreshing = false;
  async function refreshTodosSection() {
    const current = document.getElementById('todos');
    if (!current || todosRefreshing) return;
    todosRefreshing = true;
    try {
      const resp = await fetch(window.location.href, { credentials: 'same-origin' });
      if (!resp.ok) throw new Error('status ' + resp.status);
      const html = await resp.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const fresh = doc.getElementById('todos');
      const live = document.getElementById('todos');
      if (!fresh || !live) throw new Error('no #todos');
      rehomeFlagForm();
      live.replaceWith(fresh);
    } catch (e) {
      try { snapshotDrafts(); } catch (e2) {}
      window.location.reload();
    } finally {
      todosRefreshing = false;
    }
  }

  // ===== Per-section timer =====
  const chips = Array.from(document.querySelectorAll('.agenda-chip'));
  const clock = document.getElementById('meeting-clock');
  const toggleBtn = document.getElementById('timer-toggle');
  const skipBtn = document.getElementById('timer-skip');
  let timerState = { running: false, sectionIdx: 0, elapsed: 0, intervalId: null, sectionTimes: {} };
  const TIMER_KEY = 'otp-l8-timer-' + meetingId;
  // Total meeting budget (sum of every section's minutes) drives the rail's
  // total-time ring in stepped mode.
  const TOTAL_BUDGET = chips.reduce(function(s, c){ return s + (parseInt(c.dataset.budget || '5', 10) * 60); }, 0);
  function totalElapsed(){ var s = 0, t = timerState.sectionTimes || {}; for (var k in t) s += (t[k] || 0); return s; }
  function fmtHMS(s){ var h = Math.floor(s/3600), m = Math.floor((s%3600)/60), r = s%60; return (h ? h + ':' : '') + String(m).padStart(2,'0') + ':' + String(r).padStart(2,'0'); }

  // Restore a persisted timer. If it was running, add the wall-clock seconds
  // that passed while the page was away so the meeting clock stays true
  // through the reloads some actions still trigger.
  try {
    const _savedTimer = JSON.parse(localStorage.getItem(TIMER_KEY) || 'null');
    if (_savedTimer && typeof _savedTimer.elapsed === 'number') {
      timerState.sectionIdx = Math.min(Math.max(0, _savedTimer.sectionIdx || 0), Math.max(0, chips.length - 1));
      timerState.elapsed = _savedTimer.elapsed;
      timerState.running = !!_savedTimer.running;
      timerState.sectionTimes = (_savedTimer.sectionTimes && typeof _savedTimer.sectionTimes === 'object') ? _savedTimer.sectionTimes : {};
      if (timerState.running && _savedTimer.savedAt) {
        var _away = Math.max(0, Math.floor((Date.now() - _savedTimer.savedAt) / 1000));
        timerState.sectionTimes[timerState.sectionIdx] = (timerState.sectionTimes[timerState.sectionIdx] || 0) + _away;
      }
      if (timerState.running && _savedTimer.savedAt) {
        timerState.elapsed += Math.max(0, Math.floor((Date.now() - _savedTimer.savedAt) / 1000));
      }
    }
  } catch (e) { /* corrupt timer state -- start fresh */ }
  // A finished meeting never has a running clock, no matter what localStorage
  // says (covers ending from another tab/device).
  if (<%- jsonForScript(meeting.status) %> === 'completed' || <%- jsonForScript(meeting.status) %> === 'cancelled') {
    timerState.running = false;
  }

  function saveTimer() {
    try {
      localStorage.setItem(TIMER_KEY, JSON.stringify({
        sectionIdx: timerState.sectionIdx,
        elapsed: timerState.elapsed,
        running: timerState.running,
        sectionTimes: timerState.sectionTimes,
        savedAt: Date.now(),
      }));
    } catch (e) { /* storage unavailable -- timer still works for this page */ }
  }

  function activeChip() { return chips[timerState.sectionIdx]; }
  function activeBudgetSec() { return parseInt(activeChip()?.dataset.budget || '5', 10) * 60; }
  function fmt(s) {
    const sign = s < 0 ? '-' : '';
    const a = Math.abs(s);
    const m = Math.floor(a / 60);
    const r = a % 60;
    return sign + String(m).padStart(2, '0') + ':' + String(r).padStart(2, '0');
  }
  function paintChip() {
    chips.forEach((c, i) => {
      c.classList.remove('ring-2', 'ring-orgy');
      if (i === timerState.sectionIdx) c.classList.add('ring-2', 'ring-orgy');
    });
  }
  function tick() {
    if (!timerState.running) return;
    timerState.elapsed++;
    timerState.sectionTimes[timerState.sectionIdx] = (timerState.sectionTimes[timerState.sectionIdx] || 0) + 1;
    render();
  }
  // Rail (stepped) view: a total-meeting ring + a live time on every step,
  // green while inside budget, red once over.
  function renderStepped() {
    var total = totalElapsed();
    clock.textContent = fmt(total);
    clock.classList.remove('bg-gray-900', 'bg-red-600', 'bg-amber-500', 'animate-pulse');
    var arc = document.getElementById('ring-arc');
    if (arc) {
      var frac = TOTAL_BUDGET > 0 ? Math.max(0, Math.min(1, total / TOTAL_BUDGET)) : 0;
      arc.style.strokeDashoffset = String(339 * (1 - frac));
      arc.style.stroke = total > TOTAL_BUDGET ? '#dc2626' : '#16a34a';
    }
    var rb = document.getElementById('ring-budget');
    if (rb) rb.textContent = '/ ' + fmtHMS(TOTAL_BUDGET);
    chips.forEach(function(c, i){
      var tm = c.querySelector('.st-tm');
      if (!tm) return;
      var sec = timerState.sectionTimes[i] || 0;
      var bud = parseInt(c.dataset.budget || '5', 10) * 60;
      if (sec > 0) { tm.textContent = fmt(sec); tm.classList.toggle('st-over', sec > bud); tm.classList.add('st-spent'); }
    });
  }
  function render() {
    var railMode = !!document.getElementById('agenda-nav')?.classList.contains('otp-rail');
    if (railMode) {
      renderStepped();
    } else {
      const remaining = activeBudgetSec() - timerState.elapsed;
      clock.textContent = fmt(remaining);
      if (remaining < 0) {
        clock.classList.remove('bg-gray-900');
        clock.classList.add('bg-red-600', 'animate-pulse');
      } else if (remaining < 60) {
        clock.classList.remove('bg-gray-900', 'bg-red-600', 'animate-pulse');
        clock.classList.add('bg-amber-500');
      } else {
        clock.classList.remove('bg-red-600', 'bg-amber-500', 'animate-pulse');
        clock.classList.add('bg-gray-900');
      }
    }
    paintChip();
    saveTimer();
  }
  // ===== Shared timer sync (the whole room sees one clock) =====
  // A user start/pause/section-change POSTs the state; the server caches it and
  // broadcasts a kind:'timer' event that applyRemoteTimer() applies on every other
  // client. _applyingRemote stops an applied update from re-posting; _timerReady
  // stops the initial auto-start from broadcasting before we're set up.
  let _applyingRemote = false;
  let _timerReady = false;
  let _postTimerT = null;
  function postTimer() {
    if (_applyingRemote || !_timerReady) return;
    if (_postTimerT) clearTimeout(_postTimerT);
    _postTimerT = setTimeout(function () {
      try {
        fetch('/api/v1/meetings/' + meetingId + '/timer', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ running: timerState.running, sectionIdx: timerState.sectionIdx, elapsed: timerState.elapsed, sectionTimes: timerState.sectionTimes }),
        }).catch(function () {});
      } catch (e) { /* offline -- the local timer still runs */ }
    }, 150);
  }
  function applyRemoteTimer(t) {
    if (!t || typeof t !== 'object') return;
    _applyingRemote = true;
    try {
      timerState.sectionIdx = Math.min(Math.max(0, parseInt(t.sectionIdx, 10) || 0), Math.max(0, chips.length - 1));
      timerState.sectionTimes = (t.sectionTimes && typeof t.sectionTimes === 'object') ? t.sectionTimes : {};
      timerState.elapsed = (typeof t.elapsed === 'number') ? t.elapsed : 0;
      timerState.running = !!t.running;
      if (timerState.running) {
        if (!timerState.intervalId) timerState.intervalId = setInterval(tick, 1000);
        if (toggleBtn) toggleBtn.textContent = 'Pause';
      } else {
        if (timerState.intervalId) { clearInterval(timerState.intervalId); timerState.intervalId = null; }
        if (toggleBtn) toggleBtn.textContent = timerState.elapsed > 0 ? 'Resume' : 'Start';
      }
      applyFocus();
      render();
    } finally { _applyingRemote = false; }
  }

  function startTimer() {
    timerState.running = true;
    if (!timerState.intervalId) timerState.intervalId = setInterval(tick, 1000);
    toggleBtn.textContent = 'Pause';
    render();
    postTimer();
  }
  function pauseTimer() {
    timerState.running = false;
    if (timerState.intervalId) { clearInterval(timerState.intervalId); timerState.intervalId = null; }
    toggleBtn.textContent = 'Resume';
    render();
    postTimer();
  }
  function jumpTo(idx) {
    timerState.sectionIdx = Math.max(0, Math.min(chips.length - 1, idx));
    timerState.elapsed = 0;
    applyFocus();
    if (focusMode) {
      document.getElementById('agenda-nav')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      chips[timerState.sectionIdx].scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    render();
    postTimer();
  }
  toggleBtn?.addEventListener('click', () => { timerState.running ? pauseTimer() : startTimer(); });
  skipBtn?.addEventListener('click', () => { jumpTo(timerState.sectionIdx + 1); });
  const prevBtn = document.getElementById('timer-prev');
  prevBtn?.addEventListener('click', () => { jumpTo(timerState.sectionIdx - 1); });
  chips.forEach((c, i) => c.addEventListener('click', () => { jumpTo(i); if (!timerState.running) startTimer(); }));

  // Focus mode: EOS-style single-section view. Shows only the active agenda
  // section in the main pane; the rest hide. Rides the same sectionIdx the
  // timer already tracks, so Prev/Next and the chips drive it for free.
  // Persisted per browser.
  const FOCUS_MODE_KEY = 'otp-l8-focus-mode';
  const sections = chips.map(c => document.getElementById(c.dataset.section));
  let focusMode = false;
  try { focusMode = localStorage.getItem(FOCUS_MODE_KEY) === '1'; } catch (e) { /* no storage */ }
  // Labs meetings_broken_out: the focused rail run-mode is always single-section.
  const _stepped = !!document.getElementById('l8-meeting')?.classList.contains('meeting-stepped');
  if (_stepped) focusMode = true;
  const focusBtn = document.getElementById('focus-toggle');
  function applyFocus() {
    sections.forEach((s, i) => { if (s) s.style.display = (focusMode && i !== timerState.sectionIdx) ? 'none' : ''; });
    if (focusBtn) {
      focusBtn.textContent = focusMode ? 'Focus: on' : 'Focus';
      focusBtn.classList.toggle('bg-orgy-blue', focusMode);
      focusBtn.classList.toggle('text-white', focusMode);
      focusBtn.classList.toggle('bg-gray-200', !focusMode);
    }
  }
  function setFocus(on) {
    focusMode = on;
    try { localStorage.setItem(FOCUS_MODE_KEY, on ? '1' : '0'); } catch (e) { /* no storage */ }
    applyFocus();
  }
  focusBtn?.addEventListener('click', () => setFocus(!focusMode));
  applyFocus();

  // Keyboard flow: space = pause/resume the timer, [ / ] = prev / next section.
  // Ignored while typing in a field so it never eats meeting notes.
  document.addEventListener('keydown', (e) => {
    const t = e.target;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT' || t.isContentEditable)) return;
    if (e.key === ' ' || e.code === 'Space') {
      e.preventDefault();
      timerState.running ? pauseTimer() : startTimer();
    } else if (e.key === ']') {
      jumpTo(timerState.sectionIdx + 1);
    } else if (e.key === '[') {
      jumpTo(timerState.sectionIdx - 1);
    } else if (e.key === 'f' || e.key === 'F') {
      setFocus(!focusMode);
    }
  });
  // Resume ticking if a running timer was restored from a prior page load.
  if (timerState.running && !timerState.intervalId) {
    timerState.intervalId = setInterval(tick, 1000);
    toggleBtn.textContent = 'Pause';
  } else if (!localStorage.getItem(TIMER_KEY)) {
    // First load of an in-progress meeting with no timer yet: start the clock
    // automatically, so "Start Meeting" and the section timer are one action.
    const _statusEl = document.getElementById('meeting-status');
    if (_statusEl && _statusEl.textContent.trim() === 'in_progress') startTimer();
  }
  render();
  // From here on, user-driven timer changes broadcast to the room. (The initial
  // auto-start above is intentionally local -- the SSE replay syncs us to any
  // clock the room already has running.)
  _timerReady = true;

  // Rebuild cascading message from meeting state
  const rebuildBtn = document.getElementById('rebuild-cascading');
  if (rebuildBtn) rebuildBtn.addEventListener('click', async () => {
    const orig = rebuildBtn.textContent;
    rebuildBtn.disabled = true; rebuildBtn.textContent = 'Rebuilding...';
    const res = await api('/meetings/' + meetingId + '/rebuild-cascading', { method: 'POST' });
    if (res?.cascadingMessage !== undefined) {
      const ta = document.getElementById('cascading-message');
      if (ta) ta.value = res.cascadingMessage;
      const status = document.getElementById('cascading-status');
      if (status) {
        status.textContent = 'Rebuilt from headlines + solved + new to-dos';
        setTimeout(() => { status.textContent = ''; }, 3000);
      }
    } else {
      alert('Rebuild failed: ' + errMsg(res));
    }
    rebuildBtn.disabled = false; rebuildBtn.textContent = orig;
  });

  // Cascade meeting to team agent inboxes
  const cascadeBtn = document.getElementById('cascade-to-team');
  if (cascadeBtn) cascadeBtn.addEventListener('click', async () => {
    const orig = cascadeBtn.textContent;
    cascadeBtn.disabled = true; cascadeBtn.textContent = 'Cascading...';
    const res = await api('/meetings/' + meetingId + '/cascade', { method: 'POST' });
    if (res?.cascaded) {
      const status = document.getElementById('cascading-status');
      if (status) {
        const delivered = (res.deliveries || []).filter(d => d.delivered).length;
        status.textContent = 'Cascaded to ' + delivered + ' agent inbox(es)';
        setTimeout(() => { status.textContent = ''; }, 4000);
      }
    } else {
      alert('Cascade failed: ' + errMsg(res));
    }
    cascadeBtn.disabled = false; cascadeBtn.textContent = orig;
  });

  // Save segue / headlines / cascading message (delegated -- the headlines Save
  // button lives in #headlines, which gets live-swapped).
  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-save]');
    if (!btn) return;
    const field = btn.dataset.save;
    const map = { segueNotes: 'segue-notes', headlines: 'headlines-notes', cascadingMessage: 'cascading-message' };
    const el = document.getElementById(map[field]);
    if (!el) return;
    btn.textContent = 'Saving...';
    await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ [field]: el.value }) });
    btn.textContent = 'Saved';
    setTimeout(() => btn.textContent = 'Save', 1500);
  });

  // ===== Per-attendee check-in (Segue) =====
  // Each attendee card has its own input + Save. Saving writes that
  // attendee's checkinText + checkinAt onto the entry in meeting.attendees
  // (matched by externalId, externalIds[*], or memberId) and reloads.
  document.querySelectorAll('[data-checkin-attendee]').forEach(function(card) {
    const key = card.getAttribute('data-checkin-attendee');
    const editor = card.querySelector('[data-checkin-editor]');
    const display = card.querySelector('[data-checkin-display]');
    const input = card.querySelector('[data-checkin-input]');
    const saveBtn = card.querySelector('[data-checkin-save]');
    const editBtn = card.querySelector('[data-checkin-edit]');
    const cancelBtn = card.querySelector('[data-checkin-cancel]');
    const msgEl = card.querySelector('[data-checkin-msg]');

    if (editBtn) editBtn.addEventListener('click', function() {
      if (display) display.classList.add('hidden');
      if (editor) editor.classList.remove('hidden');
      if (input) input.focus();
    });
    if (cancelBtn) cancelBtn.addEventListener('click', function() {
      if (editor) editor.classList.add('hidden');
      if (display) display.classList.remove('hidden');
      if (msgEl) msgEl.textContent = '';
    });
    if (saveBtn) saveBtn.addEventListener('click', async function() {
      const text = ((input && input.value) || '').trim();
      if (msgEl) { msgEl.textContent = 'Saving...'; msgEl.className = 'text-xs text-gray-500'; }
      saveBtn.disabled = true;
      const nowIso = new Date().toISOString();
      const newAttendees = (attendees || []).map(function(a) {
        if (!a) return a;
        const aKey = a.externalId || a.memberId || '';
        const inExternalIds = Array.isArray(a.externalIds) && a.externalIds.indexOf(key) !== -1;
        if (aKey === key || inExternalIds || a.memberId === key) {
          return Object.assign({}, a, { checkinText: text, checkinAt: nowIso });
        }
        return a;
      });
      const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ attendees: newAttendees }) });
      saveBtn.disabled = false;
      if (res && res.error) {
        if (msgEl) { msgEl.textContent = 'Error: ' + errMsg(res); msgEl.className = 'text-xs text-red-600'; }
        return;
      }
      attendees = newAttendees;
      reloadKeep();
    });
  });

  // Save-on-blur for the free-text segments, so notes are never lost by
  // forgetting to click Save. Delegated (focusin snapshots, focusout saves if
  // changed) so the headlines-notes textarea survives a #headlines swap.
  (function(){
    const NOTES = { 'segue-notes': 'segueNotes', 'headlines-notes': 'headlines', 'cascading-message': 'cascadingMessage' };
    document.addEventListener('focusin', function(e){
      const el = e.target;
      if (el && el.id && NOTES[el.id]) el.dataset.savedValue = el.value;
    });
    document.addEventListener('focusout', async function(e){
      const el = e.target;
      if (!el || !el.id || !NOTES[el.id]) return;
      const base = el.dataset.savedValue;
      if (base === undefined || el.value === base) return;
      el.dataset.savedValue = el.value;
      await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ [NOTES[el.id]]: el.value }) });
    });
  })();

  // Start / end / extend meeting. Bound by class so the header AND footer
  // buttons (and the locked-banner Start) all work from one handler each.
  document.querySelectorAll('.js-start-meeting').forEach((startBtn) => {
    startBtn.addEventListener('click', async () => {
      const orig = startBtn.textContent;
      startBtn.disabled = true; startBtn.textContent = 'Starting...';
      const res = await api('/meetings/' + meetingId + '/start', { method: 'POST' });
      if (!res || res.error) {
        alert('Could not start the meeting: ' + errMsg(res));
        startBtn.disabled = false; startBtn.textContent = orig;
        return;
      }
      reloadKeep();
    });
  });
  document.querySelectorAll('.js-end-meeting').forEach((endBtn) => {
    endBtn.addEventListener('click', async () => {
      // Gate (in-progress only): every attendee needs a score or an absent mark
      // before finishing. A never-started scheduled meeting can still be ended.
      try {
        var _st = document.getElementById('meeting-status');
        var _inProgress = _st && _st.textContent.trim() === 'in_progress';
        var _miss = (_inProgress && typeof ratingsMissing === 'function') ? ratingsMissing() : [];
        if (_miss.length) {
          alert('Add a rating for each person (or mark them absent) before finishing the meeting.');
          var _chip = document.querySelector('.agenda-chip[data-section="conclude"]'); if (_chip) _chip.click();
          var _f = document.querySelector('[data-rating-input][data-attendee-key="' + _attKey(_miss[0]) + '"]');
          if (_f) { try { _f.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (e) {} _f.focus(); }
          return;
        }
      } catch (e) { /* if the gate errors, don't block ending */ }
      if (!confirm('End the meeting?')) return;
      const orig = endBtn.textContent;
      // Disable every End button so the header + footer can't double-fire.
      document.querySelectorAll('.js-end-meeting').forEach((b) => { b.disabled = true; });
      endBtn.textContent = 'Ending...';
      // Stop the agenda clock and clear its persisted state so it doesn't
      // resurrect as "running" after the reload.
      try { pauseTimer(); } catch (e) { /* timer not initialized */ }
      try { localStorage.removeItem(TIMER_KEY); } catch (e) { /* storage unavailable */ }
      // Persist ratings entered this session so finishing never loses them.
      try { await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ ratings: collectRatings() }) }); } catch (e) { /* keep ending */ }
      const res = await api('/meetings/' + meetingId + '/end', { method: 'POST' });
      if (!res || res.error) {
        alert('Could not end the meeting: ' + errMsg(res));
        document.querySelectorAll('.js-end-meeting').forEach((b) => { b.disabled = false; });
        endBtn.textContent = orig;
        return;
      }
      // In the focused run-mode the global nav is hidden, so finishing must take
      // you OUT of the meeting. Elsewhere keep the in-place reload (frozen record).
      if (document.getElementById('agenda-nav')?.classList.contains('otp-rail')) { window.location.href = '/l8'; return; }
      reloadKeep();
    });
  });
  document.querySelectorAll('.js-extend-meeting').forEach((extendBtn) => {
    extendBtn.addEventListener('click', async () => {
      const orig = extendBtn.textContent;
      extendBtn.disabled = true; extendBtn.textContent = 'Extending...';
      const res = await api('/meetings/' + meetingId + '/extend', { method: 'POST' });
      if (!res || res.error) {
        alert('Could not extend the meeting: ' + errMsg(res));
        extendBtn.disabled = false; extendBtn.textContent = orig;
        return;
      }
      extendBtn.textContent = 'Extended +1h';
      setTimeout(() => { extendBtn.disabled = false; extendBtn.textContent = orig; }, 2000);
    });
  });

  // Locked = a future occurrence opened directly. Make the body read-only so
  // data goes into the current meeting, not this one. Edits are also rejected
  // server-side (423); this just makes it visually clear. Start stays usable.
  <% if (typeof locked !== 'undefined' && locked) { %>
  (function lockMeetingBody(){
    const root = document.getElementById('l8-meeting');
    if (!root) return;
    root.querySelectorAll('input, textarea, select').forEach((el) => { el.disabled = true; });
    root.querySelectorAll('button').forEach((b) => {
      if (b.classList.contains('js-start-meeting') || b.id === 'cal-toggle' || b.id === 'cal-close') return;
      b.disabled = true;
    });
  })();
  <% } %>

  // Delete meeting. A recurring meeting asks for a scope (this one / this and
  // following / the whole series), like any calendar app; a one-off keeps the
  // plain confirm.
  const IS_RECURRING = <%- (meeting.recurrenceRule || meeting.recurrenceParentId) ? 'true' : 'false' %>;

  function chooseDeleteScope() {
    return new Promise((resolve) => {
      const btn = 'display:block;width:100%;text-align:left;padding:11px 14px;border-radius:8px;border:1px solid #d9e2da;background:#f7faf6;font-size:14px;font-weight:600;color:#16241b;cursor:pointer;';
      const danger = 'display:block;width:100%;text-align:left;padding:11px 14px;border-radius:8px;border:1px solid #f0c9c9;background:#fdf3f3;font-size:14px;font-weight:600;color:#a3271f;cursor:pointer;';
      const ov = document.createElement('div');
      ov.style.cssText = 'position:fixed;inset:0;background:rgba(15,27,20,.55);display:flex;align-items:center;justify-content:center;z-index:9999;';
      ov.innerHTML =
        '<div style="background:#fff;border-radius:12px;max-width:430px;width:90%;padding:24px;font-family:Inter,system-ui,sans-serif;box-shadow:0 20px 60px rgba(0,0,0,.3);">' +
          '<div style="font-weight:800;font-size:18px;color:#16241b;margin-bottom:6px;">Delete recurring meeting</div>' +
          '<div style="font-size:13.5px;color:#5d6b60;line-height:1.5;margin-bottom:18px;">This meeting repeats. Choose what to delete.</div>' +
          '<div style="display:flex;flex-direction:column;gap:9px;">' +
            '<button data-scope="occurrence" style="' + btn + '">Only this meeting<div style="font-weight:400;color:#5d6b60;font-size:12px;margin-top:2px;">Future occurrences stay on the calendar.</div></button>' +
            '<button data-scope="following" style="' + btn + '">This and all following<div style="font-weight:400;color:#5d6b60;font-size:12px;margin-top:2px;">Ends the series from here forward.</div></button>' +
            '<button data-scope="series" style="' + danger + '">The entire series<div style="font-weight:400;color:#a3271f;opacity:.8;font-size:12px;margin-top:2px;">Removes every meeting in this series.</div></button>' +
          '</div>' +
          '<button data-scope="" style="display:block;width:100%;text-align:center;margin-top:14px;padding:9px;background:none;border:none;color:#5d6b60;font-size:13px;cursor:pointer;">Cancel</button>' +
        '</div>';
      const cleanup = () => ov.remove();
      ov.addEventListener('click', (e) => {
        if (e.target === ov) { cleanup(); resolve(null); return; }
        const b = e.target.closest('[data-scope]');
        if (!b) return;
        const s = b.getAttribute('data-scope');
        cleanup();
        resolve(s || null);
      });
      document.body.appendChild(ov);
    });
  }

  const deleteMeetingBtn = document.getElementById('delete-meeting');
  if (deleteMeetingBtn) deleteMeetingBtn.addEventListener('click', async () => {
    let scope = 'occurrence';
    if (IS_RECURRING) {
      scope = await chooseDeleteScope();
      if (!scope) return; // cancelled
    } else if (!confirm('Delete this meeting? It will be removed from the L8 list.')) {
      return;
    }
    deleteMeetingBtn.disabled = true; deleteMeetingBtn.textContent = 'Deleting...';
    const res = await api('/meetings/' + meetingId, { method: 'DELETE', body: JSON.stringify({ scope }) });
    if (res?.deleted) {
      window.location.href = withOrg('/l8');
    } else {
      alert('Delete failed: ' + errMsg(res));
      deleteMeetingBtn.disabled = false; deleteMeetingBtn.textContent = 'Delete meeting';
    }
  });

  // Attendees -- normalized list held in JS, edited via chips + add-select.
  const attendeesEditBtn = document.getElementById('edit-attendees-btn');
  const attendeesEditor = document.getElementById('attendees-editor');
  const attendeesDisplay = document.getElementById('attendees-display');
  let attendees = <%- jsonForScript(normalizedAttendees) %>;

  if (attendeesEditBtn) attendeesEditBtn.addEventListener('click', () => {
    attendeesEditor.classList.toggle('hidden');
    attendeesDisplay.classList.toggle('hidden');
  });

  function renderAttendeeChips() {
    const wrap = document.getElementById('attendees-chips');
    if (!wrap) return;
    wrap.innerHTML = '';
    if (attendees.length === 0) {
      const empty = document.createElement('span');
      empty.className = 'text-xs text-gray-500 italic';
      empty.textContent = 'No attendees -- add one below';
      wrap.appendChild(empty);
      return;
    }
    attendees.forEach(a => {
      const chip = document.createElement('span');
      chip.className = 'text-xs px-2 py-1 rounded-full inline-flex items-center gap-1 ' +
        (a.entityType === 'agent' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800');
      const label = document.createElement('span');
      label.textContent = (a.name || a.externalId) + ' (' + a.entityType + ')';
      chip.appendChild(label);
      const x = document.createElement('button');
      x.textContent = '✕';
      x.className = 'text-gray-500 hover:text-red-600 font-bold';
      x.setAttribute('data-remove-attendee', a.entityType + ':' + a.externalId);
      chip.appendChild(x);
      wrap.appendChild(chip);
    });
  }

  async function saveAttendees() {
    const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ attendees }) });
    if (res?.error) { alert(errMsg(res)); return; }
    reloadKeep();
  }

  document.getElementById('attendees-chips')?.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-remove-attendee]');
    if (!btn) return;
    const key = btn.getAttribute('data-remove-attendee');
    const idx = attendees.findIndex(a => (a.entityType + ':' + a.externalId) === key);
    if (idx === -1) return;
    attendees.splice(idx, 1);
    saveAttendees();
  });

  document.getElementById('attendee-add-btn')?.addEventListener('click', () => {
    const sel = document.getElementById('attendee-add-select');
    const val = sel && sel.value;
    if (!val) return;
    const [entityType, externalId, ...rest] = val.split(':');
    if (!entityType || !externalId) return;
    if (attendees.some(a => a.entityType === entityType && a.externalId === externalId)) return;
    attendees.push({ entityType, externalId, name: rest.join(':') || externalId });
    saveAttendees();
  });

  renderAttendeeChips();

  // Refresh scorecard (delegated -- #refresh-scorecard lives inside #scorecard,
  // which gets live-swapped, so an id-bound handler would orphan).
  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('#refresh-scorecard');
    if (!btn) return;
    const orig = btn.textContent;
    btn.disabled = true; btn.textContent = 'Refreshing...';
    const res = await api('/meetings/' + meetingId + '/refresh-scorecard', { method: 'POST' });
    if (res?.error) {
      alert('Refresh failed: ' + errMsg(res));
      btn.disabled = false; btn.textContent = orig;
      return;
    }
    reloadKeep();
  });

  // ===== Rock actions (event-delegated on document) =====
  // Delegated so the Rocks (#rocks) section can be live-swapped on a teammate's
  // change (refreshRocksSection) without rebinding. Every handler reads state
  // from the closest [data-rock-id] card -- no baked closure.
  async function rockStatusWrite(btn, patch, failLabel) {
    const card = btn.closest('[data-rock-id]');
    if (!card) return;
    const rockId = card.dataset.rockId;
    btn.disabled = true;
    const res = await api('/rocks/' + rockId, { method: 'PUT', body: JSON.stringify(patch) });
    if (res?.error) { alert(failLabel + ' failed: ' + errMsg(res)); btn.disabled = false; return; }
    card.style.transition = 'opacity 0.25s';
    card.style.opacity = '0';
    setTimeout(() => reloadKeep(), 200);
  }
  document.addEventListener('click', async (e) => {
    const rocksRoot = document.getElementById('rocks');
    if (!rocksRoot) return;
    const trigger = e.target.closest('[data-rock-toggle],[data-rock-complete],[data-rock-archive],[data-rock-reopen]');
    if (!trigger || !rocksRoot.contains(trigger)) return;
    const card = trigger.closest('[data-rock-id]');
    if (!card) return;

    // Complete / Archive / Reopen -- fade then reloadKeep() re-renders.
    if (trigger.matches('[data-rock-complete]')) { rockStatusWrite(trigger, { completed: true }, 'Complete'); return; }
    if (trigger.matches('[data-rock-archive]')) {
      if (!confirm('Archive this priority? It will be hidden from the active Quarterly Priorities (you can Reopen it later).')) return;
      rockStatusWrite(trigger, { archived: true }, 'Archive');
      return;
    }
    if (trigger.matches('[data-rock-reopen]')) { rockStatusWrite(trigger, { completed: false, archived: false }, 'Reopen'); return; }

    // On / Off toggle -- repaint badge + buttons + "Changed this meeting" note in place.
    const onTrack = trigger.dataset.rockToggle === 'on';
    const res = await api('/rocks/' + card.dataset.rockId, { method: 'PUT', body: JSON.stringify({ onTrack }) });
    if (res && res.error) { alert('Update failed: ' + errMsg(res)); return; }
    const badge = card.querySelector('[data-rock-status-badge]');
    if (badge) {
      badge.textContent = onTrack ? 'On Track' : 'Off Track';
      badge.className = 'inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ' +
        (onTrack ? 'bg-status-ontrack-soft text-status-ontrack' : 'bg-status-offtrack-soft text-status-offtrack');
    }
    const onBtn = card.querySelector('[data-rock-toggle="on"]');
    const offBtn = card.querySelector('[data-rock-toggle="off"]');
    if (onBtn) onBtn.className = 'text-xs px-2 py-1 rounded hover:opacity-80 ' + (onTrack ? 'bg-status-ontrack-soft text-status-ontrack font-bold' : 'bg-gray-100 text-gray-400');
    if (offBtn) offBtn.className = 'text-xs px-2 py-1 rounded hover:opacity-80 ' + (!onTrack ? 'bg-status-offtrack-soft text-status-offtrack font-bold' : 'bg-gray-100 text-gray-400');
    const note = card.querySelector('[data-rock-change]');
    const base = card.dataset.rockBaseline; // 'on' | 'off' | 'none'
    if (note && base && base !== 'none') {
      const baseOn = base === 'on';
      if (onTrack === baseOn) {
        note.classList.add('hidden');
        note.textContent = '';
      } else {
        note.classList.remove('hidden');
        note.textContent = '↳ Changed this meeting: ' + (baseOn ? 'On Track' : 'Off Track') + ' → ' + (onTrack ? 'On Track' : 'Off Track');
      }
    }
  });

  document.addEventListener('change', async (e) => {
    const rocksRoot = document.getElementById('rocks');
    if (!rocksRoot) return;
    const t = e.target;
    if (!rocksRoot.contains(t)) return;

    // Milestone check-off (optimistic strike + count chip; revert on failure).
    if (t.classList && t.classList.contains('ms-check')) {
      const li = t.closest('[data-ms-id]');
      const block = t.closest('[data-ms-rock]');
      if (!li) return;
      const checked = t.checked;
      const titleEl = li.querySelector('.ms-title');
      const repaint = () => {
        if (titleEl) titleEl.className = 'ms-title flex-1 break-words ' + (t.checked ? 'line-through text-gray-400' : 'text-gray-700');
        if (block) {
          const total = block.querySelectorAll('.ms-check').length;
          const done = block.querySelectorAll('.ms-check:checked').length;
          const chip = block.querySelector('.ms-chip');
          if (chip) chip.textContent = done + '/' + total;
        }
      };
      repaint();
      const res = await api('/milestones/' + li.dataset.msId + '/complete', { method: 'POST', body: JSON.stringify({ completed: checked }) });
      if (res && res.error) { t.checked = !checked; repaint(); alert('Milestone update failed: ' + errMsg(res)); }
      return;
    }

    // Rock due-date (noon local avoids a UTC-midnight prior-day rollback).
    if (t.matches('[data-rock-due]')) {
      const card = t.closest('[data-rock-id]');
      if (!card) return;
      const val = t.value;
      if (!val) return;
      const dueDate = new Date(val + 'T12:00:00').toISOString();
      t.disabled = true;
      const res = await api('/rocks/' + card.dataset.rockId, { method: 'PUT', body: JSON.stringify({ dueDate }) });
      t.disabled = false;
      if (res?.error) { alert('Due-date save failed: ' + errMsg(res)); }
      return;
    }

    // Rock move-to-team (fade out -- it now belongs to a different team's Leadership Meeting).
    if (t.matches('[data-rock-move-team]')) {
      const newTeamId = t.value;
      if (!newTeamId) return;
      const card = t.closest('[data-rock-id]');
      if (!card) return;
      const rockId = card.dataset.rockId;
      t.disabled = true;
      const res = await api('/rocks/' + rockId, { method: 'PUT', body: JSON.stringify({ teamId: newTeamId }) });
      if (res?.error) { alert('Move failed: ' + errMsg(res)); t.disabled = false; t.value = ''; return; }
      card.style.transition = 'opacity 0.25s';
      card.style.opacity = '0';
      setTimeout(() => card.remove(), 250);
      return;
    }

    // Rock manual ordering (blank clears it; reloadKeep re-sorts the list).
    if (t.matches('[data-rock-position]')) {
      const card = t.closest('[data-rock-id]');
      if (!card) return;
      const rockId = card.dataset.rockId;
      const raw = t.value.trim();
      const position = raw === '' ? null : parseInt(raw, 10);
      if (position !== null && (isNaN(position) || position < 0)) {
        alert('Enter a positive number, or leave blank to sort by due date.');
        return;
      }
      t.disabled = true;
      const res = await api('/rocks/' + rockId, { method: 'PUT', body: JSON.stringify({ position }) });
      if (res?.error) { alert('Save failed: ' + errMsg(res)); t.disabled = false; return; }
      reloadKeep();
      return;
    }
  });

  // To-do toggle (delegated -- #todos gets live-swapped on a teammate's change).
  document.addEventListener('change', async (e) => {
    const box = e.target.closest('[data-todo-toggle]');
    if (!box) return;
    const todosRoot = document.getElementById('todos');
    if (!todosRoot || !todosRoot.contains(box)) return;
    const card = box.closest('[data-todo-id]');
    if (!card) return;
    await api('/todos/' + card.dataset.todoId, { method: 'PUT', body: JSON.stringify({ done: box.checked }) });
  });

  // ===== Editable KPI value (event-delegated on document) =====
  // Delegated so the Scorecard (#scorecard) can be live-swapped on a teammate's
  // change (refreshScorecardSection) without rebinding. Each handler resolves
  // the cell via the closest [data-kpi-id].
  document.addEventListener('click', async (e) => {
    const scoreRoot = document.getElementById('scorecard');
    if (!scoreRoot) return;
    const trigger = e.target.closest('[data-kpi-display],[data-kpi-cancel],[data-kpi-save]');
    if (!trigger || !scoreRoot.contains(trigger)) return;
    const cell = trigger.closest('[data-kpi-id]');
    if (!cell) return;
    const display = cell.querySelector('[data-kpi-display]');
    const editor = cell.querySelector('[data-kpi-editor]');
    const input = cell.querySelector('[data-kpi-input]');

    if (trigger.matches('[data-kpi-display]')) {
      if (display) display.classList.add('hidden');
      if (editor) editor.classList.remove('hidden');
      if (input) input.focus();
      return;
    }
    if (trigger.matches('[data-kpi-cancel]')) {
      if (editor) editor.classList.add('hidden');
      if (display) display.classList.remove('hidden');
      return;
    }
    // data-kpi-save
    const saveBtn = trigger;
    const raw = input.value.trim();
    const value = raw === '' ? null : parseFloat(raw);
    // Always write a new dated value: prior becomes "Previous", this one "Latest".
    const periodStart = new Date().toISOString();
    saveBtn.disabled = true; saveBtn.textContent = 'Saving...';
    const res = await api('/kpis/' + cell.dataset.kpiId + '/values', { method: 'POST', body: JSON.stringify({ periodStart, value }) });
    if (res?.error) {
      alert('Save failed: ' + errMsg(res));
      saveBtn.disabled = false; saveBtn.textContent = 'Save';
      return;
    }
    // An in-progress meeting renders the FROZEN /start scorecard snapshot, so
    // without a re-snapshot the value we just wrote never appears after reload
    // (David, 2026-06-10 live Leadership Meeting: "0 sales/close rate and it would not update").
    // Re-snapshot like the ↻ Refresh button, then reload. If the refresh fails
    // the value is still persisted, so reload either way.
    const statusEl = document.getElementById('meeting-status');
    if (statusEl && statusEl.textContent.trim() === 'in_progress') {
      await api('/meetings/' + meetingId + '/refresh-scorecard', { method: 'POST' });
    }
    reloadKeep();
  });

  // ===== Add quarterly priority (event-delegated) =====
  // #rock-add-form lives inside #rocks, which gets live-swapped, so id-bound
  // handlers would orphan. Delegate; read fields by id at click time.
  document.addEventListener('click', async (e) => {
    const trigger = e.target.closest('#rock-add-toggle, #new-rock-cancel, #new-rock-save');
    if (!trigger) return;
    if (trigger.id === 'rock-add-toggle') { const f = document.getElementById('rock-add-form'); if (f) f.classList.toggle('hidden'); return; }
    if (trigger.id === 'new-rock-cancel') { const f = document.getElementById('rock-add-form'); if (f) f.classList.add('hidden'); return; }
    // new-rock-save
    const btn = trigger;
    const title = document.getElementById('new-rock-title').value.trim();
    const ownerVal = document.getElementById('new-rock-owner').value;
    const owner = parseOwner(ownerVal);
    const quarter = document.getElementById('new-rock-quarter').value.trim();
    const dueDateRaw = document.getElementById('new-rock-due').value;
    const statusNote = document.getElementById('new-rock-status').value.trim();
    if (!title || !owner || !quarter || !dueDateRaw) {
      return alert('Title, owner, quarter, and due date are all required.');
    }
    if (!/^\d{4}-Q[1-4]$/.test(quarter)) {
      return alert('Quarter must look like "2026-Q2".');
    }
    const dueDate = new Date(dueDateRaw + 'T23:59:59Z').toISOString();
    btn.disabled = true; btn.textContent = 'Adding...';
    const res = await api('/rocks', { method: 'POST', body: JSON.stringify({
      title,
      ownerEntityType: owner.entityType,
      ownerExternalId: owner.externalId,
      ownerName: owner.name,
      quarter,
      dueDate,
      onTrack: true,
      statusNote: statusNote || undefined,
      teamId: (document.getElementById('new-rock-team') || {}).value || teamId || undefined,
      executionItemId: (document.getElementById('new-rock-exec') || {}).value || undefined,
    })});
    if (res?.error) { alert('Add failed: ' + errMsg(res)); btn.disabled = false; btn.textContent = 'Add Priority'; return; }
    reloadKeep();
  });

  // ===== Add issue (event-delegated) =====
  // #issue-add-form lives INSIDE #ids, which gets live-swapped on a teammate's
  // change (refreshIssuesSection), so id-bound handlers would orphan. Delegate
  // on document; reads fields by id at click time (always the fresh ones).
  document.addEventListener('click', async (e) => {
    const trigger = e.target.closest('#issue-add-toggle, #new-issue-cancel, #new-issue-save');
    if (!trigger) return;
    if (trigger.id === 'issue-add-toggle') {
      const f = document.getElementById('issue-add-form'); if (f) f.classList.toggle('hidden'); return;
    }
    if (trigger.id === 'new-issue-cancel') {
      const f = document.getElementById('issue-add-form'); if (f) f.classList.add('hidden'); return;
    }
    // new-issue-save
    const btn = trigger;
    const title = document.getElementById('new-issue-title').value.trim();
    const description = document.getElementById('new-issue-desc').value.trim();
    const priority = document.getElementById('new-issue-priority').value;
    const ownerVal = document.getElementById('new-issue-owner').value;
    const owner = parseOwner(ownerVal);
    if (!title) return alert('Issue title is required.');
    btn.disabled = true; btn.textContent = 'Adding...';
    const createBody = {
      title,
      description: description || ('Added during meeting on ' + new Date().toISOString().slice(0,10)),
      priority,
      category: 'other',
    };
    // Tag the new issue with this meeting's team so it shows up on the
    // right Leadership Meeting (and stays off others).
    if (teamId) createBody.teamId = teamId;
    if (owner) {
      createBody.ownerEntityType = owner.entityType;
      createBody.ownerExternalId = owner.externalId;
      createBody.ownerName = owner.name;
    }
    const createRes = await api('/tickets', { method: 'POST', body: JSON.stringify(createBody) });
    if (createRes?.error || !createRes?.ticket?.id) {
      alert('Add failed: ' + errMsg(createRes));
      btn.disabled = false; btn.textContent = 'Add Issue';
      return;
    }
    reloadKeep();
  });

  // Add new to-do (delegated -- #add-todo lives inside #todos).
  document.addEventListener('click', async (e) => {
    if (!e.target.closest('#add-todo')) return;
    const title = document.getElementById('new-todo-title').value.trim();
    // Multi-assignee: each selected person gets their own independent copy.
    const ownerSel = document.getElementById('new-todo-owner');
    const owners = Array.prototype.slice.call(ownerSel ? ownerSel.selectedOptions : [])
      .map(function (o) { return parseOwner(o.value); })
      .filter(Boolean)
      .map(function (o) { return { ownerEntityType: o.entityType, ownerExternalId: o.externalId, ownerName: o.name }; });
    if (!title || owners.length === 0) return alert('Title and at least one owner required');
    const priority = (document.getElementById('new-todo-priority') || {}).value || 'p3';
    const recurrenceRule = (document.getElementById('new-todo-recur') || {}).value || null;
    const description = (document.getElementById('new-todo-desc') || {}).value || '';
    // Custom due date wins; fall back to 7-day default if the user leaves it
    // blank. Default behavior preserved -- pre-2026-05-26 every Leadership Meeting todo was
    // stamped with this auto-default and there was no way to override it
    // from inside the Leadership Meeting view.
    const dueOverride = (document.getElementById('new-todo-due') || {}).value || '';
    let dueAt;
    if (dueOverride) {
      // <input type="date"> returns YYYY-MM-DD; anchor to end-of-day local
      // so a "due today" pick doesn't show overdue at 9 AM the same day.
      const [y, m, d] = dueOverride.split('-').map(Number);
      dueAt = new Date(y, (m || 1) - 1, d || 1, 23, 59, 0);
    } else {
      dueAt = new Date(); dueAt.setDate(dueAt.getDate() + 7);
    }
    const body = {
      kind: 'l10', teamId, priority,
      title, owners,
      meetingId, dueAt: dueAt.toISOString(),
    };
    if (description.trim()) body.description = description.trim();
    if (recurrenceRule) body.recurrenceRule = recurrenceRule;
    await api('/todos', { method: 'POST', body: JSON.stringify(body) });
    reloadKeep();
  });

  // ===== IDS issue actions (event-delegated on document) =====
  // Delegated so the Issues (#ids) section can be live-swapped on a teammate's
  // change (refreshIssuesSection) without rebinding -- the fresh cards' clicks
  // bubble to these document-level listeners. Every handler reads its state from
  // the closest [data-ticket-id] card in the DOM, never a baked closure.
  function hideIssueForms(card) {
    ['edit', 'solve', 'convert'].forEach(k => {
      const f = card.querySelector('[data-form="' + k + '"]');
      if (f) f.classList.add('hidden');
    });
  }
  document.addEventListener('click', async (e) => {
    const idsRoot = document.getElementById('ids');
    if (!idsRoot) return;
    const trigger = e.target.closest('[data-ids-set],[data-action]');
    if (!trigger || !idsRoot.contains(trigger)) return;
    const card = trigger.closest('[data-ticket-id]');
    if (!card) return;
    const ticketId = card.dataset.ticketId;

    // Identify / Discuss (repaint the IDS status pill in place, no reload)
    if (trigger.matches('[data-ids-set]')) {
      const idsStatus = trigger.dataset.idsSet;
      const res = await api('/tickets/' + ticketId, { method: 'PUT', body: JSON.stringify({ idsStatus }) });
      if (res && res.error) { alert('Update failed: ' + errMsg(res)); return; }
      const pill = card.querySelector('[data-ids-pill]');
      if (pill) {
        pill.textContent = idsStatus;
        const cls = idsStatus === 'identified' ? 'bg-blue-100 text-blue-800'
                  : idsStatus === 'discussed' ? 'bg-amber-100 text-amber-800'
                  : idsStatus === 'solved' ? 'bg-emerald-100 text-emerald-800'
                  : 'bg-gray-100 text-gray-700';
        pill.className = 'text-xs px-2 py-0.5 rounded ' + cls;
      }
      return;
    }

    const action = trigger.dataset.action;
    const editForm = card.querySelector('[data-form="edit"]');
    const solveForm = card.querySelector('[data-form="solve"]');
    const convertForm = card.querySelector('[data-form="convert"]');

    // Solve
    if (action === 'solve') { hideIssueForms(card); if (solveForm) solveForm.classList.remove('hidden'); return; }
    if (action === 'solve-cancel') { if (solveForm) solveForm.classList.add('hidden'); return; }
    if (action === 'solve-confirm') {
      const btn = trigger;
      const resolution = card.querySelector('[data-field="resolution"]').value.trim();
      if (!resolution) return alert('Resolution is required');
      const createFollowUp = card.querySelector('[data-field="create-followup"]').checked;
      const ownerVal = card.querySelector('[data-field="followup-owner"]').value;
      const owner = parseOwner(ownerVal);
      const titleVal = card.querySelector('[data-field="followup-title"]').value.trim();
      const body = { resolution, meetingId };
      if (createFollowUp) {
        if (!owner) return alert('Pick an owner for the follow-up to-do (or uncheck the box)');
        body.followUp = {
          title: titleVal || ('Follow up: ' + card.dataset.ticketTitle),
          ownerEntityType: owner.entityType,
          ownerExternalId: owner.externalId,
          ownerName: owner.name,
        };
      }
      btn.disabled = true; btn.textContent = 'Solving...';
      const res = await api('/tickets/' + ticketId + '/solve', { method: 'POST', body: JSON.stringify(body) });
      if (res?.error) { alert('Error: ' + errMsg(res)); btn.disabled = false; btn.textContent = 'Solve + Cascade'; return; }
      // Pull latest meeting state, update cascading textarea inline, then
      // collapse this card so the cascade builds up without a reload.
      const meetingNow = await api('/meetings/' + meetingId);
      if (meetingNow?.meeting) {
        const ta = document.getElementById('cascading-message');
        if (ta) ta.value = meetingNow.meeting.cascadingMessage || '';
        const status = document.getElementById('cascading-status');
        if (status) {
          status.textContent = 'Auto-appended just now';
          setTimeout(() => { status.textContent = ''; }, 3000);
        }
      }
      card.classList.add('opacity-50');
      card.style.transition = 'all 0.4s ease-out';
      card.style.maxHeight = card.offsetHeight + 'px';
      requestAnimationFrame(() => {
        card.style.maxHeight = '0px';
        card.style.padding = '0';
        card.style.margin = '0';
        card.style.border = 'none';
        card.style.overflow = 'hidden';
      });
      setTimeout(() => card.remove(), 400);
      return;
    }

    // Convert to to-do
    if (action === 'convert') { hideIssueForms(card); if (convertForm) convertForm.classList.remove('hidden'); return; }
    if (action === 'convert-cancel') { if (convertForm) convertForm.classList.add('hidden'); return; }
    if (action === 'convert-confirm') {
      const btn = trigger;
      const ownerVal = card.querySelector('[data-field="convert-owner"]').value;
      const owner = parseOwner(ownerVal);
      const title = card.querySelector('[data-field="convert-title"]').value.trim();
      if (!owner || !title) return alert('Title and owner required');
      const dueAt = new Date(); dueAt.setDate(dueAt.getDate() + 7);
      btn.disabled = true; btn.textContent = 'Creating...';
      await api('/todos', { method: 'POST', body: JSON.stringify({
        kind: 'l10', teamId,
        title, ownerExternalId: owner.externalId, ownerEntityType: owner.entityType, ownerName: owner.name,
        meetingId, dueAt: dueAt.toISOString(),
        description: 'Converted from issue: "' + card.dataset.ticketTitle + '"',
      })});
      const deleteAfter = card.querySelector('[data-field="delete-after-convert"]').checked;
      if (deleteAfter) {
        await api('/tickets/' + ticketId, { method: 'DELETE' });
      }
      reloadKeep();
      return;
    }

    // Edit
    if (action === 'edit') { hideIssueForms(card); if (editForm) editForm.classList.remove('hidden'); return; }
    if (action === 'edit-cancel') { if (editForm) editForm.classList.add('hidden'); return; }
    if (action === 'edit-save') {
      const btn = trigger;
      const title = editForm.querySelector('[data-field="title"]').value.trim();
      const description = editForm.querySelector('[data-field="description"]').value;
      const ownerVal = editForm.querySelector('[data-field="owner"]').value;
      const owner = parseOwner(ownerVal);
      if (!title) return alert('Title required');
      const body = { title, description };
      if (owner) {
        body.ownerEntityType = owner.entityType;
        body.ownerExternalId = owner.externalId;
        body.ownerName = owner.name;
      } else {
        body.ownerEntityType = null;
        body.ownerExternalId = null;
        body.ownerName = null;
      }
      btn.disabled = true; btn.textContent = 'Saving...';
      await api('/tickets/' + ticketId, { method: 'PUT', body: JSON.stringify(body) });
      reloadKeep();
      return;
    }

    // Delete (open + solved cards) -- removes the row instantly, no reload.
    if (action === 'delete') {
      const btn = trigger;
      if (!confirm('Delete this issue? This cannot be undone from the UI.')) return;
      btn.disabled = true; btn.textContent = '...';
      const res = await api('/tickets/' + ticketId, { method: 'DELETE' });
      if (res?.error) { alert('Delete failed: ' + errMsg(res)); btn.disabled = false; btn.textContent = 'Delete'; return; }
      card.style.transition = 'all 0.3s ease-out';
      card.style.maxHeight = card.offsetHeight + 'px';
      requestAnimationFrame(() => {
        card.style.maxHeight = '0px';
        card.style.padding = '0';
        card.style.margin = '0';
        card.style.border = 'none';
        card.style.opacity = '0';
        card.style.overflow = 'hidden';
      });
      setTimeout(() => card.remove(), 300);
      return;
    }

    // Reopen (solved-list cards) -- back to open IDS lifecycle.
    if (action === 'reopen') {
      await api('/tickets/' + ticketId, { method: 'PUT', body: JSON.stringify({ idsStatus: 'open', solvedInMeetingId: null }) });
      reloadKeep();
      return;
    }
  });

  // Move issue to a different team (select change, delegated).
  document.addEventListener('change', async (e) => {
    const idsRoot = document.getElementById('ids');
    if (!idsRoot) return;
    const sel = e.target.closest('[data-action="move-team"]');
    if (!sel || !idsRoot.contains(sel)) return;
    const card = sel.closest('[data-ticket-id]');
    if (!card) return;
    const ticketId = card.dataset.ticketId;
    const newTeamId = sel.value;
    if (!newTeamId) return;
    sel.disabled = true;
    const res = await api('/tickets/' + ticketId, { method: 'PUT', body: JSON.stringify({ teamId: newTeamId }) });
    if (res?.error) {
      alert('Move failed: ' + errMsg(res));
      sel.disabled = false;
      sel.value = '';
      return;
    }
    card.style.transition = 'opacity 0.25s';
    card.style.opacity = '0';
    setTimeout(() => card.remove(), 250);
  });

  // ===== Add headline (delegated -- #add-headline lives inside #headlines) =====
  document.addEventListener('click', async (e) => {
    const addBtn = e.target.closest('#add-headline');
    if (!addBtn) return;
    const kind = (document.getElementById('new-headline-kind') || {}).value || 'other';
    const body = (document.getElementById('new-headline-body') || {}).value.trim();
    if (!body) return alert('Headline text is required.');
    addBtn.disabled = true; addBtn.textContent = 'Adding...';
    const res = await api('/meetings/' + meetingId + '/headlines', {
      method: 'POST',
      body: JSON.stringify({ kind, body }),
    });
    if (res?.error || !res?.headline) {
      alert('Add failed: ' + errMsg(res));
      addBtn.disabled = false; addBtn.textContent = 'Add';
      return;
    }
    reloadKeep();
  });

  // ===== Shared flag-to-issue form =====
  // One hidden form, moved next to whatever item was flagged. Used by both
  // headline items (§4) and Scorecard KPI rows (§2).
  const flagForm = document.getElementById('flag-issue-form');
  const flagTitle = document.getElementById('flag-title');
  const flagTeam = document.getElementById('flag-team');
  const flagOwner = document.getElementById('flag-owner');
  const MEETING_TITLE = <%- jsonForScript(meeting.title || '') %>;
  let flagSource = null; // 'Headlines' | 'Scorecard'

  function openFlagForm(btn, source) {
    flagSource = source;
    flagTitle.value = btn.getAttribute('data-flag-title') || '';
    flagTeam.value = <%- jsonForScript(meeting.teamId || '') %>;
    const ownerKey = btn.getAttribute('data-owner') || '';
    // Owner option values are entityType:externalId:name -- match on the
    // entityType:externalId prefix that the KPI button carries.
    flagOwner.value = '';
    if (ownerKey) {
      Array.from(flagOwner.options).forEach(opt => {
        if (opt.value && opt.value.startsWith(ownerKey + ':')) flagOwner.value = opt.value;
      });
    }
    // Move the form directly after the flagged item's container.
    const anchor = btn.closest('[data-headline-id]') || btn.closest('tr');
    if (anchor && anchor.parentNode) {
      if (anchor.tagName === 'TR') {
        // Inside a table -- park the form after the whole table instead.
        const table = anchor.closest('table');
        if (table && table.parentNode) table.parentNode.insertBefore(flagForm, table.nextSibling);
      } else {
        anchor.parentNode.insertBefore(flagForm, anchor.nextSibling);
      }
    }
    flagForm.classList.remove('hidden');
    flagTitle.focus();
  }

  // Flag-to-issue buttons (delegated): KPI rows in #scorecard + headline items
  // in #headlines. Both live in swappable sections, so per-element binding would
  // orphan. openFlagForm + the form's own buttons reference the stable
  // #flag-issue-form (kept out of every section by rehomeFlagForm), so only the
  // triggers need delegating.
  document.addEventListener('click', (e) => {
    const kpiBtn = e.target.closest('[data-flag-kpi]');
    if (kpiBtn) { openFlagForm(kpiBtn, 'Scorecard'); return; }
    const hlBtn = e.target.closest('[data-flag-headline]');
    if (hlBtn) { openFlagForm(hlBtn, 'Headlines'); return; }
  });

  // ===== Mark headline addressed (delegated) =====
  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-headline-done]');
    if (!btn) return;
    const id = btn.getAttribute('data-headline-done');
    btn.disabled = true; btn.textContent = 'Marking...';
    const res = await api('/meetings/' + meetingId + '/headlines/' + id + '/read', { method: 'POST' });
    if (res?.error) {
      alert('Failed: ' + errMsg(res));
      btn.disabled = false; btn.textContent = '✓ Addressed';
      return;
    }
    reloadKeep();
  });
  // (data-flag-kpi handled by the delegated flag-button listener above.)

  document.getElementById('flag-cancel')?.addEventListener('click', () => {
    flagForm.classList.add('hidden');
  });

  document.getElementById('flag-create')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    const title = flagTitle.value.trim();
    if (title.length < 5) return alert('Issue title must be at least 5 characters.');
    const description = 'Flagged as an issue from the ' + (flagSource || 'meeting') +
      ' of meeting: ' + MEETING_TITLE;
    const body = {
      title,
      description,
      category: 'other',
      priority: 'medium',
    };
    const selectedTeam = flagTeam.value;
    if (selectedTeam) body.teamId = selectedTeam;
    const owner = parseOwner(flagOwner.value);
    if (owner) {
      body.ownerEntityType = owner.entityType;
      body.ownerExternalId = owner.externalId;
      body.ownerName = owner.name;
    }
    btn.disabled = true; btn.textContent = 'Creating...';
    const res = await api('/tickets', { method: 'POST', body: JSON.stringify(body) });
    if (res?.error || !res?.ticket?.id) {
      alert('Flag failed: ' + errMsg(res));
      btn.disabled = false; btn.textContent = 'Create Issue';
      return;
    }
    reloadKeep();
  });

  // ===== Meeting rating (Conclude) =====
  function _attKey(k) { return (window.CSS && CSS.escape) ? CSS.escape(k) : k; }
  function _absentFor(k) { return document.querySelector('[data-absent-input][data-attendee-key="' + _attKey(k) + '"]'); }
  // Build the ratings payload: a number 1-10, or the sentinel 'absent'.
  function collectRatings() {
    var r = {};
    document.querySelectorAll('[data-rating-input]').forEach(function (i) {
      var k = i.dataset.attendeeKey;
      var ab = _absentFor(k);
      if (ab && ab.checked) { r[k] = 'absent'; return; }
      var v = parseFloat(i.value);
      if (!isNaN(v) && v >= 1 && v <= 10) r[k] = v;
    });
    return r;
  }
  // Attendees still needing a score or an absent mark (gates finishing).
  function ratingsMissing() {
    var miss = [];
    document.querySelectorAll('[data-rating-input]').forEach(function (i) {
      var ab = _absentFor(i.dataset.attendeeKey);
      var hasScore = i.value !== '' && !isNaN(parseFloat(i.value));
      if (!hasScore && !(ab && ab.checked)) miss.push(i.dataset.attendeeKey);
    });
    return miss;
  }
  function renderRatingAvg() {
    const inputs = Array.from(document.querySelectorAll('[data-rating-input]'));
    const vals = inputs.map(i => parseFloat(i.value)).filter(v => !isNaN(v) && v >= 1 && v <= 10);
    const avgEl = document.getElementById('rating-avg');
    if (avgEl) avgEl.textContent = vals.length ? ('avg ' + (vals.reduce((a, b) => a + b, 0) / vals.length).toFixed(1)) : '';
  }
  document.querySelectorAll('[data-rating-input]').forEach(i => i.addEventListener('input', renderRatingAvg));
  // Absent toggle: disable + clear the score while absent.
  document.querySelectorAll('[data-absent-input]').forEach(function (ab) {
    function sync() { var inp = document.querySelector('[data-rating-input][data-attendee-key="' + _attKey(ab.dataset.attendeeKey) + '"]'); if (inp) { inp.disabled = ab.checked; if (ab.checked) inp.value = ''; } }
    ab.addEventListener('change', function () { sync(); renderRatingAvg(); });
    sync();
  });
  renderRatingAvg();
  const saveRatingsBtn = document.getElementById('save-ratings');
  if (saveRatingsBtn) saveRatingsBtn.addEventListener('click', async () => {
    const status = document.getElementById('ratings-status');
    saveRatingsBtn.disabled = true; saveRatingsBtn.textContent = 'Saving...';
    const res = await api('/meetings/' + meetingId, { method: 'PUT', body: JSON.stringify({ ratings: collectRatings() }) });
    saveRatingsBtn.disabled = false; saveRatingsBtn.textContent = 'Save ratings';
    if (res && res.error) { if (status) status.textContent = 'Error: ' + errMsg(res); return; }
    if (status) { status.textContent = 'Saved'; setTimeout(() => { status.textContent = ''; }, 2000); }
  });

  // ----- Live updates (SSE) + presence dots -----
  //
  // Connects to /api/v1/meetings/:id/events and listens for two events:
  //   meeting-updated -- something in this meeting's data changed; reload
  //   presence -- the list of viewers changed; update green dots
  // The same EventSource connection is the heartbeat for presence; when
  // the tab closes, the server sees the disconnect and drops us from the
  // viewer list.
  (function liveUpdates() {
    if (typeof EventSource === 'undefined') return; // very old browser
    const liveBadge = document.getElementById('meeting-live-indicator');
    const countEl = document.getElementById('meeting-watcher-count');
    let es = null;
    let reloadTimer = null;
    let reconnectMs = 1000;

    function scheduleReload(reason) {
      // Don't yank the page out from under the user mid-edit. If a
      // textarea or input is focused, defer the reload until they blur
      // or the next change comes through.
      const active = document.activeElement;
      if (active && (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT' || active.isContentEditable)) {
        // Mark dirty; reload on blur instead.
        document.body.dataset.pendingReload = '1';
        return;
      }
      if (reloadTimer) return;
      // Snapshot typed content so any non-focused-but-still-in-flight
      // edit (e.g. user typed in a textarea, then clicked away to a
      // non-input element while waiting) survives the reload.
      reloadTimer = setTimeout(() => { snapshotDrafts(); window.location.reload(); }, 600);
    }

    // Realtime (R2.3): a teammate changed an issue -> live-swap ONLY the #ids
    // section instead of a full reload. Same mid-edit guard as scheduleReload,
    // but scoped to #ids: if the user is typing INSIDE the Issues section, defer
    // to focusout (editing elsewhere is undisturbed by an #ids swap).
    let issueRefreshTimer = null;
    function scheduleIssueRefresh() {
      const active = document.activeElement;
      const idsEl = document.getElementById('ids');
      if (active && idsEl && idsEl.contains(active) &&
          (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT' || active.isContentEditable)) {
        document.body.dataset.pendingIssueRefresh = '1';
        return;
      }
      if (issueRefreshTimer) return;
      issueRefreshTimer = setTimeout(() => { issueRefreshTimer = null; refreshIssuesSection(); }, 600);
    }

    // Same for the Rocks section (kind === 'rock').
    let rockRefreshTimer = null;
    function scheduleRockRefresh() {
      const active = document.activeElement;
      const rocksEl = document.getElementById('rocks');
      if (active && rocksEl && rocksEl.contains(active) &&
          (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT' || active.isContentEditable)) {
        document.body.dataset.pendingRockRefresh = '1';
        return;
      }
      if (rockRefreshTimer) return;
      rockRefreshTimer = setTimeout(() => { rockRefreshTimer = null; refreshRocksSection(); }, 600);
    }

    // Same for the Scorecard section (kind === 'kpi').
    let scorecardRefreshTimer = null;
    function scheduleScorecardRefresh() {
      const active = document.activeElement;
      const scoreEl = document.getElementById('scorecard');
      if (active && scoreEl && scoreEl.contains(active) &&
          (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT' || active.isContentEditable)) {
        document.body.dataset.pendingScorecardRefresh = '1';
        return;
      }
      if (scorecardRefreshTimer) return;
      scorecardRefreshTimer = setTimeout(() => { scorecardRefreshTimer = null; refreshScorecardSection(); }, 600);
    }

    // Same for the Headlines section (kind === 'headline').
    let headlinesRefreshTimer = null;
    function scheduleHeadlinesRefresh() {
      const active = document.activeElement;
      const hlEl = document.getElementById('headlines');
      if (active && hlEl && hlEl.contains(active) &&
          (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT' || active.isContentEditable)) {
        document.body.dataset.pendingHeadlinesRefresh = '1';
        return;
      }
      if (headlinesRefreshTimer) return;
      headlinesRefreshTimer = setTimeout(() => { headlinesRefreshTimer = null; refreshHeadlinesSection(); }, 600);
    }

    // Same for the To-dos section (kind === 'todo').
    let todosRefreshTimer = null;
    function scheduleTodosRefresh() {
      const active = document.activeElement;
      const todosEl = document.getElementById('todos');
      if (active && todosEl && todosEl.contains(active) &&
          (active.tagName === 'TEXTAREA' || active.tagName === 'INPUT' || active.isContentEditable)) {
        document.body.dataset.pendingTodosRefresh = '1';
        return;
      }
      if (todosRefreshTimer) return;
      todosRefreshTimer = setTimeout(() => { todosRefreshTimer = null; refreshTodosSection(); }, 600);
    }

    function applyPresence(presence) {
      if (!Array.isArray(presence)) return;
      if (countEl) countEl.textContent = String(presence.length);
      if (liveBadge) liveBadge.classList.remove('hidden');
      // Build a set of externalIds currently watching.
      const watchingIds = new Set(presence.map(p => p && p.externalId).filter(Boolean));
      const watchingMemberIds = new Set(presence.map(p => p && p.subscriberId).filter(Boolean));
      document.querySelectorAll('[data-attendee]').forEach(el => {
        const key = el.dataset.attendee || '';
        const parts = key.split(':');
        const extId = parts[1] || '';
        const isHere = extId && watchingIds.has(extId);
        // Add or remove a small green dot indicator.
        let dot = el.querySelector('[data-presence-dot]');
        if (isHere) {
          if (!dot) {
            dot = document.createElement('span');
            dot.setAttribute('data-presence-dot', '1');
            dot.title = 'Watching now';
            dot.style.cssText = 'display:inline-block;width:0.5rem;height:0.5rem;border-radius:9999px;background:#10b981;margin-right:4px;vertical-align:middle;animation:pulse 2s ease-in-out infinite;';
            el.insertBefore(dot, el.firstChild);
          }
        } else if (dot) {
          dot.remove();
        }
      });
      // Also annotate segue cards with presence dots.
      document.querySelectorAll('[data-checkin-attendee]').forEach(el => {
        const key = el.dataset.checkinAttendee || '';
        const isHere = key && watchingIds.has(key);
        let dot = el.querySelector('[data-presence-dot-segue]');
        if (isHere) {
          if (!dot) {
            const badge = el.querySelector('.flex.items-center.gap-2.mb-2');
            if (badge) {
              dot = document.createElement('span');
              dot.setAttribute('data-presence-dot-segue', '1');
              dot.title = 'Viewing now';
              dot.style.cssText = 'display:inline-block;width:0.5rem;height:0.5rem;border-radius:9999px;background:#10b981;animation:pulse 2s ease-in-out infinite;';
              badge.appendChild(dot);
            }
          }
        } else if (dot) {
          dot.remove();
        }
      });
    }

    function connect() {
      try { es && es.close(); } catch (e) { /* ignore */ }
      es = new EventSource('/api/v1/meetings/' + meetingId + '/events');
      es.addEventListener('open', () => { reconnectMs = 1000; });
      es.addEventListener('presence', (e) => {
        try {
          const payload = JSON.parse(e.data);
          applyPresence(payload.presence || []);
        } catch (err) { /* ignore */ }
      });
      es.addEventListener('meeting-updated', (e) => {
        try {
          const payload = JSON.parse(e.data);
          const kind = payload.kind || 'updated';
          // Issues + Rocks + Scorecard + Headlines + To-dos update live (targeted swap); else reload.
          if (kind === 'issue') scheduleIssueRefresh();
          else if (kind === 'rock') scheduleRockRefresh();
          else if (kind === 'kpi') scheduleScorecardRefresh();
          else if (kind === 'headline') scheduleHeadlinesRefresh();
          else if (kind === 'todo') scheduleTodosRefresh();
          else if (kind === 'timer') applyRemoteTimer(payload.timer);
          else scheduleReload(kind);
        } catch (err) { scheduleReload('unknown'); }
      });
      es.addEventListener('error', () => {
        if (liveBadge) liveBadge.classList.add('hidden');
        try { es && es.close(); } catch (e) { /* ignore */ }
        // Exponential backoff capped at 30s.
        setTimeout(connect, reconnectMs);
        reconnectMs = Math.min(reconnectMs * 2, 30_000);
      });
    }

    // Reload when input loses focus if an update came in mid-edit. Snapshot
    // drafts before the reload so the typed content the user just blurred
    // away from is preserved across the round-trip.
    document.addEventListener('focusout', () => {
      setTimeout(() => {
        if (document.body.dataset.pendingIssueRefresh === '1') {
          delete document.body.dataset.pendingIssueRefresh;
          refreshIssuesSection();
        }
        if (document.body.dataset.pendingRockRefresh === '1') {
          delete document.body.dataset.pendingRockRefresh;
          refreshRocksSection();
        }
        if (document.body.dataset.pendingScorecardRefresh === '1') {
          delete document.body.dataset.pendingScorecardRefresh;
          refreshScorecardSection();
        }
        if (document.body.dataset.pendingHeadlinesRefresh === '1') {
          delete document.body.dataset.pendingHeadlinesRefresh;
          refreshHeadlinesSection();
        }
        if (document.body.dataset.pendingTodosRefresh === '1') {
          delete document.body.dataset.pendingTodosRefresh;
          refreshTodosSection();
        }
        if (document.body.dataset.pendingReload === '1') {
          delete document.body.dataset.pendingReload;
          snapshotDrafts();
          window.location.reload();
        }
      }, 200);
    });

    // Close cleanly on unload so presence drops fast.
    window.addEventListener('beforeunload', () => { try { es && es.close(); } catch (e) { /* ignore */ } });

    connect();
  })();
})();
</script>
<style>
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
</style>
<script>
// Labs meetings_broken_out rail actions: Add / Tools / Tangent / Notes / Finish,
// plus the per-step advance arrow. Talks to the core meeting only through DOM
// clicks (the hidden #timer-skip and the section chips), so it stays decoupled.
(function(){
  var rail = document.getElementById('agenda-nav');
  if (!rail || !rail.classList.contains('otp-rail')) return;
  var mtg = document.getElementById('l8-meeting');
  var mid = (mtg && mtg.dataset && mtg.dataset.meetingId) ? mtg.dataset.meetingId : '';

  function goToSection(id){ var chip = rail.querySelector('.agenda-chip[data-section="' + id + '"]'); if (chip) chip.click(); }
  function openIssueForm(){
    var t = document.getElementById('issue-add-toggle');
    if (t) { var f = document.getElementById('issue-add-form'); if (f && f.classList.contains('hidden')) t.click(); }
    var ti = document.getElementById('new-issue-title'); if (ti) ti.focus();
  }
  function focusFirstField(sel){ var el = document.querySelector(sel + ' input, ' + sel + ' textarea'); if (el) el.focus(); }

  function addThen(sec, fn){ goToSection(sec); setTimeout(fn, 150); }
  var isMac = /Mac|iP(hone|ad|od)/.test(navigator.platform || '');
  var MOD = isMac ? '⌘' : 'Ctrl ';

  // ---- command palette (Add / Tools), keyboard-driven like the best meeting apps ----
  function _addModal(kind){ if (window.openAddModal) window.openAddModal(kind); }
  var ADD_ITEMS = [
    { label: 'Quarterly Priority', desc: 'A Rock for the quarter',     run: function(){ _addModal('rocks'); } },
    { label: 'To-do',              desc: 'A 7-day commitment',         run: function(){ _addModal('todos'); } },
    { label: 'Issue',              desc: 'Identify, discuss, solve',   run: function(){ _addModal('ids'); } },
    { label: 'Headline',           desc: 'Customer or employee news',  run: function(){ _addModal('headlines'); } },
    { label: 'Measurable',         desc: 'A scorecard KPI',            run: function(){ _addModal('measurable'); } }
  ];
  // Tools open IN the meeting (iframe overlay) so you never bounce away.
  var TOOL_ITEMS = [
    { label: 'Dashboard',            desc: 'Your team dashboard',   run: function(){ openTool('/dashboard', 'Dashboard'); } },
    { label: 'Accountability Map', desc: 'Seats and owners',      run: function(){ openTool('/dashboard/team', 'Accountability Map'); } },
    { label: 'Scorecard',            desc: 'KPIs and trends',       run: function(){ openTool('/dashboard/kpis', 'Scorecard'); } },
    { label: 'CEO dashboard',        desc: 'The vision + numbers',  run: function(){ openTool('/dashboard/ceo', 'CEO dashboard'); } },
    { label: 'Meeting formats',      desc: 'Build a custom agenda', run: function(){ openTool('/dashboard/meeting-formats', 'Meeting formats'); } },
    { label: 'All meetings',         desc: 'Meetings home',         run: function(){ openTool('/l8', 'Meetings'); } }
  ];
  // ---- in-meeting tool overlay (iframe) ----
  var toolOv = null;
  function buildToolOverlay() {
    toolOv = document.createElement('div'); toolOv.className = 'tool-overlay'; toolOv.hidden = true;
    toolOv.innerHTML = '<div class="tool-ov-card"><div class="tool-ov-head"><span class="tool-ov-title"></span><div class="tool-ov-actions"><a class="tool-ov-newtab" target="_blank" rel="noopener" title="Open in a full tab">Open &#8599;</a><button type="button" class="tool-ov-close" aria-label="Close">&times;</button></div></div><iframe class="tool-ov-frame" title="Tool"></iframe></div>';
    document.body.appendChild(toolOv);
    toolOv.addEventListener('mousedown', function (e) { if (e.target === toolOv) closeTool(); });
    toolOv.querySelector('.tool-ov-close').addEventListener('click', closeTool);
  }
  function openTool(url, title) {
    if (!toolOv) buildToolOverlay();
    toolOv.querySelector('.tool-ov-title').textContent = title;
    toolOv.querySelector('.tool-ov-newtab').href = url;
    toolOv.querySelector('.tool-ov-frame').src = url;
    toolOv.hidden = false;
  }
  function closeTool() { if (toolOv) { toolOv.hidden = true; var fr = toolOv.querySelector('.tool-ov-frame'); if (fr) fr.src = 'about:blank'; } }
  var pal = null, palInput = null, palList = null, palHint = null, palItems = [], palView = [], palSel = 0;
  function buildPalette(){
    pal = document.createElement('div'); pal.className = 'rail-palette'; pal.hidden = true;
    pal.innerHTML = '<div class="rp-card"><div class="rp-search"><svg class="rp-mag" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg><input class="rp-input" type="text" placeholder="Search" autocomplete="off"><span class="rp-hint"></span></div><div class="rp-list"></div></div>';
    document.body.appendChild(pal);
    palInput = pal.querySelector('.rp-input'); palList = pal.querySelector('.rp-list'); palHint = pal.querySelector('.rp-hint');
    pal.addEventListener('mousedown', function(e){ if (e.target === pal) closePalette(); });
    palInput.addEventListener('input', renderPalette);
    palInput.addEventListener('keydown', palKey);
  }
  function openPalette(title, items, hint){
    if (!pal) buildPalette();
    palItems = items; palInput.value = ''; palSel = 0;
    palInput.placeholder = 'Search ' + title.toLowerCase() + '...'; palHint.textContent = hint || '';
    renderPalette(); pal.hidden = false; setTimeout(function(){ palInput.focus(); }, 10);
  }
  function closePalette(){ if (pal) pal.hidden = true; }
  function renderPalette(){
    var q = (palInput.value || '').toLowerCase().trim();
    palView = palItems.filter(function(it){ return !q || it.label.toLowerCase().indexOf(q) >= 0 || (it.desc && it.desc.toLowerCase().indexOf(q) >= 0); });
    if (palSel >= palView.length) palSel = Math.max(0, palView.length - 1);
    palList.innerHTML = '';
    palView.forEach(function(it, i){
      var row = document.createElement('button'); row.type = 'button'; row.className = 'rp-row' + (i === palSel ? ' rp-sel' : '');
      row.innerHTML = '<span class="rp-lbl"><b></b><small></small></span>' + (i < 9 ? '<kbd class="rp-num">' + (i + 1) + '</kbd>' : '');
      row.querySelector('b').textContent = it.label;
      if (it.desc) row.querySelector('small').textContent = it.desc;
      row.addEventListener('mouseenter', function(){ palSel = i; paintSel(); });
      row.addEventListener('click', function(){ runPalette(i); });
      palList.appendChild(row);
    });
    if (!palView.length) palList.innerHTML = '<div class="rp-empty">No matches</div>';
  }
  function paintSel(){ Array.prototype.forEach.call(palList.children, function(c, i){ if (c.classList) c.classList.toggle('rp-sel', i === palSel); }); }
  function runPalette(i){ var it = palView[i]; closePalette(); if (it && it.run) it.run(); }
  function palKey(e){
    if (e.key === 'Escape') { e.preventDefault(); closePalette(); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); palSel = Math.min(palView.length - 1, palSel + 1); paintSel(); return; }
    if (e.key === 'ArrowUp') { e.preventDefault(); palSel = Math.max(0, palSel - 1); paintSel(); return; }
    if (e.key === 'Enter') { e.preventDefault(); runPalette(palSel); return; }
    if (/^[1-9]$/.test(e.key) && palInput.value === '') { var n = parseInt(e.key, 10) - 1; if (n < palView.length) { e.preventDefault(); runPalette(n); } }
  }
  var addBtn = document.getElementById('rail-add');
  if (addBtn) addBtn.addEventListener('click', function(){ openPalette('Add', ADD_ITEMS, MOD + 'K'); });
  var toolsBtn = document.getElementById('rail-tools');
  if (toolsBtn) toolsBtn.addEventListener('click', function(){ openPalette('Tools', TOOL_ITEMS, MOD + '/'); });

  // per-step advance arrow (only the active step shows it)
  rail.querySelectorAll('.st-go').forEach(function(go){
    go.addEventListener('click', function(e){ e.preventDefault(); e.stopPropagation(); var n = document.getElementById('timer-skip'); if (n) n.click(); });
  });

  // Issues: tuck Edit / Delete / move-to behind a per-row ⋯, leaving the IDS
  // workflow (Identify / Discuss / Solve / To-Do) inline. Buttons keep their
  // delegated data-action handlers -- we only relocate them in the DOM.
  function buildIdsRowMenus(){
    document.querySelectorAll('#ids [data-ticket-id]').forEach(function(card){
      var actions = card.querySelector('.justify-between > div:last-child');
      if (!actions || actions.querySelector('.ids-row-menu')) return;
      var menu = document.createElement('details'); menu.className = 'ids-row-menu';
      menu.innerHTML = '<summary class="ids-row-menu-btn" title="More">⋯</summary><div class="ids-row-menu-pop"></div>';
      var pop = menu.querySelector('.ids-row-menu-pop');
      ['[data-action="edit"]', '[data-action="delete"]', '[data-action="move-team"]'].forEach(function(sel){
        var el = actions.querySelector(sel); if (el) pop.appendChild(el);
      });
      if (pop.children.length) actions.appendChild(menu);
    });
  }
  buildIdsRowMenus();
  // Live sync: when a teammate's change live-swaps a section (refreshIssuesSection
  // replaceWith()s #ids), re-tuck the per-row ⋯ so it persists for everyone in the
  // meeting. childList-only on the section parent -> fires on section swaps, not on
  // the per-second clock tick. Idempotent: cards with a menu are skipped.
  var _idsObs = (typeof MutationObserver !== 'undefined') ? new MutationObserver(function(){ buildIdsRowMenus(); }) : null;
  var _idsRoot = document.getElementById('l8-meeting');
  if (_idsObs && _idsRoot) _idsObs.observe(_idsRoot, { childList: true });
  document.addEventListener('click', function(e){
    document.querySelectorAll('.ids-row-menu[open]').forEach(function(d){ if (!d.contains(e.target)) d.removeAttribute('open'); });
  });

  // Finish meeting -> the real End-meeting control
  var fin = document.getElementById('rail-finish');
  if (fin) fin.addEventListener('click', function(){ var e = document.querySelector('.js-end-meeting'); if (e) e.click(); });

  // Notes: localStorage-backed scratch panel for this meeting
  var notesBtn = document.getElementById('rail-notes');
  var panel = null;
  function buildNotes(){
    panel = document.createElement('aside'); panel.className = 'rail-notes-panel'; panel.hidden = true;
    panel.innerHTML = '<div class="rnp-head"><span>Notes</span><button type="button" class="rnp-close" aria-label="Close">&times;</button></div><textarea class="rnp-ta" placeholder="Meeting notes (saved in this browser)..."></textarea>';
    document.body.appendChild(panel);
    var ta = panel.querySelector('.rnp-ta');
    try { ta.value = localStorage.getItem('otp-l8-notes-' + mid) || ''; } catch (e) {}
    ta.addEventListener('input', function(){ try { localStorage.setItem('otp-l8-notes-' + mid, ta.value); } catch (e) {} });
    panel.querySelector('.rnp-close').addEventListener('click', function(){ panel.hidden = true; notesBtn.classList.remove('rail-act-on'); });
  }
  if (notesBtn) notesBtn.addEventListener('click', function(){
    if (!panel) buildNotes();
    panel.hidden = !panel.hidden;
    notesBtn.classList.toggle('rail-act-on', !panel.hidden);
    if (!panel.hidden) panel.querySelector('.rnp-ta').focus();
  });

  // Tangent: a playful Ollie nudge to park off-script talk as an issue
  var tanBtn = document.getElementById('rail-tangent');
  var modal = null;
  function buildTangent(){
    modal = document.createElement('div'); modal.className = 'rail-tangent-modal'; modal.hidden = true;
    modal.innerHTML = '<div class="rtm-card"><button type="button" class="rtm-x" aria-label="Close">&times;</button>'
      + '<h3 class="rtm-h">Tangent alert!</h3>'
      + '<img class="rtm-ollie" src="/public/images/orgy/coach.png" alt="Ollie" />'
      + '<p class="rtm-p">Looks like we have wandered off-script. If it matters, <button type="button" class="rtm-link" id="rtm-park">park it as an issue</button> so it does not get lost.</p>'
      + '<button type="button" class="rtm-ok">&#128077; Got it</button></div>';
    document.body.appendChild(modal);
    function close(){ modal.hidden = true; }
    modal.addEventListener('click', function(e){ if (e.target === modal) close(); });
    modal.querySelector('.rtm-x').addEventListener('click', close);
    modal.querySelector('.rtm-ok').addEventListener('click', close);
    modal.querySelector('#rtm-park').addEventListener('click', function(){ close(); if (window.openAddModal) window.openAddModal('ids'); else { goToSection('ids'); setTimeout(openIssueForm, 140); } });
  }
  if (tanBtn) tanBtn.addEventListener('click', function(){ if (!modal) buildTangent(); modal.hidden = false; });

  // global shortcuts: Cmd/Ctrl+K opens Add, Cmd/Ctrl+/ opens Tools, Esc closes overlays
  document.addEventListener('keydown', function(e){
    var mod = isMac ? e.metaKey : e.ctrlKey;
    if (mod && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); openPalette('Add', ADD_ITEMS, MOD + 'K'); return; }
    if (mod && e.key === '/') { e.preventDefault(); openPalette('Tools', TOOL_ITEMS, MOD + '/'); return; }
    if (e.key === 'Escape') {
      if (pal && !pal.hidden) pal.hidden = true;
      if (modal && !modal.hidden) modal.hidden = true;
      if (panel && !panel.hidden) { panel.hidden = true; if (notesBtn) notesBtn.classList.remove('rail-act-on'); }
      if (toolOv && !toolOv.hidden) closeTool();
    }
  });
})();
</script>
<script>
// Ungated (all meetings): header overflow menu + the To-Dos quick-add toggle.
(function(){
  var det = document.querySelector('.hdr-overflow');
  if (det) {
    det.querySelectorAll('.hdr-mi').forEach(function(b){ b.addEventListener('click', function(){ setTimeout(function(){ det.removeAttribute('open'); }, 0); }); });
    document.addEventListener('click', function(e){ if (det.open && !det.contains(e.target)) det.removeAttribute('open'); });
  }
  // Delegated so it survives #todos being live-swapped on a teammate's change.
  document.addEventListener('click', function(e){
    if (!e.target.closest || !e.target.closest('#todo-add-toggle')) return;
    var tf = document.getElementById('todo-add-form'); if (!tf) return;
    tf.classList.toggle('hidden');
    if (!tf.classList.contains('hidden')) { var i = document.getElementById('new-todo-title'); if (i) i.focus(); }
  });
})();
</script>
<script>
// Add modals (Labs): the +Add palette opens a centered modal. For Rock / To-do /
// Issue / Headline we MOVE the section's existing add-form in (its delegated
// handler + reloadKeep-on-success are reused), and put it back on close. For
// Measurable we use the dedicated #kpi-add-form and POST /kpis directly.
(function () {
  var modal = document.getElementById('mtg-modal');
  if (!modal) return;
  var bodyEl = document.getElementById('mtg-modal-body');
  var titleEl = document.getElementById('mtg-modal-title');
  var kpiForm = document.getElementById('kpi-add-form');
  var moved = null, home = null;
  var MAP = {
    rocks:     { form: 'rock-add-form',     title: 'Add quarterly priority', focus: 'new-rock-title' },
    todos:     { form: 'todo-add-form',     title: 'Add to-do',              focus: 'new-todo-title' },
    ids:       { form: 'issue-add-form',    title: 'Add issue',              focus: 'new-issue-title' },
    headlines: { form: 'headline-add-form', title: 'Add headline',           focus: 'new-headline-body' }
  };
  function putBack() {
    if (moved && home) {
      moved.classList.add('hidden');
      if (home.next && home.next.parentNode === home.parent) home.parent.insertBefore(moved, home.next);
      else home.parent.appendChild(moved);
    }
    moved = null; home = null;
  }
  function closeModal() { putBack(); if (kpiForm) kpiForm.classList.add('hidden'); bodyEl.style.display = ''; modal.hidden = true; }
  function openAddModal(kind) {
    putBack();
    if (kind === 'measurable') {
      titleEl.textContent = 'Add measurable';
      bodyEl.style.display = 'none';
      if (kpiForm) kpiForm.classList.remove('hidden');
      modal.hidden = false;
      var kt = document.getElementById('new-kpi-title'); if (kt) setTimeout(function () { kt.focus(); }, 10);
      return;
    }
    var m = MAP[kind]; if (!m) return;
    var form = document.getElementById(m.form); if (!form) return;
    home = { parent: form.parentNode, next: form.nextSibling };
    moved = form;
    form.classList.remove('hidden');
    if (kpiForm) kpiForm.classList.add('hidden');
    bodyEl.style.display = '';
    bodyEl.appendChild(form);
    titleEl.textContent = m.title;
    modal.hidden = false;
    var f = document.getElementById(m.focus); if (f) setTimeout(function () { f.focus(); }, 10);
  }
  window.openAddModal = openAddModal;
  window.closeAddModal = closeModal;

  var closeBtn = document.getElementById('mtg-modal-close');
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('mousedown', function (e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

  // Measurable (KPI) create -> POST /api/v1/kpis, then reload to show it.
  var kpiSave = document.getElementById('kpi-add-save');
  if (kpiSave) kpiSave.addEventListener('click', async function () {
    var title = (document.getElementById('new-kpi-title').value || '').trim();
    var status = document.getElementById('kpi-add-status');
    if (!title) { if (status) status.textContent = 'Title is required.'; return; }
    var owner = (document.getElementById('new-kpi-owner').value || '').split(':');
    var goalRaw = document.getElementById('new-kpi-goal').value;
    var payload = {
      ownerEntityType: owner[0] || 'human',
      ownerExternalId: owner[1] || '',
      title: title,
      description: (document.getElementById('new-kpi-desc').value || '').trim() || undefined,
      goalOperator: document.getElementById('new-kpi-op').value,
      goalValue: goalRaw === '' ? null : Number(goalRaw),
      unit: (document.getElementById('new-kpi-unit').value || '').trim() || undefined,
      timeGrain: document.getElementById('new-kpi-grain').value,
      teamId: document.getElementById('new-kpi-team').value || undefined
    };
    if (!payload.ownerExternalId) { if (status) status.textContent = 'Pick an owner.'; return; }
    kpiSave.disabled = true; kpiSave.textContent = 'Adding...';
    try {
      var res = await fetch('/api/v1/kpis', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      if (!res.ok) {
        var j = await res.json().catch(function () { return null; });
        if (status) status.textContent = 'Error: ' + ((j && j.error && j.error.message) || ('HTTP ' + res.status));
        kpiSave.disabled = false; kpiSave.textContent = '+ Add measurable';
        return;
      }
      window.location.reload();
    } catch (e) {
      if (status) status.textContent = 'Network error.';
      kpiSave.disabled = false; kpiSave.textContent = '+ Add measurable';
    }
  });
})();
</script>
