<% /* XSS guard: embed a value in an inline <script> via jsonForScript() -- escapes < and > so a value containing </script> can't break out of the script context. This page server-renders all values into the form, so the helper is unused, but kept to match the checkup.ejs convention. */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%
  // ---- Settings: Preferences (User Settings) ----
  // Locals: preferences {theme,dateFormat,defaultTeamId,timezone}, teams [{id,name}].
  // Auto-injected: memberRole, currentPath, assetVersion, authState.
  // Everything below is typeof-guarded so the page never throws on a missing local.
  var _av     = (typeof assetVersion !== 'undefined') ? assetVersion : 'dev';
  var _auth   = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _prefs  = (typeof preferences !== 'undefined' && preferences && typeof preferences === 'object') ? preferences : {};
  var _teams  = (typeof teams !== 'undefined' && Array.isArray(teams)) ? teams : [];
  var _theme  = _prefs.theme || 'light';
  var _dfmt   = _prefs.dateFormat || 'MDY';
  var _team   = (_prefs.defaultTeamId !== undefined && _prefs.defaultTeamId !== null) ? String(_prefs.defaultTeamId) : '';
  var _tz     = _prefs.timezone || 'America/New_York';

  var _tzList = [
    { id: 'America/New_York',    label: 'Eastern (America/New_York)' },
    { id: 'America/Chicago',     label: 'Central (America/Chicago)' },
    { id: 'America/Denver',      label: 'Mountain (America/Denver)' },
    { id: 'America/Los_Angeles', label: 'Pacific (America/Los_Angeles)' },
    { id: 'UTC',                 label: 'UTC' },
    { id: 'Europe/London',       label: 'London (Europe/London)' }
  ];

  var _dateFmts = [
    { id: 'MDY', sample: '6/6/2026' },
    { id: 'DMY', sample: '06/06/2026' },
    { id: 'YMD', sample: '2026-06-06' }
  ];
%>

<!-- ================= HEADER ================= -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-10 pb-6">
    <div class="flex items-center gap-3 sm:gap-4">
      <img src="/public/images/orgy/mcp-api.png?v=<%= _av %>" alt="" class="w-12 sm:w-14 shrink-0" loading="eager" decoding="async">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-otp-300">User Settings</p>
        <h1 class="text-2xl font-extrabold text-white">Preferences</h1>
      </div>
    </div>
    <p class="text-gray-400 text-sm mt-2">Set your theme, date format, default team, and timezone.</p>
  </div>
</section>

<section class="bg-white py-10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <% if (_auth === 'unauthenticated') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Sign in to manage your preferences.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Sign In</a>
      </div>
    <% } else if (_auth === 'no_org') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Complete your organization profile first.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Set Up Profile</a>
      </div>
    <% } else { %>

      <!-- two-column: nav stacks above content on mobile, sidebar on >=md -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">

        <!-- left: settings nav -->
        <%- include('../partials/settings-nav') %>

        <!-- right: content -->
        <form id="preferences-form" class="flex-1 min-w-0 w-full space-y-6">

          <div class="flex items-center justify-between gap-4">
            <h2 class="font-bold text-gray-900 text-lg">Your Preferences</h2>
            <button type="submit"
                    class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
              Save Changes
            </button>
          </div>

          <!-- Card 1: Theme -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">Theme</h3>
            <p class="text-sm text-gray-500 mb-4">Choose how OTP looks.</p>
            <div class="space-y-2.5">
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="radio" name="theme" value="light" class="text-otp-500 focus:ring-otp-500" <%= _theme === 'light' ? 'checked' : '' %>>
                <span class="text-sm text-gray-800 font-medium">Light</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="radio" name="theme" value="dual" class="text-otp-500 focus:ring-otp-500" <%= _theme === 'dual' ? 'checked' : '' %>>
                <span class="text-sm text-gray-800 font-medium">Dual</span>
              </label>
            </div>
          </div>

          <!-- Card 2: Preferred Date Format -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">Preferred Date Format</h3>
            <p class="text-sm text-gray-500 mb-4">How dates display across OTP.</p>
            <div class="space-y-2.5">
              <% _dateFmts.forEach(function(f) { %>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="radio" name="dateFormat" value="<%= f.id %>" class="text-otp-500 focus:ring-otp-500" <%= _dfmt === f.id ? 'checked' : '' %>>
                  <span class="text-sm text-gray-800 font-medium"><%= f.id %></span>
                  <span class="text-sm text-gray-400 font-mono">(<%= f.sample %>)</span>
                </label>
              <% }); %>
            </div>
          </div>

          <!-- Card 3: Default Team -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">Default Team</h3>
            <p class="text-sm text-gray-500 mb-4">The team selected by default when you log in.</p>
            <select name="defaultTeamId" id="pref-team"
                    class="w-full sm:max-w-sm px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500">
              <option value="" <%= _team === '' ? 'selected' : '' %>>None</option>
              <% _teams.forEach(function(t) { %>
                <% var _tid = String(t.id); %>
                <option value="<%= _tid %>" <%= _team === _tid ? 'selected' : '' %>><%= t.name %></option>
              <% }); %>
            </select>
          </div>

          <!-- Card 4: Preferred Timezone -->
          <div class="bg-gray-50 border rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-1">Preferred Timezone</h3>
            <p class="text-sm text-gray-500 mb-4">Used for scheduling and timestamps.</p>
            <select name="timezone" id="pref-tz"
                    class="w-full sm:max-w-sm px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500">
              <% _tzList.forEach(function(z) { %>
                <option value="<%= z.id %>" <%= _tz === z.id ? 'selected' : '' %>><%= z.label %></option>
              <% }); %>
            </select>
          </div>

          <div class="flex items-center gap-4">
            <button type="submit"
                    class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
              Save Changes
            </button>
            <span id="pref-saved" class="hidden text-sm font-semibold text-green-600">Saved</span>
          </div>

        </form>
      </div>

    <% } %>
  </div>
</section>

<script>
  (function () {
    var form = document.getElementById('preferences-form');
    if (!form) return;
    var saved = document.getElementById('pref-saved');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var fd = new FormData(form);
      var payload = {
        theme: fd.get('theme') || 'light',
        dateFormat: fd.get('dateFormat') || 'MDY',
        defaultTeamId: fd.get('defaultTeamId') || null,
        timezone: fd.get('timezone') || 'America/New_York'
      };

      try {
        var res = await fetch('/settings/preferences', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!res.ok) {
          var data = {};
          try { data = await res.json(); } catch (_) {}
          alert((data && data.error && data.error.message) || (data && data.error) || 'Failed to save preferences');
          return;
        }

        // Optional: reflect theme live.
        try { document.documentElement.setAttribute('data-theme', payload.theme); } catch (_) {}

        if (saved) {
          saved.classList.remove('hidden');
          setTimeout(function () { saved.classList.add('hidden'); }, 2500);
        }
      } catch (err) {
        alert('Failed to save preferences');
      }
    });
  })();
</script>
