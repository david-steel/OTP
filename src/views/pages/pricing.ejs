</section>

<!-- ================= PAID CONTACT FORM ================= -->
<section class="bg-[var(--white)]">
  <div id="paid-form" class="max-w-[680px] mx-auto px-6 py-20 sm:py-24">
    <div class="text-center mb-8">
      <div class="eyebrow mb-3">Get in touch</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.15]"
          style="font-size:clamp(1.7rem,3.2vw,2.3rem); font-weight:700;">
        Talk to us about the paid plan.
      </h2>
      <p class="text-[15px] text-[var(--ink-soft)] leading-[1.6] mt-3">
        Tell us about your organization and what you need beyond the meeting. We will get back to you within 24 hours.
      </p>
    </div>

    <form id="contact-form" class="card p-6 sm:p-8 space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-[13px] font-medium text-[var(--ink)] mb-1.5">Name</label>
          <input type="text" name="name" required class="pr-field" placeholder="Your name">
        </div>
        <div>
          <label class="block text-[13px] font-medium text-[var(--ink)] mb-1.5">Work Email</label>
          <input type="email" name="email" required class="pr-field" placeholder="you@company.com">
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-[13px] font-medium text-[var(--ink)] mb-1.5">Company</label>
          <input type="text" name="company" required class="pr-field" placeholder="Company name">
        </div>
        <div>
          <label class="block text-[13px] font-medium text-[var(--ink)] mb-1.5">Team Size</label>
          <select name="size" class="pr-field">
            <option value="">Select...</option>
            <option value="1-10">1-10 people</option>
            <option value="11-50">11-50 people</option>
            <option value="51-200">51-200 people</option>
            <option value="201-1000">201-1,000 people</option>
            <option value="1000+">1,000+ people</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-[13px] font-medium text-[var(--ink)] mb-1.5">What are you looking to do?</label>
        <textarea name="message" rows="4" required class="pr-field resize-none" placeholder="Tell us about your AI setup and what you need beyond the meeting..."></textarea>
      </div>
      <button type="submit" id="submit-btn" class="btn-ink w-full px-6 py-3.5 text-[15px]">Send Inquiry</button>
      <div id="form-success" class="hidden text-center py-4">
        <div class="font-semibold text-[15px] mb-1" style="color:var(--green-deep);">Sent. We will be in touch within 24 hours.</div>
        <p class="text-[13px] text-[var(--ink-soft)]">Check your email for a confirmation.</p>
      </div>
      <div id="form-error" class="hidden text-center py-2 text-[13px]" style="color:var(--orange-deep);"></div>
    </form>
  </div>
</section>

