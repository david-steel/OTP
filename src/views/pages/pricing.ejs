<!-- ================= FAQ ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[760px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-4">Questions</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.15] mb-9"
