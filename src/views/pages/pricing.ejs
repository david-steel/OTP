<%# /pricing -- v7 layout (light, editorial). Free = the meeting product
    (chart + humans + agents + Radar). Private = $99/mo privacy tier (the
    meeting product with the org's OOS kept off the public network; Calendly
    CTA, no checkout). Paid = everything else (network, intelligence,
    private layer). Custom pricing, contact form.
    Dual-rendered via renderInShell: signed-in viewers get the app shell. %>
<style>
  .pr-check { width:20px; height:20px; flex:none; margin-top:1px; }
  .pr-faq { border:1px solid var(--line); border-radius:14px; background:var(--card); overflow:hidden; }
  .pr-faq summary {
    cursor:pointer; list-style:none; padding:18px 22px;
    font-weight:600; font-size:15px; color:var(--ink);
    display:flex; align-items:center; justify-content:space-between; gap:1rem;
  }
  .pr-faq summary::-webkit-details-marker { display:none; }
  .pr-faq summary .pr-chev { transition:transform .2s ease; flex:none; }
  .pr-faq[open] summary .pr-chev { transform:rotate(180deg); }
  .pr-faq-body { padding:0 22px 18px; font-size:14px; color:var(--ink-soft); line-height:1.7; }
  .pr-field {
    width:100%; padding:10px 12px; font-size:14px;
    border:1px solid var(--line); border-radius:10px;
    background:var(--white); color:var(--ink); outline:none;
    transition:border-color .15s ease;
  }
  .pr-field:focus { border-color:var(--blue); }
  .pr-tilt { animation:pr-tilt 6s ease-in-out infinite; transform-origin:60% 90%; }
  @keyframes pr-tilt { 0%,100%{transform:rotate(-7deg);} 50%{transform:rotate(8deg);} }
  @media (prefers-reduced-motion:reduce){ .pr-tilt{ animation:none; } }
</style>

<%# In-shell trim: inside the authed main layout (renderInShell), the app
    shell's fixed nav is already cleared by the layout's pt, so the v7
    nav-clearing pt-[124px]/pt-[148px] would double the gap. Inline style
    wins over both Tailwind classes. authUserId only exists on the authed
    path -- the v7 marketing render is unchanged. %>
<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[820px] mx-auto px-6 pt-[124px] pb-14 sm:pt-[148px] sm:pb-16 text-center"<%- (typeof authUserId !== 'undefined' && authUserId) ? ' style="padding-top:56px;"' : '' %>>
    <div class="eyebrow mb-5 flex items-center gap-2.5 justify-center">
      <span class="tick" style="background:var(--orgy);"></span>Pricing
    </div>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(2.1rem,4.4vw,3.4rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
      Free to run the meeting.<br>Paid for everything else.
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[38rem] mx-auto mt-5">
      Everything you need to run a leadership meeting with your humans and your AI agents is free, forever. The cross-organization network and the private intelligence layer are where OTP charges.
    </p>
  </div>
</section>

<!-- ================= PRICING CARDS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

