          <p class="font-mono text-[11px] text-[var(--ink-mute)] text-center mt-2.5">We will scope it to your organization.</p>
        </div>
      </div>

      <!-- ENTERPRISE -- self-serve seat plan. $250/mo base (25 seats), +$10/seat,
           optional +$199/mo support, BYOK, never trained on. -->
      <div class="card p-8 sm:p-9 flex flex-col relative border-t-[3px]"
           style="border-top-color:var(--ink);">
        <div class="eyebrow mb-3" style="color:var(--ink);">Self-serve at scale</div>
        <div class="flex items-baseline gap-2 mb-3">
          <span class="font-display text-[var(--ink)] text-[3rem] font-bold leading-none">$250</span>
          <span class="font-mono text-[13px] text-[var(--ink-mute)]">/ month base</span>
        </div>
        <p class="text-[14px] text-[var(--ink-soft)] leading-[1.65] mb-6">
          25 agent seats included at $10/seat/mo. Add seats as your team grows, bring your own AI key, and keep your data yours. Upgrade yourself, no sales call.
        </p>
        <div class="border-t border-[var(--line)] pt-6 flex-1">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] mb-4" style="color:var(--ink);">Everything in Free, plus:</p>
          <ul class="space-y-3">
            <% var enterpriseFeatures = [
              ['25 agent seats included', ' -- a $250/mo base, billed at $10 per seat per month'],
              ['Scale by the seat', ' -- every additional agent seat is just $10/mo'],
              ['Optional priority support', ' -- add it for $199/mo whenever you need it'],
              ['Bring your own AI key (BYOK)', ' -- run on your own model provider and key'],
