      <div class="flex flex-wrap gap-3 justify-center mt-7">
        <a href="/sign-up" class="btn-primary px-7 py-3.5 text-[15px]">Get Started</a>
        <a href="/meet-radar" class="btn-ghost px-7 py-3.5 text-[15px]">Meet Radar</a>
      </div>
    </div>
  </div>
</section>

<script>
document.getElementById('contact-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('submit-btn');
  var form = this;
  btn.disabled = true;
  btn.textContent = 'Sending...';
  document.getElementById('form-error').classList.add('hidden');

  var name = form.name.value.trim();
  var email = form.email.value.trim();
  var company = form.company.value.trim();
  var size = form.size.value;
  var message = form.message.value.trim();

  try {
    var res = await fetch('/api/v1/tickets', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        title: '[Paid plan inquiry] ' + company + ' - ' + name,
        description: 'Name: ' + name + '\nEmail: ' + email + '\nCompany: ' + company + '\nTeam Size: ' + (size || 'Not specified') + '\n\n' + message,
        category: 'other',
        priority: 'high',
        reporterEmail: email
      })
    });
    if (res.ok) {
      form.classList.add('hidden');
      document.getElementById('form-success').classList.remove('hidden');
    } else {
      throw new Error('Server error');
    }
  } catch (err) {
    document.getElementById('form-error').textContent = 'Something went wrong. Please try again in a moment.';
    document.getElementById('form-error').classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Send Inquiry';
  }
});
</script>
