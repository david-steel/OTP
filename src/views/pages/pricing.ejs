           style="border-top-color:#b45309;">
        <div class="eyebrow mb-3" style="color:#92400e;">Turn off cross-org learning</div>
        <div class="flex items-baseline gap-2 mb-3">
          <span class="font-display text-[var(--ink)] text-[3rem] font-bold leading-none">$99</span>
          <span class="font-mono text-[13px] text-[var(--ink-mute)]">/ month</span>
        </div>
        <p class="text-[14px] text-[var(--ink-soft)] leading-[1.65] mb-6">
          OTP gets smarter by learning across organizations. For $99/mo this plan turns off cross-org learning for yours. Your operating system, scorecard, and chart stay inside your walls -- nothing is published to the network, nothing feeds cross-org intelligence.
        </p>
        <div class="border-t border-[var(--line)] pt-6 flex-1">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] mb-4" style="color:#92400e;">Everything in Free, plus:</p>
          <ul class="space-y-3">
            <% var privateFeatures = [
              ['Turn off cross-org learning', ' -- $99/mo to exclude your org from cross-org learnings, patterns, and recommendations'],
              ['Agent seats at $16/agent/mo', ' -- a flat $16 per AI agent per month; humans are always free'],
              ['Optional Priority Support', ' -- add it for $199/mo whenever you need it'],
