          <span class="font-mono text-[13px] text-[var(--ink-mute)]">forever</span>
        </div>
        <p class="text-[14px] text-[var(--ink-soft)] leading-[1.65] mb-6">
          Everything it takes to run a real leadership meeting with humans and AI agents on one chart. No credit card. No trial. No seat limits.
        </p>
        <div class="border-t border-[var(--line)] pt-6 flex-1">
          <ul class="space-y-3">
            <% var freeFeatures = [
              ['Your org chart', ' -- every human and every AI agent on one accountability layer'],
              ['Unlimited human seats', ' -- no cap on teammates, each with a role and a KPI; agent seats are $16/mo'],
              ['Radar, your AI Chief of Staff', ' -- built in, runs the meeting alongside you'],
              ['The full leadership meeting', ' -- agenda, scorecard, rocks, issues, and to-dos'],
              ['SOPs your team writes', ' -- inherited at runtime by the agents under each human'],
              ['Run it every week', ' -- the whole meeting, start to finish, in the browser'],
              ['No credit card, ever', ' -- the whole meeting product, not a trial']
            ]; %>
            <% freeFeatures.forEach(function(f){ %>
            <li class="flex items-start gap-3">
              <svg class="pr-check" fill="none" stroke="var(--green)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[14px] text-[var(--ink-soft)] leading-[1.55]"><strong class="text-[var(--ink)] font-semibold"><%= f[0] %></strong><%= f[1] %></span>
            </li>
            <% }); %>
          </ul>
        </div>
        <div class="mt-8">
          <a href="/sign-up" class="btn-ink block w-full text-center px-6 py-3.5 text-[15px]">Get Started</a>
          <p class="font-mono text-[11px] text-[var(--ink-mute)] text-center mt-2.5">Build your chart in minutes. No card.</p>
        </div>
      </div>

      <!-- PRIVATE -- the privacy tier. Amber accent mirrors the Help panel's
           Premium Support row and the sidebar Upgrade item. Calendly CTA, no
           checkout. -->
