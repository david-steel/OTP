        ['Is my data used to train AI models?', 'No. Nothing you put in OTP is sent to third-party models for training. The paid private layer adds full data isolation, so nothing leaves your organization at all.'],
        ['What does OTP work with?', 'The meeting runs in any browser. The paid network layer connects to any MCP-compatible AI client, including Claude, Cursor, and Windsurf, and is model-agnostic.'],
        ['How do I get the paid plan?', 'Pricing is scoped to your organization. Tell us what you need in the form above and we will get back to you within 24 hours.']
      ]; %>
      <% faqs.forEach(function(q){ %>
      <details class="pr-faq">
        <summary>
          <%= q[0] %>
          <svg class="pr-chev" width="16" height="16" fill="none" stroke="var(--ink-mute)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
