            <% enterpriseFeatures.forEach(function(f){ %>
            <li class="flex items-start gap-3">
              <svg class="pr-check" fill="none" stroke="var(--ink)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <span class="text-[14px] text-[var(--ink-soft)] leading-[1.55]"><strong class="text-[var(--ink)] font-semibold"><%= f[0] %></strong><%= f[1] %></span>
