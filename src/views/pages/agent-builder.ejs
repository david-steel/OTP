  .ab-tag-input{position:relative;display:flex;flex-wrap:wrap;gap:6px;align-items:center;padding:8px 10px;border-radius:10px;background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.1);min-height:44px;transition:border-color .2s}
  .ab-tag-input:focus-within{border-color:rgba(0,149,255,.4)}
  .ab-pills{display:flex;flex-wrap:wrap;gap:5px}
  .ab-pill{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:6px;background:rgba(0,149,255,.15);color:#93c5fd;font-size:12px;font-weight:500;white-space:nowrap}
  .ab-pill button{background:none;border:none;color:#6b7280;cursor:pointer;font-size:14px;line-height:1;padding:0 0 0 2px}
  .ab-pill button:hover{color:#ef4444}
  .ab-tag-field{flex:1;min-width:120px;background:transparent;border:none;color:#fff;font-size:13px;outline:none}
  .ab-tag-field::placeholder{color:#6b7280}
  .ab-suggestions{position:absolute;top:100%;left:0;right:0;z-index:20;max-height:180px;overflow-y:auto;margin-top:4px;background:#1e293b;border:1px solid rgba(255,255,255,.1);border-radius:8px}
  .ab-suggestions div{padding:8px 12px;font-size:13px;color:#d1d5db;cursor:pointer}
  .ab-suggestions div:hover{background:rgba(0,149,255,.1);color:#fff}
  .ab-sug-hint{font-style:italic;color:#6b7280 !important;cursor:default !important}
  .ab-sug-hint:hover{background:transparent !important;color:#6b7280 !important}
  .ab-custom-label{font-size:10px;color:#6b7280;font-weight:400}

  .ab-fcard{padding:16px 8px;border-radius:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);text-align:center;cursor:pointer;transition:all .2s}
  .ab-fcard:hover{border-color:rgba(0,149,255,.3)}
  .ab-fcard.selected{background:rgba(0,149,255,.1);border-color:#0095ff}

  .ab-slider-row{display:flex;align-items:center;gap:10px}
  .ab-slider-row label{font-size:13px;color:#d1d5db;width:130px;flex-shrink:0}
  .ab-slider{flex:1;accent-color:#0095ff;cursor:pointer}
  .ab-slider-val{font-size:13px;color:#0095ff;font-weight:700;width:20px;text-align:right}

  .ab-radar-grid{fill:none;stroke:rgba(255,255,255,.08);stroke-width:1}
  .ab-radar-poly{fill:rgba(0,149,255,.15);stroke:#0095ff;stroke-width:2;transition:all .3s}
  .ab-radar-dot{fill:#0095ff}

  .ab-mbti-toggle{padding:10px;border-radius:8px;background:rgba(0,149,255,.1);border:1px solid rgba(0,149,255,.3);color:#93c5fd;font-size:13px;cursor:pointer;transition:all .2s;text-align:center}
  .ab-mbti-toggle.dim{background:rgba(255,255,255,.03);border-color:rgba(255,255,255,.1);color:#6b7280}

  .ab-trait-desc{font-size:11px;color:#6b7280;line-height:1.4;margin:4px 0 0 0;padding-left:140px;transition:opacity .2s}
  @media(max-width:639px){.ab-trait-desc{padding-left:0}}
  .ab-personality-panel{transition:all .3s}

  .ab-faq{border:1px solid #e5e7eb;border-radius:10px;overflow:hidden}
  .ab-faq-q{width:100%;text-align:left;padding:14px 16px;font-size:15px;font-weight:600;color:#111827;background:transparent;border:none;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
  .ab-faq-arrow{font-size:18px;color:#9ca3af;transition:transform .2s}
  .ab-faq-a{max-height:0;overflow:hidden;padding:0 16px;font-size:14px;color:#6b7280;line-height:1.6;transition:max-height .3s,padding .3s}
  .ab-faq.open .ab-faq-a{max-height:200px;padding:0 16px 14px}
  .ab-faq.open .ab-faq-arrow{transform:rotate(45deg)}

  .ab-rev-pill{display:inline-block;padding:2px 10px;border-radius:5px;background:#f3f4f6;color:#374151;font-size:12px;font-weight:500}
</style>

<script>
(function(){
  var SKILLS=['Email management','CRM updates','Lead follow-up','Data analysis','Report generation','Calendar management','Cold outreach','Social media management','Content writing','Customer support','Billing and invoicing','Project management','Meeting scheduling','Call center management','Ad campaign monitoring','Performance reporting','Client onboarding','Proposal creation','Pipeline management','Appointment booking','Follow-up sequences','Speed to lead','Review management','Reputation monitoring','SEO monitoring','Website monitoring','Inventory tracking','Order fulfillment','Staff scheduling','Payroll processing','Compliance monitoring','Contract management','Vendor management','Quality assurance','Training and onboarding','Documentation','Workflow automation','Data entry','Competitive analysis','Market research','Financial reporting','Budget tracking','Event planning','Newsletter management','Community management'];
  var TOOLS=['Gmail','Slack','Google Calendar','Google Sheets','Google Docs','Google Drive','Todoist','Asana','Trello','Monday.com','ClickUp','GHL/GoHighLevel','HubSpot','Salesforce','Pipedrive','Meta Ads','Google Ads','TikTok Ads','LinkedIn Ads','Shopify','WooCommerce','Stripe','QuickBooks','Xero','FreshBooks','Zapier','Make/Integromat','n8n','Calendly','Acuity','Fireflies','Otter.ai','Zoom','Microsoft Teams','Accelo','Jobber','ServiceTitan','Zenoti','Mindbody','ClubReady','GymSales','ABC Fitness','Proposify','PandaDoc','DocuSign','Notion','Confluence','Obsidian','Claude Code','Cursor','ChatGPT','GitHub','Jira','Linear','Intercom','Zendesk','Freshdesk','Mailchimp','SendGrid','Twilio','WhatsApp Business'];
  var selectedSkills=[];
  var selectedTools=[];
  var currentStep=1;
  var chosenFramework=null;
  var mbtiLetters=['I','S','T','J'];

  /* STEP NAV */
  window.goStep=function(n){
    if(n===currentStep) return;
    document.querySelectorAll('.step-panel').forEach(function(p){p.classList.add('hidden')});
    document.querySelector('.step-panel[data-step="'+n+'"]').classList.remove('hidden');
    document.querySelectorAll('.step-dot').forEach(function(d,i){
      var s=i+1;
      d.className='step-dot'+(s<n?' done':(s===n?' active':''));
    });
    document.querySelectorAll('.step-line').forEach(function(l,i){
      l.className='step-line'+(i+1<n?' active':'');
    });
    currentStep=n;
    if(n===4){populateReview();populateBoost()}
    var target=document.getElementById('builder-form');
    window.scrollTo({top:target.offsetTop-80,behavior:'smooth'});
  };

  /* TAG INPUT with free-text support */
  function initTagInput(fieldId,sugId,pillsId,allItems,selected,hintId){
    var field=document.getElementById(fieldId);
    var sugBox=document.getElementById(sugId);
    var pillsBox=document.getElementById(pillsId);
    var allLower=allItems.map(function(s){return s.toLowerCase()});

    function isPreset(val){return allLower.indexOf(val.toLowerCase())!==-1}

    function renderPills(){
      pillsBox.innerHTML='';
      selected.forEach(function(s,i){
        var pill=document.createElement('span');
        pill.className='ab-pill';
        var custom=!isPreset(s)?' <span class="ab-custom-label">(custom)</span>':'';
        pill.innerHTML=s+custom+'<button data-i="'+i+'">\u00d7</button>';
        pill.querySelector('button').addEventListener('click',function(){
          selected.splice(parseInt(this.dataset.i),1);
          renderPills();
          if(hintId) updateSkillHints();
        });
        pillsBox.appendChild(pill);
      });
    }

    function addTag(val){
      val=val.trim();
      if(!val||selected.indexOf(val)!==-1) return;
      var match=allItems.find(function(item){return item.toLowerCase()===val.toLowerCase()});
      selected.push(match||val);
      field.value='';
      sugBox.classList.add('hidden');
      renderPills();
      if(hintId) updateSkillHints();
    }

    function showSuggestions(q){
      var lower=q.toLowerCase();
      var matches=allItems.filter(function(item){
        return item.toLowerCase().indexOf(lower)!==-1 && selected.indexOf(item)===-1;
      });
      sugBox.innerHTML='';
      if(!q){sugBox.classList.add('hidden');return;}
      matches.slice(0,8).forEach(function(m){
        var div=document.createElement('div');
        div.textContent=m;
        div.addEventListener('click',function(){addTag(m)});
        sugBox.appendChild(div);
      });
      if(!matches.length&&q.length>1){
        var hint=document.createElement('div');
        hint.className='ab-sug-hint';
        hint.textContent='Press Enter to add "'+q+'" as custom';
        sugBox.appendChild(hint);
      }
      sugBox.classList.remove('hidden');
    }

    field.addEventListener('input',function(){showSuggestions(this.value)});
    field.addEventListener('focus',function(){if(this.value) showSuggestions(this.value)});
    field.addEventListener('keydown',function(e){
      if(e.key==='Enter'||e.key===','){
        e.preventDefault();
        var val=this.value.replace(/,$/,'');
        if(val) addTag(val);
      }
      if(e.key==='Backspace'&&!this.value&&selected.length){
        selected.pop();renderPills();
        if(hintId) updateSkillHints();
      }
    });
    document.addEventListener('click',function(e){
      if(!e.target.closest('#'+fieldId)&&!e.target.closest('#'+sugId)){
        sugBox.classList.add('hidden');
      }
    });
  }

  initTagInput('skills-field','skills-suggestions','skills-pills',SKILLS,selectedSkills,'skills-hints');
  initTagInput('tools-field','tools-suggestions','tools-pills',TOOLS,selectedTools,null);

  /* PERSONALITY FRAMEWORK */
  window.pickFramework=function(fw){
    chosenFramework=fw;
    document.querySelectorAll('.ab-fcard').forEach(function(c){
      c.classList.toggle('selected',c.dataset.fw===fw);
    });
    ['disc','big5','mbti','skip'].forEach(function(p){
      document.getElementById('panel-'+p).classList.toggle('hidden',p!==fw);
    });
    if(fw==='disc') drawRadar('radar-disc',4,getSliderValues('panel-disc'));
    if(fw==='big5') drawRadar('radar-big5',5,getSliderValues('panel-big5'));
  };

  function getSliderValues(panelId){
    var vals=[];
    document.querySelectorAll('#'+panelId+' .ab-slider').forEach(function(s){vals.push(parseInt(s.value))});
    return vals;
  }

  /* TRAIT DESCRIPTIONS */
  var traitDescs={
    D:[
      'Your agent defers to you on most decisions, asks permission before acting, avoids confrontation',
      'Your agent balances independence with deference, flags issues but waits for direction on big calls',
      'Your agent takes charge, makes decisions autonomously, flags problems directly and forcefully'
    ],
    I:[
      'Your agent communicates with facts and data only, minimal warmth, straight to the point',
      'Your agent is professional and clear, occasionally adds context or encouragement',
      'Your agent is warm, motivating, uses encouragement and positive framing, builds rapport in communications'
    ],
    S:[
      'Your agent moves fast, embraces change, may skip process steps to get results quickly',
      'Your agent balances speed with process, follows established patterns but adapts when needed',
      'Your agent is methodical, consistent, follows processes strictly, resists sudden changes'
    ],
    C:[
      'Your agent is flexible with rules, improvises, finds creative workarounds',
      'Your agent follows guidelines but applies judgment, bends rules when the situation warrants',
      'Your agent follows every rule precisely, documents everything, flags any deviation from protocol'
    ],
    O:[
      'Your agent sticks to proven approaches, resists experimenting, prefers established solutions',
      'Your agent is open to new ideas when evidence supports them, balances innovation with pragmatism',
      'Your agent actively seeks creative solutions, proposes unconventional approaches, challenges assumptions'
    ],
    C2:[
      'Your agent prioritizes speed over precision, may skip documentation, focuses on outcomes',
      'Your agent balances thoroughness with efficiency, documents important decisions',
      'Your agent is extremely organized, tracks every detail, never skips a step, comprehensive documentation'
    ],
    E:[
      'Your agent works quietly in the background, reports only when asked, minimal proactive communication',
      'Your agent communicates proactively when something matters, stays quiet otherwise',
      'Your agent is highly communicative, surfaces insights proactively, provides running commentary on its work'
    ],
    A:[
      'Your agent pushes back on requests it disagrees with, challenges your assumptions, plays devil\'s advocate',
      'Your agent voices concerns when stakes are high but generally aligns with direction',
      'Your agent is supportive and accommodating, avoids conflict, focuses on alignment and harmony'
    ],
    ES:[
      'Your agent escalates quickly when things go wrong, treats small issues as urgent, errs on the side of alarm',
      'Your agent maintains composure on routine issues, escalates proportionally to severity',
      'Your agent stays calm under pressure, absorbs ambiguity without escalating, only flags truly critical issues'
    ]
  };

  function updateTraitDesc(trait,val){
    var el=document.querySelector('.ab-trait-desc[data-desc="'+trait+'"]');
    if(!el) return;
    var v=parseInt(val);
    var idx=v<=3?0:(v<=6?1:2);
    el.textContent=traitDescs[trait][idx];
  }

  document.querySelectorAll('.ab-slider').forEach(function(slider){
    slider.addEventListener('input',function(){
      this.closest('.ab-slider-row').querySelector('.ab-slider-val').textContent=this.value;
      var panel=this.closest('.ab-personality-panel');
      if(!panel) return;
      if(panel.id==='panel-disc') drawRadar('radar-disc',4,getSliderValues(panel.id));
      if(panel.id==='panel-big5') drawRadar('radar-big5',5,getSliderValues(panel.id));
      var trait=this.dataset.trait;
      if(trait) updateTraitDesc(trait,this.value);
    });
  });

  /* RADAR CHART */
  function drawRadar(svgId,n,values){
    var svg=document.getElementById(svgId);
    if(!svg) return;
    var cx=100,cy=100,maxR=80;
    var html='';
    for(var ring=2;ring<=10;ring+=2){
      var pts=[];
      for(var i=0;i<n;i++){
        var angle=(Math.PI*2*i/n)-Math.PI/2;
        var r=maxR*ring/10;
        pts.push((cx+r*Math.cos(angle)).toFixed(1)+','+(cy+r*Math.sin(angle)).toFixed(1));
      }
      html+='<polygon points="'+pts.join(' ')+'" class="ab-radar-grid"/>';
    }
    for(var i=0;i<n;i++){
      var angle=(Math.PI*2*i/n)-Math.PI/2;
      var x2=cx+maxR*Math.cos(angle);
      var y2=cy+maxR*Math.sin(angle);
      html+='<line x1="'+cx+'" y1="'+cy+'" x2="'+x2.toFixed(1)+'" y2="'+y2.toFixed(1)+'" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>';
    }
    var dataPts=[];
    for(var i=0;i<n;i++){
      var angle=(Math.PI*2*i/n)-Math.PI/2;
      var r=maxR*(values[i]||5)/10;
      dataPts.push((cx+r*Math.cos(angle)).toFixed(1)+','+(cy+r*Math.sin(angle)).toFixed(1));
    }
    html+='<polygon points="'+dataPts.join(' ')+'" class="ab-radar-poly"/>';
    for(var i=0;i<n;i++){
      var angle=(Math.PI*2*i/n)-Math.PI/2;
      var r=maxR*(values[i]||5)/10;
      html+='<circle cx="'+(cx+r*Math.cos(angle)).toFixed(1)+'" cy="'+(cy+r*Math.sin(angle)).toFixed(1)+'" r="3" class="ab-radar-dot"/>';
    }
    svg.innerHTML=html;
  }

  /* MBTI */
  window.toggleMBTI=function(idx,letter){
    mbtiLetters[idx]=letter;
    var btns=document.querySelectorAll('#mbti-grid .ab-mbti-toggle');
    var row=idx*2;
    btns[row].classList.toggle('dim',btns[row].dataset.val!==letter);
    btns[row+1].classList.toggle('dim',btns[row+1].dataset.val!==letter);
    document.getElementById('mbti-result').textContent=mbtiLetters.join('');
  };

  /* REVIEW */
  function populateReview(){
    document.getElementById('rev-industry').textContent=document.getElementById('f-industry').value||'--';
    document.getElementById('rev-title').textContent=document.getElementById('f-title').value||'--';
    document.getElementById('rev-desc').textContent=document.getElementById('f-desc').value||'--';

    var skillsEl=document.getElementById('rev-skills');
    skillsEl.innerHTML=selectedSkills.length?selectedSkills.map(function(s){return'<span class="ab-rev-pill">'+s+'</span>'}).join(''):'<span class="text-gray-400 text-sm">None selected</span>';

    var toolsEl=document.getElementById('rev-tools');
    toolsEl.innerHTML=selectedTools.length?selectedTools.map(function(t){return'<span class="ab-rev-pill">'+t+'</span>'}).join(''):'<span class="text-gray-400 text-sm">None selected</span>';

    var label=document.getElementById('rev-personality-label');
    var revRadar=document.getElementById('rev-radar');
    revRadar.classList.add('hidden');

    if(chosenFramework==='disc'){
      label.textContent='DISC';
      revRadar.classList.remove('hidden');
      drawRadar('rev-radar',4,getSliderValues('panel-disc'));
    }else if(chosenFramework==='big5'){
      label.textContent='Big Five';
      revRadar.classList.remove('hidden');
      drawRadar('rev-radar',5,getSliderValues('panel-big5'));
    }else if(chosenFramework==='mbti'){
      label.textContent=mbtiLetters.join('');
    }else if(chosenFramework==='skip'){
      label.textContent='Balanced default';
    }else{
      label.textContent='Not set';
    }
  }

  /* BUILD */
  window.buildAgent=function(){
    document.getElementById('build-btn').style.display='none';
    document.getElementById('build-loading').classList.remove('hidden');

    var traits={};
    if(chosenFramework==='disc'){
      var vals=getSliderValues('panel-disc');
      traits={D:vals[0],I:vals[1],S:vals[2],C:vals[3]};
    }else if(chosenFramework==='big5'){
      var vals=getSliderValues('panel-big5');
      traits={O:vals[0],C2:vals[1],E:vals[2],A:vals[3],ES:vals[4]};
    }else if(chosenFramework==='mbti'){
      traits={type:mbtiLetters.join('')};
    }

    var payload={
      industry:document.getElementById('f-industry').value||'General',
      jobTitle:document.getElementById('f-title').value||'AI Agent',
      jobDescription:document.getElementById('f-desc').value||'',
      skills:selectedSkills,
      tools:selectedTools,
      personalityFramework:chosenFramework||'skip',
      personalityTraits:traits,
      additionalContext:document.getElementById('f-extra').value||''
    };

    fetch('/api/v1/agent-builder/generate',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(payload)
    })
    .then(function(res){return res.json()})
    .then(function(data){
      document.getElementById('build-loading').classList.add('hidden');
      document.getElementById('build-btn').style.display='';
      if(data.success){
        showResultModal(data.agentFile,data.stats);
      }else{
        alert('Generation failed. Please try again.');
      }
    })
    .catch(function(){
      document.getElementById('build-loading').classList.add('hidden');
      document.getElementById('build-btn').style.display='';
      alert('Network error. Please try again.');
    });
  };

  /* RESULT MODAL */
  function showResultModal(md,stats){
    var existing=document.getElementById('agent-result-modal');
    if(existing) existing.remove();

    var overlay=document.createElement('div');
    overlay.id='agent-result-modal';
    overlay.style.cssText='position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(4px)';

    var card=document.createElement('div');
    card.style.cssText='background:#1e293b;border:1px solid rgba(255,255,255,.15);border-radius:16px;max-width:720px;width:100%;max-height:90vh;display:flex;flex-direction:column;overflow:hidden';

    var header=document.createElement('div');
    header.style.cssText='padding:20px 24px;border-bottom:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:space-between;flex-shrink:0';
    header.innerHTML='<div><div style="font-size:18px;font-weight:700;color:#fff">Your Agent File</div><div style="font-size:13px;color:#9ca3af;margin-top:2px">'+stats.practiceCount+' coordination patterns  |  '+stats.failureModeCount+' failure modes  |  '+stats.boundaryRuleCount+' boundary rules</div></div>';

    var btnRow=document.createElement('div');
    btnRow.style.cssText='display:flex;gap:8px';

    var copyBtn=document.createElement('button');
    copyBtn.textContent='Copy';
    copyBtn.style.cssText='padding:6px 14px;border-radius:8px;background:rgba(0,149,255,.15);color:#93c5fd;font-size:13px;font-weight:600;border:1px solid rgba(0,149,255,.3);cursor:pointer';
    copyBtn.addEventListener('click',function(){
      navigator.clipboard.writeText(md).then(function(){copyBtn.textContent='Copied!';setTimeout(function(){copyBtn.textContent='Copy'},2000)});
    });

    var dlBtn=document.createElement('button');
    dlBtn.textContent='Download .md';
    dlBtn.style.cssText='padding:6px 14px;border-radius:8px;background:rgba(0,149,255,.15);color:#93c5fd;font-size:13px;font-weight:600;border:1px solid rgba(0,149,255,.3);cursor:pointer';
    dlBtn.addEventListener('click',function(){
      var blob=new Blob([md],{type:'text/markdown'});
      var url=URL.createObjectURL(blob);
      var a=document.createElement('a');
      a.href=url;
      a.download=(document.getElementById('f-title').value||'agent').toLowerCase().replace(/\s+/g,'-')+'.md';
      a.click();
      URL.revokeObjectURL(url);
    });

    var closeBtn=document.createElement('button');
    closeBtn.textContent='Close';
    closeBtn.style.cssText='padding:6px 14px;border-radius:8px;background:rgba(255,255,255,.05);color:#9ca3af;font-size:13px;font-weight:600;border:1px solid rgba(255,255,255,.1);cursor:pointer';
    closeBtn.addEventListener('click',function(){overlay.remove()});

    btnRow.appendChild(copyBtn);
    btnRow.appendChild(dlBtn);
    btnRow.appendChild(closeBtn);
    header.appendChild(btnRow);

    var body=document.createElement('div');
    body.style.cssText='padding:20px 24px;overflow-y:auto;flex:1';

    var pre=document.createElement('pre');
    pre.style.cssText='white-space:pre-wrap;word-wrap:break-word;font-size:13px;line-height:1.7;color:#e2e8f0;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;margin:0';
    pre.textContent=md;
    body.appendChild(pre);

    card.appendChild(header);
    card.appendChild(body);
    overlay.appendChild(card);
    document.body.appendChild(overlay);

    overlay.addEventListener('click',function(e){if(e.target===overlay) overlay.remove()});
  }

  /* INDUSTRY INTELLIGENCE */
  var industryIntel={
    'Agency':{count:42,slug:'agency',label:'agency'},
    'Fitness':{count:28,slug:'fitness',label:'fitness'},
    'Healthcare':{count:35,slug:'healthcare',label:'healthcare'},
    'SaaS':{count:51,slug:'saas',label:'SaaS'},
    'Professional Services':{count:31,slug:'professional-services',label:'professional services'},
    'E-Commerce':{count:39,slug:'ecommerce',label:'e-commerce'},
    'Education':{count:22,slug:'education',label:'education'},
    'Real Estate':{count:26,slug:'real-estate',label:'real estate'},
    'Legal':{count:18,slug:'legal',label:'legal'},
    'Other':{count:15,slug:'general',label:'general business'}
  };
  var indSelect=document.getElementById('f-industry');
  var indCard=document.getElementById('industry-intel');
  var indText=document.getElementById('industry-intel-text');
  indSelect.addEventListener('change',function(){
    var info=industryIntel[this.value];
    if(info){
      indText.innerHTML='OTP has <strong class="text-otp-300">'+info.count+'</strong> coordination practices for <strong class="text-otp-300">'+info.label+'</strong>. Your agent will inherit failure patterns, boundary rules, and operational heuristics from real '+info.label+' teams. <a href="/practices/'+info.slug+'" class="text-otp-400 underline hover:text-otp-300">View practices</a>';
      indCard.classList.remove('hidden');
    }else{indCard.classList.add('hidden')}
  });

  /* SKILL HINTS */
  var skillPairs={
    'Email management':['CRM updates','Follow-up sequences'],
    'CRM updates':['Lead follow-up','Pipeline management'],
    'Lead follow-up':['Speed to lead','Appointment booking'],
    'Data analysis':['Report generation','Performance reporting'],
    'Cold outreach':['Follow-up sequences','Pipeline management'],
    'Calendar management':['Meeting scheduling','Appointment booking'],
    'Call center management':['Speed to lead','Performance reporting'],
    'Ad campaign monitoring':['Performance reporting','Budget tracking'],
    'Project management':['Documentation','Quality assurance'],
    'Pipeline management':['CRM updates','Proposal creation'],
    'Client onboarding':['Documentation','Training and onboarding'],
    'Customer support':['CRM updates','Documentation']
  };
  var skillUsageCounts={
    'Email management':64,'CRM updates':58,'Lead follow-up':47,'Data analysis':53,
    'Report generation':41,'Cold outreach':39,'Pipeline management':36,'Calendar management':34,
    'Customer support':45,'Project management':42,'Call center management':22,'Performance reporting':38
  };

  function updateSkillHints(){
    var box=document.getElementById('skills-hints');
    var txt=document.getElementById('skills-hints-text');
    if(!selectedSkills.length){box.classList.add('hidden');return}
    var hints=[];
    selectedSkills.forEach(function(s){
      if(skillPairs[s]){
        var comp=skillPairs[s].filter(function(c){return selectedSkills.indexOf(c)===-1});
        if(comp.length) hints.push('Agents with <strong class="text-otp-300">'+s+'</strong> perform 40% better when paired with <strong class="text-otp-300">'+comp[0]+'</strong>.');
      }
      if(skillUsageCounts[s]) hints.push('<strong class="text-otp-300">'+skillUsageCounts[s]+'</strong> organizations on OTP use agents with '+s+'.');
    });
    if(hints.length){
      txt.innerHTML=hints.slice(0,2).join(' ');
      box.classList.remove('hidden');
    }else{box.classList.add('hidden')}
  }

  /* OTP BOOST on review step */
  function populateBoost(){
    var ind=document.getElementById('f-industry').value;
    var info=industryIntel[ind]||{count:15,label:'your industry'};
    var base=info.count;
    document.getElementById('boost-patterns').textContent=base+' coordination patterns from '+info.label+' teams';
    document.getElementById('boost-failures').textContent=Math.round(base*0.6)+' known failure modes your agent will avoid';
    document.getElementById('boost-boundaries').textContent=Math.round(base*0.4)+' boundary rules from real production deployments';
  }

  /* FAQ */
  window.toggleFaq=function(btn){
    btn.parentNode.classList.toggle('open');
  };

  /* Pre-fill from homepage redirect */
  var params = new URLSearchParams(window.location.search);
  if (params.get('industry')) {
    var industrySelect = document.getElementById('f-industry');
    if (industrySelect) {
      industrySelect.value = params.get('industry');
      industrySelect.dispatchEvent(new Event('change'));
    }
  }
  if (params.get('title')) {
    var titleInput = document.getElementById('f-title');
    if (titleInput) titleInput.value = decodeURIComponent(params.get('title'));
  }
})();
</script>
