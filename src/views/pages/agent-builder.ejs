  .step-line{width:40px;height:2px;background:rgba(255,255,255,.1);transition:background .3s}
  .step-line.active{background:#0095ff}

  .ab-input{width:100%;padding:10px 14px;border-radius:10px;background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.1);color:#fff;font-size:14px;outline:none;transition:border-color .2s,box-shadow .2s}
