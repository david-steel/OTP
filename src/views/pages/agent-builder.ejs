<!-- HERO -->
<section class="relative overflow-hidden bg-otp-950 flex items-center py-24 sm:py-32">
  <div class="absolute top-[-300px] left-[-200px] w-[800px] h-[800px] bg-otp-500/20 rounded-full blur-[180px] pointer-events-none"></div>
  <div class="absolute bottom-[-200px] right-[-250px] w-[700px] h-[700px] bg-purple-500/15 rounded-full blur-[160px] pointer-events-none"></div>

  <div class="relative w-full max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-otp-300 mb-6">
      <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
      <span>Informed by <%= typeof publisherCount !== 'undefined' ? publisherCount : '0' %> organizations</span>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] mb-6 tracking-tight">
      Hire Your Next <span class="gradient-text">AI Agent</span>
    </h1>
    <p class="text-lg sm:text-xl text-gray-400 leading-relaxed max-w-xl mx-auto mb-10">
      Describe the role. Set the personality. OTP builds it using coordination patterns from teams already running agents in production.
    </p>
    <a href="#builder-form" class="inline-block px-8 py-3.5 bg-otp-500 text-white rounded-xl font-semibold hover:bg-otp-400 transition-all hover:shadow-lg hover:shadow-otp-500/25 text-sm">
      Start Hiring
    </a>
  </div>
</section>

<!-- MULTI-STEP FORM -->
<section id="builder-form" class="bg-otp-950 py-16 sm:py-24 border-t border-white/5">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">

    <!-- Step indicator -->
    <div class="flex items-center justify-center gap-2 mb-10" id="step-indicators">
      <div class="step-dot active" data-step="1"><span>1</span></div>
      <div class="step-line active"></div>
      <div class="step-dot" data-step="2"><span>2</span></div>
      <div class="step-line"></div>
      <div class="step-dot" data-step="3"><span>3</span></div>
      <div class="step-line"></div>
      <div class="step-dot" data-step="4"><span>4</span></div>
    </div>

    <!-- Steps container -->
    <div class="relative overflow-hidden" id="steps-container">

      <!-- STEP 1: The Role -->
      <div class="step-panel" data-step="1">
        <h2 class="text-2xl font-bold text-white mb-1">The Role</h2>
        <p class="text-sm text-gray-500 mb-8">What job are you hiring for?</p>

        <div class="space-y-5">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Industry</label>
            <select id="f-industry" class="ab-select">
              <option value="">Pick one</option>
              <option>Agency</option>
              <option>Fitness</option>
              <option>Healthcare</option>
              <option>SaaS</option>
              <option>Professional Services</option>
              <option>E-Commerce</option>
              <option>Education</option>
              <option>Real Estate</option>
              <option>Legal</option>
              <option>Other</option>
            </select>
          </div>
          <div id="industry-intel" class="hidden bg-otp-900/40 border border-otp-500/20 rounded-lg p-3 -mt-1">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-otp-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
              <p class="text-xs text-gray-400 leading-relaxed" id="industry-intel-text"></p>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Job Title</label>
            <input id="f-title" type="text" class="ab-input" placeholder="e.g., Email Triage Assistant, Pipeline Scanner, Call Center Manager">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Job Description</label>
            <textarea id="f-desc" rows="4" class="ab-input resize-none" placeholder="What should this agent DO? Describe it like you're explaining to a smart new hire."></textarea>
          </div>
        </div>

        <div class="flex justify-end mt-8">
          <button onclick="goStep(2)" class="ab-btn-primary">Continue</button>
        </div>
      </div>

      <!-- STEP 2: Skills & Tools -->
      <div class="step-panel hidden" data-step="2">
        <h2 class="text-2xl font-bold text-white mb-1">Skills &amp; Tools</h2>
        <p class="text-sm text-gray-500 mb-8">What does this agent need to know and connect to?</p>

        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Skills Needed</label>
            <div class="ab-tag-input" id="skills-input">
              <div class="ab-pills" id="skills-pills"></div>
              <input type="text" class="ab-tag-field" id="skills-field" placeholder="Type to search skills..." autocomplete="off">
              <div class="ab-suggestions hidden" id="skills-suggestions"></div>
            </div>
          </div>
          <div id="skills-hints" class="hidden bg-otp-900/40 border border-otp-500/20 rounded-lg p-3 -mt-2">
            <p class="text-xs text-gray-400 leading-relaxed" id="skills-hints-text"></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Tools to Integrate</label>
            <div class="ab-tag-input" id="tools-input">
              <div class="ab-pills" id="tools-pills"></div>
              <input type="text" class="ab-tag-field" id="tools-field" placeholder="Type to search tools..." autocomplete="off">
              <div class="ab-suggestions hidden" id="tools-suggestions"></div>
            </div>
          </div>
        </div>

        <div class="flex justify-between mt-8">
          <button onclick="goStep(1)" class="ab-btn-secondary">Back</button>
          <button onclick="goStep(3)" class="ab-btn-primary">Continue</button>
        </div>
      </div>

      <!-- STEP 3: Personality -->
      <div class="step-panel hidden" data-step="3">
        <h2 class="text-2xl font-bold text-white mb-1">Personality</h2>
        <p class="text-sm text-gray-500 mb-8">How should your agent communicate?</p>

        <div class="bg-otp-900/40 border border-otp-500/20 rounded-lg p-3 mb-6">
          <p class="text-xs text-gray-400 leading-relaxed">Personality maps directly to your agent's rules. A high-Dominance agent gets rules like "Make decisions autonomously. Flag after acting, not before." A high-Compliance agent gets "Never act without explicit approval. Document every decision."</p>
        </div>
        <!-- Framework selector -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8" id="framework-cards">
          <button onclick="pickFramework('disc')" class="ab-fcard" data-fw="disc">
            <div class="text-lg font-bold text-white mb-0.5">DISC</div>
            <div class="text-xs text-gray-500">4 dimensions</div>
          </button>
          <button onclick="pickFramework('big5')" class="ab-fcard" data-fw="big5">
            <div class="text-lg font-bold text-white mb-0.5">Big Five</div>
            <div class="text-xs text-gray-500">5 traits</div>
          </button>
          <button onclick="pickFramework('mbti')" class="ab-fcard" data-fw="mbti">
            <div class="text-lg font-bold text-white mb-0.5">MBTI</div>
            <div class="text-xs text-gray-500">16 types</div>
          </button>
          <button onclick="pickFramework('skip')" class="ab-fcard" data-fw="skip">
            <div class="text-lg font-bold text-white mb-0.5">Skip</div>
            <div class="text-xs text-gray-500">Balanced default</div>
          </button>
        </div>

        <!-- DISC panel -->
        <div id="panel-disc" class="ab-personality-panel hidden">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start">
            <div class="space-y-4">
              <div><div class="ab-slider-row"><label>Dominance</label><input type="range" min="1" max="10" value="5" data-trait="D" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="D">Your agent balances independence with deference, flags issues but waits for direction on big calls</p></div>
              <div><div class="ab-slider-row"><label>Influence</label><input type="range" min="1" max="10" value="5" data-trait="I" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="I">Your agent is professional and clear, occasionally adds context or encouragement</p></div>
              <div><div class="ab-slider-row"><label>Steadiness</label><input type="range" min="1" max="10" value="5" data-trait="S" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="S">Your agent balances speed with process, follows established patterns but adapts when needed</p></div>
              <div><div class="ab-slider-row"><label>Compliance</label><input type="range" min="1" max="10" value="5" data-trait="C" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="C">Your agent follows guidelines but applies judgment, bends rules when the situation warrants</p></div>
            </div>
            <div class="flex justify-center">
              <svg id="radar-disc" viewBox="0 0 200 200" class="w-48 h-48"></svg>
            </div>
          </div>
        </div>

        <!-- Big Five panel -->
        <div id="panel-big5" class="ab-personality-panel hidden">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start">
            <div class="space-y-4">
              <div><div class="ab-slider-row"><label>Openness</label><input type="range" min="1" max="10" value="5" data-trait="O" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="O">Your agent is open to new ideas when evidence supports them, balances innovation with pragmatism</p></div>
              <div><div class="ab-slider-row"><label>Conscientiousness</label><input type="range" min="1" max="10" value="5" data-trait="C2" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="C2">Your agent balances thoroughness with efficiency, documents important decisions</p></div>
              <div><div class="ab-slider-row"><label>Extraversion</label><input type="range" min="1" max="10" value="5" data-trait="E" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="E">Your agent communicates proactively when something matters, stays quiet otherwise</p></div>
              <div><div class="ab-slider-row"><label>Agreeableness</label><input type="range" min="1" max="10" value="5" data-trait="A" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="A">Your agent voices concerns when stakes are high but generally aligns with direction</p></div>
              <div><div class="ab-slider-row"><label>Emotional Stability</label><input type="range" min="1" max="10" value="5" data-trait="ES" class="ab-slider"><span class="ab-slider-val">5</span></div><p class="ab-trait-desc" data-desc="ES">Your agent maintains composure on routine issues, escalates proportionally to severity</p></div>
            </div>
            <div class="flex justify-center">
              <svg id="radar-big5" viewBox="0 0 200 200" class="w-48 h-48"></svg>
            </div>
          </div>
        </div>

        <!-- MBTI panel -->
        <div id="panel-mbti" class="ab-personality-panel hidden">
          <div class="flex flex-col items-center gap-5">
            <div class="grid grid-cols-2 gap-3 w-full max-w-xs" id="mbti-grid">
              <button onclick="toggleMBTI(0,'I')" class="ab-mbti-toggle" data-idx="0" data-val="I"><span class="font-bold">I</span>ntrovert</button>
              <button onclick="toggleMBTI(0,'E')" class="ab-mbti-toggle dim" data-idx="0" data-val="E"><span class="font-bold">E</span>xtravert</button>
              <button onclick="toggleMBTI(1,'S')" class="ab-mbti-toggle" data-idx="1" data-val="S"><span class="font-bold">S</span>ensing</button>
              <button onclick="toggleMBTI(1,'N')" class="ab-mbti-toggle dim" data-idx="1" data-val="N"><span class="font-bold">N</span> Intuition</button>
              <button onclick="toggleMBTI(2,'T')" class="ab-mbti-toggle" data-idx="2" data-val="T"><span class="font-bold">T</span>hinking</button>
              <button onclick="toggleMBTI(2,'F')" class="ab-mbti-toggle dim" data-idx="2" data-val="F"><span class="font-bold">F</span>eeling</button>
              <button onclick="toggleMBTI(3,'J')" class="ab-mbti-toggle" data-idx="3" data-val="J"><span class="font-bold">J</span>udging</button>
              <button onclick="toggleMBTI(3,'P')" class="ab-mbti-toggle dim" data-idx="3" data-val="P"><span class="font-bold">P</span>erceiving</button>
            </div>
            <div class="text-4xl font-extrabold text-white tracking-widest" id="mbti-result">ISTJ</div>
          </div>
        </div>

        <!-- Skip panel -->
        <div id="panel-skip" class="ab-personality-panel hidden">
          <div class="text-center py-6">
            <p class="text-gray-400 text-sm">We will use a balanced default personality. You can always customize later.</p>
          </div>
        </div>

        <div class="flex justify-between mt-8">
          <button onclick="goStep(2)" class="ab-btn-secondary">Back</button>
          <button onclick="goStep(4)" class="ab-btn-primary">Continue</button>
        </div>
      </div>

      <!-- STEP 4: Review & Generate -->
      <div class="step-panel hidden" data-step="4">
        <h2 class="text-2xl font-bold text-white mb-1">Review &amp; Generate</h2>
        <p class="text-sm text-gray-500 mb-8">Everything look right?</p>

        <div class="bg-otp-900/60 border border-white/10 rounded-xl p-6 space-y-5" id="review-card">
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Industry</div>
            <div class="text-white font-medium" id="rev-industry">--</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Job Title</div>
            <div class="text-white font-medium" id="rev-title">--</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Description</div>
            <div class="text-gray-300 text-sm leading-relaxed" id="rev-desc">--</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Skills</div>
            <div class="flex flex-wrap gap-1.5" id="rev-skills"></div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Tools</div>
            <div class="flex flex-wrap gap-1.5" id="rev-tools"></div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Personality</div>
            <div id="rev-personality" class="flex items-center gap-4">
              <span class="text-white font-medium" id="rev-personality-label">--</span>
              <svg id="rev-radar" viewBox="0 0 200 200" class="w-28 h-28 hidden"></svg>
            </div>
          </div>
        </div>

        <!-- OTP Network Boost -->
        <div class="mt-5 bg-otp-900/40 border border-otp-500/20 rounded-xl p-5" id="otp-boost">
          <div class="text-xs text-otp-400 uppercase tracking-wider font-semibold mb-3">OTP Network Boost</div>
          <div class="space-y-2 text-sm text-gray-400">
            <div class="flex items-center gap-2"><span class="text-green-400">+</span><span id="boost-patterns">Coordination patterns from production teams loading...</span></div>
            <div class="flex items-center gap-2"><span class="text-green-400">+</span><span id="boost-failures">Known failure modes your agent will avoid loading...</span></div>
            <div class="flex items-center gap-2"><span class="text-green-400">+</span><span id="boost-boundaries">Boundary rules from real deployments loading...</span></div>
            <div class="flex items-center gap-2"><span class="text-otp-400">&#9889;</span><span>MCP connection available: plug your agent into the live network for continuous improvement</span></div>
          </div>
        </div>

        <div class="mt-6">
          <label class="block text-sm font-medium text-gray-300 mb-1.5">Anything else?</label>
          <textarea id="f-extra" rows="2" class="ab-input resize-none" placeholder="Optional context, constraints, preferences..."></textarea>
        </div>

        <div class="flex justify-between mt-8">
          <button onclick="goStep(3)" class="ab-btn-secondary">Back</button>
          <button onclick="buildAgent()" class="ab-btn-build" id="build-btn">Build My Agent</button>
        </div>

        <!-- Loading overlay -->
        <div id="build-loading" class="hidden mt-8 text-center">
          <div class="inline-flex items-center gap-3 px-6 py-4 bg-otp-900/80 border border-otp-500/30 rounded-xl">
            <svg class="w-5 h-5 text-otp-400 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="text-otp-300 text-sm font-medium">Building your agent from <%= typeof claimCount !== 'undefined' ? claimCount : '0' %> coordination patterns...</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

