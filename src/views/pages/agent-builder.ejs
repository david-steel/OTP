<style>
  .step-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#6b7280;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);transition:all .3s}
