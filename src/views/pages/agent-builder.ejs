<section class="bg-otp-950 py-16 sm:py-24 border-t border-white/5">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <p class="text-center text-gray-400 text-sm mb-3 reveal">Why agents built here are different</p>
    <h2 class="text-3xl sm:text-4xl font-extrabold text-white text-center mb-12 tracking-tight reveal">
      Informed by <span class="gradient-text"><%= typeof publisherCount !== 'undefined' ? publisherCount : '0' %> organizations</span> running AI in production
    </h2>
