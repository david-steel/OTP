<%# /sign-up -- v7-styled conversion page. Rendered via renderV7 with
   loadClerk:true, so v7.ejs injects the Clerk script and this page mounts
   the SignUp widget into #clerk-sign-up. The skeleton inside that slot is
   what users see while Clerk JS is in flight -- Clerk replaces innerHTML on
   mount, so the skeleton self-removes. afterSignUpUrl points to
   /onboarding/profile where the Google Ads conversion event fires. %>
<style>
  /* Loading skeleton (replaced by Clerk when mountSignUp runs) */
  @keyframes su-shimmer { 0%, 100% { opacity: 0.45; } 50% { opacity: 1; } }
  .su-skel-row { height: 0.95rem; background: var(--line-soft); border-radius: 6px; }
  .su-skel-row + .su-skel-row { margin-top: 0.75rem; }
  .su-skel-input { height: 2.6rem; background: var(--line-soft); border-radius: 10px; }
  .su-skel-input + .su-skel-input { margin-top: 0.75rem; }
  .su-skel { animation: su-shimmer 1.6s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) { .su-skel { animation: none; } }

  /* Soften Clerk's default card chrome so it sits flat inside our v7 card */
  #clerk-sign-up .cl-rootBox,
  #clerk-sign-up .cl-card {
    box-shadow: none !important;
    border: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  /* Free badge — high-contrast eyebrow on the orgy color the brand owns */
  .su-free-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--orgy);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .su-free-dot {
    width: 6px; height: 6px; border-radius: 999px;
    background: var(--ink);
    animation: su-shimmer 1.6s ease-in-out infinite;
  }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[104px] pb-10 sm:pt-[128px] sm:pb-14 text-center">
    <div class="su-free-badge mb-5">
      <span class="su-free-dot"></span>Free for your whole team. Not a trial.
    </div>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(2rem,4.4vw,3.1rem); line-height:1.07; font-weight:700; letter-spacing:-0.025em;">
      Create your free OTP workspace.
    </h1>
    <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[40rem] mx-auto mt-5">
      Run your 1:1s, weekly leadership meeting, org chart, and a lot more on OTP. Every human free; agents $16 a month.
    </p>
  </div>
</section>

<!-- ================= FORM + WHAT'S NEXT ================= -->
<section class="bg-[var(--white)] pb-14">
  <div class="max-w-[1080px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-10 lg:gap-14 items-start">

      <!-- LEFT: Clerk widget (value bullets removed -- generic SaaS-list
           feel was killing the editorial confidence of the page; the hero
           subhead already covers the value prop) -->
      <div>
        <!-- Clerk slot. Skeleton inside is replaced by Clerk.mountSignUp(). -->
        <div class="rounded-2xl border border-[var(--line)] bg-[var(--card)] p-6 sm:p-8" style="box-shadow:0 1px 2px rgba(20,22,28,0.04), 0 12px 32px rgba(20,22,28,0.05);">
          <div id="clerk-sign-up" class="min-h-[440px]">
            <div class="su-skel">
              <div class="su-skel-row" style="width:55%; margin-bottom:1rem;"></div>
              <div class="su-skel-input"></div>
              <div class="su-skel-input"></div>
              <div class="su-skel-input"></div>
              <div class="su-skel-row" style="width:60%; height:2.4rem; margin-top:1.4rem;"></div>
            </div>
            <p class="text-center text-[12px] mt-6" style="color:var(--ink-mute);">Loading secure sign-up…</p>
          </div>

          <noscript>
            <div class="text-center py-6">
              <p class="text-[14px] text-[var(--ink)] mb-2 font-semibold">JavaScript is required to create an account.</p>
              <p class="text-[13px] text-[var(--ink-soft)]">Enable JavaScript in your browser and reload this page.</p>
            </div>
          </noscript>
        </div>

        <p class="text-center text-[13px] mt-5" style="color:var(--ink-soft);">
          Already have an account?
          <a href="/sign-in" class="text-[var(--ink)] underline underline-offset-2 hover:text-[var(--blue)] transition-colors">Sign in</a>.
        </p>
      </div>

      <!-- RIGHT: what happens next. Hands are inline bullet-numbering at
           22px (the hand IS the number, so no "01/02/03" duplication).
           Same Orgy vocabulary as home-v7's hand-1/2/3 but sized down to
           bullet weight. -->
      <aside>
        <div class="rounded-2xl border border-[var(--line-soft)] p-6 sm:p-7" style="background:#fbfaf5;">
          <p class="eyebrow mb-5">What happens next</p>
          <ol class="space-y-4">
            <li class="flex items-start gap-3">
              <img src="/public/hand-1.png" alt="1" class="shrink-0" style="height:22px;width:auto;margin-top:2px;" loading="lazy">
              <div>
                <p class="text-[14px] font-semibold text-[var(--ink)] mb-0.5 leading-tight">Verify your email</p>
                <p class="text-[12.5px] leading-relaxed" style="color:var(--ink-soft);">A 6-digit code from Clerk. Thirty seconds.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <img src="/public/hand-2.png" alt="2" class="shrink-0" style="height:22px;width:auto;margin-top:2px;" loading="lazy">
              <div>
                <p class="text-[14px] font-semibold text-[var(--ink)] mb-0.5 leading-tight">Name your organization</p>
                <p class="text-[12.5px] leading-relaxed" style="color:var(--ink-soft);">One field. Your team's home in OTP.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <img src="/public/hand-3.png" alt="3" class="shrink-0" style="height:22px;width:auto;margin-top:2px;" loading="lazy">
              <div>
                <p class="text-[14px] font-semibold text-[var(--ink)] mb-0.5 leading-tight">Run your first weekly meeting</p>
                <p class="text-[12.5px] leading-relaxed" style="color:var(--ink-soft);">Scorecard, IDS, to-dos, headlines. Built into the chart.</p>
              </div>
            </li>
          </ol>

          <hr class="my-5" style="border-color:var(--line-soft);">

          <div class="space-y-2 text-[12px]" style="color:var(--ink-soft);">
            <p>Authentication by <strong class="text-[var(--ink)]">Clerk</strong> (SOC 2 Type II).</p>
            <p>No card required. The meeting software is free, forever.</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  (function waitForClerk() {
    if (!window.Clerk) return setTimeout(waitForClerk, 100);
    window.Clerk.load().then(function() {
      if (window.Clerk.user) {
        window.location.href = '/dashboard';
        return;
      }
      var slot = document.getElementById('clerk-sign-up');
      if (!slot) return;
      // Clerk's mountSignUp APPENDS to the slot, it does not clear children.
      // Wipe the skeleton ourselves first so it does not stack above the
      // Clerk widget (caught 2026-05-21 by David in a real preview).
      slot.innerHTML = '';
      slot.classList.remove('min-h-[440px]'); // let Clerk size itself
      window.Clerk.mountSignUp(slot, {
        afterSignInUrl: '/dashboard',
        afterSignUpUrl: '/onboarding/profile',
        // Theme the widget to the OTP v7 brand: orgy-green primary button
        // (Clerk's default blue clashes with our editorial light style), and
        // hide Clerk's duplicate "Create your account / to continue to OTP"
        // header since our page H1 already says it.
        appearance: {
          variables: {
            colorPrimary: '#A8E63A',
            colorText: '#14161c',
            colorTextOnPrimaryBackground: '#14161c',
            colorBackground: '#ffffff',
            colorInputBackground: '#ffffff',
            colorInputText: '#14161c',
            borderRadius: '10px',
            fontFamily: 'Inter, sans-serif',
          },
          elements: {
            rootBox: { width: '100%' },
            card: { boxShadow: 'none', border: '0', padding: '0', background: 'transparent' },
            header: { display: 'none' },
            headerTitle: { display: 'none' },
            headerSubtitle: { display: 'none' },
            formButtonPrimary: {
              backgroundColor: '#A8E63A',
              color: '#14161c',
              fontWeight: '700',
              textTransform: 'none',
            },
            footer: { display: 'none' }, // hides "Secured by Clerk" footer
          },
        },
      });
    }).catch(function() {
      var slot = document.getElementById('clerk-sign-up');
      if (!slot) return;
      slot.innerHTML =
        '<div style="text-align:center; padding:2.5rem 0;">' +
          '<p style="font-size:14px; color:var(--ink); margin-bottom:0.75rem; font-weight:600;">Sign-up didn\'t load.</p>' +
          '<p style="font-size:13px; color:var(--ink-soft); margin-bottom:1rem;">This is usually a browser extension or ad blocker.</p>' +
          '<button onclick="location.reload()" class="btn-primary" style="padding:0.55rem 1.25rem; font-size:13px;">Retry</button>' +
        '</div>';
    });
  })();
</script>
