<% /* XSS guard: embed a value in an inline <script> via jsonForScript() -- escapes < and > so a value containing </script> can't break out of the script context. This page server-renders all values into the form, so the helper is unused, but kept to match the checkup.ejs convention. */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%- include('../partials/orgy-palette'); %>
<%
  // ---- Settings: Configuration (Company Settings) ----
  // Locals: org {name,website,description,public}, canEdit (bool).
  // Auto-injected: memberRole, currentPath, assetVersion, authState.
  // Everything below is typeof-guarded so the page never throws on a missing local.
  var _av     = (typeof assetVersion !== 'undefined') ? assetVersion : 'dev';
  var _auth   = (typeof authState !== 'undefined' && authState) ? String(authState) : 'authenticated';
  var _org    = (typeof org !== 'undefined' && org && typeof org === 'object') ? org : {};
  // canEdit defaults to false when undefined (fail safe -- read-only unless explicitly allowed).
  var _canEdit = (typeof canEdit !== 'undefined') ? !!canEdit : false;

  var _name   = (_org.name !== undefined && _org.name !== null) ? String(_org.name) : '';
  var _website = (_org.website !== undefined && _org.website !== null) ? String(_org.website) : '';
  var _desc   = (_org.description !== undefined && _org.description !== null) ? String(_org.description) : '';
  var _public = !!_org.public;
  var _isPrivate = !!_org.isPrivate;
  var _orgId  = (_org.id !== undefined && _org.id !== null) ? String(_org.id) : '';
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%- include('../partials/ui-page-header', { helpKey: 'settings.configuration', title: 'Configuration', eyebrow: 'Company Settings', subtitle: 'Your company name, website, and description.', mascot: 'mcp-api' }) %>


    <% if (_auth === 'unauthenticated') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Sign in to manage company settings.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Sign In</a>
      </div>
    <% } else if (_auth === 'no_org') { %>
      <div class="bg-gray-50 border rounded-xl p-8 text-center">
        <p class="text-gray-600 mb-4">Complete your organization profile first.</p>
        <a href="/dashboard" class="inline-block px-5 py-2.5 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors">Set Up Profile</a>
      </div>
    <% } else { %>

      <!-- two-column: nav stacks above content on mobile, sidebar on >=md -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start">

        <!-- left: settings nav -->
        <%- include('../partials/settings-nav') %>

        <!-- right: content -->
        <form id="configuration-form" class="flex-1 min-w-0 w-full space-y-6">

          <div class="flex items-center justify-between gap-4">
            <h2 class="font-bold text-gray-900 text-lg">Company Information</h2>
            <% if (_canEdit) { %>
              <button type="submit"
                      class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
                Save Changes
              </button>
            <% } %>
          </div>

          <% if (!_canEdit) { %>
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
              <p class="text-sm text-amber-800 font-medium">Only owners and admins can edit company settings.</p>
            </div>
          <% } %>

          <!-- Card: Company Information -->
          <div class="bg-gray-50 border rounded-xl p-6 space-y-5">

            <!-- Company name (required) -->
            <div>
              <label for="cfg-name" class="block font-bold text-gray-900 mb-1">Company name <span class="text-red-500">*</span></label>
              <p class="text-sm text-gray-500 mb-2">The name shown across OTP.</p>
              <input type="text" name="name" id="cfg-name" required
                     value="<%= _name %>"
                     <%= _canEdit ? '' : 'disabled' %>
                     class="w-full sm:max-w-md px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500 disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
            </div>

            <!-- Company website (optional) -->
            <div>
              <label for="cfg-website" class="block font-bold text-gray-900 mb-1">Company website</label>
              <p class="text-sm text-gray-500 mb-2">Optional. Your public site or landing page.</p>
              <input type="url" name="website" id="cfg-website"
                     value="<%= _website %>"
                     placeholder="https://example.com"
                     <%= _canEdit ? '' : 'disabled' %>
                     class="w-full sm:max-w-md px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500 disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
            </div>

            <!-- Description (optional) -->
            <div>
              <label for="cfg-description" class="block font-bold text-gray-900 mb-1">Description</label>
              <p class="text-sm text-gray-500 mb-2">Optional. A short description of your organization.</p>
              <textarea name="description" id="cfg-description" rows="4"
                        <%= _canEdit ? '' : 'disabled' %>
                        class="w-full sm:max-w-md px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500 disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed"><%= _desc %></textarea>
            </div>

            <!-- Public toggle -->
            <div>
              <label class="flex items-start gap-3 <%= _canEdit ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                <input type="checkbox" name="public" id="cfg-public" value="1"
                       class="mt-0.5 text-otp-500 focus:ring-otp-500 rounded"
                       <%= _public ? 'checked' : '' %>
                       <%= _canEdit ? '' : 'disabled' %>>
                <span>
                  <span class="block text-sm text-gray-800 font-medium">List this organization publicly</span>
                  <span class="block text-sm text-gray-500">When on, your organization can appear in public listings.</span>
                </span>
              </label>
            </div>

            <!-- Company ID (read-only, copyable) -->
            <% if (_orgId) { %>
            <div>
              <label class="block font-bold text-gray-900 mb-1">Company ID</label>
              <p class="text-sm text-gray-500 mb-2">Your organization's unique ID. Share it with support or paste it when reporting a correction.</p>
              <div class="flex items-center gap-2 w-full sm:max-w-md">
                <input type="text" id="cfg-org-id" value="<%= _orgId %>" readonly
                       class="flex-1 px-3 py-2 border rounded-lg text-sm bg-gray-100 text-gray-600 font-mono select-all focus:outline-none">
                <button type="button" id="cfg-org-id-copy" aria-label="Copy Company ID" title="Copy"
                        class="flex-none p-2 border rounded-lg bg-white hover:bg-gray-50 text-gray-600 hover:text-otp-600 transition-colors">
                  <svg id="cfg-org-id-copy-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                    <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
                  </svg>
                </button>
              </div>
            </div>
            <script>
              (function(){
                var btn = document.getElementById('cfg-org-id-copy');
                var input = document.getElementById('cfg-org-id');
                var icon = document.getElementById('cfg-org-id-copy-icon');
                if (!btn || !input) return;
                var CHECK = '<path d="M20 6L9 17l-5-5"></path>';
                var COPY = '<rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path>';
                btn.addEventListener('click', function(){
                  var done = function(){
                    if (icon) { icon.innerHTML = CHECK; setTimeout(function(){ icon.innerHTML = COPY; }, 1500); }
                  };
                  if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(input.value).then(done).catch(function(){ input.select(); document.execCommand('copy'); done(); });
                  } else {
                    input.select(); document.execCommand('copy'); done();
                  }
                });
              })();
            </script>
            <% } %>

          </div>

          <!-- Card: Privacy (Private mode) -->
          <div class="bg-gray-50 border rounded-xl p-6 space-y-5">
            <div>
              <h3 class="font-bold text-gray-900">Privacy</h3>
              <p class="text-sm text-gray-500 mt-1">Control whether your organization's data ever reaches the network.</p>
            </div>

            <!-- Private mode toggle -->
            <div>
              <label class="flex items-start gap-3 <%= _canEdit ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                <input type="checkbox" name="isPrivate" id="cfg-private" value="1"
                       class="mt-0.5 text-otp-500 focus:ring-otp-500 rounded"
                       <%= _isPrivate ? 'checked' : '' %>
                       <%= _canEdit ? '' : 'disabled' %>>
                <span>
                  <span class="block text-sm text-gray-800 font-medium">Private mode</span>
                  <span class="block text-sm text-gray-500">When on, your organization's data is never published to the network, browse, search, the intelligence graph, or used in cross-org recommendations. Share by invitation only. Your own team still sees everything.</span>
                  <span class="block text-sm text-gray-400 mt-1">Private mode is a Premium feature. <a href="/pricing" class="text-otp-600 underline">See plans</a>.</span>
                </span>
              </label>
            </div>
          </div>

          <% if (_canEdit) { %>
            <div class="flex items-center gap-4">
              <button type="submit"
                      class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
                Save Changes
              </button>
              <span id="cfg-saved" class="hidden text-sm font-semibold text-green-600">Saved</span>
            </div>
          <% } %>

        </form>

        <!-- Card: Bring your own AI key (BYOK). Hydrates client-side from
             GET /api/v1/org/ai-key so this card needs no extra route locals. -->
        <div class="flex-1 min-w-0 w-full">
          <div class="bg-gray-50 border rounded-xl p-6 space-y-5">
            <div>
              <h3 class="font-bold text-gray-900">Bring your own AI key</h3>
              <p class="text-sm text-gray-500 mt-1">Providing a key routes all AI features through your own provider account instead of OTP's shared key.</p>
            </div>

            <p id="ai-key-status" class="text-sm text-gray-600">Loading…</p>

            <div id="ai-key-noenc" class="hidden bg-gray-100 border rounded-lg p-3">
              <p class="text-sm text-gray-500">Your administrator must set AI_KEYS_ENCRYPTION_KEY before customer keys can be stored.</p>
            </div>

            <% if (_canEdit) { %>
            <div id="ai-key-form" class="hidden space-y-4">
              <div>
                <label for="ai-key-provider" class="block font-bold text-gray-900 mb-1">Provider</label>
                <select id="ai-key-provider"
                        class="w-full sm:max-w-md px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500">
                  <option value="anthropic">Anthropic</option>
                  <option value="openai">OpenAI</option>
                </select>
              </div>
              <div>
                <label for="ai-key-input" class="block font-bold text-gray-900 mb-1">API key</label>
                <p class="text-sm text-gray-500 mb-2">Stored encrypted. We never display it again.</p>
                <input type="password" id="ai-key-input" autocomplete="off"
                       placeholder="sk-…"
                       class="w-full sm:max-w-md px-3 py-2 border rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-otp-500">
              </div>
              <div class="flex items-center gap-4">
                <button type="button" id="ai-key-save"
                        class="px-5 py-2 bg-otp-500 text-white font-semibold rounded-lg hover:bg-otp-600 transition-colors text-sm whitespace-nowrap">
                  Save key
                </button>
                <button type="button" id="ai-key-revoke"
                        class="hidden px-5 py-2 border border-red-300 text-red-700 font-semibold rounded-lg hover:bg-red-50 transition-colors text-sm whitespace-nowrap">
                  Revoke key
                </button>
                <span id="ai-key-msg" class="hidden text-sm font-semibold text-green-600">Saved</span>
              </div>
            </div>
            <% } else { %>
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
              <p class="text-sm text-amber-800 font-medium">Only owners and admins can change the AI key.</p>
            </div>
            <% } %>
          </div>
        </div>
      </div>

    <% } %>
</div>

<% if (_canEdit) { %>
<script>
  (function () {
    var form = document.getElementById('configuration-form');
    if (!form) return;
    var saved = document.getElementById('cfg-saved');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var fd = new FormData(form);
      var payload = {
        name: (fd.get('name') || '').trim(),
        website: (fd.get('website') || '').trim(),
        description: (fd.get('description') || '').trim(),
        public: fd.get('public') === '1',
        isPrivate: fd.get('isPrivate') === '1'
      };

      try {
        var res = await fetch('/settings/configuration', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!res.ok) {
          var data = {};
          try { data = await res.json(); } catch (_) {}
          alert((data && data.error && data.error.message) || (data && data.error) || 'Failed to save company settings');
          return;
        }

        if (saved) {
          saved.classList.remove('hidden');
          setTimeout(function () { saved.classList.add('hidden'); }, 2500);
        }
      } catch (err) {
        alert('Failed to save company settings');
      }
    });
  })();
</script>
<% } %>

<script>
  // BYOK AI-key card: hydrate META client-side; never render the key itself.
  (function () {
    var statusEl  = document.getElementById('ai-key-status');
    if (!statusEl) return;
    var noencEl   = document.getElementById('ai-key-noenc');
    var formEl    = document.getElementById('ai-key-form');
    var providerEl = document.getElementById('ai-key-provider');
    var inputEl   = document.getElementById('ai-key-input');
    var saveBtn   = document.getElementById('ai-key-save');
    var revokeBtn = document.getElementById('ai-key-revoke');
    var msgEl     = document.getElementById('ai-key-msg');
    var canEdit   = !!formEl;

    function providerLabel(p) {
      if (p === 'anthropic') return 'Anthropic';
      if (p === 'openai') return 'OpenAI';
      return p || 'your';
    }

    function render(meta) {
      if (meta && meta.encryptionConfigured === false) {
        if (noencEl) noencEl.classList.remove('hidden');
        if (formEl) formEl.classList.add('hidden');
      }
      if (meta && meta.configured) {
        statusEl.textContent = 'Using your own ' + providerLabel(meta.provider) + ' key ••••' + (meta.last4 || '');
        if (canEdit && revokeBtn) revokeBtn.classList.remove('hidden');
      } else {
        statusEl.textContent = "Using OTP's shared key";
        if (canEdit && revokeBtn) revokeBtn.classList.add('hidden');
      }
    }

    function flash(text, ok) {
      if (!msgEl) return;
      msgEl.textContent = text;
      msgEl.className = 'text-sm font-semibold ' + (ok ? 'text-green-600' : 'text-red-600');
      msgEl.classList.remove('hidden');
      setTimeout(function () { msgEl.classList.add('hidden'); }, 2500);
    }

    async function load() {
      try {
        var res = await fetch('/api/v1/org/ai-key', { headers: { 'Accept': 'application/json' } });
        var meta = await res.json();
        render(meta);
      } catch (e) {
        statusEl.textContent = 'Could not load AI key status.';
      }
    }

    if (canEdit) {
      formEl.classList.remove('hidden');

      saveBtn.addEventListener('click', async function () {
        var key = (inputEl.value || '').trim();
        if (!key) { flash('Enter a key first', false); return; }
        try {
          var res = await fetch('/api/v1/org/ai-key', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ provider: providerEl.value, key: key })
          });
          if (!res.ok) {
            var data = {};
            try { data = await res.json(); } catch (_) {}
            flash((data && data.error && data.error.message) || 'Failed to save key', false);
            return;
          }
          inputEl.value = '';
          flash('Saved', true);
          await load();
        } catch (e) {
          flash('Failed to save key', false);
        }
      });

      revokeBtn.addEventListener('click', async function () {
        if (!window.confirm('Revoke this key and fall back to OTP\'s shared key?')) return;
        try {
          var res = await fetch('/api/v1/org/ai-key', { method: 'DELETE' });
          if (!res.ok) { flash('Failed to revoke key', false); return; }
          flash('Revoked', true);
          await load();
        } catch (e) {
          flash('Failed to revoke key', false);
        }
      });
    }

    load();
  })();
</script>
