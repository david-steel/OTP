<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-2">
    <div>
      <h1 class="text-2xl font-bold">Pre-Signup Subscribers</h1>
      <p class="text-gray-500 text-sm">People you've collected emails from. Conversion tracked when they sign up via Clerk.</p>
    </div>
    <span class="px-3 py-1 bg-red-100 text-red-700 text-xs font-bold rounded-full uppercase">Super Admin</span>
  </div>

  <div class="mb-6">
    <a href="/admin" class="text-xs text-otp-600 hover:underline">&larr; Back to Admin Dashboard</a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-5 gap-3 mb-8">
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-3xl font-bold text-otp-600"><%= stats.total %></div>
      <div class="text-xs text-gray-500 mt-1">Total</div>
      <div class="text-xs text-gray-400 mt-1">all time</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-3xl font-bold <%= stats.active > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= stats.active %></div>
      <div class="text-xs text-gray-500 mt-1">Active</div>
      <div class="text-xs text-gray-400 mt-1">not unsubscribed</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-3xl font-bold <%= stats.converted > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= stats.converted %></div>
      <div class="text-xs text-gray-500 mt-1">Converted</div>
      <div class="text-xs text-gray-400 mt-1">signed up</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-3xl font-bold <%= stats.conversionRate > 0 ? 'text-otp-600' : 'text-gray-300' %>"><%= stats.conversionRate %>%</div>
      <div class="text-xs text-gray-500 mt-1">Conv. Rate</div>
      <div class="text-xs text-gray-400 mt-1">converted / active</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-3xl font-bold <%= stats.unsubscribed > 0 ? 'text-amber-600' : 'text-gray-300' %>"><%= stats.unsubscribed %></div>
      <div class="text-xs text-gray-500 mt-1">Unsub'd</div>
      <div class="text-xs text-gray-400 mt-1">opted out</div>
    </div>
  </div>

  <!-- By source -->
  <% if (Object.keys(stats.bySource).length > 0) { %>
  <div class="mb-8">
    <h3 class="text-sm font-semibold uppercase text-gray-600 tracking-wide mb-3">By source</h3>
    <div class="bg-white border rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs uppercase text-gray-600">
          <tr>
            <th class="text-left px-4 py-2">Source</th>
            <th class="text-right px-4 py-2">Total</th>
            <th class="text-right px-4 py-2">Converted</th>
            <th class="text-right px-4 py-2">Conv. Rate</th>
          </tr>
        </thead>
        <tbody>
          <% for (const [source, bucket] of Object.entries(stats.bySource)) { %>
          <tr class="border-t">
            <td class="px-4 py-2 font-mono text-xs"><%= source %></td>
            <td class="px-4 py-2 text-right"><%= bucket.count %></td>
            <td class="px-4 py-2 text-right"><%= bucket.converted %></td>
            <td class="px-4 py-2 text-right text-gray-500"><%= bucket.count > 0 ? Math.round((bucket.converted / bucket.count) * 1000) / 10 : 0 %>%</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- Add form -->
  <div class="mb-8 bg-white border rounded-lg p-6">
    <h2 class="font-semibold text-lg mb-1">Add a prospect</h2>
    <p class="text-xs text-gray-500 mb-4">When someone gives you their email but hasn't signed up yet. Pushes to the Resend Audience for broadcasts.</p>

    <form id="add-subscriber-form" class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1" for="email">Email <span class="text-red-500">*</span></label>
          <input id="email" name="email" type="email" required class="w-full px-3 py-2 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="someone@example.com">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1" for="name">Name</label>
          <input id="name" name="name" type="text" class="w-full px-3 py-2 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="Jane Doe">
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-700 mb-1" for="notes">Notes <span class="text-gray-400 font-normal">(where you met, what they care about)</span></label>
        <textarea id="notes" name="notes" rows="2" class="w-full px-3 py-2 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="Met at HFA. Said OTP solves their multi-AI memory problem."></textarea>
      </div>
      <div class="grid grid-cols-2 gap-3 items-end">
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1" for="source">Source</label>
          <select id="source" name="source" class="w-full px-3 py-2 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-otp-500">
            <option value="founder-add">founder-add (default)</option>
            <option value="founder-call">founder-call</option>
            <option value="conference">conference</option>
            <option value="linkedin">linkedin</option>
            <option value="referral">referral</option>
            <option value="podcast">podcast</option>
            <option value="other">other</option>
          </select>
        </div>
        <div>
          <button type="submit" id="submit-btn" class="w-full px-4 py-2 bg-otp-500 text-white rounded-lg hover:bg-otp-600 text-sm font-medium transition-colors">
            Add to list
          </button>
        </div>
      </div>
      <div id="add-msg" class="text-sm hidden"></div>
    </form>
  </div>

  <!-- Subscribers table -->
  <div class="mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h3 class="font-semibold">All subscribers (<%= subscribers.length %>)</h3>
      <span class="text-xs text-gray-400">most recent first</span>
    </div>
    <div class="bg-white border rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs uppercase text-gray-600">
          <tr>
            <th class="text-left px-3 py-2">Email</th>
            <th class="text-left px-3 py-2">Name</th>
            <th class="text-left px-3 py-2">Source</th>
            <th class="text-left px-3 py-2">Added</th>
            <th class="text-left px-3 py-2">Status</th>
            <th class="text-left px-3 py-2">Notes</th>
          </tr>
        </thead>
        <tbody>
          <% if (subscribers.length === 0) { %>
            <tr><td colspan="6" class="px-3 py-8 text-center text-gray-400">No subscribers yet. Add the first one above.</td></tr>
          <% } %>
          <% for (const s of subscribers) { %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-3 py-2 font-mono text-xs"><%= s.email %></td>
            <td class="px-3 py-2"><%= s.name || '—' %></td>
            <td class="px-3 py-2 text-xs text-gray-500"><%= s.source %></td>
            <td class="px-3 py-2 text-xs text-gray-500"><%= new Date(s.subscribedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
            <td class="px-3 py-2">
              <% if (s.unsubscribedAt) { %>
                <span class="px-2 py-0.5 bg-amber-100 text-amber-700 text-xs rounded-full">unsubscribed</span>
              <% } else if (s.convertedAt) { %>
                <span class="px-2 py-0.5 bg-green-100 text-green-700 text-xs rounded-full">converted</span>
              <% } else { %>
                <span class="px-2 py-0.5 bg-blue-100 text-blue-700 text-xs rounded-full">pre-signup</span>
              <% } %>
            </td>
            <td class="px-3 py-2 text-xs text-gray-600 max-w-md truncate" title="<%= s.notes || '' %>"><%= s.notes || '—' %></td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  (function() {
    const form = document.getElementById('add-subscriber-form');
    const btn = document.getElementById('submit-btn');
    const msg = document.getElementById('add-msg');

    function showMsg(text, kind) {
      msg.textContent = text;
      msg.className = 'text-sm mt-2 px-3 py-2 rounded-lg ' + (
        kind === 'error' ? 'bg-red-50 text-red-700 border border-red-200' :
        kind === 'ok' ? 'bg-green-50 text-green-700 border border-green-200' :
        'hidden'
      );
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Adding...';
      showMsg('', null);

      const payload = {
        email: form.email.value.trim(),
        name: form.name.value.trim() || undefined,
        notes: form.notes.value.trim() || undefined,
        source: form.source.value,
      };

      try {
        const res = await fetch('/api/v1/admin/subscribers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (!res.ok || data.error) {
          showMsg('Error: ' + (data.error?.message || 'Add failed'), 'error');
          btn.disabled = false;
          btn.textContent = 'Add to list';
          return;
        }
        const status = data.status === 'created' ? 'Added' : 'Updated';
        showMsg(status + ' ' + data.subscriber.email + '. Reloading...', 'ok');
        setTimeout(function() { window.location.reload(); }, 800);
      } catch (err) {
        showMsg('Error: ' + err.message, 'error');
        btn.disabled = false;
        btn.textContent = 'Add to list';
      }
    });
  })();
</script>
