<style>
  /* Four-stage arc: tool -> assistant -> agent -> robot
     Stage 3 (Agent) is the current "you are here" -- highlighted as OTP's home.
     Stage 4 (Robot) is the next wave -- subtle glow, "shipping" badge. */
  .stage-card {
    position: relative;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 1.25rem 1rem;
    transition: transform 250ms ease, border-color 250ms ease, background 250ms ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .stage-card:hover { transform: translateY(-2px); }
  .stage-marker {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 0.75rem auto;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #6b7280;
    z-index: 1;
    position: relative;
  }
  .stage-meta {
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b7280;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .stage-name {
    text-align: center;
    font-size: 22px;
    font-weight: 800;
    color: #f3f4f6;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .stage-desc {
    text-align: center;
    font-size: 12px;
    line-height: 1.45;
    color: #9ca3af;
  }

  /* Past stages: muted, history */
  .stage-past .stage-marker { color: #6b7280; }
  .stage-past .stage-name { color: #9ca3af; }
  .stage-recent .stage-marker { color: #818cf8; background: rgba(99, 102, 241, 0.06); border-color: rgba(99, 102, 241, 0.18); }
  .stage-recent .stage-name { color: #c7d2fe; }

  /* Current stage (Agent) -- highlighted, brighter, pulse */
  .stage-current {
    background: linear-gradient(180deg, rgba(14, 165, 233, 0.10) 0%, rgba(15, 23, 42, 0.4) 100%);
    border-color: rgba(14, 165, 233, 0.35);
    box-shadow: 0 0 32px rgba(14, 165, 233, 0.10);
  }
  .stage-current .stage-name { color: #fff; }
  .stage-current .stage-desc { color: #cbd5e1; }
  .stage-marker-current {
    color: #fff !important;
    background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
    border-color: rgba(56, 189, 248, 0.6) !important;
    box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.18), 0 0 24px rgba(14, 165, 233, 0.45);
    animation: stage-pulse 2.6s ease-in-out infinite;
  }
  @keyframes stage-pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.18), 0 0 24px rgba(14, 165, 233, 0.45); }
    50% { box-shadow: 0 0 0 8px rgba(14, 165, 233, 0.10), 0 0 36px rgba(14, 165, 233, 0.65); }
  }
  .stage-here-pill {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 10px; border-radius: 999px;
    font-size: 9px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    background: rgba(16, 185, 129, 0.15);
    color: #6ee7b7;
    border: 1px solid rgba(16, 185, 129, 0.35);
    white-space: nowrap;
  }

  /* Future stage (Robot) -- gathering, faint purple glow, "shipping" tone */
  .stage-future {
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.06) 0%, rgba(15, 23, 42, 0.4) 100%);
    border-color: rgba(168, 85, 247, 0.18);
  }
  .stage-marker-future {
    color: #c4b5fd !important;
    background: rgba(168, 85, 247, 0.12) !important;
    border-color: rgba(168, 85, 247, 0.32) !important;
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.18);
  }
  .stage-future .stage-name { color: #e9d5ff; }
</style>

