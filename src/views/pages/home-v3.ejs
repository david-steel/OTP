<!-- Hero slider script -->
<script>
var currentHeroSlide = 1;
var heroSlideCount = 3;
var heroAutoTimer = null;

function switchHeroSlide(n) {
  if (n === currentHeroSlide) return;

  for (var i = 1; i <= heroSlideCount; i++) {
    var slide = document.getElementById('hero-slide-' + i);
    var dot = document.getElementById('hero-dot-' + i);
    if (i === n) {
      slide.style.opacity = '1';
      slide.style.pointerEvents = 'auto';
      dot.className = 'hero-dot w-2.5 h-2.5 rounded-full bg-otp-500 transition-all duration-300';
    } else {
      slide.style.opacity = '0';
      slide.style.pointerEvents = 'none';
      dot.className = 'hero-dot w-2.5 h-2.5 rounded-full bg-white/20 hover:bg-white/40 transition-all duration-300';
    }
  }
  currentHeroSlide = n;

  if (heroAutoTimer) clearInterval(heroAutoTimer);
  heroAutoTimer = setInterval(function() {
    switchHeroSlide((currentHeroSlide % heroSlideCount) + 1);
  }, 15000);
}

heroAutoTimer = setInterval(function() {
  switchHeroSlide((currentHeroSlide % heroSlideCount) + 1);
}, 15000);

// Hero Agent Builder inline form
document.getElementById('hero-ab-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var industry = document.getElementById('hero-ab-industry').value;
  var title = document.getElementById('hero-ab-title').value;
  var params = [];
  if (industry) params.push('industry=' + encodeURIComponent(industry));
  if (title) params.push('title=' + encodeURIComponent(title));
  var url = '/agent-builder' + (params.length ? '?' + params.join('&') : '');
  window.location.href = url;
});
</script>


