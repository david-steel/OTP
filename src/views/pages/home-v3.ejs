<!-- Bottom CTA canvas (subtle version) -->
<script>
(function() {
  var canvas = document.getElementById('bottom-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var dpr = window.devicePixelRatio || 1;
  var W, H, particles = [];

  function resize() {
    var r = canvas.parentElement.getBoundingClientRect();
    W = r.width; H = r.height;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function init() {
    particles = [];
    for (var i = 0; i < 40; i++) {
      particles.push({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.3, vy: (Math.random() - 0.5) * 0.3,
        r: 0.8 + Math.random() * 1,
        color: Math.random() > 0.5 ? '0,149,255' : '124,58,237'
      });
    }
  }

  resize(); init();
  window.addEventListener('resize', function() { resize(); init(); });

  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
      for (var j = i + 1; j < particles.length; j++) {
        var q = particles[j];
        var dx = p.x - q.x, dy = p.y - q.y, d = Math.sqrt(dx * dx + dy * dy);
        if (d < 120) {
          ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = 'rgba(' + p.color + ',' + ((1 - d / 120) * 0.1) + ')';
          ctx.lineWidth = 0.5; ctx.stroke();
        }
      }
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, 6.28);
      ctx.fillStyle = 'rgba(' + p.color + ',0.4)'; ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

<!-- Upload zone interaction -->
<script>
(function() {
  var zone = document.getElementById('upload-zone');
  var defaultState = document.getElementById('upload-default');
  var hoverState = document.getElementById('upload-hover');
  var fileInput = document.getElementById('file-input');
  var pasteArea = document.getElementById('paste-area');
  var scanBtn = document.getElementById('scan-btn');
  var scoreCta = document.getElementById('score-cta');
  var bottomCta = document.getElementById('bottom-cta');

  if (!zone || !fileInput || !pasteArea || !scanBtn) return;

  async function processContent(content) {
    if (!content || !content.trim()) return;
    try { localStorage.setItem('otp_generated_oos', content); } catch(e) {}

    // Show scanning state
    scanBtn.textContent = 'Scanning...';
    scanBtn.disabled = true;
    if (defaultState) defaultState.querySelector('p.text-lg').textContent = 'Scanning your file...';

    try {
      // Call the from-text scanner directly
      var resp = await fetch('/api/v1/scanner/from-text', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: content }),
      });
      var data = await resp.json();

      if (data.score) {
        localStorage.setItem('otp_scan_result', JSON.stringify(data));
        window.location.href = '/scan-results';
        return;
      }
    } catch(e) {}

    // Fallback if scanner fails
    window.location.href = '/publish';
  }

  // Drag and drop
  zone.addEventListener('dragover', function(e) {
    e.preventDefault(); e.stopPropagation();
    if (defaultState) defaultState.classList.add('hidden');
    if (hoverState) hoverState.classList.remove('hidden');
  });
  zone.addEventListener('dragleave', function(e) {
    e.preventDefault(); e.stopPropagation();
    if (defaultState) defaultState.classList.remove('hidden');
    if (hoverState) hoverState.classList.add('hidden');
  });
  zone.addEventListener('drop', function(e) {
    e.preventDefault(); e.stopPropagation();
    if (defaultState) defaultState.classList.remove('hidden');
    if (hoverState) hoverState.classList.add('hidden');
    var file = e.dataTransfer.files[0];
    if (file) {
      var reader = new FileReader();
      reader.onload = function(ev) { processContent(ev.target.result); };
      reader.readAsText(file);
    }
  });

  // Click to upload
  zone.addEventListener('click', function(e) {
    if (e.target === pasteArea || e.target === scanBtn || pasteArea.contains(e.target)) return;
    fileInput.click();
  });
  fileInput.addEventListener('change', function() {
    var file = fileInput.files[0];
    if (file) {
      var reader = new FileReader();
      reader.onload = function(ev) { processContent(ev.target.result); };
      reader.readAsText(file);
    }
  });

  // Paste area enable/disable scan button
  pasteArea.addEventListener('input', function() {
    scanBtn.disabled = !pasteArea.value.trim();
  });
  scanBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    processContent(pasteArea.value);
  });

  // Score CTA and bottom CTA scroll to upload zone
  if (scoreCta) {
    scoreCta.addEventListener('click', function(e) {
      e.preventDefault();
      zone.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(function() { pasteArea.focus(); }, 600);
    });
  }
  if (bottomCta) {
    bottomCta.addEventListener('click', function(e) {
      e.preventDefault();
      zone.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(function() { pasteArea.focus(); }, 600);
    });
  }
})();
</script>

<!-- Score ring animation on scroll -->
<script>
(function() {
  var ring = document.querySelector('.score-ring');
  if (!ring) return;
  var animated = false;
  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !animated) {
      animated = true;
      ring.style.transition = 'stroke-dashoffset 2s cubic-bezier(0.16, 1, 0.3, 1)';
      ring.style.strokeDashoffset = '158.3';
      observer.unobserve(ring);
    }
  }, { threshold: 0.3 });

  // Start with full offset (hidden)
  ring.style.strokeDashoffset = '879.6';
  observer.observe(ring);
})();
</script>
