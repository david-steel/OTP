<%- include('../partials/orgy-palette'); %>
<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="mb-6">
    <a href="/dashboard" class="text-sm text-orgy-blue hover:text-orgy inline-flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Dashboard
    </a>
  </div>

  <%- include('../partials/ui-page-header', { helpKey: 'page.sourceDocs', mascot: 'doc', title: 'Source Documents' }) %>
  <p class="text-gray-500 text-sm mb-8">Upload source material and we will extract OOS files from it.</p>

  <!-- Upload Section -->
  <div class="bg-white rounded-xl border p-6 mb-8">
    <h2 class="font-semibold mb-4">Upload New Document</h2>
    <form id="upload-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" name="title" required class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none" placeholder="e.g. Our CLAUDE.md, Team Playbook, SOPs">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Paste Text</label>
        <textarea name="raw_text" rows="6" class="w-full border rounded-lg px-4 py-2.5 text-sm focus:border-orgy-blue focus:ring-1 focus:ring-orgy-blue outline-none resize-none font-mono" placeholder="Paste your document text here..."></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Or Upload File</label>
        <div class="border-2 border-dashed rounded-lg p-6 text-center hover:border-orgy transition-colors">
          <input type="file" name="file" id="file-input" accept=".txt,.md,.json,.yaml,.yml" class="hidden">
          <label for="file-input" class="cursor-pointer">
            <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
            <p class="text-sm text-gray-500">Click to upload .txt, .md, .json, or .yaml</p>
            <p class="text-xs text-gray-400 mt-1" id="file-name">No file selected</p>
          </label>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" id="process-btn" class="px-6 py-2.5 bg-orgy-blue text-white rounded-lg font-medium text-sm hover:bg-orgy-blue-deep transition-colors">Process</button>
        <span id="upload-status" class="text-sm"></span>
      </div>
    </form>
  </div>

  <!-- Documents List -->
  <h2 class="font-semibold mb-3">Your Documents</h2>
  <% if (typeof documents !== 'undefined' && documents.length > 0) { %>
    <div class="space-y-3">
      <% documents.forEach(function(doc) { %>
        <a href="/dashboard/source-docs/<%= doc.id %>" class="bg-white p-4 rounded-lg border claim-card flex items-center justify-between block">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-medium text-gray-900 truncate"><%= doc.title %></span>
              <%
                var statusColor = 'bg-gray-100 text-gray-600';
                if (doc.status === 'processing') statusColor = 'bg-yellow-100 text-yellow-700';
                if (doc.status === 'completed') statusColor = 'bg-green-100 text-green-700';
                if (doc.status === 'failed') statusColor = 'bg-red-100 text-red-700';
              %>
              <span class="text-xs px-2 py-0.5 rounded capitalize <%= statusColor %>"><%= doc.status %></span>
            </div>
            <div class="flex gap-4 text-xs text-gray-400">
              <span><%= doc.section_count || 0 %> sections</span>
              <span>Uploaded <%= new Date(doc.created_at).toLocaleDateString() %></span>
            </div>
          </div>
          <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-12 text-gray-400 bg-white rounded-lg border">
      <p class="text-lg mb-1">No documents uploaded yet.</p>
      <p class="text-sm">Upload a source document above to get started.</p>
    </div>
  <% } %>
</div>

<script>
document.getElementById('file-input').addEventListener('change', function() {
  var name = this.files.length > 0 ? this.files[0].name : 'No file selected';
  document.getElementById('file-name').textContent = name;
});

document.getElementById('upload-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('process-btn');
  var status = document.getElementById('upload-status');
  var form = this;
  btn.disabled = true;
  btn.textContent = 'Processing...';
  status.textContent = '';
  status.className = 'text-sm';

  var title = form.title.value.trim();
  var rawText = form.raw_text.value.trim();
  var fileInput = document.getElementById('file-input');

  // If a file is selected and no text pasted, read the file
  if (!rawText && fileInput.files.length > 0) {
    try {
      rawText = await fileInput.files[0].text();
    } catch (err) {
      status.textContent = 'Failed to read file.';
      status.className = 'text-sm text-red-600';
      btn.disabled = false;
      btn.textContent = 'Process';
      return;
    }
  }

  if (!rawText) {
    status.textContent = 'Please paste text or upload a file.';
    status.className = 'text-sm text-red-600';
    btn.disabled = false;
    btn.textContent = 'Process';
    return;
  }

  try {
    var res = await fetch('/api/v1/source-docs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: title, raw_text: rawText })
    });
    if (res.ok) {
      var data = await res.json();
      window.location.href = '/dashboard/source-docs/' + data.id;
    } else {
      var err = await res.json().catch(function() { return {}; });
      throw new Error(err.error || 'Upload failed.');
    }
  } catch (err) {
    status.textContent = err.message;
    status.className = 'text-sm text-red-600';
    btn.disabled = false;
    btn.textContent = 'Process';
  }
});
</script>
