<!-- Industry Practice Pack Header -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14 pb-10 sm:pb-14">
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
        <a href="/practices" class="hover:text-white transition-colors">Practices</a>
        <span>/</span>
        <span class="px-2 py-0.5 rounded-full bg-otp-500/20 text-otp-300 font-semibold"><%= industryName %></span>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight"><%= industryName %> AI Coordination Playbook</h1>
      <p class="text-gray-400 mt-4 max-w-lg"><%= industryDescription %></p>
      <div class="flex items-center gap-4 mt-6 text-sm text-gray-400">
        <span><strong class="text-white"><%= practiceCount %></strong> practices</span>
        <span><strong class="text-white"><%= categories.length %></strong> categories</span>
      </div>
      <div class="flex gap-3 mt-6">
        <a href="/api/v1/public/practices/<%= industrySlug %>?format=claudemd"
           class="px-5 py-2.5 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-all text-sm"
           download>
          Download CLAUDE.md
        </a>
        <a href="/generate?industry=<%= industrySlug %>"
           class="px-5 py-2.5 bg-white/5 text-white border border-white/10 rounded-lg font-semibold hover:bg-white/10 transition-all text-sm">
          Generate Custom CLAUDE.md
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Category Filter -->
<section class="bg-white border-b border-gray-100 sticky top-0 z-10">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-3">
    <div class="flex flex-wrap gap-2">
      <a href="/practices/<%= industrySlug %>"
         class="px-3 py-1.5 rounded-full text-sm font-medium transition-colors <%= !activeCategory ? 'bg-otp-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
        All (<%= practiceCount %>)
      </a>
      <% categories.forEach(function(cat) { %>
        <a href="/practices/<%= industrySlug %>?category=<%= encodeURIComponent(cat.category) %>"
           class="px-3 py-1.5 rounded-full text-sm font-medium transition-colors <%= activeCategory === cat.category ? 'bg-otp-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
          <%= cat.category %> (<%= cat.count %>)
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- Practice Cards -->
<section class="bg-white py-8 sm:py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="space-y-4">
      <% practices.forEach(function(p) { %>
        <div class="p-5 sm:p-6 rounded-xl border border-gray-100 hover:border-otp-200 transition-colors group" id="<%= p.slug %>">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= p.category %></span>
                <% if (p.evidence) { %>
                  <span class="px-2 py-0.5 rounded text-xs font-medium
                    <%= p.evidence === 'MEASURED_RESULT' ? 'bg-green-50 text-green-700' :
                       p.evidence === 'OBSERVED_REPEATEDLY' ? 'bg-blue-50 text-blue-700' :
                       'bg-purple-50 text-purple-700' %>">
                    <%= p.evidence === 'MEASURED_RESULT' ? 'Measured' :
                       p.evidence === 'OBSERVED_REPEATEDLY' ? 'Observed' : 'Rule' %>
                  </span>
                <% } %>
              </div>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-otp-600 transition-colors"><%= p.term %></h3>
              <p class="text-gray-600 mt-2 leading-relaxed"><%= p.definition %></p>
              <% if (p.failureMode) { %>
                <details class="mt-3 group/fail">
                  <summary class="text-xs font-medium text-gray-400 cursor-pointer hover:text-gray-600 transition-colors select-none flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                    What goes wrong without this
                  </summary>
                  <div class="mt-2 p-3 bg-amber-50/50 rounded-lg border border-amber-100/50">
                    <p class="text-sm text-amber-800/70 leading-relaxed"><%= p.failureMode %></p>
                  </div>
                </details>
              <% } %>
            </div>
            <!-- Useful button -->
            <div class="flex flex-col items-center shrink-0">
              <button onclick="markUseful('<%= p.id %>', this)" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 hover:border-otp-300 hover:bg-otp-50 text-gray-400 hover:text-otp-500 transition-all text-xs font-medium useful-btn" data-id="<%= p.id %>" aria-label="Mark this practice as useful">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.5c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75A2.25 2.25 0 0116.5 4.5c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H13.48a4.5 4.5 0 01-1.423-.23l-3.114-1.04a4.5 4.5 0 00-1.423-.23H3.75"/></svg>
                <span class="vote-score" data-id="<%= p.id %>"><%= p.votes?.score || 0 %></span>
              </button>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <% if (practices.length === 0) { %>
      <div class="text-center py-12 text-gray-400">
        No practices found for this category. <a href="/practices/<%= industrySlug %>" class="text-otp-500">View all practices</a>
      </div>
    <% } %>
  </div>
</section>

<!-- Newsletter Signup -->
<section class="bg-otp-950 py-12">
  <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-xl font-bold text-white mb-2">Stay in the loop</h2>
    <p class="text-gray-400 mb-6">Get weekly coordination intelligence updates. No account required.</p>
    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3">
      <input type="email" name="email" required placeholder="your@email.com"
             class="flex-1 px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500">
      <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off">
      <button type="submit"
              class="px-6 py-3 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-all whitespace-nowrap">
        Subscribe
      </button>
    </form>
    <p id="newsletter-result" class="text-sm mt-3 hidden"></p>
  </div>
</section>

<!-- Voting Script -->
<script>
async function markUseful(practiceId, btn) {
  try {
    var res = await fetch('/api/v1/public/practices/vote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bestPracticeId: practiceId, vote: 1 }),
    });
    var data = await res.json();
    if (data.score !== undefined) {
      var scoreEl = btn.querySelector('.vote-score');
      if (scoreEl) scoreEl.textContent = data.score;
      btn.classList.add('border-otp-300', 'bg-otp-50', 'text-otp-500');
      btn.classList.remove('border-gray-200', 'text-gray-400');
    }
  } catch (e) {
    console.error('Vote failed:', e);
  }
}

document.getElementById('newsletter-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target;
  const email = form.email.value;
  const honeypot = form.website.value;
  const resultEl = document.getElementById('newsletter-result');

  if (honeypot) return; // Bot detected

  try {
    const res = await fetch('/api/v1/newsletter/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, source: 'practice_page' }),
    });
    const data = await res.json();
    resultEl.classList.remove('hidden');
    if (res.ok) {
      resultEl.className = 'text-sm mt-3 text-green-400';
      resultEl.textContent = data.message || "You're in! Check your email to confirm.";
      form.email.value = '';
    } else {
      resultEl.className = 'text-sm mt-3 text-red-400';
      resultEl.textContent = data.error?.message || 'Something went wrong. Try again.';
    }
  } catch (e) {
    resultEl.classList.remove('hidden');
    resultEl.className = 'text-sm mt-3 text-red-400';
    resultEl.textContent = 'Network error. Please try again.';
  }
});
</script>
