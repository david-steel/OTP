<!-- ============================================================
     /plan — Read-only visual preview of the OTP Plan page.
     Two-column card layout inspired by Ninety's V/TO, using OUR
     labels (no ™, no V/TO branding). Static demo data from the
     Sneeze It plan; will become dynamic per workspace in a later
     pass with edit modals + DB schema.
     ============================================================ -->
<section class="bg-gray-50 min-h-screen">

  <!-- Page header — title, team selector, share toggle, archive -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 py-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-none">Plan</h1>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-otp-500 bg-otp-50 border border-otp-100 px-2 py-1 rounded">Preview</span>
        </div>
        <div class="flex flex-wrap items-center gap-3 text-sm">
          <button type="button" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-gray-700 hover:border-gray-400">
            <span class="text-xs text-gray-500">Team:</span>
            <span class="font-medium">Leadership Team</span>
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <span class="relative inline-flex h-6 w-11 items-center rounded-full bg-otp-500">
              <span class="inline-block h-4 w-4 transform rounded-full bg-white translate-x-6 transition"></span>
            </span>
            <span class="text-gray-700">Share Plan with All Teams</span>
          </label>
          <button type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-gray-600 hover:border-gray-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            Archive
          </button>
        </div>
      </div>

      <!-- Tabs -->
      <div class="mt-5 flex items-center gap-6 -mb-px border-b border-transparent">
        <button type="button" class="text-sm font-semibold pb-3 text-gray-900 border-b-2 border-pink-500">Vision</button>
        <button type="button" class="text-sm font-medium pb-3 text-gray-500 hover:text-gray-700">Traction</button>
        <button type="button" class="text-sm font-medium pb-3 text-gray-500 hover:text-gray-700">SWOT</button>
      </div>
    </div>
  </div>

  <!-- Two-column card grid -->
  <div class="max-w-7xl mx-auto px-6 sm:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-6">

      <!-- ====== LEFT COLUMN (2/3 width on lg) ====== -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Core Values -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-7 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">Core Values <span class="text-sm font-normal text-gray-500">(CHAMPS)</span></h2>
            <button type="button" class="text-gray-400 hover:text-gray-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
          </div>
          <dl class="divide-y divide-gray-100">
            <div class="px-7 py-4 grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-2 sm:gap-6">
              <dt class="text-sm font-semibold text-gray-900">Communicate With Courage</dt>
              <dd class="text-sm text-gray-600">Speak truthfully, listen actively, and create clarity, even when it's hard.</dd>
            </div>
            <div class="px-7 py-4 grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-2 sm:gap-6">
              <dt class="text-sm font-semibold text-gray-900">Heart In The Game</dt>
              <dd class="text-sm text-gray-600">Show up with passion, energy, and emotional buy-in. Play with purpose.</dd>
            </div>
            <div class="px-7 py-4 grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-2 sm:gap-6">
              <dt class="text-sm font-semibold text-gray-900">Make Each Other Better</dt>
              <dd class="text-sm text-gray-600">Elevate your teammates. Give, receive, and seek feedback. Protect the culture.</dd>
            </div>
            <div class="px-7 py-4 grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-2 sm:gap-6">
              <dt class="text-sm font-semibold text-gray-900">Push For Greatness</dt>
              <dd class="text-sm text-gray-600">Pursue excellence relentlessly. Improve constantly. Raise the bar.</dd>
            </div>
            <div class="px-7 py-4 grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-2 sm:gap-6">
              <dt class="text-sm font-semibold text-gray-900">Stay Resilient</dt>
              <dd class="text-sm text-gray-600">Adapt under pressure. Show grit in the face of challenges. Bounce back stronger, with relentless determination. Be the calm in the chaos.</dd>
            </div>
          </dl>
        </div>

        <!-- Core Focus -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-7 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">Core Focus</h2>
            <button type="button" class="text-gray-400 hover:text-gray-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
          </div>
          <div class="px-7 py-5">
            <div class="mb-5">
              <p class="text-sm font-bold text-gray-900 mb-1">Purpose</p>
              <p class="text-sm text-gray-700">PROFIT!</p>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 mb-1">Niche</p>
              <p class="text-sm text-gray-700">Delivering qualified appointments that fuel growth for membership and retention-driven businesses.</p>
            </div>
          </div>
        </div>

        <!-- 10 Year Target -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-7 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">10 Year Target</h2>
            <button type="button" class="text-gray-400 hover:text-gray-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
          </div>
          <div class="px-7 py-5">
            <p class="text-sm text-gray-700">Create a million shown appointments for membership and retention brands worldwide.</p>
          </div>
        </div>

        <!-- Go to Market Strategy -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-7 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">Go to Market Strategy</h2>
            <button type="button" class="text-gray-400 hover:text-gray-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
          </div>
          <div class="px-7 py-5 space-y-5">
            <div>
              <p class="text-sm font-bold text-gray-900 mb-1">Target Market</p>
              <p class="text-sm text-gray-700">Multi-location membership and retention brands (fitness, wellness, hospitality) with $1M-$50M revenue, an installed call center, and an executive team that already runs an operating system.</p>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 mb-1">3 Uniques</p>
              <ul class="text-sm text-gray-700 list-disc pl-5 space-y-1">
                <li>Agency-funded operating platform (clients run free)</li>
                <li>AI agents that hold the org's other agents accountable</li>
                <li>Per-client playbook compounds across the entire book</li>
              </ul>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 mb-1">Proven Process</p>
              <p class="text-sm text-gray-700">Capture, Core, Clarity, Call Center.</p>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 mb-1">Guarantee</p>
              <p class="text-sm text-gray-700">Qualified appointments delivered on a per-location basis or your money back.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- ====== RIGHT COLUMN (1/3 width on lg) ====== -->
      <div class="space-y-6">

        <!-- 3 Year -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-7 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">3 Year</h2>
            <button type="button" class="text-gray-400 hover:text-gray-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
          </div>
          <div class="px-7 py-5">
            <p class="text-sm font-bold text-gray-900 mb-1">Future Date</p>
            <p class="text-sm text-gray-700 mb-5">December 31, 2026</p>

            <p class="text-sm font-bold text-gray-900 mb-1">Revenue</p>
            <div class="flex items-baseline justify-between mb-5">
              <span class="text-sm text-gray-700">Revenue</span>
              <span class="text-sm font-medium text-gray-900">$6M</span>
            </div>

            <p class="text-sm font-bold text-gray-900 mb-1">Profit</p>
            <div class="flex items-baseline justify-between mb-5">
              <span class="text-sm text-gray-700">Net Operating Income %</span>
              <span class="text-sm font-medium text-gray-900">10</span>
            </div>

            <p class="text-sm font-bold text-gray-900 mb-3">Measurables</p>
            <p class="text-xs text-gray-500 mb-1">What Does It Look Like?</p>
            <ul class="space-y-2 mt-3">
              <% const measurables = [
                '95% Target Market Clients',
                'Strong Sales Process',
                'Successfully Expanded into New Markets',
                'Core Processes Documented and Followed By All',
                '1 Trade show per month',
                'Clear Growth Path for Employees',
                'Founding 25 Coaches on OTP',
              ]; %>
              <% measurables.forEach(m => { %>
                <li class="flex items-start gap-2.5 text-sm text-gray-700">
                  <input type="checkbox" disabled class="mt-0.5 h-4 w-4 rounded border-gray-300" />
                  <span><%= m %></span>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>

        <!-- 1 Year -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="px-7 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900">1 Year</h2>
            <button type="button" class="text-gray-400 hover:text-gray-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
          </div>
          <div class="px-7 py-5">
            <p class="text-sm font-bold text-gray-900 mb-1">Future Date</p>
            <p class="text-sm text-gray-700 mb-4">December 31, 2026</p>
            <p class="text-sm font-bold text-gray-900 mb-3">Goals</p>
            <ul class="space-y-2.5">
              <li class="flex items-start gap-2.5 text-sm text-gray-700">
                <input type="checkbox" disabled class="mt-0.5 h-4 w-4 rounded border-gray-300" />
                <span>50 OTP signups via Founding 25 coaches</span>
              </li>
              <li class="flex items-start gap-2.5 text-sm text-gray-700">
                <input type="checkbox" disabled class="mt-0.5 h-4 w-4 rounded border-gray-300" />
                <span>$2M ARR from Sneeze It</span>
              </li>
              <li class="flex items-start gap-2.5 text-sm text-gray-700">
                <input type="checkbox" disabled class="mt-0.5 h-4 w-4 rounded border-gray-300" />
                <span>Accelo → Trello migration complete</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Preview banner -->
        <div class="bg-otp-50 border border-otp-100 rounded-2xl p-5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-otp-700 mb-2">Read-only preview</p>
          <p class="text-sm text-gray-700 leading-relaxed">
            This is what your Plan will look like in OTP. Edit modals, per-team data, and live measurables wire in next. The structure is locked.
          </p>
        </div>

      </div>

    </div>
  </div>
</section>
