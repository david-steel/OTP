<%- include('../partials/api-save-handler'); %>
<style>
  .sb-shell { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; overflow: hidden; }
  .sb-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .sb-table th { background: #f9fafb; text-align: left; padding: 0.6rem 0.75rem; font-weight: 600; color: #374151; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
  .sb-table th.center, .sb-table td.center { text-align: center; }
  .sb-table th.period-col { color: #6b7280; }
  .sb-table td { padding: 0.55rem 0.75rem; border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
  .sb-table tr:hover td { background: #fafafa; }
  .sb-title { font-weight: 600; color: #111827; }
  .sb-meta { font-size: 11px; color: #9ca3af; margin-top: 0.1rem; }
  .sb-owner { display: inline-flex; align-items: center; gap: 0.4rem; }
  .sb-avatar { width: 22px; height: 22px; border-radius: 999px; background: #e5e7eb; color: #6b7280; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; }
  .sb-avatar.agent { background: #ede9fe; color: #6d28d9; }
  .sb-avatar.human { background: #fce7f3; color: #be185d; }
  .sb-goal-pill { font-size: 11px; font-weight: 700; color: #1f2937; background: #f3f4f6; padding: 0.2rem 0.55rem; border-radius: 999px; white-space: nowrap; }
  .sb-fx-pill { font-size: 10px; font-weight: 700; color: #b45309; background: #fef3c7; padding: 0.15rem 0.45rem; border-radius: 999px; margin-left: 0.3rem; }
  .sb-cell { width: 80px; text-align: center; }
  .sb-cell input { width: 100%; padding: 0.3rem 0.4rem; border: 1px solid transparent; border-radius: 4px; background: transparent; text-align: center; font-size: 13px; color: #111827; font-family: inherit; }
  .sb-cell input:focus { outline: none; border-color: #ec4899; background: #fff; box-shadow: 0 0 0 2px rgba(236,72,153,0.12); }
  .sb-cell.met { background: #ecfdf5; }
  .sb-cell.missed { background: #fef2f2; }
  .sb-cell.met input { color: #047857; font-weight: 600; }
  .sb-cell.missed input { color: #b91c1c; font-weight: 600; }
  .sb-group-header { padding: 0.85rem 1rem; background: #fff; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: space-between; }
  .sb-group-title { font-weight: 700; font-size: 15px; color: #111827; display: inline-flex; align-items: center; gap: 0.5rem; }
  .sb-group-count { font-size: 11px; font-weight: 600; color: #6b7280; background: #f3f4f6; padding: 0.15rem 0.55rem; border-radius: 999px; }
  .sb-empty { padding: 3rem 2rem; text-align: center; color: #6b7280; }
  .sb-tab-strip { display: inline-flex; gap: 0; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 4px; margin-bottom: 1rem; }
  .sb-tab { padding: 0.4rem 0.9rem; font-size: 12px; font-weight: 600; color: #6b7280; cursor: pointer; border-radius: 7px; border: none; background: transparent; }
  .sb-tab.active { background: #111827; color: #fff; }
  .sb-tab.disabled { color: #d1d5db; cursor: not-allowed; }
  .sb-filter-row { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-bottom: 1rem; }
  .sb-filter { padding: 0.45rem 0.75rem; border: 1px solid #e5e7eb; border-radius: 8px; background: #fff; font-size: 12px; color: #374151; cursor: pointer; }
  .sb-period-cell { font-size: 10px; font-weight: 600; color: #6b7280; }
  .sb-spark { width: 240px; height: 36px; }
  .sb-spark .line { fill: none; stroke: #ec4899; stroke-width: 1.5; }
  .sb-spark .area { fill: rgba(236,72,153,0.10); stroke: none; }
  .sb-spark .goal-line { stroke: #94a3b8; stroke-width: 1; stroke-dasharray: 2 3; }
  .sb-spark .dot { fill: #ec4899; }
  .sb-spark .dot.met { fill: #10b981; }
  .sb-spark .dot.missed { fill: #ef4444; }
  .sb-spark-summary { font-size: 11px; color: #6b7280; margin-top: 2px; }
  .kpi-owner-seg { display:inline-flex; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden; }
  .kpi-owner-btn { font-size:12px; font-weight:600; padding:3px 11px; background:#fff; color:#6b7280; border:none; border-left:1px solid #e5e7eb; cursor:pointer; line-height:1.4; }
  .kpi-owner-btn:first-child { border-left:none; }
  .kpi-owner-btn.active { background:#2563eb; color:#fff; }
  .kpi-owner-btn:not(.active):hover { background:#f3f4f6; }
  /* Clean per-row actions: quiet by default, reveal on row hover. */
  .sb-teamtag { display:inline-flex; align-items:center; padding:2px 9px; border-radius:9999px; font-size:10px; font-weight:600; white-space:nowrap; }
  .sb-acts { display:inline-flex; align-items:center; gap:1px; opacity:0; transition:opacity .12s ease; }
  tr:hover .sb-acts, .sb-acts:focus-within { opacity:1; }
  .sb-act { font-size:11px; font-weight:600; color:#9ca3af; background:none; border:none; cursor:pointer; padding:2px 7px; border-radius:6px; line-height:1.5; white-space:nowrap; }
  .sb-act:hover { color:#2563eb; background:#eff6ff; }
  .sb-act.danger:hover { color:#b91c1c; background:#fef2f2; }
  .sb-act-sep { width:1px; height:12px; background:#e5e7eb; margin:0 3px; }
  .sb-move { font-size:11px; color:#6b7280; border:1px solid #e5e7eb; border-radius:6px; padding:2px 5px; background:#fff; cursor:pointer; }
  tbody tr:hover { background:#fafbfc; }
  @media (hover:none) { .sb-acts { opacity:1; } }
</style>
<%- include('../partials/orgy-palette'); %>

<section class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-6 sm:pt-10 pb-6">
    <div class="flex items-center gap-3 text-xs text-gray-500 mb-3">
      <a href="/dashboard" class="hover:text-orgy-blue">Dashboard</a>
      <span>/</span>
      <span class="text-gray-700 font-medium">KPIs</span>
    </div>
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div class="flex items-center gap-3">
        <img src="/public/images/orgy/kpis.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="" class="orgy-mascot-wave w-14 sm:w-16 shrink-0" loading="eager" decoding="async">
        <div>
          <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= org.name %> &mdash; Scoreboard <button type="button" class="help-q" data-help="page.kpis" aria-label="About the Scoreboard">?</button></h1>
          <p class="text-sm text-gray-500 mt-1">Every measurable on your org chart, indexed by the seat that owns it. Add one with the <strong>+ Add KPI</strong> button, or from the <a href="/dashboard/team" class="text-orgy-blue hover:underline">Team chart</a>.</p>
        </div>
      </div>
      <% var _canAddKpi = ['owner','admin','manager','visionary','integrator'].indexOf((typeof viewerRole !== 'undefined' ? viewerRole : '') || '') >= 0; %>
      <div class="flex items-center gap-2">
        <% if (_canAddKpi) { %>
          <button id="btn-add-kpi" style="font-size:13px; font-weight:600; padding:0.4rem 0.9rem; background:#2563eb; color:#fff; border:none; border-radius:8px; cursor:pointer;" title="Add a new KPI to any seat on this scoreboard.">+ Add KPI</button>
        <% } %>
        <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
          <button id="btn-publish-all-kpis" class="text-xs px-3 py-1.5 bg-amber-50 text-amber-800 border border-amber-300 rounded-lg hover:bg-amber-100 font-semibold inline-flex items-center gap-1.5" title="Push every KPI definition into the org's OOS as a structured claim.">
            Publish all KPIs to OOS
          </button>
          <span id="publish-msg" class="text-xs text-gray-500"></span>
        <% } %>
      </div>
    </div>
  </div>
</section>

<section class="bg-gray-50 py-6 sm:py-8 min-h-[60vh]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <%
      const grainLabels = { weekly: 'Weekly', monthly: 'Monthly', quarterly: 'Quarterly', annual: 'Annual' };
      const rangeLabels = {
        weekly: 'Last 13 weeks', monthly: 'Last 12 months',
        quarterly: 'Last 8 quarters', annual: 'Last 5 years',
      };
    %>

    <% var archSuffix = (typeof showArchived !== 'undefined' && showArchived) ? '&archived=1' : ''; %>
    <div class="sb-tab-strip">
      <a class="sb-tab <%= view === 'trends' ? 'active' : '' %>" href="?grain=<%= grain %>&view=trends<%= archSuffix %>">Trends</a>
      <a class="sb-tab <%= view !== 'trends' && grain === 'weekly' ? 'active' : '' %>" href="?grain=weekly<%= archSuffix %>">Weekly</a>
      <a class="sb-tab <%= view !== 'trends' && grain === 'monthly' ? 'active' : '' %>" href="?grain=monthly<%= archSuffix %>">Monthly</a>
      <a class="sb-tab <%= view !== 'trends' && grain === 'quarterly' ? 'active' : '' %>" href="?grain=quarterly<%= archSuffix %>">Quarterly</a>
      <a class="sb-tab <%= view !== 'trends' && grain === 'annual' ? 'active' : '' %>" href="?grain=annual<%= archSuffix %>">Annual</a>
      <a class="sb-tab" style="<%= (typeof showArchived !== 'undefined' && showArchived) ? 'background:#6b7280;color:#fff;' : '' %>"
         href="?grain=<%= grain %><%= view === 'trends' ? '&view=trends' : '' %><%= (typeof showArchived !== 'undefined' && showArchived) ? '' : '&archived=1' %>"
         title="Archived KPIs are hidden everywhere by default. They are never deleted -- their history stays.">
        <%= (typeof showArchived !== 'undefined' && showArchived) ? 'Hide archived' : 'Show archived' %>
      </a>
    </div>

    <div class="sb-filter-row">
      <span class="sb-filter" title="Phase later: filter by team">Team: All</span>
      <span class="sb-filter">View by: <%= grainLabels[grain] %></span>
      <span class="sb-filter">Date Range: <%= rangeLabels[grain] %></span>
      <span class="kpi-owner-seg" role="group" aria-label="Filter KPIs by owner type">
        <button type="button" class="kpi-owner-btn active" data-mode="all">All</button>
        <button type="button" class="kpi-owner-btn" data-mode="human">Human</button>
        <button type="button" class="kpi-owner-btn" data-mode="agent">Agent</button>
      </span>
    </div>

    <!-- Shared KPIs: one metric assigned to several people, goals + actuals summed. -->
    <% var rollups = (typeof sharedRollups !== 'undefined' && sharedRollups) ? sharedRollups : []; %>
    <% var SB_OP = { gte: '≥', lte: '≤', gt: '>', lt: '<', eq: '=' }; %>
    <% if (rollups.length > 0) { %>
      <div class="sb-shell" data-shell-kind="shared" style="margin-bottom: 1.25rem;">
        <div class="sb-group-header">
          <div class="sb-group-title">Shared KPIs <span class="sb-group-count"><%= rollups.length %></span></div>
        </div>
        <div style="padding: 0.25rem 1rem 1rem;">
          <% rollups.forEach(function(rl) { %>
            <div style="border: 1px solid #e5e7eb; border-radius: 10px; padding: 0.75rem 0.9rem; margin-top: 0.75rem;">
              <div style="display:flex; align-items:baseline; justify-content:space-between; gap:0.75rem; flex-wrap:wrap;">
                <div style="font-weight:700; color:#111827; font-size:14px;"><%= rl.title %></div>
                <div style="font-size:12px; color:#6b7280;">
                  <span style="font-weight:700; color:#111827;">Total goal:</span>
                  <%= rl.goalSum == null ? '—' : ((SB_OP[rl.goalOperator] || '') + ' ' + rl.goalSum + (rl.unit ? ' ' + rl.unit : '')) %>
                  &nbsp;&middot;&nbsp;
                  <span style="font-weight:700; color:#111827;">Latest total:</span>
                  <%= rl.latestSum == null ? '—' : (rl.latestSum + (rl.unit ? ' ' + rl.unit : '')) %>
                </div>
              </div>
              <table style="width:100%; font-size:12px; margin-top:0.5rem; border-collapse:collapse;">
                <% rl.members.forEach(function(m) { %>
                  <tr>
                    <td style="padding:0.25rem 0; color:#374151;"><%= m.ownerName %></td>
                    <td style="padding:0.25rem 0; color:#6b7280; text-align:right; width:90px;">goal <%= m.goalValue == null ? '—' : m.goalValue %></td>
                    <td style="padding:0.25rem 0; color:#111827; text-align:right; font-weight:600; width:100px;">latest <%= m.latestValue == null ? '—' : m.latestValue %></td>
                    <td style="padding:0.25rem 0; text-align:right; width:80px;">
                      <button type="button" class="kpi-unshare" data-kpi-id="<%= m.kpiId %>" style="font-size:11px; color:#b91c1c; background:none; border:none; cursor:pointer;">Remove</button>
                    </td>
                  </tr>
                <% }); %>
              </table>
              <div style="margin-top:0.4rem;">
                <button type="button" class="kpi-add-person" data-kpi-id="<%= rl.members[0].kpiId %>" data-kpi-title="<%= rl.title %>" style="font-size:11px; font-weight:600; color:#2563eb; background:none; border:none; cursor:pointer; padding:0;">+ Add another person</button>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Assign-to-person panel (shared; toggled by the + person buttons) -->
    <div id="kpi-assign-panel" class="sb-shell" style="display:none; margin-bottom:1.25rem; padding:1rem;">
      <div style="font-weight:700; color:#111827; margin-bottom:0.5rem;">
        Add a person to <span id="kpi-assign-title">this KPI</span>
      </div>
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
        <select id="kpi-assign-owner" style="font-size:13px; padding:0.4rem 0.5rem; border:1px solid #e5e7eb; border-radius:6px;">
          <option value="">Pick a person...</option>
          <% (teamNodes || []).filter(function(n){ return n.type === 'human' || n.type === 'agent'; }).forEach(function(n) { %>
            <option value="<%= n.type %>:<%= n.externalId %>:<%= n.label %>"><%= n.label %></option>
          <% }); %>
        </select>
        <input id="kpi-assign-goal" type="number" step="any" placeholder="Their goal" style="width:110px; font-size:13px; padding:0.4rem 0.5rem; border:1px solid #e5e7eb; border-radius:6px;" />
        <button type="button" id="kpi-assign-submit" style="font-size:13px; font-weight:600; padding:0.4rem 0.9rem; background:#2563eb; color:#fff; border:none; border-radius:6px; cursor:pointer;">Add</button>
        <button type="button" id="kpi-assign-cancel" style="font-size:13px; padding:0.4rem 0.7rem; background:#fff; color:#6b7280; border:1px solid #e5e7eb; border-radius:6px; cursor:pointer;">Cancel</button>
      </div>
      <p style="font-size:11px; color:#9ca3af; margin-top:0.4rem;">Each person reports their own number. The scorecard sums the goals and the actuals.</p>
    </div>

    <!-- Edit-KPI panel (toggled by the per-row "edit" buttons). Always rendered
         (hidden by default); only admins get edit buttons to open it. NOTE: do
         not gate on isKpiAdmin here -- that const is scoped to the row loop. -->
    <div id="kpi-edit-panel" class="sb-shell" style="display:none; margin-bottom:1.25rem; padding:1rem;">
      <div id="ke-panel-title" style="font-weight:700; color:#111827; margin-bottom:0.75rem;">Edit KPI</div>
      <% var keInput = 'width:100%; font-size:13px; padding:0.4rem 0.5rem; border:1px solid #e5e7eb; border-radius:6px;'; var keLabel = 'display:flex; flex-direction:column; gap:0.25rem; font-size:12px; font-weight:600; color:#374151;';
         var _allGroups = Array.from(new Set([].concat(
           (typeof kpiGroupOrder !== 'undefined' && Array.isArray(kpiGroupOrder)) ? kpiGroupOrder : [],
           (scoreboard.rows || []).map(function(r){ return r.kpi && r.kpi.groupName; }).filter(Boolean)
         ))).sort(); %>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; max-width:780px;">
        <label style="<%= keLabel %>; grid-column:1/3;">Name<input id="ke-title" type="text" style="<%= keInput %>" /></label>
        <label style="<%= keLabel %>; grid-column:1/3;">Comments / description<textarea id="ke-desc" rows="2" style="<%= keInput %>"></textarea></label>
        <label style="<%= keLabel %>">Owner (person)
          <select id="ke-owner" style="<%= keInput %>">
            <option value="">(unchanged)</option>
            <% (teamNodes || []).filter(function(n){ return n.type === 'human' || n.type === 'agent'; }).forEach(function(n) { %>
              <option value="<%= n.type %>:<%= n.externalId %>"><%= n.label %><%= n.type === 'agent' ? ' (agent)' : '' %></option>
            <% }); %>
          </select>
        </label>
        <label style="<%= keLabel %>">Team
          <select id="ke-team" style="<%= keInput %>">
            <option value="">(no team)</option>
            <% (orgTeams || []).forEach(function(tm) { %><option value="<%= tm.id %>"><%= tm.name %></option><% }); %>
          </select>
        </label>
        <label style="<%= keLabel %>">Group
          <select id="ke-group" style="<%= keInput %>">
            <option value="">No group (Other)</option>
            <% _allGroups.forEach(function(g) { %><option value="<%= g %>"><%= g %></option><% }); %>
            <option value="__new__">➕ New group&hellip;</option>
          </select>
          <input id="ke-group-new" type="text" placeholder="New group name" style="<%= keInput %>; display:none; margin-top:4px;" />
        </label>
        <label style="<%= keLabel %>">Goal
          <span style="display:flex; gap:4px;">
            <select id="ke-goalop" style="<%= keInput %>; flex:0 0 84px;">
              <option value="">none</option>
              <option value="gte">≥</option><option value="lte">≤</option>
              <option value="gt">&gt;</option><option value="lt">&lt;</option><option value="eq">=</option>
            </select>
            <input id="ke-goalval" type="number" step="any" placeholder="target" style="<%= keInput %>" />
          </span>
        </label>
        <label style="<%= keLabel %>">Unit<input id="ke-unit" type="text" placeholder="e.g. calls" style="<%= keInput %>" /></label>
        <label style="<%= keLabel %>">Cadence
          <select id="ke-grain" style="<%= keInput %>">
            <option value="weekly">Weekly</option><option value="monthly">Monthly</option>
            <option value="quarterly">Quarterly</option><option value="annual">Annual</option>
          </select>
        </label>
        <label style="<%= keLabel %>">Aggregation
          <select id="ke-agg" style="<%= keInput %>">
            <option value="sum">Sum</option><option value="avg">Average</option><option value="last">Last</option>
            <option value="first">First</option><option value="min">Min</option><option value="max">Max</option>
          </select>
        </label>
        <label style="<%= keLabel %>; grid-column:1/3;">Formula <span style="font-weight:400; color:#9ca3af;">(optional, for computed KPIs)</span><input id="ke-formula" type="text" placeholder="e.g. demos_booked / conversations" style="<%= keInput %>" /></label>
        <label style="display:flex; align-items:center; gap:0.5rem; font-size:13px; color:#374151; grid-column:1/3;"><input id="ke-archived" type="checkbox" /> Archived (hidden from default views, history kept)</label>
      </div>
      <div style="margin-top:0.85rem; display:flex; gap:0.5rem;">
        <button type="button" id="ke-save" style="font-size:13px; font-weight:600; padding:0.45rem 1rem; background:#2563eb; color:#fff; border:none; border-radius:6px; cursor:pointer;">Save changes</button>
        <button type="button" id="ke-cancel" style="font-size:13px; padding:0.45rem 0.8rem; background:#fff; color:#6b7280; border:1px solid #e5e7eb; border-radius:6px; cursor:pointer;">Cancel</button>
      </div>
    </div>

    <% var _kpiAdminTop = ['owner','admin','manager','visionary','integrator'].indexOf((typeof viewerRole !== 'undefined' ? viewerRole : '') || '') >= 0; %>
    <% if (_kpiAdminTop) { %>
    <div style="display:flex; justify-content:flex-end; margin-bottom:0.6rem;">
      <button type="button" id="kg-open" style="font-size:12px; font-weight:600; color:#6b7280; background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:0.4rem 0.8rem; cursor:pointer;">Manage groups</button>
    </div>
    <div id="kpi-groups-panel" class="sb-shell" style="display:none; margin-bottom:1.25rem; padding:1rem;">
      <div style="font-weight:700; color:#111827; margin-bottom:0.4rem;">Manage groups</div>
      <p style="font-size:11px; color:#9ca3af; margin:0 0 0.75rem;">Reorder with the arrows. Rename or delete a group (its KPIs become ungrouped, never deleted). New groups also show up in each KPI's Edit dropdown.</p>
      <div id="kg-list" style="display:flex; flex-direction:column; gap:6px; max-width:560px;"><div style="color:#9ca3af; font-size:13px;">Loading…</div></div>
      <div style="display:flex; gap:0.5rem; margin-top:0.85rem; max-width:560px;">
        <input id="kg-new" type="text" placeholder="New group name" style="flex:1; font-size:13px; padding:0.4rem 0.5rem; border:1px solid #e5e7eb; border-radius:6px;" />
        <button type="button" id="kg-add" style="font-size:13px; font-weight:600; padding:0.4rem 0.9rem; background:#2563eb; color:#fff; border:none; border-radius:6px; cursor:pointer;">Add group</button>
        <button type="button" id="kg-close" style="font-size:13px; padding:0.4rem 0.7rem; background:#fff; color:#6b7280; border:1px solid #e5e7eb; border-radius:6px; cursor:pointer;">Close</button>
      </div>
    </div>
    <% } %>

    <% if (scoreboard.rows.length === 0) { %>
      <div class="sb-shell sb-empty">
        <p style="font-size:14px; margin-bottom:0.5rem;"><strong>No KPIs yet.</strong></p>
        <p style="font-size:13px; margin-bottom:0.75rem;">Add one right here, or from the <a href="/dashboard/team" class="text-orgy-blue hover:underline">Team chart</a> on any seat.</p>
        <% if (_kpiAdminTop) { %>
          <button id="btn-add-kpi-empty" style="font-size:13px; font-weight:600; padding:0.45rem 1rem; background:#2563eb; color:#fff; border:none; border-radius:8px; cursor:pointer;">+ Add your first KPI</button>
        <% } %>
      </div>
    <% } else { %>
      <%
        // Group rows by group_name (null -> 'Other')
        const grouped = new Map();
        scoreboard.rows.forEach(r => {
          const g = r.kpi.groupName || 'Other';
          if (!grouped.has(g)) grouped.set(g, []);
          grouped.get(g).push(r);
        });
        const _kgOrder = (typeof kpiGroupOrder !== 'undefined' && Array.isArray(kpiGroupOrder)) ? kpiGroupOrder : [];
        const _kgIdx = (name) => { const i = _kgOrder.indexOf(name); return i === -1 ? 9999 : i; };
        const groupOrder = Array.from(grouped.keys()).sort((a, b) => {
          if (a === 'Winning Scoreboard') return -1;
          if (b === 'Winning Scoreboard') return 1;
          if (a === 'Other') return 1;
          if (b === 'Other') return -1;
          const ia = _kgIdx(a), ib = _kgIdx(b);
          if (ia !== ib) return ia - ib;
          return a.localeCompare(b);
        });
        // Owner lookup
        const ownerByExt = new Map();
        teamNodes.forEach(n => ownerByExt.set(n.externalId, n));
      %>

      <% groupOrder.forEach(function(group) { %>
        <% const rows = grouped.get(group); %>
        <div class="sb-shell" style="margin-bottom: 1.25rem;">
          <div class="sb-group-header">
            <div class="sb-group-title"><%= group %> <span class="sb-group-count"><%= rows.length %></span></div>
          </div>
          <div style="overflow-x: auto;">
            <table class="sb-table">
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Owner</th>
                  <th class="center">Goal</th>
                  <% if (view === 'trends') { %>
                    <th class="center">Latest</th>
                    <th class="center">Trend (<%= rangeLabels[grain] %>)</th>
                  <% } else { %>
                    <th class="center">Average</th>
                    <th class="center">Total</th>
                    <% periodLabels.forEach(function(label) { %>
                      <th class="center period-col"><%= label %></th>
                    <% }); %>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach(function(row) {
                  const k = row.kpi;
                  const owner = ownerByExt.get(k.ownerExternalId);
                  const ownerName = owner ? (owner.label || k.ownerExternalId) : k.ownerExternalId;
                  const ownerInitials = (owner ? (owner.label || '?') : '?').slice(0, 2).toUpperCase();
                  const goalText = (k.goalOperator && k.goalValue !== null && k.goalValue !== undefined)
                    ? ({ gte: '≥', lte: '≤', gt: '>', lt: '<', eq: '=' })[k.goalOperator] + ' ' + k.goalValue + (k.unit ? ' ' + k.unit : '')
                    : '—';
                  // Latest non-null value (rightmost period with data)
                  let latestVal = null;
                  for (let i = row.periods.length - 1; i >= 0; i--) {
                    if (row.periods[i].value !== null && row.periods[i].value !== undefined) { latestVal = row.periods[i].value; break; }
                  }
                %>
                  <%
                    const kpiTeam = (orgTeams || []).find(function(t) { return t.id === k.teamId; });
                    const isKpiAdmin = ['owner','admin','manager','visionary','integrator'].indexOf(viewerRole || '') >= 0;
                  %>
                  <tr data-kpi-id="<%= k.id %>" data-owner-type="<%= k.ownerEntityType %>" data-goal-op="<%= k.goalOperator || '' %>" data-goal-value="<%= k.goalValue == null ? '' : k.goalValue %>"<% if (k.archivedAt) { %> style="opacity:0.55;"<% } %>>
                    <td>
                      <div class="sb-title"><%= k.title %><% if (k.formula) { %><span class="sb-fx-pill">fx</span><% } %><% if (k.archivedAt) { %><span style="margin-left:6px; display:inline-flex; align-items:center; padding:1px 8px; background:#f3f4f6; color:#6b7280; border:1px solid #d1d5db; border-radius:9999px; font-size:10px; font-weight:600;" title="Archived <%= new Date(k.archivedAt).toLocaleDateString() %> -- hidden from default views, history preserved">Archived</span><% } %></div>
                      <% if (k.description) { %><div class="sb-meta"><%= k.description.length > 70 ? k.description.slice(0, 70) + '...' : k.description %></div><% } %>
                      <div style="margin-top:5px; display:flex; align-items:center; gap:8px;">
                        <% if (kpiTeam) { %>
                          <span class="sb-teamtag" style="background:#eef2ff; color:#3730a3; border:1px solid #c7d2fe;"><%= kpiTeam.name %></span>
                        <% } else { %>
                          <span class="sb-teamtag" style="background:#fef3c7; color:#92400e; border:1px solid #fde68a;">no team</span>
                        <% } %>
                        <% if (isKpiAdmin) { %>
                          <span class="sb-acts">
                            <button type="button" class="kpi-edit-btn sb-act" data-kpi="<%= JSON.stringify({ id: k.id, title: k.title, description: k.description || '', groupName: k.groupName || '', ownerEntityType: k.ownerEntityType, ownerExternalId: k.ownerExternalId, goalOperator: k.goalOperator || '', goalValue: (k.goalValue == null ? '' : k.goalValue), unit: k.unit || '', timeGrain: k.timeGrain || 'weekly', aggregationMethod: k.aggregationMethod || 'sum', formula: k.formula || '', teamId: k.teamId || '', archived: !!k.archivedAt }) %>" title="Edit name, description, owner, team, goal, formula, and more">Edit</button>
                            <button type="button" class="kpi-add-person sb-act" data-kpi-id="<%= k.id %>" data-kpi-title="<%= k.title %>" title="Assign this KPI to another person too">Add person</button>
                            <% if ((orgTeams || []).length > 0) { %>
                              <select class="kpi-team-mover sb-move" title="Move this KPI to a different team">
                                <option value="">Move&hellip;</option>
                                <% (orgTeams || []).forEach(function(tm) { if (tm.id === k.teamId) return; %>
                                  <option value="<%= tm.id %>"><%= tm.name %></option>
                                <% }); %>
                              </select>
                            <% } %>
                            <span class="sb-act-sep"></span>
                            <% if (k.archivedAt) { %>
                              <button type="button" class="kpi-archive-btn sb-act" data-kpi-id="<%= k.id %>" data-archived="1" title="Restore this KPI to the active scoreboard">Unarchive</button>
                            <% } else { %>
                              <button type="button" class="kpi-archive-btn sb-act danger" data-kpi-id="<%= k.id %>" data-archived="" title="Archive this KPI: hidden from default views, history kept, unarchive anytime.">Archive</button>
                            <% } %>
                          </span>
                        <% } %>
                      </div>
                    </td>
                    <td>
                      <span class="sb-owner">
                        <span class="sb-avatar <%= k.ownerEntityType %>"><%= ownerInitials %></span>
                        <span style="font-size:12px; color:#374151;"><%= ownerName %></span>
                      </span>
                    </td>
                    <td class="center"><span class="sb-goal-pill"><%= goalText %></span></td>
                    <% if (view === 'trends') { %>
                      <td class="center" style="font-weight:600; color:#111827;"><%= latestVal === null ? '—' : (Math.round(latestVal * 100) / 100) + (k.unit ? ' ' + k.unit : '') %></td>
                      <td class="center">
                        <div class="sb-spark-wrap" data-periods='<%= JSON.stringify(row.periods.map(p => p.value)) %>' data-goal-op="<%= k.goalOperator || '' %>" data-goal-value="<%= k.goalValue == null ? '' : k.goalValue %>"></div>
                      </td>
                    <% } else { %>
                      <td class="center" data-col="avg">—</td>
                      <td class="center" data-col="total">—</td>
                      <% row.periods.forEach(function(p) { %>
                        <td class="center sb-cell" data-period-start="<%= p.periodStart %>">
                          <input type="number" step="any" value="<%= p.value == null ? '' : p.value %>"
                                 data-orig="<%= p.value == null ? '' : p.value %>"
                                 placeholder="—" />
                        </td>
                      <% }); %>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% }); %>
    <% } %>

  </div>
</section>

<script>
  function meetsGoal(value, op, target) {
    if (value === null || value === '' || isNaN(value)) return null;
    if (!op || target === null || target === '' || isNaN(target)) return null;
    var v = Number(value), t = Number(target);
    switch (op) {
      case 'gte': return v >= t;
      case 'lte': return v <= t;
      case 'gt':  return v > t;
      case 'lt':  return v < t;
      case 'eq':  return v === t;
    }
    return null;
  }

  function recomputeRowSummary(tr) {
    var inputs = tr.querySelectorAll('.sb-cell input');
    var nums = [];
    inputs.forEach(function(inp) {
      if (inp.value !== '' && !isNaN(Number(inp.value))) nums.push(Number(inp.value));
    });
    var avg = nums.length === 0 ? null : nums.reduce(function(a, b) { return a + b; }, 0) / nums.length;
    var total = nums.length === 0 ? null : nums.reduce(function(a, b) { return a + b; }, 0);
    var avgEl = tr.querySelector('[data-col="avg"]');
    var totalEl = tr.querySelector('[data-col="total"]');
    if (avgEl) avgEl.textContent = avg === null ? '—' : Math.round(avg * 100) / 100;
    if (totalEl) totalEl.textContent = total === null ? '—' : Math.round(total * 100) / 100;
  }

  function paintRowGoals(tr) {
    var op = tr.getAttribute('data-goal-op');
    var target = tr.getAttribute('data-goal-value');
    tr.querySelectorAll('.sb-cell').forEach(function(td) {
      td.classList.remove('met', 'missed');
      var inp = td.querySelector('input');
      if (!inp || inp.value === '') return;
      var meets = meetsGoal(inp.value, op, target);
      if (meets === true) td.classList.add('met');
      else if (meets === false) td.classList.add('missed');
    });
  }

  function renderSpark(wrap) {
    var values;
    try { values = JSON.parse(wrap.getAttribute('data-periods') || '[]'); } catch (e) { values = []; }
    if (!Array.isArray(values) || values.length === 0) { wrap.innerHTML = '<span style="color:#9ca3af; font-size:11px;">no data</span>'; return; }
    var op = wrap.getAttribute('data-goal-op') || '';
    var goalVal = wrap.getAttribute('data-goal-value');
    goalVal = goalVal === '' || goalVal == null ? null : Number(goalVal);

    var W = 240, H = 36, pad = 4;
    var nums = values.map(function(v) { return v === null || v === undefined ? null : Number(v); });
    var present = nums.filter(function(v) { return v !== null && !isNaN(v); });
    if (present.length === 0) { wrap.innerHTML = '<span style="color:#9ca3af; font-size:11px;">no data</span>'; return; }
    var min = Math.min.apply(null, present);
    var max = Math.max.apply(null, present);
    if (goalVal !== null && !isNaN(goalVal)) { min = Math.min(min, goalVal); max = Math.max(max, goalVal); }
    var range = max - min || 1;
    var n = nums.length;
    var x = function(i) { return pad + (i * (W - 2 * pad)) / Math.max(1, n - 1); };
    var y = function(v) { return H - pad - ((v - min) / range) * (H - 2 * pad); };

    var ptStr = '';
    var areaPts = [];
    var dots = '';
    var lastValid = null;
    nums.forEach(function(v, i) {
      if (v === null || isNaN(v)) return;
      var px = x(i), py = y(v);
      if (ptStr === '') ptStr = px + ',' + py;
      else ptStr += ' ' + px + ',' + py;
      areaPts.push([px, py]);
      var dotClass = 'dot';
      if (op && goalVal !== null) {
        var meets = (op === 'gte' ? v >= goalVal : op === 'lte' ? v <= goalVal : op === 'gt' ? v > goalVal : op === 'lt' ? v < goalVal : op === 'eq' ? v === goalVal : null);
        if (meets === true) dotClass = 'dot met';
        else if (meets === false) dotClass = 'dot missed';
      }
      dots += '<circle cx="' + px + '" cy="' + py + '" r="2" class="' + dotClass + '"/>';
      lastValid = { x: px, y: py };
    });
    var area = '';
    if (areaPts.length > 1) {
      area = 'M ' + areaPts[0][0] + ',' + (H - pad) + ' L ' + areaPts.map(function(p) { return p[0] + ',' + p[1]; }).join(' L ') + ' L ' + areaPts[areaPts.length - 1][0] + ',' + (H - pad) + ' Z';
    }
    var goalLine = '';
    if (goalVal !== null && !isNaN(goalVal)) {
      var gy = y(goalVal);
      goalLine = '<line x1="' + pad + '" y1="' + gy + '" x2="' + (W - pad) + '" y2="' + gy + '" class="goal-line"/>';
    }
    var svg = '<svg class="sb-spark" viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="none">'
      + (area ? '<path class="area" d="' + area + '"/>' : '')
      + goalLine
      + (ptStr ? '<polyline class="line" points="' + ptStr + '"/>' : '')
      + dots
      + '</svg>';
    wrap.innerHTML = svg;
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.sb-spark-wrap').forEach(renderSpark);
    document.querySelectorAll('tr[data-kpi-id]').forEach(function(tr) {
      recomputeRowSummary(tr);
      paintRowGoals(tr);
    });

    var publishBtn = document.getElementById('btn-publish-all-kpis');
    var publishMsg = document.getElementById('publish-msg');
    if (publishBtn) {
      publishBtn.addEventListener('click', function() {
        if (!confirm('Push every KPI definition into your published OOS as a structured claim? This is load-bearing — agents reading the OOS will see what each seat is measured on.')) return;
        OTP.apiSave({
          method: 'POST', url: '/api/v1/kpis/publish-all',
          msgEl: publishMsg, btnEl: publishBtn,
          errorContext: 'Publish all KPIs',
          onSuccess: function(data) {
            var failed = (data.failed && data.failed.length) || 0;
            publishMsg.textContent = 'Published ' + data.published + ' KPI' + (data.published === 1 ? '' : 's') + (failed > 0 ? '; ' + failed + ' failed' : '') + '.';
            publishMsg.style.color = '#047857';
          },
        });
      });
    }

    document.querySelectorAll('.sb-cell input').forEach(function(inp) {
      inp.addEventListener('blur', function() {
        var tr = inp.closest('tr');
        var td = inp.closest('.sb-cell');
        var kpiId = tr.getAttribute('data-kpi-id');
        var periodStart = td.getAttribute('data-period-start');
        var orig = inp.getAttribute('data-orig') || '';
        var newVal = inp.value;
        if (orig === newVal) return;
        var saveOpts;
        if (newVal === '') {
          saveOpts = {
            method: 'DELETE',
            url: '/api/v1/kpis/' + encodeURIComponent(kpiId) + '/values?periodStart=' + encodeURIComponent(periodStart),
            errorContext: 'Delete KPI value',
          };
        } else {
          saveOpts = {
            method: 'POST',
            url: '/api/v1/kpis/' + encodeURIComponent(kpiId) + '/values',
            body: { periodStart: periodStart, value: Number(newVal) },
            errorContext: 'Save KPI value',
          };
        }
        // Optimistic: input already shows newVal. Rollback to orig in
        // onError; the helper then surfaces the real server message
        // (e.g. "value must be a number", "period is closed") instead
        // of "Save failed: 422".
        saveOpts.onError = function() { inp.value = orig; };
        saveOpts.onSuccess = function() {
          inp.setAttribute('data-orig', newVal);
          recomputeRowSummary(tr);
          paintRowGoals(tr);
        };
        OTP.apiSave(saveOpts);
      });
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); inp.blur(); }
      });
    });

    // KPI team mover -- admin-only dropdown next to each KPI title.
    document.querySelectorAll('.kpi-team-mover').forEach(function(sel) {
      sel.addEventListener('change', function(e) {
        var newTeamId = e.currentTarget.value;
        if (!newTeamId) return;
        var tr = e.currentTarget.closest('tr');
        if (!tr) return;
        var kpiId = tr.dataset.kpiId;
        OTP.apiSave({
          method: 'PATCH', url: '/api/v1/kpis/' + encodeURIComponent(kpiId),
          body: { teamId: newTeamId },
          btnEl: e.currentTarget,
          errorContext: 'Move KPI to team',
          onSuccess: function() {
            // Fade the row out -- it now belongs to a different team scoreboard.
            tr.style.transition = 'opacity 0.25s';
            tr.style.opacity = '0';
            setTimeout(function(){ tr.remove(); }, 250);
          },
          onError: function() { e.currentTarget.value = ''; },
        });
      });
    });

    // KPI archive / unarchive -- soft retirement, never a delete. The KPI
    // and its full value history stay in the database; archived KPIs are
    // hidden from every default list and reachable via the Show-archived tab.
    document.querySelectorAll('.kpi-archive-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var kpiId = btn.getAttribute('data-kpi-id');
        var isArchived = btn.getAttribute('data-archived') === '1';
        if (!isArchived && !confirm('Archive this KPI? It disappears from the scoreboard, the dashboard, and meeting snapshots, but nothing is deleted -- the full history is kept and you can unarchive it anytime from the Show archived view.')) return;
        OTP.apiSave({
          method: 'PATCH', url: '/api/v1/kpis/' + encodeURIComponent(kpiId),
          body: { archived: !isArchived },
          btnEl: btn,
          errorContext: isArchived ? 'Unarchive KPI' : 'Archive KPI',
          onSuccess: function() { location.reload(); },
        });
      });
    });

    // --- Edit KPI: name, description, owner, team, goal, unit, cadence, formula, archive ---
    (function() {
      var panel = document.getElementById('kpi-edit-panel');
      if (!panel) return;
      var $ = function(id){ return document.getElementById(id); };
      var cur = null;
      var mode = 'edit'; // 'edit' (PATCH existing) | 'create' (POST new)

      // Open the same panel in "create" mode: blank fields, owner required,
      // ke-save POSTs a new KPI instead of patching one. Lets a KPI be added
      // straight from the Scoreboard instead of only from the Team chart.
      function openCreate() {
        mode = 'create';
        cur = { id: null };
        var t = $('ke-panel-title'); if (t) t.textContent = 'Add KPI';
        var sb = $('ke-save'); if (sb) sb.textContent = 'Create KPI';
        var os = $('ke-owner'); if (os && os.options.length) os.options[0].text = '— Select owner —';
        $('ke-title').value = '';
        $('ke-desc').value = '';
        $('ke-owner').value = '';
        $('ke-team').value = '';
        if ($('ke-group')) $('ke-group').value = '';
        if ($('ke-group-new')) { $('ke-group-new').style.display = 'none'; $('ke-group-new').value = ''; }
        $('ke-goalop').value = '';
        $('ke-goalval').value = '';
        $('ke-unit').value = '';
        $('ke-grain').value = 'weekly';
        $('ke-agg').value = 'sum';
        $('ke-formula').value = '';
        $('ke-archived').checked = false;
        panel.style.display = 'block';
        panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      var addBtn = $('btn-add-kpi'); if (addBtn) addBtn.addEventListener('click', openCreate);
      var addBtnEmpty = $('btn-add-kpi-empty'); if (addBtnEmpty) addBtnEmpty.addEventListener('click', openCreate);

      document.querySelectorAll('.kpi-edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          try { cur = JSON.parse(btn.getAttribute('data-kpi') || 'null'); } catch (e) { cur = null; }
          if (!cur) return;
          mode = 'edit';
          var t = $('ke-panel-title'); if (t) t.textContent = 'Edit KPI';
          var sb = $('ke-save'); if (sb) sb.textContent = 'Save changes';
          var os = $('ke-owner'); if (os && os.options.length) os.options[0].text = '(unchanged)';
          $('ke-title').value = cur.title || '';
          $('ke-desc').value = cur.description || '';
          $('ke-owner').value = (cur.ownerEntityType && cur.ownerExternalId) ? (cur.ownerEntityType + ':' + cur.ownerExternalId) : '';
          $('ke-team').value = cur.teamId || '';
          if ($('ke-group')) $('ke-group').value = cur.groupName || '';
          if ($('ke-group-new')) { $('ke-group-new').style.display = 'none'; $('ke-group-new').value = ''; }
          $('ke-goalop').value = cur.goalOperator || '';
          $('ke-goalval').value = (cur.goalValue === '' || cur.goalValue == null) ? '' : cur.goalValue;
          $('ke-unit').value = cur.unit || '';
          $('ke-grain').value = cur.timeGrain || 'weekly';
          $('ke-agg').value = cur.aggregationMethod || 'sum';
          $('ke-formula').value = cur.formula || '';
          $('ke-archived').checked = !!cur.archived;
          panel.style.display = 'block';
          panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });
      var cancel = $('ke-cancel');
      if (cancel) cancel.addEventListener('click', function() { panel.style.display = 'none'; cur = null; });
      var grpSel = $('ke-group');
      if (grpSel) grpSel.addEventListener('change', function() {
        var nv = $('ke-group-new');
        if (!nv) return;
        if (grpSel.value === '__new__') { nv.style.display = 'block'; nv.focus(); }
        else { nv.style.display = 'none'; }
      });
      var save = $('ke-save');
      if (save) save.addEventListener('click', function() {
        if (!cur) return;
        var title = ($('ke-title').value || '').trim();
        if (!title) { alert('Name is required.'); return; }
        var goalop = $('ke-goalop').value;
        var goalvalRaw = $('ke-goalval').value;
        if (goalop && (goalvalRaw === '' || isNaN(Number(goalvalRaw)))) {
          alert('Enter a goal value, or set the goal to "none".'); return;
        }
        if (mode === 'create') {
          var ownerValC = $('ke-owner').value;
          if (!ownerValC) { alert('Pick an owner -- the seat this KPI belongs to.'); return; }
          var pc = ownerValC.split(':');
          // createSchema requires ownerEntityType + ownerExternalId + title;
          // groupName/description are optional-but-NOT-nullable, so omit when
          // blank rather than send null (null would 400).
          var bodyC = {
            ownerEntityType: pc[0],
            ownerExternalId: pc.slice(1).join(':'),
            title: title,
            timeGrain: $('ke-grain').value,
            aggregationMethod: $('ke-agg').value,
          };
          var descC = ($('ke-desc').value || '').trim(); if (descC) bodyC.description = descC;
          var unitC = ($('ke-unit').value || '').trim(); if (unitC) bodyC.unit = unitC;
          var formulaC = ($('ke-formula').value || '').trim(); if (formulaC) bodyC.formula = formulaC;
          var teamC = $('ke-team').value; if (teamC) bodyC.teamId = teamC;
          var grpC = (function(){ var g = $('ke-group'); if (!g) return ''; if (g.value === '__new__') { return (($('ke-group-new').value || '').trim()); } return g.value || ''; })();
          if (grpC) bodyC.groupName = grpC;
          if (goalop) { bodyC.goalOperator = goalop; bodyC.goalValue = Number(goalvalRaw); }
          OTP.apiSave({
            method: 'POST', url: '/api/v1/kpis',
            body: bodyC, btnEl: save, errorContext: 'Add KPI',
            onSuccess: function() { location.reload(); },
          });
          return;
        }
        var body = {
          title: title,
          description: (($('ke-desc').value || '').trim()) || null,
          unit: (($('ke-unit').value || '').trim()) || null,
          timeGrain: $('ke-grain').value,
          aggregationMethod: $('ke-agg').value,
          formula: (($('ke-formula').value || '').trim()) || null,
          archived: $('ke-archived').checked,
          teamId: $('ke-team').value || null,
          groupName: (function() {
            var g = $('ke-group'); if (!g) return undefined;
            if (g.value === '__new__') { return (($('ke-group-new').value || '').trim()) || null; }
            return g.value || null;
          })(),
        };
        if (goalop) { body.goalOperator = goalop; body.goalValue = Number(goalvalRaw); }
        else { body.goalOperator = null; body.goalValue = null; }
        var ownerVal = $('ke-owner').value;
        if (ownerVal) { var p = ownerVal.split(':'); body.ownerEntityType = p[0]; body.ownerExternalId = p.slice(1).join(':'); }
        OTP.apiSave({
          method: 'PATCH', url: '/api/v1/kpis/' + encodeURIComponent(cur.id),
          body: body, btnEl: save, errorContext: 'Edit KPI',
          onSuccess: function() { location.reload(); },
        });
      });
    })();

    // --- Manage groups: reorder (arrows), add, rename, delete ---
    (function() {
      var openBtn = document.getElementById('kg-open');
      var panel = document.getElementById('kpi-groups-panel');
      if (!openBtn || !panel) return;
      var listEl = document.getElementById('kg-list');
      var groups = [];
      var dirty = false;

      function load() {
        fetch('/api/v1/kpi-groups', { headers: { 'Accept': 'application/json' } })
          .then(function(r) { return r.json(); })
          .then(function(d) { groups = (d && d.groups) || []; render(); })
          .catch(function() { listEl.innerHTML = '<div style="color:#b91c1c;font-size:13px;">Could not load groups.</div>'; });
      }
      function mkBtn(label, disabled, fn, danger) {
        var b = document.createElement('button'); b.type = 'button'; b.textContent = label;
        b.style.cssText = 'font-size:12px;font-weight:600;background:none;border:none;cursor:pointer;padding:2px 7px;border-radius:6px;color:' + (danger ? '#b91c1c' : '#6b7280') + ';' + (disabled ? 'opacity:0.3;pointer-events:none;' : '');
        if (!disabled) b.addEventListener('click', fn);
        return b;
      }
      function render() {
        if (!groups.length) { listEl.innerHTML = '<div style="color:#9ca3af;font-size:13px;">No groups yet. Add one below, then move KPIs into it from each KPI\'s Edit.</div>'; return; }
        listEl.innerHTML = '';
        groups.forEach(function(g, i) {
          var row = document.createElement('div');
          row.style.cssText = 'display:flex;align-items:center;gap:6px;padding:6px 10px;border:1px solid #e5e7eb;border-radius:8px;background:#fff;';
          var nm = document.createElement('span'); nm.style.cssText = 'flex:1;font-size:13px;font-weight:600;color:#111827;';
          nm.textContent = g.name + ' ';
          var cnt = document.createElement('span'); cnt.style.cssText = 'color:#9ca3af;font-weight:400;font-size:11px;'; cnt.textContent = '(' + (g.kpiCount || 0) + ')';
          nm.appendChild(cnt); row.appendChild(nm);
          row.appendChild(mkBtn('↑', i === 0, function() { move(i, -1); }));
          row.appendChild(mkBtn('↓', i === groups.length - 1, function() { move(i, 1); }));
          row.appendChild(mkBtn('rename', false, function() { rename(g.name); }));
          row.appendChild(mkBtn('delete', false, function() { del(g.name, g.kpiCount || 0); }, true));
          listEl.appendChild(row);
        });
      }
      function persistOrder() {
        OTP.apiSave({ method: 'PATCH', url: '/api/v1/kpi-groups/reorder', body: { names: groups.map(function(g) { return g.name; }) }, errorContext: 'Reorder groups' });
      }
      function move(i, dir) {
        var j = i + dir; if (j < 0 || j >= groups.length) return;
        var t = groups[i]; groups[i] = groups[j]; groups[j] = t; dirty = true; render(); persistOrder();
      }
      function rename(from) {
        var to = window.prompt('Rename group "' + from + '" to:', from); if (to == null) return; to = to.trim();
        if (!to || to === from) return;
        OTP.apiSave({ method: 'PATCH', url: '/api/v1/kpi-groups/rename', body: { from: from, to: to }, errorContext: 'Rename group', onSuccess: function() { location.reload(); } });
      }
      function del(name, count) {
        if (!window.confirm('Delete the group "' + name + '"? Its ' + count + ' KPI(s) become ungrouped (moved to Other). No KPI is deleted.')) return;
        OTP.apiSave({ method: 'DELETE', url: '/api/v1/kpi-groups', body: { name: name }, errorContext: 'Delete group', onSuccess: function() { location.reload(); } });
      }
      openBtn.addEventListener('click', function() { panel.style.display = 'block'; load(); panel.scrollIntoView({ behavior: 'smooth', block: 'center' }); });
      var closeBtn = document.getElementById('kg-close');
      if (closeBtn) closeBtn.addEventListener('click', function() { if (dirty) { location.reload(); } else { panel.style.display = 'none'; } });
      var addBtn = document.getElementById('kg-add'); var addInp = document.getElementById('kg-new');
      if (addBtn) addBtn.addEventListener('click', function() {
        var name = (addInp.value || '').trim(); if (!name) { addInp.focus(); return; }
        OTP.apiSave({ method: 'POST', url: '/api/v1/kpi-groups', body: { name: name }, btnEl: addBtn, errorContext: 'Add group', onSuccess: function() { addInp.value = ''; dirty = true; load(); } });
      });
      if (addInp) addInp.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); addBtn.click(); } });
    })();

    // --- Shared KPIs: assign a KPI to another person ---
    var assignPanel = document.getElementById('kpi-assign-panel');
    var assignTitle = document.getElementById('kpi-assign-title');
    var assignOwner = document.getElementById('kpi-assign-owner');
    var assignGoal = document.getElementById('kpi-assign-goal');
    var assignSubmit = document.getElementById('kpi-assign-submit');
    var assignCancel = document.getElementById('kpi-assign-cancel');
    var assignKpiId = null;

    document.querySelectorAll('.kpi-add-person').forEach(function(btn) {
      btn.addEventListener('click', function() {
        assignKpiId = btn.getAttribute('data-kpi-id');
        if (assignTitle) assignTitle.textContent = btn.getAttribute('data-kpi-title') || 'this KPI';
        if (assignOwner) assignOwner.value = '';
        if (assignGoal) assignGoal.value = '';
        if (assignPanel) {
          assignPanel.style.display = 'block';
          assignPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });

    if (assignCancel) assignCancel.addEventListener('click', function() {
      if (assignPanel) assignPanel.style.display = 'none';
      assignKpiId = null;
    });

    if (assignSubmit) assignSubmit.addEventListener('click', function() {
      if (!assignKpiId) return;
      var val = assignOwner ? assignOwner.value : '';
      if (!val) { alert('Pick a person first.'); return; }
      var parts = val.split(':');
      var body = {
        ownerEntityType: parts[0],
        ownerExternalId: parts[1],
        ownerName: parts.slice(2).join(':'),
      };
      var goalRaw = assignGoal ? assignGoal.value.trim() : '';
      if (goalRaw !== '') body.goalValue = Number(goalRaw);
      OTP.apiSave({
        method: 'POST', url: '/api/v1/kpis/' + encodeURIComponent(assignKpiId) + '/assign',
        body: body,
        btnEl: assignSubmit,
        errorContext: 'Assign KPI',
        onSuccess: function() { location.reload(); },
      });
    });

    document.querySelectorAll('.kpi-unshare').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!confirm('Remove this person from the shared KPI? Their KPI row and its values stay -- it just stops rolling up.')) return;
        OTP.apiSave({
          method: 'POST', url: '/api/v1/kpis/' + encodeURIComponent(btn.getAttribute('data-kpi-id')) + '/unshare',
          btnEl: btn,
          errorContext: 'Unshare KPI',
          onSuccess: function() { location.reload(); },
        });
      });
    });

    // KPI owner-type filter: All / Human / Agent. Client-side show/hide on the
    // already-rendered rows; collapses emptied groups + updates counts;
    // persists the choice per browser.
    (function(){
      function applyOwnerFilter(mode){
        document.querySelectorAll('tr[data-owner-type]').forEach(function(tr){
          tr.style.display = (mode === 'all' || tr.getAttribute('data-owner-type') === mode) ? '' : 'none';
        });
        document.querySelectorAll('.sb-shell').forEach(function(shell){
          if (shell.getAttribute('data-shell-kind') === 'shared'){
            shell.style.display = (mode === 'agent') ? 'none' : '';
            return;
          }
          var rows = shell.querySelectorAll('tr[data-owner-type]');
          if (rows.length === 0) return;
          var visible = 0;
          rows.forEach(function(r){ if (r.style.display !== 'none') visible++; });
          shell.style.display = visible ? '' : 'none';
          var badge = shell.querySelector('.sb-group-count');
          if (badge) badge.textContent = visible;
        });
        document.querySelectorAll('.kpi-owner-btn').forEach(function(b){
          b.classList.toggle('active', b.getAttribute('data-mode') === mode);
        });
        try { localStorage.setItem('otp-kpi-owner-filter', mode); } catch(e){}
      }
      document.querySelectorAll('.kpi-owner-btn').forEach(function(btn){
        btn.addEventListener('click', function(){ applyOwnerFilter(btn.getAttribute('data-mode')); });
      });
      var saved = 'all';
      try { saved = localStorage.getItem('otp-kpi-owner-filter') || 'all'; } catch(e){}
      if (saved !== 'all') applyOwnerFilter(saved);
    })();
  });
</script>
