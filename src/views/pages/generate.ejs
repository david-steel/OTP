<!-- Generator Header -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14 pb-10 sm:pb-14">
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
        <a href="/practices" class="hover:text-white transition-colors">Practices</a>
        <span>/</span>
        <span class="px-2 py-0.5 rounded-full bg-otp-500/20 text-otp-300 font-semibold">Generator</span>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight">Generate Your CLAUDE.md</h1>
      <p class="text-gray-400 mt-4 max-w-lg">Tell us about your team. Get a complete coordination document your agents can follow from day one.</p>
    </div>
  </div>
</section>

<!-- Generator Form -->
<section class="bg-white py-10 sm:py-14">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <form id="generate-form" class="space-y-6">
      <!-- Industry -->
      <div>
        <label for="industry" class="block text-sm font-semibold text-gray-700 mb-2">Industry</label>
        <select id="industry" name="industry" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500">
          <option value="">Select your industry...</option>
          <option value="agency" <%= typeof preselectedIndustry !== 'undefined' && preselectedIndustry === 'agency' ? 'selected' : '' %>>Digital Marketing Agency</option>
          <option value="fitness" <%= typeof preselectedIndustry !== 'undefined' && preselectedIndustry === 'fitness' ? 'selected' : '' %>>Fitness / Franchise</option>
          <option value="healthcare" <%= typeof preselectedIndustry !== 'undefined' && preselectedIndustry === 'healthcare' ? 'selected' : '' %>>Healthcare</option>
          <option value="saas" <%= typeof preselectedIndustry !== 'undefined' && preselectedIndustry === 'saas' ? 'selected' : '' %>>SaaS</option>
          <option value="professional-services" <%= typeof preselectedIndustry !== 'undefined' && preselectedIndustry === 'professional-services' ? 'selected' : '' %>>Professional Services</option>
          <option value="ecommerce" <%= typeof preselectedIndustry !== 'undefined' && preselectedIndustry === 'ecommerce' ? 'selected' : '' %>>E-commerce</option>
        </select>
      </div>

      <!-- Team Size + Agent Count -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="teamSize" class="block text-sm font-semibold text-gray-700 mb-2">Team size (people)</label>
          <input type="number" id="teamSize" name="teamSize" min="1" max="500" value="10" required
                 class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500">
        </div>
        <div>
          <label for="agentCount" class="block text-sm font-semibold text-gray-700 mb-2">AI agents</label>
          <input type="number" id="agentCount" name="agentCount" min="1" max="50" value="5" required
                 class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500">
        </div>
      </div>

      <!-- Focus (optional) -->
      <div>
        <label for="focus" class="block text-sm font-semibold text-gray-700 mb-2">Special focus <span class="text-gray-400 font-normal">(optional)</span></label>
        <input type="text" id="focus" name="focus" maxlength="500" placeholder="e.g., client communication, data pipeline, sales automation..."
               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-otp-500 focus:ring-1 focus:ring-otp-500">
      </div>

      <!-- Submit -->
      <button type="submit" id="generate-btn"
              class="w-full px-6 py-3.5 bg-otp-500 text-white rounded-xl font-semibold hover:bg-otp-400 transition-all hover:shadow-lg hover:shadow-otp-500/25 text-base disabled:opacity-50 disabled:cursor-not-allowed">
        Generate CLAUDE.md
      </button>
    </form>

    <!-- Loading state -->
    <div id="generate-loading" class="hidden mt-8 text-center">
      <div class="inline-flex items-center gap-3 px-6 py-4 bg-otp-50 rounded-xl">
        <svg class="animate-spin w-5 h-5 text-otp-500" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span class="text-otp-700 font-medium">Generating your CLAUDE.md...</span>
      </div>
      <p class="text-sm text-gray-400 mt-3">This takes 5-10 seconds. Using your industry's coordination practices as context.</p>
    </div>

    <!-- Result -->
    <div id="generate-result" class="hidden mt-8">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-bold text-gray-900">Your CLAUDE.md</h2>
          <p id="result-meta" class="text-sm text-gray-500"></p>
        </div>
        <div class="flex gap-2">
          <button onclick="copyResult()" id="copy-btn" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors">Copy</button>
          <button onclick="downloadResult()" class="px-4 py-2 bg-otp-500 text-white rounded-lg text-sm font-medium hover:bg-otp-400 transition-colors">Download</button>
        </div>
      </div>
      <div class="relative">
        <pre id="result-content" class="bg-gray-50 border border-gray-200 rounded-xl p-5 text-sm text-gray-800 font-mono whitespace-pre-wrap overflow-x-auto max-h-[600px] overflow-y-auto leading-relaxed"></pre>
      </div>

      <!-- Follow-up CTA -->
      <div class="mt-6 p-5 bg-otp-50 rounded-xl border border-otp-100">
        <p class="text-sm text-otp-800 font-medium mb-2">What's next?</p>
        <ul class="text-sm text-otp-700 space-y-1.5">
          <li>1. Paste this into your project as <code class="bg-white px-1.5 py-0.5 rounded text-xs">CLAUDE.md</code></li>
          <li>2. Customize the agent names and roles for your team</li>
          <li>3. <a href="/practices" class="text-otp-500 underline">Browse practices</a> to add industry-specific rules</li>
          <li>4. <a href="/publish" class="text-otp-500 underline">Publish your OOS</a> when you're ready to share back</li>
        </ul>
      </div>
    </div>

    <!-- Error state -->
    <div id="generate-error" class="hidden mt-8 p-5 bg-red-50 border border-red-100 rounded-xl">
      <p class="text-sm text-red-700 font-medium">Generation failed</p>
      <p id="error-message" class="text-sm text-red-600 mt-1"></p>
      <button onclick="resetGenerator()" class="mt-3 text-sm text-red-500 underline">Try again</button>
    </div>
  </div>
</section>

<script>
let generatedMarkdown = '';
let generatedIndustry = '';

document.getElementById('generate-form').addEventListener('submit', async function(e) {
  e.preventDefault();

  const form = e.target;
  const btn = document.getElementById('generate-btn');
  const loading = document.getElementById('generate-loading');
  const result = document.getElementById('generate-result');
  const errorEl = document.getElementById('generate-error');

  result.classList.add('hidden');
  errorEl.classList.add('hidden');

  btn.disabled = true;
  btn.textContent = 'Generating...';
  loading.classList.remove('hidden');

  const body = {
    industry: form.industry.value,
    teamSize: parseInt(form.teamSize.value, 10),
    agentCount: parseInt(form.agentCount.value, 10),
    focus: form.focus.value || undefined,
  };

  try {
    const res = await fetch('/api/v1/public/generate-claudemd', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    const data = await res.json();

    loading.classList.add('hidden');
    btn.disabled = false;
    btn.textContent = 'Generate CLAUDE.md';

    if (!res.ok) {
      errorEl.classList.remove('hidden');
      document.getElementById('error-message').textContent = data.error?.message || 'Something went wrong.';
      return;
    }

    generatedMarkdown = data.markdown;
    generatedIndustry = data.industry;

    document.getElementById('result-content').textContent = data.markdown;
    document.getElementById('result-meta').textContent =
      (data.source === 'ai' ? 'AI-generated' : 'Template-based') +
      (data.practiceCount > 0 ? ' | ' + data.practiceCount + ' practices used as context' : '');

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });

  } catch (err) {
    loading.classList.add('hidden');
    btn.disabled = false;
    btn.textContent = 'Generate CLAUDE.md';
    errorEl.classList.remove('hidden');
    document.getElementById('error-message').textContent = 'Network error. Please check your connection and try again.';
  }
});

function copyResult() {
  navigator.clipboard.writeText(generatedMarkdown).then(function() {
    var btn = document.getElementById('copy-btn');
    btn.textContent = 'Copied!';
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });
}

function downloadResult() {
  var blob = new Blob([generatedMarkdown], { type: 'text/markdown' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'CLAUDE-' + (generatedIndustry || 'coordination') + '.md';
  a.click();
  URL.revokeObjectURL(url);
}

function resetGenerator() {
  document.getElementById('generate-error').classList.add('hidden');
  document.getElementById('generate-result').classList.add('hidden');
}
</script>
