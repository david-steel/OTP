<%# Manifesto homepage v6 -- "The Letter" (Fable).
    A signed letter from David Steel with exhibits, rebuilt after a 3-persona
    adversarial copy test (Ninety loyalist / AI-burned cynic / COO). Every
    claim on this page is verifiable: live OOS link, real importers, real
    pricing, published failure log. Fugu-quiet one-accent editorial system.
    Body-only; renderV7 wraps it. %>
<% var _v = (typeof assetVersion !== 'undefined' ? assetVersion : 'dev');
   var LIVE_OOS = '/oos/38970f19-3b87-4498-910b-3bbb736178fc';
   var crew = [
     { name:'Radar',  role:'Chief of Staff', slug:'radar' },
     { name:'Dan',    role:'Strategist',     slug:'dan' },
     { name:'Pepper', role:'Exec Assistant', slug:'pepper' },
     { name:'Dash',   role:'Analyst',        slug:'dash' },
     { name:'Tally',  role:'Scorekeeper',    slug:'tally' }
   ]; %>
<style>
  /* ---- type system: battle / head / body / label. same use everywhere. ---- */
  .ig{ --t-battle:clamp(2.3rem,4.6vw,3.8rem); --t-head:clamp(1.45rem,2.3vw,1.95rem);
       --t-body:clamp(1.02rem,1.12vw,1.12rem); --t-label:12px;
       --rule:#e7e8ec; --accent:#06724a; --mark:#a8e63a;
       background:var(--white,#fcfcfd); }
  .ig *{ box-sizing:border-box; }
  .ig-battle{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:var(--t-battle); line-height:1.03; letter-spacing:-0.035em; color:var(--ink,#14161c); }
  .ig-head{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:600; font-size:var(--t-head); line-height:1.2; letter-spacing:-0.02em; color:var(--ink,#14161c); }
  .ig-body{ font-family:'Inter',sans-serif; font-weight:400; font-size:var(--t-body); line-height:1.66; color:var(--ink-soft,#494d57); }
  .ig-label{ font-family:'JetBrains Mono',ui-monospace,monospace; font-weight:500; font-size:var(--t-label); letter-spacing:.18em; text-transform:uppercase; color:var(--accent); }
  .ig-accent{ color:var(--accent); }

  .ig-wrap{ max-width:1120px; margin:0 auto; padding:0 36px; }
  .ig-link{ font-family:'Inter',sans-serif; font-weight:600; font-size:15px; color:var(--accent); text-decoration:none; }
  .ig-link:hover{ text-decoration:underline; }
  .ig-cta{ display:flex; gap:24px; align-items:center; flex-wrap:wrap; }
  .ig-note{ font-family:'Inter',sans-serif; font-size:13px; color:var(--ink-mute,#888c96); }

  /* section grammar: full-bleed hairline, mono label hanging in the left column */
  .ig-sec{ border-top:1px solid var(--rule); }
  .ig-sec .ig-wrap{ display:grid; grid-template-columns:180px minmax(0,1fr); gap:56px; padding-top:88px; padding-bottom:88px; align-items:start; }
  .ig-side{ position:sticky; top:96px; }
  .ig-main{ max-width:680px; }
  .ig-main .ig-body{ margin-top:18px; max-width:60ch; }
  .ig-main .ig-body + .ig-body{ margin-top:14px; }
  .ig-main .ig-cta{ margin-top:32px; }

  /* hero */
  .ig-hero .ig-wrap{ display:grid; grid-template-columns:minmax(0,1fr) 500px; gap:48px; align-items:center; padding-top:104px; padding-bottom:88px; }
  .ig-kicker{ display:inline-flex; align-items:center; gap:10px; margin-bottom:28px; }
  .ig-tick{ width:8px; height:8px; background:var(--mark); display:inline-block; }
  .ig-h1{ max-width:19ch; }
  .ig-sub{ margin-top:26px; max-width:52ch; text-wrap:pretty; }
  .ig-hero .ig-cta{ margin-top:34px; }
  .ig-hero .ig-note{ margin-top:14px; }
  .ig-heroart{ position:relative; height:430px; }
  .ig-heroart-m{ display:none; }
  .ig-scene{ position:absolute; top:50%; left:50%; width:660px; height:560px; transform:translate(-50%,-50%) scale(.78); transform-origin:center; }
  .ig-scene .rise{ opacity:0; animation:h-rise .7s cubic-bezier(.16,1,.3,1) forwards; }
  @keyframes h-rise{ from{opacity:0;transform:translateY(16px);} to{opacity:1;transform:translateY(0);} }
  .ig-scene .pop{ opacity:0; animation:h-pop .55s cubic-bezier(.34,1.4,.5,1) forwards; }
  @keyframes h-pop{ from{opacity:0;transform:scale(.86);} to{opacity:1;transform:scale(1);} }
  .h-mascot{ position:absolute; left:46px; top:172px; width:316px; z-index:3; }
  .h-mascot img{ width:100%; display:block; animation:h-float 5.5s ease-in-out infinite; }
  @keyframes h-float{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12px);} }
  .h-glow{ position:absolute; left:66px; top:364px; width:278px; height:104px; z-index:1; background:radial-gradient(ellipse, rgba(168,230,58,.28), transparent 70%); animation:h-breathe 5.5s ease-in-out infinite; }
  @keyframes h-breathe{ 0%,100%{opacity:.55;transform:scale(.92);} 50%{opacity:1;transform:scale(1.08);} }
  .h-bubble{ position:absolute; left:14px; top:8px; width:330px; z-index:5; background:#fff; border:1px solid var(--rule,#e6e8ec); border-radius:16px 16px 16px 4px; padding:14px 17px; box-shadow:0 10px 30px -12px rgba(20,22,28,.22); font-family:'Inter',sans-serif; font-size:14px; line-height:1.55; color:var(--ink,#14161c); }
  .h-bubble b{ color:var(--accent,#06724a); font-weight:600; }
  .h-conn{ position:absolute; inset:0; z-index:2; pointer-events:none; overflow:visible; }
  .h-conn path{ fill:none; stroke-width:2; stroke-linecap:round; stroke-dasharray:1; stroke-dashoffset:1; animation:h-draw 1s ease forwards; }
  @keyframes h-draw{ to{stroke-dashoffset:0;} }
  .h-pulse{ fill:#fff; stroke-width:2; }
  .h-rail{ position:absolute; right:0; top:70px; width:248px; z-index:4; display:flex; flex-direction:column; gap:9px; }
  .h-pill{ display:inline-flex; align-items:center; gap:7px; align-self:flex-start; background:#fff; border:1px solid var(--rule,#e6e8ec); border-radius:999px; padding:5px 12px 5px 8px; font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:.04em; box-shadow:0 4px 14px -6px rgba(20,22,28,.18); }
  .h-pill-ico{ width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
  .h-pill.hu{ color:var(--orange-deep,#d4540a); } .h-pill.hu .h-pill-ico{ background:rgba(255,122,26,.16); }
  .h-pill.ag{ color:var(--blue-deep,#0a56b0); } .h-pill.ag .h-pill-ico{ background:rgba(13,125,242,.14); }
  .h-card{ background:#fff; border:1px solid var(--rule,#e6e8ec); border-radius:13px; padding:11px 12px; box-shadow:0 6px 20px -10px rgba(20,22,28,.2); display:flex; gap:10px; align-items:flex-start; }
  .h-av{ width:34px; height:34px; border-radius:9px; flex:none; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:13px; color:#fff; font-family:'Schibsted Grotesk',sans-serif; }
  .h-card-body{ flex:1; min-width:0; }
  .h-name{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:13px; color:var(--ink,#14161c); }
  .h-sub{ font-family:'Inter',sans-serif; font-size:11px; color:var(--ink-mute,#888c96); margin-top:1px; }
  .h-stat{ display:flex; align-items:center; gap:5px; font-size:10.5px; font-weight:600; margin-top:6px; font-family:'Inter',sans-serif; }
  .h-d{ width:6px; height:6px; border-radius:50%; flex:none; }
  .h-live{ display:inline-flex; align-items:center; gap:4px; font-size:9.5px; font-weight:700; color:var(--green-deep,#06724a); }
  .h-live i{ width:6px; height:6px; border-radius:50%; background:var(--green,#0a9d63); animation:h-livedot 1.8s ease-in-out infinite; }
  @keyframes h-livedot{ 0%,100%{box-shadow:0 0 0 0 rgba(10,157,99,.5);} 50%{box-shadow:0 0 0 5px rgba(10,157,99,0);} }
  .h-bar{ height:5px; border-radius:3px; background:#f0f1f3; margin-top:7px; overflow:hidden; }
  .h-bar i{ display:block; height:100%; border-radius:3px; background:var(--blue,#0d7df2); transform:scaleX(0); transform-origin:left; animation:h-grow 1.3s cubic-bezier(.16,1,.3,1) forwards; }
  @keyframes h-grow{ to{transform:scaleX(1);} }

  /* puck rows: NOW / NEXT / THEN */
  .ig-puck{ margin-top:36px; }
  .ig-prow{ display:flex; gap:24px; align-items:baseline; padding:22px 0; border-top:1px solid var(--rule); }
  .ig-prow .tag{ font-family:'JetBrains Mono',ui-monospace,monospace; font-size:12px; font-weight:500; letter-spacing:.18em; color:var(--accent); flex:0 0 64px; }
  .ig-prow .t{ font-family:'Inter',sans-serif; font-size:var(--t-body); line-height:1.6; color:var(--ink,#14161c); max-width:56ch; }

  /* COO Q&A rows */
  .ig-qa{ margin-top:34px; }
  .ig-qrow{ padding:24px 0; border-top:1px solid var(--rule); }
  .ig-qrow .q{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:16px; color:var(--ink,#14161c); }
  .ig-qrow .a{ font-family:'Inter',sans-serif; font-size:15px; line-height:1.62; color:var(--ink-soft,#494d57); margin-top:8px; max-width:60ch; }

  /* proof band */
  .ig-proof{ background:#f4f5f7; }
  .ig-proof .ig-main{ max-width:760px; }
  .ig-crew{ display:flex; gap:16px; margin-top:36px; flex-wrap:wrap; }
  .ig-member{ background:#fff; border:1px solid var(--rule); border-radius:14px; padding:12px 12px 14px; width:128px; box-shadow:0 1px 2px rgba(20,22,28,.04); transition:transform .25s cubic-bezier(.16,1,.3,1); }
  .ig-member:hover{ transform:translateY(-4px); }
  .ig-member img{ width:100%; aspect-ratio:1/1; border-radius:9px; display:block; object-fit:cover; background:#f0f1f3; }
  .ig-member .mn{ margin-top:10px; font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:13.5px; font-weight:700; color:var(--ink,#14161c); }
  .ig-member .mr{ font-family:'Inter',sans-serif; font-size:11.5px; color:var(--ink-mute,#888c96); margin-top:1px; }

  /* platform shot */
  .ig-shot{ margin-top:30px; border:1px solid var(--rule); border-radius:12px; overflow:hidden; max-width:560px; box-shadow:0 16px 40px rgba(20,22,28,.08); }
  .ig-shot img{ width:100%; display:block; }

  /* close + signature */
  .ig-close{ border-top:1px solid var(--rule); }
  .ig-close .ig-wrap{ padding-top:120px; padding-bottom:120px; text-align:center; }
  .ig-enemy{ max-width:19ch; margin:0 auto; text-wrap:balance; }
  .ig-mark{ position:relative; display:inline-block; white-space:nowrap; }
  .ig-mark svg{ position:absolute; left:-2%; bottom:-0.12em; width:104%; height:.22em; overflow:visible; }
  .ig-mark svg path{ fill:none; stroke:var(--mark); stroke-width:7; stroke-linecap:round; }
  .ig-litany{ margin:38px auto 0; max-width:52ch; }
  .ig-litany p{ font-family:'Inter',sans-serif; font-weight:500; font-size:clamp(1.02rem,1.3vw,1.18rem); line-height:1.7; color:var(--ink-soft,#494d57); margin:0; }
  .ig-sig{ margin-top:44px; }
  .ig-sig .name{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:1.35rem; color:var(--ink,#14161c); }
  .ig-sig .role{ font-family:'JetBrains Mono',ui-monospace,monospace; font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--ink-mute,#888c96); margin-top:6px; }
  .ig-ps{ margin:40px auto 0; max-width:56ch; font-family:'Inter',sans-serif; font-size:15px; line-height:1.65; color:var(--ink-soft,#494d57); }

  /* reveal */
  .ig-reveal{ opacity:0; transform:translateY(16px); transition:opacity .65s ease, transform .65s cubic-bezier(.16,1,.3,1); }
  .ig-reveal.in{ opacity:1; transform:none; }
  .ig-mark svg path{ stroke-dasharray:1; stroke-dashoffset:1; }
  .in .ig-mark svg path{ animation:ig-draw .8s ease .45s forwards; }
  @keyframes ig-draw{ to{stroke-dashoffset:0;} }
  @media (prefers-reduced-motion: reduce){
    .ig-reveal{ opacity:1 !important; transform:none !important; transition:none; }
    .ig-scene .pop, .ig-scene .rise, .h-mascot img, .h-bar i, .ig-heroart-m{ animation:none !important; opacity:1 !important; transform:none !important; }
    .ig-mark svg path{ stroke-dashoffset:0; animation:none !important; }
  }

  @media (max-width:900px){
    .ig-hero .ig-wrap{ grid-template-columns:1fr; gap:24px; padding-top:92px; padding-bottom:68px; }
    .ig-heroart{ height:auto; }
    .ig-scene{ display:none; }
    .ig-heroart-m{ display:block; width:210px; margin:0 auto; animation:h-float 5.5s ease-in-out infinite; }
    .ig-sec .ig-wrap{ grid-template-columns:1fr; gap:18px; padding-top:60px; padding-bottom:60px; }
    .ig-side{ position:static; }
    .ig-wrap{ padding:0 22px; }
    .ig-prow{ flex-direction:column; gap:8px; padding:18px 0; }
    .ig-close .ig-wrap{ padding-top:84px; padding-bottom:92px; }
  }
</style>

<div class="ig">

  <!-- HERO -->
  <section class="ig-hero">
    <div class="ig-wrap">
      <div>
        <div class="ig-kicker"><span class="ig-tick"></span><span class="ig-label">A letter from David Steel, founder of OTP</span></div>
        <h1 class="ig-battle ig-h1">You bought into the system. <span class="ig-accent">The needle didn't move.</span></h1>
        <p class="ig-body ig-sub">The meetings got tighter. The scorecard got filled in. And two years later the company looked about the same. The system was never the problem. What was missing was a workforce to run it between the meetings. So I built one.</p>
        <div class="ig-cta">
          <a href="/watch" class="btn-primary px-8 py-4 text-[16px]">Watch us run, live &rarr;</a>
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="ig-link">Claim a founding seat &rarr;</a>
        </div>
        <p class="ig-note">Every human is free. Agent seats are $16 a month.</p>
      </div>
      <div class="ig-heroart">
        <div class="ig-scene">
          <div class="h-glow"></div>
          <svg class="h-conn" viewBox="0 0 660 560">
            <path pathLength="1" d="M348,337 C384,337 388,140 412,140" stroke="var(--orange,#ff7a1a)" style="animation-delay:.7s"/>
            <path pathLength="1" d="M348,340 C384,340 390,215 412,215" stroke="var(--orange,#ff7a1a)" style="animation-delay:.8s"/>
            <path pathLength="1" d="M348,342 C384,342 390,329 412,329" stroke="var(--blue,#0d7df2)" style="animation-delay:.9s"/>
            <path pathLength="1" d="M348,345 C384,345 392,408 412,408" stroke="var(--blue,#0d7df2)" style="animation-delay:1s"/>
            <circle class="h-pulse" r="4" stroke="var(--orange,#ff7a1a)"><animateMotion dur="2.8s" repeatCount="indefinite" begin="1.7s" path="M348,337 C384,337 388,140 412,140"/></circle>
            <circle class="h-pulse" r="4" stroke="var(--blue,#0d7df2)"><animateMotion dur="2.8s" repeatCount="indefinite" begin="2.3s" path="M348,345 C384,345 392,408 412,408"/></circle>
          </svg>
          <div class="h-mascot pop" style="animation-delay:.3s"><img src="/public/orgy-cut.png?v=<%= _v %>" alt="Ollie, the OTP mascot: half living creature, half circuitry. People and AI as one."></div>
          <div class="h-bubble pop" style="animation-delay:.95s">Unlocking the potential in every person through the partnership of people and AI, <b>so together we leave the world better than we found it.</b></div>
          <div class="h-rail">
            <div class="h-pill hu pop" style="animation-delay:.55s"><span class="h-pill-ico"><svg width="10" height="10" viewBox="0 0 24 24" fill="var(--orange-deep,#d4540a)"><circle cx="12" cy="7" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8z"/></svg></span>HUMANS</div>
            <div class="h-card rise" style="animation-delay:.62s"><div class="h-av" style="background:#e07a3a">K</div><div class="h-card-body"><div class="h-name">K. G.</div><div class="h-sub">Creative Director</div><div class="h-stat" style="color:var(--orange-deep,#d4540a)"><span class="h-d" style="background:var(--orange,#ff7a1a)"></span>In a meeting</div></div></div>
            <div class="h-card rise" style="animation-delay:.72s"><div class="h-av" style="background:#c4612a">B</div><div class="h-card-body"><div class="h-name">B. T.</div><div class="h-sub">COO / Integrator</div><div class="h-stat" style="color:var(--orange-deep,#d4540a)"><span class="h-d" style="background:var(--orange,#ff7a1a)"></span>Working on ops</div></div></div>
            <div class="h-pill ag pop" style="animation-delay:.8s;margin-top:4px;"><span class="h-pill-ico"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--blue-deep,#0a56b0)" stroke-width="2.4" stroke-linecap="round"><rect x="5" y="8" width="14" height="11" rx="3"/><path d="M12 4v4M9 13h.01M15 13h.01"/></svg></span>AI AGENTS</div>
            <div class="h-card rise" style="animation-delay:.88s"><div class="h-av" style="background:#0d7df2">R</div><div class="h-card-body"><div style="display:flex;justify-content:space-between;align-items:center"><div class="h-name">Radar</div><span class="h-live"><i></i>Live</span></div><div class="h-sub">Preparing the briefing</div><div class="h-bar"><i style="width:72%;animation-delay:1.3s"></i></div></div></div>
            <div class="h-card rise" style="animation-delay:.98s"><div class="h-av" style="background:#0a64c4">D</div><div class="h-card-body"><div style="display:flex;justify-content:space-between;align-items:center"><div class="h-name">Dash</div><span class="h-live"><i></i>Live</span></div><div class="h-sub">Reading the ad accounts</div><div class="h-bar"><i style="width:64%;background:var(--green,#0a9d63);animation-delay:1.45s"></i></div></div></div>
          </div>
        </div>
        <img class="ig-heroart-m" src="/public/orgy-cut.png?v=<%= _v %>" alt="Ollie, the OTP mascot">
      </div>
    </div>
  </section>

  <!-- 01 A CONFESSION -->
  <section class="ig-sec" id="why">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">01 / A confession</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">I was promised freedom. I got a phone.</h2>
        <p class="ig-body">I run a marketing agency. Payroll, clients, a Tuesday leadership meeting. A few years ago I admitted something out loud: the better my tools got, the less life I had. The phone that promised to connect me took my attention. The software that promised to save time filled the time with more work. My team was productive. Nobody was free. Work had quietly stolen the fun out of our lives, and the freedom we were promised turned out to be an illusion with a login screen.</p>
      </div>
    </div>
  </section>

  <!-- 02 WHAT I DID ABOUT IT -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">02 / What I did about it</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">So I hired employees who don't have inboxes.</h2>
        <p class="ig-body">I started building AI agents. Not chatbots. Employees. Radar prepares my morning briefing before I wake up. Dash reads every ad account so nobody has to stare at dashboards. Pepper triages my inbox. Dan pressure-tests my strategy in writing before I bet money on it. Tally keeps the score honest.</p>
        <p class="ig-body">Then I hit a wall, and it was not the AI. It was the org chart. Every system for running a company assumes the company is made only of people. There was no seat for an agent, no number it owned, no one it answered to. So we built OTP: the operating system where people and AI hold seats on the same chart.</p>
      </div>
    </div>
  </section>

  <!-- EXHIBIT A: LIVE PROOF -->
  <section class="ig-sec ig-proof">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">Exhibit A / Our company, live</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">Don't take my word for anything. Watch us run.</h2>
        <p class="ig-body">Companies have published their handbooks before. We publish something further: our operating system, live, with AI agents holding seats, owning numbers, and getting corrected in public. Every role. Every rule. Every mistake, because when an agent gets something wrong here, the correction becomes a published rule with the failure written into it.</p>
        <div class="ig-crew">
          <% crew.forEach(function(m){ %>
            <div class="ig-member">
              <img src="/public/images/vs/<%= m.slug %>.png?v=<%= _v %>" alt="<%= m.name %>, the OTP <%= m.role %>" loading="lazy">
              <div class="mn"><%= m.name %></div>
              <div class="mr"><%= m.role %></div>
            </div>
          <% }); %>
        </div>
        <div class="ig-cta">
          <a href="/watch" class="ig-link">Watch us run, live &rarr;</a>
          <a href="<%= LIVE_OOS %>" class="ig-link">Read the published rules &rarr;</a>
          <a href="/free-agents" class="ig-link">Meet the agents &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 03 WHERE THIS GOES -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">03 / Where this goes</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">I skate to where the puck is going. Here is the whole rink.</h2>
        <div class="ig-puck">
          <div class="ig-prow"><span class="tag">Now</span><span class="t">You run your company on meetings, priorities, and a scorecard. OTP does that today, free, for your whole team.</span></div>
          <div class="ig-prow"><span class="tag">Next</span><span class="t">AI agents take seats on the chart, own real numbers, and work the six days between meetings. Mine already do.</span></div>
          <div class="ig-prow"><span class="tag">Then</span><span class="t">Your organization runs as one. People and AI, one team, one rhythm, no gap between deciding and doing.</span></div>
        </div>
        <p class="ig-body">I won't tell you your competitors are about to lap you. I don't know your market. I know one thing that is checkable: this future is not a prediction, because it is already running at my company. You can go look at it.</p>
      </div>
    </div>
  </section>

  <!-- EXHIBIT B: THE MACHINE -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">Exhibit B / The machine</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">Don't switch. Run us alongside.</h2>
        <p class="ig-body">OTP's free tier is the whole meeting product: the chart, the scorecard, priorities, to-dos, the weekly meeting. Free for every human, no credit card, and it is not a trial. Agent seats are $16 a month, and the <a href="/pricing" class="ig-link" style="font-size:inherit;">full price list is public</a>. If you run on Ninety or Bloom Growth today, drop in your export files and OTP rebuilds your chart from who owns what, in an afternoon. Then run both, side by side, for a quarter. If we don't earn the switch, you lost an afternoon.</p>
        <p class="ig-body">Two rules, before you ask. Numbers: our scorekeeper agent reads the source systems and pushes the scorecard, timestamped and logged. Agents don't type numbers they didn't read. Actions: nothing goes to a client or a teammate without a human approving it. That rule is published in our operating system, where you can hold us to it.</p>
        <div class="ig-shot">
          <img src="/public/images/vs/l10.png?v=<%= _v %>" alt="The OTP weekly meeting: timed agenda, live scoreboard, every commitment tracked" loading="lazy">
        </div>
        <div class="ig-cta">
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Set up your company free &rarr;</a>
          <a href="/import/ninety" class="ig-link">Import from Ninety or Bloom &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 04 THE QUESTIONS YOUR COO WILL ASK -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">04 / For your COO</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">The boring answers, on purpose.</h2>
        <p class="ig-body">You will forward this to the person who actually has to implement it. These are for them.</p>
        <div class="ig-qa">
          <div class="ig-qrow"><div class="q">Whose data is it?</div><div class="a">Yours. Import from Ninety or Bloom Growth in an afternoon; the chart rebuilds itself from who owns what. Export today is by request, and we honor it fast; self-serve export is on the roadmap. Either way, leaving was designed in, not bolted on.</div></div>
          <div class="ig-qrow"><div class="q">What can an agent do on its own?</div><div class="a">Read, prepare, draft, propose. It cannot send anything to a client or teammate without a human approving it, and every action is logged with a timestamp. Where you see an agent of ours called autonomous, the autonomy lives inside that gate: it decides what to prepare and when, never what leaves the building.</div></div>
          <div class="ig-qrow"><div class="q">How secure is "early"?</div><div class="a">The honest answer: we are early, and I won't pretend otherwise. Role-based access and audit trails are built in, you can bring your own AI key so your data runs on your own model provider, and the full posture is written down plainly on our <a href="/trust" class="ig-link" style="font-size:inherit;">trust page</a>, including what we don't have yet. Ask me anything directly; you get me, not a sales engineer.</div></div>
          <div class="ig-qrow"><div class="q">What does early cost me?</div><div class="a">The product ships weekly and improves in public. What it does not cost: money (humans are free), migration pain (an afternoon), or lock-in (see the first answer).</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 05 YOUR TUESDAY -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">05 / Your Tuesday</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">Now let me describe your Tuesday, six months from now.</h2>
        <p class="ig-body">Week one first, because that is where tools go to die: your chart in an afternoon, your scorekeeper reading your numbers within days, your first meeting run off a board nobody typed. Then the compounding starts.</p>
        <p class="ig-body">Your briefing wrote itself before you woke up. The scorecard filled itself in from the source systems on Friday, timestamped. Three of last week's to-dos were done by Wednesday, by agents, reviewed by the humans who own them. The meeting takes half the time, because everyone, human and AI, already knows the score. You leave at five. Not because you gave up. Because it's handled.</p>
        <p class="ig-body">Then the real question shows up, the one I built all of this to ask: what will you do with the hours you get back?</p>
      </div>
    </div>
  </section>

  <!-- 06 THE ASK -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">06 / Fifty companies</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">I'm not looking for a million users. I'm looking for fifty.</h2>
        <p class="ig-body">That is not scarcity theater. It is arithmetic. I can give real, personal attention to fifty companies while we build this, so fifty is the number. The Founding Fifty put people and AI on one chart and run as one, with me in the room. And your agents will not be copies of mine: Radar and Dash grew out of an agency, yours will grow out of your company. What OTP gives them is what mine have. A seat, a number, and a chain of command.</p>
        <p class="ig-body">And you will not stand up your first agent alone, because I know that is the real question behind the $16. Founding Fifty means we build your first one with you: a scorekeeper that reads your source systems (even if your source system is a spreadsheet) and fills your scorecard before your second meeting. A seat is easy. We make sure someone worth seating shows up.</p>
        <p class="ig-body">Today the deepest proof I can show you is my own company, and I know that is a sample size of one. That is exactly what the Founding Fifty is for: making it fifty.</p>
        <div class="ig-cta">
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Claim a founding seat &rarr;</a>
        </div>
        <p class="ig-note" style="margin-top:14px;">Every human is free. No credit card.</p>
      </div>
    </div>
  </section>

  <!-- CLOSE + SIGNATURE -->
  <section class="ig-close">
    <div class="ig-wrap">
      <p class="ig-battle ig-enemy ig-reveal">We refuse to accept that humanity's greatest potential should be spent <span class="ig-mark">managing work<svg viewBox="0 0 200 14" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" d="M3,10 Q55,4 110,8 T197,6"/></svg></span>.</p>
      <div class="ig-litany ig-reveal">
        <p>There will always be more human potential to unlock. There will always be better ways for people and AI to work together. There will always be a world to leave better than we found it. This work has no finish line. We chose it anyway.</p>
      </div>
      <div class="ig-sig ig-reveal">
        <div class="name">David Steel</div>
        <div class="role">Founder, OTP</div>
      </div>
      <p class="ig-ps ig-reveal">P.S. If you only do one thing today, spend ten minutes at <a href="/watch" class="ig-link" style="font-size:inherit;">the window into our company</a>. It says more than any homepage could.</p>
    </div>
  </section>
</div>

<script>
(function(){
  var els = [].slice.call(document.querySelectorAll('.ig-reveal'));
  if (!('IntersectionObserver' in window) || (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {
    els.forEach(function(e){ e.classList.add('in'); }); return;
  }
  var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if (e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, { rootMargin:'0px 0px -8% 0px', threshold:0.12 });
  els.forEach(function(e){ io.observe(e); });
  setTimeout(function(){ els.forEach(function(e){ e.classList.add('in'); }); }, 2800);
})();
</script>
