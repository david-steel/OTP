<%# Manifesto homepage v4 -- DISCIPLINED type system (Sakana-style restraint).
    Four sizes only: display (hero + close), head (every section), body, label.
    Head + body per movement, not walls of giant text. Spine, portraits, shot
    kept. Body-only; renderV7 wraps it. %>
<% var _v = (typeof assetVersion !== 'undefined' ? assetVersion : 'dev');
   var crew = [
     { name:'Radar',  role:'Chief of Staff', slug:'radar' },
     { name:'Dan',    role:'Strategist',     slug:'dan' },
     { name:'Pepper', role:'Exec Assistant', slug:'pepper' },
     { name:'Dash',   role:'Analyst',        slug:'dash' },
     { name:'Tally',  role:'Scorekeeper',    slug:'tally' }
   ]; %>
<style>
  /* ---- ONE type system. four sizes. used the same way every time. ---- */
  .mf{ --t-display:clamp(2.4rem,4.4vw,3.3rem); --t-head:clamp(1.4rem,2.1vw,1.85rem);
       --t-body:clamp(1rem,1.1vw,1.1rem); --t-label:12px;
       --rule:#e7e8ec; }
  .mf *{ box-sizing:border-box; }
  .mf-display{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:500; font-size:var(--t-display); line-height:1.06; letter-spacing:-0.035em; color:var(--ink,#14161c); }
  .mf-head{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:600; font-size:var(--t-head); line-height:1.18; letter-spacing:-0.022em; color:var(--ink,#14161c); }
  .mf-body{ font-family:'Inter',sans-serif; font-weight:400; font-size:var(--t-body); line-height:1.62; color:var(--ink-soft,#3c424d); }
  .mf-label{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:var(--t-label); letter-spacing:.16em; text-transform:uppercase; color:var(--ink-mute,#7c828d); }
  .mf-accent{ color:var(--blue,#0d7df2); }

  .mf-wrap{ max-width:1080px; margin:0 auto; padding:0 32px; }
  .mf-link{ font-family:'Inter',sans-serif; font-weight:600; font-size:14px; color:var(--blue,#0d7df2); text-decoration:none; }
  .mf-link:hover{ text-decoration:underline; }
  .mf-cta{ margin-top:30px; display:flex; gap:22px; align-items:center; flex-wrap:wrap; }

  /* hero */
  .mf-hero{ padding:132px 0 90px; }
  .mf-herogrid{ display:grid; grid-template-columns:1.08fr .92fr; gap:52px; align-items:center; }
  .mf-kicker{ display:inline-flex; align-items:center; gap:10px; margin-bottom:26px; }
  .mf-tick{ width:7px; height:7px; border-radius:50%; background:var(--orgy,#a8e63a); display:inline-block; }
  .mf-h1{ max-width:16ch; }
  .mf-sub{ margin-top:26px; max-width:32rem; }
  .mf-heroart{ display:flex; justify-content:center; }
  .mf-heroart img{ width:min(360px,84%); height:auto; filter:drop-shadow(0 26px 42px rgba(20,22,28,.17)); animation:mf-float 6.5s ease-in-out infinite; }
  @keyframes mf-float{ 0%,100%{ transform:translateY(0);} 50%{ transform:translateY(-14px);} }
  @media (prefers-reduced-motion: reduce){ .mf-heroart img{ animation:none; } }

  /* stage + running spine */
  .mf-stage{ position:relative; max-width:1080px; margin:0 auto; padding:0 32px; }
  .mf-stage::before{ content:''; position:absolute; left:32px; top:0; bottom:0; width:1px; background:var(--rule); pointer-events:none; }

  /* movement: index | content, ruled, calm rhythm */
  .mv{ display:grid; grid-template-columns:140px minmax(0,1fr); gap:48px; align-items:start;
       padding:64px 0 64px 28px; border-top:1px solid var(--rule); }
  .mv-num{ font-family:'JetBrains Mono',ui-monospace,monospace; font-size:14px; font-weight:500; color:var(--blue,#0d7df2); letter-spacing:.04em; }
  .mv-side .mf-label{ margin-top:14px; line-height:1.6; display:block; }
  .mv-head{ max-width:24ch; }
  .mv-body{ max-width:32rem; margin-top:16px; }

  /* vision list -- distinguished by weight, not size */
  .mv-list{ max-width:34rem; margin-top:4px; }
  .mv-li{ display:flex; gap:16px; align-items:baseline; padding:14px 0; border-top:1px solid var(--rule); }
  .mv-li:first-child{ border-top:0; padding-top:0; }
  .mv-li .li-n{ font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-mute,#9aa0aa); flex:0 0 22px; }
  .mv-li .li-hand{ width:32px; height:auto; flex:0 0 32px; display:block; align-self:center; }
  .mv-li .li-t{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:500; font-size:var(--t-body); line-height:1.4; color:var(--ink,#14161c); }

  /* meeting shot */
  .mf-shot{ margin-top:26px; border:1px solid var(--rule); border-radius:12px; overflow:hidden; max-width:520px; box-shadow:0 20px 44px rgba(20,22,28,.07); }
  .mf-shot img{ width:100%; display:block; }

  /* blue proof panel */
  .mf-proof{ background:var(--blue,#0d7df2); margin:0 -32px; padding:76px 60px; }
  .mf-proof .mv{ border-top:0; padding:0; }
  .mf-proof .mv-num{ color:rgba(255,255,255,.9); }
  .mf-proof .mf-label{ color:rgba(255,255,255,.72); }
  .mf-proof .mv-head{ color:#fff; }
  .mf-proof .mv-body{ color:rgba(255,255,255,.86); }
  .mf-crew{ display:flex; gap:20px; margin-top:32px; flex-wrap:wrap; }
  .mf-member{ width:96px; }
  .mf-member img{ width:96px; height:96px; border-radius:16px; display:block; object-fit:cover; background:#fff; box-shadow:0 8px 20px rgba(8,30,66,.18); }
  .mf-member .mn{ margin-top:12px; font-family:'Inter',sans-serif; font-size:12.5px; font-weight:600; color:#fff; }
  .mf-member .mr{ font-family:'Inter',sans-serif; font-size:11px; color:rgba(255,255,255,.66); }

  /* close */
  .mf-close{ border-top:1px solid var(--rule); padding:96px 0 128px 28px; }
  .mf-enemy{ font-weight:600; max-width:20ch; }
  .mf-note{ font-family:'Inter',sans-serif; font-size:13px; color:var(--ink-mute,#7c828d); margin-top:14px; }

  .mf-reveal{ opacity:0; transform:translateY(14px); transition:opacity .6s ease, transform .6s ease; }
  .mf-reveal.in{ opacity:1; transform:none; }
  @media (prefers-reduced-motion: reduce){ .mf-reveal{ opacity:1 !important; transform:none !important; transition:none; } }

  @media (max-width:760px){
    .mf-stage::before{ left:20px; }
    .mv{ grid-template-columns:1fr; gap:14px; padding:48px 0; }
    .mf-herogrid{ grid-template-columns:1fr; gap:16px; }
    .mf-heroart{ order:-1; }
    .mf-heroart img{ width:180px; }
    .mf-hero{ padding:104px 0 60px; }
    .mf-proof{ margin:0 -20px; padding:56px 24px; }
    .mf-close{ padding:60px 0 84px; }
    .mf-wrap, .mf-stage{ padding:0 20px; }
  }
</style>

<div class="mf">

  <!-- HERO -->
  <section class="mf-hero">
    <div class="mf-wrap mf-herogrid">
      <div class="mf-herocopy">
        <div class="mf-kicker"><span class="mf-tick"></span><span class="mf-label">The operating system for people and AI</span></div>
        <h1 class="mf-display mf-h1">Every person has more potential than their workday allows.</h1>
        <p class="mf-body mf-sub">OTP brings people and AI together as one team, and clears the busywork that keeps companies from thinking, creating, and growing.</p>
        <div class="mf-cta">
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Start building &rarr;</a>
          <a href="#problem" class="mf-link">Why we exist &darr;</a>
        </div>
      </div>
      <div class="mf-heroart">
        <img src="/public/orgy-cut.png?v=<%= _v %>" alt="Ollie, the OTP mascot">
      </div>
    </div>
  </section>

  <div class="mf-stage">

    <!-- 01 -->
    <div class="mv" id="problem">
      <div class="mv-side"><div class="mv-num">01</div><span class="mf-label">The problem</span></div>
      <div class="mv-main mf-reveal">
        <h2 class="mf-head mv-head">What is productivity for?</h2>
        <p class="mf-body mv-body">For decades we made people more productive. They have never felt busier. We built software to save time, then filled the time with more software. We automated the work, then invented more of it. Somewhere, we stopped asking the only question that matters.</p>
      </div>
    </div>

    <!-- 02 -->
    <div class="mv">
      <div class="mv-side"><div class="mv-num">02</div><span class="mf-label">Why we exist</span></div>
      <div class="mv-main mf-reveal">
        <h2 class="mf-head mv-head">Technology's highest purpose is not to replace people. It is to elevate them.</h2>
        <p class="mf-body mv-body">That is why OTP exists. Not to build another AI platform, but to unlock the potential in every person through the partnership of people and AI, so together we leave the world better than we found it.</p>
      </div>
    </div>

    <!-- 03 -->
    <div class="mv">
      <div class="mv-side"><div class="mv-num">03</div><span class="mf-label">Imagine if</span></div>
      <div class="mv-main mf-reveal">
        <div class="mv-list">
          <div class="mv-li"><img class="li-hand" src="/public/images/onboarding-hand-1.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="li-t">Every employee had perfect memory.</span></div>
          <div class="mv-li"><img class="li-hand" src="/public/images/onboarding-hand-2.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="li-t">Every decision built on every lesson before it.</span></div>
          <div class="mv-li"><img class="li-hand" src="/public/images/onboarding-hand-3.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="li-t">Every AI understood your whole organization.</span></div>
          <div class="mv-li"><img class="li-hand" src="/public/images/onboarding-hand-4.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="li-t">Every person had time to think, to create, to build something that matters.</span></div>
        </div>
        <p class="mf-head mv-head" style="margin-top:32px;">That's OTP.</p>
      </div>
    </div>

    <!-- PROOF -->
    <div class="mf-proof">
      <div class="mv">
        <div class="mv-side"><div class="mv-num">&mdash;</div><span class="mf-label">We live it</span></div>
        <div class="mv-main">
          <h2 class="mf-head mv-head">We run our own company on these exact agents.</h2>
          <p class="mf-body mv-body">Radar, Dan, Pepper, Dash, and Tally are the same agents that run the company that built OTP. Working live, next to our people, every single day. No one else can hand you a philosophy and show you it running.</p>
          <div class="mf-crew mf-reveal">
            <% crew.forEach(function(m){ %>
              <div class="mf-member">
                <img src="/public/images/vs/<%= m.slug %>.png?v=<%= _v %>" alt="<%= m.name %>, the OTP <%= m.role %>" loading="lazy">
                <div class="mn"><%= m.name %></div>
                <div class="mr"><%= m.role %></div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>

    <!-- 04 -->
    <div class="mv">
      <div class="mv-side"><div class="mv-num">04</div><span class="mf-label">The platform</span></div>
      <div class="mv-main mf-reveal">
        <h2 class="mf-head mv-head">Put people and AI on one accountable team.</h2>
        <p class="mf-body mv-body">OTP gives your whole team free meeting software: one chart, one scoreboard, one weekly meeting. Then every AI agent takes a seat, owns a number, and does the work between meetings, next to your people. Bring your own, or start with five of ours. Free for your whole team.</p>
        <div class="mf-shot">
          <img src="/public/images/vs/l10.png?v=<%= _v %>" alt="The OTP weekly meeting: timed agenda, live scoreboard, every commitment tracked">
        </div>
        <div class="mf-cta">
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Start free &rarr;</a>
          <a href="/compare" class="mf-link">See how it works &rarr;</a>
        </div>
      </div>
    </div>

    <!-- 05 -->
    <div class="mv">
      <div class="mv-side"><div class="mv-num">05</div><span class="mf-label">The manifesto</span></div>
      <div class="mv-main mf-reveal">
        <h2 class="mf-head mv-head">Read <em>The Intelligent Organization</em>.</h2>
        <p class="mf-body mv-body">Our founding manifesto for Organizational Intelligence Management. Twelve chapters on why companies forget, and how to build one that never does.</p>
        <div class="mf-cta">
          <a href="/the-intelligent-organization/" class="btn-primary px-8 py-4 text-[16px]">Read the manifesto &rarr;</a>
        </div>
      </div>
    </div>

    <!-- CLOSE -->
    <div class="mf-close">
      <p class="mf-display mf-enemy mf-reveal">We refuse to accept that humanity's greatest potential should be spent <span class="mf-accent">managing work</span>.</p>
      <div class="mf-cta">
        <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Start building &rarr;</a>
      </div>
      <p class="mf-note">Free for your whole team. No credit card.</p>
    </div>

  </div>
</div>

<script>
(function(){
  var els = [].slice.call(document.querySelectorAll('.mf-reveal'));
  if (!('IntersectionObserver' in window) || (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {
    els.forEach(function(e){ e.classList.add('in'); }); return;
  }
  var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if (e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, { rootMargin:'0px 0px -8% 0px', threshold:0.12 });
  els.forEach(function(e){ io.observe(e); });
  setTimeout(function(){ els.forEach(function(e){ e.classList.add('in'); }); }, 2600);
})();
</script>
