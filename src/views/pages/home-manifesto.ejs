<%# Manifesto homepage v5 -- "The Infinite Game" (Fable).
    Sakana-fugu discipline: warm white, ONE accent (the OTP green family),
    giant Schibsted statements, mono wayfinding labels in the left margin,
    full-bleed hairline rules, huge whitespace. The mission and the
    infinite-game litany ARE the page. Body-only; renderV7 wraps it. %>
<% var _v = (typeof assetVersion !== 'undefined' ? assetVersion : 'dev');
   var crew = [
     { name:'Radar',  role:'Chief of Staff', slug:'radar' },
     { name:'Dan',    role:'Strategist',     slug:'dan' },
     { name:'Pepper', role:'Exec Assistant', slug:'pepper' },
     { name:'Dash',   role:'Analyst',        slug:'dash' },
     { name:'Tally',  role:'Scorekeeper',    slug:'tally' }
   ]; %>
<style>
  /* ---- type system: battle / litany / head / body / label. same use everywhere. ---- */
  .ig{ --t-battle:clamp(2.7rem,5.6vw,4.7rem); --t-litany:clamp(1.6rem,3vw,2.55rem);
       --t-head:clamp(1.45rem,2.3vw,1.95rem); --t-body:clamp(1.02rem,1.12vw,1.12rem);
       --t-label:12px; --rule:#e7e8ec; --accent:#06724a; --mark:#a8e63a;
       background:var(--white,#fcfcfd); }
  .ig *{ box-sizing:border-box; }
  .ig-battle{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:var(--t-battle); line-height:1.03; letter-spacing:-0.035em; color:var(--ink,#14161c); }
  .ig-litany{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:600; font-size:var(--t-litany); line-height:1.16; letter-spacing:-0.025em; color:var(--ink,#14161c); }
  .ig-head{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:600; font-size:var(--t-head); line-height:1.2; letter-spacing:-0.02em; color:var(--ink,#14161c); }
  .ig-body{ font-family:'Inter',sans-serif; font-weight:400; font-size:var(--t-body); line-height:1.66; color:var(--ink-soft,#494d57); }
  .ig-label{ font-family:'JetBrains Mono',ui-monospace,monospace; font-weight:500; font-size:var(--t-label); letter-spacing:.18em; text-transform:uppercase; color:var(--accent); }
  .ig-accent{ color:var(--accent); }

  .ig-wrap{ max-width:1120px; margin:0 auto; padding:0 36px; }
  .ig-link{ font-family:'Inter',sans-serif; font-weight:600; font-size:15px; color:var(--accent); text-decoration:none; }
  .ig-link:hover{ text-decoration:underline; }
  .ig-cta{ display:flex; gap:24px; align-items:center; flex-wrap:wrap; }
  .ig-note{ font-family:'Inter',sans-serif; font-size:13px; color:var(--ink-mute,#888c96); }

  /* section grammar: full-bleed hairline, mono label hanging in the left column */
  .ig-sec{ border-top:1px solid var(--rule); }
  .ig-sec .ig-wrap{ display:grid; grid-template-columns:180px minmax(0,1fr); gap:56px; padding-top:92px; padding-bottom:92px; align-items:start; }
  .ig-side{ position:sticky; top:96px; }
  .ig-main{ max-width:680px; }
  .ig-main .ig-body{ margin-top:18px; max-width:58ch; }
  .ig-main .ig-cta{ margin-top:32px; }

  /* hero */
  .ig-hero .ig-wrap{ display:grid; grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr); gap:64px; align-items:center; padding-top:118px; padding-bottom:104px; }
  .ig-kicker{ display:inline-flex; align-items:center; gap:10px; margin-bottom:28px; }
  .ig-tick{ width:8px; height:8px; background:var(--mark); display:inline-block; }
  .ig-h1{ max-width:13ch; }
  .ig-sub{ margin-top:26px; max-width:52ch; text-wrap:pretty; }
  .ig-hero .ig-cta{ margin-top:34px; }
  .ig-hero .ig-note{ margin-top:14px; }
  .ig-panel{ position:relative; border:1px solid var(--rule); background:#fff; aspect-ratio:1/1.04; display:flex; align-items:center; justify-content:center; overflow:hidden; }
  .ig-panel::after{ content:''; position:absolute; left:50%; bottom:8%; width:62%; height:16%; transform:translateX(-50%); background:radial-gradient(ellipse, rgba(168,230,58,.30), transparent 70%); }
  .ig-panel img{ width:64%; max-width:340px; position:relative; z-index:1; animation:ig-float 6s ease-in-out infinite; }
  @keyframes ig-float{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12px);} }
  .ig-panel .ig-label{ position:absolute; left:18px; bottom:14px; z-index:2; color:var(--ink-mute,#888c96); }

  /* infinite game litany */
  .ig-game .ig-main{ max-width:760px; }
  .ig-noline{ margin-top:10px; }
  .ig-litany-list{ margin-top:44px; }
  .ig-li{ display:flex; gap:26px; align-items:center; padding:30px 0; border-top:1px solid var(--rule); }
  .ig-li img{ width:52px; height:auto; flex:0 0 52px; }
  .ig-li .t{ font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:600; font-size:clamp(1.25rem,2vw,1.7rem); line-height:1.25; letter-spacing:-0.02em; color:var(--ink,#14161c); max-width:26ch; }

  /* proof band */
  .ig-proof{ background:#f4f5f7; }
  .ig-proof .ig-main{ max-width:760px; }
  .ig-crew{ display:flex; gap:16px; margin-top:36px; flex-wrap:wrap; }
  .ig-member{ background:#fff; border:1px solid var(--rule); border-radius:14px; padding:12px 12px 14px; width:128px; box-shadow:0 1px 2px rgba(20,22,28,.04); transition:transform .25s cubic-bezier(.16,1,.3,1); }
  .ig-member:hover{ transform:translateY(-4px); }
  .ig-member img{ width:100%; aspect-ratio:1/1; border-radius:9px; display:block; object-fit:cover; background:#f0f1f3; }
  .ig-member .mn{ margin-top:10px; font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:13.5px; font-weight:700; color:var(--ink,#14161c); }
  .ig-member .mr{ font-family:'Inter',sans-serif; font-size:11.5px; color:var(--ink-mute,#888c96); margin-top:1px; }

  /* platform shot */
  .ig-shot{ margin-top:30px; border:1px solid var(--rule); border-radius:12px; overflow:hidden; max-width:560px; box-shadow:0 16px 40px rgba(20,22,28,.08); }
  .ig-shot img{ width:100%; display:block; }

  /* close */
  .ig-close{ border-top:1px solid var(--rule); }
  .ig-close .ig-wrap{ padding-top:128px; padding-bottom:140px; text-align:center; }
  .ig-enemy{ max-width:19ch; margin:0 auto; text-wrap:balance; }
  .ig-mark{ position:relative; display:inline-block; white-space:nowrap; }
  .ig-mark svg{ position:absolute; left:-2%; bottom:-0.12em; width:104%; height:.22em; overflow:visible; }
  .ig-mark svg path{ fill:none; stroke:var(--mark); stroke-width:7; stroke-linecap:round; }
  .ig-close .ig-comejoin{ margin-top:30px; font-family:'Inter',sans-serif; font-weight:500; font-size:clamp(1.05rem,1.4vw,1.25rem); color:var(--ink-soft,#494d57); }
  .ig-close .ig-cta{ justify-content:center; margin-top:36px; }
  .ig-close .ig-note{ margin-top:14px; }

  /* reveal */
  .ig-reveal{ opacity:0; transform:translateY(16px); transition:opacity .65s ease, transform .65s cubic-bezier(.16,1,.3,1); }
  .ig-reveal.in{ opacity:1; transform:none; }
  .ig-li.ig-reveal:nth-child(2){ transition-delay:.12s; }
  .ig-li.ig-reveal:nth-child(3){ transition-delay:.24s; }
  .ig-mark svg path{ stroke-dasharray:1; stroke-dashoffset:1; }
  .in .ig-mark svg path, .ig-mark.in svg path{ animation:ig-draw .8s ease .45s forwards; }
  @keyframes ig-draw{ to{stroke-dashoffset:0;} }
  @media (prefers-reduced-motion: reduce){
    .ig-reveal{ opacity:1 !important; transform:none !important; transition:none; }
    .ig-panel img{ animation:none; }
    .ig-mark svg path{ stroke-dashoffset:0; animation:none !important; }
  }

  @media (max-width:900px){
    .ig-hero .ig-wrap{ grid-template-columns:1fr; gap:44px; padding-top:96px; padding-bottom:72px; }
    .ig-panel{ max-width:420px; }
    .ig-sec .ig-wrap{ grid-template-columns:1fr; gap:18px; padding-top:64px; padding-bottom:64px; }
    .ig-side{ position:static; }
    .ig-wrap{ padding:0 22px; }
    .ig-li{ gap:18px; padding:24px 0; }
    .ig-li img{ width:40px; flex-basis:40px; }
    .ig-close .ig-wrap{ padding-top:88px; padding-bottom:96px; }
  }
</style>

<div class="ig">

  <!-- HERO: the mission is the headline -->
  <section class="ig-hero">
    <div class="ig-wrap">
      <div>
        <div class="ig-kicker"><span class="ig-tick"></span><span class="ig-label">Our mission</span></div>
        <h1 class="ig-battle ig-h1">Unlock the potential in <span class="ig-accent">every person</span>.</h1>
        <p class="ig-body ig-sub">Through the partnership of people and AI, working as one team. So together we leave the world better than we found it.</p>
        <div class="ig-cta">
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Start free &rarr;</a>
          <a href="#why" class="ig-link">Why we exist &darr;</a>
        </div>
        <p class="ig-note">Free for your whole team. No credit card.</p>
      </div>
      <div class="ig-panel">
        <img src="/public/orgy-cut.png?v=<%= _v %>" alt="Ollie, the OTP mascot: half living creature, half circuitry. People and AI as one.">
        <span class="ig-label">People &times; AI</span>
      </div>
    </div>
  </section>

  <!-- 01 THE PROBLEM -->
  <section class="ig-sec" id="why">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">01 / The problem</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">What is productivity for?</h2>
        <p class="ig-body">For decades we made people more productive. They have never felt busier. We built software to save time, then filled the time with more software. We automated the work, then invented more of it. Somewhere, we stopped asking the only question that matters.</p>
      </div>
    </div>
  </section>

  <!-- 02 OUR BELIEF -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">02 / Our belief</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">Technology's highest purpose is not to replace people. It is to elevate them.</h2>
        <p class="ig-body">That is why OTP exists. Not to build another AI platform, but to unlock the potential in every person through the partnership of people and AI, so together we leave the world better than we found it.</p>
      </div>
    </div>
  </section>

  <!-- 03 THE INFINITE GAME: the battle cry -->
  <section class="ig-sec ig-game">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">&infin; / The infinite game</span></div>
      <div class="ig-main">
        <h2 class="ig-litany ig-reveal">This is the infinite game we have chosen to play.<br><span class="ig-accent ig-noline">There is no finish line.</span></h2>
        <div class="ig-litany-list">
          <div class="ig-li ig-reveal"><img src="/public/images/onboarding-hand-1.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="t">There will always be more human potential to unlock.</span></div>
          <div class="ig-li ig-reveal"><img src="/public/images/onboarding-hand-2.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="t">There will always be better ways for people and AI to work together.</span></div>
          <div class="ig-li ig-reveal"><img src="/public/images/onboarding-hand-3.webp?v=<%= _v %>" alt="" aria-hidden="true"><span class="t">There will always be opportunities to leave the world better than we found it.</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 04 PROOF -->
  <section class="ig-sec ig-proof">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">03 / We live it</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">We run our own company on these exact agents.</h2>
        <p class="ig-body">Radar, Dan, Pepper, Dash, and Tally are the same agents that run the company that built OTP. Working live, next to our people, every single day. No one else can hand you a philosophy and show you it running.</p>
        <div class="ig-crew">
          <% crew.forEach(function(m){ %>
            <div class="ig-member">
              <img src="/public/images/vs/<%= m.slug %>.png?v=<%= _v %>" alt="<%= m.name %>, the OTP <%= m.role %>" loading="lazy">
              <div class="mn"><%= m.name %></div>
              <div class="mr"><%= m.role %></div>
            </div>
          <% }); %>
        </div>
        <div class="ig-cta"><a href="/free-agents" class="ig-link">Meet the agents &rarr;</a></div>
      </div>
    </div>
  </section>

  <!-- 05 THE PLATFORM -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">04 / The platform</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">Other tools bolt on an AI assistant. OTP makes AI an accountable employee.</h2>
        <p class="ig-body">OTP gives your whole team free meeting software: one chart, one scoreboard, one weekly meeting. Then every AI agent takes a seat, owns a number, and does the work between meetings, next to your people. Bring your own, or start with five of ours.</p>
        <div class="ig-shot">
          <img src="/public/images/vs/l10.png?v=<%= _v %>" alt="The OTP weekly meeting: timed agenda, live scoreboard, every commitment tracked" loading="lazy">
        </div>
        <div class="ig-cta">
          <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Start free &rarr;</a>
          <a href="/compare" class="ig-link">See how it works &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 06 THE MANIFESTO -->
  <section class="ig-sec">
    <div class="ig-wrap">
      <div class="ig-side"><span class="ig-label">05 / The manifesto</span></div>
      <div class="ig-main ig-reveal">
        <h2 class="ig-head">Read <em>The Intelligent Organization</em>.</h2>
        <p class="ig-body">Our founding manifesto for Organizational Intelligence Management. Twelve chapters on why companies forget, and how to build one that never does.</p>
        <div class="ig-cta"><a href="/the-intelligent-organization/" class="ig-link">Read the manifesto &rarr;</a></div>
      </div>
    </div>
  </section>

  <!-- CLOSE -->
  <section class="ig-close">
    <div class="ig-wrap">
      <p class="ig-battle ig-enemy ig-reveal">We refuse to accept that humanity's greatest potential should be spent <span class="ig-mark">managing work<svg viewBox="0 0 200 14" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" d="M3,10 Q55,4 110,8 T197,6"/></svg></span>.</p>
      <p class="ig-comejoin ig-reveal">If you believe people are meant for more, come play the infinite game with us.</p>
      <div class="ig-cta ig-reveal">
        <a href="/sign-up" onclick="return (typeof gtagSendEvent==='function')?gtagSendEvent('/sign-up'):true" class="btn-primary px-8 py-4 text-[16px]">Join us, start free &rarr;</a>
      </div>
      <p class="ig-note">Free for your whole team. No credit card.</p>
    </div>
  </section>
</div>

<script>
(function(){
  var els = [].slice.call(document.querySelectorAll('.ig-reveal'));
  if (!('IntersectionObserver' in window) || (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {
    els.forEach(function(e){ e.classList.add('in'); }); return;
  }
  var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if (e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, { rootMargin:'0px 0px -8% 0px', threshold:0.12 });
  els.forEach(function(e){ io.observe(e); });
  setTimeout(function(){ els.forEach(function(e){ e.classList.add('in'); }); }, 2800);
})();
</script>
