<%
  // grouped: Record<letter, terms[]>, groupedOrder: string[], activeLetters: Set<string>, totalCount: number
  function slugFor(t) { return t.slug; }
%>
<!-- Glossary header -->
<section class="bg-otp-950 border-b border-white/5">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14 pb-10 sm:pb-14">
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
        <span class="px-2 py-0.5 rounded-full bg-otp-500/20 text-otp-300 font-semibold">Reference</span>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight">AI Coordination Dictionary</h1>
      <p class="text-lg text-gray-300 mt-2"><%= totalCount %> Terms Defined</p>
      <p class="text-gray-400 mt-4 max-w-2xl">Plain English definitions for AI agent coordination plus the operating-system frameworks they build on -- EOS, Scaling Up, 4DX, OKRs, and Holacracy. Every term has its own page, its own structured data, and links to the related terms you'll need to understand it fully.</p>
    </div>
  </div>
</section>

<!-- Glossary body -->
<section class="bg-white py-10 sm:py-14">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- A-Z Quick nav -->
    <div class="mb-10 p-4 bg-gray-50 rounded-xl border border-gray-100">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Jump to letter</div>
      <div class="flex flex-wrap gap-2 text-sm font-semibold">
        <% groupedOrder.forEach(function(L) { %>
          <% if (activeLetters.has(L)) { %>
            <a href="#section-<%= L === '#' ? 'num' : L.toLowerCase() %>" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-gray-200 text-otp-500 hover:bg-otp-50 hover:border-otp-300 transition-colors"><%= L %></a>
          <% } else { %>
            <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 border border-gray-100 text-gray-300 cursor-default"><%= L %></span>
          <% } %>
        <% }); %>
      </div>
    </div>

    <% groupedOrder.forEach(function(L) {
      var bucket = grouped[L] || [];
      if (!bucket.length) return;
      var anchor = (L === '#') ? 'section-num' : ('section-' + L.toLowerCase());
    %>
      <div id="<%= anchor %>" class="scroll-mt-24 mb-4">
        <h2 class="text-2xl font-extrabold text-otp-600 border-b-2 border-otp-100 pb-2"><%= L %></h2>
      </div>
      <div class="space-y-8 mb-14">
        <% bucket.forEach(function(t) { %>
          <article id="<%= slugFor(t) %>" class="scroll-mt-24">
            <div class="flex items-baseline justify-between gap-4 mb-2">
              <h3 class="text-xl font-bold text-gray-900">
                <a href="/glossary/<%= t.slug %>" class="hover:text-otp-600 transition-colors"><%= t.name %></a>
              </h3>
              <% if (t.framework) { %>
                <span class="text-[11px] font-semibold uppercase tracking-wider text-otp-600 bg-otp-50 border border-otp-100 rounded-full px-2 py-0.5 whitespace-nowrap"><%= t.framework %></span>
              <% } %>
            </div>
            <p class="text-gray-700 leading-relaxed mb-2"><%= t.definition %></p>
            <% if (t.whyItMatters) { %>
              <p class="text-sm text-gray-500 italic mb-2"><span class="not-italic font-semibold text-gray-600">Why it matters:</span> <%= t.whyItMatters %></p>
            <% } %>
            <div class="text-sm">
              <a href="/glossary/<%= t.slug %>" class="text-otp-500 hover:text-otp-600 font-medium">Read full entry →</a>
              <% if (t.relatedSlugs && t.relatedSlugs.length) { %>
                <span class="text-gray-400 mx-2">·</span>
                <span class="text-gray-500">See also:
                  <% t.relatedSlugs.slice(0, 3).forEach(function(rs, i) { %>
                    <a href="/glossary/<%= rs %>" class="text-otp-500 hover:text-otp-600"><%= rs.replace(/-/g, ' ') %></a><% if (i < Math.min(t.relatedSlugs.length, 3) - 1) { %>, <% } %>
                  <% }); %>
                </span>
              <% } %>
            </div>
          </article>
        <% }); %>
      </div>
    <% }); %>

    <!-- Coordination Stack callout -->
    <div class="mt-16 p-6 bg-gray-50 rounded-xl border border-gray-100">
      <h2 class="text-lg font-bold text-gray-900 mb-2">The Three-Layer Stack</h2>
      <p class="text-gray-700 mb-4">AI coordination operates at three layers. Each layer solves a different problem and uses a different protocol.</p>
      <div class="grid sm:grid-cols-3 gap-4 text-sm">
        <a href="/glossary/mcp" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-otp-300 transition-colors">
          <div class="font-semibold text-gray-900 mb-1">Tool Layer</div>
          <div class="text-gray-600">MCP (Model Context Protocol)</div>
        </a>
        <a href="/glossary/a2a" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-otp-300 transition-colors">
          <div class="font-semibold text-gray-900 mb-1">Agent Layer</div>
          <div class="text-gray-600">A2A (Agent-to-Agent)</div>
        </a>
        <a href="/glossary/otp" class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-otp-300 transition-colors">
          <div class="font-semibold text-gray-900 mb-1">Organization Layer</div>
          <div class="text-gray-600">OTP (Organization Transport Protocol)</div>
        </a>
      </div>
    </div>

    <p class="mt-10 text-sm text-gray-500">
      Missing a term? <a href="/tickets" class="text-otp-500 hover:text-otp-600 font-medium">Submit it</a> and we'll add it.
    </p>
  </div>
</section>
