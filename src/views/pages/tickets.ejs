<div class="max-w-4xl mx-auto px-4 py-8" data-is-super-admin="<%= isSuperAdmin ? '1' : '0' %>">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold">Issue Tracker</h1>
      <p class="text-gray-500 text-sm">Report bugs, request features, and track resolutions.</p>
      <% if (isSuperAdmin) { %>
        <div class="mt-1 text-xs text-purple-700 bg-purple-50 inline-block px-2 py-0.5 rounded">SUPER ADMIN: edit / resolve / delete enabled on every ticket</div>
      <% } %>
    </div>
    <button id="new-ticket-btn" class="px-4 py-2 bg-otp-500 text-white rounded-lg text-sm font-medium hover:bg-otp-400">
      Report Issue
    </button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-red-600" id="stat-open">-</div>
      <div class="text-xs text-gray-500">Open</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-yellow-600" id="stat-progress">-</div>
      <div class="text-xs text-gray-500">In Progress</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-green-600" id="stat-resolved">-</div>
      <div class="text-xs text-gray-500">Resolved</div>
    </div>
    <div class="bg-white p-4 border rounded-lg text-center">
      <div class="text-2xl font-bold text-gray-500" id="stat-closed">-</div>
      <div class="text-xs text-gray-500">Closed</div>
    </div>
  </div>

  <!-- New Ticket Form (hidden by default) -->
  <div id="ticket-form" class="hidden bg-otp-50 border border-otp-200 p-6 rounded-lg mb-8">
    <h2 class="font-semibold text-lg mb-4">Report an Issue</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" id="ticket-title" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="Brief description of the issue">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea id="ticket-description" rows="4" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="Steps to reproduce, expected behavior, actual behavior..."></textarea>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
          <select id="ticket-category" class="w-full border rounded-lg px-3 py-2 text-sm">
            <option value="bug">Bug</option>
            <option value="feature">Feature Request</option>
            <option value="question">Question</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
          <select id="ticket-priority" class="w-full border rounded-lg px-3 py-2 text-sm">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
            <option value="critical">Critical</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email (optional)</label>
          <input type="email" id="ticket-email" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="For follow-up">
        </div>
      </div>
      <div class="flex gap-2">
        <button id="submit-ticket" class="px-4 py-2 bg-otp-500 text-white rounded-lg text-sm font-medium hover:bg-otp-400">Submit</button>
        <button id="cancel-ticket" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-300">Cancel</button>
      </div>
      <div id="ticket-success" class="hidden text-green-700 text-sm bg-green-50 border border-green-200 p-3 rounded-lg"></div>
      <div id="ticket-error" class="hidden text-red-700 text-sm bg-red-50 border border-red-200 p-3 rounded-lg"></div>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex gap-3 mb-4">
    <button class="ticket-filter px-3 py-1 text-sm rounded-lg border bg-otp-500 text-white" data-status="">All</button>
    <button class="ticket-filter px-3 py-1 text-sm rounded-lg border hover:bg-gray-50" data-status="open">Open</button>
    <button class="ticket-filter px-3 py-1 text-sm rounded-lg border hover:bg-gray-50" data-status="in_progress">In Progress</button>
    <button class="ticket-filter px-3 py-1 text-sm rounded-lg border hover:bg-gray-50" data-status="resolved">Resolved</button>
    <button class="ticket-filter px-3 py-1 text-sm rounded-lg border hover:bg-gray-50" data-status="closed">Closed</button>
  </div>

  <!-- Ticket List -->
  <div id="ticket-list" class="space-y-3">
    <div class="text-center py-8 text-gray-400 text-sm">Loading tickets...</div>
  </div>
</div>

<script>
(function() {
  var currentFilter = '';
  var IS_SUPER_ADMIN = document.querySelector('[data-is-super-admin]')?.dataset.isSuperAdmin === '1';

  // Toggle form
  document.getElementById('new-ticket-btn').addEventListener('click', function() {
    document.getElementById('ticket-form').classList.toggle('hidden');
  });
  document.getElementById('cancel-ticket').addEventListener('click', function() {
    document.getElementById('ticket-form').classList.add('hidden');
  });

  // Load stats
  fetch('/api/v1/tickets/stats').then(r => r.json()).then(function(data) {
    var s = data.stats;
    document.getElementById('stat-open').textContent = s.open_count || '0';
    document.getElementById('stat-progress').textContent = s.in_progress_count || '0';
    document.getElementById('stat-resolved').textContent = s.resolved_count || '0';
    document.getElementById('stat-closed').textContent = s.closed_count || '0';
  }).catch(function() {});

  // Load tickets
  function loadTickets(status) {
    var url = '/api/v1/tickets' + (status ? '?status=' + status : '');
    fetch(url).then(r => r.json()).then(function(data) {
      var list = document.getElementById('ticket-list');
      if (!data.tickets || data.tickets.length === 0) {
        list.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm">No tickets found.</div>';
        return;
      }
      list.innerHTML = data.tickets.map(function(t) {
        var statusColor = {
          open: 'bg-red-100 text-red-700',
          in_progress: 'bg-yellow-100 text-yellow-700',
          resolved: 'bg-green-100 text-green-700',
          closed: 'bg-gray-100 text-gray-500',
        }[t.status] || 'bg-gray-100 text-gray-500';
        var priorityColor = {
          critical: 'text-red-600',
          high: 'text-orange-600',
          medium: 'text-yellow-600',
          low: 'text-gray-500',
        }[t.priority] || 'text-gray-500';
        var adminButtons = '';
        if (IS_SUPER_ADMIN) {
          adminButtons =
            '<div class="mt-3 flex gap-1.5 flex-wrap">' +
              '<button data-action="edit"    data-id="' + t.id + '" class="text-xs px-2 py-1 bg-gray-100 rounded hover:bg-gray-200">Edit</button>' +
              (t.status !== 'resolved' && t.status !== 'closed'
                ? '<button data-action="resolve" data-id="' + t.id + '" class="text-xs px-2 py-1 bg-emerald-100 text-emerald-800 rounded hover:bg-emerald-200 font-medium">Resolve</button>'
                : '<button data-action="reopen"  data-id="' + t.id + '" class="text-xs px-2 py-1 bg-amber-100 text-amber-800 rounded hover:bg-amber-200">Reopen</button>') +
              '<button data-action="delete"  data-id="' + t.id + '" class="text-xs px-2 py-1 bg-red-50 text-red-700 rounded hover:bg-red-100">Delete</button>' +
            '</div>' +
            '<div data-form="edit-' + t.id + '" class="hidden mt-3 border-t pt-3 space-y-2">' +
              '<input data-field="title"       type="text" value="' + escapeAttr(t.title) + '" class="w-full border rounded p-2 text-sm">' +
              '<textarea data-field="description" rows="3" class="w-full border rounded p-2 text-sm">' + escapeHtml(t.description || '') + '</textarea>' +
              '<div class="grid grid-cols-2 gap-2">' +
                '<select data-field="priority" class="border rounded p-2 text-sm">' +
                  ['low','medium','high','critical'].map(function(p){ return '<option value="'+p+'"'+(t.priority===p?' selected':'')+'>'+p+'</option>'; }).join('') +
                '</select>' +
                '<select data-field="status" class="border rounded p-2 text-sm">' +
                  ['open','in_progress','resolved','closed'].map(function(s){ return '<option value="'+s+'"'+(t.status===s?' selected':'')+'>'+s.replace('_',' ')+'</option>'; }).join('') +
                '</select>' +
              '</div>' +
              '<div class="flex gap-2">' +
                '<button data-action="edit-save"   data-id="' + t.id + '" class="text-xs px-3 py-1 bg-otp-500 text-white rounded hover:bg-otp-400">Save</button>' +
                '<button data-action="edit-cancel" data-id="' + t.id + '" class="text-xs px-3 py-1 bg-gray-200 rounded hover:bg-gray-300">Cancel</button>' +
              '</div>' +
            '</div>' +
            '<div data-form="resolve-' + t.id + '" class="hidden mt-3 border-t pt-3 bg-emerald-50 -mx-4 -mb-4 px-4 pb-4 rounded-b-lg">' +
              '<label class="block text-xs font-medium text-emerald-900 mb-1">Resolution (how was this fixed?)</label>' +
              '<textarea data-field="resolution" rows="3" class="w-full border rounded p-2 text-sm mb-2" placeholder="What we did about this issue, what was decided, fix or workaround...">' + escapeHtml(t.resolution || '') + '</textarea>' +
              '<div class="flex gap-2">' +
                '<button data-action="resolve-save"   data-id="' + t.id + '" class="text-xs px-3 py-1 bg-emerald-600 text-white rounded hover:bg-emerald-500 font-medium">Resolve</button>' +
                '<button data-action="resolve-cancel" data-id="' + t.id + '" class="text-xs px-3 py-1 bg-gray-200 rounded hover:bg-gray-300">Cancel</button>' +
              '</div>' +
            '</div>';
        }
        return '<div class="bg-white p-4 rounded-lg border claim-card" data-ticket-id="' + t.id + '">' +
          '<div class="flex items-start justify-between">' +
            '<div class="flex-1">' +
              '<div class="flex items-center gap-2 mb-1">' +
                '<span class="text-xs ' + priorityColor + ' font-medium uppercase">' + t.priority + '</span>' +
                '<span class="font-medium">' + escapeHtml(t.title) + '</span>' +
              '</div>' +
              '<p class="text-sm text-gray-500">' + escapeHtml(t.description || '') + '</p>' +
              (t.resolution ? '<div class="mt-2 text-sm text-green-700 bg-green-50 p-2 rounded"><strong>Resolution:</strong> ' + escapeHtml(t.resolution) + '</div>' : '') +
            '</div>' +
            '<div class="flex flex-col items-end gap-1 ml-4 flex-shrink-0">' +
              '<span class="text-xs px-2 py-0.5 rounded ' + statusColor + '">' + t.status.replace('_', ' ') + '</span>' +
              '<span class="text-xs text-gray-400">' + new Date(t.created_at || t.createdAt).toLocaleDateString() + '</span>' +
            '</div>' +
          '</div>' +
          adminButtons +
        '</div>';
      }).join('');

      // Wire admin handlers (delegated)
      if (IS_SUPER_ADMIN) wireAdminHandlers();
    }).catch(function() {
      document.getElementById('ticket-list').innerHTML = '<div class="text-center py-8 text-gray-400 text-sm">Failed to load tickets.</div>';
    });
  }

  function wireAdminHandlers() {
    document.querySelectorAll('[data-ticket-id]').forEach(function(card) {
      var id = card.dataset.ticketId;
      var editBtn    = card.querySelector('[data-action="edit"]');
      var resolveBtn = card.querySelector('[data-action="resolve"]');
      var reopenBtn  = card.querySelector('[data-action="reopen"]');
      var deleteBtn  = card.querySelector('[data-action="delete"]');
      var editForm    = card.querySelector('[data-form="edit-' + id + '"]');
      var resolveForm = card.querySelector('[data-form="resolve-' + id + '"]');

      function hideForms() {
        if (editForm) editForm.classList.add('hidden');
        if (resolveForm) resolveForm.classList.add('hidden');
      }

      if (editBtn) editBtn.addEventListener('click', function() { hideForms(); editForm && editForm.classList.remove('hidden'); });
      if (resolveBtn) resolveBtn.addEventListener('click', function() { hideForms(); resolveForm && resolveForm.classList.remove('hidden'); });

      var editCancel = card.querySelector('[data-action="edit-cancel"]');
      if (editCancel) editCancel.addEventListener('click', function() { editForm.classList.add('hidden'); });
      var resolveCancel = card.querySelector('[data-action="resolve-cancel"]');
      if (resolveCancel) resolveCancel.addEventListener('click', function() { resolveForm.classList.add('hidden'); });

      var editSave = card.querySelector('[data-action="edit-save"]');
      if (editSave) editSave.addEventListener('click', async function() {
        editSave.disabled = true; editSave.textContent = 'Saving...';
        var body = {
          title:       editForm.querySelector('[data-field="title"]').value.trim(),
          description: editForm.querySelector('[data-field="description"]').value,
          priority:    editForm.querySelector('[data-field="priority"]').value,
          status:      editForm.querySelector('[data-field="status"]').value,
        };
        var res = await fetch('/api/v1/tickets/' + id, { method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(r => r.json());
        if (res && res.error) { alert('Save failed: ' + (res.error.message || res.message || 'unknown')); editSave.disabled = false; editSave.textContent = 'Save'; return; }
        loadTickets(currentFilter);
      });

      var resolveSave = card.querySelector('[data-action="resolve-save"]');
      if (resolveSave) resolveSave.addEventListener('click', async function() {
        var resolution = resolveForm.querySelector('[data-field="resolution"]').value.trim();
        if (!resolution) return alert('Resolution is required.');
        resolveSave.disabled = true; resolveSave.textContent = 'Resolving...';
        var res = await fetch('/api/v1/tickets/' + id, { method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'resolved', resolution: resolution }) }).then(r => r.json());
        if (res && res.error) { alert('Resolve failed: ' + (res.error.message || res.message || 'unknown')); resolveSave.disabled = false; resolveSave.textContent = 'Resolve'; return; }
        loadTickets(currentFilter);
      });

      if (reopenBtn) reopenBtn.addEventListener('click', async function() {
        if (!confirm('Reopen this ticket?')) return;
        var res = await fetch('/api/v1/tickets/' + id, { method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'open' }) }).then(r => r.json());
        if (res && res.error) { alert('Reopen failed: ' + (res.error.message || res.message || 'unknown')); return; }
        loadTickets(currentFilter);
      });

      if (deleteBtn) deleteBtn.addEventListener('click', async function() {
        if (!confirm('Delete this ticket? This soft-deletes it (recoverable in DB).')) return;
        deleteBtn.disabled = true; deleteBtn.textContent = '...';
        var res = await fetch('/api/v1/tickets/' + id, { method: 'DELETE', credentials: 'include' }).then(r => r.json());
        if (res && res.error) { alert('Delete failed: ' + (res.error.message || res.message || 'unknown')); deleteBtn.disabled = false; deleteBtn.textContent = 'Delete'; return; }
        loadTickets(currentFilter);
      });
    });
  }

  function escapeAttr(str) { return (str || '').replace(/"/g, '&quot;'); }

  loadTickets('');

  // Filter buttons
  document.querySelectorAll('.ticket-filter').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.ticket-filter').forEach(function(b) {
        b.classList.remove('bg-otp-500', 'text-white');
        b.classList.add('hover:bg-gray-50');
      });
      this.classList.add('bg-otp-500', 'text-white');
      this.classList.remove('hover:bg-gray-50');
      loadTickets(this.dataset.status);
    });
  });

  // Submit ticket
  document.getElementById('submit-ticket').addEventListener('click', function() {
    var title = document.getElementById('ticket-title').value;
    var description = document.getElementById('ticket-description').value;
    var category = document.getElementById('ticket-category').value;
    var priority = document.getElementById('ticket-priority').value;
    var email = document.getElementById('ticket-email').value;

    document.getElementById('ticket-success').classList.add('hidden');
    document.getElementById('ticket-error').classList.add('hidden');

    fetch('/api/v1/tickets', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: title, description: description, category: category, priority: priority, reporterEmail: email || undefined }),
    }).then(r => r.json()).then(function(data) {
      if (data.ticket) {
        document.getElementById('ticket-success').textContent = 'Ticket #' + data.ticket.id.substring(0, 8) + ' created. We will review it shortly.';
        document.getElementById('ticket-success').classList.remove('hidden');
        document.getElementById('ticket-title').value = '';
        document.getElementById('ticket-description').value = '';
        loadTickets(currentFilter);
        // Reload stats
        fetch('/api/v1/tickets/stats').then(r => r.json()).then(function(s) {
          document.getElementById('stat-open').textContent = s.stats.open_count || '0';
        });
      } else {
        document.getElementById('ticket-error').textContent = data.error?.message || 'Failed to create ticket.';
        document.getElementById('ticket-error').classList.remove('hidden');
      }
    }).catch(function(err) {
      document.getElementById('ticket-error').textContent = 'Network error. Please try again.';
      document.getElementById('ticket-error').classList.remove('hidden');
    });
  });

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str || '';
    return div.innerHTML;
  }
})();
</script>
