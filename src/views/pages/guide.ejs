<%# /guide -- the OrgTP User Guide help center. v7 layout, dual-rendered
    (renderInShell): signed-in viewers get the app shell, signed-out visitors
    get the v7 marketing compose. Content comes from src/data/guide-content.ts
    (guideSections local). bodyHtml is trusted authored product documentation
    (our own doc, no user data), rendered raw. NOTE: an EJS comment closes on
    the first percent-gt it sees, so no EJS tag examples in here.

    Search is fully client-side: the content is already on the page, so typing
    filters sections by their textContent. Highlighting wraps matches in
    mark elements by splitting TEXT NODES (TreeWalker) -- the query string is
    never interpolated into innerHTML, so a query like an img-onerror payload
    is inert. Deep link: /guide?q=term runs the search on load (Help-panel
    search box target). %>
<style>
  .gd-search-wrap { position:relative; }
  .gd-search {
    width:100%; padding:14px 110px 14px 46px; font-size:15px; color:var(--ink);
    background:var(--card); border:1.5px solid var(--line); border-radius:14px;
    outline:none; transition:border-color .15s ease, box-shadow .15s ease;
  }
  .gd-search:focus { border-color:var(--blue); box-shadow:0 0 0 4px rgba(13,125,242,.12); }
  .gd-search-icon { position:absolute; left:16px; top:50%; transform:translateY(-50%); pointer-events:none; }
  .gd-clear {
    position:absolute; right:10px; top:50%; transform:translateY(-50%);
    display:none; padding:6px 12px; font-size:12px; font-weight:600;
    color:var(--ink-soft); background:var(--grey); border:1px solid var(--line);
    border-radius:9999px; cursor:pointer;
  }
  .gd-count { font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-mute); min-height:18px; }

  .gd-toc { position:sticky; top:96px; align-self:start; max-height:calc(100vh - 120px); overflow:auto; }
  .gd-toc a {
    display:flex; gap:10px; align-items:baseline; padding:6px 10px; border-radius:8px;
    font-size:13px; color:var(--ink-soft); text-decoration:none; line-height:1.4;
  }
  .gd-toc a:hover { background:var(--grey); color:var(--ink); }
  .gd-toc a.gd-active { background:rgba(13,125,242,.08); color:var(--blue-deep); font-weight:600; }
  .gd-toc-no {
    font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-mute);
    flex:none; width:18px; text-align:right;
  }

  .gd-sec { scroll-margin-top:96px; }
  .gd-sec-no {
    width:36px; height:36px; border-radius:10px; flex:none;
    display:flex; align-items:center; justify-content:center;
    font-family:'Schibsted Grotesk',sans-serif; font-weight:800; font-size:15px;
    background:var(--orgy); color:var(--ink);
  }
  .gd-body { font-size:14.5px; color:var(--ink-soft); line-height:1.72; }
  .gd-body p { margin:0 0 12px; }
  .gd-body p:last-child { margin-bottom:0; }
  .gd-body h3 {
    font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:1.05rem;
    color:var(--ink); margin:20px 0 8px; letter-spacing:-0.01em;
  }
  .gd-body ul, .gd-body ol { margin:0 0 12px; padding-left:22px; }
  .gd-body ul { list-style:disc; }
  .gd-body ol { list-style:decimal; }
  .gd-body li { margin:5px 0; }
  .gd-body li::marker { color:var(--ink-mute); }
  .gd-body strong { color:var(--ink); font-weight:600; }
  .gd-body code {
    font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--blue-deep);
    background:var(--grey); border:1px solid var(--line); border-radius:5px; padding:1px 5px;
  }
  .gd-body table { width:100%; border-collapse:collapse; margin:4px 0 14px; font-size:13.5px; }
  .gd-body th {
    text-align:left; padding:8px 10px; border-bottom:2px solid var(--line);
    font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase;
    letter-spacing:0.08em; color:var(--ink-mute);
  }
  .gd-body th strong { font-weight:600; color:var(--ink-mute); }
  .gd-body td { padding:9px 10px; border-bottom:1px solid var(--line); vertical-align:top; }
  .gd-body tr:last-child td { border-bottom:none; }
  .gd-body mark, .gd-toc mark, .gd-sec h2 mark {
    background:rgba(255,213,79,.85); color:inherit; border-radius:3px; padding:0 1px;
  }
  .gd-empty { display:none; }
</style>

<%# In-shell trim: inside the authed main layout (renderInShell), the app
    shell's fixed nav is already cleared by the layout's pt, so the v7
    nav-clearing pt-[124px]/pt-[148px] would double the gap. Inline style
    wins over both Tailwind classes. authUserId only exists on the authed
    path -- the v7 marketing render is unchanged. %>
<!-- ================= HERO + SEARCH ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-10 sm:pt-[148px] sm:pb-12"<%- (typeof authUserId !== 'undefined' && authUserId) ? ' style="padding-top:56px;"' : '' %>>
    <div class="eyebrow mb-4 flex items-center gap-2.5">
      <span class="tick" style="background:var(--orgy);"></span>Help Center
    </div>
    <h1 class="font-display text-[var(--ink)]"
        style="font-size:clamp(2rem,4.4vw,3.2rem); line-height:1.1; font-weight:700; letter-spacing:-0.025em;">
      OrgTP User Guide
    </h1>
    <p class="text-[16px] text-[var(--ink-soft)] leading-[1.7] max-w-[40rem] mt-4">
      A complete walkthrough of every part of OrgTP, written for someone using it for the first time. No prior EOS or "operating system" knowledge assumed.
    </p>

    <div class="max-w-[40rem] mt-7">
      <div class="gd-search-wrap">
        <svg class="gd-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--ink-mute)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="gd-search" class="gd-search" type="search" placeholder="Search the guide&hellip; (e.g. scorecard, invite, import)"
               autocomplete="off" spellcheck="false" aria-label="Search the user guide">
        <button id="gd-clear" class="gd-clear" type="button">Clear</button>
      </div>
      <div id="gd-count" class="gd-count mt-2.5" aria-live="polite"></div>
    </div>
  </div>
</section>

<!-- ================= TOC + SECTIONS ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-12 sm:py-16">
    <div class="lg:grid lg:gap-10" style="grid-template-columns:250px minmax(0,1fr);">

      <nav class="gd-toc hidden lg:block" aria-label="Guide contents">
        <div class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.14em] text-[var(--ink-mute)] px-2.5 mb-2">Contents</div>
        <% guideSections.forEach(function(s) { %>
          <a href="#<%= s.id %>" class="gd-toc-link" data-target="<%= s.id %>">
            <span class="gd-toc-no"><%= s.number %></span>
            <span><%= s.title %></span>
          </a>
        <% }); %>
      </nav>

      <div class="min-w-0">
        <div id="gd-no-results" class="gd-empty card p-8 text-center">
          <p class="text-[15px] text-[var(--ink)] font-semibold mb-1.5">No sections match.</p>
          <p class="text-[13.5px] text-[var(--ink-soft)]">Try a different word, or <a href="/tickets" class="text-[var(--blue-deep)] link-u">raise a ticket</a> and a human will help.</p>
        </div>
        <div class="space-y-6">
          <% guideSections.forEach(function(s) { %>
            <section class="gd-sec card p-6 sm:p-8" id="<%= s.id %>">
              <div class="flex items-center gap-3.5 mb-4">
                <div class="gd-sec-no"><%= s.number %></div>
                <h2 class="font-display text-[var(--ink)] text-[1.3rem] sm:text-[1.45rem] font-bold tracking-[-0.015em] leading-[1.2]"><%= s.title %></h2>
              </div>
              <div class="gd-body"><%- s.bodyHtml %></div>
            </section>
          <% }); %>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var input = document.getElementById('gd-search');
  var clearBtn = document.getElementById('gd-clear');
  var countEl = document.getElementById('gd-count');
  var noResults = document.getElementById('gd-no-results');
  var sections = Array.prototype.slice.call(document.querySelectorAll('.gd-sec'));
  var tocLinks = Array.prototype.slice.call(document.querySelectorAll('.gd-toc-link'));
  var tocBySection = {};
  tocLinks.forEach(function (a) { tocBySection[a.getAttribute('data-target')] = a; });
  // Cache lowercased plain text per section once (textContent of marks is
  // unchanged by highlighting, but caching pre-highlight keeps it cheap).
  var texts = sections.map(function (s) { return (s.textContent || '').toLowerCase(); });

  // --- highlight machinery: text-node walks only, never innerHTML ----------
  function clearMarks(root) {
    Array.prototype.slice.call(root.querySelectorAll('mark[data-gd]')).forEach(function (m) {
      var parent = m.parentNode;
      parent.replaceChild(document.createTextNode(m.textContent), m);
      parent.normalize();
    });
  }
  function markTerm(root, term) {
    // Collect text nodes first -- wrapping mutates the tree mid-walk otherwise.
    var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);
    var nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);
    nodes.forEach(function (node) {
      var text = node.nodeValue;
      var lower = text.toLowerCase();
      var idx = lower.indexOf(term);
      if (idx === -1) return;
      var frag = document.createDocumentFragment();
      var pos = 0;
      while (idx !== -1) {
        if (idx > pos) frag.appendChild(document.createTextNode(text.slice(pos, idx)));
        var mark = document.createElement('mark');
        mark.setAttribute('data-gd', '1');
        mark.textContent = text.slice(idx, idx + term.length); // textContent assignment: safe
        frag.appendChild(mark);
        pos = idx + term.length;
        idx = lower.indexOf(term, pos);
      }
      if (pos < text.length) frag.appendChild(document.createTextNode(text.slice(pos)));
      node.parentNode.replaceChild(frag, node);
    });
  }

  // --- search -------------------------------------------------------------
  function runSearch(q) {
    var terms = q.trim().toLowerCase().split(/\s+/).filter(Boolean);
    var matches = 0;
    sections.forEach(function (sec, i) {
      clearMarks(sec);
      var hit = terms.length === 0 || terms.every(function (t) { return texts[i].indexOf(t) !== -1; });
      sec.style.display = hit ? '' : 'none';
      var toc = tocBySection[sec.id];
      if (toc) toc.style.display = hit ? '' : 'none';
      if (hit) {
        matches++;
        if (terms.length > 0) terms.forEach(function (t) { markTerm(sec, t); });
      }
    });
    if (terms.length === 0) {
      countEl.textContent = '';
      clearBtn.style.display = 'none';
      noResults.style.display = 'none';
    } else {
      countEl.textContent = matches === 1 ? '1 section matches' : matches + ' sections match';
      clearBtn.style.display = 'inline-block';
      noResults.style.display = matches === 0 ? 'block' : 'none';
    }
    // Keep ?q= shareable without adding history entries.
    try {
      var url = new URL(window.location.href);
      if (terms.length > 0) url.searchParams.set('q', q.trim()); else url.searchParams.delete('q');
      history.replaceState(null, '', url.toString());
    } catch (e) { /* older browsers: search still works, URL just doesn't sync */ }
  }

  input.addEventListener('input', function () { runSearch(input.value); });
  clearBtn.addEventListener('click', function () {
    input.value = '';
    runSearch('');
    input.focus();
  });

  // Deep link: /guide?q=term (Help-panel search lands here).
  try {
    var initial = new URLSearchParams(window.location.search).get('q');
    if (initial) { input.value = initial; runSearch(initial); }
  } catch (e) { /* no-op */ }

  // --- active-TOC highlight on scroll (cheap IntersectionObserver) ---------
  if ('IntersectionObserver' in window && tocLinks.length) {
    var activeId = null;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) activeId = entry.target.id;
      });
      tocLinks.forEach(function (a) {
        a.classList.toggle('gd-active', a.getAttribute('data-target') === activeId);
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    sections.forEach(function (s) { io.observe(s); });
  }
})();
</script>
