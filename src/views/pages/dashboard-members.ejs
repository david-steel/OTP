<%
  // Members page. Owner / admin / manager only (gated by requireCanInvite
  // in the route handler). Lists existing org_members + pending invitations
  // and provides an "Invite member" form that POSTs to /api/v1/team/invite.
  var orgName = (locals.org && locals.org.name) || 'Your org';
  var members = locals.members || [];
  var invitations = locals.invitations || [];
  var inviterRole = (locals.member && locals.member.role) || 'owner';
  var featureToggles = locals.featureToggles || [];
  var dataToggles = locals.dataToggles || [];
  var availableRoles = locals.availableRoles || [];
  var chartPositions = locals.chartPositions || [];
  var roleDefaults = locals.roleDefaults || {};
  var orgTeams = locals.orgTeams || [];
  var memberTeams = locals.memberTeams || {};
  var isSuperAdmin = locals.isSuperAdmin === true;
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-8 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <div class="text-xs uppercase tracking-wider text-gray-500 mb-1"><%= orgName %></div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Members</h1>
      <p class="text-sm text-gray-600 mt-1"><%= members.length %> active &middot; <%= invitations.length %> pending invite<%= invitations.length === 1 ? '' : 's' %></p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" onclick="document.getElementById('invite-form').scrollIntoView({behavior:'smooth',block:'start'}); setTimeout(function(){document.querySelector('#invite-form input[name=email]').focus();}, 400);"
              class="text-sm px-4 py-2 bg-otp-600 text-white rounded-lg font-semibold hover:bg-otp-700 inline-flex items-center gap-1.5 shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Invite member
      </button>
      <a href="/dashboard" class="text-xs px-3 py-1.5 bg-white border border-gray-300 rounded hover:bg-gray-50">&larr; Dashboard</a>
    </div>
  </div>

  <!-- Active members -->
  <section class="mb-10">
    <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mb-3">Active</h2>
    <% if (members.length === 0) { %>
      <div class="rounded-lg border border-gray-200 bg-gray-50 p-6 text-sm text-gray-600">No active members yet.</div>
    <% } else { %>
      <div class="overflow-hidden rounded-lg border border-gray-200">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-600">
            <tr>
              <th class="text-left px-4 py-2">Name</th>
              <th class="text-left px-4 py-2">Email</th>
              <th class="text-left px-4 py-2">Role</th>
              <th class="text-left px-4 py-2">Joined</th>
              <th class="text-right px-4 py-2 w-24">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            <% members.forEach(function(m) { %>
              <tr>
                <td class="px-4 py-3"><%= m.displayName || '(no name)' %></td>
                <td class="px-4 py-3 text-gray-600"><%= m.email || '-' %></td>
                <td class="px-4 py-3"><span class="inline-block px-2 py-0.5 rounded bg-otp-50 text-otp-700 text-xs font-semibold uppercase tracking-wide"><%= m.role %></span></td>
                <td class="px-4 py-3 text-gray-500 text-xs"><%= m.joinedAt ? new Date(m.joinedAt).toLocaleDateString() : '-' %></td>
                <td class="px-4 py-3 text-right">
                  <%
                    var memberPayload = {
                      id: m.id,
                      displayName: m.displayName || '',
                      email: m.email || '',
                      role: m.role,
                      status: m.status,
                      claimedEntityIds: Array.isArray(m.claimedEntityIds) ? m.claimedEntityIds : (m.claimedEntityId ? [m.claimedEntityId] : []),
                      featureAccess: m.featureAccess || {},
                      dataAccess: m.dataAccess || {},
                      agentAccess: m.agentAccess || {},
                      teamIds: memberTeams[m.id] || [],
                    };
                  %>
                  <div class="inline-flex gap-1">
                    <% if (isSuperAdmin && m.clerkUserId) { %>
                      <form method="POST" action="/admin/impersonate/<%= m.id %>" class="inline">
                        <button type="submit" class="text-xs px-2 py-1 bg-amber-50 text-amber-800 border border-amber-200 rounded hover:bg-amber-100 font-semibold" title="Super-admin: view the app as this user">View as</button>
                      </form>
                    <% } %>
                    <button type="button"
                            data-member='<%- JSON.stringify(memberPayload).replace(/'/g, "&#39;") %>'
                            onclick="openEditMember(this)"
                            class="text-xs px-2 py-1 bg-otp-50 text-otp-700 border border-otp-200 rounded hover:bg-otp-100">
                      Edit
                    </button>
                    <% if (m.role !== 'owner') { %>
                      <button type="button"
                              data-member-id="<%= m.id %>"
                              data-member-name="<%= (m.displayName || m.email || 'this member').replace(/"/g, '&quot;') %>"
                              onclick="revokeMember(this)"
                              class="text-xs px-2 py-1 bg-rose-50 text-rose-700 border border-rose-200 rounded hover:bg-rose-100">
                        Revoke
                      </button>
                    <% } else { %>
                      <span class="text-xs text-gray-400 italic px-2 py-1">owner</span>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <!-- Pending invitations -->
  <% if (invitations.length > 0) { %>
    <section class="mb-10">
      <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mb-3">Pending invites</h2>
      <div class="overflow-hidden rounded-lg border border-amber-200">
        <table class="w-full text-sm">
          <thead class="bg-amber-50 text-xs uppercase tracking-wide text-amber-800">
            <tr>
              <th class="text-left px-4 py-2">Email</th>
              <th class="text-left px-4 py-2">Role</th>
              <th class="text-left px-4 py-2">Sent</th>
              <th class="text-left px-4 py-2">Expires</th>
              <th class="text-right px-4 py-2 w-40">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            <% invitations.forEach(function(inv) { %>
              <tr>
                <td class="px-4 py-3"><%= inv.email %></td>
                <td class="px-4 py-3"><span class="inline-block px-2 py-0.5 rounded bg-amber-50 text-amber-700 text-xs font-semibold uppercase tracking-wide"><%= inv.role %></span></td>
                <td class="px-4 py-3 text-gray-500 text-xs"><%= inv.createdAt ? new Date(inv.createdAt).toLocaleDateString() : '-' %></td>
                <td class="px-4 py-3 text-gray-500 text-xs"><%= inv.expiresAt ? new Date(inv.expiresAt).toLocaleDateString() : '-' %></td>
                <td class="px-4 py-3 text-right">
                  <div class="inline-flex gap-1">
                    <button type="button"
                            data-invite-id="<%= inv.id %>"
                            data-invite-email="<%= inv.email.replace(/"/g, '&quot;') %>"
                            onclick="resendInvite(this)"
                            class="text-xs px-2 py-1 bg-sky-50 text-sky-700 border border-sky-200 rounded hover:bg-sky-100">
                      Resend
                    </button>
                    <button type="button"
                            data-invite-id="<%= inv.id %>"
                            data-invite-email="<%= inv.email.replace(/"/g, '&quot;') %>"
                            onclick="revokeInvite(this)"
                            class="text-xs px-2 py-1 bg-rose-50 text-rose-700 border border-rose-200 rounded hover:bg-rose-100">
                      Revoke
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>

  <!-- Invite form -->
  <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-bold text-gray-900 mb-1">Invite a member</h2>
    <p class="text-sm text-gray-600 mb-6">Set their role and pre-configure their access. They'll receive an email with a link to accept.</p>

    <form id="invite-form" class="space-y-6">

      <!-- Identity -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Email</span>
          <input name="email" type="email" required class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm" placeholder="bogdan@sneeze.it">
        </label>
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Display name</span>
          <input name="displayName" type="text" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm" placeholder="Bogdan Tabaka">
        </label>
      </div>

      <!-- Role -->
      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Role</span>
        <select name="role" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
          <% availableRoles.forEach(function(r) { %>
            <option value="<%= r.value %>" <%= r.value === 'managee' ? 'selected' : '' %>><%= r.label %></option>
          <% }) %>
        </select>
        <span class="text-xs text-gray-500 mt-1 block">You can invite at-or-below your own role (<%= inviterRole %>).</span>
      </label>

      <!-- Teams (multi-select) -->
      <% if (orgTeams.length > 0) { %>
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Teams</span>
          <select name="teamIds" multiple size="<%= Math.min(5, Math.max(2, orgTeams.length)) %>" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
            <% orgTeams.forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.name %><%= t.type !== 'department' ? ' (' + t.type + ')' : '' %></option>
            <% }) %>
          </select>
          <span class="text-xs text-gray-500 mt-1 block">Hold Cmd / Ctrl to pick multiple. They join these teams immediately on accept and show up in the team's L8 meeting attendees.</span>
        </label>
      <% } %>

      <!-- Org chart positions (multi-select) -->
      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Org chart positions</span>
        <select name="claimedEntityIds" multiple size="6" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
          <% var humans = chartPositions.filter(function(p) { return p.type === 'human'; }); %>
          <% var agents = chartPositions.filter(function(p) { return p.type === 'agent'; }); %>
          <% if (humans.length > 0) { %>
            <optgroup label="Humans">
              <% humans.forEach(function(p) { %>
                <% var taken = p.claimedBy || p.pendingInvite; %>
                <% var takenLabel = p.claimedBy ? ('claimed by ' + (p.claimedBy.displayName || p.claimedBy.email || p.claimedBy.role)) : (p.pendingInvite ? ('invite pending: ' + p.pendingInvite.email) : ''); %>
                <option value="<%= p.externalId %>" <%= taken ? 'disabled' : '' %>>
                  <%= p.label %><%= taken ? ' -- ' + takenLabel : '' %>
                </option>
              <% }) %>
            </optgroup>
          <% } %>
          <% if (agents.length > 0) { %>
            <optgroup label="AI Agents">
              <% agents.forEach(function(p) { %>
                <% var taken = p.claimedBy || p.pendingInvite; %>
                <% var takenLabel = p.claimedBy ? ('claimed by ' + (p.claimedBy.displayName || p.claimedBy.email || p.claimedBy.role)) : (p.pendingInvite ? ('invite pending: ' + p.pendingInvite.email) : ''); %>
                <option value="<%= p.externalId %>" <%= taken ? 'disabled' : '' %>>
                  <%= p.label %><%= taken ? ' -- ' + takenLabel : '' %>
                </option>
              <% }) %>
            </optgroup>
          <% } %>
        </select>
        <span class="text-xs text-gray-500 mt-1 block">
          <% if (chartPositions.length === 0) { %>
            No org chart published yet. Build one at <a href="/dashboard/team" class="underline">/dashboard/team</a>, then come back to assign tiles.
          <% } else { %>
            Hold Cmd / Ctrl to select multiple tiles -- one human can hold several seats. Tiles already claimed are disabled. Leave nothing selected if this person isn't on the chart yet.
          <% } %>
        </span>
      </label>

      <!-- Feature toggles -->
      <details class="border border-gray-200 rounded-lg overflow-hidden" open>
        <summary class="cursor-pointer bg-gray-50 px-4 py-2.5 text-xs font-bold uppercase tracking-wide text-gray-700 select-none">Feature access</summary>
        <div class="p-4 space-y-3">
          <% featureToggles.forEach(function(t) { %>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="feature_<%= t.key %>" <%= t.defaultOn ? 'checked' : '' %> class="mt-0.5">
              <span class="flex-1">
                <span class="font-semibold text-sm text-gray-900"><%= t.label %></span>
                <span class="block text-xs text-gray-500 mt-0.5"><%= t.description %></span>
              </span>
            </label>
          <% }) %>
        </div>
      </details>

      <!-- Data toggles -->
      <details class="border border-gray-200 rounded-lg overflow-hidden">
        <summary class="cursor-pointer bg-gray-50 px-4 py-2.5 text-xs font-bold uppercase tracking-wide text-gray-700 select-none">Data access</summary>
        <div class="p-4 space-y-3">
          <% dataToggles.forEach(function(t) { %>
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="data_<%= t.key %>" <%= t.defaultOn ? 'checked' : '' %> class="mt-0.5">
              <span class="flex-1">
                <span class="font-semibold text-sm text-gray-900"><%= t.label %></span>
                <span class="block text-xs text-gray-500 mt-0.5"><%= t.description %></span>
              </span>
            </label>
          <% }) %>
        </div>
      </details>

      <!-- Agent toggles (free-form for v1) -->
      <details class="border border-gray-200 rounded-lg overflow-hidden">
        <summary class="cursor-pointer bg-gray-50 px-4 py-2.5 text-xs font-bold uppercase tracking-wide text-gray-700 select-none">Agent access</summary>
        <div class="p-4">
          <label class="block">
            <span class="text-xs text-gray-600 mb-1 block">Comma-separated agent slugs (e.g. <code class="text-[11px] bg-gray-100 px-1 py-0.5 rounded">dirk, crystal, dash</code>). Each agent listed becomes a granted toggle on the new member's profile.</span>
            <input name="agentSlugs" type="text" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm font-mono" placeholder="dirk, crystal">
          </label>
        </div>
      </details>

      <!-- Submit -->
      <div class="flex items-center justify-between gap-3 pt-2">
        <div id="invite-status" class="text-sm text-gray-600 min-h-[1.25rem]"></div>
        <button type="submit" id="invite-submit" class="px-5 py-2 bg-otp-600 text-white rounded-lg font-semibold text-sm hover:bg-otp-700 disabled:opacity-50">
          Send invite
        </button>
      </div>
    </form>
  </section>
</div>

<!-- Edit member modal -->
<div id="edit-member-modal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center p-4 overflow-y-auto" onclick="if (event.target.id === 'edit-member-modal') closeEditMember()">
  <div class="bg-white rounded-xl shadow-2xl max-w-2xl w-full p-6 my-8">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 class="text-lg font-bold text-gray-900">Edit member</h3>
        <p class="text-xs text-gray-500 mt-0.5" id="edit-member-subtitle"></p>
      </div>
      <button onclick="closeEditMember()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
    </div>

    <form id="edit-member-form" class="space-y-5">
      <input type="hidden" id="edit-member-id">

      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Display name</span>
        <input id="edit-displayName" type="text" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
      </label>

      <div class="grid grid-cols-2 gap-3">
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Role</span>
          <select id="edit-role" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
            <% availableRoles.forEach(function(r) { %>
              <option value="<%= r.value %>"><%= r.label %></option>
            <% }) %>
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Status</span>
          <select id="edit-status" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
            <option value="active">Active</option>
            <option value="suspended">Suspended</option>
            <option value="inactive">Inactive (chart only)</option>
          </select>
        </label>
      </div>

      <% if (orgTeams.length > 0) { %>
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Teams</span>
          <select id="edit-teamIds" multiple size="<%= Math.min(5, Math.max(2, orgTeams.length)) %>" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
            <% orgTeams.forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.name %></option>
            <% }) %>
          </select>
        </label>
      <% } %>

      <% if (chartPositions.length > 0) { %>
        <label class="block">
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Chart tiles</span>
          <select id="edit-claimedEntityIds" multiple size="5" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm">
            <% chartPositions.forEach(function(p) { %>
              <option value="<%= p.externalId %>"><%= p.label %> (<%= p.type %>)</option>
            <% }) %>
          </select>
        </label>
      <% } %>

      <details class="border border-gray-200 rounded-lg overflow-hidden">
        <summary class="cursor-pointer bg-gray-50 px-4 py-2 text-xs font-bold uppercase tracking-wide text-gray-700 select-none">Feature access</summary>
        <div class="p-3 space-y-2">
          <% featureToggles.forEach(function(t) { %>
            <label class="flex items-center gap-2 cursor-pointer text-sm">
              <input type="checkbox" data-toggle-type="feature" data-toggle-key="<%= t.key %>" class="edit-toggle">
              <span class="text-gray-800"><%= t.label %></span>
            </label>
          <% }) %>
        </div>
      </details>

      <details class="border border-gray-200 rounded-lg overflow-hidden">
        <summary class="cursor-pointer bg-gray-50 px-4 py-2 text-xs font-bold uppercase tracking-wide text-gray-700 select-none">Data access</summary>
        <div class="p-3 space-y-2">
          <% dataToggles.forEach(function(t) { %>
            <label class="flex items-center gap-2 cursor-pointer text-sm">
              <input type="checkbox" data-toggle-type="data" data-toggle-key="<%= t.key %>" class="edit-toggle">
              <span class="text-gray-800"><%= t.label %></span>
            </label>
          <% }) %>
        </div>
      </details>

      <label class="block">
        <span class="text-xs font-semibold uppercase tracking-wide text-gray-700">Agent slugs (comma-separated)</span>
        <input id="edit-agentSlugs" type="text" class="mt-1 w-full border border-gray-300 rounded px-3 py-2 text-sm font-mono" placeholder="dirk, crystal">
      </label>

      <div class="flex items-center justify-between gap-3 pt-2">
        <div id="edit-status-msg" class="text-sm text-gray-600 min-h-[1.25rem]"></div>
        <div class="flex gap-2">
          <button type="button" onclick="closeEditMember()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded text-sm font-medium">Cancel</button>
          <button type="submit" id="edit-submit" class="px-4 py-2 bg-otp-600 text-white rounded-lg text-sm font-semibold hover:bg-otp-700 disabled:opacity-50">Save changes</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
window.openEditMember = function(btn) {
  var raw = btn.getAttribute('data-member');
  if (!raw) return;
  var m;
  try { m = JSON.parse(raw); } catch (e) { alert('Could not parse member data.'); return; }

  document.getElementById('edit-member-id').value = m.id;
  document.getElementById('edit-member-subtitle').textContent = (m.displayName || m.email || m.id);
  document.getElementById('edit-displayName').value = m.displayName || '';
  document.getElementById('edit-role').value = m.role || 'managee';
  // The role 'owner' isn't in availableRoles for non-owners; if the modal
  // opens for an owner, the dropdown defaults to the first option, which
  // is fine because the server protects owner role from being demoted.
  document.getElementById('edit-status').value = m.status === 'revoked' ? 'active' : (m.status || 'active');

  // Multi-selects
  var teamSel = document.getElementById('edit-teamIds');
  if (teamSel) {
    Array.prototype.forEach.call(teamSel.options, function(o) {
      o.selected = (m.teamIds || []).indexOf(o.value) !== -1;
    });
  }
  var tileSel = document.getElementById('edit-claimedEntityIds');
  if (tileSel) {
    Array.prototype.forEach.call(tileSel.options, function(o) {
      o.selected = (m.claimedEntityIds || []).indexOf(o.value) !== -1;
    });
  }

  // Toggles
  Array.prototype.forEach.call(document.querySelectorAll('.edit-toggle'), function(el) {
    var type = el.getAttribute('data-toggle-type');
    var key = el.getAttribute('data-toggle-key');
    var src = type === 'feature' ? (m.featureAccess || {}) : (m.dataAccess || {});
    el.checked = src[key] === true;
  });

  // Agent slugs
  var agentKeys = Object.keys(m.agentAccess || {}).filter(function(k) { return m.agentAccess[k] === true; });
  document.getElementById('edit-agentSlugs').value = agentKeys.join(', ');

  document.getElementById('edit-status-msg').textContent = '';
  var modal = document.getElementById('edit-member-modal');
  modal.classList.remove('hidden');
  modal.classList.add('flex');
};

window.closeEditMember = function() {
  var modal = document.getElementById('edit-member-modal');
  modal.classList.add('hidden');
  modal.classList.remove('flex');
};

(function() {
  var form = document.getElementById('edit-member-form');
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var id = document.getElementById('edit-member-id').value;
    var btn = document.getElementById('edit-submit');
    var msg = document.getElementById('edit-status-msg');
    btn.disabled = true; msg.textContent = 'Saving...';
    msg.className = 'text-sm text-gray-600 min-h-[1.25rem]';

    function readMulti(id) {
      var sel = document.getElementById(id);
      if (!sel) return undefined;
      var out = [];
      Array.prototype.forEach.call(sel.selectedOptions, function(o) { if (o.value) out.push(o.value); });
      return out;
    }
    var feature = {}, data = {};
    Array.prototype.forEach.call(document.querySelectorAll('.edit-toggle'), function(el) {
      var type = el.getAttribute('data-toggle-type');
      var key = el.getAttribute('data-toggle-key');
      (type === 'feature' ? feature : data)[key] = el.checked;
    });
    var agentSlugs = String(document.getElementById('edit-agentSlugs').value || '').split(',').map(function(s) { return s.trim(); }).filter(Boolean);
    var agentAccess = {};
    agentSlugs.forEach(function(s) { agentAccess[s] = true; });

    var body = {
      displayName: document.getElementById('edit-displayName').value || null,
      role: document.getElementById('edit-role').value,
      status: document.getElementById('edit-status').value,
      teamIds: readMulti('edit-teamIds'),
      claimedEntityIds: readMulti('edit-claimedEntityIds'),
      featureAccess: feature,
      dataAccess: data,
      agentAccess: agentAccess,
    };

    try {
      var res = await fetch('/api/v1/team/members/' + id, {
        method: 'PATCH',
