(function() {
  var form = document.getElementById('invite-form');
  var status = document.getElementById('invite-status');
  var btn = document.getElementById('invite-submit');
  if (!form) return;

  // Per-role default toggle map. When the role select changes, flip the
  // checkboxes to match this map so admins don't have to think through each
  // toggle. They can still override before submitting.
  var ROLE_DEFAULTS = <%- JSON.stringify(roleDefaults) %>;

  function applyRoleDefaults(role) {
    var defaults = ROLE_DEFAULTS[role];
    if (!defaults) return;
    Object.keys(defaults).forEach(function(key) {
      // Toggle inputs are named "feature_<key>" or "data_<key>".
      var el = form.querySelector('input[type="checkbox"][name="feature_' + key + '"]') ||
               form.querySelector('input[type="checkbox"][name="data_' + key + '"]');
      if (el) el.checked = !!defaults[key];
    });
  }

  var roleSelect = form.querySelector('select[name="role"]');
  if (roleSelect) {
    roleSelect.addEventListener('change', function() {
      applyRoleDefaults(roleSelect.value);
    });
    // Apply once on initial load to match the pre-selected role.
    applyRoleDefaults(roleSelect.value);
  }

  function readToggles(prefix) {
    var out = {};
    Array.prototype.forEach.call(form.querySelectorAll('input[type="checkbox"][name^="' + prefix + '"]'), function(el) {
      var key = el.name.slice(prefix.length);
      out[key] = el.checked;
    });
    return out;
  }

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    btn.disabled = true;
    status.textContent = 'Sending...';
    status.className = 'text-sm text-gray-600 min-h-[1.25rem]';

    var fd = new FormData(form);
    var agentSlugs = String(fd.get('agentSlugs') || '').split(',').map(function(s) { return s.trim(); }).filter(Boolean);
    var agentAccess = {};
    agentSlugs.forEach(function(s) { agentAccess[s] = true; });

    // Multi-select helper: pull selected option values from a <select multiple>.
    function readMultiSelect(name) {
      var sel = form.querySelector('select[name="' + name + '"]');
      var out = [];
      if (sel) {
        Array.prototype.forEach.call(sel.selectedOptions, function(opt) {
          if (opt.value) out.push(opt.value);
        });
      }
      return out;
    }

    var seatIds = readMultiSelect('claimedEntityIds');
    var teamIds = readMultiSelect('teamIds');

    var body = {
      email: fd.get('email'),
      displayName: fd.get('displayName') || undefined,
      role: fd.get('role') || 'managee',
      claimedEntityIds: seatIds.length > 0 ? seatIds : undefined,
      teamIds: teamIds.length > 0 ? teamIds : undefined,
      featureAccess: readToggles('feature_'),
      dataAccess: readToggles('data_'),
      agentAccess: agentAccess,
    };

    try {
      var res = await fetch('/api/v1/team/invite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var data = await res.json();
      if (!res.ok) {
        status.textContent = (data.error && data.error.message) || ('Error: ' + res.status);
        status.className = 'text-sm text-red-600 min-h-[1.25rem]';
        btn.disabled = false;
        return;
      }
      status.textContent = 'Invite sent to ' + data.email + '. Reloading...';
      status.className = 'text-sm text-emerald-700 min-h-[1.25rem]';
      setTimeout(function() { window.location.reload(); }, 900);
    } catch (err) {
      status.textContent = 'Network error -- try again.';
      status.className = 'text-sm text-red-600 min-h-[1.25rem]';
      btn.disabled = false;
    }
  });
})();
</script>
