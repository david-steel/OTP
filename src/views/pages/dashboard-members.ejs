      });
      if (!res.ok) {
        var err = await res.json().catch(function(){ return {}; });
        msg.textContent = 'Error: ' + ((err.error && err.error.message) || res.status);
        msg.className = 'text-sm text-red-600 min-h-[1.25rem]';
        btn.disabled = false;
