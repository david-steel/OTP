<div style="max-width:480px;margin:5rem auto;text-align:center;font-family:Inter,system-ui,sans-serif;padding:0 1rem;">
  <h1 style="font-size:1.5rem;font-weight:800;color:#0f172a;">Signing you in…</h1>
  <p id="demo-msg" style="color:#6b7280;margin-top:0.75rem;font-size:0.95rem;">Hang tight — dropping you into the Acme Corp demo.</p>
  <p id="demo-fallback" style="display:none;color:#6b7280;margin-top:1rem;font-size:0.85rem;">
    Tip: open this link in an <strong>incognito window</strong> (so it doesn't collide with an existing session),
    or regenerate a fresh one from <code>/admin/demo-acme/signin-link</code>.
  </p>
</div>
<script>
(function waitForClerk() {
  if (!window.Clerk) return setTimeout(waitForClerk, 100);
  window.Clerk.load().then(async function () {
    var msg = document.getElementById('demo-msg');
    var fb = document.getElementById('demo-fallback');
    var token = new URLSearchParams(window.location.search).get('token');
    if (!token) { msg.textContent = 'This link is missing its token.'; if (fb) fb.style.display = 'block'; return; }
    try {
      // A ticket sign-in needs a clean session; clear any existing one first.
      if (window.Clerk.user) { try { await window.Clerk.signOut(); } catch (_) {} }
      var si = await window.Clerk.client.signIn.create({ strategy: 'ticket', ticket: token });
      if (si && si.status === 'complete') {
        await window.Clerk.setActive({ session: si.createdSessionId });
        window.location.href = '/dashboard';
        return;
      }
      msg.textContent = 'Sign-in did not complete (status: ' + (si && si.status) + ').';
      if (fb) fb.style.display = 'block';
    } catch (e) {
      var m = (e && e.errors && e.errors[0] && e.errors[0].message) || (e && e.message) || String(e);
      msg.textContent = 'Could not sign in: ' + m;
      if (fb) fb.style.display = 'block';
    }
  });
})();
</script>
