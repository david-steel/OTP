<%# /otp-vs-ninety-eos-one -- v7 layout, ORGY branding (green/blue, not v7 orange).
    Bottom-funnel comparison. Concede Stage-1 EOS parity; win on agents-as-
    employees + the pricing flip. v7.css is PREBUILT: arbitrary Tailwind classes
    silently no-op, so ALL layout/color is scoped CSS + design tokens
    (--orgy #a8e63a, on-light green var(--blue,#0d7df2), --orgy-deep #8bc42a, --blue #0d7df2).
    Real product screenshots (chart/kpi/l10) prove the claims. Screenshot-verified. %>
<style>
  /* layout (specific padding-* props so stacked classes compose, never clobber) */
  .vs-sec   { padding-top: 80px; padding-bottom: 80px; }
  .vs-hero  { padding-top: 132px; padding-bottom: 48px; }   /* clears 64px fixed nav */
  .vs-wrap  { max-width: 1040px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .vs-center{ text-align: center; }
  .vs-paper { background: var(--white, #fcfcfd); }
  .vs-grey  { background: var(--grey, #f0f1f3); }
  .vs-ink   { background: var(--ink, #14161c); }
  @media (max-width: 640px) { .vs-sec { padding-top: 52px; padding-bottom: 52px; } .vs-hero { padding-top: 100px; padding-bottom: 36px; } }

  .vs-eyebrow { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-mute,#888c96); display:flex; align-items:center; gap:10px; }
  .vs-tick { width:8px; height:8px; border-radius:50%; background:var(--orgy,#a8e63a); display:inline-block; }
  .vs-h1 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.025em; line-height:1.05; font-size:clamp(2.1rem,4.4vw,3.5rem); color:var(--ink,#14161c); margin:0 auto; max-width:20ch; }
  .vs-h2 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.02em; line-height:1.1; font-size:clamp(1.7rem,3.3vw,2.45rem); color:var(--ink,#14161c); }
  .vs-h3 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:1.12rem; color:var(--ink,#14161c); margin-top:8px; }
  .vs-lead { font-size:18px; line-height:1.62; color:var(--ink-soft,#494d57); }
  .vs-body { font-size:16px; line-height:1.65; color:var(--ink-soft,#494d57); }
  .vs-max640 { max-width:640px; } .vs-max40 { max-width:40rem; }
  .vs-mt5{margin-top:20px;} .vs-mt7{margin-top:28px;} .vs-mt8{margin-top:32px;} .vs-mb4{margin-bottom:16px;} .vs-mb10{margin-bottom:40px;} .vs-mb12{margin-bottom:48px;}
  .vs-cta-row { display:flex; flex-wrap:wrap; gap:12px; }
  .accent { color:var(--blue,#0d7df2); }

  /* framed product screenshots */
  .vs-shotwrap { max-width:980px; margin:36px auto 0; }
  .vs-shot { display:block; width:100%; height:auto; border-radius:14px; border:1px solid var(--line,#e6e8ec); box-shadow:0 24px 60px rgba(20,22,28,.16); }
  .vs-shotcap { font-size:14px; line-height:1.55; color:var(--ink-soft,#494d57); text-align:center; margin:16px auto 0; max-width:620px; }

  /* comparison tables */
  .cmp-card { border-radius:14px; background:var(--white,#fcfcfd); box-shadow:0 1px 0 rgba(20,22,28,.04), 0 18px 40px rgba(20,22,28,.06); overflow:hidden; }
  .cmp-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; }
  .cmp { width:100%; border-collapse:separate; border-spacing:0; min-width:600px; font-size:15px; }
  .cmp th, .cmp td { padding:14px 16px; text-align:center; border-bottom:1px solid var(--line,#e6e8ec); vertical-align:middle; }
  .cmp th { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:14px; color:var(--ink,#14161c); }
  .cmp td:first-child, .cmp th:first-child { text-align:left; color:var(--ink-soft,#494d57); font-weight:600; }
  .cmp .col-otp { background:rgba(13,125,242,0.08); }
  .cmp thead .col-otp { color:var(--blue,#0d7df2); box-shadow: inset 0 -3px 0 var(--blue,#0d7df2); }
  .cmp .yes { color:var(--blue,#0d7df2); font-weight:800; }
  .cmp .no  { color:#c2c6cd; font-weight:700; }
  .cmp .price { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; color:var(--ink,#14161c); }
  .cmp .free { color:var(--blue,#0d7df2); font-weight:800; }
  .cmp .muted { color:var(--ink-mute,#888c96); font-size:13px; }
  .cmp tr:last-child td { border-bottom:none; }
  .cmp-note { font-size:13px; color:var(--ink-mute,#888c96); margin-top:14px; line-height:1.6; }
  @media (max-width:640px){
    .cmp { min-width:0; font-size:12.5px; }
    .cmp th { font-size:11.5px; }
    .cmp th, .cmp td { padding:9px 6px; }
    .cmp td:first-child, .cmp th:first-child { font-size:11.5px; }
    .cmp .muted { font-size:10px; }
    .cmp .price { font-size:12.5px; }
  }

  /* stages */
  .vs-stages { display:grid; gap:18px; }
  @media (min-width:768px){ .vs-stages { grid-template-columns:repeat(3,1fr); } }
  .vs-stage { border-radius:14px; background:var(--grey,#f0f1f3); padding:26px; }
  .vs-stage-n { font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:12px; font-weight:800; letter-spacing:.12em; color:var(--blue,#0d7df2); }

  /* subtle motion (matches home page); disabled for reduced-motion + no-JS-safe via body.vs-anim */
  @media (prefers-reduced-motion: no-preference){
    body.vs-anim .reveal { opacity:0; transform:translateY(18px); transition:opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); }
    body.vs-anim .reveal.in { opacity:1; transform:none; }
    .vs-float { animation:vs-float 5.5s ease-in-out infinite; }
    @keyframes vs-float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-10px);} }
  }
  .reg { font-size:.58em; vertical-align:super; line-height:0; font-weight:inherit; margin-left:1px; }
  .vs-blue { background:var(--blue-block,#0d5fd6); }
  .vs-team { display:grid; gap:14px; grid-template-columns:repeat(auto-fit,minmax(165px,1fr)); margin-top:36px; text-align:left; }
  .vs-teamcard { border-radius:14px; background:var(--white,#fcfcfd); border:1px solid var(--line,#e6e8ec); padding:18px; box-shadow:0 8px 22px rgba(20,22,28,.05); }
  .vs-teamname { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:16px; color:var(--ink,#14161c); }
  .vs-teamrole { font-size:11px; font-weight:800; letter-spacing:.06em; text-transform:uppercase; color:var(--blue,#0d7df2); margin-top:3px; }
  .vs-teamdesc { font-size:13.5px; line-height:1.5; color:var(--ink-soft,#494d57); margin-top:8px; }
</style>

<!-- ================= HERO + CHART SHOT ================= -->
<section class="vs-paper">
  <div class="vs-wrap vs-hero vs-center">
    <div class="vs-eyebrow vs-mb4" style="justify-content:center;"><span class="vs-tick"></span>OTP vs Ninety vs EOS One</div>
    <h1 class="vs-h1">Ninety and EOS One run your EOS<sup class="reg">&reg;</sup>. <span class="accent">OTP lets you hire agents into it.</span></h1>
    <p class="vs-lead vs-mt5 vs-max40" style="margin-left:auto;margin-right:auto;">
      They're good EOS<sup class="reg">&reg;</sup> software &mdash; they digitize the system you already run. OTP runs the same system, and lets AI agents take real seats next to your people, with real numbers to hit and real work to do. Your whole team is free. You only pay for the agents.
    </p>
    <div class="vs-cta-row vs-mt8" style="justify-content:center;">
      <a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a>
      <a href="#pricing" class="btn-ghost px-8 py-4 text-[16px]">See the difference</a>
    </div>
    <div class="vs-eyebrow vs-mt7" style="justify-content:center;flex-wrap:wrap;gap:8px;">
      <span>Whole team free</span><span style="color:#cfd3da;">&middot;</span>
      <span class="accent">Agents do the work</span><span style="color:#cfd3da;">&middot;</span>
      <span style="color:var(--blue-deep,#0a56b0);">Built on the EOS<sup class="reg">&reg;</sup> you run</span>
    </div>
    <div class="vs-shotwrap reveal">
      <img class="vs-shot" src="/public/images/vs/chart.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="The OTP accountability chart with AI agents holding seats next to people, each with skills, integrations and SOPs">
      <p class="vs-shotcap">Your org chart on OTP. The green <strong>AGENT</strong> seats are real employees &mdash; skills, integrations, a job to do. Humans and agents, one chart.</p>
    </div>
  </div>
</section>

<!-- ================= THE PRICING WEAPON ================= -->
<section id="pricing" class="vs-grey">
  <div class="vs-wrap vs-sec">
    <div class="vs-max640 vs-mb10">
      <div class="vs-eyebrow vs-mb4">The difference, in two seconds</div>
      <h2 class="vs-h2">Everyone gives the first user away. Only OTP gives your whole team away.</h2>
    </div>
    <div class="cmp-card cmp-wrap reveal" style="max-width:860px;">
      <table class="cmp">
        <thead><tr><th></th><th>Ninety</th><th>EOS One</th><th class="col-otp">OTP</th></tr></thead>
        <tbody>
          <tr><td>First user</td><td>Free</td><td>Free</td><td class="col-otp free">Free</td></tr>
          <tr><td>Every other user</td><td class="price">$11<span class="muted"> /mo each</span></td><td class="price">$10<span class="muted"> /mo each</span></td><td class="col-otp free">Free</td></tr>
          <tr><td>AI agents that do the work</td><td class="muted">Not available</td><td class="muted">Not available</td><td class="col-otp price">$11<span class="muted"> /mo per agent*</span></td></tr>
        </tbody>
      </table>
    </div>
    <p class="cmp-note vs-max640">You used to pay $11 for one more human seat. On OTP your people are free, and $11 buys an agent that works around the clock and never forgets a thing. <span class="muted">*Founding price. Per active agent seat. Humans always free.</span></p>
  </div>
</section>

<!-- ================= WHAT NONE OF THEM CAN DO + KPI SHOT ================= -->
<section class="vs-paper">
  <div class="vs-wrap vs-sec">
    <div class="vs-max640 vs-mb10">
      <div class="vs-eyebrow vs-mb4">Where the comparison ends</div>
      <h2 class="vs-h2">They added an AI assistant. OTP gives you AI employees.</h2>
      <p class="vs-body vs-mt5">EOS One has Atlas. Ninety has a Rock companion. They answer questions about your business. OTP's agents <em>are</em> the business &mdash; they take a seat, own a number, and do the work between meetings. Here's where the two paths split.</p>
    </div>
    <div class="cmp-card cmp-wrap reveal">
      <table class="cmp">
        <thead><tr><th></th><th>Ninety</th><th>EOS One</th><th class="col-otp">OTP</th></tr></thead>
        <tbody>
          <tr><td>Full EOS<sup class="reg">&reg;</sup> toolset (chart, scorecard, priorities, weekly meeting)</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>The <em>official</em> EOS product</td><td class="no">&mdash;</td><td class="yes">&#10003;</td><td class="col-otp no">&mdash;</td></tr>
          <tr><td>AI in the product</td><td class="muted">Assistant</td><td class="muted">Assistant (Atlas)</td><td class="col-otp" style="color:var(--blue,#0d7df2);font-weight:800;">Employees</td></tr>
          <tr><td>An AI agent can hold a seat on your chart</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Agents carry their own KPIs on the scorecard</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Agents do work <em>between</em> meetings</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>An agent that runs your weekly meeting</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003; <span class="muted">Radar</span></td></tr>
          <tr><td>Your whole team, free</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Your company learns from every other company on it</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Working agents included, day one</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003; <span class="muted">Five</span></td></tr>
        </tbody>
      </table>
    </div>
    <p class="cmp-note vs-max640">Yes &mdash; they're real, polished, established EOS software, and EOS One is the official one. We'll give them that. Everything below those two rows, their data model can't do: it assumes every seat is a human, and they charge you per human.</p>
    <div class="vs-shotwrap reveal">
      <img class="vs-shot" src="/public/images/vs/kpi.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="The OTP scoreboard, with a Human / Agent filter, showing each seat's KPI and goal">
      <p class="vs-shotcap">One scoreboard for the whole company. Filter by <strong>Human</strong> or <strong>Agent</strong> &mdash; every seat owns a number, people and agents alike.</p>
    </div>
  </div>
</section>

<!-- ================= MEET RADAR + L10 SHOT + FREE TEAM ================= -->
<section class="vs-grey">
  <div class="vs-wrap vs-sec vs-center">
    <img src="/public/images/vs/radar.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="Radar, the OTP chief-of-staff agent" class="vs-float" style="width:160px;height:auto;display:block;margin:0 auto 14px;filter:drop-shadow(0 14px 24px rgba(20,22,28,.16));">
    <div class="vs-eyebrow vs-mb4" style="justify-content:center;">Meet Radar</div>
    <h2 class="vs-h2">Atlas answers questions. Radar runs your weekly meeting.</h2>
    <p class="vs-body vs-mt5 vs-max40" style="margin-left:auto;margin-right:auto;">You don't start with an empty chart. Sign up and Radar &mdash; your chief of staff &mdash; takes a seat: it preps the meeting, runs the agenda on time, and keeps the team accountable between sessions. Not a chatbot you ask questions. A teammate with a job. It's the version of "an AI in your leadership meeting" that's real today &mdash; and the seat is ready for the rest as the tech catches up.</p>
    <div class="vs-mt7" style="display:flex;justify-content:center;"><a href="/free-agents" class="btn-primary px-8 py-4 text-[16px]">Get your free agents &rarr;</a></div>
    <div class="vs-shotwrap reveal">
      <img class="vs-shot" src="/public/images/vs/l10.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="The OTP weekly leadership meeting with a timed agenda, live scorecard and a focus mode">
      <p class="vs-shotcap">The weekly meeting Radar runs &mdash; timed agenda, live scorecard, focus mode. It runs itself.</p>
    </div>
    <div style="margin-top:60px;">
      <div class="vs-eyebrow vs-mb4" style="justify-content:center;">Five agents, free</div>
      <h2 class="vs-h2">Radar doesn't come alone. You get a starter team.</h2>
      <p class="vs-body vs-mt5 vs-max40" style="margin-left:auto;margin-right:auto;">Every OTP account ships with five battle-tested agents &mdash; the same ones running our company. Drop them into your chart and put them to work. All free. <a href="/free-agents" style="color:var(--blue,#0d7df2);font-weight:700;text-decoration:none;">Meet the team &rarr;</a></p>
      <div class="vs-team reveal">
        <div class="vs-teamcard"><div class="vs-teamname">Radar</div><div class="vs-teamrole">Chief of Staff</div><div class="vs-teamdesc">Runs your weekly meeting and daily briefing.</div></div>
        <div class="vs-teamcard"><div class="vs-teamname">Dan</div><div class="vs-teamrole">The Strategist</div><div class="vs-teamdesc">Challenges your priorities and keeps you honest.</div></div>
        <div class="vs-teamcard"><div class="vs-teamname">Pepper</div><div class="vs-teamrole">Executive Assistant</div><div class="vs-teamdesc">Triages your inbox and drafts in your voice.</div></div>
        <div class="vs-teamcard"><div class="vs-teamname">Dash</div><div class="vs-teamrole">The Analyst</div><div class="vs-teamdesc">Reads your numbers and flags what matters.</div></div>
        <div class="vs-teamcard"><div class="vs-teamname">Tally</div><div class="vs-teamrole">The Scorekeeper</div><div class="vs-teamdesc">Pushes your KPIs to the scoreboard automatically.</div></div>
      </div>
    </div>
  </div>
</section>

<!-- ================= THE 3 STAGES ================= -->
<section class="vs-paper">
  <div class="vs-wrap vs-sec">
    <div class="vs-max640 vs-mb12">
      <div class="vs-eyebrow vs-mb4">Where this goes</div>
      <h2 class="vs-h2">You don't tear down what you built. You build on it.</h2>
    </div>
    <div class="vs-stages reveal">
      <div class="vs-stage"><div class="vs-stage-n">STAGE 1</div><h3 class="vs-h3">The company you have</h3><p class="vs-body" style="margin-top:8px;">You run on EOS<sup class="reg">&reg;</sup>. Right people, right seats, one scorecard, the weekly meeting. It works.</p></div>
      <div class="vs-stage"><div class="vs-stage-n">STAGE 2</div><h3 class="vs-h3">The company you want</h3><p class="vs-body" style="margin-top:8px;">Agents working alongside your team &mdash; same chart, same accountability. The company that runs while you sleep.</p></div>
      <div class="vs-stage"><div class="vs-stage-n">STAGE 3</div><h3 class="vs-h3">The company that compounds</h3><p class="vs-body" style="margin-top:8px;">Every company on OTP teaches every other one. Your operation doesn't just gain AI &mdash; it learns from everyone else's.</p></div>
    </div>
    <p class="vs-body vs-mt8 vs-max640">OTP is the bridge between them, built on the EOS<sup class="reg">&reg;</sup> you already run. Same chart, same scorecard, same meeting &mdash; agents just take seats in it. You don't start over.</p>
  </div>
</section>

<!-- ================= DOGFOOD PROOF ================= -->
<section class="vs-blue">
  <div class="vs-wrap vs-sec vs-center" style="max-width:820px;">
    <div class="vs-eyebrow vs-mb4" style="justify-content:center;color:var(--orgy,#a8e63a);">The proof</div>
    <h2 class="vs-h2" style="color:#fff;">We run our own company on these exact agents.</h2>
    <p class="vs-lead vs-mt5 vs-max40" style="margin-left:auto;margin-right:auto;color:rgba(255,255,255,.74);">OTP isn't a deck. The team you'd hire &mdash; Dan, Radar, Pepper, Dash and Tally &mdash; is the same team that runs the company that built OTP, live, on this platform. No incumbent can say that. They sell you software to manage your people. We hand you a workforce and show you ours, working.</p>
    <div class="vs-mt8" style="display:flex;justify-content:center;"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a></div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="vs-grey">
  <div class="vs-wrap vs-sec vs-center" style="max-width:760px;">
    <h2 class="vs-h2">Keep your EOS<sup class="reg">&reg;</sup>. Add a workforce.</h2>
    <p class="vs-lead vs-mt5" style="max-width:34rem;margin-left:auto;margin-right:auto;">Your whole team is free. Your first agent is free. You only pay when an agent earns its seat.</p>
    <div class="vs-mt8" style="display:flex;justify-content:center;"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a></div>
    <p class="cmp-note vs-mt8">EOS<sup class="reg">&reg;</sup> and Level 10 Meeting<sup class="reg">&reg;</sup> are trademarks of EOS Worldwide. Ninety and EOS One are trademarks of their respective owners. OTP is independent and not affiliated with, or endorsed by, any of them.</p>
  </div>
</section>

<script>
(function(){
  if (!('IntersectionObserver' in window)) return;
  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  document.body.classList.add('vs-anim');
  var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, { rootMargin:'0px 0px 5% 0px', threshold:0.01 });
  document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
  setTimeout(function(){ document.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('in'); }); }, 1400);
})();
</script>
