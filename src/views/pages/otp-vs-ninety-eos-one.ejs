<%# /otp-vs-ninety-eos-one -- v7 (light, editorial). Bottom-funnel comparison.
    Rule: concede Stage-1 EOS parity, win on agents-as-employees + the pricing
    flip. IMPORTANT: v7.css is PREBUILT, so arbitrary Tailwind classes
    (pt-[120px], max-w-[920px], py-18, rounded-[14px], bg-[var(--x)]) silently
    no-op. ALL layout/color here is scoped CSS + design tokens, never arbitrary
    utilities. Screenshot-verified. %>
<style>
  /* ---- layout scaffolding (prebuilt-CSS-proof: scoped, not Tailwind arbitraries) ---- */
  .vs-sec   { padding: 80px 0; }
  .vs-hero  { padding: 132px 0 56px; }   /* clears the 64px fixed nav with air */
  .vs-wrap  { max-width: 1040px; margin: 0 auto; padding: 0 24px; }
  .vs-narrow{ max-width: 760px; margin: 0 auto; }
  .vs-center{ text-align: center; }
  .vs-paper { background: var(--white, #fcfcfd); }
  .vs-grey  { background: var(--grey, #f0f1f3); }
  .vs-ink   { background: var(--ink, #14161c); }
  @media (max-width: 640px) { .vs-sec { padding: 52px 0; } .vs-hero { padding: 100px 0 40px; } }

  .vs-eyebrow { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-mute,#888c96); display:flex; align-items:center; gap:10px; }
  .vs-tick { width:8px; height:8px; border-radius:50%; background:var(--orange,#ff7a1a); display:inline-block; }
  .vs-h1 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.025em; line-height:1.05; font-size:clamp(2.1rem,4.4vw,3.5rem); color:var(--ink,#14161c); margin:0 auto; max-width:20ch; }
  .vs-h2 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; letter-spacing:-0.02em; line-height:1.1; font-size:clamp(1.7rem,3.3vw,2.45rem); color:var(--ink,#14161c); }
  .vs-h3 { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:700; font-size:1.12rem; color:var(--ink,#14161c); margin-top:8px; }
  .vs-lead { font-size:18px; line-height:1.62; color:var(--ink-soft,#494d57); }
  .vs-body { font-size:16px; line-height:1.65; color:var(--ink-soft,#494d57); }
  .vs-max640 { max-width:640px; }
  .vs-max40 { max-width:40rem; }
  .vs-mt5{margin-top:20px;} .vs-mt7{margin-top:28px;} .vs-mt8{margin-top:32px;} .vs-mb4{margin-bottom:16px;} .vs-mb10{margin-bottom:40px;} .vs-mb12{margin-bottom:48px;}
  .vs-cta-row { display:flex; flex-wrap:wrap; gap:12px; }

  /* ---- comparison tables ---- */
  .cmp-card { border-radius:14px; background:var(--white,#fcfcfd); box-shadow:0 1px 0 rgba(20,22,28,.04), 0 18px 40px rgba(20,22,28,.06); overflow:hidden; }
  .cmp-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; }
  .cmp { width:100%; border-collapse:separate; border-spacing:0; min-width:600px; font-size:15px; }
  .cmp th, .cmp td { padding:14px 16px; text-align:center; border-bottom:1px solid var(--line,#e6e8ec); vertical-align:middle; }
  .cmp th { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:14px; color:var(--ink,#14161c); }
  .cmp td:first-child, .cmp th:first-child { text-align:left; color:var(--ink-soft,#494d57); font-weight:600; }
  .cmp .col-otp { background:rgba(255,122,26,0.06); }
  .cmp thead .col-otp { color:var(--orange-deep,#d65a00); }
  .cmp .yes { color:var(--orange-deep,#d65a00); font-weight:800; }
  .cmp .no  { color:#c2c6cd; font-weight:700; }
  .cmp .price { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; color:var(--ink,#14161c); }
  .cmp .free { color:var(--orange-deep,#d65a00); font-weight:800; }
  .cmp .muted { color:var(--ink-mute,#888c96); font-size:13px; }
  .cmp tr:last-child td { border-bottom:none; }
  .cmp-note { font-size:13px; color:var(--ink-mute,#888c96); margin-top:14px; line-height:1.6; }

  /* ---- stages ---- */
  .vs-stages { display:grid; gap:18px; }
  @media (min-width:768px){ .vs-stages { grid-template-columns:repeat(3,1fr); } }
  .vs-stage { border-radius:14px; background:var(--grey,#f0f1f3); padding:26px; }
  .vs-stage-n { font-family:'Schibsted Grotesk','Inter',sans-serif; font-size:12px; font-weight:800; letter-spacing:.12em; color:var(--orange-deep,#d65a00); }

  /* ---- meet dan ---- */
  .vs-dan { display:flex; flex-direction:column; align-items:center; gap:36px; }
  @media (min-width:768px){ .vs-dan { flex-direction:row; gap:56px; } .vs-dan-txt { text-align:left; } }
  .vs-dan-img { width:220px; max-width:55vw; flex:none; }
</style>

<!-- ================= HERO ================= -->
<section class="vs-paper">
  <div class="vs-wrap vs-hero vs-center">
    <div class="vs-eyebrow vs-mb4" style="justify-content:center;"><span class="vs-tick"></span>OTP vs Ninety vs EOS One</div>
    <h1 class="vs-h1">Ninety and EOS One run your EOS. <span style="color:var(--orange-deep,#d65a00);">OTP lets you hire agents into it.</span></h1>
    <p class="vs-lead vs-mt5 vs-max40" style="margin-left:auto;margin-right:auto;">
      They're good EOS&reg; software &mdash; they digitize the system you already run. OTP runs the same system, and lets AI agents take real seats next to your people, with real numbers to hit and real work to do. Your whole team is free. You only pay for the agents.
    </p>
    <div class="vs-cta-row vs-mt8" style="justify-content:center;">
      <a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a>
      <a href="#pricing" class="btn-ghost px-8 py-4 text-[16px]">See the difference</a>
    </div>
    <div class="vs-eyebrow vs-mt7" style="justify-content:center;flex-wrap:wrap;gap:8px;">
      <span>Whole team free</span><span style="color:#cfd3da;">&middot;</span>
      <span style="color:var(--orange-deep,#d65a00);">Agents do the work</span><span style="color:#cfd3da;">&middot;</span>
      <span style="color:var(--blue-deep,#0d57c8);">Built on the EOS you run</span>
    </div>
  </div>
</section>

<!-- ================= THE PRICING WEAPON ================= -->
<section id="pricing" class="vs-grey">
  <div class="vs-wrap vs-sec">
    <div class="vs-max640 vs-mb10">
      <div class="vs-eyebrow vs-mb4">The difference, in two seconds</div>
      <h2 class="vs-h2">Everyone gives the first user away. Only OTP gives your whole team away.</h2>
    </div>
    <div class="cmp-card cmp-wrap" style="max-width:860px;">
      <table class="cmp">
        <thead><tr><th></th><th>Ninety</th><th>EOS One</th><th class="col-otp">OTP</th></tr></thead>
        <tbody>
          <tr><td>First user</td><td>Free</td><td>Free</td><td class="col-otp free">Free</td></tr>
          <tr><td>Every other user</td><td class="price">$11<span class="muted"> /mo each</span></td><td class="price">$10<span class="muted"> /mo each</span></td><td class="col-otp free">Free</td></tr>
          <tr><td>AI agents that do the work</td><td class="muted">Not available</td><td class="muted">Not available</td><td class="col-otp price">$11<span class="muted"> /mo per agent*</span></td></tr>
        </tbody>
      </table>
    </div>
    <p class="cmp-note vs-max640">You used to pay $11 for one more human seat. On OTP your people are free, and $11 buys an agent that works around the clock and never forgets a thing. <span class="muted">*Founding price. Per active agent seat. Humans always free.</span></p>
  </div>
</section>

<!-- ================= WHAT NONE OF THEM CAN DO ================= -->
<section class="vs-paper">
  <div class="vs-wrap vs-sec">
    <div class="vs-max640 vs-mb10">
      <div class="vs-eyebrow vs-mb4">Where the comparison ends</div>
      <h2 class="vs-h2">They added an AI assistant. OTP gives you AI employees.</h2>
      <p class="vs-body vs-mt5">EOS One has Atlas. Ninety has a Rock companion. They answer questions about your business. OTP's agents <em>are</em> the business &mdash; they take a seat, own a number, and do the work between meetings. Here's where the two paths split.</p>
    </div>
    <div class="cmp-card cmp-wrap">
      <table class="cmp">
        <thead><tr><th></th><th>Ninety</th><th>EOS One</th><th class="col-otp">OTP</th></tr></thead>
        <tbody>
          <tr><td>Full EOS toolset (chart, scorecard, priorities, weekly meeting)</td><td class="yes">&#10003;</td><td class="yes">&#10003;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>The <em>official</em> EOS product</td><td class="no">&mdash;</td><td class="yes">&#10003;</td><td class="col-otp no">&mdash;</td></tr>
          <tr><td>AI in the product</td><td class="muted">Assistant</td><td class="muted">Assistant (Atlas)</td><td class="col-otp" style="color:var(--orange-deep,#d65a00);font-weight:800;">Employees</td></tr>
          <tr><td>An AI agent can hold a seat on your chart</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Agents carry their own KPIs on the scorecard</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Agents do work <em>between</em> meetings</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>An agent that runs your weekly meeting</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003; <span class="muted">Dan</span></td></tr>
          <tr><td>Your whole team, free</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>Your company learns from every other company on it</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003;</td></tr>
          <tr><td>A working agent the day you sign up</td><td class="no">&#10007;</td><td class="no">&#10007;</td><td class="col-otp yes">&#10003; <span class="muted">Dan</span></td></tr>
        </tbody>
      </table>
    </div>
    <p class="cmp-note vs-max640">Yes &mdash; they're real, polished, established EOS software, and EOS One is the official one. We'll give them that. Everything below those two rows, their data model can't do: it assumes every seat is a human, and they charge you per human.</p>
  </div>
</section>

<!-- ================= MEET DAN ================= -->
<section class="vs-grey">
  <div class="vs-wrap vs-sec">
    <div class="vs-dan">
      <div class="vs-dan-img"><img src="/public/images/orgy/coach.png?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : 'dev' %>" alt="Dan, the OTP EOS-facilitator agent" style="display:block;width:100%;filter:drop-shadow(0 20px 32px rgba(20,22,28,.18));"></div>
      <div class="vs-dan-txt vs-center">
        <div class="vs-eyebrow vs-mb4">Meet your first agent</div>
        <h2 class="vs-h2">Atlas talks. Dan runs the meeting.</h2>
        <p class="vs-body vs-mt5 vs-max40">You don't start with an empty chart. The day you sign up, you get Dan &mdash; an agent that takes the facilitator seat, holds you to your quarterly priorities, runs the issues list, and shows up to your weekly meeting with the work already prepped. Not a chatbot you ask questions. A teammate with a job. It's the version of "an AI in your leadership meeting" that's real today &mdash; and the seat is ready for the rest as the tech catches up.</p>
        <div class="vs-mt7"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Get Dan free &rarr;</a></div>
      </div>
    </div>
  </div>
</section>

<!-- ================= THE 3 STAGES ================= -->
<section class="vs-paper">
  <div class="vs-wrap vs-sec">
    <div class="vs-max640 vs-mb12">
      <div class="vs-eyebrow vs-mb4">Where this goes</div>
      <h2 class="vs-h2">You don't tear down what you built. You build on it.</h2>
    </div>
    <div class="vs-stages">
      <div class="vs-stage"><div class="vs-stage-n">STAGE 1</div><h3 class="vs-h3">The company you have</h3><p class="vs-body" style="margin-top:8px;">You run on EOS. Right people, right seats, one scorecard, the weekly meeting. It works.</p></div>
      <div class="vs-stage"><div class="vs-stage-n">STAGE 2</div><h3 class="vs-h3">The company you want</h3><p class="vs-body" style="margin-top:8px;">Agents working alongside your team &mdash; same chart, same accountability. The company that runs while you sleep.</p></div>
      <div class="vs-stage"><div class="vs-stage-n">STAGE 3</div><h3 class="vs-h3">The company that compounds</h3><p class="vs-body" style="margin-top:8px;">Every company on OTP teaches every other one. Your operation doesn't just gain AI &mdash; it learns from everyone else's.</p></div>
    </div>
    <p class="vs-body vs-mt8 vs-max640">OTP is the bridge between them, built on the EOS you already run. Same chart, same scorecard, same meeting &mdash; agents just take seats in it. You don't start over.</p>
  </div>
</section>

<!-- ================= DOGFOOD PROOF ================= -->
<section class="vs-ink">
  <div class="vs-wrap vs-sec vs-center" style="max-width:820px;">
    <div class="vs-eyebrow vs-mb4" style="justify-content:center;color:var(--orange,#ff7a1a);">The proof</div>
    <h2 class="vs-h2" style="color:#fff;">We run our own company on these exact agents.</h2>
    <p class="vs-lead vs-mt5 vs-max40" style="margin-left:auto;margin-right:auto;color:rgba(255,255,255,.74);">OTP isn't a deck. The team you'd hire &mdash; Dan, Radar, Pepper and more &mdash; is the same team that runs the company that built OTP, live, on this platform. No incumbent can say that. They sell you software to manage your people. We hand you a workforce and show you ours, working.</p>
    <div class="vs-mt8" style="display:flex;justify-content:center;"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a></div>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="vs-grey">
  <div class="vs-wrap vs-sec vs-center" style="max-width:760px;">
    <h2 class="vs-h2">Keep your EOS. Add a workforce.</h2>
    <p class="vs-lead vs-mt5" style="max-width:34rem;margin-left:auto;margin-right:auto;">Your whole team is free. Your first agent is free. You only pay when an agent earns its seat.</p>
    <div class="vs-mt8" style="display:flex;justify-content:center;"><a href="/sign-up" class="btn-primary px-8 py-4 text-[16px]">Start free &mdash; no card &rarr;</a></div>
    <p class="cmp-note vs-mt8">EOS&reg; and Level 10 Meeting&reg; are trademarks of EOS Worldwide. Ninety and EOS One are trademarks of their respective owners. OTP is independent and not affiliated with, or endorsed by, any of them.</p>
  </div>
</section>
