<%# /answers -- v7 layout (light, editorial). AEO hub. Lists every
    AeoCluster. Route provides `clusters` array. Data: src/data/aeo-clusters.ts %>
<style>
  .aeo-tilt { animation:aeo-tilt 6s ease-in-out infinite; transform-origin:60% 90%; }
  @keyframes aeo-tilt { 0%,100%{transform:rotate(0);} 50%{transform:rotate(-8deg);} }
  @media (prefers-reduced-motion:reduce){ .aeo-tilt{ animation:none; } }
</style>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[124px] pb-16 sm:pt-[148px] sm:pb-20">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--orange);"></span>Answers
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.1rem,4.2vw,3.4rem); line-height:1.09; font-weight:700; letter-spacing:-0.025em;">
          How to organize, govern, and <span class="text-[var(--blue)]">coordinate AI agents.</span>
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[35rem] mx-auto md:mx-0 mt-5">
          Direct answers to the questions operators ask AI engines about running AI agents inside a company. Each page below answers one cluster of high-intent questions.
        </p>
      </div>
      <div class="relative shrink-0" style="width:118px; max-width:34vw;">
        <img src="/public/hand-2.png" alt="" aria-hidden="true"
             class="aeo-tilt block w-full" style="filter:drop-shadow(0 14px 22px rgba(20,22,28,.16));">
      </div>
    </div>
  </div>
</section>

<!-- ================= CLUSTER GRID ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="eyebrow mb-7">Question clusters</div>
    <div class="grid sm:grid-cols-2 gap-5">
      <% clusters.forEach(function(c) { %>
        <a href="/answers/<%= c.slug %>" class="card lift p-7 block group">
          <span class="inline-block font-mono text-[10px] font-medium uppercase tracking-[0.14em] px-2.5 py-1 rounded-md mb-4"
                style="color:var(--blue-deep); background:rgba(13,125,242,0.08); border:1px solid rgba(13,125,242,0.2);">
            <%= c.badge %>
          </span>
          <span class="block font-display text-[var(--ink)] text-[1.1rem] font-bold leading-snug group-hover:text-[var(--blue-deep)] transition-colors">
            <%= c.h1 %>
          </span>
          <span class="block text-[14px] text-[var(--ink-soft)] leading-[1.6] mt-2.5">
            <%= c.description %>
          </span>
          <span class="inline-flex items-center gap-1 text-[14px] font-semibold text-[var(--ink)] mt-4 link-u">
            <%= c.items.length %> questions answered &rarr;
          </span>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <div class="eyebrow mb-4">Get cited</div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.07]"
        style="font-size:clamp(1.9rem,4vw,2.9rem); font-weight:700;">
      Want your patterns cited too?
    </h2>
    <p class="text-[17px] text-[var(--ink-soft)] leading-[1.6] max-w-[34rem] mx-auto mt-5">
      Publish your organization's coordination patterns to the network and let AI engines surface them as answers.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/publish" class="btn-primary px-8 py-4 text-[16px]">Publish your OOS &rarr;</a>
    </div>
  </div>
</section>
