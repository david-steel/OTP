<%# /the-otp-difference -- v7 layout (light, editorial). Google Ads sitelink
    landing page. Audience: operators evaluating OTP against per-seat
    operating-system meeting tools. Trademark-safe naming. Every CTA drives to /sign-up.
    Rendered via reply.view('pages/the-otp-difference', data, { layout: 'layouts/v7' }). %>
<style>
  .dif-peek { animation:dif-peek 7s ease-in-out infinite; }
  @keyframes dif-peek { 0%,100%{transform:translateY(8px) rotate(4deg);} 50%{transform:translateY(-6px) rotate(4deg);} }
  @media (prefers-reduced-motion:reduce){ .dif-peek{ animation:none; } }
</style>

<!-- ================= BETA BANNER ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-[112px] sm:pt-[132px]">
    <div class="rounded-2xl px-6 py-4 flex items-center justify-center gap-3 flex-wrap text-center"
         style="background:linear-gradient(135deg,rgba(168,230,58,.16),rgba(168,230,58,.06)); border:1px solid var(--orgy-deep);">
      <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] px-2 py-1 rounded-md"
            style="background:var(--ink); color:var(--orgy);">Beta</span>
      <span class="font-display text-[14px] font-bold text-[var(--ink)]">Join now = free forever for your whole team.</span>
      <span class="text-[13px] text-[var(--ink-soft)]">Beta members lock in free pricing before paid plans turn on.</span>
    </div>
  </div>
</section>

<!-- ================= HERO ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[1080px] mx-auto px-6 pt-12 pb-16 sm:pt-14 sm:pb-20">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center md:justify-start">
          <span class="tick" style="background:var(--orgy);"></span>Why OTP
        </div>
        <h1 class="font-display text-[var(--ink)]"
            style="font-size:clamp(2.25rem,4.8vw,3.8rem); line-height:1.05; font-weight:700; letter-spacing:-0.025em;">
          Same rhythm. A very different <span class="text-[var(--blue)]">layer underneath.</span>
        </h1>
        <p class="text-[17px] sm:text-[18px] text-[var(--ink-soft)] leading-[1.6] max-w-[36rem] mx-auto md:mx-0 mt-6">
          OTP runs the exact operating rhythm your leadership team already knows. Vision Plan, Weekly Scoreboard, Quarterly Priorities, To-Dos, Issues Board, the weekly Leadership Meeting, and Team Chart. The difference is three things the per-seat tools do not have.
        </p>
        <p class="text-[15px] font-semibold leading-[1.6] max-w-[36rem] mx-auto md:mx-0 mt-3" style="color:var(--green-deep);">
          Free for the whole team. A built-in AI Chief of Staff. AI-native from the ground up.
        </p>
        <div class="flex flex-wrap gap-3 justify-center md:justify-start mt-9">
          <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-primary px-8 py-4 text-[16px]">See the difference, free &rarr;</a>
        </div>
        <p class="eyebrow mt-6 text-center md:text-left" style="letter-spacing:0.2em;">
          No per-seat fees &nbsp;&middot;&nbsp; No credit card &nbsp;&middot;&nbsp; Whole team included
        </p>
      </div>
      <div class="relative shrink-0" style="width:240px; max-width:58vw;">
        <img src="/public/orgy-cut.png" alt="Ollie, the OTP mascot"
             class="dif-peek block w-full" style="filter:drop-shadow(0 22px 34px rgba(20,22,28,.2));">
      </div>
    </div>
  </div>
</section>

<!-- ================= THREE DIFFERENCES ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[1080px] mx-auto px-6 py-20 sm:py-24">
    <div class="max-w-[640px] mx-auto text-center">
      <div class="eyebrow mb-4">Three differences</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.9rem,3.8vw,2.9rem); font-weight:700;">
        The toolset is familiar. The platform underneath is not.
      </h2>
      <p class="text-[16px] text-[var(--ink-soft)] leading-[1.65] mt-5">
        Per-seat operating-system tools digitized the meeting. OTP rebuilt the layer beneath it.
      </p>
    </div>

    <div class="grid sm:grid-cols-3 gap-5 mt-12">
      <div class="card lift p-7">
        <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] mb-3" style="color:var(--orgy-deep);">Difference 1</div>
        <h3 class="font-display text-[var(--ink)] text-[1.2rem] font-bold mb-2 leading-tight">Free for the whole team</h3>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.65]">Per-seat tools bill every person on payroll at $8 to $16 a month. OTP includes the whole team at no cost. No seat math, no upgrade gate, no credit card.</p>
      </div>
      <div class="card lift p-7">
        <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] mb-3" style="color:var(--orgy-deep);">Difference 2</div>
        <h3 class="font-display text-[var(--ink)] text-[1.2rem] font-bold mb-2 leading-tight">An AI Chief of Staff is built in</h3>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.65]">Every account includes Radar. It runs the work between meetings: daily briefings, live scoreboard pulls, issues surfaced, accountability tracked. Per-seat tools only see the meeting itself.</p>
      </div>
      <div class="card lift p-7 border-t-[3px]" style="border-top-color:var(--blue); background:linear-gradient(180deg,rgba(13,125,242,.06),var(--card));">
        <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] mb-3" style="color:var(--blue-deep);">Difference 3</div>
        <h3 class="font-display text-[var(--ink)] text-[1.2rem] font-bold mb-2 leading-tight">AI-native, not bolted on</h3>
        <p class="text-[13.5px] text-[var(--ink-soft)] leading-[1.65]">OTP is built for teams that already run AI agents. It is not a digital binder bolted onto a 2018 product. The AI layer is the foundation, not an add-on.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================= COMPARISON TABLE ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[840px] mx-auto px-6 py-20 sm:py-24">
    <div class="max-w-[560px] mx-auto text-center">
      <div class="eyebrow mb-4">Side by side</div>
      <h2 class="font-display text-[var(--ink)] tracking-[-0.02em] leading-[1.1]"
          style="font-size:clamp(1.8rem,3.4vw,2.6rem); font-weight:700;">
        OTP versus per-seat meeting tools.
      </h2>
      <p class="text-[15px] text-[var(--ink-soft)] leading-[1.65] mt-4">
        Same weekly rhythm. Same full toolset. Everything else is the difference.
      </p>
    </div>

    <% const compareRows = [
      { label: 'Price',                               otp: 'Free for the whole team in Beta', them: '$8 to $16 per user per month' },
      { label: 'Whole team included',                 otp: 'Yes',                              them: 'No, billed per seat' },
      { label: 'AI Chief of Staff built in',          otp: 'Yes, Radar',                       them: 'No' },
      { label: 'Work between meetings',               otp: 'Tracked by Radar',                 them: 'Not covered' },
      { label: 'The weekly meeting and full toolset', otp: 'Yes',                              them: 'Yes' },
    ]; %>

    <div class="card mt-12 overflow-hidden" style="padding:0;">
      <table class="w-full text-left">
        <thead>
          <tr style="background:var(--grey);">
            <th class="px-5 sm:px-6 py-4"></th>
            <th class="px-5 sm:px-6 py-4 font-display text-[15px] font-bold text-[var(--blue-deep)]" style="border-left:1px solid var(--line);">OTP</th>
            <th class="px-5 sm:px-6 py-4 font-display text-[15px] font-bold text-[var(--ink-mute)]" style="border-left:1px solid var(--line);">Per-seat operating-system tools</th>
          </tr>
        </thead>
        <tbody>
          <% compareRows.forEach((row) => { %>
            <tr style="border-top:1px solid var(--line);">
              <td class="px-5 sm:px-6 py-4 text-[14px] font-semibold text-[var(--ink)]"><%= row.label %></td>
              <td class="px-5 sm:px-6 py-4 text-[14px] font-semibold text-[var(--ink)]" style="border-left:1px solid var(--line); background:rgba(13,125,242,.05);"><%= row.otp %></td>
              <td class="px-5 sm:px-6 py-4 text-[14px] text-[var(--ink-mute)]" style="border-left:1px solid var(--line);"><%= row.them %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <p class="text-[14px] text-[var(--ink-mute)] leading-[1.65] text-center mt-6 max-w-[40rem] mx-auto">
      OTP is funded by the agency Sneeze It, which runs its own leadership team on OTP. Beta members are grandfathered free for life when paid plans turn on.
    </p>
  </div>
</section>

<!-- ================= FINAL CTA ================= -->
<section class="bg-[var(--orange-block)]">
  <div class="max-w-[760px] mx-auto px-6 py-24 sm:py-28 text-center">
    <div class="inline-flex items-center gap-2 font-mono text-[11px] font-semibold uppercase tracking-[0.16em] px-4 py-1.5 rounded-full mb-7"
         style="background:var(--ink); color:var(--orgy);">
      <span aria-hidden>&starf;</span> Join in Beta = free forever <span aria-hidden>&starf;</span>
    </div>
    <h2 class="font-display text-[var(--ink)] tracking-[-0.025em] leading-[1.05]"
        style="font-size:clamp(2rem,4.4vw,3.3rem); font-weight:800;">
      Keep the rhythm you know. Run it on a better layer.
    </h2>
    <p class="text-[17px] leading-[1.6] max-w-[35rem] mx-auto mt-6" style="color:#5a2a06;">
      No retraining. No new framework. Just the operating platform per-seat tools never built: free for the whole team, with an AI Chief of Staff included.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-9">
      <a href="/sign-up" onclick="return gtagSendEvent('/sign-up')" class="btn-ink px-10 py-4 text-[16px]">Create your free account &rarr;</a>
    </div>
    <p class="text-[12px] mt-8" style="color:#7a4012;">
      OTP is an independent product.
    </p>
  </div>
</section>
