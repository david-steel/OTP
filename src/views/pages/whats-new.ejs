<!-- Hero -->
<section class="bg-otp-950 py-12 sm:py-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">What's New on OTP</h1>
    <p class="text-gray-400 max-w-xl mx-auto leading-relaxed">Platform updates, new features, and improvements. Building in public.</p>
  </div>
</section>

<!-- Timeline -->
<section class="bg-white py-12 sm:py-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">

<%
  // Group entries by month
  const months = {};
  for (const entry of changelog) {
    const d = new Date(entry.date + 'T12:00:00');
    const key = d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    const monthNum = String(d.getMonth() + 1).padStart(2, '0');
    if (!months[key]) months[key] = { monthNum, entries: [] };
    months[key].entries.push(entry);
  }
%>

<% for (const [monthLabel, group] of Object.entries(months)) { %>
    <div class="mb-12">
      <h2 class="text-lg font-extrabold text-gray-900 mb-6 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-otp-100 text-otp-600 flex items-center justify-center text-xs font-bold"><%= group.monthNum %></span>
        <%= monthLabel %>
      </h2>

      <div class="space-y-6">
        <% for (const entry of group.entries) { %>
        <%
          const entryDate = new Date(entry.date + 'T12:00:00');
          const dateLabel = entryDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          const isRecent = (new Date() - entryDate) < 7 * 24 * 60 * 60 * 1000;
        %>
        <div class="relative pl-8 border-l-2 border-otp-200">
          <div class="absolute left-[-5px] top-1 w-2 h-2 rounded-full <%= isRecent ? 'bg-otp-500' : 'bg-gray-300' %>"></div>
          <div class="flex items-center gap-2 mb-1.5">
            <span class="text-xs font-semibold <%= isRecent ? 'text-otp-600 bg-otp-50' : 'text-gray-500 bg-gray-100' %> px-2 py-0.5 rounded-full"><%= dateLabel %></span>
            <% for (const tag of entry.tags) { %>
            <%
              let tClass = 'text-gray-600 bg-gray-50';
              if (tag === 'Core') tClass = 'text-rose-600 bg-rose-50';
              else if (tag === 'Security') tClass = 'text-red-600 bg-red-50';
              else if (tag === 'Quality') tClass = 'text-purple-600 bg-purple-50';
              else if (tag === 'Major') tClass = 'text-amber-600 bg-amber-50';
              else if (tag === 'Improvement') tClass = 'text-emerald-600 bg-emerald-50';
              else if (tag === 'Performance') tClass = 'text-blue-600 bg-blue-50';
              else if (tag === 'SEO') tClass = 'text-purple-600 bg-purple-50';
              else if (tag === 'Infrastructure') tClass = 'text-amber-600 bg-amber-50';
            %>
            <span class="text-xs font-semibold <%= tClass %> px-2 py-0.5 rounded-full"><%= tag %></span>
            <% } %>
          </div>
          <h3 class="text-base font-bold text-gray-900 mb-1"><%= entry.title %></h3>
          <% if (entry.details) { %>
          <div class="changelog-details text-sm text-gray-500 leading-relaxed [&>p]:mb-2 [&>ul]:mb-2 [&>ul]:list-disc [&>ul]:pl-5 [&>ul]:space-y-1">
            <%- entry.details %>
          </div>
          <% } else { %>
          <p class="text-sm text-gray-500 leading-relaxed"><%= entry.summary %></p>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
<% } %>

  </div>
</section>

<!-- CTA -->
<section class="bg-gray-50 py-12 sm:py-16 border-t border-gray-100">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-xl font-extrabold text-gray-900 mb-3">Ready to publish your coordination intelligence?</h2>
    <p class="text-sm text-gray-500 mb-6">Join the network of organizations sharing how their AI agents coordinate.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/generate" class="px-6 py-2.5 bg-otp-500 text-white rounded-lg font-semibold hover:bg-otp-400 transition-all text-sm">Generate Your OOS</a>
      <a href="/browse" class="px-6 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-lg font-semibold hover:bg-gray-50 transition-all text-sm">Browse the Network</a>
    </div>
  </div>
</section>
