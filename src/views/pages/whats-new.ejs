<%# /whats-new -- v7 layout (light, editorial). Changelog timeline grouped by month.
    Rendered via reply.view('pages/whats-new', data, { layout: 'layouts/v7' }). %>
<style>
  .wn-track {
    position:absolute; left:5px; top:0; bottom:0; width:2px; background:var(--line);
  }
  .wn-node {
    position:absolute; left:-1px; top:4px; width:13px; height:13px;
    border-radius:50%; border:3px solid var(--white); box-sizing:content-box;
  }
  .wn-tag {
    font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:500;
    letter-spacing:0.06em; text-transform:uppercase;
    padding:2px 8px; border-radius:6px; display:inline-block;
  }
  .changelog-details { font-size:14px; color:var(--ink-soft); line-height:1.7; }
  .changelog-details p { margin-bottom:0.5rem; }
  .changelog-details ul { margin-bottom:0.5rem; list-style:disc; padding-left:1.25rem; }
  .changelog-details ul > li { margin-bottom:0.2rem; }
  .changelog-details a { color:var(--blue-deep); font-weight:600; border-bottom:1.5px solid currentColor; }
  .wn-wave { animation:wn-wave 3.4s ease-in-out infinite; transform-origin:80% 90%; }
  @keyframes wn-wave { 0%,68%,100%{transform:rotate(0);} 78%{transform:rotate(16deg);} 88%{transform:rotate(-7deg);} }
  @media (prefers-reduced-motion:reduce){ .wn-wave{ animation:none; } }
</style>

<%# In-shell trim: inside the authed main layout (renderInShell), the app
    shell's fixed nav is already cleared by the layout's pt, so the v7
    nav-clearing pt-[124px]/pt-[148px] would double the gap. Inline style
    wins over both Tailwind classes. authUserId only exists on the authed
    path -- the v7 marketing render is unchanged. %>
<!-- ================= HEADER ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[760px] mx-auto px-6 pt-[124px] pb-12 sm:pt-[148px] sm:pb-16 text-center"<%- (typeof authUserId !== 'undefined' && authUserId) ? ' style="padding-top:56px;"' : '' %>>
    <img src="/public/images/orgy-celebrate.webp" alt="" width="80" height="80" loading="eager"
         class="mx-auto mb-5 w-[72px] h-auto sm:w-[80px]" decoding="async">
    <div class="eyebrow mb-4 flex items-center gap-2.5 justify-center">
      <span class="tick" style="background:var(--orgy-deep);"></span>Changelog
    </div>
    <h1 class="font-display text-[var(--ink)] mx-auto"
        style="font-size:clamp(2.1rem,4.4vw,3.3rem); line-height:1.08; font-weight:700; letter-spacing:-0.025em;">
      What's new on OTP
    </h1>
    <p class="text-[16px] sm:text-[17px] text-[var(--ink-soft)] leading-[1.6] max-w-[32rem] mx-auto mt-5">
      Platform updates, new features, and improvements. Building in public.
    </p>
  </div>
</section>

<!-- ================= TIMELINE ================= -->
<section class="bg-[var(--grey)]">
  <div class="max-w-[760px] mx-auto px-6 py-16 sm:py-20">

<%
  // Group entries by month
  const months = {};
  for (const entry of changelog) {
    const d = new Date(entry.date + 'T12:00:00');
    const key = d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    const monthNum = String(d.getMonth() + 1).padStart(2, '0');
    if (!months[key]) months[key] = { monthNum, entries: [] };
    months[key].entries.push(entry);
  }
%>

<% for (const [monthLabel, group] of Object.entries(months)) { %>
    <div class="mb-14 last:mb-0">
      <h2 class="font-display text-[var(--ink)] flex items-center gap-3 mb-7"
          style="font-size:1.35rem; font-weight:700; letter-spacing:-0.01em;">
        <span class="font-mono flex items-center justify-center"
              style="width:34px; height:34px; border-radius:9px; font-size:12px; font-weight:500;
                     background:var(--card); border:1px solid var(--line); color:var(--ink-soft);">
          <%= group.monthNum %>
        </span>
        <%= monthLabel %>
      </h2>

      <div class="relative pl-8">
        <div class="wn-track"></div>
        <div class="space-y-7">
        <% for (const entry of group.entries) { %>
        <%
          const entryDate = new Date(entry.date + 'T12:00:00');
          const dateLabel = entryDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          const isRecent = (new Date() - entryDate) < 7 * 24 * 60 * 60 * 1000;
        %>
        <div class="relative">
          <div class="wn-node" style="background:<%= isRecent ? 'var(--blue)' : 'var(--ink-mute)' %>;"></div>
          <div class="card p-5 sm:p-6">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="wn-tag"
                    style="<%= isRecent
                      ? 'background:rgba(13,125,242,.1);color:var(--blue-deep);'
                      : 'background:var(--grey);color:var(--ink-mute);' %>">
                <%= dateLabel %>
              </span>
              <% for (const tag of entry.tags) { %>
              <%
                let tBg = 'var(--grey)', tFg = 'var(--ink-soft)';
                if (tag === 'Core')              { tBg = 'rgba(212,84,10,.1)';  tFg = 'var(--orange-deep)'; }
                else if (tag === 'Security')     { tBg = 'rgba(212,84,10,.1)';  tFg = 'var(--orange-deep)'; }
                else if (tag === 'Quality')      { tBg = 'rgba(13,125,242,.1)'; tFg = 'var(--blue-deep)'; }
                else if (tag === 'Major')        { tBg = 'rgba(255,122,26,.14)';tFg = 'var(--orange-deep)'; }
                else if (tag === 'Improvement')  { tBg = 'rgba(10,157,99,.1)';  tFg = 'var(--green-deep)'; }
                else if (tag === 'Performance')  { tBg = 'rgba(13,125,242,.1)'; tFg = 'var(--blue-deep)'; }
                else if (tag === 'SEO')          { tBg = 'rgba(13,125,242,.1)'; tFg = 'var(--blue-deep)'; }
                else if (tag === 'Infrastructure'){ tBg = 'rgba(255,122,26,.14)';tFg = 'var(--orange-deep)'; }
              %>
              <span class="wn-tag" style="background:<%= tBg %>;color:<%= tFg %>;"><%= tag %></span>
              <% } %>
            </div>
            <h3 class="font-display text-[var(--ink)] mb-1.5"
                style="font-size:1.02rem; font-weight:700; line-height:1.3;">
              <%= entry.title %>
            </h3>
            <% if (entry.details) { %>
            <div class="changelog-details">
              <%- entry.details %>
            </div>
            <% } else { %>
            <p class="text-[14px] text-[var(--ink-soft)] leading-[1.7]"><%= entry.summary %></p>
            <% } %>
          </div>
        </div>
        <% } %>
        </div>
      </div>
    </div>
<% } %>

  </div>
</section>

<!-- ================= CTA ================= -->
<section class="bg-[var(--white)]">
  <div class="max-w-[760px] mx-auto px-6 py-20 sm:py-24">
    <div class="card p-8 sm:p-11">
      <div class="flex flex-col sm:flex-row items-start gap-7">
        <div class="shrink-0 mx-auto sm:mx-0">
          <img src="/public/hand-3.png" alt="" aria-hidden="true" class="wn-wave block" style="width:82px; height:auto;">
        </div>
        <div class="text-center sm:text-left">
          <div class="eyebrow mb-3" style="color:var(--green-deep);">Join the network</div>
          <h2 class="font-display text-[var(--ink)] leading-[1.15] mb-3"
              style="font-size:clamp(1.5rem,2.8vw,2.1rem); font-weight:700;">
            Ready to publish your coordination intelligence?
          </h2>
          <p class="text-[15px] text-[var(--ink-soft)] leading-[1.7] mb-6">
            Join the network of organizations sharing how their AI agents coordinate.
          </p>
          <div class="flex flex-wrap gap-3 justify-center sm:justify-start">
            <a href="/generate" class="btn-primary px-7 py-3.5 text-[15px]">Generate your OOS &rarr;</a>
            <a href="/browse" class="btn-ghost px-7 py-3.5 text-[15px]">Browse the network</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
