    if (!gapEl) return;
    var gapQuarter = <%- jsonForScript(currentQuarter || '') %>;
    var meSeat = <%- jsonForScript(locals.meExternalId || '') %>;

    var filterBar = document.getElementById('gap-filter');
    if (filterBar) {
      var fbtns = filterBar.querySelectorAll('.gap-filter-btn');
      var applyGapFilter = function(mode){
        gapEl.querySelectorAll('.gap-item').forEach(function(li){
          var cat = li.dataset.gapCat || '';
          var rt = li.dataset.gapReportsto || '';
          var show = mode === 'all'
            || (mode === 'human' && cat === 'human')
            || (mode === 'agent' && cat === 'agent')
            || (mode === 'noseat' && cat === 'noseat')
            || (mode === 'reports' && !!rt && !!meSeat && rt === meSeat);
          li.classList.toggle('hidden', !show);
        });
        var anyVisible = false;
        gapEl.querySelectorAll('[data-gap-section]').forEach(function(sec){
          var vis = sec.querySelectorAll('.gap-item:not(.hidden)').length;
          sec.classList.toggle('hidden', vis === 0);
          var cnt = sec.querySelector('.gap-section-count');
          if (cnt) cnt.textContent = '(' + vis + ')';
          if (vis > 0) anyVisible = true;
        });
        var emptyEl = document.getElementById('gap-empty');
        if (emptyEl) emptyEl.classList.toggle('hidden', anyVisible);
        filterBar.dataset.active = mode;
        fbtns.forEach(function(b){
          var on = b.dataset.gapFilter === mode;
          b.classList.toggle('bg-gray-100', on);
          b.classList.toggle('text-gray-700', on);
          b.classList.toggle('border-gray-300', on);
          b.classList.toggle('text-gray-500', !on);
          b.classList.toggle('border-gray-200', !on);
        });
      };
      fbtns.forEach(function(b){
        b.addEventListener('click', function(){ applyGapFilter(b.dataset.gapFilter); });
      });
    }

    function showGapForm(li, form){
      li.querySelectorAll('form').forEach(function(f){ if (f !== form) f.classList.add('hidden'); });
      if (form) form.classList.toggle('hidden');
    }
    function bindToggle(sel, formSel){
      gapEl.querySelectorAll(sel).forEach(function(btn){
        btn.addEventListener('click', function(){
          var li = btn.closest('.gap-item');
          showGapForm(li, li.querySelector(formSel));
        });
      });
    }
    bindToggle('.gap-add-kpi', '.gap-kpi-form');
    bindToggle('.gap-add-rock', '.gap-rock-form');
    bindToggle('.gap-reassign-btn', '.gap-reassign-form');
    bindToggle('.gap-setmgr-btn', '.gap-setmgr-form');
    gapEl.querySelectorAll('.gap-cancel').forEach(function(btn){
      btn.addEventListener('click', function(){ btn.closest('form').classList.add('hidden'); });
    });

    function gapBusy(form, on){
      var sub = form.querySelector('button[type=submit]');
      if (!sub) return;
      if (on) { sub.dataset.label = sub.dataset.label || sub.textContent; sub.disabled = true; sub.textContent = 'Saving...'; }
      else { sub.disabled = false; sub.textContent = sub.dataset.label || sub.textContent; }
    }
    function gapSubmit(form, handler){
      form.addEventListener('submit', function(e){
        e.preventDefault();
        var req = handler(form);
        if (!req) return;
        gapBusy(form, true);
        req.then(reload).catch(function(err){
          gapBusy(form, false);
          alert((err && err.message) || 'Action failed');
        });
      });
    }

    gapEl.querySelectorAll('.gap-kpi-form').forEach(function(form){
      gapSubmit(form, function(f){
        var li = f.closest('.gap-item');
        var fd = new FormData(f);
        var title = (fd.get('title') || '').toString().trim();
        if (!title) { alert('A KPI needs a title.'); return null; }
        var body = {
          ownerEntityType: li.dataset.gapCat === 'agent' ? 'agent' : 'human',
          ownerExternalId: li.dataset.seatId,
          title: title,
          timeGrain: (fd.get('timeGrain') || 'weekly').toString(),
        };
        var gv = (fd.get('goalValue') || '').toString().trim();
        if (gv !== '') {
          body.goalOperator = (fd.get('goalOperator') || 'gte').toString();
          body.goalValue = Number(gv);
        }
        var unit = (fd.get('unit') || '').toString().trim();
        if (unit) body.unit = unit;
        return api('POST', '/kpis', body);
      });
    });

    gapEl.querySelectorAll('.gap-rock-form').forEach(function(form){
      gapSubmit(form, function(f){
        var li = f.closest('.gap-item');
        var fd = new FormData(f);
        var title = (fd.get('title') || '').toString().trim();
        var due = (fd.get('dueDate') || '').toString();
        if (title.length < 3 || !due) { alert('A Rock needs a title (3+ chars) and a due date.'); return null; }
        return api('POST', '/rocks', {
          ownerEntityType: li.dataset.gapCat === 'agent' ? 'agent' : 'human',
          ownerExternalId: li.dataset.seatId,
          title: title,
          quarter: gapQuarter,
          dueDate: new Date(due + 'T12:00:00Z').toISOString(),
        });
      });
    });

    gapEl.querySelectorAll('.gap-reassign-form').forEach(function(form){
      gapSubmit(form, function(f){
        var li = f.closest('.gap-item');
        var val = (new FormData(f).get('seat') || '').toString();
        if (!val) { alert('Pick a seat first.'); return null; }
        var parts = val.split(':');
        var entityType = parts[0];
        var externalId = parts[1];
        var name = parts.slice(2).join(':');
        var kind = li.dataset.recordKind;
        var id = li.dataset.recordId;
        if (kind === 'kpi') {
          return api('PATCH', '/kpis/' + id, { ownerEntityType: entityType, ownerExternalId: externalId });
        }
        var path = kind === 'rock' ? '/rocks/' + id : '/tickets/' + id;
        return api('PUT', path, { ownerEntityType: entityType, ownerExternalId: externalId, ownerName: name });
      });
    });

    gapEl.querySelectorAll('.gap-setmgr-form').forEach(function(form){
      gapSubmit(form, function(f){
        var li = f.closest('.gap-item');
        var mgr = (new FormData(f).get('manager') || '').toString();
        if (!mgr) { alert('Pick a human seat first.'); return null; }
        return api('PATCH', '/team/entity', {
          type: 'agent',
          externalId: li.dataset.agentId,
          patch: { reports_to: mgr },
        });
      });
    });
  })();

  // Persist My Agents open/closed state across page loads. <details> is
  // native browser collapse but doesn't remember state on its own.
  // Default state: collapsed (David flagged the section as too tall in the
  // right column on 2026-05-24). First-time visitors see the summary line;
  // expand once and the choice sticks for them.
  (function persistAgentDetails() {
    var d = document.getElementById('my-agents-details');
    if (!d) return;
    var KEY = 'otp-dashboard-my-agents-open';
    try {
      var saved = localStorage.getItem(KEY);
      if (saved === '1') d.setAttribute('open', '');
      // saved === '0' OR null both leave it collapsed (the default)
    } catch (e) { /* localStorage blocked, fall through to default */ }
    d.addEventListener('toggle', function(){
      try { localStorage.setItem(KEY, d.open ? '1' : '0'); } catch (e) { /* ignore */ }
    });
  })();

  // Persist Overdue / Upcoming / No-due-date open state across reloads.
  // Every action in the to-do list (edit, delete, complete) calls
  // window.location.reload(), which would otherwise snap the user's
  // expanded bucket back to its default. Keep it open if they opened it.
  (function persistTodoBuckets() {
    document.querySelectorAll('details[data-todo-bucket]').forEach(function(d){
      var KEY = 'otp-dashboard-todo-bucket-' + d.dataset.todoBucket;
      try {
        var saved = localStorage.getItem(KEY);
        if (saved === '1') d.setAttribute('open', '');
        else if (saved === '0') d.removeAttribute('open');
        // null = honor server-rendered default (defaultOpen)
      } catch (e) { /* localStorage blocked, fall through to default */ }
      d.addEventListener('toggle', function(){
        try { localStorage.setItem(KEY, d.open ? '1' : '0'); } catch (e) { /* ignore */ }
      });
    });
  })();

  // ================================================================
  // Inline Next Action edit/save/done (Phase 1, 2026-05-25).
  // Event delegation so it works for rocks + issues without per-row
  // binding. The endpoint URL is picked by data-na-kind. Server
  // stamps next_action_set_at on every change.
  // ================================================================
  (function wireNextActions() {
    function urlFor(kind, id) {
      if (kind === 'rock')  return '/api/v1/rocks/'   + encodeURIComponent(id);
      if (kind === 'issue') return '/api/v1/tickets/' + encodeURIComponent(id);
      return null;
    }
    document.addEventListener('click', function(e) {
      var editBtn = e.target.closest('.next-action .na-edit');
      var cancelBtn = e.target.closest('.next-action .na-cancel');
      var doneBtn = e.target.closest('.next-action .na-done');
      if (editBtn) {
        var wrap = editBtn.closest('.next-action');
        var view = wrap.querySelector('.na-view');
        var form = wrap.querySelector('.na-edit-form');
        if (view) view.classList.add('hidden');
        if (editBtn.tagName === 'BUTTON' && !view) editBtn.classList.add('hidden');
        form.classList.remove('hidden');
        var inp = form.querySelector('.na-input');
        if (inp) { inp.focus(); inp.select(); }
        return;
      }
      if (cancelBtn) {
        var wrap = cancelBtn.closest('.next-action');
        var view = wrap.querySelector('.na-view');
        var form = wrap.querySelector('.na-edit-form');
        form.classList.add('hidden');
        if (view) view.classList.remove('hidden');
        // For empty-state (no view), restore the "+ Set Next Action" button.
        var addBtn = wrap.querySelector('.na-edit');
        if (!view && addBtn) addBtn.classList.remove('hidden');
        return;
      }
      if (doneBtn) {
        var wrap = doneBtn.closest('.next-action');
        var kind = wrap.getAttribute('data-na-kind');
        var id = wrap.getAttribute('data-na-id');
        var url = urlFor(kind, id);
        if (!url) return;
        // Clear the next action -- the empty-state nudge will then
        // prompt the user to set the next next action, keeping the
        // GTD chain alive.
        OTP.apiSave({
          method: kind === 'issue' ? 'PUT' : 'PUT',
          url: url,
          body: { nextAction: null },
          btnEl: doneBtn,
          errorContext: 'Mark Next Action done',
          onSuccess: function() { window.location.reload(); },
        });
      }
    });
    document.addEventListener('submit', function(e) {
      var form = e.target.closest('.next-action .na-edit-form');
      if (!form) return;
      e.preventDefault();
      var wrap = form.closest('.next-action');
      var kind = wrap.getAttribute('data-na-kind');
      var id = wrap.getAttribute('data-na-id');
      var inp = form.querySelector('.na-input');
      var value = (inp.value || '').trim();
      var url = urlFor(kind, id);
      if (!url) return;
      var saveBtn = form.querySelector('.na-save');
      OTP.apiSave({
        method: 'PUT',
        url: url,
        body: { nextAction: value || null },
        btnEl: saveBtn,
        errorContext: 'Save Next Action',
        onSuccess: function() { window.location.reload(); },
      });
    });
  })();

})();
</script>

<script>
// Disposition for delegated to-dos the owner never closed: the delegator
// closes it out (done + verified in one step). The owner gets an alert-bell
// notification via the todos PATCH transition hooks.
(function () {
  document.querySelectorAll('.waiting-closeout').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (!confirm('Close this out yourself? It will be marked done and verified, and the owner will be notified.')) return;
      var id = btn.getAttribute('data-todo-id');
      OTP.apiSave({
        method: 'PUT', url: '/api/v1/todos/' + encodeURIComponent(id),
        body: { done: true, verified: true },
        btnEl: btn,
        errorContext: 'Close out to-do',
        onSuccess: function () {
          var li = btn.closest('li');
          if (li) { li.style.transition = 'opacity 0.25s'; li.style.opacity = '0'; setTimeout(function () { li.remove(); }, 250); }
        },
      });
    });
  });
})();
</script>

<script>
// Customize mode: per-tile hide/show, drag-reorder between any layout cell
// (SortableJS group, lazy-loaded on first toggle), per-row layout controls
// (column pattern / add row / remove row), and S-3XL font size (zoom on the
// container -- Tailwind text classes are rem-based so font-size would no-op).
// Every change debounces 600ms then PUTs the FULL state
// ({ hiddenTiles, layout, fontSize }) to /api/v1/dashboard-preferences.
// tileOrder is no longer written (schema keeps it for old saved prefs).
// The cascading tile is integrator-directive: movable, never hideable.
(function(){
  var root = document.getElementById('daily-dashboard');
  var btn = document.getElementById('dash-customize-btn');
  if (!root || !btn) return;
  var ASSET = <%- jsonForScript(typeof assetVersion !== 'undefined' ? assetVersion : 'dev') %>;
  var prefs = window.__dashboardPrefs || {};
  var ZOOM = { sm: '0.9', base: '1', lg: '1.12', xl: '1.3', xxl: '1.5', xxxl: '1.75' };
  var state = {
    hidden: Array.isArray(prefs.hiddenTiles) ? prefs.hiddenTiles.slice() : [],
    fontSize: ZOOM[prefs.fontSize] ? prefs.fontSize : 'base',
  };
  var NOT_HIDEABLE = { cascading: true };
  var MAX_ROWS = 8; // schema limit -- adding a 9th row would 400 on save
  var PATTERN_LABELS = [
    ['12', '1 column'],
    ['4-8', '1/3 + 2/3'],
    ['8-4', '2/3 + 1/3'],
    ['6-6', '1/2 + 1/2'],
    ['4-4-4', '1/3 + 1/3 + 1/3'],
  ];
  var bar = document.getElementById('dash-customize-bar');
  var errEl = document.getElementById('dash-prefs-err');
  var editing = false;
  var sortables = [];
  var sortableLoading = null;

  function tiles(){ return Array.prototype.slice.call(root.querySelectorAll('[data-tile-id]')); }
  function rows(){ return Array.prototype.slice.call(root.querySelectorAll('[data-dash-row]')); }
  function rowCells(row){ return Array.prototype.slice.call(row.querySelectorAll('[data-dash-cell]')); }
  function isHidden(id){ return state.hidden.indexOf(id) !== -1; }
  // Serialize the current DOM into the layout prefs shape. Cell count always
  // matches the row's data-dash-pattern because both are set together.
  function layoutFromDom(){
    return rows().map(function(row){
      return {
        pattern: row.getAttribute('data-dash-pattern') || '12',
        cells: rowCells(row).map(function(cell){
          return Array.prototype.map.call(cell.querySelectorAll('[data-tile-id]'),
            function(t){ return t.getAttribute('data-tile-id'); });
        }),
      };
    });
  }
  function applyZoom(){ root.style.zoom = ZOOM[state.fontSize] || '1'; }
  function syncFontSeg(){
    Array.prototype.forEach.call(document.querySelectorAll('#dash-font-seg .dk-own-btn'), function(b){
      b.classList.toggle('active', b.getAttribute('data-font') === state.fontSize);
    });
  }

  // --- persistence: debounce 600ms, PUT the full current state ---
  var saveTimer = null;
  function scheduleSave(){
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(function(){ saveNow(); }, 600);
  }
  function saveNow(bodyOverride){
    if (saveTimer) { clearTimeout(saveTimer); saveTimer = null; }
    var body = bodyOverride || {
      hiddenTiles: state.hidden,
      layout: layoutFromDom(),
      fontSize: state.fontSize,
    };
    fetch('/api/v1/dashboard-preferences', {
      method: 'PUT',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    }).then(function(r){
      if (!r.ok) throw new Error('HTTP ' + r.status);
      if (errEl) errEl.style.display = 'none';
    }).catch(function(e){
      if (errEl) {
        errEl.textContent = 'Could not save layout (' + ((e && e.message) || 'error') + ') -- changes apply for this view only';
        errEl.style.display = '';
      }
    });
  }

  // --- SortableJS: vendored at /public/js/Sortable.min.js, loaded lazily ---
  function ensureSortable(){
    if (window.Sortable) return Promise.resolve();
    if (sortableLoading) return sortableLoading;
    sortableLoading = new Promise(function(resolve, reject){
      var s = document.createElement('script');
      s.src = '/public/js/Sortable.min.js?v=' + encodeURIComponent(ASSET);
      s.onload = function(){ resolve(); };
      s.onerror = function(){ sortableLoading = null; reject(new Error('Sortable load failed')); };
      document.head.appendChild(s);
    });
    return sortableLoading;
  }
  // One Sortable per layout cell, shared group so tiles drag between any
  // cell in any row. Rebuilt whenever the row/cell structure changes.
  function destroySortables(){
    sortables.forEach(function(s){ try { s.destroy(); } catch (e) { /* already gone */ } });
    sortables = [];
  }
  function initSortables(){
    destroySortables();
    if (!editing || !window.Sortable) return;
    rows().forEach(function(row){
      rowCells(row).forEach(function(cell){
        sortables.push(new Sortable(cell, {
          group: 'dash-tiles',
          handle: '.dash-drag-handle',
          draggable: '[data-tile-id]',
          animation: 150,
          onEnd: function(){ scheduleSave(); },
        }));
      });
    });
  }

  function injectControls(tile){
    var id = tile.getAttribute('data-tile-id');
    var ctl = document.createElement('div');
    ctl.className = 'dash-edit-controls';
    var handle = document.createElement('span');
    handle.className = 'dash-drag-handle';
    handle.textContent = '⣿'; // braille "grip" glyph
    handle.title = 'Drag to move';
    ctl.appendChild(handle);
    if (!NOT_HIDEABLE[id]) { // integrator directive (cascading): movable, never hideable
      var toggle = document.createElement('button');
      toggle.type = 'button';
      toggle.className = 'dash-hide-toggle';
      toggle.textContent = isHidden(id) ? 'Show' : 'Hide';
      toggle.addEventListener('click', function(e){
        e.preventDefault(); e.stopPropagation();
        var i = state.hidden.indexOf(id);
        if (i === -1) state.hidden.push(id); else state.hidden.splice(i, 1);
        tile.classList.toggle('dash-tile-hidden', isHidden(id));
        toggle.textContent = isHidden(id) ? 'Show' : 'Hide';
        scheduleSave();
      });
      ctl.appendChild(toggle);
    }
    // Don't let clicks on the strip toggle a parent <details>.
    ctl.addEventListener('click', function(e){ e.preventDefault(); e.stopPropagation(); });
    // <details> hides non-summary children when closed, so the strip lives
    // inside the always-visible <summary>; sections get it prepended on top.
    if (tile.tagName === 'DETAILS') {
      var summary = tile.querySelector('summary');
      (summary || tile).appendChild(ctl);
    } else {
      tile.insertBefore(ctl, tile.firstChild);
    }
    tile.__dashCtl = ctl;
  }

  // --- per-row layout controls (edit mode only) ---
  // Rebuild a row's cells for a new pattern: cell i keeps its tiles, tiles
  // from removed cells merge into the last remaining cell. Nothing is lost.
  function applyPattern(row, pattern){
    var spans = (window.__dashSpanSets || {})[pattern];
    if (!spans) return;
    var oldCells = rowCells(row);
    var stacks = oldCells.map(function(c){
      return Array.prototype.slice.call(c.querySelectorAll('[data-tile-id]'));
    });
    var newCells = spans.map(function(span){
      var cell = document.createElement('div');
      cell.className = 'dash-span-' + span + ' space-y-5';
      cell.setAttribute('data-dash-cell', '');
      row.appendChild(cell);
      return cell;
    });
    stacks.forEach(function(stack, i){
      var target = newCells[Math.min(i, newCells.length - 1)];
      stack.forEach(function(t){ target.appendChild(t); });
    });
    oldCells.forEach(function(c){ if (c.parentNode) c.parentNode.removeChild(c); });
    row.setAttribute('data-dash-pattern', pattern);
  }
  function syncRowBarButtons(){
    rows().forEach(function(row, idx, all){
      var rowBar = row.__dashRowBar;
      if (!rowBar) return;
      var hasTiles = !!row.querySelector('[data-tile-id]');
      // remove: allowed when the row is empty, or when there is a row above
      // to receive its tiles. Blocked for a non-empty first row.
      rowBar.__removeBtn.disabled = (idx === 0 && hasTiles) || all.length <= 1;
      rowBar.__addBtn.disabled = all.length >= MAX_ROWS;
    });
  }
  function injectRowBar(row){
    var rowBar = document.createElement('div');
    rowBar.className = 'dash-row-bar';
    var label = document.createElement('span');
    label.textContent = 'Row';
    rowBar.appendChild(label);
    var sel = document.createElement('select');
    PATTERN_LABELS.forEach(function(p){
      var opt = document.createElement('option');
      opt.value = p[0];
      opt.textContent = p[1];
      sel.appendChild(opt);
    });
    sel.value = row.getAttribute('data-dash-pattern') || '12';
    sel.addEventListener('change', function(){
      applyPattern(row, sel.value);
      initSortables();
      syncRowBarButtons();
      scheduleSave();
    });
    rowBar.appendChild(sel);
    var addBtn = document.createElement('button');
    addBtn.type = 'button';
    addBtn.className = 'dash-row-btn';
    addBtn.textContent = '+ Add row below';
    addBtn.addEventListener('click', function(){
      if (rows().length >= MAX_ROWS || !window.__dashBuildRow) return;
      var fresh = window.__dashBuildRow('12');
      row.parentNode.insertBefore(fresh, row.nextSibling);
      injectRowBar(fresh);
      initSortables();
      syncRowBarButtons();
      scheduleSave();
    });
    rowBar.appendChild(addBtn);
    var removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'dash-row-btn';
    removeBtn.textContent = '× Remove row';
    removeBtn.addEventListener('click', function(){
      var all = rows();
      var idx = all.indexOf(row);
      var rowTiles = Array.prototype.slice.call(row.querySelectorAll('[data-tile-id]'));
      if (rowTiles.length) {
        if (idx <= 0) return; // non-empty first row: nowhere above to move tiles
        var aboveCells = rowCells(all[idx - 1]);
        var target = aboveCells[aboveCells.length - 1];
        rowTiles.forEach(function(t){ target.appendChild(t); });
      } else if (all.length <= 1) {
        return; // never remove the last row
      }
      row.parentNode.removeChild(row);
      initSortables();
      syncRowBarButtons();
      scheduleSave();
    });
    rowBar.appendChild(removeBtn);
    rowBar.__removeBtn = removeBtn;
    rowBar.__addBtn = addBtn;
    row.insertBefore(rowBar, row.firstChild);
    row.__dashRowBar = rowBar;
  }
  function removeRowBars(){
    rows().forEach(function(row){
      if (row.__dashRowBar) {
        if (row.__dashRowBar.parentNode) row.__dashRowBar.parentNode.removeChild(row.__dashRowBar);
        row.__dashRowBar = null;
      }
    });
  }

  function enterEdit(){
    editing = true;
    root.classList.add('dash-edit-mode');
    btn.textContent = 'Done';
    if (bar) bar.style.display = '';
    syncFontSeg();
    tiles().forEach(injectControls);
    rows().forEach(injectRowBar);
    syncRowBarButtons();
    ensureSortable().then(function(){
      initSortables();
    }).catch(function(){ /* drag unavailable; hide/show, rows + font size still work */ });
  }

  function exitEdit(){
    editing = false;
    root.classList.remove('dash-edit-mode');
    btn.textContent = 'Customize';
    if (bar) bar.style.display = 'none';
    destroySortables();
    tiles().forEach(function(tile){
      if (tile.__dashCtl) { tile.__dashCtl.parentNode.removeChild(tile.__dashCtl); tile.__dashCtl = null; }
    });
    removeRowBars();
    if (saveTimer) saveNow(); // flush a pending debounce on close
  }

  btn.addEventListener('click', function(){ if (editing) { exitEdit(); } else { enterEdit(); } });

  // Font size segmented control (S / M / L / XL / 2XL / 3XL)
  Array.prototype.forEach.call(document.querySelectorAll('#dash-font-seg .dk-own-btn'), function(b){
    b.addEventListener('click', function(){
      var f = b.getAttribute('data-font');
      state.fontSize = ZOOM[f] ? f : 'base';
      applyZoom(); syncFontSeg(); scheduleSave();
    });
  });

  // Reset to default: everything visible, the default rows, base font. The
  // schema is .strict() with no nulls, so reset sends the explicit default
  // layout + empty hiddenTiles (saved immediately, not debounced).
  var resetBtn = document.getElementById('dash-reset-btn');
  if (resetBtn) resetBtn.addEventListener('click', function(){
    state.hidden = [];
    state.fontSize = 'base';
    applyZoom(); syncFontSeg();
    tiles().forEach(function(tile){
      tile.classList.remove('dash-tile-hidden');
      var tg = tile.__dashCtl && tile.__dashCtl.querySelector('.dash-hide-toggle');
      if (tg) tg.textContent = 'Hide';
    });
    var def = window.__dashDefaultLayout || [];
    if (window.__dashApplyLayout && def.length) {
      destroySortables();
      removeRowBars();
      window.__dashApplyLayout(def);
      if (editing) {
        rows().forEach(injectRowBar);
        syncRowBarButtons();
        initSortables();
      }
    }
    saveNow({ hiddenTiles: [], layout: def, fontSize: 'base' });
  });
})();
</script>

