<% /* XSS guard: embed a value in an inline <script> via jsonForScript() -- escapes < and > so a value containing </script> can't break out of the script context (stored-XSS guard). */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<%
  // Daily Manager Dashboard. The home base for anyone who runs a meeting --
  // EOS-style L10 with Headlines / Rocks / KPIs / To-Dos / Issues, plus an
  // OTP-native "My Agents" surface. Designed to be opened every morning.
  //
  // Data shape passed in by the /dashboard route:
  //   org, orgs, member, capabilities, isIntegrator (bool),
  //   meetings, selectedMeetingId, headlines, currentQuarter,
  //   myRocks, myKpis, kpiValues (map kpiId -> latest value),
  //   myTodos, myIssues, myAgents,
  //   mcpStatus { connected, lastUsedAt, hasKey, keyPrefix? },
  //   memberClaimedEntityIds (string[]).

  var member = locals.member || {};
  var role = member.role || 'managee';
  var displayName = member.displayName || member.email || 'there';
  var firstName = (displayName.split(' ')[0] || displayName).split('@')[0];
  var orgName = (locals.org && locals.org.name) || '';
  var caps = locals.capabilities || {};
  var orgs = locals.orgs || [];
  var meetings = locals.meetings || [];
  var upcomingMeetings = locals.upcomingMeetings || [];
  var pastMeetings = locals.pastMeetings || [];
  var selectedMeetingId = locals.selectedMeetingId || '';
  var selectedMeeting = null;
  for (var i = 0; i < meetings.length; i++) {
    if (meetings[i].id === selectedMeetingId) { selectedMeeting = meetings[i]; break; }
  }
  var headlines = locals.headlines || [];
  var myRocks = locals.myRocks || [];
  var myKpis = locals.myKpis || [];
  var kpiValues = locals.kpiValues || {};
  var myTodos = locals.myTodos || [];
  var myIssues = locals.myIssues || [];
  var myAgents = locals.myAgents || [];
  var mcp = locals.mcpStatus || { connected: false, hasKey: false, lastUsedAt: null };
  var quarter = locals.currentQuarter || '';
  var isIntegrator = !!locals.isIntegrator;
  var orgTeams = locals.orgTeams || [];
  var selectedTeamId = locals.selectedTeamId || '';
  var scopeMine = !!locals.scopeMine;
  // teamId -> name, for the "which meeting is this tied to" label on each item.
  var teamNameById = {};
  orgTeams.forEach(function(t){ teamNameById[t.id] = t.name; });
  // Reusable team-tag markup for an item's teamId.
  function teamTag(tid){
    if (!tid || !teamNameById[tid]) return '';
    return '<span class="ml-1 inline-flex items-center gap-1 text-[10px] font-semibold text-orgy-blue bg-orgy-blue-soft rounded px-1.5 py-0.5 whitespace-nowrap">→ ' +
      String(teamNameById[tid]).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</span>';
  }
  var greeting = (function(){
    var h = new Date().getHours();
    if (h < 12) return 'Good morning';
    if (h < 18) return 'Good afternoon';
    return 'Good evening';
  })();

  // Per-user dashboard prefs (orgMembers.preferences.dashboard). Applied
  // server-side where possible so there's no flash: hidden tiles get a
  // display:none class, font size becomes a zoom on the container (Tailwind
  // text classes are rem-based, so container font-size would do nothing).
  // Tile ORDER is applied by a small synchronous script right after the grid.
  var dashPrefs = locals.dashboardPrefs || {};
  var dashHiddenTiles = Array.isArray(dashPrefs.hiddenTiles) ? dashPrefs.hiddenTiles : [];
  function dashHide(id){ return dashHiddenTiles.indexOf(id) !== -1 ? ' dash-tile-hidden' : ''; }
  var dashZoomMap = { sm: '0.9', base: '1', lg: '1.12', xl: '1.3', xxl: '1.5', xxxl: '1.75' };
  var dashZoom = dashZoomMap[dashPrefs.fontSize] || '1';
  // Row-based layout engine: when a saved layout exists the static rows below
  // are rendered visibility:hidden and a synchronous script (after the last
  // tile) rebuilds the rows from prefs.layout and moves the tiles -- so the
  // default markup never flashes in the wrong place.
  var dashHasLayout = Array.isArray(dashPrefs.layout) && dashPrefs.layout.length > 0;
  var dashRowHide = dashHasLayout ? ' style="visibility:hidden"' : '';
%>

<%- include('../partials/orgy-palette'); %>
<%- include('../partials/api-save-handler'); %>

<style>
  /* Daily dashboard: EOS-clean card polish. Scoped to #daily-dashboard so it
     touches nothing else. CSS-only -- upgrades the existing bordered section
     cards to the softer rounded/shadowed module-card look, keeps all content
     and JS. Matches the L8 meeting + mockup treatment. */
  #daily-dashboard section.rounded-lg {
    border-radius: 18px !important; border-color: var(--line, #e6e8ec) !important;
    box-shadow: 0 1px 2px rgba(16,24,40,.04), 0 1px 3px rgba(16,24,40,.05);
    padding: 22px 26px !important;
  }
  #daily-dashboard section h2 { color: var(--ink, #14161c) !important; letter-spacing: .04em; }
  /* icon-circle injected into section headers */
  #daily-dashboard .otp-dic-h2 { display: flex; align-items: center; gap: 11px; }
  #daily-dashboard .otp-dic { flex: none; width: 34px; height: 34px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; }
  #daily-dashboard .otp-dic svg { width: 18px; height: 18px; }
  #daily-dashboard .otp-dic-img { flex: none; width: 38px; height: 38px; object-fit: contain; border-radius: 8px; }
  #daily-dashboard .dk-own-seg { display:inline-flex; border:1px solid #e5e7eb; border-radius:7px; overflow:hidden; }
  #daily-dashboard .dk-own-btn { font-size:11px; font-weight:600; padding:2px 9px; background:#fff; color:#6b7280; border:none; border-left:1px solid #e5e7eb; cursor:pointer; line-height:1.5; }
  #daily-dashboard .dk-own-btn:first-child { border-left:none; }
  #daily-dashboard .dk-own-btn.active { background:#2563eb; color:#fff; }
  #daily-dashboard .dk-own-btn:not(.active):hover { background:#f3f4f6; }
  /* Customize mode: tile visibility + drag/hide controls. Plain scoped CSS
     (not Tailwind) so nothing here can be purged. */
  #daily-dashboard .dash-tile-hidden { display: none; }
  #daily-dashboard.dash-edit-mode .dash-tile-hidden { display: block; opacity: .45; }
  #daily-dashboard.dash-edit-mode [data-tile-id] { outline: 2px dashed #c7d2fe; outline-offset: 2px; }
  #daily-dashboard .dash-edit-controls { display:inline-flex; align-items:center; gap:8px; padding:2px 8px; margin:0 0 6px; background:#eef2ff; border:1px solid #c7d2fe; border-radius:8px; font-size:11px; flex:none; }
  #daily-dashboard .dash-drag-handle { cursor:grab; color:#6b7280; user-select:none; -webkit-user-select:none; font-size:14px; line-height:1; }
  #daily-dashboard .dash-hide-toggle { font-weight:600; color:#2563eb; background:none; border:none; cursor:pointer; font-size:11px; padding:0; }
  #daily-dashboard .sortable-ghost { opacity:.35; }
  /* Layout engine: per-row column spans. Scoped CSS (not Tailwind) so the
     classes exist regardless of what the purged build contains -- the built
     v7.css does not reliably include lg:col-span-6 etc. Mirrors Tailwind's
     lg: breakpoint (min-width 1024px); below it every cell is full width. */
  @media (min-width: 1024px) {
    #daily-dashboard .dash-span-4 { grid-column: span 4 / span 4; }
    #daily-dashboard .dash-span-6 { grid-column: span 6 / span 6; }
    #daily-dashboard .dash-span-8 { grid-column: span 8 / span 8; }
    #daily-dashboard .dash-span-12 { grid-column: span 12 / span 12; }
  }
  /* Anti-squish at large zooms (xl/xxl/xxxl): grid/flex children must be
     allowed to shrink (min-width:0) so text wraps instead of overflowing,
     and long unbroken strings break anywhere rather than blowing the cell
     out sideways. Horizontal page scroll at zoom 1.75 on small viewports is
     acceptable; overlapping/clipped content is not. */
  #daily-dashboard [data-dash-cell] { min-width: 0; }
  #daily-dashboard [data-tile-id] { min-width: 0; overflow-wrap: anywhere; }
  /* Edit mode: cells become visible drop targets (an empty cell needs a hit
     area to drag into); per-row toolbar spans the full row. */
  #daily-dashboard.dash-edit-mode [data-dash-cell] { min-height: 64px; outline: 1px dashed #d1d5db; outline-offset: 3px; border-radius: 10px; }
  #daily-dashboard .dash-row-bar { grid-column: 1 / -1; display: flex; align-items: center; gap: 10px; padding: 4px 10px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 11px; color: #475569; }
  #daily-dashboard .dash-row-bar select { font-size: 11px; border: 1px solid #cbd5e1; border-radius: 6px; padding: 1px 4px; background: #fff; color: #334155; }
  #daily-dashboard .dash-row-btn { font-weight: 600; color: #2563eb; background: none; border: none; cursor: pointer; font-size: 11px; padding: 0; }
  #daily-dashboard .dash-row-btn[disabled] { color: #94a3b8; cursor: not-allowed; }
</style>
<div class="w-full px-4 sm:px-6 lg:px-8 py-8<%= (typeof dashClean !== 'undefined' && dashClean) ? ' dash-clean' : '' %>" id="daily-dashboard"
     style="zoom: <%= dashZoom %>"
     data-org-id="<%= locals.org && locals.org.id %>"
     data-meeting-id="<%= selectedMeetingId %>"
     data-is-integrator="<%= isIntegrator ? '1' : '0' %>"
     data-quarter="<%= quarter %>">

  <!-- Header: greeting + org switcher + role -->
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div class="flex items-center gap-3">
      <img src="/public/images/orgy/<%= greeting === 'Good morning' ? 'good-morning' : (greeting === 'Good afternoon' ? 'good-afternoon' : 'good-evening') %>.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="" class="orgy-mascot-wave w-14 sm:w-16 shrink-0" loading="eager" decoding="async">
      <div>
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1"><%= orgName %></div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= greeting %>, <%= firstName %>.</h1>
        <p class="text-sm text-gray-600 mt-1">
          <span class="px-2 py-0.5 rounded bg-orgy-soft text-orgy-on-light text-xs font-semibold uppercase tracking-wide"><%= role %></span>
          <% if (quarter) { %>
            <span class="text-gray-400 ml-2">Quarter <%= quarter %></span>
          <% } %>
        </p>
      </div>
    </div>

    <% if (orgs.length > 1) { %>
      <form method="GET" action="/dashboard" class="text-sm">
        <label class="text-xs text-gray-500 uppercase tracking-wide block mb-1">Organization</label>
        <select name="orgId" onchange="this.form.submit()" class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orgy-blue">
          <% orgs.forEach(function(o){ %>
            <option value="<%= o.id %>" <%= o.id === (locals.org && locals.org.id) ? 'selected' : '' %>><%= o.name %></option>
          <% }); %>
        </select>
      </form>
    <% } %>

    <!-- Customize mode: hide/reorder tiles + font size. Toolbar shows only
         while editing; the button toggles edit mode (script at page bottom). -->
    <div class="flex items-center gap-3 flex-wrap">
      <div id="dash-customize-bar" class="flex items-center gap-3" style="display:none">
        <span class="text-xs text-gray-500 uppercase tracking-wide">Text</span>
        <span class="dk-own-seg" id="dash-font-seg">
          <button type="button" class="dk-own-btn" data-font="sm">S</button>
          <button type="button" class="dk-own-btn" data-font="base">M</button>
          <button type="button" class="dk-own-btn" data-font="lg">L</button>
          <button type="button" class="dk-own-btn" data-font="xl">XL</button>
          <button type="button" class="dk-own-btn" data-font="xxl">2XL</button>
          <button type="button" class="dk-own-btn" data-font="xxxl">3XL</button>
        </span>
        <button type="button" id="dash-reset-btn" class="text-xs text-orgy-blue font-semibold">Reset to default</button>
        <span id="dash-prefs-err" class="text-xs text-rose-600 font-semibold" style="display:none"></span>
      </div>
      <button type="button" id="dash-customize-btn" class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orgy-blue">Customize</button>
    </div>
  </div>

  <!-- MCP status banner -->
  <% if (!mcp.connected) { %>
    <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 p-4">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div class="min-w-0">
          <div class="text-sm font-bold text-amber-900">Connect your MCP key to make this dashboard live</div>
          <p class="text-xs text-amber-800 mt-1">
            OTP is at its best when your agents push KPIs and pull rocks via MCP.
            <% if (mcp.hasKey) { %>You have a key, but it has not been used in 7 days.<% } %>
          </p>
        </div>
        <a href="/settings/api" class="rounded bg-amber-900 text-amber-50 text-xs font-semibold px-3 py-1.5 hover:bg-amber-800">Set up MCP &rarr;</a>
      </div>
    </div>
  <% } else { %>
    <a href="/settings/api" class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2 text-xs text-emerald-900 flex items-center gap-2 hover:bg-emerald-100 hover:border-emerald-300 transition-colors">
      <span class="inline-block w-2 h-2 rounded-full bg-emerald-500"></span>
      <span class="flex-1">MCP live &middot; last seen <%= mcp.lastUsedAt ? new Date(mcp.lastUsedAt).toLocaleString() : 'just now' %></span>
      <span class="text-emerald-700 font-semibold">Manage &rarr;</span>
    </a>
  <% } %>


  <div class="grid grid-cols-1 lg:grid-cols-12 gap-5" data-dash-row data-dash-pattern="4-8"<%- dashRowHide %>>
    <div class="lg:col-span-4 space-y-5" data-dash-cell><!-- LEFT 1/3 -->
  <!-- Meeting selector -->
  <section data-tile-id="meetings" data-tile-col="left" class="mb-8 rounded-lg border border-gray-200 bg-white p-5<%= dashHide('meetings') %>">
    <div class="flex items-center justify-between gap-3 flex-wrap mb-3">
      <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/meeting.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">Meeting <button type="button" class="help-q" data-help="dashboard.meeting" aria-label="About the Meetings panel">?</button></h2>
      <% if (caps.canEditAssignedItems) { %>
        <a href="/l8" class="text-xs text-orgy-blue font-semibold">Open the L8 tool &rarr;</a>
      <% } %>
    </div>
    <% if (meetings.length === 0) { %>
      <p class="text-sm text-gray-600">No meetings yet. <% if (caps.canCreateTeams) { %><a href="/l8" class="text-orgy-blue underline">Create one</a>.<% } %></p>
    <% } else { %>
      <%
        // Clicking a meeting opens the meeting page. Preserve org context for
        // multi-org / dev impersonation (the L8 page reads ?orgId).
        var _mtgQ = (orgs.length > 1) ? ('?orgId=' + encodeURIComponent(locals.org.id)) : '';
      %>
      <div class="space-y-4">
        <div>
          <div class="text-[11px] font-bold uppercase tracking-wide text-orgy-blue mb-1.5">Upcoming</div>
          <% if (upcomingMeetings.length === 0) { %>
            <p class="text-xs text-gray-500">No upcoming meetings. <% if (caps.canCreateTeams) { %><a href="/l8" class="text-orgy-blue underline">Schedule one</a> or set a meeting to repeat.<% } %></p>
          <% } else { %>
            <div class="space-y-1.5">
              <% upcomingMeetings.forEach(function(m){ var sel = (m.id === selectedMeetingId); %>
                <a href="/l8/meeting/<%= m.id %><%= _mtgQ %>" class="block rounded border px-3 py-2 transition-colors <%= sel ? 'border-orgy bg-orgy-tint' : 'border-gray-200 hover:bg-gray-50' %>">
                  <div class="flex items-start justify-between gap-2">
                    <span class="text-sm font-medium text-gray-900 truncate"><%= m.title %></span>
                    <div class="text-right shrink-0">
                      <div class="text-xs text-gray-500 whitespace-nowrap"><%= new Date(m.scheduledAt).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %>, <%= new Date(m.scheduledAt).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></div>
                      <% if (m.status === 'in_progress') { %>
                        <span class="inline-block mt-1 px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-800 text-[10px] font-bold uppercase tracking-wide">Live</span>
                      <% } else if (m.status === 'completed') { %>
                        <span class="inline-block mt-1 px-2 py-0.5 rounded-full bg-orgy-soft text-orgy-on-light text-[10px] font-bold uppercase tracking-wide">Completed<% if (m.ratingAvg != null) { %> &middot; <%= m.ratingAvg.toFixed(1) %><% } %></span>
                      <% } %>
                    </div>
                  </div>
                  <div class="text-xs text-gray-500 mt-0.5">
                    <%= m.meetingType %><% if (m.recurrenceLabel && m.recurrenceLabel !== 'Does not repeat') { %> &middot; <%= m.recurrenceLabel %><% } %>
                  </div>
                </a>
              <% }); %>
            </div>
          <% } %>
        </div>

        <% if (pastMeetings.length > 0) { %>
          <details <%= (upcomingMeetings.length === 0 ? 'open' : '') %>>
            <summary class="text-[11px] font-bold uppercase tracking-wide text-gray-400 mb-1.5 cursor-pointer select-none">Past (<%= pastMeetings.length %>)</summary>
            <div class="space-y-1.5 mt-1.5">
              <% pastMeetings.forEach(function(m){ var sel = (m.id === selectedMeetingId); %>
                <a href="/l8/meeting/<%= m.id %><%= _mtgQ %>" class="block rounded border px-3 py-2 transition-colors <%= sel ? 'border-orgy bg-orgy-tint' : 'border-gray-200 hover:bg-gray-50' %>">
                  <div class="flex items-start justify-between gap-2">
                    <span class="text-sm text-gray-700 truncate"><%= m.title %></span>
                    <div class="text-right shrink-0">
                      <div class="text-xs text-gray-400 whitespace-nowrap"><%= new Date(m.scheduledAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                      <% if (m.status === 'completed') { %>
                        <span class="inline-block mt-1 px-2 py-0.5 rounded-full bg-orgy-soft text-orgy-on-light text-[10px] font-bold uppercase tracking-wide">Completed<% if (m.ratingAvg != null) { %> &middot; <%= m.ratingAvg.toFixed(1) %><% } %></span>
                      <% } else if (m.status === 'cancelled') { %>
                        <span class="inline-block mt-1 px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 text-[10px] font-bold uppercase tracking-wide">Cancelled</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="text-xs text-gray-400 mt-0.5">
                    <%= m.meetingType %>
                  </div>
                </a>
              <% }); %>
            </div>
          </details>
        <% } %>
      </div>
    <% } %>
    <% if ((orgTeams || []).length > 0) { %>
      <% var _tq = selectedTeamId ? ('&teamId=' + selectedTeamId) : ''; %>
      <div class="mt-3 flex flex-wrap items-end gap-4">
        <div>
          <label class="text-xs text-gray-500 uppercase tracking-wide block mb-1">Show</label>
          <div class="inline-flex rounded-lg border border-gray-300 overflow-hidden text-sm">
            <a href="/dashboard?scope=all<%= _tq %>" class="px-3 py-1.5 font-medium <%= !scopeMine ? 'bg-orgy-blue text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">All on my teams</a>
            <a href="/dashboard?scope=mine<%= _tq %>" class="px-3 py-1.5 font-medium border-l border-gray-300 <%= scopeMine ? 'bg-orgy-blue text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">Just mine</a>
          </div>
        </div>
        <form method="GET" action="/dashboard" class="text-sm">
          <% if (orgs.length > 1) { %><input type="hidden" name="orgId" value="<%= locals.org.id %>"><% } %>
          <% if (scopeMine) { %><input type="hidden" name="scope" value="mine"><% } %>
          <label class="text-xs text-gray-500 uppercase tracking-wide block mb-1">Team</label>
          <select name="teamId" onchange="this.form.submit()" class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orgy-blue">
            <option value="" <%= selectedTeamId === '' ? 'selected' : '' %>>All teams</option>
            <% (orgTeams || []).forEach(function(t){ %>
              <option value="<%= t.id %>" <%= t.id === selectedTeamId ? 'selected' : '' %>><%= t.name %></option>
            <% }); %>
          </select>
        </form>
      </div>
    <% } %>
  </section>

      <!-- Headlines: collapsed by default (reference, captured in the meeting).
           Auto-opens when there are unread headlines so nothing is buried. -->
      <details data-tile-id="headlines" data-tile-col="left" class="rounded-lg border border-gray-200 bg-white<%= dashHide('headlines') %>" open>
        <summary class="cursor-pointer select-none px-5 py-3 flex items-center justify-between hover:bg-gray-50 transition rounded-lg">
          <span class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2">
            <img class="otp-dic-img" src="/public/images/orgy/headlines.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">
            Headlines
            <button type="button" class="help-q" data-help="dashboard.headlines" aria-label="About Headlines">?</button>
            <% if (headlines.filter(function(h){return !h.readAt;}).length > 0) { %>
              <span class="ml-2 inline-block px-2 py-0.5 rounded-full bg-orgy-soft text-orgy-blue text-[10px] font-bold"><%= headlines.filter(function(h){return !h.readAt;}).length %> unread</span>
            <% } %>
          </span>
          <% if (isIntegrator) { %>
            <span class="text-[10px] uppercase tracking-wide text-orgy-blue bg-orgy-tint rounded px-1.5 py-0.5">Integrator</span>
          <% } %>
        </summary>
        <div class="px-5 pb-5">

        <% if (selectedMeetingId) { %>
          <%
            var headlineTeamName = '';
            if (selectedTeamId) {
              for (var ti = 0; ti < (orgTeams || []).length; ti++) {
                if (orgTeams[ti].id === selectedTeamId) { headlineTeamName = orgTeams[ti].name; break; }
              }
            }
          %>
          <form id="headline-form" class="mb-3 space-y-2" data-meeting-id="<%= selectedMeetingId %>">
            <div class="flex gap-2">
              <select name="kind" class="rounded border border-gray-300 bg-white px-2 py-1 text-xs">
                <option value="customer">Customer</option>
                <option value="employee">Employee</option>
                <option value="other" selected>Other</option>
              </select>
              <input type="text" name="body" required maxlength="2000" placeholder="One headline..." class="flex-1 rounded border border-gray-300 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orgy-blue">
              <button type="submit" class="rounded bg-orgy-blue text-white text-xs font-semibold px-3 py-1.5 hover:bg-orgy-blue-deep">Add</button>
            </div>
            <% if ((orgTeams || []).length > 0) { %>
            <label class="block text-[11px] font-semibold text-gray-500">Team <span class="font-normal text-gray-400">&middot; shows on this team's meeting</span></label>
            <select name="teamId" class="w-full rounded border border-gray-300 px-2 py-1.5 text-sm">
              <% (orgTeams || []).forEach(function(tm){ %>
                <option value="<%= tm.id %>" <%= tm.id === selectedTeamId ? 'selected' : '' %>><%= tm.name %></option>
              <% }); %>
            </select>
            <% } %>
          </form>
        <% } %>

        <% if (headlines.length === 0) { %>
          <p class="text-xs text-gray-500">No headlines yet for this meeting.</p>
        <% } else { %>
          <ul class="space-y-2">
            <% headlines.forEach(function(h){ %>
              <li class="flex items-start gap-2 text-sm rounded border border-gray-100 bg-gray-50/60 px-3 py-2" data-headline-id="<%= h.id %>">
                <input type="checkbox" class="headline-read-cb mt-1" <%= h.readAt ? 'checked' : '' %> <%= isIntegrator ? '' : 'disabled' %>>
                <div class="flex-1 min-w-0">
                  <div class="headline-body <%= h.readAt ? 'line-through text-gray-500' : 'text-gray-900' %>"><%= h.body %></div>
                  <% if (isIntegrator) { %>
                  <form class="headline-edit-form hidden mt-1 flex gap-1.5">
                    <input type="text" class="headline-edit-input flex-1 rounded border border-gray-300 px-2 py-1 text-xs" maxlength="2000" value="<%= h.body %>">
                    <button type="submit" class="text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Save</button>
                    <button type="button" class="headline-edit-cancel text-[11px] text-gray-500 font-semibold px-1">Cancel</button>
                  </form>
                  <% } %>
                  <div class="text-[11px] text-gray-500 mt-0.5">
                    <span class="uppercase tracking-wide"><%= h.kind %></span><%- teamTag(h.teamId) %>
                    &middot; <%= h.authorName || h.authorUserId %>
                    <%= h.readAt ? ' &middot; read ' + new Date(h.readAt).toLocaleString() : '' %>
                    <% if (isIntegrator) { %><button type="button" class="headline-edit-btn ml-2 text-orgy-blue font-semibold hover:underline">edit</button><select class="hl-team ml-1 rounded border border-gray-300 px-1 py-0.5 text-[10px]" title="Move to team"><option value="">&mdash; team &mdash;</option><% orgTeams.forEach(function(_t){ %><option value="<%= _t.id %>" <%= _t.id === h.teamId ? 'selected' : '' %>><%= _t.name %></option><% }); %></select><button type="button" class="hl-delete ml-1 text-rose-600 font-semibold hover:underline">delete</button><% } %>
                  </div>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
        </div>
      </details>


      <!-- My Rocks: collapsed by default. Quarterly priorities are weekly
           reference; each rock carries its own inline Next Action row.
           Count + off-track flag show in the summary. -->
      <%
        var _rocksOpen = myRocks.filter(function(r){ return !r.onTrack && !r.completedAt; }).length;
      %>
      <details data-tile-id="rocks" data-tile-col="left" class="rounded-lg border border-gray-200 bg-white<%= dashHide('rocks') %>" open>
        <summary class="cursor-pointer select-none px-5 py-3 flex items-center justify-between hover:bg-gray-50 transition rounded-lg">
          <span class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/quarterly-priorities.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">Quarterly Priorities
            <button type="button" class="help-q" data-help="dashboard.rocks" aria-label="About Quarterly Priorities">?</button>
            <% if (quarter) { %><span class="text-gray-400 font-normal text-[10px]"><%= quarter %></span><% } %>
            <% if (myRocks.length > 0) { %><span class="ml-1 text-gray-400 font-normal text-[11px]">(<%= myRocks.length %>)</span><% } %>
            <% if (_rocksOpen > 0) { %><span class="ml-1 inline-block px-2 py-0.5 rounded-full bg-rose-50 text-rose-700 text-[10px] font-bold border border-rose-200"><%= _rocksOpen %> off track</span><% } %>
          </span>
          <% if (isIntegrator) { %>
          <button type="button" id="rocks-build-smart" class="ml-2 shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-md border border-gray-300 text-gray-500 hover:text-orgy-blue hover:border-orgy-blue transition text-base font-bold leading-none" title="Build a SMART quarterly priority" aria-label="Build a SMART quarterly priority">+</button>
          <% } %>
        </summary>
        <div class="px-5 pb-5">
        <% if (myRocks.length === 0) { %>
          <p class="text-xs text-gray-500">No rocks claimed for this quarter.</p>
        <% } else { %>
          <ul class="space-y-2">
            <% myRocks.forEach(function(r){
                 var due = r.dueDate ? new Date(r.dueDate) : null;
                 var overdue = due && !r.completedAt && due < new Date();
            %>
              <% // Card accent follows the track status so it matches the On/Off
                 // Track badge: green = on track, red = off track. (Was keyed to
                 // "missing next action", which painted on-track rocks red and
                 // clashed with their green badge.) The "+ Set Next Action"
                 // button below remains the next-action nudge. %>
              <% var rkAccent = r.completedAt ? 'border-gray-100 bg-gray-50/60'
                   : (r.onTrack ? 'border-emerald-200 border-l-4 border-l-emerald-400 bg-emerald-50/30'
                                : 'border-rose-200 border-l-4 border-l-rose-500 bg-rose-50/30'); %>
              <% // Milestones for this rock (server-fetched; rockMilestones is a
                 // map keyed by rock id). _msToday is a local YYYY-MM-DD string so
                 // the overdue compare is plain string < string, no TZ math.
                 var _msList = (locals.rockMilestones && locals.rockMilestones[r.id]) || [];
                 var _msDone = _msList.filter(function(m){ return m.completedAt; }).length;
                 var _msToday = (function(){ var d = new Date(); return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); })(); %>
              <li class="rounded border <%= rkAccent %> px-3 py-2 text-sm" data-rock-id="<%= r.id %>" data-entity-kind="rock">
                <div class="flex items-start gap-3">
                  <button class="rock-track-toggle text-[11px] font-semibold uppercase rounded px-2 py-0.5 <%= r.onTrack ? 'bg-status-ontrack-soft text-status-ontrack' : 'bg-status-offtrack-soft text-status-offtrack' %>" data-on-track="<%= r.onTrack ? '1' : '0' %>">
                    <%= r.onTrack ? 'On track' : 'Off track' %>
                  </button>
                  <div class="flex-1 min-w-0">
                    <% var _hasSmart = (function(){ var s = r.smartData; if (!s || typeof s !== 'object') return false; if (s.specific||s.measurable||s.attainable||s.relevant||s.timeFramed||s.finishLine) return true; if (Array.isArray(s.resources) && s.resources.some(function(x){return x&&x.trim();})) return true; if (Array.isArray(s.obstacles) && s.obstacles.some(function(x){return x&&x.trim();})) return true; return false; })(); %>
                    <div class="font-semibold text-gray-900"><%= r.title %><% if (_msList.length > 0) { %> <span class="ms-chip ml-1 align-middle inline-block px-1.5 py-0.5 rounded-full text-[10px] font-bold border <%= _msDone === _msList.length ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-gray-100 text-gray-500 border-gray-200' %>" title="Milestones complete"><%= _msDone %>/<%= _msList.length %></span><% } %><% if (_hasSmart) { %> <a href="/rocks/<%= r.id %>/smart" class="ml-1 align-middle inline-block px-1.5 py-0.5 rounded-full text-[10px] font-bold border bg-orgy-soft text-orgy-on-light border-orgy-line hover:underline" title="This Rock has a SMART plan">SMART</a><% } %></div>
                    <div class="text-[11px] text-gray-500 mt-0.5">
                      <%= due ? 'Due ' + due.toLocaleDateString() : 'No due date' %>
                      <%= overdue ? ' -- OVERDUE' : '' %>
                      <%= r.completedAt ? ' -- Done' : '' %><%- teamTag(r.teamId) %>
                    </div>
                    <% if (isIntegrator) { %>
                    <div class="rk-mng">
                      <button type="button" class="rk-toggle text-[10px] text-gray-400 hover:text-gray-700 font-semibold mt-1">&middot;&middot;&middot; manage</button>
                      <div class="rk-strip hidden mt-2 pt-2 border-t border-gray-100 flex flex-wrap items-center gap-2 text-[11px]">
                        <select class="rk-team rounded border border-gray-300 px-1.5 py-1" title="Move to team"><option value="">&mdash; no team &mdash;</option><% orgTeams.forEach(function(_t){ %><option value="<%= _t.id %>" <%= _t.id === r.teamId ? 'selected' : '' %>><%= _t.name %></option><% }); %></select>
                        <select class="rk-owner rounded border border-gray-300 px-1.5 py-1" title="Reassign owner"><option value="">&mdash; owner &mdash;</option><% (locals.assignablePeople||[]).forEach(function(p){ %><option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>" <%= p.externalId === r.ownerExternalId ? 'selected' : '' %>><%= p.name %></option><% }); %></select>
                        <button type="button" class="rk-edit text-orgy-blue font-semibold hover:underline">edit</button>
                        <button type="button" class="rk-delete text-rose-600 font-semibold hover:underline ml-auto">delete</button>
                      </div>
                      <form class="rk-edit-form hidden mt-1 flex gap-1.5"><input type="text" class="rk-edit-input flex-1 rounded border border-gray-300 px-2 py-1 text-xs" value="<%= r.title %>"><button type="submit" class="text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Save</button><button type="button" class="rk-edit-cancel text-[11px] text-gray-500 font-semibold px-1">Cancel</button></form>
                    </div>
                    <% } %>
                    <% if (r.statusNote) { %>
                      <p class="text-xs text-gray-600 mt-1"><%= r.statusNote %></p>
                    <% } %>
                    <!-- Next Action row: GTD discipline. The Rock title is the
                         destination; this is the literal next move. -->
                    <div class="next-action mt-2 text-xs" data-na-id="<%= r.id %>" data-na-kind="rock">
                      <% if (r.nextAction) { %>
                        <div class="na-view flex items-start gap-1.5 text-gray-700">
                          <span class="text-orgy-on-light shrink-0">👉</span>
                          <span class="na-text flex-1 break-words"><%= r.nextAction %></span>
                          <button type="button" class="na-edit text-[10px] text-orgy-blue font-semibold hover:underline shrink-0">edit</button>
                          <button type="button" class="na-done text-[10px] text-emerald-700 font-semibold hover:underline shrink-0">done</button>
                        </div>
                      <% } else if (!r.completedAt) { %>
                        <button type="button" class="na-edit text-[11px] text-rose-700 font-semibold hover:underline">+ Set Next Action</button>
                      <% } %>
                      <form class="na-edit-form hidden mt-1 flex gap-1.5">
                        <input type="text" class="na-input flex-1 rounded border border-gray-300 px-2 py-1 text-xs" placeholder="One concrete physical step..." maxlength="500" value="<%= r.nextAction || '' %>">
                        <button type="submit" class="na-save text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Save</button>
                        <button type="button" class="na-cancel text-[11px] text-gray-500 font-semibold px-1">Cancel</button>
                      </form>
                    </div>
                    <!-- SMART planner: dedicated printable page enriching this rock. -->
                    <div class="mt-1.5">
                      <a href="/rocks/<%= r.id %>/smart" class="text-[11px] text-orgy-blue font-semibold hover:underline"><%= _hasSmart ? 'SMART planner' : '+ Build SMART' %></a>
                    </div>
                    <!-- Milestones: expandable per-rock list. Checkbox toggles
                         complete (optimistic, via /api/v1/milestones/:id/complete);
                         each milestone can carry assigned to-dos (+ to-do). -->
                    <details class="ms-block mt-2" data-ms-rock="<%= r.id %>"<%= _msList.length > 0 && _msDone < _msList.length ? ' open' : '' %>>
                      <summary class="cursor-pointer select-none text-[11px] font-semibold text-gray-500 hover:text-gray-700">
                        Milestones<% if (_msList.length > 0) { %> <span class="ms-chip text-gray-400 font-normal"><%= _msDone %>/<%= _msList.length %></span><% } %>
                      </summary>
                      <% if (_msList.length > 0) { %>
                      <ul class="ms-list mt-1.5 space-y-1">
                        <% _msList.forEach(function(m){
                             var _msDue = m.dueDate ? String(m.dueDate).slice(0, 10) : '';
                             var _msOver = _msDue && !m.completedAt && _msDue < _msToday; %>
                          <li class="text-xs" data-ms-id="<%= m.id %>">
                            <div class="flex items-start gap-1.5">
                              <input type="checkbox" class="ms-check mt-0.5 accent-emerald-600" <%= m.completedAt ? 'checked' : '' %> title="Mark milestone complete">
                              <span class="ms-title flex-1 break-words <%= m.completedAt ? 'line-through text-gray-400' : 'text-gray-800' %>"><%= m.title %></span>
                              <% if (_msDue) { %><span class="ms-due shrink-0 text-[10px] <%= _msOver ? 'text-rose-600 font-semibold' : 'text-gray-400' %>"><%= _msDue %></span><% } %>
                              <button type="button" class="ms-todo-toggle text-[10px] text-orgy-blue font-semibold hover:underline shrink-0">+ to-do</button>
                              <button type="button" class="ms-del text-[10px] text-gray-300 hover:text-rose-600 font-bold shrink-0" title="Delete milestone (its to-dos survive)">&times;</button>
                            </div>
                            <% (m.todos || []).forEach(function(mt){ %>
                              <div class="ml-5 mt-0.5 text-[11px] text-gray-500 flex items-baseline gap-1">
                                <span class="shrink-0"><%= mt.doneAt ? '☑' : '☐' %></span>
                                <span class="break-words <%= mt.doneAt ? 'line-through text-gray-400' : '' %>"><%= mt.title %></span>
                                <% if (mt.ownerName || mt.ownerExternalId) { %><span class="text-gray-400 shrink-0">&mdash; <%= mt.ownerName || mt.ownerExternalId %></span><% } %>
                              </div>
                            <% }); %>
                            <form class="ms-todo-form hidden ml-5 mt-1 flex flex-wrap gap-1.5 items-center">
                              <input type="text" name="title" required maxlength="500" placeholder="To-do for this milestone" class="flex-1 min-w-[140px] rounded border border-gray-300 px-2 py-1 text-xs">
                              <select name="owner" class="rounded border border-gray-300 px-1.5 py-1 text-xs" title="Assign to">
                                <option value="">Me</option>
                                <% (locals.assignablePeople || []).forEach(function(p){ %>
                                  <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>"><%= p.name %></option>
                                <% }); %>
                              </select>
                              <button type="submit" class="text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Add</button>
                              <button type="button" class="ms-todo-cancel text-[11px] text-gray-500 font-semibold px-1">Cancel</button>
                            </form>
                          </li>
                        <% }); %>
                      </ul>
                      <% } %>
                      <form class="ms-add-form mt-1.5 flex flex-wrap gap-1.5 items-center">
                        <input type="text" name="title" required maxlength="255" placeholder="+ milestone" class="flex-1 min-w-[120px] rounded border border-gray-300 px-2 py-1 text-xs">
                        <input type="date" name="dueDate" class="rounded border border-gray-300 px-1.5 py-1 text-xs" title="Milestone due date (optional)">
                        <button type="submit" class="text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Add</button>
                      </form>
                    </details>
                    <div data-att-host data-att-type="rock" data-att-id="<%= r.id %>"></div>
                  </div>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
        </div>
      </details>


    </div><!-- /left -->
    <div class="lg:col-span-8 space-y-5" data-dash-cell><!-- RIGHT 2/3 -->
      <!-- My To-Dos -->
      <section data-tile-id="todos" data-tile-col="right" class="rounded-lg border border-gray-200 bg-white p-5<%= dashHide('todos') %>">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/todos.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">My To-Dos <button type="button" class="help-q" data-help="dashboard.todos" aria-label="About My To-Dos">?</button></h2>
          <button id="todo-add-toggle" class="text-xs text-orgy-blue font-semibold">+ Add</button>
        </div>
        <form id="todo-add-form" class="hidden mb-3 space-y-2">
          <input type="text" name="title" required maxlength="500" placeholder="What to do" class="w-full rounded border border-gray-300 px-2 py-1.5 text-sm">
          <%- include('../partials/rich-description-editor', { targetId: 'todo-add-desc' }) %>
          <textarea id="todo-add-desc" name="description" rows="2" placeholder="Description (optional). Markdown: **bold**, *italic*, [link](https://...)" class="w-full rounded border border-gray-300 px-2 py-1 text-xs"></textarea>
          <div class="flex items-center gap-2 text-xs">
            <button type="button" id="todo-add-attach" class="text-orgy-blue font-semibold">&#128206; Attach file</button>
            <span id="todo-add-files-label" class="text-gray-500"></span>
            <input type="file" id="todo-add-files" multiple class="hidden">
          </div>
          <div class="flex gap-3 flex-wrap">
            <div class="flex flex-col gap-0.5">
              <label for="todo-delegate-to" class="text-[10px] uppercase tracking-wide text-gray-500">Delegate to</label>
              <select id="todo-delegate-to" class="rounded border border-gray-300 px-2 py-1 text-xs">
                <option value="">Just me (personal)</option>
                <% (locals.assignablePeople || []).forEach(function(p){ %>
                  <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>"><%= p.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="flex flex-col gap-0.5">
              <label for="todo-date-input" id="todo-date-label" class="text-[10px] uppercase tracking-wide text-gray-500">Due date</label>
              <input type="date" id="todo-date-input" name="dueAt" class="rounded border border-gray-300 px-2 py-1 text-xs">
            </div>
            <div class="flex flex-col gap-0.5">
              <label for="todo-recur-input" class="text-[10px] uppercase tracking-wide text-gray-500">Repeats</label>
              <select id="todo-recur-input" name="recurrence" class="rounded border border-gray-300 px-2 py-1 text-xs">
                <option value="none" selected>Does not repeat</option>
                <option value="daily">Daily</option>
                <option value="weekdays">Weekdays (Mon–Fri)</option>
                <option value="weekly">Weekly</option>
                <option value="biweekly">Every 2 weeks</option>
                <option value="monthly">Monthly</option>
                <option value="yearly">Yearly</option>
              </select>
            </div>
            <% if ((orgTeams || []).length > 0) { %>
              <div class="flex flex-col gap-0.5">
                <label for="todo-team-select" class="text-[10px] uppercase tracking-wide text-gray-500">Team</label>
                <select id="todo-team-select" class="rounded border border-gray-300 px-2 py-1 text-xs">
                  <option value="" <%= selectedTeamId === '' ? 'selected' : '' %>>Personal (no team)</option>
                  <% (orgTeams || []).forEach(function(t){ %>
                    <option value="<%= t.id %>" <%= t.id === selectedTeamId ? 'selected' : '' %>><%= t.name %></option>
                  <% }); %>
                </select>
              </div>
            <% } %>
          </div>
          <div class="flex gap-2">
            <button type="submit" class="rounded bg-orgy-blue text-white text-xs font-semibold px-3 py-1 hover:bg-orgy-blue-deep">Save</button>
          </div>
        </form>
        <% var delegatedVerifyList = locals.delegatedVerify || []; %>
        <% if (delegatedVerifyList.length > 0) { %>
          <div class="mb-4 rounded-lg bg-amber-50 border border-amber-300 p-3">
            <div class="text-[11px] uppercase tracking-wide font-bold text-amber-800 mb-2">
              &#9888; Verify these happened <span class="text-amber-600 font-semibold">(<%= delegatedVerifyList.length %>)</span>
            </div>
            <ul class="space-y-1.5">
              <% delegatedVerifyList.forEach(function(t){ %>
                <li class="flex items-start gap-2 text-sm rounded border border-amber-200 bg-white px-3 py-2" data-verify-row-id="<%= t.id %>">
                  <div class="flex-1 min-w-0">
                    <div class="text-gray-900 break-words"><%= t.title %></div>
                    <div class="text-[11px] text-gray-500 mt-0.5"><%= t.ownerName %> marked done</div>
                  </div>
                  <div class="flex items-center gap-1.5 shrink-0">
                    <button type="button" class="rounded bg-emerald-600 text-white text-[11px] font-semibold px-2 py-0.5 hover:bg-emerald-700" data-verify-id="<%= t.id %>">Verify</button>
                    <button type="button" class="rounded bg-gray-100 text-gray-700 text-[11px] font-semibold px-2 py-0.5 hover:bg-gray-200" data-reopen-id="<%= t.id %>">Reopen</button>
                  </div>
                </li>
              <% }); %>
            </ul>
          </div>
        <% } %>
        <% if (myTodos.length === 0) { %>
          <p class="text-xs text-gray-500">No open to-dos. Nice.</p>
        <% } else {
          // Bucket todos into Overdue / Today / Upcoming / No date.
          // No-date items get their own collapsible bucket so they don't get
          // hidden at the bottom of Upcoming — David flagged 2026-05-25 that
          // they need the same "open me when I want them" affordance.
          var nowD = new Date();
          var todayStart = new Date(nowD.getFullYear(), nowD.getMonth(), nowD.getDate());
          var tomorrowStart = new Date(todayStart); tomorrowStart.setDate(tomorrowStart.getDate() + 1);
          var overdueT = [], todayT = [], upcomingT = [], noDateT = [];
          myTodos.forEach(function(t){
            var due = t.dueAt ? new Date(t.dueAt) : null;
            if (!due)                                              noDateT.push(t);
            else if (!t.doneAt && due < todayStart)                overdueT.push(t);
            else if (due >= todayStart && due < tomorrowStart)     todayT.push(t);
            else                                                   upcomingT.push(t);
          });
          // Sort: overdue oldest-first, today/upcoming earliest-first, no-date by created/title.
          overdueT.sort(function(a,b){ return new Date(a.dueAt) - new Date(b.dueAt); });
          todayT.sort(function(a,b){ return new Date(a.dueAt) - new Date(b.dueAt); });
          upcomingT.sort(function(a,b){ return new Date(a.dueAt) - new Date(b.dueAt); });
          noDateT.sort(function(a,b){ return (a.title || '').localeCompare(b.title || ''); });
          // Map an iCalendar RRULE to one of our preset choices so the edit
          // form can pre-select it and the view row can show a friendly
          // cadence label. Unknown/exotic rules fall through to 'custom'
          // which the form preserves on save.
          function recurrencePreset(rule) {
            if (!rule) return { key: 'none', label: null };
            // Normalize: uppercase, strip whitespace, sort the part list AND
            // the comma-separated values inside each part (so MO,TU,WE,TH,FR
            // matches FR,MO,TH,TU,WE for the Weekdays preset).
            var parts = String(rule).toUpperCase().replace(/\s+/g,'').split(';').filter(Boolean)
              .map(function(p){
                var eq = p.indexOf('=');
                if (eq < 0) return p;
                var k = p.slice(0, eq);
                var v = p.slice(eq + 1).split(',').sort().join(',');
                return k + '=' + v;
              })
              .sort();
            var norm = parts.join(';');
            if (norm === 'FREQ=DAILY')                                return { key: 'daily',    label: 'Daily' };
            if (norm === 'BYDAY=FR,MO,TH,TU,WE;FREQ=WEEKLY')          return { key: 'weekdays', label: 'Weekdays' };
            if (norm === 'FREQ=WEEKLY')                               return { key: 'weekly',   label: 'Weekly' };
            if (norm === 'FREQ=WEEKLY;INTERVAL=2')                    return { key: 'biweekly', label: 'Every 2 weeks' };
            if (norm === 'FREQ=MONTHLY')                              return { key: 'monthly',  label: 'Monthly' };
            if (norm === 'FREQ=YEARLY')                               return { key: 'yearly',   label: 'Yearly' };
            return { key: 'custom', label: 'Custom' };
          }
          var sections = [
            { id: 'overdue',  name: 'Overdue',  items: overdueT,  color: 'text-rose-600', alwaysShow: false, collapsible: true,  defaultOpen: false },
            { id: 'today',    name: 'Today',    items: todayT,    color: 'text-gray-700', alwaysShow: true,  collapsible: false, defaultOpen: true  },
            { id: 'upcoming', name: 'Upcoming', items: upcomingT, color: 'text-gray-600', alwaysShow: false, collapsible: true,  defaultOpen: false },
            { id: 'no-date',  name: 'No due date', items: noDateT, color: 'text-gray-500', alwaysShow: false, collapsible: true,  defaultOpen: false }
          ];
        %>
          <% sections.forEach(function(section){
               if (!section.alwaysShow && section.items.length === 0) return; %>
            <% if (section.collapsible) { %>
            <details class="mt-3 first:mt-0 group" data-todo-bucket="<%= section.id %>" <%= section.defaultOpen ? 'open' : '' %>>
              <summary class="text-[11px] uppercase tracking-wide font-bold <%= section.color %> mb-1.5 cursor-pointer select-none list-none flex items-center gap-1 hover:opacity-80">
                <span class="inline-block transition-transform group-open:rotate-90 text-gray-400">▸</span>
                <%= section.name %> <span class="text-gray-400 font-semibold">(<%= section.items.length %>)</span>
              </summary>
            <% } else { %>
            <div class="text-[11px] uppercase tracking-wide font-bold <%= section.color %> mt-3 mb-1.5 first:mt-0">
              <%= section.name %> <span class="text-gray-400 font-semibold">(<%= section.items.length %>)</span>
            </div>
            <% } %>
            <% if (section.items.length === 0) { %>
              <p class="text-xs text-gray-400 italic ml-1">Nothing for today.</p>
            <% } else { %>
              <ul class="space-y-1">
                <% section.items.forEach(function(t){
                     var due = t.dueAt ? new Date(t.dueAt) : null;
                     var overdue = due && !t.doneAt && due < new Date();
                %>
                  <li class="flex items-start gap-2 text-sm rounded border border-gray-100 bg-gray-50/60 px-3 py-2" data-todo-id="<%= t.id %>">
                    <input type="checkbox" class="todo-done-cb mt-1" <%= t.doneAt ? 'checked' : '' %>>
                    <% // Priority dot color
                       var prioColor = t.priority === 'p1' ? 'bg-rose-500'
                                     : t.priority === 'p2' ? 'bg-amber-500'
                                     : t.priority === 'p3' ? 'bg-gray-400'
                                     : 'bg-gray-300';
                       // Source label
                       var sourceLabel, sourceClass;
                       if (t.kind === 'l10' && t.meetingTitle) {
                         sourceLabel = 'From ' + t.meetingTitle;
                         sourceClass = 'bg-indigo-50 text-indigo-700';
                       } else if (t.kind === 'l10' && t.teamName) {
                         sourceLabel = t.teamName + ' L10';
                         sourceClass = 'bg-indigo-50 text-indigo-700';
                       } else if (t.kind === 'l10') {
                         sourceLabel = 'L10';
                         sourceClass = 'bg-indigo-50 text-indigo-700';
                       } else {
                         sourceLabel = 'Personal';
                         sourceClass = 'bg-gray-100 text-gray-600';
                       }
                    %>
                    <span class="inline-block w-2 h-2 rounded-full mt-2 <%= prioColor %>" title="priority <%= t.priority || 'p3' %>"></span>
                    <div class="flex-1 min-w-0">
                      <div class="todo-view">
                        <div class="<%= t.doneAt ? 'line-through text-gray-500' : 'text-gray-900' %> break-words"><%= t.title %></div>
                        <% if (t.description) { %>
                          <div class="text-xs text-gray-600 mt-1 break-words"><%- renderDescription(t.description) %></div>
                        <% } %>
                        <div class="text-[11px] flex items-center gap-2 mt-1 flex-wrap">
                          <span class="td-chip px-1.5 py-0.5 rounded font-medium <%= sourceClass %>"><%= sourceLabel %></span>
                          <% var rp = recurrencePreset(t.recurrenceRule); %>
                          <% if (t.recurrenceParentId) { %>
                            <span class="td-chip td-chip-recur px-1.5 py-0.5 rounded bg-violet-50 text-violet-700 font-medium" title="Spawned from a recurring template">↻ from template</span>
                          <% } else if (rp.key !== 'none') { %>
                            <span class="td-chip td-chip-recur px-1.5 py-0.5 rounded bg-violet-50 text-violet-700 font-medium" title="Repeats: <%= t.recurrenceRule %>">↻ <%= rp.label %></span>
                          <% } %>
                          <span class="td-due <%= overdue ? 'td-overdue text-rose-600 font-semibold' : 'text-gray-500' %>"><%= due ? (overdue ? 'OVERDUE — ' : 'Due ') + due.toLocaleDateString() : 'No due date' %></span>
                          <button type="button" class="todo-edit-btn text-orgy-blue font-semibold hover:underline">Edit</button>
                          <button type="button" class="todo-delete-btn text-rose-600 font-semibold hover:underline">Delete</button>
                        </div>
                        <% if ((t.dueAtHistory || []).length > 0) { %>
                          <div class="mt-1 space-y-0.5">
                            <% (t.dueAtHistory || []).forEach(function(h){ %>
                              <div class="text-xs text-gray-500">📅 date changed: <%= h.from ? new Date(h.from).toLocaleDateString() : 'none' %> → <%= h.to ? new Date(h.to).toLocaleDateString() : 'none' %><%= h.at ? ' (' + new Date(h.at).toLocaleDateString() + ')' : '' %></div>
                            <% }); %>
                          </div>
                        <% } %>
                        <div data-att-host data-att-type="todo" data-att-id="<%= t.id %>"></div>
                      </div>
                      <form class="todo-edit hidden space-y-1.5">
                        <input type="text" name="title" required maxlength="500" value="<%= t.title %>" class="w-full rounded border border-gray-300 px-2 py-1 text-sm">
                        <%- include('../partials/rich-description-editor', { targetId: 'desc-edit-' + t.id }) %>
                        <textarea id="desc-edit-<%= t.id %>" name="description" rows="2" placeholder="Description (optional). Markdown: **bold**, *italic*, [link](https://...)" class="w-full rounded border border-gray-300 px-2 py-1 text-xs"><%= t.description || '' %></textarea>
                        <div class="flex gap-3 flex-wrap">
                          <div class="flex flex-col gap-0.5">
                            <label class="text-[10px] uppercase tracking-wide text-gray-500">Due date</label>
                            <input type="date" name="dueAt" value="<%= t.dueAt ? new Date(t.dueAt).toISOString().slice(0,10) : '' %>" class="rounded border border-gray-300 px-2 py-1 text-xs">
                          </div>
                          <div class="flex flex-col gap-0.5">
                            <label class="text-[10px] uppercase tracking-wide text-gray-500">Team</label>
                            <select name="todoTeam" class="rounded border border-gray-300 px-2 py-1 text-xs"><option value="">Personal (no team)</option><% orgTeams.forEach(function(_t){ %><option value="<%= _t.id %>" <%= _t.id === t.teamId ? 'selected' : '' %>><%= _t.name %></option><% }); %></select>
                          </div>
                          <% if (!t.recurrenceParentId) { %>
                            <div class="flex flex-col gap-0.5">
                              <label class="text-[10px] uppercase tracking-wide text-gray-500">Repeats</label>
                              <select name="recurrence" class="rounded border border-gray-300 px-2 py-1 text-xs">
                                <option value="none"     <%= rp.key === 'none'     ? 'selected' : '' %>>Does not repeat</option>
                                <option value="daily"    <%= rp.key === 'daily'    ? 'selected' : '' %>>Daily</option>
                                <option value="weekdays" <%= rp.key === 'weekdays' ? 'selected' : '' %>>Weekdays (Mon–Fri)</option>
                                <option value="weekly"   <%= rp.key === 'weekly'   ? 'selected' : '' %>>Weekly</option>
                                <option value="biweekly" <%= rp.key === 'biweekly' ? 'selected' : '' %>>Every 2 weeks</option>
                                <option value="monthly"  <%= rp.key === 'monthly'  ? 'selected' : '' %>>Monthly</option>
                                <option value="yearly"   <%= rp.key === 'yearly'   ? 'selected' : '' %>>Yearly</option>
                                <% if (rp.key === 'custom') { %>
                                  <option value="custom" selected>Custom (keep as-is)</option>
                                <% } %>
                              </select>
                            </div>
                          <% } %>
                          <div class="flex flex-col gap-0.5">
                            <label class="text-[10px] uppercase tracking-wide text-gray-500">Reassign to</label>
                            <select name="reassignTo" class="rounded border border-gray-300 px-2 py-1 text-xs">
                              <option value="">Keep with me</option>
                              <% (locals.assignablePeople || []).forEach(function(p){ %>
                                <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>"><%= p.name %></option>
                              <% }); %>
                            </select>
                          </div>
                        </div>
                        <div class="flex gap-2 items-center">
                          <button type="button" class="todo-edit-cancel text-xs text-gray-500 font-semibold hover:underline">Cancel</button>
                          <button type="submit" class="rounded bg-orgy-blue text-white text-xs font-semibold px-3 py-1 hover:bg-orgy-blue-deep ml-auto">Save</button>
                        </div>
                      </form>
                    </div>
                  </li>
                <% }); %>
              </ul>
            <% } %>
            <% if (section.collapsible) { %></details><% } %>
          <% }); %>
        <% } %>
      </section>


      <!-- My KPIs -->
      <section id="daily-my-kpis" data-tile-id="kpis" data-tile-col="right" class="rounded-lg border border-gray-200 bg-white p-5<%= dashHide('kpis') %>">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/kpis.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">My KPIs <button type="button" class="help-q" data-help="dashboard.kpis" aria-label="About My KPIs">?</button></h2>
          <a href="/dashboard/kpis" class="text-xs text-orgy-blue font-semibold">Scoreboard &rarr;</a>
        </div>
        <% if (myKpis.length === 0) { %>
          <p class="text-xs text-gray-500">No KPIs assigned to you yet.</p>
        <% } else { %>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[11px] uppercase tracking-wide text-gray-400 font-semibold">Show</span>
            <span class="dk-own-seg" role="group" aria-label="Filter KPIs by owner type">
              <button type="button" class="dk-own-btn active" data-mode="all">All</button>
              <button type="button" class="dk-own-btn" data-mode="human">Human</button>
              <button type="button" class="dk-own-btn" data-mode="agent">Agent</button>
            </span>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-[11px] uppercase tracking-wide text-gray-500 border-b border-gray-200">
                <th class="py-1">KPI</th>
                <th class="py-1">Goal</th>
                <th class="py-1">Latest</th>
                <% if (typeof dashClean !== 'undefined' && dashClean) { %><th class="py-1">Trend</th><% } %>
                <th class="py-1">Enter</th>
              </tr>
            </thead>
            <tbody>
              <% myKpis.forEach(function(k){
                   var latest = kpiValues[k.id];
                   var goalSym = { gte: '>=', lte: '<=', gt: '>', lt: '<', eq: '=' }[k.goalOperator] || '';
              %>
                <tr class="border-b border-gray-100" data-kpi-id="<%= k.id %>" data-owner-type="<%= k.ownerEntityType %>">
                  <td class="py-2 pr-3 font-medium text-gray-900"><%= k.title %></td>
                  <td class="py-2 pr-3 text-gray-600"><%= goalSym %> <%= (k.goalValue !== null && k.goalValue !== undefined) ? k.goalValue : '--' %><%= k.unit ? ' ' + k.unit : '' %></td>
                  <td class="py-2 pr-3 text-gray-700" data-kpi-latest><%= latest && latest.value !== null && latest.value !== undefined ? latest.value : '--' %></td>
                  <% if (typeof dashClean !== 'undefined' && dashClean) {
                       var _series = (typeof kpiSeries !== 'undefined' && kpiSeries[k.id]) ? kpiSeries[k.id] : [];
                       var _meets = function(v){
                         if (v === null || v === undefined || k.goalValue === null || k.goalValue === undefined) return null;
                         switch (k.goalOperator) {
                           case 'gte': return v >= k.goalValue; case 'lte': return v <= k.goalValue;
                           case 'gt': return v > k.goalValue;  case 'lt': return v < k.goalValue;
                           case 'eq': return v === k.goalValue; default: return null;
                         }
                       };
                  %>
                  <td class="py-2 pr-3">
                    <div class="dk-spark"><% _series.forEach(function(v){ var m = _meets(v); %><span class="dk-cell <%= m === true ? 'ok' : (m === false ? 'bad' : 'na') %>" title="<%= v === null || v === undefined ? 'no value' : v %>"></span><% }); %></div>
                  </td>
                  <% } %>
                  <td class="py-2">
                    <div class="flex items-center gap-1.5">
                      <input type="number" step="any" class="kpi-value-input rounded border border-gray-300 px-2 py-1 text-xs w-20" placeholder="value" value="<%= latest && latest.value !== null && latest.value !== undefined ? latest.value : '' %>">
                      <button type="button" class="kpi-save-btn rounded bg-orgy-blue px-2.5 py-1 text-[11px] font-semibold text-white hover:bg-orgy-blue-deep disabled:opacity-50">Save</button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
          <p class="dk-own-empty text-xs text-gray-500 mt-2" style="display:none">No KPIs for this owner type.</p>
        <% } %>
      </section>
      <script>
        // My KPIs owner-type filter (All / Human / Agent). Shares the
        // 'otp-kpi-owner-filter' localStorage key with the full Scoreboard so the
        // choice carries across both surfaces. Client-side row show/hide only.
        (function(){
          var sec = document.getElementById('daily-my-kpis');
          if (!sec) return;
          function apply(mode){
            var vis = 0;
            sec.querySelectorAll('tr[data-owner-type]').forEach(function(tr){
              var show = (mode === 'all' || tr.getAttribute('data-owner-type') === mode);
              tr.style.display = show ? '' : 'none';
              if (show) vis++;
            });
            var empty = sec.querySelector('.dk-own-empty');
            if (empty) empty.style.display = vis ? 'none' : '';
            sec.querySelectorAll('.dk-own-btn').forEach(function(b){
              b.classList.toggle('active', b.getAttribute('data-mode') === mode);
            });
            try { localStorage.setItem('otp-kpi-owner-filter', mode); } catch(e){}
          }
          sec.querySelectorAll('.dk-own-btn').forEach(function(b){
            b.addEventListener('click', function(){ apply(b.getAttribute('data-mode')); });
          });
          var saved = 'all';
          try { saved = localStorage.getItem('otp-kpi-owner-filter') || 'all'; } catch(e){}
          if (saved !== 'all') apply(saved);
        })();
      </script>


      <!-- IDS Issues -->
      <section data-tile-id="issues" data-tile-col="right" class="rounded-lg border border-gray-200 bg-white p-5<%= dashHide('issues') %>">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/issues.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">Issues (IDS) <button type="button" class="help-q" data-help="dashboard.issues" aria-label="About Issues and IDS">?</button></h2>
          <button id="issue-add-toggle" class="text-xs text-orgy-blue font-semibold">+ Add</button>
        </div>
        <form id="issue-add-form" class="hidden mb-3 space-y-2">
          <input type="text" name="title" required maxlength="500" placeholder="Issue title" class="w-full rounded border border-gray-300 px-2 py-1.5 text-sm">
          <textarea name="description" rows="2" placeholder="Why does this matter?" class="w-full rounded border border-gray-300 px-2 py-1.5 text-sm"></textarea>
          <% if ((orgTeams || []).length > 0) { %>
          <label class="block text-[11px] font-semibold text-gray-500">Team <span class="font-normal text-gray-400">&middot; shows on this team's meeting to solve</span></label>
          <select name="teamId" class="w-full rounded border border-gray-300 px-2 py-1.5 text-sm">
            <% (orgTeams || []).forEach(function(tm){ %>
              <option value="<%= tm.id %>" <%= tm.id === selectedTeamId ? 'selected' : '' %>><%= tm.name %></option>
            <% }); %>
          </select>
          <% } %>
          <button type="submit" class="rounded bg-orgy-blue text-white text-xs font-semibold px-3 py-1 hover:bg-orgy-blue-deep">Add issue</button>
        </form>
        <% if (myIssues.length === 0) { %>
          <p class="text-xs text-gray-500">No open issues for you. Use this list at L10 -- Identify, Discuss, Solve.</p>
        <% } else { %>
          <%
            var issueCounts = { open: 0, identified: 0, discussed: 0 };
            myIssues.forEach(function(t){ if (issueCounts[t.idsStatus] !== undefined) issueCounts[t.idsStatus]++; });
            var totalOpen = issueCounts.open + issueCounts.identified + issueCounts.discussed;
          %>
          <div id="issue-filter" class="flex items-center gap-1 text-[11px] mb-2 flex-wrap" data-active="open">
            <button type="button" data-filter="open"       class="issue-filter-btn rounded px-2 py-0.5 font-semibold bg-orgy-blue text-white">Open <span class="opacity-70">(<%= issueCounts.open %>)</span></button>
            <button type="button" data-filter="identified" class="issue-filter-btn rounded px-2 py-0.5 font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200">Identified <span class="opacity-70">(<%= issueCounts.identified %>)</span></button>
            <button type="button" data-filter="discussed"  class="issue-filter-btn rounded px-2 py-0.5 font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200">Discussed <span class="opacity-70">(<%= issueCounts.discussed %>)</span></button>
            <button type="button" data-filter="all"        class="issue-filter-btn rounded px-2 py-0.5 font-semibold bg-gray-100 text-gray-700 hover:bg-gray-200">All open <span class="opacity-70">(<%= totalOpen %>)</span></button>
          </div>
          <p id="issue-empty-msg" class="text-xs text-gray-500 hidden">No issues with that status.</p>
          <ul id="issue-list" class="space-y-1">
            <% myIssues.forEach(function(t){ var iNeedsNext = !t.nextAction; %>
              <li class="issue-row text-sm rounded border <%= iNeedsNext ? 'border-rose-200 border-l-4 border-l-rose-500 bg-rose-50/30' : 'border-gray-100 bg-gray-50/60' %> px-3 py-2" data-issue-id="<%= t.id %>" data-status="<%= t.idsStatus %>">
                <div class="flex items-start justify-between gap-2">
                  <div class="flex-1 min-w-0">
                    <div class="font-semibold text-gray-900"><%= t.title %></div>
                    <% if (t.description) { %><p class="text-xs text-gray-600 mt-0.5"><%= t.description %></p><% } %>
                    <div class="text-[11px] text-gray-500 mt-0.5">
                      <%= t.idsStatus %><%= t.priorityRank ? ' &middot; #' + t.priorityRank : '' %><%- teamTag(t.teamId) %>
                      <% if (isIntegrator) { %><button type="button" class="ix-manage-toggle ml-1 text-gray-400 hover:text-gray-700 font-semibold">&middot;&middot;&middot; manage</button><% } %>
                    </div>
                    <% if (isIntegrator) { %>
                    <div class="ix-manage hidden mt-2 pt-2 border-t border-gray-100 flex flex-wrap items-center gap-2 text-[11px]">
                      <select class="ix-team rounded border border-gray-300 px-1.5 py-1" title="Move to team / meeting">
                        <option value="">&mdash; no team &mdash;</option>
                        <% orgTeams.forEach(function(_t){ %><option value="<%= _t.id %>" <%= _t.id === t.teamId ? 'selected' : '' %>><%= _t.name %></option><% }); %>
                      </select>
                      <select class="ix-owner rounded border border-gray-300 px-1.5 py-1" title="Reassign owner">
                        <option value="">&mdash; owner &mdash;</option>
                        <% (locals.assignablePeople || []).forEach(function(p){ %><option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>" <%= p.externalId === t.ownerExternalId ? 'selected' : '' %>><%= p.name %></option><% }); %>
                      </select>
                      <button type="button" class="ix-edit text-orgy-blue font-semibold hover:underline">edit</button>
                      <button type="button" class="ix-delete text-rose-600 font-semibold hover:underline ml-auto">delete</button>
                    </div>
                    <form class="ix-edit-form hidden mt-1 flex gap-1.5">
                      <input type="text" class="ix-edit-input flex-1 rounded border border-gray-300 px-2 py-1 text-xs" maxlength="500" value="<%= t.title %>">
                      <button type="submit" class="text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Save</button>
                      <button type="button" class="ix-edit-cancel text-[11px] text-gray-500 font-semibold px-1">Cancel</button>
                    </form>
                    <% } %>
                    <!-- Next Action: same machinery as Rocks. -->
                    <div class="next-action mt-2 text-xs" data-na-id="<%= t.id %>" data-na-kind="issue">
                      <% if (t.nextAction) { %>
                        <div class="na-view flex items-start gap-1.5 text-gray-700">
                          <span class="text-orgy-on-light shrink-0">👉</span>
                          <span class="na-text flex-1 break-words"><%= t.nextAction %></span>
                          <button type="button" class="na-edit text-[10px] text-orgy-blue font-semibold hover:underline shrink-0">edit</button>
                          <button type="button" class="na-done text-[10px] text-emerald-700 font-semibold hover:underline shrink-0">done</button>
                        </div>
                      <% } else { %>
                        <button type="button" class="na-edit text-[11px] text-rose-700 font-semibold hover:underline">+ Set Next Action</button>
                      <% } %>
                      <form class="na-edit-form hidden mt-1 flex gap-1.5">
                        <input type="text" class="na-input flex-1 rounded border border-gray-300 px-2 py-1 text-xs" placeholder="One concrete physical step..." maxlength="500" value="<%= t.nextAction || '' %>">
                        <button type="submit" class="na-save text-[11px] rounded bg-orgy-blue text-white font-semibold px-2 py-1 hover:bg-orgy-blue-deep">Save</button>
                        <button type="button" class="na-cancel text-[11px] text-gray-500 font-semibold px-1">Cancel</button>
                      </form>
                    </div>
                    <div data-att-host data-att-type="issue" data-att-id="<%= t.id %>"></div>
                  </div>
                  <% if (isIntegrator) { %>
                    <button class="issue-solve-btn text-[11px] font-semibold rounded px-2 py-0.5 bg-white border border-gray-300 text-gray-700 hover:border-status-ontrack hover:text-status-ontrack whitespace-nowrap">&#10003; Mark solved</button>
                  <% } %>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </section>


    </div><!-- /right -->
  </div><!-- /grid -->

  <script>
  // Tile order from saved prefs. Runs synchronously right after the grid
  // markup (before later scripts) so the reorder happens pre-paint -- no
  // visible jump. Ordered ids first, unlisted tiles keep template order at
  // the end. Only reorders within the same parent; bottom row is fixed.
  // Also stashes the template order so "Reset to default" can restore it.
  (function(){
    var prefs = <%- jsonForScript(locals.dashboardPrefs || {}) %> || {};
    // Layout engine supersedes the legacy two-column order: when a saved
    // layout exists, the row-builder script (after the last tile) owns all
    // placement and this legacy reorder must not fight it.
    if (Array.isArray(prefs.layout) && prefs.layout.length) return;
    var order = (prefs && prefs.tileOrder) || {};
    window.__dashTileTemplateOrder = {};
    ['left', 'right'].forEach(function(col){
      var tiles = document.querySelectorAll('[data-tile-id][data-tile-col="' + col + '"]');
      if (!tiles.length) { window.__dashTileTemplateOrder[col] = []; return; }
      var parent = tiles[0].parentNode;
      var byId = {}, template = [];
      Array.prototype.forEach.call(tiles, function(t){
        if (t.parentNode !== parent) return;
        byId[t.getAttribute('data-tile-id')] = t;
        template.push(t.getAttribute('data-tile-id'));
      });
      window.__dashTileTemplateOrder[col] = template;
      var ids = order[col];
      if (!ids || !ids.length) return;
      var placed = {};
      ids.forEach(function(id){ if (byId[id]) { parent.appendChild(byId[id]); placed[id] = true; } });
      template.forEach(function(id){ if (!placed[id]) parent.appendChild(byId[id]); });
    });
  })();
  </script>

  <!-- Agents + OTP Insights: own grid so the two collapsed bars align on one
       row regardless of the rails' unequal heights above. -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 mt-5" data-dash-row data-dash-pattern="4-8"<%- dashRowHide %>>
    <div class="lg:col-span-4 space-y-5" data-dash-cell><!-- Agents (aligned row) -->
      <!-- My Agents (compact, collapsible -- David flagged 2026-05-24 that
           the full agent list took up too much space in the right column.
           Same <details>/<summary> pattern as OTP Insights. Summary line
           always shows the at-a-glance health (count + avg + red/yellow).
           User's open/closed preference is persisted in localStorage via
           the small script at the bottom of this page. -->
      <%
         var agentRedCount = myAgents.filter(function(a){ return (a.score||0) < 3; }).length;
         var agentYellowCount = myAgents.filter(function(a){ return (a.score||0) >= 3 && (a.score||0) < 6; }).length;
         var agentAvg = myAgents.length > 0 ? (myAgents.reduce(function(s,a){ return s + (a.score||0); }, 0) / myAgents.length) : 0;
      %>
      <details id="my-agents-details" data-tile-id="agents" data-tile-col="bottom" class="rounded-lg border border-gray-200 bg-white<%= dashHide('agents') %>">
        <summary class="cursor-pointer select-none px-5 py-3 flex items-center justify-between hover:bg-gray-50 transition rounded-lg">
          <span class="flex items-center gap-3 flex-wrap min-w-0">
            <span class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/agents.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">My Agents <button type="button" class="help-q" data-help="dashboard.agents" aria-label="About My Agents">?</button></span>
            <% if (myAgents.length > 0) { %>
              <span class="text-[11px] text-gray-500 flex items-center gap-3 flex-wrap">
                <span><strong class="text-gray-700"><%= myAgents.length %></strong> seats</span>
                <span>avg <strong class="text-gray-700"><%= agentAvg.toFixed(1) %>/8</strong></span>
                <% if (agentRedCount > 0) { %><span class="text-rose-600 font-semibold"><%= agentRedCount %> red</span><% } %>
                <% if (agentYellowCount > 0) { %><span class="text-amber-600 font-semibold"><%= agentYellowCount %> yellow</span><% } %>
              </span>
            <% } else { %>
              <span class="text-[11px] text-gray-500">No agents yet</span>
            <% } %>
          </span>
          <a href="/dashboard/team" class="text-xs text-orgy-blue font-semibold hover:underline shrink-0 ml-3" onclick="event.stopPropagation()">View chart &rarr;</a>
        </summary>
        <div class="px-5 pb-5 pt-1 border-t border-gray-100">
          <% if (myAgents.length === 0) { %>
            <div class="rounded border border-dashed border-gray-300 bg-gray-50/40 p-4 text-xs text-gray-600 mt-3">
              No agents on your team chart yet. Build one at <a href="/dashboard/team" class="text-orgy-blue font-semibold hover:underline">/dashboard/team</a> &mdash; agents you add there appear here automatically.
            </div>
          <% } else { %>
            <ul class="divide-y divide-gray-100 -mx-2 mt-2">
              <% myAgents.forEach(function(a){
                   var score = a.score || 0;
                   var pct = Math.round((score / 8) * 100);
                   var color = score >= 6 ? 'bg-emerald-500' : score >= 3 ? 'bg-amber-400' : score > 0 ? 'bg-rose-400' : 'bg-gray-300';
                   var kpiN = (typeof a.kpiCount === 'number') ? a.kpiCount : 0;
              %>
                <li>
                  <a href="/dashboard/team" class="flex items-center gap-2 text-sm px-2 py-1.5 hover:bg-gray-50 rounded" data-agent-id="<%= a.id %>">
                    <span class="inline-block w-2 h-2 rounded-full <%= color %> shrink-0"></span>
                    <span class="font-medium text-gray-900 truncate flex-1 min-w-0"><%= a.name %></span>
                    <span class="hidden sm:inline-block w-24 h-1 bg-gray-200 rounded overflow-hidden shrink-0">
                      <span class="block h-full <%= color %>" style="width: <%= pct %>%"></span>
                    </span>
                    <span class="text-[11px] font-semibold text-gray-700 tabular-nums w-10 text-right shrink-0"><%= score.toFixed ? score.toFixed(1) : score %></span>
                    <span class="hidden sm:inline text-[10px] text-gray-500 tabular-nums w-14 text-right shrink-0"><%= kpiN %> KPI<%= kpiN === 1 ? '' : 's' %></span>
                  </a>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </details>

    </div>
    <div class="lg:col-span-8 space-y-5" data-dash-cell><!-- OTP Insights (aligned row) -->
  <!-- OTP Insights: diagnostic surfaces moved out of the main grid 2026-05-24
       so the dashboard reads balanced like Ninety. The four cards here are
       coaching/reflection, not daily action: Waiting on others, Founder
       Dependency, Accountability Gaps, and Hand-off candidates. Collapsed
       by default; one click expands. Same data, same JS handlers (the form
       and section IDs are preserved), just behind a click. -->
  <details data-tile-id="insights" data-tile-col="bottom" class="mt-8<%= dashHide('insights') %>">
    <summary class="cursor-pointer select-none rounded-lg border border-orgy bg-orgy-tint px-5 py-3 flex items-center justify-between hover:bg-orgy-soft transition" style="border-color: var(--orgy-green);">
      <span class="flex items-center gap-2.5">
        <img src="/public/images/orgy-magnify.webp" alt="" class="w-8 shrink-0" loading="lazy" decoding="async">
        <span class="text-sm font-bold uppercase tracking-wide text-gray-700">OTP Insights</span>
        <button type="button" class="help-q" data-help="dashboard.insights" aria-label="About OTP Insights">?</button>
      </span>
      <span class="text-[11px] text-gray-500 font-medium">Diagnostics &middot; click to expand</span>
    </summary>
    <div class="space-y-6 mt-4">

      <!-- Waiting on others (delegated, still in progress) -->
      <% var delegatedWaitingList = locals.delegatedWaiting || []; %>
      <% if (delegatedWaitingList.length > 0) { %>
        <section class="rounded-lg border border-gray-200 bg-white p-5">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/checking.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">Waiting on others <button type="button" class="help-q" data-help="dashboard.waiting" aria-label="About Waiting on others">?</button> <span class="text-gray-400 font-normal text-[10px]">(<%= delegatedWaitingList.length %>)</span></h2>
          </div>
          <ul class="space-y-1">
            <% delegatedWaitingList.forEach(function(t){
                 var promised = t.dueAt ? new Date(t.dueAt) : null;
            %>
              <li class="flex items-start gap-2 text-sm rounded border border-gray-100 bg-gray-50/60 px-3 py-2" data-waiting-id="<%= t.id %>">
                <div class="flex-1 min-w-0">
                  <div class="text-gray-900 break-words"><%= t.title %></div>
                  <div class="text-[11px] text-gray-500 mt-0.5">
                    waiting on <%= t.ownerName %>
                    <%= promised ? ' · promised ' + promised.toLocaleDateString() : '' %>
                  </div>
                </div>
                <button type="button" class="waiting-closeout shrink-0 text-[11px] font-semibold text-gray-500 hover:text-gray-800 border border-gray-200 rounded px-2 py-1 bg-white" data-todo-id="<%= t.id %>" title="They never closed it? Disposition it yourself: marks the to-do done and verified, and notifies them.">Close it out</button>
              </li>
            <% }); %>
          </ul>
        </section>
      <% } %>

      <!-- Founder Dependency -->
      <% var fd = locals.founderDependency || { hasTopSeat: false, pct: 0, ownedByTop: 0, totalOpen: 0, topNames: [] }; %>
      <section class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mb-2 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/founder-dependency.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">Founder Dependency <button type="button" class="help-q" data-help="dashboard.founderDependency" aria-label="About Founder Dependency">?</button></h2>
        <% if (!fd.hasTopSeat) { %>
          <p class="text-xs text-gray-500">No top human seat on the chart yet -- add the seat that reports to nobody to track this.</p>
        <% } else if (fd.totalOpen === 0) { %>
          <p class="text-xs text-gray-500">No open work to measure yet.</p>
        <% } else { var fdHigh = fd.pct >= 50; %>
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-bold <%= fdHigh ? 'text-amber-600' : 'text-emerald-600' %>"><%= fd.pct %>%</span>
            <span class="text-xs font-semibold <%= fdHigh ? 'text-amber-700' : 'text-emerald-700' %>"><%= fdHigh ? 'High -- absorb more onto the team' : 'Healthy' %></span>
          </div>
          <p class="text-xs text-gray-500 mt-1">
            <%= fd.ownedByTop %> of <%= fd.totalOpen %> open items (rocks, KPIs, issues, to-dos) sit on <%= fd.topNames.join(', ') %>.
          </p>
        <% } %>
      </section>

      <!-- Accountability Gaps (chart <-> work reconciliation) -->
      <%
        var accGaps = locals.accountabilityGaps || {};
        var seatsNoMeasurable = accGaps.seatsNoMeasurable || [];
        var orphanedWork = accGaps.orphanedWork || [];
        var agentsNoHuman = accGaps.agentsNoHuman || [];
        var accAllClear = seatsNoMeasurable.length === 0 && orphanedWork.length === 0 && agentsNoHuman.length === 0;
      %>
      <section class="rounded-lg border border-gray-200 bg-white p-5" id="acc-gaps">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 otp-dic-h2"><img class="otp-dic-img" src="/public/images/orgy/accountability-gaps.png?v=<%= typeof assetVersion !== "undefined" ? assetVersion : "dev" %>" alt="">Accountability Gaps <button type="button" class="help-q" data-help="dashboard.accountabilityGaps" aria-label="About Accountability Gaps">?</button></h2>
          <a href="/dashboard/team" class="text-xs text-orgy-blue font-semibold hover:underline">View chart &rarr;</a>
        </div>
        <% if (accAllClear) { %>
          <p class="text-xs text-emerald-700 flex items-center gap-1.5">
            <span class="text-emerald-600">&#10003;</span>
            Chart and work reconcile -- every seat has a measurable, every item has a seat.
          </p>
        <% } else { %>
          <div id="gap-filter" class="flex flex-wrap items-center gap-1 text-[11px] mb-3" data-active="all">
            <button type="button" data-gap-filter="all" class="gap-filter-btn rounded px-2 py-1 font-semibold border border-gray-300 bg-gray-100 text-gray-700">All</button>
            <button type="button" data-gap-filter="human" class="gap-filter-btn rounded px-2 py-1 font-semibold border border-gray-200 text-gray-500 hover:bg-gray-50">All Human</button>
            <button type="button" data-gap-filter="agent" class="gap-filter-btn rounded px-2 py-1 font-semibold border border-gray-200 text-gray-500 hover:bg-gray-50">All Agents</button>
            <button type="button" data-gap-filter="reports" class="gap-filter-btn rounded px-2 py-1 font-semibold border border-gray-200 text-gray-500 hover:bg-gray-50">Direct Reports</button>
            <button type="button" data-gap-filter="noseat" class="gap-filter-btn rounded px-2 py-1 font-semibold border border-gray-200 text-gray-500 hover:bg-gray-50">No Seat</button>
          </div>
          <div class="space-y-4" id="gap-buckets">
            <div data-gap-section="seat"<% if (seatsNoMeasurable.length === 0) { %> class="hidden"<% } %>>
              <div class="text-[11px] uppercase tracking-wide font-bold text-amber-700 mb-1.5">
                Seats with no measurable <span class="gap-section-count text-amber-500 font-semibold">(<%= seatsNoMeasurable.length %>)</span>
              </div>
              <ul class="space-y-1">
                <% seatsNoMeasurable.forEach(function(s){ %>
                  <li class="gap-item text-sm rounded border border-amber-100 bg-amber-50/60 px-3 py-1.5"
                      data-gap-cat="<%= s.type === 'agent' ? 'agent' : 'human' %>"
                      data-gap-reportsto="<%= s.reportsTo || '' %>"
                      data-seat-id="<%= s.externalId %>">
                    <div class="flex items-start justify-between gap-2 flex-wrap">
                      <div>
                        <span class="font-medium text-amber-900"><%= s.label %></span>
                        <% if (s.type) { %><span class="text-amber-600 text-[11px]">(<%= s.type %>)</span><% } %>
                        <span class="text-amber-700"> -- owns no KPI or Rock.</span>
                      </div>
                      <div class="flex gap-1.5 shrink-0">
                        <button type="button" class="gap-add-kpi rounded border border-amber-300 bg-white px-2 py-0.5 text-[11px] font-semibold text-amber-800 hover:bg-amber-100">+ Add KPI</button>
                        <button type="button" class="gap-add-rock rounded border border-amber-300 bg-white px-2 py-0.5 text-[11px] font-semibold text-amber-800 hover:bg-amber-100">+ Add Rock</button>
                      </div>
                    </div>
                    <form class="gap-kpi-form hidden mt-2 flex flex-col gap-1.5 border-t border-amber-100 pt-2">
                      <input type="text" name="title" required maxlength="255" placeholder="KPI title (e.g. Weekly qualified calls)" class="rounded border border-gray-300 px-2 py-1 text-xs">
                      <div class="flex gap-1.5 flex-wrap">
                        <select name="timeGrain" class="rounded border border-gray-300 px-2 py-1 text-xs">
                          <option value="weekly">Weekly</option>
                          <option value="monthly">Monthly</option>
                          <option value="quarterly">Quarterly</option>
                          <option value="annual">Annual</option>
                        </select>
                        <select name="goalOperator" class="rounded border border-gray-300 px-2 py-1 text-xs">
                          <option value="gte">&ge; at least</option>
                          <option value="lte">&le; at most</option>
                          <option value="eq">= exactly</option>
                          <option value="gt">&gt; more than</option>
                          <option value="lt">&lt; less than</option>
                        </select>
                        <input type="number" name="goalValue" step="any" placeholder="Goal" class="w-20 rounded border border-gray-300 px-2 py-1 text-xs">
                        <input type="text" name="unit" maxlength="40" placeholder="Unit" class="w-20 rounded border border-gray-300 px-2 py-1 text-xs">
                      </div>
                      <div class="flex gap-1.5">
                        <button type="submit" class="rounded bg-amber-600 px-2.5 py-1 text-[11px] font-semibold text-white hover:bg-amber-700">Create KPI</button>
                        <button type="button" class="gap-cancel rounded border border-gray-300 px-2.5 py-1 text-[11px] text-gray-600 hover:bg-gray-50">Cancel</button>
                      </div>
                    </form>
                    <form class="gap-rock-form hidden mt-2 flex flex-col gap-1.5 border-t border-amber-100 pt-2">
                      <input type="text" name="title" required minlength="3" maxlength="500" placeholder="Rock title (a 90-day priority)" class="rounded border border-gray-300 px-2 py-1 text-xs">
                      <div class="flex gap-1.5 items-center flex-wrap">
                        <label class="text-[10px] uppercase tracking-wide text-gray-500">Due</label>
                        <input type="date" name="dueDate" required class="rounded border border-gray-300 px-2 py-1 text-xs">
                        <span class="text-[10px] text-gray-400">Quarter <%= currentQuarter %></span>
                      </div>
                      <div class="flex gap-1.5">
                        <button type="submit" class="rounded bg-amber-600 px-2.5 py-1 text-[11px] font-semibold text-white hover:bg-amber-700">Create Rock</button>
                        <button type="button" class="gap-cancel rounded border border-gray-300 px-2.5 py-1 text-[11px] text-gray-600 hover:bg-gray-50">Cancel</button>
                      </div>
                    </form>
                  </li>
                <% }); %>
              </ul>
            </div>
            <div data-gap-section="orphan"<% if (orphanedWork.length === 0) { %> class="hidden"<% } %>>
              <div class="text-[11px] uppercase tracking-wide font-bold text-amber-700 mb-1.5">
                Work with no seat <span class="gap-section-count text-amber-500 font-semibold">(<%= orphanedWork.length %>)</span>
              </div>
              <ul class="space-y-1">
                <% orphanedWork.forEach(function(w){ %>
                  <li class="gap-item text-sm rounded border border-amber-100 bg-amber-50/60 px-3 py-1.5"
                      data-gap-cat="noseat"
                      data-record-id="<%= w.recordId %>"
                      data-record-kind="<%= w.kind %>">
                    <div class="flex items-start justify-between gap-2 flex-wrap">
                      <div>
                        <span class="font-medium text-amber-900"><%= w.label %></span>
                        <span class="text-amber-600 text-[11px]">(<%= w.kind %>)</span>
                        <span class="text-amber-700"> -- owned by <%= w.ownerExternalId %>, not on the chart.</span>
                      </div>
                      <button type="button" class="gap-reassign-btn rounded border border-amber-300 bg-white px-2 py-0.5 text-[11px] font-semibold text-amber-800 hover:bg-amber-100 shrink-0">Reassign</button>
                    </div>
                    <form class="gap-reassign-form hidden mt-2 flex gap-1.5 items-center flex-wrap border-t border-amber-100 pt-2">
                      <select name="seat" class="rounded border border-gray-300 px-2 py-1 text-xs">
                        <option value="">Pick a seat...</option>
                        <% (locals.assignablePeople || []).forEach(function(p){ %>
                          <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>"><%= p.name %></option>
                        <% }); %>
                      </select>
                      <button type="submit" class="rounded bg-amber-600 px-2.5 py-1 text-[11px] font-semibold text-white hover:bg-amber-700">Move</button>
                      <button type="button" class="gap-cancel rounded border border-gray-300 px-2.5 py-1 text-[11px] text-gray-600 hover:bg-gray-50">Cancel</button>
                    </form>
                  </li>
                <% }); %>
              </ul>
            </div>
            <div data-gap-section="agent"<% if (agentsNoHuman.length === 0) { %> class="hidden"<% } %>>
              <div class="text-[11px] uppercase tracking-wide font-bold text-amber-700 mb-1.5">
                Agents with no human accountable <span class="gap-section-count text-amber-500 font-semibold">(<%= agentsNoHuman.length %>)</span>
              </div>
              <ul class="space-y-1">
                <% agentsNoHuman.forEach(function(a){ %>
                  <li class="gap-item text-sm rounded border border-amber-100 bg-amber-50/60 px-3 py-1.5"
                      data-gap-cat="agent"
                      data-gap-reportsto="<%= a.reportsTo || '' %>"
                      data-agent-id="<%= a.externalId %>">
                    <div class="flex items-start justify-between gap-2 flex-wrap">
                      <div>
                        <span class="font-medium text-amber-900"><%= a.label %></span>
                        <span class="text-amber-700"> -- no human seat above this agent.</span>
                      </div>
                      <button type="button" class="gap-setmgr-btn rounded border border-amber-300 bg-white px-2 py-0.5 text-[11px] font-semibold text-amber-800 hover:bg-amber-100 shrink-0">Set manager</button>
                    </div>
                    <form class="gap-setmgr-form hidden mt-2 flex gap-1.5 items-center flex-wrap border-t border-amber-100 pt-2">
                      <select name="manager" class="rounded border border-gray-300 px-2 py-1 text-xs">
                        <option value="">Pick a human seat...</option>
                        <% (locals.assignablePeople || []).filter(function(p){ return p.entityType === 'human'; }).forEach(function(p){ %>
                          <option value="<%= p.externalId %>"><%= p.name %></option>
                        <% }); %>
                      </select>
                      <button type="submit" class="rounded bg-amber-600 px-2.5 py-1 text-[11px] font-semibold text-white hover:bg-amber-700">Save</button>
                      <button type="button" class="gap-cancel rounded border border-gray-300 px-2.5 py-1 text-[11px] text-gray-600 hover:bg-gray-50">Cancel</button>
                    </form>
                  </li>
                <% }); %>
              </ul>
            </div>
          </div>
          <p id="gap-empty" class="hidden text-xs text-gray-500 mt-2">No gaps match this filter.</p>
        <% } %>
      </section>

      <!-- Delegate and Elevate: recurring-load hand-off candidates -->
      <% var handoffs = locals.delegateElevate || []; %>
      <section class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mb-3">Hand-off candidates <button type="button" class="help-q" data-help="dashboard.handoff" aria-label="About Hand-off candidates">?</button></h2>
        <% if (handoffs.length === 0) { %>
          <p class="text-xs text-emerald-700 flex items-center gap-1.5">
            <span class="text-emerald-600">&#10003;</span>
            No one is carrying a heavy recurring load.
          </p>
        <% } else { %>
          <ul class="space-y-1.5">
            <% handoffs.forEach(function(h){ %>
              <li class="text-sm rounded border border-amber-100 bg-amber-50/60 px-3 py-2">
                <div class="flex items-center justify-between gap-2">
                  <a href="/team/<%= encodeURIComponent(h.externalId) %>" class="font-medium text-amber-900 hover:underline"><%= h.name %></a>
                  <span class="text-amber-600 text-[11px] font-semibold"><%= h.count %> recurring</span>
                </div>
                <div class="text-amber-700 text-[11px] mt-0.5">
                  Oldest: "<%= h.oldestTitle %>" -- held <%= h.oldestDays %> days. Consider a lower seat or an agent.
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </section>

    </div>
  </details>
    </div>
  </div><!-- /grid -->

  <!-- People Review banner: surfaces GWC + Values rating so it's discoverable
       from the daily dashboard. Always visible (not collapsed) because
       discovery was the problem -- David flagged 2026-05-24 that the People
       Analyzer was built but unreachable from the main surfaces. -->
  <a href="/team/review" class="mt-8 block rounded-lg border border-orgy-soft bg-white hover:bg-orgy-tint px-5 py-3 flex items-center justify-between transition group">
    <span class="flex items-center gap-3 min-w-0">
      <img src="/public/images/orgy-idle.webp" alt="" class="w-8 shrink-0" loading="lazy" decoding="async">
      <span class="min-w-0">
        <span class="block text-sm font-bold uppercase tracking-wide text-gray-700">People Review</span>
        <span class="block text-[11px] text-gray-500">Rate each seat against Gets it, Wants it, Capacity, and your values</span>
      </span>
    </span>
    <span class="text-xs font-semibold text-orgy-blue group-hover:underline shrink-0 ml-3">Open &rarr;</span>
  </a>


  <!-- Cascading Message (read-only, integrator-set). Lives in its own
       full-width layout row so the layout engine can move it like any other
       tile; it stays non-hideable. -->
  <% if (selectedMeeting && selectedMeeting.cascadingMessage) { %>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 mt-6" data-dash-row data-dash-pattern="12"<%- dashRowHide %>>
      <div class="dash-span-12 space-y-5" data-dash-cell>
        <section data-tile-id="cascading" data-tile-col="bottom" class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <h2 class="text-sm font-bold uppercase tracking-wide text-gray-700 mb-2">Cascading message <button type="button" class="help-q" data-help="dashboard.cascade" aria-label="About the Cascading message">?</button></h2>
          <pre class="whitespace-pre-wrap text-xs text-gray-800 font-mono"><%= selectedMeeting.cascadingMessage %></pre>
        </section>
      </div>
    </div>
  <% } %>

  <script>
  // Layout engine row builder. Runs synchronously after the LAST tile in the
  // template (the rows above are server-rendered visibility:hidden when a
  // saved layout exists) so a custom layout is applied before paint.
  //
  // window.__dashApplyLayout(layout) rebuilds the row/cell containers from a
  // layout config ([{ pattern, cells: [[tileId,...],...] }]) and moves the
  // existing server-rendered tile DOM into the cells -- no tile markup is
  // duplicated. Rules: unknown/missing tile ids are skipped; tiles the
  // layout never mentions are appended to the last cell of the first row
  // (never lose a tile) -- except the cascading tile, which gets its own
  // full-width row at the end so the integrator directive stays prominent.
  //
  // Fast path: with no saved layout this defines the helpers and exits --
  // the server-rendered default rows (tagged data-dash-row/data-dash-cell)
  // already ARE the default layout, so the DOM is untouched.
  (function(){
    var prefs = <%- jsonForScript(locals.dashboardPrefs || {}) %> || {};
    var DEFAULT_LAYOUT = [
      { pattern: '4-8', cells: [['meetings', 'headlines', 'rocks'], ['todos', 'kpis', 'issues']] },
      { pattern: '4-8', cells: [['agents'], ['insights']] },
      { pattern: '12', cells: [['cascading']] }
    ];
    var SPAN_SETS = { '12': [12], '4-8': [4, 8], '8-4': [8, 4], '6-6': [6, 6], '4-4-4': [4, 4, 4] };
    window.__dashDefaultLayout = DEFAULT_LAYOUT;
    window.__dashSpanSets = SPAN_SETS;

    function buildRow(pattern){
      var row = document.createElement('div');
      row.className = 'grid grid-cols-1 lg:grid-cols-12 gap-5 mt-5';
      row.setAttribute('data-dash-row', '');
      row.setAttribute('data-dash-pattern', SPAN_SETS[pattern] ? pattern : '12');
      (SPAN_SETS[pattern] || [12]).forEach(function(span){
        var cell = document.createElement('div');
        cell.className = 'dash-span-' + span + ' space-y-5';
        cell.setAttribute('data-dash-cell', '');
        row.appendChild(cell);
      });
      return row;
    }
    window.__dashBuildRow = buildRow;

    window.__dashApplyLayout = function(layout){
      var root = document.getElementById('daily-dashboard');
      if (!root || !Array.isArray(layout)) return;
      var tilesById = {}, tileIds = [];
      Array.prototype.forEach.call(root.querySelectorAll('[data-tile-id]'), function(t){
        var id = t.getAttribute('data-tile-id');
        if (!tilesById[id]) { tilesById[id] = t; tileIds.push(id); }
      });
      var oldRows = Array.prototype.slice.call(root.querySelectorAll('[data-dash-row]'));
      if (!oldRows.length) return;
      var parent = oldRows[0].parentNode;
      var marker = document.createComment('dash-rows');
      parent.insertBefore(marker, oldRows[0]);
      var placed = {}, newRows = [], firstRowLastCell = null;
      layout.forEach(function(rowCfg){
        if (!rowCfg || !SPAN_SETS[rowCfg.pattern]) return;
        var row = buildRow(rowCfg.pattern);
        var cells = row.querySelectorAll('[data-dash-cell]');
        (Array.isArray(rowCfg.cells) ? rowCfg.cells : []).forEach(function(cellIds, i){
          var cell = cells[Math.min(i, cells.length - 1)];
          (Array.isArray(cellIds) ? cellIds : []).forEach(function(id){
            if (tilesById[id] && !placed[id]) { cell.appendChild(tilesById[id]); placed[id] = true; }
          });
        });
        if (!newRows.length) firstRowLastCell = cells[cells.length - 1];
        newRows.push(row);
      });
      if (!newRows.length) {
        var fallback = buildRow('12');
        firstRowLastCell = fallback.querySelector('[data-dash-cell]');
        newRows.push(fallback);
      }
      var strayCascading = null;
      tileIds.forEach(function(id){
        if (placed[id]) return;
        if (id === 'cascading') { strayCascading = tilesById[id]; return; }
        firstRowLastCell.appendChild(tilesById[id]);
        placed[id] = true;
      });
      if (strayCascading) {
        var cascRow = buildRow('12');
        cascRow.querySelector('[data-dash-cell]').appendChild(strayCascading);
        newRows.push(cascRow);
      }
      newRows[0].classList.remove('mt-5'); // first row sits flush like the template's
      newRows.forEach(function(row){ parent.insertBefore(row, marker); });
      oldRows.forEach(function(r){ if (r.parentNode) r.parentNode.removeChild(r); });
      parent.removeChild(marker);
    };

    if (Array.isArray(prefs.layout) && prefs.layout.length) {
      window.__dashApplyLayout(prefs.layout);
    }
  })();
  </script>

  <!-- Footer -->
  <footer class="mt-10 text-xs text-gray-400">
    Daily dashboard v1. Run an L10 from this page every week. Push KPIs and pull rocks via MCP.
    <% if (caps.canEditOrgSettings) { %>
      &middot; <a href="/dashboard/publisher" class="underline hover:text-orgy-blue">Switch to publisher view</a>
    <% } %>
  </footer>
</div>

<script>
// Per-user dashboard prefs (orgMembers.preferences.dashboard), embedded for
// client JS. Read-only for now -- a later task applies them to rendering.
window.__dashboardPrefs = <%- jsonForScript(locals.dashboardPrefs || {}) %>;
(function(){
  var root = document.getElementById('daily-dashboard');
  if (!root) return;
  var meetingId = root.dataset.meetingId || '';
  var orgId = root.dataset.orgId || '';
  var isIntegrator = root.dataset.isIntegrator === '1';
  var quarter = root.dataset.quarter || '';

  function api(method, path, body) {
    // Fastify rejects empty-body requests if Content-Type is application/json
    // (FST_ERR_CTP_EMPTY_JSON_BODY). Only set the header when we have a body.
    var opts = {
      method: method,
      headers: {},
      credentials: 'same-origin',
    };
    if (body) {
      opts.headers['Content-Type'] = 'application/json';
      opts.body = JSON.stringify(body);
    }
    return fetch('/api/v1' + path, opts).then(function(r){
      if (!r.ok) {
        return r.text().then(function(text){
          var j = {};
          try { j = text ? JSON.parse(text) : {}; } catch (e) { /* non-JSON body */ }
          var inner = j.error || {};
          var err = {
            status: r.status,
            code: inner.code || 'API_ERROR',
            message: inner.message || ('HTTP ' + r.status + (text && text.length < 200 ? ' ' + text : '')),
            details: inner.details,
          };
          console.error('[api]', method, path, err);
          throw err;
        });
      }
      return r.json();
    }, function(networkErr){
      var err = { status: 0, code: 'NETWORK', message: networkErr && networkErr.message || 'Network error' };
      console.error('[api]', method, path, err);
      throw err;
    });
  }
  function fmtApiError(err) {
    if (!err) return 'Unknown error';
    var parts = [];
    if (err.status) parts.push(err.status);
    if (err.code) parts.push(err.code);
    var head = parts.join(' ');
    return (head ? head + ' — ' : '') + (err.message || 'Failed');
  }

  function reload() { window.location.reload(); }

  // --- Realtime (R2.2): auto-refresh this dashboard when someone ELSE changes
  // shared data (a teammate or an agent completes a to-do, moves a rock, saves
  // a KPI, etc). The page already reload()s after the viewer's own mutations,
  // so a remote-event reload is symmetric -- not a new disruption pattern. We
  // debounce bursts and never yank the page mid-edit: if a field is focused or
  // the add-to-do form is open, we show a small "Updated -- refresh" pill and
  // apply once the viewer is idle. Gated by OTPLive (only connects when the live
  // stream is on); a complete no-op otherwise. NOTE: this is a guarded reload,
  // not per-section targeted-swap -- the dashboard binds its handlers at load
  // with no re-init path, so an innerHTML swap would kill them. Targeted-swap is
  // a later increment that first needs that JS refactored to be re-callable.
  (function(){
    if (!(window.OTPLive && window.OTPLive.enabled())) return;
    var RELEVANT = { todo: 1, rock: 1, kpi: 1, issue: 1, meeting: 1 };
    var timer = null;
    function userBusy(){
      var a = document.activeElement;
      if (a && (a.tagName === 'INPUT' || a.tagName === 'TEXTAREA' || a.tagName === 'SELECT' || a.isContentEditable)) return true;
      var addForm = document.getElementById('todo-add-form');
      if (addForm && !addForm.classList.contains('hidden')) return true; // mid add-to-do
      return false;
    }
    function showPill(){
      if (document.getElementById('otp-live-pill')) return;
      var p = document.createElement('button');
      p.id = 'otp-live-pill';
      p.type = 'button';
      p.textContent = 'Refresh for new updates';
      p.style.cssText = 'position:fixed;bottom:18px;right:18px;z-index:9999;background:#1742d6;color:#fff;border:none;border-radius:999px;padding:9px 16px;font-size:13px;font-weight:600;box-shadow:0 4px 14px rgba(0,0,0,0.18);cursor:pointer;';
      p.addEventListener('click', reload);
      document.body.appendChild(p);
    }
    function apply(){
      timer = null;
      if (userBusy()) { showPill(); timer = setTimeout(apply, 4000); return; } // wait for idle
      reload();
    }
    function schedule(){ clearTimeout(timer); timer = setTimeout(apply, 1500); } // coalesce bursts
    window.OTPLive.subscribe({
      onEvent: function(env){ if (RELEVANT[env.topic]) schedule(); },
      onResync: schedule,
    });
  })();

  // --- Headlines ---
  var headlineTeamId = <%- jsonForScript(selectedTeamId || '') %>;
  var hlForm = document.getElementById('headline-form');
  if (hlForm) {
    hlForm.addEventListener('submit', function(e){
      e.preventDefault();
      var fd = new FormData(hlForm);
      var hlBody = { body: fd.get('body'), kind: fd.get('kind') };
      // Route to the team chosen in the selector; fall back to the active
      // team filter. The headline surfaces on that team's meeting via teamId.
      var _hlTeam = fd.get('teamId') || headlineTeamId;
      if (_hlTeam) hlBody.teamId = _hlTeam;
      api('POST', '/meetings/' + meetingId + '/headlines', hlBody)
        .then(reload)
        .catch(function(err){ alert('Headline failed: ' + fmtApiError(err)); });
    });
  }
  document.querySelectorAll('.headline-read-cb').forEach(function(cb){
    cb.addEventListener('change', function(){
      if (!isIntegrator) return;
      var li = cb.closest('[data-headline-id]');
      var hid = li.dataset.headlineId;
      var path = cb.checked ? '/read' : '/unread';
      api('POST', '/meetings/' + meetingId + '/headlines/' + hid + path, {})
        .then(reload)
        .catch(function(err){ cb.checked = !cb.checked; alert(fmtApiError(err)); });
    });
  });
  // Headline inline edit (author or Integrator; PUT body/kind).
  document.querySelectorAll('.headline-edit-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var li = btn.closest('[data-headline-id]');
      li.querySelector('.headline-body').classList.add('hidden');
      li.querySelector('.headline-edit-form').classList.remove('hidden');
      var inp = li.querySelector('.headline-edit-input'); if (inp) inp.focus();
    });
  });
  document.querySelectorAll('.headline-edit-cancel').forEach(function(btn){
    btn.addEventListener('click', function(){
      var li = btn.closest('[data-headline-id]');
      li.querySelector('.headline-edit-form').classList.add('hidden');
      li.querySelector('.headline-body').classList.remove('hidden');
    });
  });
  document.querySelectorAll('.headline-edit-form').forEach(function(form){
    form.addEventListener('submit', function(e){
      e.preventDefault();
      var li = form.closest('[data-headline-id]');
      var hid = li.dataset.headlineId;
      var val = li.querySelector('.headline-edit-input').value;
      api('PUT', '/meetings/' + meetingId + '/headlines/' + hid, { body: val })
        .then(reload)
        .catch(function(err){ alert('Edit failed: ' + fmtApiError(err)); });
    });
  });

  // --- Rocks: on/off track toggle ---
  document.querySelectorAll('.rock-track-toggle').forEach(function(btn){
    btn.addEventListener('click', function(){
      var li = btn.closest('[data-rock-id]');
      var rid = li.dataset.rockId;
      var current = btn.dataset.onTrack === '1';
      var next = !current;
      api('PUT', '/rocks/' + rid, { onTrack: next })
        .then(reload)
        .catch(function(err){ alert('Could not update rock: ' + fmtApiError(err)); });
    });
  });

  // --- Rock milestones ---
  // Checkbox: optimistic toggle (strike the title, repaint both chips
  // locally), revert on API failure. No reload -- checking off milestones
  // mid-review should feel instant.
  function msRepaintChips(block) {
    var total = block.querySelectorAll('.ms-check').length;
    var done = block.querySelectorAll('.ms-check:checked').length;
    // Both chips (card header + summary line) live inside the rock card.
    var scope = block.closest('[data-rock-id]') || block;
    scope.querySelectorAll('.ms-chip').forEach(function(chip){ chip.textContent = done + '/' + total; });
  }
  document.querySelectorAll('.ms-check').forEach(function(cb){
    cb.addEventListener('change', function(){
      var li = cb.closest('[data-ms-id]');
      var block = cb.closest('.ms-block');
      var checked = cb.checked;
      var titleEl = li.querySelector('.ms-title');
      // Optimistic paint.
      if (titleEl) titleEl.className = 'ms-title flex-1 break-words ' + (checked ? 'line-through text-gray-400' : 'text-gray-800');
      if (block) msRepaintChips(block);
      api('POST', '/milestones/' + li.dataset.msId + '/complete', { completed: checked })
        .catch(function(err){
          cb.checked = !checked;
          if (titleEl) titleEl.className = 'ms-title flex-1 break-words ' + (!checked ? 'line-through text-gray-400' : 'text-gray-800');
          if (block) msRepaintChips(block);
          alert('Milestone update failed: ' + fmtApiError(err));
        });
    });
  });
  // + milestone inline form (title + optional date; dueDate is a plain
  // YYYY-MM-DD string -- the API stores a calendar date, no TZ math).
  document.querySelectorAll('.ms-add-form').forEach(function(fm){
    fm.addEventListener('submit', function(e){
      e.preventDefault();
      var block = fm.closest('.ms-block');
      var rid = block ? block.dataset.msRock : '';
      var fd = new FormData(fm);
      var msBody = { title: (fd.get('title') || '').toString().trim() };
      if (!msBody.title) return;
      var msDue = (fd.get('dueDate') || '').toString();
      if (msDue) msBody.dueDate = msDue;
      api('POST', '/rocks/' + rid + '/milestones', msBody)
        .then(reload)
        .catch(function(err){ alert('Add milestone failed: ' + fmtApiError(err)); });
    });
  });
  // Per-milestone "+ to-do": owner select mirrors the My To-Dos quick-add
  // (same assignablePeople source; picking a person stamps me as delegator).
  document.querySelectorAll('.ms-todo-toggle').forEach(function(btn){
    btn.addEventListener('click', function(){
      var li = btn.closest('[data-ms-id]');
      var form = li.querySelector('.ms-todo-form');
      if (form) { form.classList.remove('hidden'); var inp = form.querySelector('input[name="title"]'); if (inp) inp.focus(); }
    });
  });
  document.querySelectorAll('.ms-todo-cancel').forEach(function(btn){
    btn.addEventListener('click', function(){
      var form = btn.closest('.ms-todo-form');
      if (form) form.classList.add('hidden');
    });
  });
  document.querySelectorAll('.ms-todo-form').forEach(function(fm){
    fm.addEventListener('submit', function(e){
      e.preventDefault();
      var li = fm.closest('[data-ms-id]');
      var fd = new FormData(fm);
      var tBody = {
        title: (fd.get('title') || '').toString().trim(),
        milestoneId: li.dataset.msId,
        ownerEntityType: 'human',
        ownerExternalId: '<%= (locals.memberClaimedEntityIds && locals.memberClaimedEntityIds[0]) || (locals.member && locals.member.email) || "self" %>',
      };
      if (!tBody.title) return;
      var ownerVal = (fd.get('owner') || '').toString();
      if (ownerVal) {
        var op = ownerVal.split(':');
        tBody.ownerEntityType = op[0];
        tBody.ownerExternalId = op[1];
        tBody.ownerName = op.slice(2).join(':');
        tBody.delegatorEntityType = <%- jsonForScript(locals.meEntityType || '') %>;
        tBody.delegatorExternalId = <%- jsonForScript(locals.meExternalId || '') %>;
        tBody.delegatorName = <%- jsonForScript(locals.meName || '') %>;
      }
      api('POST', '/todos', tBody)
        .then(reload)
        .catch(function(err){ alert('Add to-do failed: ' + fmtApiError(err)); });
    });
  });
  document.querySelectorAll('.ms-del').forEach(function(btn){
    btn.addEventListener('click', function(){
      if (!confirm('Delete this milestone? Its to-dos survive, unlinked.')) return;
      var li = btn.closest('[data-ms-id]');
      api('DELETE', '/milestones/' + li.dataset.msId)
        .then(reload)
        .catch(function(err){ alert('Delete failed: ' + fmtApiError(err)); });
    });
  });

  // --- KPIs: inline value entry ---
  // One save path, three triggers: the Save button (explicit), Enter in the
  // input (keyboard), and blur/change (auto-save convenience). David asked
  // for a visible button -- the value used to save silently on blur with no
  // affordance, which read as "no way to submit." Added 2026-05-28.
  function saveKpiValueInput(inp, btn) {
    // Guard against the double-fire race: clicking Save blurs the input,
    // which fires the debounced `change` auto-save ~300ms later. Without
    // this guard, the second call captured btn.textContent ("Saving…") as
    // its reset label and restored the button to "Saving…" forever. The
    // button-disabled check skips the redundant second save outright, and
    // the reset label is now the literal "Save" (never the live text).
    // Caught 2026-05-28 -- Recurring Monthly Revenue row stuck on Saving….
    if (btn && btn.disabled) return;
    var tr = inp.closest('[data-kpi-id]');
    if (!tr) return;
    var kid = tr.dataset.kpiId;
    var val = inp.value === '' ? null : parseFloat(inp.value);
    if (val === null || Number.isNaN(val)) { alert('Enter a number first.'); inp.focus(); return; }
    var now = new Date();
    var dow = now.getDay(); // 0 Sun .. 6 Sat
    var weekStart = new Date(now); weekStart.setDate(now.getDate() - dow); weekStart.setHours(0,0,0,0);
    var weekEnd = new Date(weekStart); weekEnd.setDate(weekStart.getDate() + 7);
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    api('POST', '/kpis/' + kid + '/values', { periodStart: weekStart.toISOString(), periodEnd: weekEnd.toISOString(), value: val, source: 'manual' })
      .then(function(){
        inp.classList.add('ring-1'); inp.classList.add('ring-emerald-400');
        setTimeout(function(){ inp.classList.remove('ring-1'); inp.classList.remove('ring-emerald-400'); }, 800);
        var latestCell = tr.querySelector('[data-kpi-latest]');
        if (latestCell) latestCell.textContent = val;
        if (btn) { btn.textContent = 'Saved ✓'; setTimeout(function(){ btn.textContent = 'Save'; btn.disabled = false; }, 1200); }
      })
      .catch(function(err){
        if (btn) { btn.disabled = false; btn.textContent = 'Save'; }
        alert('KPI save failed: ' + fmtApiError(err));
      });
  }

  document.querySelectorAll('.kpi-value-input').forEach(function(inp){
    // Enter saves immediately.
    inp.addEventListener('keydown', function(e){
      if (e.key === 'Enter') {
        e.preventDefault();
        var b = inp.closest('[data-kpi-id]').querySelector('.kpi-save-btn');
        saveKpiValueInput(inp, b);
      }
    });
    // Auto-save on blur/change preserved as a convenience.
    var debounce = null;
    inp.addEventListener('change', function(){
      clearTimeout(debounce);
      debounce = setTimeout(function(){
        var b = inp.closest('[data-kpi-id]').querySelector('.kpi-save-btn');
        saveKpiValueInput(inp, b);
      }, 300);
    });
  });
  document.querySelectorAll('.kpi-save-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var inp = btn.closest('[data-kpi-id]').querySelector('.kpi-value-input');
      saveKpiValueInput(inp, btn);
    });
  });

  // --- To-Dos ---
  var todoToggle = document.getElementById('todo-add-toggle');
  var todoForm = document.getElementById('todo-add-form');
  if (todoToggle && todoForm) {
    todoToggle.addEventListener('click', function(){ todoForm.classList.toggle('hidden'); });
    // Relabel the single date field based on whether the to-do is delegated.
    var delegateSelEl = document.getElementById('todo-delegate-to');
    var dateLabelEl = document.getElementById('todo-date-label');
    if (delegateSelEl && dateLabelEl) {
      delegateSelEl.addEventListener('change', function(){
        dateLabelEl.textContent = delegateSelEl.value ? 'Promised by' : 'Due date';
      });
    }
    var todoAttachBtn = document.getElementById('todo-add-attach');
    var todoAttachInput = document.getElementById('todo-add-files');
    var todoAttachLabel = document.getElementById('todo-add-files-label');
    if (todoAttachBtn && todoAttachInput) {
      todoAttachBtn.addEventListener('click', function(){ todoAttachInput.click(); });
      todoAttachInput.addEventListener('change', function(){
        var n = todoAttachInput.files.length;
        todoAttachLabel.textContent = n ? (n === 1 ? todoAttachInput.files[0].name : n + ' files staged') : '';
      });
    }
    todoForm.addEventListener('submit', function(e){
      e.preventDefault();
      var fd = new FormData(todoForm);
      var body = { title: fd.get('title'), ownerEntityType: 'human', ownerExternalId: '<%= (locals.memberClaimedEntityIds && locals.memberClaimedEntityIds[0]) || (locals.member && locals.member.email) || "self" %>' };
      var descVal = (fd.get('description') || '').toString().trim();
      if (descVal) body.description = descVal;
      var due = fd.get('dueAt');
      if (due) body.dueAt = new Date(due + 'T17:00:00').toISOString();
      // Recurrence: map the preset key to an RRULE. 'none' leaves it off.
      var addRecKey = (fd.get('recurrence') || '').toString();
      var addRecMap = {
        daily:    'FREQ=DAILY',
        weekdays: 'FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR',
        weekly:   'FREQ=WEEKLY',
        biweekly: 'FREQ=WEEKLY;INTERVAL=2',
        monthly:  'FREQ=MONTHLY',
        yearly:   'FREQ=YEARLY',
      };
      if (addRecMap[addRecKey]) body.recurrenceRule = addRecMap[addRecKey];
      // NOTE: do NOT auto-stamp meetingId from the page. To-dos route to a
      // meeting by teamId (the visible Team selector below), so pinning the
      // on-screen meeting only mislabels it (e.g. "From Janine 1:1" for a
      // to-do you didn't mean to put there). The Team selector is the single
      // source of truth. David flagged 2026-05-29.
      // Delegation: if a person is picked, reassign owner and stamp the delegator.
      var delegateSel = document.getElementById('todo-delegate-to');
      var delegateVal = delegateSel ? delegateSel.value : '';
      if (delegateVal) {
        var parts = delegateVal.split(':');
        body.ownerEntityType = parts[0];
        body.ownerExternalId = parts[1];
        body.ownerName = parts.slice(2).join(':');
        body.delegatorEntityType = <%- jsonForScript(locals.meEntityType || '') %>;
        body.delegatorExternalId = <%- jsonForScript(locals.meExternalId || '') %>;
        body.delegatorName = <%- jsonForScript(locals.meName || '') %>;
      }
      // Team scoping: if a team is picked, this becomes an L10 (team) to-do.
      var teamSel = document.getElementById('todo-team-select');
      var teamVal = teamSel ? teamSel.value : '';
      if (teamVal) {
        body.teamId = teamVal;
        body.kind = 'l10';
      }
      api('POST', '/todos', body).then(function(j){
        // Staged files upload against the new todo id, then the page reloads.
        var files = todoAttachInput ? Array.prototype.slice.call(todoAttachInput.files) : [];
        var newId = j && j.todo && j.todo.id;
        if (!files.length || !newId || !window.OTPAttachments) return;
        var failed = [];
        var chain = Promise.resolve();
        files.forEach(function(f){
          chain = chain.then(function(){
            return window.OTPAttachments.uploadTo('todo', newId, f).catch(function(err){
              failed.push(f.name + ' (' + ((err && err.message) || 'failed') + ')');
            });
          });
        });
        return chain.then(function(){
          if (failed.length) alert('To-do saved, but these files did not attach:\n' + failed.join('\n'));
        });
      }).then(reload).catch(function(err){ alert('Add to-do failed: ' + fmtApiError(err)); });
