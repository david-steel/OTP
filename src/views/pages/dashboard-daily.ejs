  // Build SMART: "+" in the Quarterly Priorities tile header. Creates a
  // placeholder rock owned by the current member (same owner source as the
  // dashboard's quick-add), for the current quarter with a quarter-end due
  // date, then routes to /rocks/:id/smart so the user lands in the planner.
  (function(){
    var buildBtn = document.getElementById('rocks-build-smart');
    if (!buildBtn) return;
    var SMART_OWNER = '<%= (locals.memberClaimedEntityIds && locals.memberClaimedEntityIds[0]) || (locals.member && locals.member.email) || "self" %>';
    function quarterEndIso(q){
      // q is "YYYY-Qn". Quarter end = last day of the quarter's 3rd month.
      var m = /^(\d{4})-Q([1-4])$/.exec(q || '');
      var now = new Date();
      var year = m ? Number(m[1]) : now.getUTCFullYear();
      var qn = m ? Number(m[2]) : (Math.floor(now.getUTCMonth() / 3) + 1);
      var endMonth = qn * 3; // 3,6,9,12
      // Day 0 of next month = last day of endMonth. Noon UTC to dodge TZ edges.
      return new Date(Date.UTC(year, endMonth, 0, 12, 0, 0)).toISOString();
    }
    buildBtn.addEventListener('click', function(e){
      e.preventDefault(); e.stopPropagation();
      buildBtn.disabled = true;
      api('POST', '/rocks', {
        ownerEntityType: 'human',
        ownerExternalId: SMART_OWNER,
        title: 'New Quarterly Priority',
        quarter: quarter,
        dueDate: quarterEndIso(quarter),
      }).then(function(res){
        var id = res && res.rock && res.rock.id;
        if (id) { window.location.href = '/rocks/' + id + '/smart'; }
        else { buildBtn.disabled = false; alert('Could not create priority.'); }
      }).catch(function(err){ buildBtn.disabled = false; alert('Create failed: ' + fmtApiError(err)); });
    });
  })();
