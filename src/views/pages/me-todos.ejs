      btn.disabled = false;
      alert('Could not add: ' + err.message);
    }
  });
})();

// ---- Swipe-left-to-complete on each todo card -----------------------
(function wireSwipeToComplete() {
  // Only worth wiring on touch devices.
  if (!('ontouchstart' in window)) return;
  var THRESHOLD = 90;  // px the user has to drag left before release fires Done
  var MAX = 220;        // clamp transform so the card can't fly off entirely

  document.querySelectorAll('.me-card[data-id]').forEach(function(card) {
    // Wrap existing children in a .me-card-body so we can transform
    // it independently of the .me-swipe-bg sibling we're about to add.
    if (!card.querySelector('.me-card-body')) {
      var bg = document.createElement('div');
      bg.className = 'me-swipe-bg';
      bg.textContent = '✓ Done';
      var body = document.createElement('div');
      body.className = 'me-card-body';
      while (card.firstChild) body.appendChild(card.firstChild);
      card.appendChild(bg);
      card.appendChild(body);
    }
    var body = card.querySelector('.me-card-body');

    var startX = 0, startY = 0, dx = 0, dy = 0, isSwiping = false, locked = false;

    card.addEventListener('touchstart', function(e) {
      // Ignore swipes that start on a button / link / input.
      var t = e.target;
      if (t.closest && t.closest('button, a, input, select, textarea, .me-desc-toggle')) return;
      var p = e.touches[0];
      startX = p.clientX; startY = p.clientY; dx = 0; dy = 0;
      isSwiping = true; locked = false;
    }, { passive: true });

    card.addEventListener('touchmove', function(e) {
      if (!isSwiping) return;
      var p = e.touches[0];
      dx = p.clientX - startX;
      dy = p.clientY - startY;
      if (!locked) {
        // First decisive movement decides whether this is a swipe or a
        // vertical scroll. Once locked vertical, stay out of the way.
        if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 6) { isSwiping = false; return; }
        if (Math.abs(dx) > 6) locked = true;
      }
      if (!locked) return;
      // Only animate left-swipes; right-swipes do nothing.
      var clamped = Math.max(-MAX, Math.min(0, dx));
      card.classList.add('swiping');
      body.style.transform = 'translateX(' + clamped + 'px)';
    }, { passive: true });

    card.addEventListener('touchend', function() {
      if (!isSwiping) return;
      isSwiping = false;
      card.classList.remove('swiping');
      if (dx < -THRESHOLD) {
        // Fly out, then trigger the existing markDone path on this card's
        // Done button so optimistic UI + audit logging stay consistent.
        body.style.transform = 'translateX(-100%)';
        var doneBtn = card.querySelector('.me-actions .me-btn.primary');
        if (doneBtn) {
          // The existing markDone(btn, id) handler reads id from the
          // bound onclick attribute -- so we just .click() it.
          setTimeout(function() { doneBtn.click(); }, 160);
        } else {
          // No Done button (shouldn't happen) -- snap back.
          body.style.transform = '';
        }
      } else {
        body.style.transform = '';
      }
    });

    card.addEventListener('touchcancel', function() {
      isSwiping = false;
      card.classList.remove('swiping');
      body.style.transform = '';
    });
  });
})();

// ---- PWA install nudge ----------------------------------------------
(function wireInstall() {
  var banner = document.getElementById('me-install');
  var goBtn = document.getElementById('me-install-go');
  var dismissBtn = document.getElementById('me-install-dismiss');
  if (!banner) return;

  // Don't show in standalone (already installed).
  if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone) return;

  var DISMISS_KEY = 'otp-install-nudge-dismissed';
  if (localStorage.getItem(DISMISS_KEY)) return;

  var deferredPrompt = null;

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    banner.classList.add('shown');
  });

  // iOS Safari doesn't fire beforeinstallprompt -- show the nudge with
  // a tap-to-instructions fallback on the second visit.
  var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
  if (isIOS) {
    var visits = parseInt(localStorage.getItem('otp-me-visits') || '0', 10) + 1;
    localStorage.setItem('otp-me-visits', String(visits));
    if (visits >= 2) {
      goBtn.textContent = 'How';
      banner.classList.add('shown');
    }
  }

  goBtn.addEventListener('click', async function() {
    if (deferredPrompt) {
      deferredPrompt.prompt();
      try { await deferredPrompt.userChoice; } catch (e) { /* user dismissed */ }
      deferredPrompt = null;
      banner.classList.remove('shown');
      localStorage.setItem(DISMISS_KEY, '1');
    } else if (isIOS) {
      alert('In Safari: tap the Share button, then "Add to Home Screen".');
      localStorage.setItem(DISMISS_KEY, '1');
      banner.classList.remove('shown');
    }
  });
  dismissBtn.addEventListener('click', function() {
    banner.classList.remove('shown');
    localStorage.setItem(DISMISS_KEY, '1');
  });
})();
</script>

<%
function humanAgo(d) {
  const ms = Date.now() - d.getTime();
  const mins = Math.floor(ms / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days < 7) return days + 'd ago';
  return d.toLocaleDateString();
}
%>

<script>
// Disposition: delegator closes out a to-do its owner never finished.
(function () {
  document.querySelectorAll('.waiting-closeout').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (!confirm('Close this out yourself? It will be marked done and verified, and the owner will be notified.')) return;
      var id = btn.getAttribute('data-todo-id');
      btn.disabled = true;
      fetch('/api/v1/todos/' + encodeURIComponent(id), {
        method: 'PUT',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ done: true, verified: true }),
      }).then(function (r) {
        if (r.ok) { location.reload(); }
        else { btn.disabled = false; alert('Could not close this out (' + r.status + ').'); }
      }).catch(function () { btn.disabled = false; alert('Could not close this out.'); });
    });
  });
})();
</script>

