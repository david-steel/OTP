<% /* XSS guard: embed a value in an inline <script> via jsonForScript() -- escapes < and > so a value containing </script> can't break out of the script context (stored-XSS guard). */ function jsonForScript(v){ return JSON.stringify(v === undefined ? null : v).replace(/</g,'\\u003c').replace(/>/g,'\\u003e'); } %>
<style>
  body { background: #fafaf9; }
  .me-wrap { max-width: 680px; margin: 0 auto; padding: 16px 12px 80px; }
  .me-h { padding: 8px 4px 16px; }
  .me-h h1 { margin: 0 0 4px; font-size: 22px; font-weight: 700; color: #111; }
  .me-h .sub { color: #666; font-size: 14px; }
  .me-card {
    background: #fff;
    border: 1px solid #e7e5e4;
    border-radius: 12px;
    padding: 16px;
    margin: 12px 0;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .me-card.red { border-left: 4px solid #dc2626; }
  .me-card.agent { border-left: 4px solid #6b46c1; }
  .me-card.done { opacity: 0.5; }
  .me-title {
    font-size: 16px; font-weight: 600; color: #111; line-height: 1.35;
    margin: 0 0 8px;
    word-wrap: break-word;
  }
  .me-meta { display: flex; gap: 8px; flex-wrap: wrap; font-size: 12px; color: #666; margin-bottom: 10px; }
  .me-tag { padding: 2px 8px; border-radius: 999px; background: #f3f0ff; color: #6b46c1; font-weight: 600; font-size: 11px; }
  .me-tag.red { background: #fee2e2; color: #dc2626; }
  .me-desc {
    font-size: 14px; color: #333; line-height: 1.5; margin: 8px 0 4px;
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 4.5em;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }
  .me-desc.expanded {
    max-height: none;
  }
  .me-desc:not(.expanded)::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5em;
    background: linear-gradient(to bottom, transparent, #fff);
    pointer-events: none;
  }
  .me-desc-toggle {
    font-size: 12px; color: #6b46c1; font-weight: 600; cursor: pointer;
    padding: 4px 0; margin-bottom: 8px;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }
  .me-desc code {
    background: #f5f5f4; padding: 2px 5px; border-radius: 4px;
    font-size: 12px; font-family: ui-monospace, SFMono-Regular, monospace;
    word-break: break-all;
  }
  .me-actions { display: flex; gap: 8px; margin-top: 8px; }
  .me-btn {
    flex: 1; padding: 12px 12px;
    border-radius: 8px; border: none;
    font-size: 14px; font-weight: 600;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    min-height: 44px;
  }
  .me-btn.primary { background: #6b46c1; color: #fff; }
  .me-btn.primary:active { background: #553c9a; }
  .me-btn.secondary { background: #f5f5f4; color: #555; }
  .me-btn.secondary:active { background: #e7e5e4; }
  .me-btn.danger { background: #fee2e2; color: #dc2626; }
  .me-btn.danger:active { background: #dc2626; color: #fff; }
  .me-btn.danger.confirm { background: #dc2626; color: #fff; }
  .me-btn[disabled] { opacity: 0.5; cursor: not-allowed; }

  .me-edit { margin-top: 12px; display: none; }
  .me-edit.open { display: block; }
  .me-edit label { display: block; font-size: 12px; font-weight: 600; color: #666; margin: 8px 0 4px; text-transform: uppercase; letter-spacing: 0.4px; }
  .me-edit input, .me-edit textarea {
    width: 100%; box-sizing: border-box;
    padding: 10px 12px; font-size: 15px;
    border: 1px solid #d4d4d8; border-radius: 8px;
    background: #fff; color: #111;
    font-family: inherit;
    -webkit-appearance: none;
  }
  .me-edit textarea { min-height: 100px; resize: vertical; line-height: 1.45; }
  .me-edit input:focus, .me-edit textarea:focus { outline: none; border-color: #6b46c1; box-shadow: 0 0 0 3px rgba(107,70,193,0.15); }

  .me-empty {
    padding: 48px 24px; text-align: center; color: #888;
    background: #fff; border: 1px solid #e7e5e4; border-radius: 12px;
  }
  .me-empty .big { font-size: 32px; margin-bottom: 8px; }
  .me-section-h {
    font-size: 13px; font-weight: 700; text-transform: uppercase;
    color: #888; letter-spacing: 0.5px;
    margin: 24px 4px 8px;
  }
  .me-foot {
    text-align: center; color: #999; font-size: 12px; margin-top: 32px;
  }
  .me-foot a { color: #6b46c1; }
  @media (prefers-color-scheme: dark) {
    body { background: #18181b; }
    .me-h h1 { color: #fafafa; }
    .me-h .sub { color: #a1a1aa; }
    .me-card { background: #27272a; border-color: #3f3f46; }
    .me-title { color: #fafafa; }
    .me-desc { color: #d4d4d8; }
    .me-desc code { background: #18181b; }
    .me-btn.secondary { background: #3f3f46; color: #d4d4d8; }
    .me-btn.danger { background: #450a0a; color: #fca5a5; }
    .me-empty { background: #27272a; border-color: #3f3f46; color: #a1a1aa; }
    .me-meta { color: #a1a1aa; }
    .me-edit input, .me-edit textarea { background: #18181b; border-color: #3f3f46; color: #fafafa; }
    .me-edit label { color: #a1a1aa; }
  }
  /* Priority dot — sits at the left of each card meta row */
  .me-prio { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; }
  .me-prio.p1 { background: #e94b6a; }     /* danger red */
  .me-prio.p2 { background: #fbbf24; }     /* warm gold */
  .me-prio.p3 { background: #9ca3af; }     /* neutral */
  .me-prio.p4 { background: #d1d5db; opacity: 0.7; }
  @media (prefers-color-scheme: dark) {
    .me-prio.p3 { background: #6b7280; }
    .me-prio.p4 { background: #4b5563; }
  }
  .me-recur { display: inline-block; margin-left: 6px; font-size: 11px; color: #6b7280; }
  .me-recur::before { content: "↻ "; }
  .me-section-l10 { margin-top: 24px; padding: 12px 14px; border-left: 3px solid #6366f1; background: #eef2ff; border-radius: 6px; }
  @media (prefers-color-scheme: dark) {
    .me-section-l10 { background: #1e1b4b; }
  }
  .me-section-l10 .l10-title { font-size: 12px; font-weight: 700; color: #4338ca; text-transform: uppercase; letter-spacing: 0.08em; }
  @media (prefers-color-scheme: dark) {
    .me-section-l10 .l10-title { color: #a5b4fc; }
  }
  /* Create form */
  .me-create-card { background: #ffffff; border: 1px solid #e4e4e7; border-radius: 12px; padding: 12px 14px; margin-bottom: 16px; box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
  .me-create-title { width: 100%; border: none; outline: none; font-size: 17px; font-weight: 600; padding: 6px 0; background: transparent; color: inherit; }
  .me-create-desc { width: 100%; border: none; outline: none; resize: none; min-height: 32px; max-height: 120px; padding: 4px 0 8px; background: transparent; color: inherit; font-size: 14px; font-family: inherit; }
  .me-create-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; padding-top: 10px; border-top: 1px solid #f4f4f5; }
  .me-create-row select, .me-create-row input[type="datetime-local"] { border: 1px solid #e4e4e7; background: #fafafa; border-radius: 6px; padding: 6px 8px; font-size: 13px; color: inherit; }
  .me-create-row .me-btn { margin-left: auto; }
  @media (prefers-color-scheme: dark) {
    .me-create-card { background: #18181b; border-color: #27272a; box-shadow: none; }
    .me-create-row { border-top-color: #27272a; }
    .me-create-row select, .me-create-row input[type="datetime-local"] { background: #27272a; border-color: #3f3f46; color: #fafafa; }
  }
  /* Edit form upgrades (priority/date/recur/meeting selectors live inline) */
  .me-edit-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
  .me-edit-row select, .me-edit-row input[type="datetime-local"] { border: 1px solid #d4d4d8; background: #fafafa; border-radius: 6px; padding: 6px 8px; font-size: 13px; color: inherit; }
  @media (prefers-color-scheme: dark) {
    .me-edit-row select, .me-edit-row input[type="datetime-local"] { background: #27272a; border-color: #3f3f46; color: #fafafa; }
  }

  /* =================================================================
     Mobile rebuild (2026-05-25): thumb-reachable sticky add bar at
     the bottom of the viewport, swipe-left-to-complete on cards, and
     a single-tap PWA install banner. Desktop layout is unchanged --
     the bar and FAB are display:none above 760px. */

  /* Sticky bottom bar: position fixed, safe-area inset, always visible. */
  .me-mobile-add {
    display: none;
    position: fixed; left: 0; right: 0; bottom: 0;
    background: #ffffff;
    border-top: 1px solid #e7e5e4;
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom)) 12px;
    box-shadow: 0 -4px 16px rgba(15,23,42,0.08);
    z-index: 40;
  }
  .me-mobile-add form { display: flex; gap: 8px; align-items: center; }
  .me-mobile-add input {
    flex: 1; min-height: 44px;
    border: 1px solid #d4d4d8; border-radius: 10px;
    padding: 0 14px; font-size: 16px;  /* >=16px stops iOS zoom on focus */
    background: #fafafa; color: inherit;
    -webkit-appearance: none;
  }
  .me-mobile-add input:focus { outline: none; border-color: #8BC42A; box-shadow: 0 0 0 3px rgba(168,230,58,0.25); background: #fff; }
  .me-mobile-add button {
    min-height: 44px; min-width: 56px;
    border: none; border-radius: 10px;
    background: #A8E63A; color: #14161c;
    font-size: 15px; font-weight: 700;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .me-mobile-add button:active { background: #8BC42A; }
  .me-mobile-add button[disabled] { opacity: 0.6; }
  @media (prefers-color-scheme: dark) {
    .me-mobile-add { background: #18181b; border-top-color: #27272a; box-shadow: 0 -4px 16px rgba(0,0,0,0.3); }
    .me-mobile-add input { background: #27272a; border-color: #3f3f46; color: #fafafa; }
    .me-mobile-add input:focus { background: #18181b; }
  }

  /* Swipe-to-complete: the card sits over a green "Done" zone that
     reveals as the user drags left. Past 100px, releasing fires
     markDone. The transform comes off touchmove; the snap-back /
     fly-out comes off touchend. */
  .me-card[data-id] { position: relative; touch-action: pan-y; }
  .me-card[data-id] .me-swipe-bg {
    position: absolute; inset: 0;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: flex-end;
    padding-right: 24px;
    background: linear-gradient(90deg, transparent 0%, #A8E63A 60%, #8BC42A 100%);
    color: #14161c; font-weight: 700; font-size: 15px;
    opacity: 0; pointer-events: none;
    transition: opacity 120ms ease;
  }
  .me-card[data-id].swiping { transition: none; }
  .me-card[data-id].swiping .me-swipe-bg { opacity: 1; }
  .me-card[data-id] .me-card-body { background: inherit; border-radius: inherit; position: relative; transition: transform 200ms cubic-bezier(0.4, 0.0, 0.2, 1); }
  .me-card[data-id].swiping .me-card-body { transition: none; }

  /* Mobile-only layout swaps. */
  @media (max-width: 760px) {
    .me-wrap { padding-bottom: 90px; }  /* clear the sticky bar */
    .me-mobile-add { display: block; }
    /* Hide the desktop create card on mobile -- the sticky bar is the
       way you add. Power features (priority, due date, delegation,
       recurrence) live in the per-card Edit drawer instead. */
    .me-create-card { display: none; }
  }

  /* PWA install nudge: shows once if the browser supports
     beforeinstallprompt, hidden via .hidden class until JS reveals it. */
  .me-install {
    display: none;
    margin: 12px 4px 0;
    padding: 10px 12px;
    border-radius: 10px;
    background: #ECFCCB; color: #14161c;
    border: 1px solid #A8E63A;
    font-size: 13px;
    align-items: center; gap: 10px;
  }
  .me-install.shown { display: flex; }
  .me-install button {
    margin-left: auto;
    min-height: 36px; padding: 0 12px;
    border: none; border-radius: 8px;
    background: #A8E63A; color: #14161c;
    font-size: 13px; font-weight: 700;
    cursor: pointer;
  }
  .me-install .me-install-dismiss {
    background: transparent; color: #14161c; padding: 6px 8px;
    font-weight: 500;
  }
</style>

<div class="me-wrap">
  <div class="me-h">
    <h1>Your queue <button type="button" class="help-q" data-help="page.todos" aria-label="About your to-do queue">?</button></h1>
    <div class="sub"><%= todos.length %> open · drafted by you and your AI agents · triage from your phone</div>
  </div>

  <!-- New todo create form -->
  <div class="me-create-card">
    <input id="new-todo-title" type="text" placeholder="What needs to happen?" maxlength="500" class="me-create-title" />
    <%- include('../partials/rich-description-editor', { targetId: 'new-todo-desc' }) %>
    <textarea id="new-todo-desc" placeholder="Description (optional). Markdown supported: **bold**, *italic*, [link](https://...)" class="me-create-desc"></textarea>
    <div class="me-create-row">
      <select id="new-todo-priority" title="Priority">
        <option value="p1">P1 critical</option>
        <option value="p2">P2 high</option>
        <option value="p3" selected>P3 normal</option>
        <option value="p4">P4 low</option>
      </select>
      <label id="me-date-label" for="new-todo-quickdate" style="font-size:13px; color:#666;">When</label>
      <select id="new-todo-quickdate" title="When">
        <option value="">No date</option>
        <option value="today-afternoon">This afternoon</option>
        <option value="today-evening">Tonight</option>
        <option value="tomorrow-am">Tomorrow morning</option>
        <option value="tomorrow-pm">Tomorrow afternoon</option>
        <option value="end-of-week">End of week (Fri 5pm)</option>
        <option value="next-week">Next Monday</option>
        <option value="custom">Custom...</option>
      </select>
      <input id="new-todo-custom-date" type="datetime-local" style="display:none;" />
      <label for="new-todo-delegate" style="font-size:13px; color:#666;">Assign to <span style="color:#999;">(pick one or more; none = just you)</span></label>
      <select id="new-todo-delegate" title="Assign to one or more people. Each person gets their own copy of this to-do." multiple size="3" style="min-width:150px;">
        <% (assignablePeople || []).forEach(function(p) { %>
          <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>"><%= p.name %></option>
        <% }); %>
      </select>
      <select id="new-todo-recur" title="Recurrence">
        <option value="">No repeat</option>
        <option value="FREQ=DAILY">Daily</option>
        <option value="FREQ=WEEKLY">Weekly</option>
        <option value="FREQ=WEEKLY;BYDAY=MO,WE,FR">M / W / F</option>
        <option value="FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR">Weekdays</option>
        <option value="FREQ=MONTHLY">Monthly</option>
      </select>
      <% if (upcomingMeetings && upcomingMeetings.length > 0) { %>
        <select id="new-todo-meeting" title="Attach to a meeting (makes it an L10 todo)">
          <option value="">No meeting (personal)</option>
          <% upcomingMeetings.forEach(function(m) {
            const d = new Date(m.scheduledAt);
            const label = (m.teamName || 'meeting') + ' · ' + d.toLocaleDateString(undefined,{weekday:'short',month:'short',day:'numeric'}) + ' · ' + m.title;
          %>
            <option value="<%= m.id %>:<%= m.teamId || '' %>"><%= label %></option>
          <% }); %>
        </select>
      <% } %>
      <button class="me-btn primary" onclick="createTodo(this)">Add to queue</button>
    </div>
  </div>

  <% if ((delegatedVerify || []).length > 0) { %>
    <div class="me-card" style="border-left:4px solid #f59e0b; background:#fffbeb;">
      <h2 class="me-title">⚠ Verify these happened (<%= (delegatedVerify || []).length %>) <button type="button" class="help-q" data-help="page.todosVerify" aria-label="About verification">?</button></h2>
      <% (delegatedVerify || []).forEach(function(t) { %>
        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #fde68a;">
          <div style="font-weight: 600; color: #111;"><%= t.title %></div>
          <div class="me-meta"><span><%= t.ownerName || 'someone' %> marked done</span></div>
          <div class="me-actions">
            <button class="me-btn primary" onclick="verifyTodo(this,'<%= t.id %>')">Verify</button>
            <button class="me-btn secondary" onclick="reopenTodo(this,'<%= t.id %>')">Reopen</button>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <% if (todos.length === 0) { %>
    <div class="me-empty">
      <div class="big">✓</div>
      <div style="font-size: 18px; font-weight: 600; color: inherit;">Nothing on your queue.</div>
      <div style="margin-top: 4px;">Agents flag action items here when they need you.</div>
    </div>
  <% } %>

  <% todos.forEach(function(t) {
    const title = t.title || '';
    const isWatchdogRed = title.includes('🔴') || title.startsWith('[Watchdog');
    const tagMatch = title.match(/^\[([^\]]+)\]\s*/);
    const tagText = tagMatch ? tagMatch[1] : null;
    const cleanTitle = tagMatch ? title.slice(tagMatch[0].length) : title;
    const desc = t.description || '';
    const created = t.createdAt ? new Date(t.createdAt) : null;
    const ago = created ? humanAgo(created) : '';
  %>
    <div class="me-card <%= isWatchdogRed ? 'red' : (tagText ? 'agent' : '') %>" data-id="<%= t.id %>" data-title="<%= encodeURIComponent(title) %>" data-desc="<%= encodeURIComponent(desc) %>">
      <div class="me-view">
        <div class="me-meta">
          <span class="me-prio <%= t.priority || 'p3' %>" title="priority <%= t.priority || 'p3' %>"></span>
          <% if (tagText) { %><span class="me-tag <%= isWatchdogRed ? 'red' : '' %>"><%= tagText %></span><% } %>
          <% if (ago) { %><span><%= ago %></span><% } %>
          <% if (t.recurrenceParentId) { %><span class="me-recur">recurring instance</span><% } %>
        </div>
        <h2 class="me-title"><%= cleanTitle %></h2>
        <% var dueHistory = t.dueAtHistory || []; %>
        <% if (dueHistory.length > 0) { %>
          <div class="me-meta" style="margin-top:-4px;">
            <% dueHistory.forEach(function(h) {
              var fromTxt = h.from ? new Date(h.from).toLocaleDateString() : 'none';
              var toTxt = h.to ? new Date(h.to).toLocaleDateString() : 'none';
              var atTxt = h.at ? new Date(h.at).toLocaleDateString() : '';
            %>
              <span>📅 date changed: <%= fromTxt %> → <%= toTxt %><%= atTxt ? ' (' + atTxt + ')' : '' %></span>
            <% }); %>
          </div>
        <% } %>
        <% if (desc) { %>
          <div class="me-desc" onclick="toggleDesc(this)"><%- renderDescription(desc) %></div>
          <% if (desc.length > 120 || (desc.match(/\n/g) || []).length > 2) { %>
            <div class="me-desc-toggle" onclick="toggleDesc(this.previousElementSibling)">Tap description to expand</div>
          <% } %>
        <% } %>
        <div data-att-host data-att-type="todo" data-att-id="<%= t.id %>"></div>
        <div class="me-actions">
          <button class="me-btn secondary" onclick="openEdit(this)">Edit</button>
          <button class="me-btn primary" onclick="markDone(this, '<%= t.id %>')">Done</button>
          <button class="me-btn secondary" onclick="promoteToL10(this, '<%= t.id %>')" title="Send this to the leadership L10">→ L10</button>
          <button class="me-btn danger" onclick="confirmDelete(this, '<%= t.id %>')">Delete</button>
        </div>
      </div>
      <div class="me-edit">
        <label>Title</label>
        <input type="text" class="me-edit-title" value="<%= title %>" maxlength="500" />
        <label>Description</label>
        <textarea class="me-edit-desc"><%= desc %></textarea>
        <div class="me-edit-row">
          <select class="me-edit-priority" title="Priority">
            <% ['p1','p2','p3','p4'].forEach(function(p) { %>
              <option value="<%= p %>" <%= (t.priority || 'p3') === p ? 'selected' : '' %>><%= p.toUpperCase() %></option>
            <% }); %>
          </select>
          <input type="datetime-local" class="me-edit-due" value="<%= t.dueAt ? new Date(t.dueAt).toISOString().slice(0,16) : '' %>" />
          <select class="me-edit-recur" title="Recurrence">
            <option value="" <%= !t.recurrenceRule ? 'selected' : '' %>>No repeat</option>
            <option value="FREQ=DAILY" <%= t.recurrenceRule === 'FREQ=DAILY' ? 'selected' : '' %>>Daily</option>
            <option value="FREQ=WEEKLY" <%= t.recurrenceRule === 'FREQ=WEEKLY' ? 'selected' : '' %>>Weekly</option>
            <option value="FREQ=WEEKLY;BYDAY=MO,WE,FR" <%= t.recurrenceRule === 'FREQ=WEEKLY;BYDAY=MO,WE,FR' ? 'selected' : '' %>>M / W / F</option>
            <option value="FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR" <%= t.recurrenceRule === 'FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR' ? 'selected' : '' %>>Weekdays</option>
            <option value="FREQ=MONTHLY" <%= t.recurrenceRule === 'FREQ=MONTHLY' ? 'selected' : '' %>>Monthly</option>
          </select>
          <select class="me-edit-reassign" title="Reassign to">
            <option value="">Keep with me</option>
            <% (assignablePeople || []).forEach(function(p) { %>
              <option value="<%= p.entityType %>:<%= p.externalId %>:<%= p.name %>"><%= p.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="me-actions">
          <button class="me-btn secondary" onclick="cancelEdit(this)">Cancel</button>
          <button class="me-btn primary" onclick="saveEdit(this, '<%= t.id %>')">Save</button>
        </div>
      </div>
    </div>
  <% }); %>

  <% if ((delegatedWaiting || []).length > 0) { %>
    <div class="me-section-h">Waiting on others</div>
    <% (delegatedWaiting || []).forEach(function(t) { %>
      <div class="me-card">
        <h2 class="me-title"><%= t.title %></h2>
        <div class="me-meta">
          <span>waiting on <%= t.ownerName || 'someone' %></span>
          <% if (t.dueAt) { %><span>promised <%= new Date(t.dueAt).toLocaleDateString() %></span><% } %>
        </div>
        <div style="margin-top:8px;">
          <button type="button" class="waiting-closeout" data-todo-id="<%= t.id %>" style="font-size:12px; font-weight:600; color:#6b7280; background:#fff; border:1px solid #e5e7eb; border-radius:6px; padding:4px 10px; cursor:pointer;" title="They never closed it? Disposition it yourself: marks the to-do done and verified, and notifies them.">Close it out</button>
        </div>
      </div>
    <% }); %>
  <% } %>

  <% if (l10Todos && l10Todos.length > 0) { %>
    <div class="me-section-l10">
      <div class="l10-title"><%= l10Todos.length %> L10 to-do<%= l10Todos.length === 1 ? '' : 's' %> assigned to you</div>
      <div style="font-size: 13px; color: inherit; margin-top: 4px;">
        Action items from leadership team meetings. Manage in <a href="/l8">/l8</a>.
      </div>
      <% l10Todos.forEach(function(t) { %>
        <div style="margin-top: 10px; padding: 10px 12px; background: rgba(255,255,255,0.5); border-radius: 6px;">
          <div class="me-meta">
            <span class="me-prio <%= t.priority || 'p3' %>"></span>
            <% if (t.dueAt) { %><span>due <%= new Date(t.dueAt).toLocaleDateString() %></span><% } %>
          </div>
          <div style="font-weight: 600; margin-top: 2px;"><%= t.title %></div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <% if (justDone && justDone.length > 0) { %>
    <div class="me-section-h">Closed last 24h</div>
    <% justDone.forEach(function(t) { %>
      <div class="me-card done">
        <div class="me-meta"><span>✓ <%= t.doneAt ? humanAgo(new Date(t.doneAt)) : '' %></span></div>
        <h2 class="me-title" style="text-decoration: line-through;"><%= t.title %></h2>
      </div>
    <% }); %>
  <% } %>

  <div class="me-foot">
    OTP · <a href="/dashboard">Daily dashboard</a> · <a href="/dashboard/kpis">KPIs</a>
  </div>

  <!-- PWA install nudge (hidden until JS reveals it once
       beforeinstallprompt fires or, for iOS Safari, on the second
       visit). Sits inside .me-wrap so the bottom bar covers it
       without overlap. -->
  <div id="me-install" class="me-install" role="region" aria-label="Install OTP">
    <span><strong>Install OTP</strong> on your home screen for one-tap todo capture.</span>
    <button id="me-install-go" type="button">Install</button>
    <button id="me-install-dismiss" type="button" class="me-install-dismiss" aria-label="Dismiss">Later</button>
  </div>
</div>

<!-- Sticky bottom add bar (mobile-only, hidden >760px). One title
     input + send button. Power features (priority / due date /
     delegation / recurrence) live in the desktop create card and in
     each todo's Edit drawer -- the mobile bar is for capture speed,
     not configuration. -->
<div class="me-mobile-add" role="region" aria-label="Quick add to-do">
  <form id="me-mobile-add-form" autocomplete="off">
    <input id="me-mobile-add-input" type="text" name="title" placeholder="Add a to-do..." maxlength="500" enterkeyhint="send" />
    <button type="submit" id="me-mobile-add-btn">Add</button>
  </form>
</div>

<script>
function toggleDesc(el) {
  el.classList.toggle('expanded');
  const next = el.nextElementSibling;
  if (next && next.classList && next.classList.contains('me-desc-toggle')) {
    next.textContent = el.classList.contains('expanded') ? 'Tap to collapse' : 'Tap description to expand';
  }
}

function openEdit(btn) {
  const card = btn.closest('.me-card');
  if (!card) return;
  card.querySelector('.me-view').style.display = 'none';
  card.querySelector('.me-edit').classList.add('open');
  const titleInput = card.querySelector('.me-edit-title');
  if (titleInput) titleInput.focus();
}

function cancelEdit(btn) {
  const card = btn.closest('.me-card');
  if (!card) return;
  card.querySelector('.me-edit').classList.remove('open');
  card.querySelector('.me-view').style.display = '';
  const origTitle = decodeURIComponent(card.dataset.title || '');
  const origDesc = decodeURIComponent(card.dataset.desc || '');
  const ti = card.querySelector('.me-edit-title');
  const td = card.querySelector('.me-edit-desc');
  if (ti) ti.value = origTitle;
  if (td) td.value = origDesc;
}

async function saveEdit(btn, id) {
  const card = btn.closest('.me-card');
  if (!card) return;
  const title = card.querySelector('.me-edit-title').value.trim();
  const description = card.querySelector('.me-edit-desc').value;
  if (!title) { alert('Title cannot be empty.'); return; }
  const priority = (card.querySelector('.me-edit-priority') || {}).value || undefined;
  const dueStr = (card.querySelector('.me-edit-due') || {}).value || '';
  const dueAt = dueStr ? new Date(dueStr).toISOString() : null;
  const recurrenceRule = (card.querySelector('.me-edit-recur') || {}).value || null;
  const body = { title, description, priority, dueAt, recurrenceRule };
  // Reassign: if a person is picked, transfer ownership to them and stamp
  // the current user as the delegator. Value format is
  // "<entityType>:<externalId>:<name>". "Keep with me" sends nothing.
  const reassignVal = (card.querySelector('.me-edit-reassign') || {}).value || '';
  if (reassignVal) {
    const parts = reassignVal.split(':');
    body.ownerEntityType = parts[0];
    body.ownerExternalId = parts[1];
    body.ownerName = parts.slice(2).join(':');
    body.delegatorEntityType = <%- jsonForScript(meEntityType || 'human') %>;
    body.delegatorExternalId = <%- jsonForScript(meExternalId || '') %>;
    body.delegatorName = <%- jsonForScript(meName || '') %>;
  }
  btn.disabled = true;
  btn.textContent = 'Saving...';
  try {
    const r = await fetch('/api/v1/todos/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    card.dataset.title = encodeURIComponent(title);
    card.dataset.desc = encodeURIComponent(description);
    location.reload();
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Save';
    alert('Could not save: ' + e.message);
  }
}

// Map the quick-date preset enum to an actual JS Date. Returns null for the
// blank option. Custom returns whatever the user typed in the datetime-local
// input (or null if empty).
function resolveQuickDate(preset, customStr) {
  const now = new Date();
  function atHour(date, h, m = 0) {
    const d = new Date(date);
    d.setHours(h, m, 0, 0);
    return d;
  }
  function addDays(n) {
    const d = new Date(now);
    d.setDate(d.getDate() + n);
    return d;
  }
  switch (preset) {
    case '': return null;
    case 'today-afternoon': return atHour(now, 15);
    case 'today-evening':   return atHour(now, 19);
    case 'tomorrow-am':     return atHour(addDays(1), 9);
    case 'tomorrow-pm':     return atHour(addDays(1), 15);
    case 'end-of-week': {
      // Friday 5pm. If today is past Fri 5pm, jump to next Friday.
      const f = new Date(now);
      const dow = f.getDay(); // 0 = Sun
      const daysToFri = (5 - dow + 7) % 7;
      f.setDate(f.getDate() + (daysToFri === 0 && f.getHours() >= 17 ? 7 : daysToFri));
      return atHour(f, 17);
    }
    case 'next-week': {
      const m = new Date(now);
      const dow = m.getDay();
      const daysToMon = ((1 - dow + 7) % 7) || 7;
      m.setDate(m.getDate() + daysToMon);
      return atHour(m, 9);
    }
    case 'custom':
      return customStr ? new Date(customStr) : null;
  }
  return null;
}

document.addEventListener('DOMContentLoaded', () => {
  const quick = document.getElementById('new-todo-quickdate');
  const custom = document.getElementById('new-todo-custom-date');
  if (quick && custom) {
    quick.addEventListener('change', () => {
      custom.style.display = quick.value === 'custom' ? '' : 'none';
    });
  }
  // Flip the date label depending on whether the todo is delegated.
  const delegate = document.getElementById('new-todo-delegate');
  const dateLabel = document.getElementById('me-date-label');
  if (delegate && dateLabel) {
    const syncDateLabel = () => {
      dateLabel.textContent = delegate.value ? 'Promised by' : 'When';
    };
    delegate.addEventListener('change', syncDateLabel);
    syncDateLabel();
  }
});

async function createTodo(btn) {
  const titleEl = document.getElementById('new-todo-title');
  const title = titleEl.value.trim();
  if (!title) { titleEl.focus(); return; }
  const description = document.getElementById('new-todo-desc').value;
  const priority = document.getElementById('new-todo-priority').value || 'p3';
  const preset = document.getElementById('new-todo-quickdate').value;
  const customDate = document.getElementById('new-todo-custom-date').value;
  const dueDate = resolveQuickDate(preset, customDate);
  const recurrenceRule = (document.getElementById('new-todo-recur') || {}).value || null;
  const meetingSel = document.getElementById('new-todo-meeting');
  const meetingVal = meetingSel ? meetingSel.value : '';
  // "<meetingId>:<teamId>" -- if set, promotes the todo to kind='l10'
  // attached to that meeting + its team. Otherwise stays personal.
  let meetingId = null;
  let teamId = null;
  let kind = 'personal';
  if (meetingVal) {
    const parts = meetingVal.split(':');
    meetingId = parts[0] || null;
    teamId = parts[1] || null;
    kind = 'l10';
  }

  const ownerExternalId = '<%= ownerExternalId %>';
  const body = {
    kind,
    priority,
    teamId,
    meetingId,
    ownerEntityType: 'human',
    ownerExternalId,
    title,
    description: description || undefined,
    dueAt: dueDate ? dueDate.toISOString() : undefined,
    recurrenceRule: recurrenceRule || undefined,
  };

  // Multi-assignee: every selected person gets their own independent copy of
  // this to-do (each owned and checked off separately). None selected = just me.
  // Each option value is "<entityType>:<externalId>:<name>".
  const assignSel = document.getElementById('new-todo-delegate');
  const picked = assignSel ? Array.prototype.slice.call(assignSel.selectedOptions || []) : [];
  if (picked.length > 0) {
    body.owners = picked.map(function (opt) {
      const parts = opt.value.split(':');
      return { ownerEntityType: parts[0], ownerExternalId: parts[1], ownerName: parts.slice(2).join(':') };
    });
    // Stamp the creator as delegator on every copy.
    body.delegatorEntityType = <%- jsonForScript(meEntityType || 'human') %>;
    body.delegatorExternalId = <%- jsonForScript(meExternalId || '') %>;
    body.delegatorName = <%- jsonForScript(meName || '') %>;
  }

  btn.disabled = true;
  const origText = btn.textContent;
  btn.textContent = 'Adding...';
  try {
    const r = await fetch('/api/v1/todos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    if (!r.ok) {
      const err = await r.json().catch(() => ({}));
      throw new Error(err?.error?.message || ('HTTP ' + r.status));
    }
    location.reload();
  } catch (e) {
    btn.disabled = false;
    btn.textContent = origText;
    alert('Could not create: ' + e.message);
  }
}

async function promoteToL10(btn, id) {
  if (!confirm('Send this to-do to the leadership L10? It will leave your personal queue and become visible to the whole team.')) return;
  btn.disabled = true;
  const origText = btn.textContent;
  btn.textContent = 'Promoting...';
  try {
    const r = await fetch('/api/v1/todos/' + id + '/promote', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({}),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const card = btn.closest('.me-card');
    if (card) {
      card.style.transition = 'opacity 0.2s';
      card.style.opacity = '0';
      setTimeout(() => location.reload(), 250);
    }
  } catch (e) {
    btn.disabled = false;
    btn.textContent = origText;
    alert('Could not promote: ' + e.message);
  }
}

async function markDone(btn, id) {
  btn.disabled = true;
  btn.textContent = 'Marking...';
  try {
    const r = await fetch('/api/v1/todos/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ done: true }),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const card = btn.closest('.me-card');
    if (card) {
      card.style.transition = 'opacity 0.2s';
      card.style.opacity = '0';
      setTimeout(() => { card.remove(); checkEmpty(); }, 200);
    }
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Done';
    alert('Could not mark done: ' + e.message);
  }
}

async function verifyTodo(btn, id) {
  btn.disabled = true;
  btn.textContent = 'Verifying...';
  try {
    const r = await fetch('/api/v1/todos/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ verified: true }),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    location.reload();
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Verify';
    alert('Could not verify: ' + e.message);
  }
}

async function reopenTodo(btn, id) {
  btn.disabled = true;
  btn.textContent = 'Reopening...';
  try {
    const r = await fetch('/api/v1/todos/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ done: false }),
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    location.reload();
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Reopen';
    alert('Could not reopen: ' + e.message);
  }
}

function confirmDelete(btn, id) {
  if (!btn.classList.contains('confirm')) {
    btn.classList.add('confirm');
    btn.textContent = 'Confirm?';
    setTimeout(() => {
      if (btn.classList.contains('confirm') && !btn.disabled) {
        btn.classList.remove('confirm');
        btn.textContent = 'Delete';
      }
    }, 3000);
    return;
  }
  doDelete(btn, id);
}

async function doDelete(btn, id) {
  btn.disabled = true;
  btn.textContent = 'Deleting...';
  try {
    const r = await fetch('/api/v1/todos/' + id, {
      method: 'DELETE',
      credentials: 'same-origin',
    });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const card = btn.closest('.me-card');
    if (card) {
      card.style.transition = 'opacity 0.2s';
      card.style.opacity = '0';
      setTimeout(() => { card.remove(); checkEmpty(); }, 200);
    }
  } catch (e) {
    btn.disabled = false;
    btn.classList.remove('confirm');
    btn.textContent = 'Delete';
    alert('Could not delete: ' + e.message);
  }
}

function checkEmpty() {
  const remaining = document.querySelectorAll('.me-card:not(.done)').length;
  if (remaining === 0) {
    location.reload();
  }
}

