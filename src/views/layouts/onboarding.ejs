<%# ============================================================
   OTP onboarding layout -- standalone focused wizard.
   No site nav, no footer: the 7-step post-signup flow keeps the
   user on one task. Opt in per route with:
     reply.view('pages/onboarding-x', data, { layout: 'layouts/onboarding' })
   Each page view carries its own <style> block (verbatim from the
   verified design previews) so every screen renders self-contained.
   ============================================================ %>
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<!-- SearchAtlas OTTO dynamic optimization -->
<script nowprocket nitro-exclude type="text/javascript" id="sa-dynamic-optimization" data-uuid="b8465197-493e-41b8-9e52-4089d6bd6a59" src=""></script>
<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2CGLFY76YW"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-2CGLFY76YW');</script>
<!-- Google Ads -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-18159119434"></script>
<script>gtag('config','AW-18159119434');</script>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="theme-color" content="#fcfcfd">
<meta name="twitter:site" content="@OrgTP_1">
<meta name="robots" content="noindex, nofollow">
<title><%= typeof title !== 'undefined' && title ? title : 'Set up your org · OTP' %></title>
<link rel="icon" type="image/png" href="/public/favicon-orgy.png">
<link rel="apple-touch-icon" href="/public/favicon-orgy-512.png">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
</head>
<body>
<%- body %>
<script>
  // Fresh-auth helper for onboarding write fetches. Defined UNCONDITIONALLY so
  // the forms never break even if Clerk fails to load: it falls back to a
  // plain cookie request (the prior behavior). When Clerk is present it mints a
  // fresh session token, so writes never hit a stale __session cookie.
  window.otpFreshAuth = async function(){
    var h = { 'Content-Type': 'application/json' };
    try {
      if (window.Clerk && window.Clerk.session) {
        var t = await window.Clerk.session.getToken();
        if (t) h['Authorization'] = 'Bearer ' + t;
      }
    } catch (e) {}
    return h;
  };
</script>
<% if (typeof clerkPubKey !== 'undefined' && clerkPubKey && typeof clerkInstance !== 'undefined' && clerkInstance) { %>
<script
  async
  crossorigin="anonymous"
  data-clerk-publishable-key="<%= clerkPubKey %>"
  src="https://<%= clerkInstance %>/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
></script>
<script>
  // Core fix: the onboarding layout previously never loaded Clerk, so the
  // session cookie went stale during the wizard and writes 401'd. Loading
  // Clerk keeps the token auto-refreshed across all 7 steps.
  window.addEventListener('load', function(){
    if (window.Clerk && window.Clerk.load) { window.Clerk.load().catch(function(){}); }
  });
</script>
<% } %>
</body>
</html>
