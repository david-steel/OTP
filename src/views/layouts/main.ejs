                    <div style="min-width:0;">
                      <div id="otp-avatar-name" style="font-size:14px;font-weight:600;color:var(--ink);line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
                      <% if (_displayRole) { %><div style="font-size:11px;color:var(--ink-mute);line-height:1.3;"><%= _displayRole %></div><% } %>
                      <div id="otp-avatar-email" style="font-size:11px;color:var(--ink-mute);line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
