  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-2CGLFY76YW');</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'OTP - A protocol for AI agent coordination' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' && description ? description : 'OTP is the coordination intelligence layer for AI-native organizations. Publish how your AI team works, learn from others, and build better agent systems.' %>">
