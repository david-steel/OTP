  <!-- Scroll reveal script -->
  <script>
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });
  </script>

  <% if (typeof clerkPubKey !== 'undefined' && clerkPubKey && typeof clerkInstance !== 'undefined' && clerkInstance) { %>
  <script
    async
    crossorigin="anonymous"
    data-clerk-publishable-key="<%= clerkPubKey %>"
    src="https://<%= clerkInstance %>/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
    type="text/javascript"
  ></script>
  <script>
    (function waitForClerk() {
      if (!window.Clerk) return setTimeout(waitForClerk, 50);
      var clerk = window.Clerk;
      clerk.load().then(function() {
      window.__clerk = clerk;

      function makeSignInBtn(cls) {
        var btn = document.createElement('button');
        btn.textContent = 'Sign In';
        btn.className = cls + ' cursor-pointer';
        btn.addEventListener('click', function() { clerk.openSignIn({ redirectUrl: window.location.href }); });
        return btn;
      }
      function makeSignUpBtn(cls) {
        var btn = document.createElement('button');
        btn.textContent = 'Sign Up';
        btn.className = cls + ' cursor-pointer';
        btn.addEventListener('click', function() { clerk.openSignUp({ redirectUrl: '/publish' }); });
        return btn;
      }

      // Desktop nav
      var desktopNav = document.getElementById('auth-nav');
      if (desktopNav) {
        desktopNav.innerHTML = '';
        if (clerk.user) {
          var d1 = document.createElement('a'); d1.href = '/dashboard'; d1.className = 'text-gray-300 hover:text-white transition-colors'; d1.textContent = 'Dashboard'; desktopNav.appendChild(d1);
          var d2 = document.createElement('a'); d2.href = '/publish'; d2.className = 'px-4 py-2 bg-otp-500 rounded-lg hover:bg-otp-400 font-medium transition-colors'; d2.textContent = 'Publish'; desktopNav.appendChild(d2);
          var d3 = document.createElement('div'); desktopNav.appendChild(d3); clerk.mountUserButton(d3, { afterSignOutUrl: '/' });
        } else {
          desktopNav.appendChild(makeSignInBtn('text-gray-300 hover:text-white transition-colors'));
          desktopNav.appendChild(makeSignUpBtn('px-4 py-2 bg-otp-500 rounded-lg hover:bg-otp-400 font-medium transition-colors'));
        }
      }

      // Mobile header
      var headerNav = document.getElementById('auth-nav-header');
      if (headerNav) {
        headerNav.innerHTML = '';
        if (clerk.user) {
          var h1 = document.createElement('div'); headerNav.appendChild(h1); clerk.mountUserButton(h1, { afterSignOutUrl: '/' });
        } else {
          headerNav.appendChild(makeSignInBtn('text-gray-300 hover:text-white text-sm transition-colors'));
          headerNav.appendChild(makeSignUpBtn('px-3 py-1.5 bg-otp-500 rounded-lg hover:bg-otp-400 font-medium text-sm transition-colors'));
        }
      }

      // Mobile menu
      var mobileNav = document.getElementById('auth-nav-mobile');
      if (mobileNav) {
        mobileNav.innerHTML = '';
        if (clerk.user) {
          var m1 = document.createElement('a'); m1.href = '/dashboard'; m1.className = 'text-gray-300 hover:text-white py-2.5 px-3 rounded-lg hover:bg-white/5 transition-colors'; m1.textContent = 'Dashboard'; mobileNav.appendChild(m1);
          var m2 = document.createElement('a'); m2.href = '/publish'; m2.className = 'px-4 py-2.5 bg-otp-500 rounded-lg hover:bg-otp-400 font-medium text-center transition-colors'; m2.textContent = 'Publish'; mobileNav.appendChild(m2);
        } else {
          mobileNav.appendChild(makeSignInBtn('text-gray-300 hover:text-white py-2.5 px-3 rounded-lg hover:bg-white/5 text-left transition-colors'));
          mobileNav.appendChild(makeSignUpBtn('px-4 py-2.5 bg-otp-500 rounded-lg hover:bg-otp-400 font-medium text-center transition-colors'));
        }
      }

      window.dispatchEvent(new CustomEvent('clerk-loaded', { detail: { user: clerk.user } }));
      });
    })();
  </script>
  <% } %>
</body>
</html>
