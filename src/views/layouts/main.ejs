                <div class="v7-dropdown">
                  <% if (_has(_ALL)) { %><a href="/dashboard">Daily <span style="color:var(--ink-mute); font-size:11px;">— run my day</span></a><% } %>
                  <% if (_has(_ALL)) { %><a href="/l8">Meetings <span style="color:var(--ink-mute); font-size:11px;">— L8 / L10</span></a><% } %>
                  <% if (_has(_ALL)) { %><a href="/dashboard/team">Team chart</a><% } %>
                  <% if (_has(_ALL)) { %><a href="/dashboard/kpis">KPIs / Scoreboard</a><% } %>
                  <% if (_has(_ORG_WIDE) || _has(_INVITER)) { %><div class="v7-dd-divider"></div><% } %>
                  <% if (_has(_ORG_WIDE)) { %><a href="/dashboard/oos-operating-plan">Operating plan</a><% } %>
                  <% if (_has(_INVITER)) { %><a href="/dashboard/members">Members</a><% } %>
                  <% if (_has(_ORG_WIDE)) { %><a href="/dashboard/publisher">Publisher</a><% } %>
                  <% if (_has(_ORG_WIDE)) { %><a href="/settings/api">MCP / API keys</a><% } %>
                </div>
              </div>
            </div>
            <a href="/publish" class="v7-cta-publish">Publish</a>
            <%
