               // desktop). Name/email are NOT available as layout locals, so the
               // header fills them client-side from clerk.user (see hydration
               // block below). Role IS server-rendered from memberRole.
               var _displayRole = _role ? (_role.charAt(0).toUpperCase() + _role.slice(1)) : '';
            %>
            <!-- Custom avatar menu (signed-in) -->
            <div class="relative group z-50" id="otp-avatar-menu">
              <button class="flex items-center cursor-pointer rounded-full" aria-label="Account menu" style="line-height:0;">
                <img id="otp-avatar-img" src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32'><rect width='32' height='32' rx='16' fill='%230d7df2' fill-opacity='0.12'/><text x='16' y='21' font-family='Inter,system-ui,sans-serif' font-size='13' font-weight='600' fill='%230d7df2' text-anchor='middle'>·</text></svg>" alt="Account" width="32" height="32" style="width:32px;height:32px;border-radius:9999px;object-fit:cover;border:1px solid rgba(20,22,28,0.10);" />
              </button>
              <!-- Invisible bridge keeps :hover continuous from trigger to panel -->
              <div class="absolute top-full right-0 hidden group-hover:block group-focus-within:block z-50" style="min-width: 240px;">
