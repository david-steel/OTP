  <!-- Open Graph -->
  <meta property="og:site_name" content="OTP - Organization Transport Protocol">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'OTP - A protocol for AI agent coordination' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' && description ? description : 'OTP is the coordination intelligence layer for AI-native organizations. Publish how your AI team works, learn from others, and build better agent systems.' %>">
  <meta property="og:url" content="<%= typeof canonical !== 'undefined' && canonical ? canonical : 'https://orgtp.com' %>">
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : 'https://orgtp.com/public/og-image.png' %>">

  <!-- Twitter Card -->
