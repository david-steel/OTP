          <% } else { %>
            <a href="/sign-in" class="v7-nav-link">Sign In</a>
            <a href="/publish" class="v7-cta-publish">Publish</a>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden v7-mobile-menu">
      <div class="px-4 py-4 flex flex-col gap-1 text-sm">
        <% if (!_inApp) { %>
