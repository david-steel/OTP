            </div>
          </div>
        </div>

        <a href="/whats-new" class="v7-nav-link">What's New</a>
        <% } %>
        <div id="auth-nav" class="flex items-center gap-3">
          <% if (typeof authUserId !== 'undefined' && authUserId) {
               // Role-gated dashboard links. Mirrors dashboard-tabs.ejs buckets.
               var _role = (locals.memberRole || '').toString();
               var _ORG_WIDE = ['owner','admin','implementer','visionary','integrator'];
               var _INVITER  = ['owner','admin','manager','visionary','integrator'];
               var _ALL = true; // every authed org member
               function _has(allowed){
                 if (allowed === true) return true;
                 if (!_role) return false;
                 for (var i=0;i<allowed.length;i++){ if (allowed[i]===_role) return true; }
                 return false;
               }
          %>
            <!-- Dashboard dropdown (signed-in users) -->
            <div class="relative group z-50">
              <button class="v7-nav-link flex items-center gap-1 cursor-pointer">
                Dashboard
                <svg class="w-3.5 h-3.5 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <!-- Invisible bridge keeps :hover continuous from trigger to panel -->
              <div class="absolute top-full right-0 hidden group-hover:block group-focus-within:block z-50" style="min-width: 240px;">
