        <a href="/pricing" class="py-2.5 px-3 rounded-lg transition-colors">Pricing</a>

        <div class="v7-mobile-section-label pt-3 pb-1">Explore</div>
        <a href="/browse" class="py-2 px-6 rounded-lg transition-colors">Browse</a>
        <a href="/search" class="py-2 px-6 rounded-lg transition-colors">Search</a>
        <a href="/graph" class="py-2 px-6 rounded-lg transition-colors">Graph</a>
        <a href="/claims" class="py-2 px-6 rounded-lg transition-colors">Claims</a>

        <div class="v7-mobile-section-label pt-3 pb-1">Learn</div>
        <a href="/blog" class="py-2 px-6 rounded-lg transition-colors">Blog</a>
        <a href="/guide" class="py-2 px-6 rounded-lg transition-colors">Guide</a>
        <a href="/faq" class="py-2 px-6 rounded-lg transition-colors">FAQ</a>
        <a href="/answers" class="py-2 px-6 rounded-lg transition-colors">Answers</a>
        <a href="/glossary" class="py-2 px-6 rounded-lg transition-colors">Glossary</a>
        <a href="/agent-onboarding" class="py-2 px-6 rounded-lg transition-colors">Agent Onboarding</a>
        <a href="/machine-commerce" class="py-2 px-6 rounded-lg transition-colors">Machine Commerce</a>
        <a href="/mcp" class="py-2 px-6 rounded-lg transition-colors">MCP Hub</a>

        <a href="/whats-new" class="py-2.5 px-3 rounded-lg transition-colors mt-1">What's New</a>
        <% } %>
        <div id="auth-nav-mobile" class="flex flex-col gap-2 pt-3 mt-2 border-t" style="border-color:rgba(20,22,28,0.08);">
          <% if (typeof authUserId !== 'undefined' && authUserId) {
               var _mRole = (locals.memberRole || '').toString();
               var _mORG_WIDE = ['owner','admin','implementer','visionary','integrator'];
               var _mINVITER  = ['owner','admin','manager','visionary','integrator'];
               function _mHas(allowed){
                 if (allowed === true) return true;
                 if (!_mRole) return false;
                 for (var i=0;i<allowed.length;i++){ if (allowed[i]===_mRole) return true; }
                 return false;
