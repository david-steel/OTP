         teams:  '<circle cx="9" cy="7" r="3"/><circle cx="17" cy="9" r="2.5"/><path d="M2 21v-2a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v2"/>',
         doc:    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h6"/>',
         grid4:  '<path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z"/>',
         inbox:  '<path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.5 5h13l3.5 7v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-6z"/>',
         zap:    '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
         target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>'
       };
       // Rail focused on daily-use items + Upgrade. Practice / Docs / Workspaces
       // / Inquiries moved to the Settings hub (partials/settings-nav.ejs);
       // Tickets + Guide live in the Help menu (top nav). Gates: Issues=INVITER,
       // CEO=owner/visionary, Members/Teams=INVITER, the rest ORG_WIDE.
       var _sbItems = [
         { href:'/dashboard',                    label:'Daily',          icon:_sbI.sun,    allow:true },
         { href:'/l8',                           label:'Meetings',       icon:_sbI.cal,    allow:true },
         { href:'/dashboard/team',               label:'Team chart',     icon:_sbI.org,    allow:true },
         { href:'/dashboard/kpis',               label:'KPIs',           icon:_sbI.chart,  allow:true },
         { href:'/me/todos',                     label:'To-Dos',         icon:_sbI.check,  allow:true },
         { href:'/dashboard/ids',                label:'Issues',         icon:_sbI.alert,  allow:_sbINVITER },
         { divider:true },
         { href:'/dashboard/oos-operating-plan', label:'Operating plan', icon:_sbI.map,    allow:_sbORG_WIDE },
         { href:'/rocks',                        label:'Quarterly Priorities', icon:_sbI.target, allow:true },
         { href:'/processes',                    label:'Processes',      icon:_sbI.map,    allow:true },
         { href:'/dashboard/ceo',                label:'CEO',            icon:_sbI.star,   allow:_sbCEO },
         { href:'/dashboard/members',            label:'Members',        icon:_sbI.people, allow:_sbINVITER },
         { href:'/dashboard/teams',              label:'Teams',          icon:_sbI.teams,  allow:_sbINVITER },
         { href:'/dashboard/publisher',          label:'Publisher',      icon:_sbI.send,   allow:_sbORG_WIDE },
         { href:'/settings/api',                 label:'MCP / API keys', icon:_sbI.key,    allow:_sbORG_WIDE },
         { divider:true },
         { href:'/pricing',                      label:'Upgrade',        icon:_sbI.zap,    allow:true, upsell:true }
       ];
       // Render sequentially; a divider only prints when items rendered on both
       // sides of it (so a fully role-gated-out group can't leave a double rule).
       var _sbHtml = '';
       var _sbUpgradeHtml = '';
       var _sbPendingDivider = false;
       var _sbRenderedAny = false;
       for (var _sbIdx = 0; _sbIdx < _sbItems.length; _sbIdx++) {
         var _sbIt = _sbItems[_sbIdx];
         if (_sbIt.divider) { if (_sbRenderedAny) _sbPendingDivider = true; continue; }
         if (!_sbHas(_sbIt.allow)) continue;
         if (_sbIt.coach && !_sbIsCoach) continue;
         // Upgrade is pinned in the sidebar footer (always above the fold), not
         // in the scrolling nav -- capture it and skip the normal render.
         if (_sbIt.upsell) {
           _sbUpgradeHtml = '<a href="' + _sbIt.href + '" class="otp-sb-link otp-sb-upsell' + (_sbActive(_sbIt.href) ? ' active' : '') + '" title="' + _sbIt.label + '">'
             + '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + _sbIt.icon + '</svg>'
             + '<span class="otp-sb-label">' + _sbIt.label + '</span></a>';
           continue;
         }
         if (_sbPendingDivider) { _sbHtml += '<div class="otp-sb-divider"></div>'; _sbPendingDivider = false; }
         _sbHtml += '<a href="' + _sbIt.href + '" class="otp-sb-link' + (_sbIt.upsell ? ' otp-sb-upsell' : '') + (_sbActive(_sbIt.href) ? ' active' : '') + '" title="' + _sbIt.label + '">'
           + '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + _sbIt.icon + '</svg>'
           + '<span class="otp-sb-label">' + _sbIt.label + '</span></a>';
         _sbRenderedAny = true;
       }
  %>
  <style>
    /* App sidebar (signed-in, desktop only). Color tokens mirror the existing
       chrome: .v7-nav slab (#fcfcfd / rgba(20,22,28,0.08) border) and
       .v7-dropdown hover (rgba(13,125,242,0.06) / var(--blue-deep)). */
    .otp-sb {
      position: fixed; top: 65px; left: 0; bottom: 0; width: 230px;
      background: #fcfcfd; border-right: 1px solid rgba(20,22,28,0.08);
      display: none; flex-direction: column; z-index: 40;
      overflow: hidden; /* the nav scrolls; org header + Upgrade footer stay pinned */
      transition: width .2s ease;
    }
    body.otp-rail-collapsed .otp-sb { width: 56px; }
    .otp-sb-org {
      flex: none; padding: 14px 16px 10px; font-size: 13px; font-weight: 700;
      color: var(--ink, #14161c); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      border-bottom: 1px solid rgba(20,22,28,0.06);
    }
    body.otp-rail-collapsed .otp-sb-org { display: none; }
    .otp-sb-nav { flex: 1 1 auto; min-height: 0; overflow-y: auto; overflow-x: hidden; display: flex; flex-direction: column; gap: 2px; padding: 10px 8px; }
    /* Pinned footer: keeps Upgrade above the fold no matter how tall the nav is. */
    .otp-sb-foot { flex: none; padding: 6px 8px; border-top: 1px solid rgba(20,22,28,0.06); }
    .otp-sb-link {
      display: flex; align-items: center; gap: 10px; padding: 8px 11px;
      border-radius: 8px; color: var(--ink, #14161c); font-size: 14px; font-weight: 500;
      text-decoration: none; white-space: nowrap; transition: background .12s ease, color .12s ease;
    }
    .otp-sb-link svg { flex: none; }
    .otp-sb-link:hover { background: rgba(13,125,242,0.06); color: var(--blue-deep, #0b62c4); }
    .otp-sb-link.active { background: rgba(13,125,242,0.08); color: var(--blue-deep, #0b62c4); font-weight: 600; }
    /* Upgrade upsell row (GHL-style): amber treatment mirroring the Help
       panel's Premium Support row (#fffbeb tint, #b45309 icon stroke). */
    .otp-sb-link.otp-sb-upsell { background: #fffbeb; }
    .otp-sb-link.otp-sb-upsell svg { stroke: #b45309; }
    .otp-sb-link.otp-sb-upsell:hover { background: #fef3c7; color: #92400e; }
    .otp-sb-link.otp-sb-upsell.active { background: #fef3c7; color: #92400e; font-weight: 600; }
    .otp-sb-divider { flex: none; height: 1px; background: rgba(20,22,28,0.06); margin: 8px 6px; }
    body.otp-rail-collapsed .otp-sb .otp-sb-label { display: none; }
    .otp-sb-toggle {
      flex: none; display: flex; align-items: center; gap: 10px; margin: 8px;
      padding: 8px 11px; border-radius: 8px; border: none; background: none;
      color: var(--ink-mute, #888c96); font-size: 13px; font-weight: 500;
      cursor: pointer; white-space: nowrap; text-align: left; font-family: inherit;
      transition: background .12s ease, color .12s ease;
    }
    .otp-sb-toggle:hover { background: rgba(13,125,242,0.06); color: var(--blue-deep, #0b62c4); }
    .otp-sb-toggle svg { flex: none; }
    .otp-sb-toggle .otp-sb-chev-r { display: none; }
    body.otp-rail-collapsed .otp-sb-toggle .otp-sb-chev-l { display: none; }
    body.otp-rail-collapsed .otp-sb-toggle .otp-sb-chev-r { display: inline; }
    /* Desktop (md+) only: show the rail and shift the content area right.
       Below md the rail stays hidden and the hamburger menu carries the links. */
    @media (min-width: 768px) {
      .otp-sb { display: flex; }
      body.otp-has-rail main { margin-left: 230px; transition: margin-left .2s ease; }
      body.otp-has-rail.otp-rail-collapsed main { margin-left: 56px; }
    }
    /* Grey app canvas on dashboard/meeting pages -- preserved from the old
       dashboard-tabs rail so tiles keep their card-on-grey treatment. */
    main.otp-app-canvas { background: var(--grey, #f0f1f3); min-height: 100vh; }
  </style>
  <aside id="otp-sidebar" class="otp-sb" aria-label="App navigation">
    <div class="otp-sb-org"><span class="otp-sb-label"><%= (locals.orgName || 'Workspace') %></span></div>
    <nav class="otp-sb-nav"><%- _sbHtml %></nav>
    <% if (_sbUpgradeHtml) { %><div class="otp-sb-foot"><%- _sbUpgradeHtml %></div><% } %>
    <button type="button" id="otp-sb-toggle" class="otp-sb-toggle" title="<%= (typeof sidebarCollapsed !== 'undefined' && sidebarCollapsed) ? 'Expand sidebar' : 'Collapse sidebar' %>" aria-label="Toggle sidebar">
      <svg class="otp-sb-chev-l" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      <svg class="otp-sb-chev-r" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      <span class="otp-sb-label">Collapse</span>
    </button>
  </aside>
  <script>
    (function () {
      var sbToggle = document.getElementById('otp-sb-toggle');
      if (!sbToggle || window.__otpSbInit) return;
      window.__otpSbInit = true;
      sbToggle.addEventListener('click', function () {
        var collapsed = document.body.classList.toggle('otp-rail-collapsed');
        sbToggle.title = collapsed ? 'Expand sidebar' : 'Collapse sidebar';
        // Fire-and-forget persistence per member. A legacy founder with no
        // org_members row gets a 403 here -- the collapse still works for the
        // session, so swallow everything beyond a console note.
        fetch('/api/v1/dashboard-preferences', {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sidebarCollapsed: collapsed }),
        }).then(function (r) {
          if (!r.ok) console.warn('sidebar preference not saved (' + r.status + ')');
        }).catch(function (err) { console.warn('sidebar preference not saved', err); });
      });
    })();
  </script>
  <% } %>

