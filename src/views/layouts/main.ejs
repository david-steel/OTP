  <!-- Scroll reveal script -->
  <script>
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });
  </script>

  <% if (typeof clerkPubKey !== 'undefined' && clerkPubKey && typeof clerkInstance !== 'undefined' && clerkInstance) { %>
  <script
    async
    crossorigin="anonymous"
    data-clerk-publishable-key="<%= clerkPubKey %>"
    src="https://<%= clerkInstance %>/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
    type="text/javascript"
  ></script>
  <script>
    (function waitForClerk() {
      if (!window.Clerk) return setTimeout(waitForClerk, 50);
      var clerk = window.Clerk;
      clerk.load().then(function() {
      window.__clerk = clerk;

      function makeSignInBtn() {
        var btn = document.createElement('button');
        btn.textContent = 'Sign In';
        btn.className = 'v7-nav-link cursor-pointer';
        btn.addEventListener('click', function() { clerk.openSignIn({ redirectUrl: window.location.href }); });
        return btn;
      }
      function makeSignUpBtn() {
        var btn = document.createElement('button');
        btn.textContent = 'Sign Up';
        btn.className = 'v7-cta-publish cursor-pointer';
        btn.addEventListener('click', function() { clerk.openSignUp({ redirectUrl: '/publish' }); });
        return btn;
      }

      // Desktop nav: server already rendered the right state (Dashboard
      // dropdown + Publish + a CUSTOM avatar menu if signed-in, or Sign In +
      // Publish if not). We do NOT mount Clerk's default UserButton on desktop
      // anymore -- instead we populate the server-rendered custom avatar menu
      // (#otp-avatar-menu) from clerk.user. We still do NOT clobber the
      // server's nav -- doing so wipes out the server-rendered dropdown markup.
      var avatarMenu = document.getElementById('otp-avatar-menu');
      var desktopNav = document.getElementById('auth-nav');
      if (clerk.user && avatarMenu) {
        var u = clerk.user;
        var imgUrl = u.imageUrl || '';
        var fullName = (u.fullName || '').trim();
        var primaryEmail = (u.primaryEmailAddress && u.primaryEmailAddress.emailAddress) || '';
        if (imgUrl) {
          var imgEl = document.getElementById('otp-avatar-img');
          var imgElMenu = document.getElementById('otp-avatar-img-menu');
          if (imgEl) imgEl.src = imgUrl;
          if (imgElMenu) imgElMenu.src = imgUrl;
        }
        // Name/email are not server-rendered (no layout local) -- fill from Clerk.
        var nameEl = document.getElementById('otp-avatar-name');
        if (nameEl && !nameEl.textContent.trim() && fullName) nameEl.textContent = fullName;
        var emailEl = document.getElementById('otp-avatar-email');
        if (emailEl && !emailEl.textContent.trim() && primaryEmail) emailEl.textContent = primaryEmail;
        // Wire Log Out to Clerk sign-out.
        var logoutEl = document.getElementById('otp-avatar-logout');
        if (logoutEl) {
          logoutEl.addEventListener('click', async function (e) {
            e.preventDefault();
            // Await sign-out, then force a full reload to the sign-in page.
            // signOut({redirectUrl}) alone cleared the session but wasn't
            // navigating, so the stale logged-in UI lingered until a refresh.
            try { await window.Clerk.signOut(); } catch (err) {}
            window.location.href = '/sign-in';
          });
        }
      } else if (clerk.user && desktopNav && !avatarMenu) {
        // Fallback for state mismatch (server thought signed-out, Clerk
        // says signed-in). Build the same dropdown the server would.
        desktopNav.innerHTML = '';
        var fallbackHtml =
          '<div class="relative group z-50">' +
            '<button class="v7-nav-link flex items-center gap-1 cursor-pointer">Dashboard' +
              '<svg class="w-3.5 h-3.5 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>' +
            '</button>' +
            '<div class="absolute top-full right-0 hidden group-hover:block group-focus-within:block z-50" style="min-width: 240px;">' +
              '<div class="h-2"></div>' +
              '<div class="v7-dropdown">' +
                '<a href="/dashboard">Daily</a>' +
                '<a href="/l8">Meetings</a>' +
                '<a href="/dashboard/team">Team chart</a>' +
                '<a href="/dashboard/kpis">KPIs / Scoreboard</a>' +
                // Role-gated items (Operating plan / Members / Publisher / MCP) intentionally
                // omitted here -- this fallback fires when server thought signed-out but Clerk
                // says signed-in, so memberRole is unknown. The server-rendered nav on the
                // next page load shows the full role-appropriate set.
              '</div>' +
            '</div>' +
          '</div>' +
          '<a href="/publish" class="v7-cta-publish">Publish</a>' +
          '<div id="auth-user-button-desktop"></div>';
        desktopNav.innerHTML = fallbackHtml;
        var slot = document.getElementById('auth-user-button-desktop');
        if (slot) clerk.mountUserButton(slot, { afterSignOutUrl: '/sign-in' });
      } else if (!clerk.user && desktopNav) {
        // Signed-out: server already rendered Sign In + Publish. Nothing to do.
      }

      // Mobile header (the avatar slot in the top bar). Server doesn't
      // render anything here -- leave full client-side control.
      var headerNav = document.getElementById('auth-nav-header');
      if (headerNav) {
        headerNav.innerHTML = '';
        if (clerk.user) {
          var h1 = document.createElement('div'); headerNav.appendChild(h1); clerk.mountUserButton(h1, { afterSignOutUrl: '/sign-in' });
        } else {
          headerNav.appendChild(makeSignInBtn());
          headerNav.appendChild(makeSignUpBtn());
        }
      }

      // Mobile menu: server already rendered the full Dashboard section.
      // Mount UserButton into the slot if present.
      var mobileSlot = document.getElementById('auth-user-button-mobile');
      var mobileNav = document.getElementById('auth-nav-mobile');
      if (clerk.user && mobileSlot) {
        mobileSlot.innerHTML = '';
        clerk.mountUserButton(mobileSlot, { afterSignOutUrl: '/sign-in' });
      } else if (clerk.user && mobileNav && !mobileSlot) {
        mobileNav.innerHTML = '';
        var mDashWrap = document.createElement('div');
        mDashWrap.innerHTML =
          '<a href="/dashboard" class="block py-2.5 px-3 rounded-lg transition-colors">Daily</a>' +
          '<a href="/l8" class="block py-2.5 px-3 rounded-lg transition-colors">Meetings</a>' +
          '<a href="/dashboard/team" class="block py-2.5 px-3 rounded-lg transition-colors">Team chart</a>' +
          '<a href="/dashboard/kpis" class="block py-2.5 px-3 rounded-lg transition-colors">KPIs</a>' +
          '<a href="/publish" class="v7-cta-publish text-center mt-2">Publish</a>';
        mobileNav.appendChild(mDashWrap);
      }

      window.dispatchEvent(new CustomEvent('clerk-loaded', { detail: { user: clerk.user } }));
      });
    })();
  </script>
  <% } %>
  <% if (typeof authUserId !== 'undefined' && authUserId) { %>
<script>
(function () {
  var bell = document.getElementById('otp-bell');
  if (!bell || window.__otpBellInit) return;
  window.__otpBellInit = true;
  var btn = document.getElementById('otp-bell-btn');
  var badge = document.getElementById('otp-bell-count');
  var panel = document.getElementById('otp-bell-panel');
  var itemsEl = document.getElementById('otp-bell-items');
  var items = [];

  function esc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML; }
  function ago(iso) {
    var ms = Date.now() - new Date(iso).getTime();
    var m = Math.floor(ms / 60000);
    if (m < 1) return 'just now';
    if (m < 60) return m + 'm ago';
    var h = Math.floor(m / 60);
    if (h < 24) return h + 'h ago';
    return Math.floor(h / 24) + 'd ago';
  }
  function setCount(n) {
    if (n > 0) { badge.textContent = n > 99 ? '99+' : String(n); badge.style.display = 'block'; }
    else { badge.style.display = 'none'; }
  }
  // Browser notifications (tab must be open; permission requested on first
  // bell click). Fire only for unread items newer than the last batch seen,
  // capped so a backlog can't spam the desktop.
  function browserNotify(list) {
    if (localStorage.getItem('otpPushOn') === '1') return; // service-worker push handles it
    if (!('Notification' in window) || Notification.permission !== 'granted') return;
    var lastSeen = localStorage.getItem('otpBellSeen') || '';
    var newest = lastSeen, fired = 0;
    list.forEach(function (n) {
      if (!n.readAt && n.createdAt > lastSeen && fired < 3) {
        try { new Notification('OTP', { body: n.title }); fired++; } catch (e) {}
      }
      if (n.createdAt > newest) newest = n.createdAt;
    });
    if (newest) localStorage.setItem('otpBellSeen', newest);
  }
  // Web push: register the service worker and subscribe this browser so
  // alerts arrive even with no OTP tab open. Runs only once permission is
  // granted; degrades silently when the server has no VAPID keys or the
  // browser lacks support.
  function urlB64ToUint8Array(base64) {
    var padding = '='.repeat((4 - (base64.length % 4)) % 4);
    var raw = atob((base64 + padding).replace(/-/g, '+').replace(/_/g, '/'));
    var arr = new Uint8Array(raw.length);
    for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
    return arr;
  }
  function ensurePushSubscription() {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
    if (!('Notification' in window) || Notification.permission !== 'granted') return;
    fetch('/api/v1/push/public-key', { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (cfg) {
        if (!cfg || !cfg.enabled || !cfg.publicKey) return;
        return navigator.serviceWorker.register('/sw.js')
          .then(function (reg) { return navigator.serviceWorker.ready.then(function () { return reg; }); })
          .then(function (reg) {
            return reg.pushManager.getSubscription().then(function (sub) {
              return sub || reg.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlB64ToUint8Array(cfg.publicKey),
              });
            });
          })
          .then(function (sub) {
            return fetch('/api/v1/push/subscriptions', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(sub.toJSON()),
            });
          })
          .then(function (r) { if (r && r.ok) localStorage.setItem('otpPushOn', '1'); });
      })
      .catch(function () {});
  }
  function renderItems() {
    if (items.length === 0) {
      itemsEl.innerHTML = '<div style="padding:18px 14px; font-size:13px; color:#6b7280;">Nothing yet. You\'ll see new to-dos assigned to you, finished delegations, and close-outs here.</div>';
      return;
    }
    itemsEl.innerHTML = items.map(function (n) {
      var inner =
        '<div style="font-size:13px; color:#111827; line-height:1.45;' + (n.readAt ? '' : ' font-weight:600;') + '">' + esc(n.title) + '</div>' +
        '<div style="font-size:11px; color:#9ca3af; margin-top:2px;">' + esc(ago(n.createdAt)) + '</div>';
      var style = 'display:block; padding:10px 14px; border-bottom:1px solid rgba(20,22,28,0.05); text-decoration:none;' + (n.readAt ? '' : ' background:#f0f7ff;');
      return n.href
        ? '<a href="' + esc(n.href) + '" style="' + style + '">' + inner + '</a>'
        : '<div style="' + style + '">' + inner + '</div>';
    }).join('');
  }
  function refresh() {
    fetch('/api/v1/notifications', { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data) return;
        items = data.items || [];
        setCount(data.unread || 0);
        browserNotify(items);
      })
      .catch(function () {});
  }
  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    var open = panel.style.display !== 'none';
    if (open) { panel.style.display = 'none'; return; }
    renderItems();
    panel.style.display = 'block';
    if ('Notification' in window && Notification.permission === 'default') {
      try {
        Notification.requestPermission().then(function (p) {
          if (p === 'granted') ensurePushSubscription();
        });
      } catch (err) {}
    }
    if (badge.style.display !== 'none') {
      fetch('/api/v1/notifications/read-all', { method: 'POST', credentials: 'same-origin' })
        .then(function () { setCount(0); })
        .catch(function () {});
    }
  });
  document.addEventListener('click', function (e) {
    if (panel.style.display !== 'none' && !bell.contains(e.target)) panel.style.display = 'none';
  });
  refresh();
  ensurePushSubscription();
  setInterval(refresh, 120000); // light poll: every 2 minutes while the tab is open

  // Realtime (R2): when the live org stream is up, refresh the bell the moment
  // anything changes (debounced to coalesce bursts). The 2-min poll above stays
  // as the fallback, so behaviour is unchanged when the stream is off.
  if (window.OTPLive && window.OTPLive.enabled()) {
    var liveT;
    var bump = function () { clearTimeout(liveT); liveT = setTimeout(refresh, 500); };
    window.OTPLive.subscribe({ onEvent: bump, onResync: bump });
  }
})();
</script>
<script>
(function () {
  var mega = document.getElementById('otp-mega');
  if (!mega || window.__otpMegaInit) return;
  window.__otpMegaInit = true;
  var btn = document.getElementById('otp-mega-btn');
  var badge = document.getElementById('otp-mega-count');
  var panel = document.getElementById('otp-mega-panel');
  var itemsEl = document.getElementById('otp-mega-items');
  var entries = [];
  var markedSeen = false;

  function esc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML; }
  function shortDate(iso) {
    var dt = new Date(iso + 'T00:00:00');
    if (isNaN(dt.getTime())) return iso;
    return dt.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }
  function setCount(n) {
    if (n > 0) { badge.textContent = n > 99 ? '99+' : String(n); badge.style.display = 'block'; }
    else { badge.style.display = 'none'; }
  }
  function renderItems() {
    if (entries.length === 0) {
      itemsEl.innerHTML = '<div style="padding:18px 14px; font-size:13px; color:#6b7280;">You\'re all caught up.</div>';
      return;
    }
    itemsEl.innerHTML = entries.map(function (e) {
      var chips = (e.tags || []).map(function (t) {
        return '<span style="display:inline-block; padding:1px 6px; margin-right:4px; border-radius:9999px; background:rgba(37,99,235,0.08); color:#2563eb; font-size:10px; font-weight:600;">' + esc(t) + '</span>';
      }).join('');
      var inner =
        '<div style="font-size:11px; color:#9ca3af;">' + esc(shortDate(e.date)) + (chips ? ' ' + chips : '') + '</div>' +
        '<div style="font-size:13px; color:#111827; font-weight:600; line-height:1.4; margin-top:2px;">' + esc(e.title) + '</div>' +
        '<div style="font-size:12px; color:#6b7280; line-height:1.45; margin-top:2px;">' + esc(e.summary) + '</div>';
      return '<a href="/whats-new" style="display:block; padding:10px 14px; border-bottom:1px solid rgba(20,22,28,0.05); text-decoration:none;">' + inner + '</a>';
    }).join('');
  }
  function markSeen() {
    if (markedSeen) return;
    markedSeen = true;
    fetch('/api/v1/whats-new/seen', { method: 'POST', credentials: 'same-origin' })
      .then(function () { setCount(0); })
      .catch(function () {});
  }
  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    var bellPanel = document.getElementById('otp-bell-panel');
    if (bellPanel) bellPanel.style.display = 'none';
    var open = panel.style.display !== 'none';
    if (open) { panel.style.display = 'none'; return; }
    renderItems();
    panel.style.display = 'block';
    markSeen();
  });
  var bellBtn = document.getElementById('otp-bell-btn');
  if (bellBtn) bellBtn.addEventListener('click', function () { panel.style.display = 'none'; });
  document.addEventListener('click', function (e) {
    if (panel.style.display !== 'none' && !mega.contains(e.target)) panel.style.display = 'none';
  });
  fetch('/api/v1/whats-new/unread', { credentials: 'same-origin' })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data || !data.ok) return;
      entries = data.entries || [];
      setCount(data.unread || 0);
    })
    .catch(function () {});
})();
</script>
<script>
(function () {
  var help = document.getElementById('otp-help');
  if (!help || window.__otpHelpInit) return;
  window.__otpHelpInit = true;
  var btn = document.getElementById('otp-help-btn');
  var panel = document.getElementById('otp-help-panel');
  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    // Mutual exclusion: opening help closes the bell + What's New panels.
    var bellPanel = document.getElementById('otp-bell-panel');
    if (bellPanel) bellPanel.style.display = 'none';
    var megaPanel = document.getElementById('otp-mega-panel');
    if (megaPanel) megaPanel.style.display = 'none';
    panel.style.display = panel.style.display !== 'none' ? 'none' : 'block';
  });
  // ...and opening bell or What's New closes help.
  var bellBtn = document.getElementById('otp-bell-btn');
  if (bellBtn) bellBtn.addEventListener('click', function () { panel.style.display = 'none'; });
  var megaBtn = document.getElementById('otp-mega-btn');
  if (megaBtn) megaBtn.addEventListener('click', function () { panel.style.display = 'none'; });
  document.addEventListener('click', function (e) {
    if (panel.style.display !== 'none' && !help.contains(e.target)) panel.style.display = 'none';
  });
})();
</script>
<script>
(function () {
  var root = document.getElementById('otp-askai');
  if (!root || window.__otpAskAiInit) return;
  window.__otpAskAiInit = true;
  var btn = document.getElementById('otp-askai-btn');
  var panel = document.getElementById('otp-askai-panel');
  var msgsEl = document.getElementById('otp-askai-msgs');
  var input = document.getElementById('otp-askai-input');
  var sendBtn = document.getElementById('otp-askai-send');
  var messages = []; // page-lifetime chat history: {role, content}
  var streaming = false;

  function isOpen() { return panel.style.display !== 'none'; }
  function closePanel() { panel.style.display = 'none'; }
  function openPanel() {
    // Mutual exclusion: opening Ask AI closes bell + What's New + help.
    ['otp-bell-panel', 'otp-mega-panel', 'otp-help-panel'].forEach(function (id) {
      var p = document.getElementById(id);
      if (p) p.style.display = 'none';
    });
    panel.style.display = 'flex';
    input.focus();
  }
  // ...and opening any of the other three closes Ask AI.
  ['otp-bell-btn', 'otp-mega-btn', 'otp-help-btn'].forEach(function (id) {
    var b = document.getElementById(id);
    if (b) b.addEventListener('click', closePanel);
  });
  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    if (isOpen()) { closePanel(); return; }
    openPanel();
  });
  document.addEventListener('click', function (e) {
    if (isOpen() && !root.contains(e.target)) closePanel();
  });

  // Render plain text into a bubble via textContent only (never innerHTML
  // for user/assistant text), with simple paragraph splits.
  function setBubbleText(bubble, text) {
    bubble.textContent = '';
    var paras = String(text).split(/\n{2,}/);
    for (var i = 0; i < paras.length; i++) {
      var p = document.createElement('div');
      p.textContent = paras[i];
      if (i > 0) p.style.marginTop = '8px';
      bubble.appendChild(p);
    }
  }
  function addBubble(role, text) {
    var b = document.createElement('div');
    if (role === 'user') {
      b.style.cssText = 'align-self:flex-end; max-width:85%; padding:8px 11px; border-radius:12px 12px 3px 12px; background:rgba(109,40,217,0.10); color:#3b2174; font-size:13px; line-height:1.5; white-space:pre-wrap; word-break:break-word;';
    } else {
      b.style.cssText = 'align-self:flex-start; max-width:85%; padding:8px 11px; border-radius:12px 12px 12px 3px; background:#f3f4f6; color:#111827; font-size:13px; line-height:1.5; word-break:break-word;';
    }
    setBubbleText(b, text);
    msgsEl.appendChild(b);
    msgsEl.scrollTop = msgsEl.scrollHeight;
    return b;
  }
  function setBusy(on) {
    streaming = on;
    sendBtn.disabled = on;
    sendBtn.style.opacity = on ? '0.55' : '1';
    sendBtn.style.cursor = on ? 'default' : 'pointer';
  }

  function send() {
    if (streaming) return;
    var q = input.value.replace(/\s+$/, '');
    if (!q) return;
    if (q.length > 4000) q = q.slice(0, 4000);
    input.value = '';
    messages.push({ role: 'user', content: q });
    addBubble('user', q);
    var bubble = addBubble('assistant', '…');
    setBusy(true);

    var acc = '';
    fetch('/api/v1/ask-ai', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: messages.slice(-20) }),
    }).then(function (res) {
      if (!res.ok) {
        return res.json().catch(function () { return null; }).then(function (body) {
          var code = body && body.error && body.error.code;
          if (code === 'NOT_CONFIGURED') {
            setBubbleText(bubble, "Ask AI isn't set up yet — check back soon.");
          } else if (res.status === 429) {
            setBubbleText(bubble, 'Slow down a little — try again in a minute.');
          } else {
            setBubbleText(bubble, 'Something went wrong. Please try again.');
          }
          setBusy(false);
        });
      }
      var reader = res.body.getReader();
      var decoder = new TextDecoder();
      var buf = '';
      function handleLine(line) {
        if (line.slice(0, 6) !== 'data: ') return;
        var payload;
        try { payload = JSON.parse(line.slice(6)); } catch (e) { return; }
        if (typeof payload.t === 'string') {
          acc += payload.t;
          setBubbleText(bubble, acc);
          msgsEl.scrollTop = msgsEl.scrollHeight;
        } else if (payload.error) {
          setBubbleText(bubble, payload.error);
          acc = '';
        } else if (payload.done) {
          if (acc) messages.push({ role: 'assistant', content: acc });
        }
      }
      function pump() {
        return reader.read().then(function (r) {
          if (r.done) {
            if (acc && (messages.length === 0 || messages[messages.length - 1].content !== acc)) {
              // Stream ended without a {done} frame; keep what we got.
              messages.push({ role: 'assistant', content: acc });
            }
            setBusy(false);
            return;
          }
          buf += decoder.decode(r.value, { stream: true });
          var parts = buf.split('\n\n');
          buf = parts.pop();
          parts.forEach(function (chunk) {
            chunk.split('\n').forEach(handleLine);
          });
          return pump();
        });
      }
      return pump();
    }).catch(function () {
      setBubbleText(bubble, 'Connection lost. Please try again.');
      setBusy(false);
    });
  }

  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
  });
})();
</script>
<% } %>
<%- include('../partials/help') %>
</body>
</html>
