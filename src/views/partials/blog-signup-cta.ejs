<!-- Blog signup CTA -- slim inline email capture, top of every post. v7 light. -->
<section class="bg-[var(--grey)] border-b border-[var(--line)]">
  <div class="max-w-3xl mx-auto px-6 pt-[84px] pb-4 sm:pb-5">
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
      <div class="flex-shrink-0 text-[14px] text-[var(--ink-soft)]">
        <span class="font-display font-bold text-[var(--ink)]">Join OTP</span>
        <span class="text-[var(--ink-mute)] ml-2">the operating platform for people and AI agents</span>
      </div>
      <form id="blog-signup-form" class="flex-1 flex items-center gap-2 sm:ml-auto" autocomplete="on">
        <label for="blog-signup-email" class="sr-only">Email address</label>
        <input id="blog-signup-email" type="email" name="email" placeholder="you@domain.com" required
               class="flex-1 px-3 py-2 rounded-lg text-[14px] text-[var(--ink)] bg-[var(--card)] border border-[var(--line)] focus-visible:outline-none focus-visible:border-[var(--blue)] focus-visible:ring-1 focus-visible:ring-[rgba(13,125,242,0.3)]">
        <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true">
        <button type="submit" class="btn-primary px-4 py-2 text-[13px] whitespace-nowrap">
          Get updates
        </button>
      </form>
    </div>
    <p id="blog-signup-result" class="text-[14px] mt-2 hidden" aria-live="polite"></p>
  </div>
</section>

<script>
document.getElementById('blog-signup-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target;
  const email = form.email.value;
  const honeypot = form.website.value;
  const resultEl = document.getElementById('blog-signup-result');
  if (honeypot) return;
  try {
    const res = await fetch('/api/v1/newsletter/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, source: 'blog_inline' }),
    });
    const data = await res.json();
    resultEl.classList.remove('hidden');
    if (res.ok) {
      resultEl.className = 'text-[14px] mt-2 text-[var(--green-deep)]';
      resultEl.textContent = data.message || "You're in! Check your email to confirm.";
      form.email.value = '';
      if (typeof gtag === 'function') gtag('event', 'newsletter_signup', { source: 'blog_inline' });
    } else {
      resultEl.className = 'text-[14px] mt-2 text-[#c0392b]';
      resultEl.textContent = data.error?.message || 'Something went wrong.';
    }
  } catch (err) {
    resultEl.classList.remove('hidden');
    resultEl.className = 'text-[14px] mt-2 text-[#c0392b]';
    resultEl.textContent = 'Network error. Please try again.';
  }
});
</script>
