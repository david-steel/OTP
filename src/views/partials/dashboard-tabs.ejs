<%
  // Dashboard nav strip. Renders horizontally above the page content for any
  // path under /dashboard or /l8. Role-filtered.
  //
  // Inputs (all from view-wrapper defaults; falls back gracefully):
  //   currentPath -- request URL path
  //   memberRole  -- one of the Role enum values, or null when unauth
  //
  // No-op return if not authenticated or path is not a dashboard page.
  var path = locals.currentPath || '';
  var role = (locals.memberRole || '').toString();
  var inDashArea = path === '/dashboard' || path.indexOf('/dashboard/') === 0
                || path === '/l8' || path.indexOf('/l8/') === 0;
  var authed = !!locals.authUserId;
%>

<% if (authed && inDashArea) {
     // Role buckets (mirror permissions.ts)
     var ALL = ['owner','admin','manager','managee','observer','implementer','visionary','integrator','free','member'];
     var INTEGRATOR_LIKE = ['owner','admin','integrator','implementer'];
     var ORG_WIDE = ['owner','admin','implementer','visionary','integrator'];
     var INVITER = ['owner','admin','manager','visionary','integrator'];
     var ALL_AUTHED = ALL; // anyone with an org

     function hasRole(allowed){
       if (!role) return false;
       for (var i=0;i<allowed.length;i++){ if (allowed[i]===role) return true; }
       return false;
     }

     // Tab definitions. Order matters -- left to right.
     var tabs = [
       { href: '/dashboard',                    label: 'Daily',     allow: ALL_AUTHED },
       { href: '/l8',                           label: 'Meetings',  allow: ALL_AUTHED },
       { href: '/dashboard/team',               label: 'Team',      allow: ALL_AUTHED },
       { href: '/dashboard/kpis',               label: 'KPIs',      allow: ALL_AUTHED },
       { href: '/dashboard/oos-operating-plan', label: 'Plan',      allow: ORG_WIDE },
       { href: '/dashboard/members',            label: 'Members',   allow: INVITER },
       { href: '/dashboard/source-documents',   label: 'Docs',      allow: ORG_WIDE },
       { href: '/dashboard/workspaces',         label: 'Workspaces',allow: ORG_WIDE },
       { href: '/dashboard/inquiries',          label: 'Inquiries', allow: ORG_WIDE },
       { href: '/dashboard/publisher',          label: 'Publisher', allow: ORG_WIDE },
       { href: '/dashboard/api',                label: 'MCP / API', allow: ORG_WIDE },
     ];

     // Active match: longest-prefix wins. /dashboard/team beats /dashboard.
     var activeHref = '';
     for (var i=0;i<tabs.length;i++){
       var t = tabs[i];
       if (path === t.href || (t.href !== '/dashboard' && path.indexOf(t.href) === 0)) {
         if (t.href.length > activeHref.length) activeHref = t.href;
       }
     }
     if (!activeHref && (path === '/dashboard' || path === '/l8' || path.indexOf('/l8/') === 0)) {
       activeHref = path === '/dashboard' ? '/dashboard' : '/l8';
     }
%>
  <div class="border-b border-gray-200 bg-white sticky top-[60px] z-30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav class="flex gap-1 overflow-x-auto -mb-px text-sm" aria-label="Dashboard">
        <% tabs.forEach(function(t){ if (!hasRole(t.allow)) return; var active = t.href === activeHref; %>
          <a href="<%= t.href %>"
             class="whitespace-nowrap px-3 py-2.5 border-b-2 font-medium transition-colors <%= active ? 'border-otp-600 text-otp-700' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %>">
            <%= t.label %>
          </a>
        <% }); %>
      </nav>
    </div>
  </div>
<% } %>
