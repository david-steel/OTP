<!-- meeting section partial: headlines -- verbatim extract from l8-leadership.ejs (Inc 1, additive). Props contract: src/shared/meeting-section-props.ts -->
  <section id="headlines" class="mb-12">
    <h2 class="text-2xl font-extrabold tracking-tight text-gray-900 mb-3">4. Customer &amp; Employee Headlines <span class="text-sm text-gray-400 font-normal">5 min</span> <button type="button" class="help-q" data-help="l8meeting.headlines" aria-label="About Headlines">?</button></h2>

    <!-- Structured headline items -->
    <div class="space-y-2 mb-3">
      <% (headlineItems || []).forEach(function(h) {
           const kindClass = h.kind === 'customer' ? 'bg-blue-100 text-blue-800' :
                             h.kind === 'employee' ? 'bg-purple-100 text-purple-800' :
                             'bg-gray-100 text-gray-700';
      %>
        <div class="border rounded p-3 flex items-start justify-between gap-3" data-headline-id="<%= h.id %>">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs px-2 py-0.5 rounded <%= kindClass %>"><%= h.kind %></span>
              <% if (h.authorName) { %><span class="text-xs text-gray-500"><%= h.authorName %></span><% } %>
            </div>
            <div class="text-sm"><%= h.body %></div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <% if (h.readAt) { %>
              <span class="text-xs px-2 py-1 text-emerald-700">✓ addressed</span>
            <% } else { %>
              <button class="text-xs px-2 py-1 bg-status-ontrack-soft text-status-ontrack rounded hover:opacity-80"
                      data-headline-done="<%= h.id %>">✓ Addressed</button>
            <% } %>
            <button class="text-xs px-2 py-1 bg-orgy-blue-soft rounded hover:bg-orgy-soft"
                    data-flag-headline="<%= h.id %>"
                    data-flag-title="<%= String(h.body || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;') %>">→ Issue</button>
          </div>
        </div>
      <% }); %>
      <% if ((headlineItems || []).length === 0) { %>
        <div class="text-sm text-gray-500 italic">No headlines yet.</div>
      <% } %>
    </div>

    <!-- Add headline -->
    <div id="headline-add-form" class="flex gap-2 mb-4">
      <select id="new-headline-kind" class="border rounded p-2 text-sm">
        <option value="customer">customer</option>
        <option value="employee">employee</option>
        <option value="other" selected>other</option>
      </select>
      <input id="new-headline-body" type="text" placeholder="Notable win or loss with a customer or team member..." class="flex-1 border rounded p-2 text-sm">
      <button id="add-headline" class="px-3 py-2 bg-orgy-blue text-white text-sm rounded hover:bg-orgy-blue-deep">Add</button>
    </div>

    <label class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Cascading preview (free text)</label>
    <textarea id="headlines-notes" class="w-full border rounded p-3 text-sm h-24" placeholder="Notable wins or losses with customers and team..."><%= meeting.headlines || '' %></textarea>
    <button data-save="headlines" class="mt-2 text-xs px-3 py-1 bg-gray-100 rounded hover:bg-gray-200">Save</button>
  </section>
