<!-- meeting section partial: todos -- verbatim extract from l8-leadership.ejs (Inc 1, additive). Props contract: src/shared/meeting-section-props.ts -->
  <section id="todos" class="mb-12">
    <h2 class="text-2xl font-extrabold tracking-tight text-gray-900 mb-3">5. To-Dos <span class="text-sm text-gray-400 font-normal">5 min &middot; 7-day commitments from prior meeting</span> <button type="button" class="help-q" data-help="l8meeting.todos" aria-label="About To-Dos">?</button></h2>
    <% if (!todos || todos.length === 0) { %>
      <div class="bg-gray-50 border rounded p-4 text-sm text-gray-600">No open to-dos.</div>
    <% } else { %>
      <ul class="space-y-1">
        <% todos.forEach(function(t) { %>
          <li class="flex items-center gap-3 border rounded p-2" data-todo-id="<%= t.id %>">
            <input type="checkbox" data-todo-toggle <%= t.doneAt ? 'checked' : '' %> class="w-4 h-4">
            <div class="flex-1">
              <div class="text-sm <%= t.doneAt ? 'line-through text-gray-400' : '' %>"><%= t.title %></div>
              <% if (t.description) { %>
                <div class="text-xs text-gray-600 mt-0.5 break-words"><%- renderDescription(t.description) %></div>
              <% } %>
              <div class="text-xs text-gray-500">
                <%= t.ownerName || t.ownerExternalId %>
                <% if (t.dueAt) { %> &middot; due <%= new Date(t.dueAt).toLocaleDateString() %><% } %>
              </div>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>

    <!-- New todo quick-add (collapsed behind a toggle so the section reads clean) -->
    <div class="mt-3">
    <button id="todo-add-toggle" type="button" class="text-xs px-3 py-1.5 bg-orgy-blue text-white rounded hover:bg-orgy-blue-deep">+ Add to-do</button>
    <div id="todo-add-form" class="hidden mt-3 space-y-2">
    <div class="grid grid-cols-12 gap-2">
      <input id="new-todo-title" type="text" placeholder="New to-do (assigned at this meeting)..." class="col-span-5 border rounded p-2 text-sm">
      <select id="new-todo-owner" class="col-span-3 border rounded p-2 text-sm" multiple size="3" title="Assign to one or more. Each person gets their own copy of this to-do.">
        <% (availableOwners || []).forEach(function(a) { %>
          <option value="<%= a.entityType %>:<%= a.externalId %>:<%= a.name || a.externalId %>"><%= a.name || a.externalId %><%= a.isAttendee ? '' : ' (not in room)' %></option>
        <% }); %>
      </select>
      <input id="new-todo-due" type="date" class="col-span-2 border rounded p-2 text-sm" title="due date (default: 7 days from today)">
      <select id="new-todo-priority" class="col-span-1 border rounded p-2 text-sm" title="priority">
        <option value="p1">P1</option>
        <option value="p2">P2</option>
        <option value="p3" selected>P3</option>
        <option value="p4">P4</option>
      </select>
      <select id="new-todo-recur" class="col-span-1 border rounded p-2 text-sm" title="recurrence">
        <option value="">no repeat</option>
        <option value="FREQ=DAILY">daily</option>
        <option value="FREQ=WEEKLY">weekly</option>
        <option value="FREQ=WEEKLY;BYDAY=MO,WE,FR">M/W/F</option>
        <option value="FREQ=MONTHLY">monthly</option>
      </select>
      <button id="add-todo" class="col-span-12 px-3 py-2 bg-orgy-blue text-white text-sm rounded hover:bg-orgy-blue-deep">Add</button>
    </div>
    <div>
      <%- include('../partials/rich-description-editor', { targetId: 'new-todo-desc' }) %>
      <textarea id="new-todo-desc" rows="2" placeholder="Description (optional). Markdown: **bold**, *italic*, [link](https://...)" class="w-full border rounded p-2 text-sm"></textarea>
    </div>
    </div>
    </div>
  </section>
