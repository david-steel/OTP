<!-- Attachments UI: paperclip affordance for to-dos / issues / rocks.
     Drop a host element anywhere:
       div + data-att-host + data-att-type (todo|issue|rock) + data-att-id (uuid)
     then include this partial ONCE at the end of the page. The module
     batch-fetches counts, lazy-loads each list on expand, uploads via
     FileReader base64 (5 MB cap), unlinks, and -- on to-do hosts -- offers
     a "carry" picker that links the same blob onto an Issue or a Rock
     (second link row server-side; the file is never re-uploaded).
     All rendering uses textContent (no innerHTML with user data). -->
<style>
  [data-att-host] { margin-top: 4px; font-size: 12px; }
  .att-toggle { background: none; border: none; padding: 0; cursor: pointer; color: #6b7280; font-size: 12px; font-weight: 600; }
  .att-toggle:hover { color: #374151; text-decoration: underline; }
  .att-panel { margin-top: 4px; border: 1px solid #e5e7eb; border-radius: 6px; background: #fff; padding: 6px 8px; }
  .att-row { display: flex; align-items: center; gap: 8px; padding: 3px 0; flex-wrap: wrap; }
  .att-row + .att-row { border-top: 1px solid #f3f4f6; }
  .att-name { color: #1d4ed8; text-decoration: none; font-weight: 600; word-break: break-all; }
  .att-name:hover { text-decoration: underline; }
  .att-size { color: #9ca3af; }
  .att-act { background: none; border: none; padding: 0; cursor: pointer; font-size: 11px; font-weight: 600; }
  .att-carry { color: #6b46c1; }
  .att-carry:hover { text-decoration: underline; }
  .att-unlink { color: #dc2626; }
  .att-unlink:hover { text-decoration: underline; }
  .att-add { color: #6b46c1; font-weight: 600; background: none; border: none; padding: 2px 0; cursor: pointer; font-size: 12px; }
  .att-add:hover { text-decoration: underline; }
  .att-status { color: #6b7280; font-style: italic; }
  .att-error { color: #dc2626; }
  .att-picker { display: flex; gap: 6px; align-items: center; margin: 4px 0; flex-wrap: wrap; width: 100%; }
  .att-picker select { max-width: 240px; font-size: 12px; border: 1px solid #d1d5db; border-radius: 4px; padding: 2px 4px; }
  .att-picker button { font-size: 11px; font-weight: 600; border-radius: 4px; padding: 2px 8px; cursor: pointer; border: 1px solid #d1d5db; background: #fff; color: #374151; }
  .att-picker .att-picker-go { background: #6b46c1; color: #fff; border-color: #6b46c1; }
</style>
<script>
(function () {
  if (window.__otpAttachmentsInit) return;
  window.__otpAttachmentsInit = true;

  var MAX_BYTES = 5 * 1024 * 1024;
  var TYPE_LABELS = { todo: 'To-Do', issue: 'Issue', rock: 'Rock' };

  function attApi(method, path, body) {
    var opts = { method: method, headers: {}, credentials: 'same-origin' };
    if (body) {
      opts.headers['Content-Type'] = 'application/json';
      opts.body = JSON.stringify(body);
    }
    return fetch('/api/v1' + path, opts).then(function (r) {
      if (!r.ok) {
        return r.text().then(function (text) {
          var j = {};
          try { j = text ? JSON.parse(text) : {}; } catch (e) { /* non-JSON */ }
          var inner = j.error || {};
          throw { status: r.status, code: inner.code || 'API_ERROR', message: inner.message || ('HTTP ' + r.status) };
        });
      }
      return r.json();
    });
  }

  function fmtErr(err) {
    if (!err) return 'Unknown error';
    return (err.code ? err.code + ' — ' : '') + (err.message || 'Failed');
  }

  function fmtSize(bytes) {
    if (bytes >= 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    if (bytes >= 1024) return Math.round(bytes / 1024) + ' KB';
    return bytes + ' B';
  }

  function el(tag, cls, text) {
    var n = document.createElement(tag);
    if (cls) n.className = cls;
    if (text !== undefined) n.textContent = text;
    return n;
  }

  function setCount(host, n) {
    host.__attCount = n;
    var label = host.querySelector('.att-toggle');
    if (label) label.textContent = '📎 ' + (n > 0 ? n + ' attachment' + (n === 1 ? '' : 's') : 'Attach file');
  }

  function refreshList(host) {
    var type = host.getAttribute('data-att-type');
    var id = host.getAttribute('data-att-id');
    var list = host.querySelector('.att-list');
    if (!list) return;
    list.textContent = 'Loading…';
    list.className = 'att-list att-status';
    attApi('GET', '/attachments/by-entity?entityType=' + encodeURIComponent(type) + '&entityId=' + encodeURIComponent(id))
      .then(function (j) {
        var items = j.attachments || [];
        setCount(host, items.length);
        list.textContent = '';
        list.className = 'att-list';
        if (items.length === 0) {
          list.appendChild(el('div', 'att-status', 'No attachments yet.'));
          return;
        }
        items.forEach(function (a) {
          var row = el('div', 'att-row');
          var link = el('a', 'att-name', a.filename);
          link.href = '/api/v1/attachments/' + a.id + '/download';
          row.appendChild(link);
          row.appendChild(el('span', 'att-size', fmtSize(a.sizeBytes || 0)));
          if (type === 'todo') {
            ['issue', 'rock'].forEach(function (target) {
              var carry = el('button', 'att-act att-carry', '→ ' + TYPE_LABELS[target]);
              carry.type = 'button';
              carry.title = 'Link this file onto an existing ' + TYPE_LABELS[target] + ' (no re-upload)';
              carry.addEventListener('click', function () { openCarryPicker(host, row, a.id, target); });
              row.appendChild(carry);
            });
          }
          var unlink = el('button', 'att-act att-unlink', '× unlink');
          unlink.type = 'button';
          unlink.title = 'Remove this file from this ' + (TYPE_LABELS[type] || type) + '. If this is its last link, the file is deleted.';
          unlink.addEventListener('click', function () {
            if (!confirm('Remove "' + a.filename + '" from this ' + (TYPE_LABELS[type] || type) + '?')) return;
            attApi('DELETE', '/attachments/' + a.id + '/links', { entityType: type, entityId: id })
              .then(function () { refreshList(host); })
              .catch(function (e) { alert('Unlink failed: ' + fmtErr(e)); });
          });
          row.appendChild(unlink);
          list.appendChild(row);
        });
      })
      .catch(function (e) {
        list.textContent = 'Could not load attachments (' + fmtErr(e) + ')';
        list.className = 'att-list att-error';
      });
  }

  function openCarryPicker(host, row, attachmentId, targetType) {
    var existing = row.querySelector('.att-picker');
    if (existing) { existing.remove(); return; }
    var picker = el('div', 'att-picker');
    var select = document.createElement('select');
    select.appendChild(new Option('Loading ' + TYPE_LABELS[targetType].toLowerCase() + 's…', ''));
    var go = el('button', 'att-picker-go', 'Link');
    go.type = 'button';
    var cancel = el('button', '', 'Cancel');
    cancel.type = 'button';
    cancel.addEventListener('click', function () { picker.remove(); });
    picker.appendChild(select);
    picker.appendChild(go);
    picker.appendChild(cancel);
    row.appendChild(picker);

    var listPath = targetType === 'issue' ? '/tickets?status=open&limit=100' : '/rocks';
    attApi('GET', listPath)
      .then(function (j) {
        var options = [];
        if (targetType === 'issue') {
          (j.tickets || []).forEach(function (t) {
            if (t.idsStatus === 'solved') return;
            options.push({ id: t.id, label: t.title });
          });
        } else {
          (j.rocks || []).forEach(function (r) {
            if (r.completedAt || r.archivedAt) return;
            options.push({ id: r.id, label: r.title + (r.quarter ? ' (' + r.quarter + ')' : '') });
          });
        }
        select.textContent = '';
        if (options.length === 0) {
          select.appendChild(new Option('No open ' + TYPE_LABELS[targetType].toLowerCase() + 's found', ''));
          go.disabled = true;
          return;
        }
        select.appendChild(new Option('Choose ' + (targetType === 'issue' ? 'an issue' : 'a priority') + '…', ''));
        options.forEach(function (o) {
          var label = o.label.length > 80 ? o.label.slice(0, 77) + '…' : o.label;
          select.appendChild(new Option(label, o.id));
        });
      })
      .catch(function (e) {
        select.textContent = '';
        select.appendChild(new Option('Load failed: ' + fmtErr(e), ''));
        go.disabled = true;
      });

    go.addEventListener('click', function () {
      var entityId = select.value;
      if (!entityId) { alert('Pick a ' + TYPE_LABELS[targetType].toLowerCase() + ' first.'); return; }
      go.disabled = true;
      go.textContent = 'Linking…';
      attApi('POST', '/attachments/' + attachmentId + '/links', { entityType: targetType, entityId: entityId })
        .then(function (j) {
          picker.remove();
          var note = el('span', 'att-status', j.created === false ? 'Already linked.' : 'Linked ✓');
          row.appendChild(note);
          setTimeout(function () { note.remove(); }, 3000);
        })
        .catch(function (e) {
          go.disabled = false;
          go.textContent = 'Link';
          alert('Link failed: ' + fmtErr(e));
        });
    });
  }

  function uploadFile(host, file) {
    var type = host.getAttribute('data-att-type');
    var id = host.getAttribute('data-att-id');
    var status = host.querySelector('.att-upload-status');
    if (file.size > MAX_BYTES) {
      status.textContent = '"' + file.name + '" is ' + fmtSize(file.size) + ' — the limit is 5 MB.';
      status.className = 'att-upload-status att-error';
      return;
    }
    status.textContent = 'Uploading ' + file.name + '…';
    status.className = 'att-upload-status att-status';
    var reader = new FileReader();
    reader.onerror = function () {
      status.textContent = 'Could not read the file.';
      status.className = 'att-upload-status att-error';
    };
    reader.onload = function () {
      var dataUrl = String(reader.result || '');
      var base64 = dataUrl.indexOf(',') >= 0 ? dataUrl.slice(dataUrl.indexOf(',') + 1) : dataUrl;
      attApi('POST', '/attachments', {
        filename: file.name,
        mimeType: file.type || 'application/octet-stream',
        dataBase64: base64,
        link: { entityType: type, entityId: id },
      })
        .then(function () {
          status.textContent = '';
          refreshList(host);
        })
        .catch(function (e) {
          status.textContent = 'Upload failed: ' + (e.status === 413 ? 'file is over the 5 MB limit.' : fmtErr(e));
          status.className = 'att-upload-status att-error';
        });
    };
    reader.readAsDataURL(file);
  }

  // Promise-based upload for other page scripts (e.g. the quick-add form
  // stages files before the entity exists, then uploads against the new id).
  function uploadTo(entityType, entityId, file) {
    return new Promise(function (resolve, reject) {
      if (file.size > MAX_BYTES) {
        reject({ code: 'TOO_LARGE', message: '"' + file.name + '" is ' + fmtSize(file.size) + ', over the 5 MB limit.' });
        return;
      }
      var reader = new FileReader();
      reader.onerror = function () { reject({ code: 'READ_ERROR', message: 'Could not read ' + file.name + '.' }); };
      reader.onload = function () {
        var dataUrl = String(reader.result || '');
        var base64 = dataUrl.indexOf(',') >= 0 ? dataUrl.slice(dataUrl.indexOf(',') + 1) : dataUrl;
        attApi('POST', '/attachments', {
          filename: file.name,
          mimeType: file.type || 'application/octet-stream',
          dataBase64: base64,
          link: { entityType: entityType, entityId: entityId },
        }).then(resolve, reject);
      };
      reader.readAsDataURL(file);
    });
  }
  window.OTPAttachments = { uploadTo: uploadTo };

  function initHost(host) {
    if (host.__attReady) return;
    host.__attReady = true;
    var toggle = el('button', 'att-toggle', '📎 Attach file');
    toggle.type = 'button';
    var panel = el('div', 'att-panel');
    panel.style.display = 'none';
    var list = el('div', 'att-list');
    var addBtn = el('button', 'att-add', '+ Attach file');
    addBtn.type = 'button';
    var input = document.createElement('input');
    input.type = 'file';
    input.style.display = 'none';
    var status = el('div', 'att-upload-status');
    addBtn.addEventListener('click', function () { input.click(); });
    input.addEventListener('change', function () {
      if (input.files && input.files[0]) uploadFile(host, input.files[0]);
      input.value = '';
    });
    toggle.addEventListener('click', function () {
      var open = panel.style.display !== 'none';
      panel.style.display = open ? 'none' : '';
      if (!open) refreshList(host);
    });
    panel.appendChild(list);
    panel.appendChild(addBtn);
    panel.appendChild(input);
    panel.appendChild(status);
    host.appendChild(toggle);
    host.appendChild(panel);
  }

  function init() {
    var hosts = Array.prototype.slice.call(document.querySelectorAll('[data-att-host]'));
    if (hosts.length === 0) return;
    hosts.forEach(initHost);
    // Batched count fetch per entity type so the paperclip badge shows
    // without one request per row.
    var byType = {};
    hosts.forEach(function (h) {
      var t = h.getAttribute('data-att-type');
      (byType[t] = byType[t] || []).push(h);
    });
    Object.keys(byType).forEach(function (t) {
      var group = byType[t];
      var ids = group.map(function (h) { return h.getAttribute('data-att-id'); }).filter(Boolean);
      if (ids.length === 0) return;
      attApi('GET', '/attachments/counts?entityType=' + encodeURIComponent(t) + '&entityIds=' + encodeURIComponent(ids.join(',')))
        .then(function (j) {
          var counts = j.counts || {};
          group.forEach(function (h) { setCount(h, counts[h.getAttribute('data-att-id')] || 0); });
        })
        .catch(function () { /* badge stays at default label */ });
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
