<%-
  /*
    Reusable Plan section card.
    Renders one section in the always-open card style used on both the
    /plan preview and /dashboard/oos-operating-plan tabbed view.

    Expects in scope:
      s          — section row from oos_operating_plan_sections
      sectionMeta — the full meta lookup with tagline + fields per section key

    All data-section-* attributes preserved so the existing edit JS
    (data-section-edit / -save / -cancel / -input / -row / -msg) keeps
    working without changes.
  */
%>
<% var meta = sectionMeta[s.sectionKey]; %>
<% var content = (s.contentJson && typeof s.contentJson === 'object') ? s.contentJson : {}; %>
<% var anyValue = meta && meta.fields ? meta.fields.some(function(f) { var v = content[f.key]; return v !== undefined && v !== null && String(v).trim() !== ''; }) : false; %>
<div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
  <div class="px-6 sm:px-7 py-5 border-b border-gray-100 flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-1"><%= s.title %></h3>
      <% if (meta) { %>
        <p class="text-sm text-gray-500 leading-relaxed"><%= meta.tagline %></p>
      <% } %>
    </div>
    <span class="text-[10px] uppercase tracking-[0.15em] text-gray-400 font-mono whitespace-nowrap mt-1.5"><%= s.sectionKey.replace(/_/g, ' ') %></span>
  </div>
  <div class="px-6 sm:px-7 py-5" data-section-row="<%= s.id %>">
    <div data-section-view>
      <% if (anyValue) { %>
        <dl class="space-y-3">
          <% meta.fields.forEach(function(f) { var v = content[f.key]; if (v !== undefined && v !== null && String(v).trim() !== '') { %>
            <div>
              <dt class="text-xs font-semibold text-gray-800"><%= f.label %></dt>
              <dd class="text-sm text-gray-700 mt-0.5 whitespace-pre-wrap"><%= String(v) %></dd>
            </div>
          <% } }) %>
        </dl>
      <% } else if (meta && meta.fields && meta.fields.length > 0) { %>
        <p class="text-xs text-gray-500 italic mb-2">No content yet. This section captures:</p>
        <ul class="text-xs text-gray-600 space-y-1 mb-2">
          <% meta.fields.forEach(function(f) { %>
            <li><strong class="text-gray-800"><%= f.label %>:</strong> <%= f.desc %></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="text-xs text-gray-400 italic">No content yet.</p>
      <% } %>
      <button class="mt-3 px-3 py-1.5 bg-otp-500 text-white rounded-lg text-xs hover:bg-otp-600 font-medium" data-section-edit="<%= s.id %>"><%= anyValue ? 'Edit' : 'Add content' %></button>
    </div>
    <div data-section-editor class="hidden space-y-3">
      <% if (meta && meta.fields) { meta.fields.forEach(function(f) { var v = content[f.key] !== undefined && content[f.key] !== null ? String(content[f.key]) : ''; %>
        <div>
          <label class="block text-xs font-semibold text-gray-800 mb-0.5"><%= f.label %></label>
          <p class="text-xs text-gray-500 mb-1.5"><%= f.desc %></p>
          <% if (f.multiline) { %>
            <textarea data-section-input="<%= s.id %>" data-field-key="<%= f.key %>" rows="3" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="<%= f.desc %>"><%= v %></textarea>
          <% } else { %>
            <input data-section-input="<%= s.id %>" data-field-key="<%= f.key %>" type="text" value="<%= v %>" class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-otp-500" placeholder="<%= f.desc %>">
          <% } %>
        </div>
      <% }) } %>
      <div class="flex items-center gap-2 pt-1">
        <button class="px-3 py-1.5 bg-otp-500 text-white rounded-lg text-xs hover:bg-otp-600 font-medium" data-section-save="<%= s.id %>">Save</button>
        <button class="px-3 py-1.5 bg-gray-100 text-gray-700 border rounded-lg text-xs hover:bg-gray-200" data-section-cancel="<%= s.id %>">Cancel</button>
        <span class="text-xs" data-section-msg="<%= s.id %>"></span>
      </div>
    </div>
  </div>
</div>
