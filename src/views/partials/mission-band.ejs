<%# Shared OTP mission band -- the company battle cry. Self-contained (.mzn-*)
    because the home-v8 hp-* classes are page-local. Include with
    <%- include('../partials/mission-band') %> at the close of marketing pages.
    Visible copy is the short clause; the full mission sentence lives in the footer. %>
<section class="mzn">
  <div class="mzn-glow" aria-hidden="true"></div>
  <div class="mzn-wrap">
    <span class="mzn-kicker"><span class="mzn-tick"></span>Our mission</span>
    <h2 class="mzn-line">Unlocking the potential in every person through the <span class="mzn-accent">partnership of people and&nbsp;AI</span>.</h2>
  </div>
</section>
<style>
  .mzn { position:relative; overflow:hidden; background:#f7f5ef; border-top:1px solid rgba(20,39,26,.07); border-bottom:1px solid rgba(20,39,26,.07); padding:108px 24px; }
  .mzn-glow { position:absolute; left:50%; top:46%; width:780px; height:540px; max-width:120vw; transform:translate(-50%,-50%); background:radial-gradient(closest-side, rgba(168,230,58,.15), rgba(168,230,58,0) 72%); pointer-events:none; }
  .mzn-wrap { position:relative; max-width:1000px; margin:0 auto; text-align:center; }
  .mzn-kicker { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; font-size:12px; letter-spacing:.16em; text-transform:uppercase; color:var(--ink-mute,#6b7280); display:inline-flex; align-items:center; gap:9px; margin-bottom:28px; }
  .mzn-tick { width:8px; height:8px; border-radius:50%; background:var(--orgy,#a8e63a); display:inline-block; }
  .mzn-line { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:800; letter-spacing:-0.028em; line-height:1.07; font-size:clamp(2.05rem,5vw,3.6rem); color:var(--ink,#14161c); margin:0 auto; max-width:18ch; text-wrap:balance; }
  .mzn-accent { color:var(--blue,#0d7df2); white-space:nowrap; }
  @media (max-width:900px){ .mzn-accent { white-space:normal; } .mzn-line{ max-width:16ch; } }
  @media (max-width:640px){ .mzn { padding:76px 20px; } .mzn-line{ max-width:none; } }
</style>
