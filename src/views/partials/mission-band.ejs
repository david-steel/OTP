<%# OTP mission band -- the company battle cry. Restrained: big medium-weight
    type, tight tracking, lots of white space, a single accent. Scoped .mzn-
    classes (home-v8 hp- classes are page-local). Include this partial at the
    close of marketing pages. Visible copy is the short clause; the full mission
    sentence lives in the footer. %>
<section class="mzn">
  <div class="mzn-wrap">
    <span class="mzn-kicker">our mission</span>
    <h2 class="mzn-line">Unlocking the potential in every person through the <span class="mzn-accent">partnership of people and AI</span>.</h2>
  </div>
</section>
<style>
  .mzn { background:#ffffff; padding:156px 24px; }
  .mzn-wrap { max-width:1080px; margin:0 auto; text-align:center; }
  .mzn-kicker { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:600; font-size:13px; letter-spacing:.02em; color:var(--ink-mute,#9aa0aa); display:block; margin-bottom:32px; }
  .mzn-line { font-family:'Schibsted Grotesk','Inter',sans-serif; font-weight:500; letter-spacing:-0.035em; line-height:1.07; font-size:clamp(2.3rem,5.6vw,4.25rem); color:var(--ink,#14161c); margin:0 auto; max-width:17ch; }
  .mzn-accent { color:var(--blue,#0d7df2); font-weight:500; }
  @media (max-width:640px){ .mzn { padding:100px 20px; } .mzn-line{ max-width:none; } }
</style>
