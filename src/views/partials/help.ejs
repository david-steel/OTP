<!-- OTP site-wide help popup system.
     Usage: <button type="button" class="help-q" data-help="KEY" aria-label="...">?</button>
     Add new topics by extending OTP_HELP below. -->

<style>
.help-q {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1px solid #9ca3af;
  background: transparent;
  color: #6b7280;
  font-size: 11px;
  font-weight: 700;
  line-height: 1;
  cursor: pointer;
  padding: 0;
  vertical-align: middle;
  transition: background 0.12s ease, color 0.12s ease, border-color 0.12s ease;
}
.help-q:hover {
  background: #e5e7eb;
  color: #374151;
  border-color: #6b7280;
}
</style>

<script>
(function () {
  if (window.OTP_HELP) return; // guard against double-initialization

  window.OTP_HELP = {
    'l8.cadence': {
      title: 'The meeting cadence',
      attribution: 'Modeled on EOS®. EOS® and Level 10 Meeting® are trademarks of EOS Worldwide, LLC.',
      html: '<p style="margin:0 0 12px;">Pick the type that matches the rhythm you are running:</p>' +
        '<ul style="list-style:none;padding:0;margin:0 0 14px;display:flex;flex-direction:column;gap:10px;">' +
          '<li><strong style="color:#16241b;">Weekly — Leadership &amp; Departmental.</strong> The 90-minute weekly meeting, same agenda every time: check-in, scorecard, quarterly priorities, headlines, to-dos, then solve issues.</li>' +
          '<li><strong style="color:#16241b;">Quarterly Session.</strong> Step back every 90 days: review the quarter, reset your Rocks, solve the bigger issues.</li>' +
          '<li><strong style="color:#16241b;">Annual Planning.</strong> Two days a year on vision and the year ahead.</li>' +
          '<li><strong style="color:#16241b;">Same Page / One-on-One.</strong> Keep leaders aligned between the bigger sessions.</li>' +
        '</ul>' +
        '<p style="margin:0 0 16px;color:#5d6b60;">New to the rhythm? A typical rollout runs an intro meeting → a focus day → two vision-building days, then settles into the weekly / quarterly / annual pulse above.</p>',
      link: { href: '/level-10-meetings', label: 'See the full agenda &amp; cadence →' }
    },

    'dashboard.meeting': {
      title: 'Meetings',
      html: '<p style="margin:0 0 12px;">Your next (or most recent) weekly meeting, with a badge showing whether it is upcoming, live, or completed — completed meetings also show the team\'s 1–10 rating.</p>' +
        '<p style="margin:0 0 16px;">The weekly meeting is where the whole system pays off: scorecard, priorities, headlines, to-dos, and issue-solving on one timed page. Click any meeting to open it.</p>',
      link: { href: '/l8', label: 'Open the meetings page →' }
    },

    'dashboard.headlines': {
      title: 'Headlines',
      html: '<p style="margin:0 0 12px;">A <strong style="color:#16241b;">headline</strong> is a short piece of customer or employee news — good or bad — worth sharing with the team.</p>' +
        '<p style="margin:0 0 16px;">Headlines collect here during the week, then get read out in the weekly meeting, where each one is marked addressed or converted into an issue. The badge shows how many you haven\'t read yet.</p>'
    },

    'dashboard.rocks': {
      title: 'Quarterly Priorities (Rocks)',
      html: '<p style="margin:0 0 12px;">A <strong style="color:#16241b;">Rock</strong> is a big goal you commit to finishing in the next ~90 days. A company only carries a few at a time.</p>' +
        '<p style="margin:0 0 16px;">This panel shows your Rocks for the current quarter and whether each is on track or off track. You review and update them in section 3 of the weekly meeting — anything off track becomes discussion material.</p>'
    },

    'dashboard.todos': {
      title: 'My To-Dos',
      html: '<p style="margin:0 0 12px;">A <strong style="color:#16241b;">to-do</strong> is a small action item due within about 7 days, owned by one person.</p>' +
        '<p style="margin:0 0 16px;">Add one in the quick-add box — you can delegate it to a teammate, set a due date, make it repeat, and tie it to a team. Check it off when done; delegated items come back to you for verification.</p>',
      link: { href: '/me/todos', label: 'Open your full to-do queue →' }
    },

    'dashboard.kpis': {
      title: 'My KPIs',
      html: '<p style="margin:0 0 12px;">A <strong style="color:#16241b;">KPI</strong> is a number a seat watches — the handful of measurables that tell you the business is healthy, reviewed weekly on the scorecard.</p>' +
        '<p style="margin:0 0 16px;">This panel shows the KPIs you own, with the latest value against its goal: green means met, red means missed.</p>',
      link: { href: '/dashboard/kpis', label: 'Open the full scoreboard →' }
    },

    'dashboard.issues': {
      title: 'Issues (IDS)',
      html: '<p style="margin:0 0 12px;">An <strong style="color:#16241b;">issue</strong> is anything that needs to be worked through as a team. OTP works each one in three steps: <strong style="color:#16241b;">I</strong>dentify, <strong style="color:#16241b;">D</strong>iscuss, <strong style="color:#16241b;">S</strong>olve.</p>' +
        '<p style="margin:0 0 16px;">This panel shows open issues you own or that need attention. Most issue-solving happens live in the weekly meeting — raising an issue here is how you get it on that agenda.</p>',
      link: { href: '/dashboard/ids', label: 'See all issues across teams →' }
    },

    'dashboard.agents': {
      title: 'My Agents',
      html: '<p style="margin:0 0 12px;">An <strong style="color:#16241b;">agent</strong> is an AI tool with a real seat on your org chart — it has an owner, a job, and accountability like anyone else.</p>' +
        '<p style="margin:0 0 16px;">This panel shows the agent seats you own, their average maturity score out of 8, and red/yellow flags for the ones that need attention.</p>',
      link: { href: '/dashboard/team', label: 'See them on the org chart →' }
    },

    'dashboard.insights': {
      title: 'OTP Insights',
      html: '<p style="margin:0 0 16px;">Diagnostics OTP computes from your operating data: what you\'re waiting on others for, how much of the company still routes through the founder, where accountability is missing, and what could be handed off. Worth expanding once a week — these are the early warnings.</p>'
    },

    'dashboard.waiting': {
      title: 'Waiting on others',
      html: '<p style="margin:0 0 16px;">To-dos you delegated that are still open — who owns each one and the date they promised. When an item is finished it moves to your verification queue so nothing closes without your sign-off.</p>'
    },

    'dashboard.founderDependency': {
      title: 'Founder Dependency',
      html: '<p style="margin:0 0 12px;">The percentage of all open work — Rocks, KPIs, issues, to-dos — sitting on the top seat of the chart.</p>' +
        '<p style="margin:0 0 16px;">Under 50% shows green (healthy). At 50% or above it turns amber: too much of the company runs through one person, and it\'s time to absorb more onto the team.</p>'
    },

    'dashboard.accountabilityGaps': {
      title: 'Accountability Gaps',
      html: '<p style="margin:0 0 12px;">A reconciliation between your org chart and your actual work. It flags three gaps: seats with no measurable, work items with no seat, and agents with no human owner.</p>' +
        '<p style="margin:0 0 16px;">The goal is a clean check: every seat has a measurable, every item has a seat.</p>'
    },

    'dashboard.handoff': {
      title: 'Hand-off candidates',
      html: '<p style="margin:0 0 16px;">People carrying a heavy recurring load. For each, you\'ll see how many recurring items they hold and the oldest one with how long they\'ve carried it — a signal to move it to a lower seat or hand it to an agent.</p>'
    },

    'dashboard.cascade': {
      title: 'Cascading message',
      html: '<p style="margin:0 0 16px;">A short summary written in the Conclude step of the weekly meeting, set by the meeting leader, meant to be passed down to the wider team so everyone hears the same message.</p>'
    },

    'l8meeting.driving': {
      title: 'Driving toward',
      html: '<p style="margin:0 0 16px;">The long-term direction from your Operating Plan — the 3–5 year target, 10-year vision, and this year\'s objective — pinned above the meeting so every weekly decision gets made against it.</p>',
      link: { href: '/dashboard/oos-operating-plan', label: 'Open the Operating Plan →' }
    },

    'l8meeting.calendar': {
      title: 'Add to calendar',
      html: '<p style="margin:0 0 16px;">OTP doesn\'t send calendar invites. Create the recurring invite yourself in Google Calendar or Outlook — set the recurrence and attendees there — then paste the block below into it. The link brings every attendee back to this meeting page.</p>'
    },

    'l8meeting.attendees': {
      title: 'Attendees &amp; Access',
      html: '<p style="margin:0 0 12px;">Who\'s in this meeting — humans in blue, AI agents in purple. Click <strong style="color:#16241b;">Edit</strong> to add or remove anyone.</p>' +
        '<p style="margin:0 0 16px;">The pulsing dot means someone else has this page open right now. Agents you add carry their numbers into the Agent Reports panel below.</p>'
    },

    'l8meeting.agentReports': {
      title: 'Agent Reports',
      html: '<p style="margin:0 0 16px;">What each AI seat carries into this meeting: the KPIs and priorities it owns. Review an agent\'s card the same way you\'d review a teammate\'s numbers — agents have seats and accountability like everyone else.</p>'
    },

    'l8meeting.checkin': {
      title: '1. Check-in',
      html: '<p style="margin:0 0 16px;">A quick round to warm up the room: each attendee shares one personal best and one business best from the week. Keep it moving — the point is presence, not discussion.</p>'
    },

    'l8meeting.scorecard': {
      title: '2. Scorecard',
      html: '<p style="margin:0 0 12px;">Read this week\'s numbers — no discussion. Each KPI shows green (met) or red (missed) against its goal. Anything off track gets dropped to the Issues list and solved there, not here.</p>' +
        '<p style="margin:0 0 16px;">Starting the meeting freezes the scorecard as the official record of where the week stood. <strong style="color:#16241b;">↻ Refresh</strong> pulls in numbers entered after the start.</p>'
    },

    'l8meeting.rocks': {
      title: '3. Quarterly Priorities',
      html: '<p style="margin:0 0 12px;">The big bets for the quarter, each with an owner. Go around and toggle <strong style="color:#16241b;">On Track</strong> or <strong style="color:#16241b;">Off Track</strong> — off-track ones become Issues to solve in section 6.</p>' +
        '<p style="margin:0 0 16px;">This list stays live during the meeting, so edits show for everyone immediately.</p>'
    },

    'l8meeting.headlines': {
      title: '4. Customer &amp; Employee Headlines',
      html: '<p style="margin:0 0 16px;">Short customer and employee news, good or bad. Read them out, mark each one <strong style="color:#16241b;">Addressed</strong>, or convert it to an Issue if it needs real discussion. The cascading preview below drafts the message you\'ll confirm at Conclude.</p>'
    },

    'l8meeting.todos': {
      title: '5. To-Dos',
      html: '<p style="margin:0 0 16px;">Last meeting\'s 7-day commitments. Check off what got done — the done-rate is the team\'s discipline metric. Anything stuck or carried twice becomes an Issue. Quick-add new to-dos as they come up.</p>'
    },

    'l8meeting.ids': {
      title: '6. Issues (IDS)',
      html: '<p style="margin:0 0 12px;">The core of the meeting — 60 of the 90 minutes. Work the list top-down, one issue at a time: <strong style="color:#16241b;">I</strong>dentify the real issue, <strong style="color:#16241b;">D</strong>iscuss it once, <strong style="color:#16241b;">S</strong>olve it with an owner and a to-do.</p>' +
        '<p style="margin:0 0 16px;">Solving prompts for a resolution note so the decision is on record. Solved means solved — don\'t relitigate next week.</p>'
    },

    'l8meeting.conclude': {
      title: '7. Conclude',
      html: '<p style="margin:0 0 16px;">Wrap in five minutes: recap the to-dos created today, confirm the cascading message for the wider team, and have each attendee rate the meeting 1–10. Aim for an 8+ average — a consistently low score is itself an issue for next week\'s list.</p>'
    },

    'page.todos': {
      title: 'Your to-do queue',
      html: '<p style="margin:0 0 12px;">Every open to-do you own, in one mobile-friendly queue — a <strong style="color:#16241b;">to-do</strong> is a small action item due within about 7 days, owned by one person.</p>' +
        '<p style="margin:0 0 16px;">Create at the top (priority, due date, delegate, repeat, attach to a meeting), mark Done, or send one to the weekly meeting with <strong style="color:#16241b;">→ L10</strong>. Items you delegated sit under Waiting on others until they\'re finished.</p>'
    },

    'page.todosVerify': {
      title: 'Verify these happened',
      html: '<p style="margin:0 0 16px;">To-dos you delegated that the owner marked done. Nothing you hand off closes silently — you confirm each one with <strong style="color:#16241b;">Verify</strong>, or <strong style="color:#16241b;">Reopen</strong> it if it isn\'t actually finished.</p>'
    },

    'page.kpis': {
      title: 'The Scoreboard',
      html: '<p style="margin:0 0 12px;">Every measurable number in the company, organized by the seat that owns it. A <strong style="color:#16241b;">KPI</strong> is a number a seat watches — reviewed weekly so problems show up in the data before they show up in the bank account.</p>' +
        '<p style="margin:0 0 16px;">Switch views with the tabs (Trends shows sparklines; Weekly through Annual show period grids). Type actual values straight into the period cells — green means the goal was met, red means it was missed.</p>'
    },

    'page.ids': {
      title: 'Issues — admin view',
      html: '<p style="margin:0 0 12px;">The bird\'s-eye list of every open issue across all teams — for leaders managing more than one team. An <strong style="color:#16241b;">issue</strong> is anything the team needs to work through: Identify, Discuss, Solve.</p>' +
        '<p style="margin:0 0 16px;">Filter by team or IDS status, and use the per-row mover to hand an issue to a different team. The actual solving happens inside each team\'s weekly meeting.</p>'
    },

    'page.orgChart': {
      title: 'The org chart',
      html: '<p style="margin:0 0 12px;">Your whole organization — humans and AI agents — and who reports to whom. Every <strong style="color:#16241b;">seat</strong> has an owner, responsibilities, and accountability, whether the seat is filled by a person or an agent.</p>' +
        '<p style="margin:0 0 16px;">Click a tile to edit a seat, add humans or agents, or invite by email. Edits save to a <strong style="color:#16241b;">draft</strong> until you click Publish — publishing turns the chart into your OOS, the coordination file your agents read.</p>'
    },

    'page.peopleReview': {
      title: 'People Review',
      html: '<p style="margin:0 0 12px;">Rate each direct report on <strong style="color:#16241b;">seat fit</strong> — Gets it, Wants it, Capacity to do it — plus each of your core values. Click a cell to cycle its rating.</p>' +
        '<p style="margin:0 0 16px;">The computed verdict (Solid / Needs conversation / Wrong seat) tells you whether you have the right person in the right seat — the conversation starter, not the conclusion.</p>'
    },

    'page.members': {
      title: 'Members &amp; access',
      html: '<p style="margin:0 0 16px;">Who can sign in to this organization and what each person can see and do. Invite by email with a role (Owner and Admin down to Observer and Free), assign teams, and fine-tune Feature / Data / Agent access. You can edit, resend, or revoke any invite.</p>'
    },

    'page.teams': {
      title: 'Teams',
      html: '<p style="margin:0 0 16px;">Sub-teams let you scope meetings, issues, and KPIs to a group instead of the whole company — each team gets its own weekly meeting and its own scoreboard. Create one, then add the members who belong on it.</p>'
    },

    'page.sourceDocs': {
      title: 'Source Documents',
      html: '<p style="margin:0 0 16px;">Upload your raw operating docs — a playbook, SOPs, a CLAUDE.md — and OTP extracts the coordination intelligence into OOS files your agents can read. Upload or paste, click Process, then open the generated OOS.</p>'
    },

    'page.operatingPlan': {
      title: 'The Operating Plan',
      html: '<p style="margin:0 0 12px;">A guided business-planning workspace: vision, market, annual game plan, and a 90-day execution engine. It turns strategy into an owned, dated execution list — and into OOS claims your agents read.</p>' +
        '<p style="margin:0 0 16px;">Fill in the sections, generate the 90-day plan, and (as an admin) push it to your OOS. The glossary at the top defines every term on this page.</p>'
    },

    'page.ceo': {
      title: 'The CEO view',
      html: '<p style="margin:0 0 16px;">The whole company on one screen: long-term direction, scoreboard health, this quarter\'s execution, and the team — driven entirely by your Operating Plan. The attention badge counts what\'s off track right now.</p>',
      link: { href: '/dashboard/oos-operating-plan', label: 'Open the Operating Plan →' }
    },

    'page.claims': {
      title: 'Coordination knowledge',
      html: '<p style="margin:0 0 12px;">A public, browse-by-topic index of coordination knowledge published by organizations on OTP. A <strong style="color:#16241b;">claim</strong> is one coordination rule — the rule, why it matters, and its failure mode — tagged with confidence and evidence.</p>' +
        '<p style="margin:0 0 16px;">Click a section to read its claims. Publishing your own OOS adds your organization\'s learnings to the network.</p>'
    },

    'page.graph': {
      title: 'The Intelligence Graph',
      html: '<p style="margin:0 0 16px;">An interactive map of how organizations connect through shared patterns and best practices. Switch modes to explore Intelligence, Infrastructure, or Best Practices — in Best Practices mode you can ingest a practice into your own org as a claim. Click any node for detail.</p>'
    },

    'settings.profile': {
      title: 'Profile',
      html: '<p style="margin:0 0 16px;">Your personal info for this organization: pronouns, title, bio, work-style metrics (MBTI, Kolbe, CliftonStrengths), extra emails and phones, and LinkedIn. Teammates see this on your seat profile.</p>'
    },

    'settings.account': {
      title: 'Account',
      html: '<p style="margin:0 0 16px;">Your login identity — email, password, two-factor, and connected accounts. This is handled by Clerk, the sign-in provider, and follows you across every organization you belong to.</p>'
    },

    'settings.billing': {
      title: 'Billing',
      html: '<p style="margin:0 0 16px;">What your AI-agent team costs. Humans are always free; each active agent seat on your chart is billable. The page shows a monthly estimate based on your current chart.</p>'
    },

    'settings.integrations': {
      title: 'Integrations',
      html: '<p style="margin:0 0 16px;">Connect outside tools. API &amp; MCP access is live today — that\'s how your AI agents read and write OTP data. Slack, Google Workspace, and Microsoft 365 are on the way.</p>'
    },

    'settings.notifications': {
      title: 'Notifications',
      html: '<p style="margin:0 0 16px;">Which events reach you — assignments, comments, mentions, headlines — and on which channel. Each row is an event type; each column is a channel. Toggle the combinations you want.</p>'
    },

    'settings.preferences': {
      title: 'Preferences',
      html: '<p style="margin:0 0 16px;">Your personal defaults: theme, date format, default team, and timezone. These only affect how OTP looks and behaves for you, not for your organization.</p>'
    },

    'settings.api': {
      title: 'API Keys',
      html: '<p style="margin:0 0 12px;">Keys that let your AI agents connect to OTP. Click <strong style="color:#16241b;">Generate New Key</strong>, name it, and copy it immediately — it\'s shown only once. Revoke any key anytime.</p>' +
        '<p style="margin:0 0 16px;"><strong style="color:#16241b;">MCP</strong> (Model Context Protocol) is the standard that lets an agent talk to OTP safely — the page includes a copy-paste setup snippet for Claude Code. Read-only tools work without a key; publishing to your OOS requires one.</p>'
    },

    'settings.configuration': {
      title: 'Configuration',
      html: '<p style="margin:0 0 16px;">Company-level info: name, website, description, and whether to list your organization publicly. Only admins can edit this page.</p>'
    }
  };

  var _activeTrigger = null;

  function openHelp(key, triggerEl) {
    var entry = window.OTP_HELP[key];
    if (!entry) return;

    _activeTrigger = triggerEl || null;

    var ov = document.createElement('div');
    ov.id = 'otp-help-overlay';
    ov.style.cssText = 'position:fixed;inset:0;background:rgba(15,27,20,.55);display:flex;align-items:center;justify-content:center;z-index:9999;padding:16px;';

    var footerHtml = '<div style="display:flex;gap:10px;align-items:center;">';
    if (entry.link) {
      footerHtml += '<a href="' + entry.link.href + '" style="font-size:13px;font-weight:600;color:#0d7df2;text-decoration:none;">' + entry.link.label + '</a>';
    }
    footerHtml += '<button data-close style="margin-left:auto;padding:8px 14px;border:1px solid #d9e2da;background:#f7faf6;border-radius:8px;font-size:13px;font-weight:600;color:#16241b;cursor:pointer;">Got it</button>';
    footerHtml += '</div>';

    ov.innerHTML =
      '<div style="background:#fff;border-radius:12px;max-width:520px;width:100%;max-height:85vh;overflow:auto;padding:26px;font-family:Inter,system-ui,sans-serif;box-shadow:0 20px 60px rgba(0,0,0,.3);">' +
        '<div style="font-weight:800;font-size:19px;color:#16241b;margin-bottom:4px;">' + entry.title + '</div>' +
        (entry.attribution ? '<div style="font-size:11.5px;color:#8a8472;margin-bottom:16px;">' + entry.attribution + '</div>' : '') +
        '<div style="font-size:14px;color:#3a3a32;line-height:1.6;">' + entry.html + '</div>' +
        footerHtml +
      '</div>';

    document.body.appendChild(ov);

    ov.addEventListener('click', function (e) {
      if (e.target === ov || (e.target.closest && e.target.closest('[data-close]'))) {
        closeHelp();
      }
    });
  }

  function closeHelp() {
    var ov = document.getElementById('otp-help-overlay');
    if (ov) ov.remove();
    if (_activeTrigger) {
      _activeTrigger.focus();
      _activeTrigger = null;
    }
  }

  // Delegated listener for all [data-help] buttons on any page.
  document.addEventListener('click', function (e) {
    var btn = e.target.closest && e.target.closest('[data-help]');
    if (!btn) return;
    // Some triggers sit inside <summary> or <a> -- don't toggle/navigate.
    e.preventDefault();
    e.stopPropagation();
    var key = btn.getAttribute('data-help');
    if (key) openHelp(key, btn);
  });

  // Close on Escape.
  document.addEventListener('keydown', function (e) {
    if ((e.key === 'Escape' || e.keyCode === 27) && document.getElementById('otp-help-overlay')) {
      closeHelp();
    }
  });
})();
</script>
