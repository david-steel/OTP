# Copy this to .env and fill in real values
# cp .env.example .env

# Database
DATABASE_URL=postgresql://otp:otp@localhost:5432/otp

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Cloudflare R2 Storage
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=otp-oos-files

# App
NODE_ENV=development
PORT=3000

# Public read-only REST API at /api/v1/* (consumed by the OTP MCP server).
# Set to "true" to enable. Disabled by default for safety.
ENABLE_PUBLIC_API=false
